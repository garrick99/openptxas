.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    add.s32 %r22, %r3, %r3;
    max.s32 %r27, %r22, %r3;
    cvt.s64.s32 %rd13, %r22;
    sub.u32 %r6, %r27, %r3;
    shr.s32 %r18, %r27, 31;
    max.s32 %r8, %r6, %r3;
    shl.b64 %rd13, %rd7, 62;
    setp.eq.s32 %p1, %r3, 15;
    @%p1 or.b32 %r9, %r18, %r3;
    max.s32 %r20, %r8, 256;
    add.s32 %r17, %r22, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
