.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    and.b64 %rd10, %rd7, %rd7;
    max.s32 %r17, %r3, %r3;
    setp.ne.u32 %p3, %r3, 4294967295;
    @%p3 add.s32 %r5, %r3, 65535;
    mad.lo.u32 %r13, %r3, %r5, %r3;
    setp.eq.u32 %p3, %r3, %r3;
    and.b32 %r4, %r3, %r3;
    mul.wide.s32 %rd10, %r5, %r13;
    mul.lo.u32 %r19, %r3, 8;
    add.u32 %r6, %r19, %r3;
    sub.s32 %r13, %r19, %r4;
    and.b32 %r15, %r4, 4;
    cvt.s64.s32 %rd6, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
