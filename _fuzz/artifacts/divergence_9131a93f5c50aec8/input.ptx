.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r7, %r3, 5;
    shr.s32 %r26, %r3, 0;
    cvt.u64.u32 %rd9, %r26;
    min.s32 %r12, %r7, 4294967295;
    max.u32 %r16, %r12, 63;
    shr.s64 %rd13, %rd9, 31;
    mul.wide.s32 %rd10, %r7, %r7;
    or.b32 %r13, %r12, %r12;
    setp.le.s32 %p2, %r12, 4;
    mul.lo.s64 %rd7, %rd10, %rd13;
    sub.u32 %r24, %r16, %r13;
    selp.b32 %r19, %r3, %r7, %p2;
    mul.wide.u32 %rd8, %r26, %r16;
    mad.lo.s32 %r6, %r12, %r12, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
