.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r11, %r3, %r0;
    setp.lt.u32 %p1, %r11, %r11;
    vote.sync.ballot.b32 %r14, %p1, -1;
    shfl.sync.bfly.b32 %r10, %r11, 16, 0x1f, -1;
    setp.ge.u32 %p2, %r11, %r10;
    vote.sync.ballot.b32 %r8, %p2, -1;
    and.b32 %r15, %r0, %r14;
    shfl.sync.down.b32 %r7, %r3, 4, 0x1f, -1;
    vote.sync.all.pred %p3, %p2, -1;
    shfl.sync.bfly.b32 %r18, %r14, 2, 0x1f, -1;
    shfl.sync.bfly.b32 %r15, %r11, 8, 0x1f, -1;
    shfl.sync.idx.b32 %r11, %r7, 31, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
