.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r9, %r3, %r3, %r3;
    cvt.u64.u32 %rd15, %r3;
    min.u32 %r6, %r9, 65536;
    xor.b32 %r15, %r9, 0;
    min.u32 %r20, %r3, %r3;
    max.s32 %r20, %r20, %r20;
    cvt.s32.s64 %r13, %rd15;
    sub.u32 %r9, %r9, 1;
    add.s32 %r25, %r20, %r9;
    or.b32 %r4, %r15, 2;
    setp.ne.u32 %p2, %r9, %r15;
    @%p2 mad.lo.s32 %r19, %r3, %r4, %r20;
    shr.s32 %r9, %r4, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
