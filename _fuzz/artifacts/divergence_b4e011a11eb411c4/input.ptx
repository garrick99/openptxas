.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r9, %r3, 64;
    xor.b32 %r20, %r9, %r3;
    mul.wide.u32 %rd7, %r20, %r3;
    sub.s32 %r7, %r20, 1;
    setp.ne.s32 %p3, %r7, 15;
    @!%p3 selp.b32 %r13, %r9, %r9, %p3;
    or.b32 %r14, %r9, 1;
    min.u32 %r21, %r9, %r20;
    setp.ne.u32 %p4, %r14, %r21;
    @!%p4 sub.s32 %r21, %r14, %r9;
    mul.lo.s32 %r24, %r13, 31;
    add.u32 %r6, %r13, %r7;
    mul.wide.u32 %rd10, %r13, %r6;
    mad.lo.s32 %r16, %r24, %r14, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
