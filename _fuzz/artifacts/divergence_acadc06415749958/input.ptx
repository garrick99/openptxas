    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r22, %r3, %r3;
    shr.u32 %r27, %r22, 3;
    add.s32 %r9, %r3, %r22;
    mul.wide.s32 %rd10, %r3, %r3;
    add.s32 %r27, %r9, %r9;
    setp.gt.u32 %p3, %r27, 4294967295;
    selp.b32 %r10, %r9, %r3, %p3;
    max.u32 %r20, %r9, %r9;
    max.u32 %r9, %r10, %r9;
    selp.b32 %r18, %r9, %r20, %p3;
    sub.s32 %r11, %r20, %r27;
    max.u32 %r18, %r20, 1;
    xor.b32 %r10, %r18, %r27;
    max.u32 %r5, %r18, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
