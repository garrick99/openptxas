.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd6, %r3, %r3;
    min.u64 %rd10, %rd6, %rd6;
    max.u32 %r27, %r3, 32;
    shr.u32 %r6, %r3, 4;
    min.s32 %r15, %r27, 5;
    sub.s32 %r4, %r27, 8;
    cvt.u32.u64 %r10, %rd6;
    or.b64 %rd8, %rd10, %rd6;
    mul.wide.s32 %rd7, %r6, %r15;
    shl.b32 %r24, %r3, 15;
    min.u32 %r12, %r6, %r27;
    sub.s32 %r11, %r27, 65535;
    max.u32 %r22, %r11, %r24;
    min.u32 %r4, %r22, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
