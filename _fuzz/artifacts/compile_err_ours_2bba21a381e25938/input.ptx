    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.bfly.b32 %r11, %r3, 1, 0x1f, -1;
    shfl.sync.down.b32 %r6, %r11, 2, 0x1f, -1;
    shfl.sync.down.b32 %r11, %r0, 8, 0x1f, -1;
    setp.lt.u32 %p1, %r11, %r6;
    vote.sync.ballot.b32 %r6, %p1, -1;
    xor.b32 %r11, %r11, %r3;
    shfl.sync.idx.b32 %r7, %r11, 0, 0x1f, -1;
    vote.sync.any.pred %p1, %p1, -1;
    setp.gt.u32 %p1, %r0, 0;
    vote.sync.ballot.b32 %r4, %p1, -1;
    xor.b32 %r15, %r4, %r4;
    setp.eq.u32 %p3, %r6, 2147483647;
    vote.sync.ballot.b32 %r15, %p3, -1;
    ld.param.u64 %rd3, [p_out];
