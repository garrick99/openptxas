.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hi.u32 %p1, %r3, 255;
    shr.u32 %r16, %r3, 0;
    cvt.u64.u32 %rd8, %r3;
    shl.b32 %r8, %r3, 16;
    sub.u64 %rd8, %rd8, %rd8;
    add.s32 %r17, %r8, %r16;
    and.b32 %r13, %r16, %r8;
    shr.u64 %rd14, %rd8, 62;
    cvt.u64.u32 %rd5, %r8;
    or.b32 %r10, %r16, 1;
    cvt.s32.s64 %r25, %rd14;
    max.u32 %r5, %r17, %r16;
    add.u32 %r5, %r10, %r3;
    sub.s64 %rd10, %rd8, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
