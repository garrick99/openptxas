.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r15, %r3, 256;
    setp.lt.u32 %p2, %r3, 15;
    and.b32 %r11, %r15, %r3;
    sub.s32 %r13, %r11, %r15;
    shr.u32 %r27, %r13, 4;
    sub.s32 %r12, %r13, 15;
    setp.lt.s32 %p3, %r15, 15;
    @!%p3 cvt.s64.s32 %rd11, %r3;
    max.u32 %r5, %r13, %r11;
    cvt.u64.u32 %rd12, %r15;
    max.s32 %r19, %r13, %r3;
    min.u32 %r24, %r12, 65536;
    setp.lo.u32 %p3, %r13, %r24;
    @%p3 mul.lo.u32 %r8, %r12, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
