.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r22, %r3, %r3;
    cvt.s64.s32 %rd13, %r22;
    sub.u32 %r15, %r3, %r3;
    shl.b32 %r8, %r22, 4;
    setp.lt.s32 %p2, %r8, 63;
    @%p2 shl.b32 %r15, %r15, 3;
    mul.lo.u64 %rd15, %rd13, %rd13;
    mul.wide.s32 %rd9, %r3, %r15;
    and.b32 %r17, %r3, %r15;
    add.s64 %rd7, %rd15, %rd15;
    setp.gt.u32 %p3, %r15, %r15;
    setp.eq.u32 %p1, %r22, %r17;
    @!%p1 or.b32 %r5, %r15, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
