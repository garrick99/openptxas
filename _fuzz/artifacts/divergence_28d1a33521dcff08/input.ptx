.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r15, %r3, 255;
    sub.s32 %r4, %r15, 65535;
    mul.wide.u32 %rd10, %r3, %r15;
    cvt.u64.u32 %rd12, %r4;
    sub.u32 %r24, %r4, 2147483647;
    setp.gt.s32 %p3, %r4, %r15;
    cvt.u64.u32 %rd10, %r24;
    min.s32 %r14, %r15, 2;
    mad.lo.s32 %r13, %r14, %r4, %r15;
    cvt.u64.u32 %rd15, %r13;
    shr.s32 %r26, %r13, 3;
    cvt.u64.u32 %rd14, %r15;
    cvt.u32.u64 %r25, %rd12;
