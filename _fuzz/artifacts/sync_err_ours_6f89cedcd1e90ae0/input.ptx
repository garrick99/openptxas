.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    and.b64 %rd5, %rd14, %rd14;
    cvt.u32.u64 %r20, %rd5;
    cvt.s64.s32 %rd11, %r20;
    sub.s32 %r8, %r3, 2;
    sub.u32 %r10, %r20, %r20;
    cvt.s64.s32 %rd12, %r3;
    mul.lo.s64 %rd12, %rd5, %rd11;
    or.b64 %rd10, %rd14, %rd12;
    mad.lo.u32 %r11, %r8, %r3, %r8;
    mul.lo.u64 %rd10, %rd5, %rd10;
    mul.lo.s32 %r11, %r11, 7;
    shl.b32 %r7, %r11, 1;
    add.u32 %r19, %r7, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
