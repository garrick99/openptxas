.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r19, %r3, 0;
    mul.wide.u32 %rd10, %r19, %r3;
    cvt.s32.s64 %r23, %rd10;
    mad.lo.s32 %r15, %r3, %r23, %r23;
    setp.lt.u32 %p2, %r23, 16;
    @!%p2 shr.u32 %r7, %r23, 15;
    xor.b32 %r13, %r15, %r3;
    add.u32 %r8, %r15, %r23;
    min.u32 %r21, %r3, %r23;
    or.b32 %r25, %r3, 32;
    or.b64 %rd13, %rd10, %rd10;
    add.s32 %r14, %r8, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
