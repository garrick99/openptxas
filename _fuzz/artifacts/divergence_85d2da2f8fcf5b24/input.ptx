.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    shl.b64 %rd6, %rd14, 16;
    max.s32 %r26, %r3, %r3;
    min.u64 %rd6, %rd6, %rd6;
    sub.s32 %r14, %r26, 4294967295;
    cvt.s32.s64 %r10, %rd14;
    setp.ge.u32 %p2, %r26, %r3;
    setp.ge.s32 %p2, %r10, %r26;
    @!%p2 shl.b32 %r25, %r3, 3;
    setp.hi.u32 %p4, %r3, %r26;
    @!%p4 mad.lo.s32 %r26, %r26, %r14, %r14;
    cvt.u64.u32 %rd10, %r26;
    min.u32 %r10, %r10, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
