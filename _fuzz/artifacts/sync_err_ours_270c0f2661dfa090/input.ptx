.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r15, %r3, 32;
    min.s32 %r19, %r15, 0;
    cvt.u64.u32 %rd11, %r19;
    setp.le.u32 %p4, %r19, 255;
    and.b32 %r13, %r19, %r3;
    shl.b32 %r18, %r13, 30;
    or.b32 %r21, %r18, 1;
    mul.lo.u32 %r6, %r3, %r3;
    mul.lo.u32 %r20, %r3, 7;
    max.u64 %rd9, %rd11, %rd11;
    sub.u32 %r20, %r3, %r20;
    add.u32 %r8, %r13, %r6;
    shr.s32 %r11, %r6, 16;
    shr.s64 %rd8, %rd11, 47;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
