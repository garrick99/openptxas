.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p4, %r3, 31;
    setp.lt.s32 %p2, %r3, 65535;
    @!%p2 mul.lo.s32 %r22, %r3, 31;
    add.u32 %r26, %r3, 8;
    or.b32 %r6, %r3, 64;
    sub.s32 %r10, %r22, %r26;
    sub.u32 %r8, %r22, %r22;
    cvt.u64.u32 %rd10, %r6;
    add.s32 %r4, %r26, %r6;
    sub.s32 %r4, %r10, 63;
    mad.lo.s32 %r9, %r10, %r26, %r3;
    shl.b64 %rd15, %rd10, 63;
    mad.lo.s32 %r27, %r26, %r3, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
