.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r10, %r3, 32;
    xor.b32 %r7, %r3, 5;
    and.b32 %r13, %r7, 63;
    xor.b32 %r21, %r3, %r13;
    shl.b32 %r6, %r21, 3;
    mul.wide.s32 %rd10, %r10, %r10;
    mad.lo.s32 %r13, %r21, %r7, %r10;
    shr.u64 %rd8, %rd10, 7;
    mul.wide.u32 %rd7, %r10, %r7;
    sub.s32 %r14, %r21, %r7;
    mul.lo.u32 %r19, %r6, 16;
    setp.ge.s32 %p3, %r6, %r10;
    shr.s64 %rd11, %rd8, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
