.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    setp.ge.u32 %p3, %r3, 15;
    min.u32 %r26, %r3, 65535;
    max.s32 %r8, %r26, %r3;
    cvt.s64.s32 %rd13, %r8;
    cvt.s32.s64 %r5, %rd5;
    add.u32 %r24, %r8, 2;
    max.u32 %r25, %r24, %r5;
    cvt.u64.u32 %rd14, %r24;
    cvt.s32.s64 %r15, %rd5;
    shr.s32 %r23, %r24, 4;
    mad.lo.s32 %r25, %r26, %r26, %r26;
    mul.wide.u32 %rd12, %r25, %r26;
    mad.lo.u32 %r27, %r24, %r25, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
