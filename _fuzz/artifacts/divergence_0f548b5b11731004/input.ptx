.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p2, %r3, %r3;
    @%p2 mul.lo.u32 %r20, %r3, %r3;
    cvt.s64.s32 %rd15, %r20;
    max.s32 %r24, %r20, %r20;
    or.b32 %r9, %r24, %r3;
    mul.wide.s32 %rd6, %r24, %r9;
    selp.b32 %r23, %r24, %r9, %p2;
    sub.s32 %r13, %r3, %r9;
    shl.b64 %rd7, %rd15, 7;
    sub.u64 %rd13, %rd6, %rd6;
    max.u32 %r20, %r3, 32;
    mul.lo.u32 %r25, %r9, 4;
    mul.lo.s32 %r20, %r24, 4;
    max.u64 %rd6, %rd7, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
