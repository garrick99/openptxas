.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r19, %r3, %r3, %r3;
    mul.wide.u32 %rd13, %r3, %r19;
    setp.le.u32 %p2, %r19, 1;
    @%p2 mad.lo.s32 %r24, %r19, %r19, %r19;
    selp.b32 %r22, %r24, %r3, %p2;
    mul.wide.u32 %rd11, %r3, %r22;
    mul.wide.u32 %rd6, %r3, %r19;
    cvt.s64.s32 %rd10, %r19;
    max.u64 %rd15, %rd11, %rd6;
    setp.eq.u32 %p3, %r19, %r24;
    @%p3 max.s32 %r20, %r19, %r22;
    and.b32 %r4, %r19, %r3;
    selp.b32 %r21, %r4, %r24, %p2;
    shr.s64 %rd15, %rd11, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
