.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r25, %r3, 15;
    sub.s32 %r6, %r3, %r3;
    mul.lo.u32 %r8, %r6, 31;
    cvt.s64.s32 %rd9, %r8;
    sub.u32 %r15, %r3, %r25;
    max.s64 %rd6, %rd9, %rd9;
    min.u64 %rd5, %rd9, %rd6;
    shr.u64 %rd9, %rd5, 47;
    shr.s64 %rd14, %rd9, 1;
    mad.lo.s32 %r19, %r3, %r25, %r8;
    add.u64 %rd6, %rd5, %rd14;
    cvt.s64.s32 %rd10, %r8;
    setp.ne.s32 %p4, %r15, %r25;
    @%p4 mad.lo.s32 %r10, %r19, %r6, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
