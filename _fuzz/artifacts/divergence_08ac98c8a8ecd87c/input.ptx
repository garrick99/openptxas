.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r23, %r3, 8;
    setp.gt.u32 %p1, %r3, 2147483648;
    @%p1 mad.lo.s32 %r22, %r3, %r3, %r3;
    setp.eq.s32 %p3, %r23, %r3;
    @%p3 max.s32 %r8, %r3, 16;
    cvt.u64.u32 %rd13, %r23;
    add.u32 %r10, %r3, %r3;
    min.u32 %r19, %r23, 5;
    cvt.s32.s64 %r15, %rd13;
    mul.lo.s32 %r11, %r3, 65536;
    xor.b32 %r25, %r22, %r3;
    max.u32 %r17, %r11, %r19;
    add.s32 %r5, %r10, 8;
    add.s32 %r25, %r17, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
