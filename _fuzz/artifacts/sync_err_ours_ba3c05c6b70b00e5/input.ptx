.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    min.s32 %r18, %r3, 256;
    shl.b32 %r20, %r3, 7;
    max.s64 %rd7, %rd15, %rd15;
    cvt.u32.u64 %r21, %rd15;
    min.s32 %r27, %r20, %r21;
    cvt.u64.u32 %rd9, %r20;
    sub.s32 %r11, %r3, 31;
    setp.hi.u32 %p3, %r11, 0;
    mad.lo.u32 %r10, %r27, %r21, %r3;
    shr.s32 %r9, %r11, 7;
    and.b32 %r4, %r20, %r9;
    mul.lo.s32 %r21, %r21, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
