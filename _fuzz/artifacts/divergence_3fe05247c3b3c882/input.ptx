.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd11, %r3, %r3;
    shr.u32 %r11, %r3, 7;
    mul.lo.s32 %r15, %r3, %r11;
    xor.b32 %r24, %r15, 256;
    shl.b32 %r18, %r15, 2;
    sub.s32 %r15, %r24, %r3;
    mul.lo.s32 %r22, %r18, 64;
    shr.u64 %rd6, %rd11, 4;
    add.s32 %r22, %r3, %r11;
    cvt.u32.u64 %r18, %rd6;
    mad.lo.u32 %r8, %r15, %r22, %r3;
    shr.u64 %rd6, %rd6, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
