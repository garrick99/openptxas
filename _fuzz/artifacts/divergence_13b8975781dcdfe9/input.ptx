.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p4, %r3, %r3;
    mul.lo.u32 %r10, %r3, 32;
    cvt.s64.s32 %rd14, %r3;
    sub.u32 %r7, %r3, %r10;
    and.b32 %r12, %r10, %r10;
    mad.lo.u32 %r4, %r10, %r10, %r10;
    or.b64 %rd6, %rd14, %rd14;
    shr.s32 %r21, %r4, 3;
    mul.lo.s32 %r15, %r3, %r12;
    max.s32 %r11, %r15, 2147483647;
    xor.b32 %r27, %r21, %r12;
    add.s32 %r23, %r27, %r27;
    mul.lo.u32 %r18, %r27, 256;
    mul.lo.u32 %r19, %r4, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
