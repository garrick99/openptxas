.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r23, %r3, 16;
    max.s32 %r21, %r3, %r3;
    cvt.s64.s32 %rd13, %r3;
    shl.b64 %rd13, %rd13, 62;
    sub.s64 %rd5, %rd13, %rd13;
    mul.lo.s64 %rd8, %rd13, %rd5;
    xor.b64 %rd6, %rd8, %rd13;
    add.u32 %r9, %r3, %r21;
    shl.b32 %r8, %r3, 4;
    mul.wide.s32 %rd9, %r21, %r21;
    min.s32 %r14, %r23, 1;
    setp.hi.u32 %p4, %r3, 255;
    @!%p4 mad.lo.u32 %r10, %r21, %r14, %r9;
    shl.b32 %r6, %r14, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
