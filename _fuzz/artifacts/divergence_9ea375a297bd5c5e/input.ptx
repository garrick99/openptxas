.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r12, %r3, %r3, %r3;
    add.s32 %r4, %r3, 1;
    setp.le.s32 %p1, %r3, %r12;
    @%p1 mul.wide.u32 %rd5, %r12, %r12;
    mul.wide.u32 %rd13, %r12, %r12;
    xor.b32 %r11, %r12, %r4;
    mul.lo.u32 %r6, %r12, 4;
    shr.s32 %r26, %r12, 0;
    cvt.s32.s64 %r17, %rd13;
    mul.lo.s32 %r9, %r17, 2147483648;
    selp.b32 %r23, %r26, %r9, %p1;
    xor.b32 %r25, %r23, 2147483647;
    add.s32 %r19, %r3, 65535;
    mad.lo.s32 %r11, %r3, %r25, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
