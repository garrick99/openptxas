.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r25, %r3, 16;
    mad.lo.u32 %r8, %r3, %r25, %r3;
    cvt.s64.s32 %rd9, %r25;
    max.s64 %rd7, %rd9, %rd9;
    add.s64 %rd14, %rd9, %rd9;
    cvt.s32.s64 %r26, %rd14;
    or.b64 %rd10, %rd14, %rd9;
    mad.lo.u32 %r19, %r25, %r3, %r26;
    max.s32 %r4, %r19, %r19;
    add.u32 %r14, %r4, 4294967295;
    mul.lo.u64 %rd9, %rd10, %rd9;
    mad.lo.u32 %r5, %r3, %r19, %r19;
    setp.ge.s32 %p3, %r8, 16;
    @%p3 selp.b32 %r24, %r5, %r26, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
