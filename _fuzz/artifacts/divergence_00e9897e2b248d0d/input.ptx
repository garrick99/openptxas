.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r8, %r3, 3;
    setp.lt.s32 %p3, %r3, %r8;
    @%p3 add.s32 %r4, %r8, %r8;
    max.s32 %r8, %r8, %r4;
    max.u32 %r13, %r8, %r8;
    mul.wide.s32 %rd11, %r8, %r13;
    and.b64 %rd5, %rd11, %rd11;
    min.u64 %rd6, %rd5, %rd5;
    mul.wide.u32 %rd8, %r4, %r4;
    setp.lt.u32 %p2, %r13, 64;
    @!%p2 max.s64 %rd14, %rd11, %rd11;
    selp.b32 %r24, %r13, %r3, %p2;
    shr.u64 %rd14, %rd6, 63;
    shr.u64 %rd8, %rd8, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
