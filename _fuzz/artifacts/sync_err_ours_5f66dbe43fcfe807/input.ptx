.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    or.b32 %r22, %r3, %r3;
    mul.wide.u32 %rd7, %r22, %r22;
    cvt.s64.s32 %rd12, %r3;
    min.u32 %r21, %r3, %r22;
    shr.u32 %r6, %r22, 2;
    shr.s32 %r18, %r3, 1;
    sub.u32 %r21, %r3, %r22;
    cvt.u32.u64 %r4, %rd12;
    shr.s32 %r20, %r18, 3;
    sub.u32 %r9, %r18, %r21;
    shr.u32 %r25, %r6, 15;
    setp.lo.u32 %p2, %r4, 5;
    @%p2 shr.s32 %r24, %r4, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
