.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    mul.lo.u32 %r5, %r3, %r3;
    shr.u32 %r24, %r3, 1;
    add.s32 %r16, %r5, %r3;
    setp.eq.s32 %p3, %r3, %r16;
    cvt.u32.u64 %r4, %rd9;
    xor.b32 %r7, %r4, %r24;
    cvt.u64.u32 %rd8, %r5;
    mad.lo.s32 %r8, %r4, %r7, %r7;
    shr.s32 %r6, %r3, 1;
    min.s32 %r20, %r24, 4294967295;
    min.s32 %r24, %r8, %r16;
    mul.wide.s32 %rd8, %r6, %r24;
    selp.b32 %r7, %r8, %r24, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
