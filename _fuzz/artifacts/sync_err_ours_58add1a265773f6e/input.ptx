    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    shl.b64 %rd12, %rd5, 63;
    setp.ls.u32 %p4, %r3, 0;
    @!%p4 cvt.u32.u64 %r22, %rd5;
    sub.s64 %rd5, %rd5, %rd5;
    cvt.s32.s64 %r18, %rd5;
    sub.u32 %r15, %r22, 4294967295;
    mad.lo.u32 %r22, %r22, %r15, %r22;
    shr.s32 %r7, %r18, 3;
    add.s32 %r4, %r15, %r15;
    mul.lo.u32 %r9, %r4, 65536;
    cvt.u32.u64 %r22, %rd5;
    shr.u32 %r11, %r3, 30;
    cvt.s64.s32 %rd9, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
