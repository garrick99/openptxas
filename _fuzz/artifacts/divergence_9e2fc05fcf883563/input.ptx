.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r13, %r3, %r3;
    cvt.u64.u32 %rd5, %r13;
    mad.lo.u32 %r22, %r3, %r3, %r3;
    setp.le.u32 %p3, %r22, 0;
    @!%p3 cvt.s32.s64 %r16, %rd5;
    mul.lo.s64 %rd8, %rd5, %rd5;
    xor.b32 %r10, %r16, %r13;
    setp.ge.u32 %p2, %r10, 255;
    @%p2 max.u32 %r26, %r13, %r22;
    mul.lo.u32 %r17, %r22, 32;
    mul.wide.s32 %rd14, %r26, %r22;
    selp.b32 %r27, %r16, %r3, %p2;
    selp.b32 %r25, %r22, %r17, %p2;
    shr.s32 %r7, %r16, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
