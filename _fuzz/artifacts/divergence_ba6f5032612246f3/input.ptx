.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p2, %r3, 2147483648;
    @%p2 cvt.s64.s32 %rd14, %r3;
    min.u32 %r20, %r3, 255;
    mad.lo.s32 %r23, %r20, %r3, %r3;
    setp.ge.s32 %p2, %r23, %r23;
    mul.lo.u32 %r8, %r3, 8;
    max.s32 %r7, %r8, %r8;
    cvt.u32.u64 %r14, %rd14;
    mul.lo.u32 %r26, %r14, 16;
    mul.wide.s32 %rd7, %r23, %r26;
    max.u64 %rd8, %rd14, %rd7;
    cvt.s32.s64 %r27, %rd8;
    mad.lo.u32 %r12, %r8, %r7, %r26;
    add.u32 %r9, %r23, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
