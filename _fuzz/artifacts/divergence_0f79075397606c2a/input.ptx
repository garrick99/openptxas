.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r22, %r3, 31;
    sub.s32 %r6, %r3, %r3;
    cvt.s64.s32 %rd8, %r6;
    mul.wide.s32 %rd11, %r3, %r6;
    max.s32 %r21, %r6, %r22;
    mul.lo.u32 %r13, %r21, 4294967295;
    shr.u64 %rd14, %rd11, 47;
    or.b32 %r9, %r22, 3;
    sub.s32 %r21, %r13, 3;
    shl.b64 %rd7, %rd8, 31;
    mul.lo.s32 %r10, %r3, %r13;
    cvt.s64.s32 %rd6, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
