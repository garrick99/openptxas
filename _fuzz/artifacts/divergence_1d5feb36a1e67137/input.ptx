.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r22, %r3, %r3;
    setp.eq.u32 %p3, %r22, %r3;
    @%p3 mul.wide.s32 %rd9, %r22, %r22;
    and.b32 %r11, %r3, 5;
    cvt.s64.s32 %rd9, %r3;
    shl.b32 %r4, %r11, 3;
    setp.le.u32 %p3, %r22, 16;
    @%p3 min.s32 %r6, %r11, %r11;
    mul.lo.s64 %rd8, %rd9, %rd9;
    mul.lo.s32 %r19, %r11, %r6;
    and.b32 %r14, %r4, 7;
    add.u32 %r11, %r14, %r22;
    mad.lo.s32 %r15, %r22, %r4, %r19;
    shr.u64 %rd9, %rd9, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
