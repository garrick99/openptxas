.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r25, %r3, 0;
    max.u32 %r13, %r25, 16;
    mul.wide.u32 %rd14, %r3, %r3;
    mul.wide.u32 %rd6, %r13, %r3;
    shl.b64 %rd13, %rd6, 30;
    shl.b64 %rd10, %rd13, 32;
    add.s32 %r7, %r3, 2147483647;
    mad.lo.u32 %r22, %r3, %r25, %r7;
    min.u32 %r10, %r13, 4;
    xor.b32 %r17, %r10, %r10;
    mul.wide.s32 %rd15, %r3, %r7;
    mul.lo.u32 %r18, %r17, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
