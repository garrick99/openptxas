.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r13, %r3, %r3;
    add.s32 %r5, %r13, 16;
    sub.u32 %r22, %r5, %r5;
    sub.u32 %r21, %r3, 256;
    or.b32 %r13, %r22, %r5;
    setp.ge.u32 %p4, %r5, %r5;
    @%p4 xor.b32 %r14, %r22, %r5;
    mul.wide.u32 %rd9, %r13, %r3;
    selp.b32 %r12, %r22, %r14, %p4;
    sub.s32 %r10, %r3, 7;
    max.s32 %r19, %r14, 16;
    sub.u32 %r12, %r12, %r12;
    min.s32 %r9, %r21, %r3;
    sub.s32 %r22, %r3, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
