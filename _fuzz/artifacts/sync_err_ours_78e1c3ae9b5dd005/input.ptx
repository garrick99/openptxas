.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    mul.wide.u32 %rd6, %r3, %r3;
    cvt.s64.s32 %rd13, %r3;
    mul.lo.s32 %r8, %r3, %r3;
    mul.lo.u32 %r20, %r8, %r3;
    sub.s32 %r5, %r20, 0;
    cvt.s64.s32 %rd10, %r8;
    mul.wide.u32 %rd7, %r8, %r3;
    mad.lo.s32 %r27, %r5, %r5, %r5;
    shr.s64 %rd8, %rd7, 0;
    mul.wide.u32 %rd5, %r3, %r5;
    cvt.s64.s32 %rd12, %r27;
    max.s32 %r19, %r8, %r5;
    and.b64 %rd14, %rd5, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
