.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p3, %r3, %r3;
    @%p3 cvt.s64.s32 %rd14, %r3;
    shr.s32 %r25, %r3, 16;
    max.u32 %r15, %r25, %r25;
    mad.lo.u32 %r6, %r15, %r3, %r15;
    add.s32 %r19, %r15, 255;
    or.b64 %rd11, %rd14, %rd14;
    cvt.s64.s32 %rd13, %r3;
    shr.u64 %rd11, %rd13, 0;
    selp.b32 %r8, %r6, %r19, %p3;
    setp.gt.s32 %p1, %r19, %r3;
    @%p1 cvt.u64.u32 %rd7, %r3;
    selp.b32 %r17, %r6, %r15, %p3;
    setp.ge.s32 %p1, %r25, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
