.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r23, %r3, %r3, %r3;
    shl.b32 %r26, %r3, 16;
    mul.wide.u32 %rd5, %r26, %r3;
    mad.lo.u32 %r11, %r3, %r3, %r3;
    cvt.s32.s64 %r27, %rd5;
    add.u64 %rd11, %rd5, %rd5;
    mad.lo.u32 %r8, %r26, %r11, %r3;
    mul.wide.s32 %rd9, %r3, %r27;
    xor.b32 %r6, %r3, 4;
    shr.u32 %r5, %r6, 1;
    shr.s32 %r5, %r11, 30;
    min.s32 %r25, %r8, 8;
    cvt.s64.s32 %rd15, %r11;
    xor.b32 %r8, %r3, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
