.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r15, %r3, %r3;
    cvt.s64.s32 %rd15, %r3;
    and.b32 %r17, %r15, 255;
    min.u32 %r9, %r15, %r3;
    add.u32 %r10, %r9, %r9;
    add.s32 %r26, %r17, 64;
    mad.lo.u32 %r12, %r17, %r17, %r15;
    add.s64 %rd6, %rd15, %rd15;
    shr.s32 %r12, %r12, 31;
    min.s64 %rd9, %rd15, %rd15;
    shr.u32 %r16, %r10, 31;
    mad.lo.u32 %r10, %r12, %r9, %r10;
    min.u32 %r21, %r26, %r12;
    setp.eq.s32 %p1, %r12, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
