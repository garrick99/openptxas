.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p4, %r3, %r3;
    @!%p4 xor.b32 %r19, %r3, %r3;
    max.u32 %r26, %r19, 2;
    cvt.u64.u32 %rd15, %r3;
    sub.u32 %r24, %r26, 15;
    cvt.u64.u32 %rd12, %r19;
    add.s32 %r8, %r26, %r19;
    max.s64 %rd8, %rd15, %rd15;
    shl.b32 %r6, %r19, 15;
    cvt.s32.s64 %r11, %rd15;
    shr.s32 %r27, %r26, 2;
    shl.b32 %r13, %r19, 30;
    shl.b64 %rd8, %rd15, 48;
    xor.b64 %rd15, %rd12, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
