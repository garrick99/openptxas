.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r15, %r3, %r3;
    or.b32 %r7, %r3, 65535;
    setp.le.u32 %p3, %r15, %r3;
    shl.b32 %r22, %r7, 4;
    cvt.u64.u32 %rd8, %r3;
    cvt.s64.s32 %rd12, %r7;
    min.s64 %rd10, %rd12, %rd12;
    selp.b32 %r4, %r15, %r22, %p3;
    mul.wide.s32 %rd13, %r3, %r7;
    selp.b32 %r23, %r15, %r15, %p3;
    min.s32 %r8, %r22, %r4;
    mad.lo.s32 %r4, %r15, %r23, %r3;
    shl.b64 %rd13, %rd13, 30;
    max.u32 %r24, %r3, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
