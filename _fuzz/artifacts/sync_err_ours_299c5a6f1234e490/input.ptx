.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    mul.lo.s32 %r4, %r3, 2147483648;
    shl.b32 %r21, %r4, 1;
    min.s32 %r4, %r4, 256;
    min.s32 %r22, %r3, 32;
    shr.s32 %r6, %r22, 0;
    setp.le.u32 %p3, %r6, %r22;
    @%p3 cvt.s64.s32 %rd8, %r6;
    mul.lo.s64 %rd8, %rd14, %rd8;
    mul.lo.s32 %r20, %r21, 31;
    max.u32 %r9, %r3, %r20;
    mul.wide.u32 %rd6, %r6, %r22;
    mul.lo.s64 %rd13, %rd14, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
