.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r4, %r3, %r3;
    and.b32 %r15, %r3, 4294967295;
    max.u32 %r10, %r3, %r3;
    setp.eq.u32 %p4, %r3, %r15;
    @%p4 shl.b32 %r23, %r10, 0;
    and.b32 %r6, %r15, 4294967295;
    shr.s32 %r7, %r23, 30;
    selp.b32 %r19, %r6, %r3, %p4;
    shr.u32 %r12, %r19, 30;
    mul.lo.u32 %r6, %r12, 64;
    shr.u32 %r24, %r23, 31;
    add.u32 %r23, %r4, 7;
    xor.b32 %r27, %r24, %r12;
    min.u32 %r10, %r7, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
