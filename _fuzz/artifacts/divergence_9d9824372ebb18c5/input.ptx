.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r23, %r3, %r3, %r3;
    shl.b32 %r16, %r23, 15;
    max.s32 %r17, %r16, 15;
    mad.lo.s32 %r16, %r16, %r3, %r16;
    max.s32 %r9, %r23, %r23;
    cvt.u64.u32 %rd5, %r16;
    or.b64 %rd7, %rd5, %rd5;
    min.u32 %r11, %r23, %r3;
    max.s64 %rd5, %rd7, %rd5;
    cvt.s64.s32 %rd11, %r17;
    sub.s64 %rd6, %rd11, %rd5;
    sub.u32 %r25, %r17, %r16;
    shl.b32 %r21, %r25, 16;
    xor.b64 %rd13, %rd6, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
