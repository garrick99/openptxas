.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r24, %r3, %r3;
    xor.b32 %r20, %r24, 0;
    add.u32 %r22, %r3, 65535;
    mul.wide.s32 %rd6, %r24, %r20;
    cvt.u32.u64 %r8, %rd6;
    shr.u32 %r8, %r22, 1;
    mul.lo.s32 %r18, %r8, %r24;
    max.u32 %r5, %r20, %r8;
    setp.ge.s32 %p1, %r22, 255;
    @!%p1 cvt.s64.s32 %rd5, %r22;
    min.u32 %r13, %r8, %r20;
    setp.gt.s32 %p1, %r13, 65536;
    @!%p1 cvt.s32.s64 %r23, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
