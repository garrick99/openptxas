.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r6, %r3, 3;
    cvt.u64.u32 %rd14, %r3;
    shr.s64 %rd5, %rd14, 33;
    mad.lo.s32 %r10, %r3, %r3, %r6;
    shl.b32 %r13, %r10, 1;
    add.s32 %r22, %r10, %r6;
    mul.wide.s32 %rd9, %r13, %r3;
    and.b32 %r25, %r6, 8;
    add.s32 %r18, %r13, %r25;
    add.u32 %r22, %r10, 2;
    cvt.u64.u32 %rd8, %r6;
    setp.ne.u32 %p2, %r22, %r22;
    @%p2 sub.s32 %r17, %r25, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
