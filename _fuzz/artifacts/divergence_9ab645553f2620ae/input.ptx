.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd7, %r3, %r3;
    min.s64 %rd10, %rd7, %rd7;
    add.s32 %r21, %r3, 255;
    xor.b32 %r12, %r21, %r21;
    and.b64 %rd11, %rd10, %rd7;
    max.u32 %r10, %r12, %r21;
    mul.lo.s32 %r16, %r21, %r21;
    add.s32 %r13, %r16, %r16;
    or.b64 %rd7, %rd10, %rd10;
    shr.u32 %r8, %r10, 1;
    mul.lo.u32 %r19, %r3, %r12;
    mul.wide.u32 %rd9, %r21, %r10;
    add.s32 %r6, %r13, %r3;
    shr.u32 %r15, %r16, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
