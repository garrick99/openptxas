.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r15, %r3, 15;
    cvt.u64.u32 %rd7, %r15;
    sub.u64 %rd6, %rd7, %rd7;
    mad.lo.s32 %r13, %r15, %r15, %r15;
    shl.b32 %r11, %r3, 3;
    shl.b64 %rd9, %rd7, 63;
    sub.u32 %r23, %r13, %r13;
    cvt.u32.u64 %r11, %rd6;
    shl.b64 %rd11, %rd7, 0;
    shr.u64 %rd13, %rd9, 4;
    cvt.s32.s64 %r12, %rd11;
    mul.wide.s32 %rd12, %r23, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
