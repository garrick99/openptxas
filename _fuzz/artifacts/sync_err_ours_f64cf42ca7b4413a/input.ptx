.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r14, %r3, %r3;
    add.u32 %r4, %r14, 1;
    sub.u32 %r17, %r3, 256;
    add.u32 %r22, %r4, %r4;
    cvt.s64.s32 %rd15, %r22;
    setp.ls.u32 %p4, %r14, %r4;
    @%p4 shr.s32 %r12, %r14, 30;
    shl.b64 %rd9, %rd15, 1;
    setp.eq.s32 %p1, %r22, %r17;
    @!%p1 max.s32 %r13, %r4, %r3;
    or.b64 %rd13, %rd15, %rd9;
    setp.lt.s32 %p2, %r4, 8;
    @%p2 and.b32 %r9, %r12, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
