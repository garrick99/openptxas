.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r9, %r3, %r3;
    mul.wide.s32 %rd14, %r3, %r9;
    mad.lo.u32 %r8, %r3, %r3, %r9;
    shr.u64 %rd14, %rd14, 33;
    mul.lo.s32 %r9, %r3, %r9;
    sub.s64 %rd15, %rd14, %rd14;
    setp.le.s32 %p4, %r8, %r3;
    @!%p4 add.u32 %r20, %r3, 63;
    cvt.s64.s32 %rd5, %r9;
    shl.b32 %r14, %r20, 4;
    mad.lo.u32 %r20, %r14, %r9, %r20;
    mul.wide.u32 %rd14, %r20, %r8;
    shl.b32 %r25, %r14, 2;
    or.b64 %rd5, %rd14, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
