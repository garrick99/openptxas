.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.bfly.b32 %r9, %r0, 8, 0x1f, -1;
    shfl.sync.idx.b32 %r7, %r3, 7, 0x1f, -1;
    max.u32 %r19, %r0, %r7;
    and.b32 %r8, %r0, %r9;
    max.u32 %r7, %r9, %r3;
    shfl.sync.up.b32 %r10, %r19, 8, 0x1f, -1;
    sub.u32 %r14, %r19, %r3;
    setp.eq.u32 %p1, %r7, %r14;
    vote.sync.ballot.b32 %r13, %p1, -1;
    shfl.sync.idx.b32 %r14, %r13, 0, 0x1f, -1;
    setp.ne.u32 %p2, %r9, 3;
    vote.sync.ballot.b32 %r17, %p2, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
