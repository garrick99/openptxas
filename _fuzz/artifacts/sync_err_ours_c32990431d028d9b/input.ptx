.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r5, %r3, 64;
    mad.lo.u32 %r8, %r3, %r3, %r3;
    and.b32 %r6, %r3, 1;
    xor.b32 %r21, %r5, %r6;
    mul.wide.u32 %rd5, %r21, %r21;
    mad.lo.s32 %r24, %r3, %r6, %r8;
    cvt.u64.u32 %rd14, %r21;
    min.s32 %r15, %r24, %r21;
    add.s32 %r22, %r8, %r8;
    shr.u64 %rd10, %rd5, 7;
    shl.b32 %r19, %r22, 4;
    shl.b32 %r6, %r3, 3;
    setp.gt.u32 %p2, %r3, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
