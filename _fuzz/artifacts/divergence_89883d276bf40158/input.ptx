.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd9, %r3, %r3;
    mul.lo.s32 %r22, %r3, %r3;
    add.s32 %r24, %r3, 15;
    setp.eq.s32 %p3, %r3, %r22;
    @!%p3 max.s32 %r9, %r3, %r22;
    max.u64 %rd9, %rd9, %rd9;
    sub.u32 %r8, %r22, %r24;
    mul.wide.s32 %rd12, %r8, %r9;
    setp.eq.u32 %p1, %r24, %r9;
    sub.s64 %rd15, %rd9, %rd9;
    mul.wide.s32 %rd11, %r8, %r22;
    mul.lo.s32 %r10, %r8, 2147483648;
    sub.u32 %r18, %r8, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
