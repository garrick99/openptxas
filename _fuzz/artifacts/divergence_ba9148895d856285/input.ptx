.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r12, %r3, %r3;
    mul.wide.u32 %rd14, %r3, %r3;
    sub.u32 %r11, %r12, %r12;
    mad.lo.u32 %r22, %r12, %r3, %r12;
    shr.u64 %rd14, %rd14, 48;
    shr.u32 %r24, %r3, 0;
    add.u32 %r10, %r24, 4;
    cvt.u64.u32 %rd12, %r24;
    setp.eq.u32 %p2, %r10, %r22;
    cvt.s64.s32 %rd11, %r10;
    shr.u64 %rd10, %rd14, 16;
    min.s64 %rd6, %rd11, %rd11;
    mad.lo.u32 %r27, %r24, %r11, %r24;
    sub.s32 %r17, %r24, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
