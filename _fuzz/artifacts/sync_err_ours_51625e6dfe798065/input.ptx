.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r9, %r3, 16;
    sub.s32 %r14, %r3, 0;
    add.s32 %r21, %r3, %r3;
    or.b32 %r7, %r21, %r9;
    mad.lo.u32 %r10, %r14, %r14, %r9;
    cvt.u64.u32 %rd8, %r3;
    mul.lo.u32 %r16, %r3, 65536;
    max.s64 %rd15, %rd8, %rd8;
    mad.lo.s32 %r24, %r10, %r9, %r21;
    add.u64 %rd8, %rd8, %rd8;
    mul.lo.s32 %r14, %r3, %r21;
    setp.ls.u32 %p3, %r3, %r24;
    shr.u64 %rd8, %rd15, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
