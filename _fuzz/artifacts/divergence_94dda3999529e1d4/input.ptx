.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r8, %r3, 3;
    setp.ge.u32 %p1, %r8, 255;
    cvt.s64.s32 %rd11, %r3;
    cvt.s64.s32 %rd15, %r3;
    mul.lo.u64 %rd5, %rd11, %rd15;
    cvt.s64.s32 %rd9, %r3;
    shl.b64 %rd11, %rd11, 0;
    cvt.s32.s64 %r13, %rd15;
    add.s32 %r21, %r13, 64;
    cvt.s64.s32 %rd10, %r13;
    mad.lo.s32 %r20, %r13, %r8, %r8;
    mul.lo.s64 %rd15, %rd5, %rd10;
    shl.b32 %r27, %r20, 16;
    min.u32 %r11, %r3, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
