.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p2, %r3, 3;
    @%p2 shr.s32 %r9, %r3, 30;
    max.s32 %r7, %r3, 31;
    mul.lo.s32 %r19, %r9, 4294967295;
    selp.b32 %r18, %r7, %r9, %p2;
    add.u32 %r5, %r18, 15;
    and.b32 %r6, %r5, %r5;
    or.b32 %r6, %r6, %r6;
    cvt.s64.s32 %rd5, %r18;
    max.s32 %r5, %r18, %r3;
    cvt.u32.u64 %r12, %rd5;
    cvt.u64.u32 %rd6, %r6;
    cvt.u64.u32 %rd12, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
