.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p3, %r3, %r3;
    @%p3 cvt.u64.u32 %rd5, %r3;
    shl.b32 %r6, %r3, 2;
    mad.lo.u32 %r23, %r3, %r6, %r6;
    sub.s32 %r10, %r6, 15;
    max.s32 %r8, %r10, 65535;
    min.u32 %r7, %r23, %r23;
    mul.lo.s32 %r8, %r8, %r8;
    max.s64 %rd10, %rd5, %rd5;
    cvt.u32.u64 %r9, %rd10;
    mul.lo.s32 %r13, %r8, 3;
    max.s32 %r18, %r8, %r9;
    sub.s32 %r16, %r6, 7;
    max.u32 %r16, %r18, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
