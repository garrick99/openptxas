.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    cvt.s64.s32 %rd5, %r3;
    min.u64 %rd7, %rd5, %rd5;
    cvt.s64.s32 %rd7, %r3;
    setp.eq.s32 %p1, %r3, %r3;
    @%p1 add.s64 %rd7, %rd7, %rd5;
    add.u64 %rd5, %rd5, %rd7;
    sub.u32 %r13, %r3, 3;
    selp.b32 %r8, %r13, %r13, %p1;
    and.b32 %r18, %r13, 8;
    mul.lo.s32 %r27, %r3, 32;
    cvt.s64.s32 %rd5, %r18;
    sub.s64 %rd13, %rd5, %rd7;
    selp.b32 %r5, %r8, %r27, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
