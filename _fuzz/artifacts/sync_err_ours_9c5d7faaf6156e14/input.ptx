.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r11, %r3, %r3;
    cvt.s64.s32 %rd11, %r11;
    mul.lo.s32 %r17, %r3, 3;
    sub.u32 %r8, %r17, 4294967295;
    add.s32 %r20, %r11, 31;
    cvt.u64.u32 %rd12, %r8;
    cvt.u32.u64 %r18, %rd11;
    min.s32 %r22, %r8, 16;
    setp.lo.u32 %p4, %r3, %r18;
    max.u32 %r18, %r11, %r20;
    add.s32 %r20, %r18, 4;
    add.u64 %rd6, %rd12, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
