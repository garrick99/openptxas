.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r9, %r3, 2147483648;
    max.u32 %r16, %r9, 63;
    cvt.u64.u32 %rd6, %r3;
    and.b32 %r12, %r16, %r3;
    shr.s64 %rd10, %rd6, 1;
    shr.u64 %rd12, %rd6, 0;
    max.u32 %r19, %r12, %r9;
    setp.ge.s32 %p3, %r16, %r16;
    @!%p3 selp.b32 %r25, %r12, %r3, %p3;
    and.b32 %r27, %r9, 7;
    shr.s32 %r14, %r25, 31;
    cvt.s32.s64 %r23, %rd12;
    max.s32 %r17, %r25, %r27;
    max.u32 %r18, %r14, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
