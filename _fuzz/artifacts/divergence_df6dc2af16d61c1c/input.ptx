.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r19, %r3, %r3;
    and.b32 %r9, %r3, 2147483648;
    cvt.s64.s32 %rd8, %r3;
    setp.ls.u32 %p2, %r9, %r9;
    @!%p2 max.s32 %r11, %r9, 64;
    shr.u32 %r19, %r19, 30;
    shl.b64 %rd11, %rd8, 62;
    or.b32 %r10, %r19, 3;
    or.b32 %r4, %r3, %r3;
    cvt.s64.s32 %rd11, %r11;
    cvt.u32.u64 %r17, %rd11;
    cvt.s64.s32 %rd9, %r10;
    add.s32 %r26, %r9, 7;
    selp.b32 %r11, %r17, %r19, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
