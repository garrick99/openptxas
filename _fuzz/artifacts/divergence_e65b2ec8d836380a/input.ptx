.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r22, %r3, 15;
    mad.lo.s32 %r20, %r3, %r22, %r22;
    cvt.s64.s32 %rd7, %r20;
    cvt.u64.u32 %rd6, %r20;
    shr.s32 %r17, %r3, 31;
    max.u32 %r11, %r3, %r17;
    shr.s32 %r13, %r20, 31;
    shl.b32 %r16, %r17, 15;
    xor.b32 %r4, %r11, 3;
    mul.lo.s32 %r27, %r22, 4;
    mad.lo.u32 %r10, %r17, %r22, %r16;
    setp.ge.u32 %p4, %r20, %r3;
    @!%p4 mad.lo.u32 %r14, %r11, %r17, %r4;
    mad.lo.s32 %r14, %r14, %r16, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
