.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    mul.wide.u32 %rd14, %r3, %r3;
    mul.wide.s32 %rd7, %r3, %r3;
    mul.lo.u32 %r12, %r3, 3;
    add.s64 %rd8, %rd14, %rd14;
    min.u32 %r10, %r3, 65536;
    shl.b32 %r15, %r12, 2;
    min.s32 %r12, %r10, %r10;
    min.u32 %r23, %r10, %r3;
    sub.s64 %rd13, %rd8, %rd15;
    setp.le.s32 %p1, %r10, %r23;
    cvt.u32.u64 %r14, %rd15;
    max.u32 %r9, %r12, %r15;
    cvt.s32.s64 %r8, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
