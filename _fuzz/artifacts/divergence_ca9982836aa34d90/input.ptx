.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r21, %r3, 255;
    max.s32 %r7, %r3, 5;
    mul.wide.s32 %rd13, %r7, %r21;
    mad.lo.u32 %r7, %r7, %r3, %r21;
    or.b32 %r18, %r7, 8;
    add.s32 %r25, %r21, %r18;
    cvt.s32.s64 %r10, %rd13;
    mul.lo.s32 %r12, %r7, %r10;
    sub.s32 %r26, %r7, 1;
    sub.u32 %r4, %r26, %r10;
    add.s64 %rd13, %rd13, %rd13;
    add.s32 %r19, %r10, 64;
    max.s32 %r8, %r7, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
