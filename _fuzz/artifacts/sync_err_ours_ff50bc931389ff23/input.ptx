.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r24, %r3, %r3;
    cvt.u64.u32 %rd14, %r24;
    mul.wide.s32 %rd13, %r3, %r3;
    min.u32 %r18, %r3, 1;
    mul.lo.s32 %r26, %r24, %r3;
    mul.lo.s32 %r4, %r26, 31;
    shr.u64 %rd9, %rd13, 1;
    mul.wide.u32 %rd6, %r24, %r4;
    mad.lo.u32 %r19, %r3, %r26, %r26;
    shr.s32 %r5, %r24, 30;
    max.s32 %r20, %r19, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
