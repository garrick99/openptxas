.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r22, %r3, %r3;
    setp.lo.u32 %p4, %r22, 31;
    @!%p4 sub.s32 %r11, %r3, %r3;
    add.s32 %r26, %r11, %r22;
    sub.s32 %r8, %r26, 8;
    shr.s32 %r20, %r3, 16;
    sub.s32 %r27, %r22, %r8;
    cvt.s64.s32 %rd9, %r27;
    sub.s64 %rd10, %rd9, %rd9;
    and.b32 %r16, %r26, %r27;
    setp.eq.s32 %p2, %r26, 2;
    sub.u64 %rd13, %rd10, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
