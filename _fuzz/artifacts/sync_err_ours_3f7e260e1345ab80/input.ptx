.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd8, %r3, %r3;
    setp.lt.s32 %p1, %r3, 1;
    @%p1 sub.s32 %r7, %r3, %r3;
    and.b32 %r26, %r3, 15;
    sub.s32 %r22, %r26, %r26;
    mul.lo.u64 %rd11, %rd8, %rd8;
    mul.wide.s32 %rd11, %r3, %r26;
    shr.u32 %r8, %r22, 1;
    cvt.s64.s32 %rd5, %r3;
    shl.b32 %r25, %r22, 4;
    min.s64 %rd10, %rd8, %rd11;
    or.b32 %r10, %r25, 3;
    mul.lo.s32 %r12, %r22, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
