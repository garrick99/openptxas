.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r4, %r3, 4;
    cvt.u64.u32 %rd5, %r4;
    mad.lo.s32 %r19, %r4, %r3, %r3;
    shr.s32 %r14, %r4, 31;
    mul.lo.u32 %r23, %r3, 255;
    cvt.s32.s64 %r22, %rd5;
    setp.le.s32 %p1, %r3, %r19;
    sub.s32 %r21, %r3, 5;
    max.s32 %r12, %r14, %r14;
    xor.b32 %r25, %r23, %r21;
    mul.wide.s32 %rd10, %r4, %r4;
    cvt.u64.u32 %rd13, %r23;
    add.u32 %r23, %r14, %r25;
    min.u32 %r17, %r23, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
