.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r22, %r3, %r3;
    shr.s32 %r27, %r3, 31;
    cvt.u64.u32 %rd10, %r3;
    shr.u64 %rd15, %rd10, 30;
    and.b32 %r6, %r22, 8;
    cvt.s64.s32 %rd10, %r27;
    mad.lo.u32 %r17, %r6, %r22, %r22;
    mul.wide.u32 %rd12, %r3, %r27;
    or.b32 %r6, %r3, %r3;
    mul.wide.u32 %rd6, %r17, %r17;
    and.b32 %r15, %r17, %r3;
    mul.wide.u32 %rd12, %r22, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
