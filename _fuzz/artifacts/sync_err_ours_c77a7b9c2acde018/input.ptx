.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r25, %r3, 63;
    sub.s32 %r25, %r25, %r3;
    min.s32 %r10, %r25, %r25;
    mul.lo.s32 %r18, %r3, 2;
    sub.s32 %r21, %r3, %r18;
    setp.ge.s32 %p1, %r10, %r10;
    setp.ge.u32 %p4, %r3, %r21;
    or.b32 %r5, %r10, %r21;
    mul.wide.s32 %rd5, %r21, %r25;
    cvt.s64.s32 %rd15, %r3;
    shr.s64 %rd15, %rd5, 62;
    setp.ne.s32 %p3, %r10, 32;
    @%p3 xor.b32 %r27, %r10, 0;
    xor.b32 %r27, %r10, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
