.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r26, %r3, 2;
    min.u32 %r26, %r3, 64;
    cvt.s64.s32 %rd11, %r3;
    shl.b64 %rd9, %rd11, 16;
    cvt.s64.s32 %rd15, %r3;
    sub.u32 %r9, %r3, %r26;
    shl.b32 %r21, %r3, 2;
    mul.wide.u32 %rd5, %r9, %r21;
    mul.wide.s32 %rd9, %r3, %r26;
    add.u32 %r27, %r26, 31;
    min.u32 %r9, %r27, %r9;
    cvt.s64.s32 %rd11, %r9;
    setp.lo.u32 %p4, %r21, 256;
    @!%p4 mul.wide.s32 %rd13, %r3, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
