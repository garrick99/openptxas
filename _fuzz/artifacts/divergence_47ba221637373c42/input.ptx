.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r20, %r3, %r3, %r3;
    add.u32 %r4, %r20, %r20;
    sub.s32 %r5, %r20, 2;
    cvt.u64.u32 %rd11, %r3;
    shl.b32 %r18, %r4, 1;
    sub.s32 %r4, %r5, %r4;
    shr.u64 %rd5, %rd11, 0;
    sub.s32 %r26, %r4, %r4;
    cvt.s64.s32 %rd8, %r26;
    sub.s32 %r26, %r26, %r20;
    setp.ne.u32 %p1, %r5, %r26;
    setp.eq.u32 %p4, %r4, %r3;
    @%p4 shl.b32 %r10, %r20, 2;
    add.s64 %rd12, %rd5, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
