.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r20, %r3, %r3;
    add.u32 %r15, %r3, %r20;
    mad.lo.u32 %r27, %r3, %r3, %r3;
    setp.ge.s32 %p2, %r15, 64;
    @%p2 mul.wide.s32 %rd9, %r3, %r20;
    and.b32 %r8, %r3, 1;
    shr.u64 %rd8, %rd9, 16;
    mad.lo.u32 %r24, %r15, %r3, %r15;
    setp.ne.u32 %p3, %r8, 63;
    @%p3 add.s64 %rd8, %rd9, %rd8;
    and.b32 %r23, %r8, 8;
    mul.lo.u32 %r20, %r20, 65536;
    mul.wide.u32 %rd13, %r8, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
