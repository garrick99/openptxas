.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r18, %r3, %r3;
    xor.b32 %r25, %r3, %r3;
    min.s32 %r7, %r25, %r18;
    or.b32 %r10, %r3, 32;
    add.u32 %r17, %r7, %r25;
    shr.u32 %r19, %r17, 16;
    cvt.s64.s32 %rd6, %r7;
    shr.u64 %rd11, %rd6, 16;
    or.b32 %r20, %r19, %r25;
    setp.le.u32 %p1, %r10, 2147483647;
    @%p1 shr.u64 %rd6, %rd11, 2;
    setp.lo.u32 %p4, %r17, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
