.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p2, %r3, 63;
    @!%p2 mad.lo.s32 %r10, %r3, %r3, %r3;
    and.b32 %r26, %r3, 65535;
    mad.lo.s32 %r20, %r10, %r10, %r26;
    max.u32 %r21, %r10, %r3;
    add.u32 %r23, %r10, %r26;
    cvt.s64.s32 %rd5, %r20;
    shl.b32 %r7, %r23, 15;
    selp.b32 %r11, %r10, %r20, %p2;
    setp.le.s32 %p3, %r10, 16;
    shr.u32 %r26, %r7, 30;
    min.s32 %r17, %r21, %r7;
    min.s64 %rd14, %rd5, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
