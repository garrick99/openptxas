.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r26, %r3, %r3;
    sub.u32 %r14, %r3, 32;
    cvt.s64.s32 %rd15, %r26;
    setp.gt.s32 %p2, %r26, %r14;
    @!%p2 cvt.u32.u64 %r24, %rd15;
    xor.b32 %r16, %r24, %r14;
    cvt.s32.s64 %r16, %rd15;
    add.s32 %r16, %r14, %r14;
    xor.b32 %r17, %r24, %r3;
    setp.gt.u32 %p2, %r24, 8;
    @!%p2 max.u32 %r19, %r16, %r24;
    sub.s32 %r27, %r24, 1;
    shl.b32 %r19, %r19, 16;
    setp.lo.u32 %p1, %r26, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
