.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r22, %r3, 3;
    or.b32 %r7, %r3, 0;
    mul.wide.s32 %rd9, %r22, %r22;
    shr.u64 %rd12, %rd9, 15;
    min.u32 %r14, %r7, 2147483647;
    add.s64 %rd9, %rd9, %rd12;
    mul.lo.s64 %rd12, %rd12, %rd12;
    or.b64 %rd6, %rd9, %rd9;
    shr.u32 %r23, %r14, 0;
    mul.wide.u32 %rd9, %r3, %r23;
    shr.u32 %r24, %r7, 0;
    shl.b32 %r27, %r3, 15;
    max.s32 %r26, %r14, 255;
    setp.ne.u32 %p1, %r27, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
