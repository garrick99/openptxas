.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r13, %r3, 0;
    mul.lo.s32 %r7, %r13, %r13;
    mul.wide.u32 %rd13, %r3, %r3;
    mul.wide.s32 %rd10, %r3, %r13;
    shl.b32 %r24, %r7, 0;
    mad.lo.s32 %r25, %r24, %r13, %r13;
    shr.s32 %r6, %r13, 15;
    add.s32 %r25, %r6, %r7;
    setp.lo.u32 %p3, %r7, 4294967295;
    @%p3 max.s64 %rd14, %rd10, %rd13;
    max.u32 %r11, %r6, %r6;
    max.s32 %r8, %r24, %r3;
    mad.lo.s32 %r4, %r7, %r6, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
