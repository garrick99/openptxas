.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    sub.s32 %r13, %r3, 256;
    min.s64 %rd13, %rd12, %rd12;
    cvt.u64.u32 %rd7, %r13;
    shr.s32 %r13, %r3, 15;
    max.u64 %rd12, %rd12, %rd7;
    shr.u64 %rd9, %rd13, 4;
    mul.lo.s32 %r15, %r3, 2147483647;
    setp.ge.u32 %p4, %r3, %r3;
    @%p4 selp.b32 %r17, %r13, %r15, %p4;
    max.u32 %r8, %r15, %r3;
    shl.b32 %r12, %r13, 30;
    add.s64 %rd10, %rd12, %rd13;
    and.b32 %r11, %r15, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
