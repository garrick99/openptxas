.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    setp.ne.s32 %p1, %r3, 2;
    @%p1 max.u64 %rd7, %rd13, %rd13;
    cvt.s32.s64 %r16, %rd13;
    selp.b32 %r8, %r3, %r3, %p1;
    min.s32 %r15, %r8, %r16;
    xor.b32 %r11, %r3, 4294967295;
    max.s32 %r16, %r8, %r15;
    sub.s32 %r15, %r11, %r11;
    shr.u32 %r22, %r8, 7;
    min.u32 %r24, %r16, 2147483648;
    setp.ge.s32 %p4, %r3, 32;
    @%p4 shr.u64 %rd15, %rd7, 33;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
