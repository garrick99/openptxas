.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r25, %r3, 2147483648;
    and.b32 %r25, %r25, %r3;
    max.s32 %r7, %r3, 2;
    mul.lo.u32 %r16, %r7, 8;
    add.u32 %r20, %r16, %r7;
    mul.wide.u32 %rd7, %r20, %r25;
    cvt.u32.u64 %r13, %rd7;
    add.u32 %r11, %r13, %r3;
    shl.b32 %r7, %r7, 30;
    max.s32 %r16, %r13, 0;
    mad.lo.u32 %r10, %r25, %r11, %r3;
    min.u64 %rd6, %rd7, %rd7;
    setp.lt.u32 %p1, %r25, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
