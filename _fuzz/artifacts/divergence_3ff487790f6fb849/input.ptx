.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p2, %r3, 256;
    @%p2 mul.wide.s32 %rd15, %r3, %r3;
    selp.b32 %r18, %r3, %r3, %p2;
    setp.gt.s32 %p2, %r18, %r18;
    @%p2 xor.b32 %r27, %r3, 65535;
    shr.u64 %rd13, %rd15, 2;
    setp.ne.s32 %p2, %r18, 15;
    @%p2 sub.s32 %r7, %r3, %r27;
    mad.lo.s32 %r24, %r27, %r3, %r3;
    sub.s64 %rd13, %rd13, %rd15;
    min.s32 %r12, %r18, 7;
    and.b32 %r14, %r3, %r7;
    mul.wide.s32 %rd11, %r12, %r12;
    and.b64 %rd12, %rd15, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
