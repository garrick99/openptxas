.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r15, %r3, 4;
    cvt.u64.u32 %rd11, %r15;
    mul.lo.s32 %r26, %r15, 4294967295;
    mul.wide.u32 %rd11, %r15, %r26;
    shr.u32 %r20, %r15, 1;
    shr.u32 %r4, %r20, 30;
    mul.wide.u32 %rd7, %r20, %r4;
    cvt.s64.s32 %rd12, %r4;
    mad.lo.s32 %r23, %r4, %r26, %r4;
    add.u32 %r14, %r26, 2147483648;
    xor.b32 %r5, %r4, %r4;
    max.u32 %r27, %r20, 8;
    mul.wide.s32 %rd15, %r15, %r23;
    or.b32 %r9, %r14, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
