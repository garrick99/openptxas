.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    cvt.u64.u32 %rd7, %r3;
    cvt.u32.u64 %r18, %rd7;
    cvt.u32.u64 %r13, %rd7;
    mad.lo.s32 %r27, %r18, %r18, %r18;
    shr.s32 %r18, %r3, 15;
    setp.ls.u32 %p4, %r27, %r18;
    @%p4 min.u32 %r24, %r18, 2;
    cvt.u32.u64 %r26, %rd7;
    add.u32 %r19, %r24, 7;
    mad.lo.s32 %r18, %r24, %r3, %r19;
    and.b32 %r14, %r18, %r3;
    and.b64 %rd15, %rd7, %rd7;
    mul.lo.s32 %r16, %r27, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
