.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    and.b32 %r21, %r3, %r3;
    max.u32 %r18, %r3, 64;
    mad.lo.s32 %r6, %r18, %r18, %r21;
    sub.s32 %r16, %r6, %r21;
    shr.s32 %r5, %r3, 7;
    mul.lo.u32 %r23, %r16, 2147483648;
    setp.lt.s32 %p4, %r3, 7;
    @!%p4 max.u64 %rd6, %rd11, %rd11;
    shl.b32 %r24, %r16, 30;
    setp.ne.s32 %p1, %r23, 2147483648;
    shl.b64 %rd7, %rd11, 16;
    mul.wide.u32 %rd10, %r3, %r21;
    mul.lo.u64 %rd10, %rd11, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
