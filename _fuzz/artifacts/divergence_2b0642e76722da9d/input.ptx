.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    cvt.u32.u64 %r22, %rd11;
    cvt.s64.s32 %rd12, %r22;
    sub.s32 %r10, %r22, %r22;
    setp.lt.u32 %p3, %r10, 0;
    @%p3 and.b32 %r27, %r22, %r22;
    mul.wide.u32 %rd5, %r3, %r27;
    mul.wide.s32 %rd8, %r10, %r10;
    cvt.u64.u32 %rd6, %r3;
    max.s64 %rd6, %rd11, %rd5;
    shr.u64 %rd13, %rd6, 16;
    add.s32 %r25, %r22, %r22;
    cvt.s64.s32 %rd15, %r25;
    shr.s32 %r17, %r27, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
