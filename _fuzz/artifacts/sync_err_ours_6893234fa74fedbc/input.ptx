.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r11, %r3, %r3;
    cvt.s64.s32 %rd10, %r11;
    shl.b32 %r5, %r11, 16;
    shr.s32 %r6, %r5, 0;
    shr.s32 %r23, %r3, 7;
    min.u32 %r26, %r6, %r5;
    mul.lo.s32 %r25, %r5, 2;
    shr.s32 %r25, %r5, 2;
    and.b64 %rd9, %rd10, %rd10;
    mul.wide.u32 %rd9, %r6, %r25;
    shr.s32 %r16, %r6, 2;
    cvt.s32.s64 %r22, %rd10;
    cvt.u64.u32 %rd15, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
