.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r8, %r3, %r3;
    mul.wide.s32 %rd10, %r3, %r3;
    cvt.s32.s64 %r12, %rd10;
    and.b64 %rd5, %rd10, %rd10;
    cvt.u64.u32 %rd6, %r8;
    mul.wide.s32 %rd10, %r3, %r12;
    mad.lo.u32 %r26, %r12, %r3, %r8;
    cvt.s64.s32 %rd13, %r3;
    sub.u32 %r24, %r12, %r8;
    mul.lo.s32 %r8, %r26, %r12;
    mul.wide.u32 %rd6, %r12, %r12;
    min.u32 %r26, %r8, 63;
    mul.lo.s32 %r23, %r24, %r24;
    add.s64 %rd6, %rd5, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
