.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r20, %r3, %r3;
    min.s32 %r6, %r3, %r3;
    shr.u32 %r17, %r6, 3;
    sub.s32 %r22, %r20, %r17;
    cvt.s64.s32 %rd14, %r22;
    max.s32 %r17, %r3, 65536;
    mul.wide.s32 %rd8, %r17, %r20;
    setp.ge.s32 %p3, %r17, %r17;
    shr.s64 %rd5, %rd8, 3;
    mad.lo.u32 %r27, %r22, %r3, %r17;
    mad.lo.s32 %r9, %r22, %r17, %r6;
    cvt.u64.u32 %rd13, %r9;
    shr.s32 %r9, %r9, 4;
    min.u32 %r27, %r3, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
