.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r15, %r3, %r3;
    max.s32 %r24, %r3, %r3;
    mul.lo.u32 %r23, %r15, 2147483647;
    or.b32 %r22, %r24, %r15;
    mul.lo.u32 %r21, %r22, %r23;
    mul.wide.s32 %rd7, %r23, %r24;
    mul.lo.u32 %r27, %r23, %r23;
    cvt.s32.s64 %r4, %rd7;
    and.b32 %r9, %r24, %r24;
    or.b32 %r16, %r9, %r21;
    max.u32 %r10, %r9, %r4;
    min.u32 %r25, %r23, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
