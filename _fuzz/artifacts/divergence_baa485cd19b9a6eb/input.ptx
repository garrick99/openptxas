.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r5, %r3, %r3, %r3;
    mul.wide.s32 %rd8, %r5, %r5;
    shr.s32 %r11, %r3, 16;
    mul.wide.u32 %rd14, %r5, %r5;
    shl.b32 %r8, %r5, 2;
    mul.lo.u64 %rd13, %rd14, %rd8;
    add.s32 %r16, %r11, %r5;
    mul.wide.u32 %rd6, %r5, %r16;
    mul.lo.s32 %r8, %r5, 4294967295;
    mad.lo.u32 %r23, %r16, %r8, %r16;
    mul.lo.s32 %r5, %r23, %r5;
    setp.hi.u32 %p3, %r16, 16;
    add.s32 %r18, %r16, %r23;
    shr.u64 %rd10, %rd8, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
