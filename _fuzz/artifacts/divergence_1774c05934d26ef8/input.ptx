.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.up.b32 %r13, %r3, 4, 0x1f, -1;
    xor.b32 %r13, %r0, %r0;
    or.b32 %r15, %r0, %r3;
    add.u32 %r12, %r15, %r3;
    setp.le.u32 %p1, %r13, 16;
    vote.sync.ballot.b32 %r9, %p1, -1;
    shfl.sync.idx.b32 %r10, %r0, 15, 0x1f, -1;
    shfl.sync.down.b32 %r5, %r15, 1, 0x1f, -1;
    add.u32 %r17, %r13, %r12;
    setp.le.u32 %p3, %r12, 16;
    vote.sync.ballot.b32 %r10, %p3, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
