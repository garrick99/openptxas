.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    mul.lo.u32 %r18, %r3, %r3;
    xor.b32 %r15, %r3, 255;
    shr.s32 %r8, %r3, 7;
    shr.s32 %r14, %r15, 0;
    xor.b64 %rd6, %rd12, %rd12;
    min.s64 %rd6, %rd6, %rd6;
    mad.lo.u32 %r7, %r3, %r8, %r18;
    shr.s32 %r10, %r15, 30;
    cvt.u32.u64 %r23, %rd6;
    mul.lo.s32 %r18, %r3, %r14;
    mad.lo.s32 %r7, %r23, %r8, %r8;
    mul.wide.u32 %rd11, %r15, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
