.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    min.u32 %r14, %r3, %r3;
    setp.le.u32 %p4, %r3, 2;
    @%p4 add.s64 %rd6, %rd6, %rd6;
    max.s32 %r11, %r3, %r3;
    min.s32 %r18, %r14, 2147483647;
    sub.s32 %r13, %r11, 32;
    sub.u32 %r4, %r18, %r13;
    shl.b64 %rd6, %rd6, 48;
    cvt.u64.u32 %rd5, %r14;
    cvt.u32.u64 %r13, %rd6;
    or.b32 %r21, %r4, %r14;
    mad.lo.u32 %r25, %r14, %r3, %r13;
    shl.b32 %r11, %r13, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
