.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r18, %r3, 255;
    mad.lo.u32 %r10, %r3, %r3, %r18;
    min.s32 %r4, %r10, %r10;
    cvt.u64.u32 %rd9, %r10;
    mul.lo.u32 %r5, %r3, 31;
    shr.u32 %r14, %r5, 4;
    shr.u64 %rd15, %rd9, 15;
    mul.lo.s32 %r10, %r18, 5;
    shl.b64 %rd7, %rd15, 16;
    and.b64 %rd8, %rd15, %rd9;
    add.u32 %r20, %r18, 8;
    and.b64 %rd9, %rd8, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
