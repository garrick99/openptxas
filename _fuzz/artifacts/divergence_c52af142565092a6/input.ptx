.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    mul.lo.u32 %r10, %r3, %r3;
    and.b32 %r20, %r10, 32;
    xor.b64 %rd6, %rd11, %rd11;
    add.u32 %r16, %r10, 32;
    sub.u32 %r14, %r10, %r10;
    and.b64 %rd15, %rd11, %rd11;
    shl.b64 %rd14, %rd6, 4;
    cvt.u64.u32 %rd6, %r16;
    add.s32 %r19, %r20, 2;
    max.s32 %r18, %r14, 2;
    cvt.u32.u64 %r14, %rd14;
    cvt.u64.u32 %rd11, %r10;
    add.u32 %r19, %r20, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
