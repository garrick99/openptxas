.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p4, %r3, %r3;
    @!%p4 or.b32 %r16, %r3, %r3;
    or.b32 %r24, %r3, %r3;
    cvt.s64.s32 %rd10, %r3;
    mad.lo.u32 %r11, %r3, %r3, %r3;
    shl.b32 %r6, %r11, 1;
    mul.lo.u64 %rd8, %rd10, %rd10;
    and.b32 %r16, %r6, %r11;
    add.s64 %rd5, %rd10, %rd10;
    cvt.s32.s64 %r13, %rd10;
    mul.wide.u32 %rd6, %r3, %r16;
    and.b32 %r23, %r11, 0;
    max.s64 %rd8, %rd6, %rd8;
    max.s32 %r7, %r3, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
