.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    shr.s32 %r24, %r3, 2;
    add.s32 %r15, %r3, %r24;
    max.u32 %r25, %r24, %r15;
    mad.lo.s32 %r4, %r3, %r25, %r24;
    mul.lo.u32 %r12, %r4, 5;
    setp.hi.u32 %p1, %r4, %r12;
    add.u32 %r19, %r3, 15;
    shr.s64 %rd9, %rd15, 16;
    and.b64 %rd9, %rd15, %rd15;
    shr.s64 %rd15, %rd9, 15;
    setp.ge.s32 %p4, %r3, %r24;
    @%p4 mul.lo.s32 %r9, %r24, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
