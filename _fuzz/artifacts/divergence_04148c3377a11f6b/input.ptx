.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r19, %r3, 3;
    add.u32 %r25, %r3, 64;
    mul.wide.u32 %rd6, %r25, %r3;
    shl.b32 %r25, %r19, 30;
    mul.lo.s32 %r15, %r19, 65536;
    xor.b64 %rd13, %rd6, %rd6;
    shr.s32 %r14, %r3, 16;
    setp.gt.u32 %p1, %r19, %r14;
    @%p1 mad.lo.s32 %r23, %r25, %r19, %r3;
    setp.lo.u32 %p4, %r19, %r3;
    @%p4 mad.lo.s32 %r24, %r3, %r19, %r23;
    sub.s32 %r16, %r25, %r14;
    sub.s32 %r22, %r23, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
