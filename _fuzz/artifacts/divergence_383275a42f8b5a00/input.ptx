.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    shr.s32 %r5, %r3, 4;
    cvt.u32.u64 %r14, %rd8;
    cvt.s64.s32 %rd7, %r14;
    max.s32 %r6, %r14, 4294967295;
    shr.s64 %rd12, %rd7, 0;
    min.s32 %r9, %r6, %r3;
    setp.gt.s32 %p1, %r5, 32;
    @%p1 mul.lo.s64 %rd11, %rd12, %rd8;
    shr.u32 %r21, %r9, 1;
    cvt.s32.s64 %r12, %rd11;
    max.s32 %r4, %r5, %r12;
    max.s64 %rd8, %rd12, %rd12;
    xor.b32 %r24, %r4, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
