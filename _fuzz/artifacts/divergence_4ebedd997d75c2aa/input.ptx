.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    mul.lo.u32 %r12, %r3, %r3;
    shr.s32 %r24, %r3, 1;
    shr.s64 %rd10, %rd9, 32;
    or.b32 %r26, %r3, 1;
    sub.s32 %r10, %r3, 15;
    sub.u64 %rd7, %rd10, %rd10;
    min.s32 %r27, %r10, %r3;
    mul.lo.u64 %rd8, %rd7, %rd9;
    mad.lo.u32 %r13, %r12, %r26, %r27;
    mul.lo.s32 %r5, %r26, 2147483647;
    mad.lo.u32 %r25, %r24, %r13, %r5;
    min.s64 %rd10, %rd10, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
