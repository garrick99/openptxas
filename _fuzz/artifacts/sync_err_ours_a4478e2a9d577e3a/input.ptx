.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd15, %r3, %r3;
    shr.s32 %r18, %r3, 31;
    sub.u32 %r17, %r3, %r3;
    add.s32 %r27, %r3, %r3;
    shr.s64 %rd12, %rd15, 1;
    shr.s32 %r22, %r18, 7;
    mul.wide.s32 %rd15, %r17, %r27;
    xor.b32 %r16, %r17, %r18;
    shl.b32 %r4, %r18, 7;
    and.b32 %r21, %r22, 64;
    shr.s64 %rd14, %rd12, 48;
    sub.s32 %r25, %r17, 255;
    shr.u32 %r11, %r21, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
