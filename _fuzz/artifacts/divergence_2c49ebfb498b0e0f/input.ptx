.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r18, %r3, 0;
    shl.b32 %r8, %r3, 0;
    mul.wide.u32 %rd13, %r3, %r3;
    sub.s32 %r27, %r18, 7;
    cvt.u64.u32 %rd13, %r18;
    mul.lo.u32 %r15, %r18, 65536;
    cvt.u32.u64 %r7, %rd13;
    setp.le.u32 %p4, %r3, %r8;
    @%p4 max.u32 %r13, %r7, 255;
    cvt.s64.s32 %rd6, %r8;
    min.s32 %r22, %r3, 0;
    mad.lo.s32 %r8, %r22, %r15, %r13;
    setp.ls.u32 %p2, %r8, 7;
    @%p2 mul.lo.u32 %r24, %r8, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
