.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r12, %r3, 0;
    shr.u32 %r7, %r12, 4;
    min.u32 %r16, %r7, %r12;
    add.u32 %r19, %r12, 65535;
    and.b32 %r22, %r3, %r3;
    add.s32 %r19, %r19, 8;
    max.s32 %r8, %r3, %r7;
    setp.ne.s32 %p2, %r16, %r22;
    @%p2 shr.u32 %r19, %r22, 15;
    mul.wide.u32 %rd10, %r7, %r8;
    add.u32 %r24, %r16, %r3;
    setp.le.s32 %p1, %r24, 255;
    selp.b32 %r10, %r19, %r22, %p1;
    or.b32 %r18, %r19, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
