.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r20, %r3, %r3;
    mul.lo.u32 %r13, %r3, %r20;
    add.u32 %r8, %r20, %r13;
    sub.s32 %r24, %r3, %r3;
    max.u32 %r4, %r13, %r8;
    cvt.s64.s32 %rd7, %r13;
    sub.s32 %r24, %r4, 31;
    mad.lo.s32 %r15, %r4, %r3, %r8;
    shr.u64 %rd13, %rd7, 7;
    mad.lo.u32 %r17, %r13, %r13, %r15;
    and.b32 %r15, %r20, 31;
    shr.u32 %r23, %r17, 0;
    xor.b64 %rd14, %rd13, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
