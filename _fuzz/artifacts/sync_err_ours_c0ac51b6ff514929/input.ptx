.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r26, %r3, 64;
    mul.wide.s32 %rd11, %r26, %r3;
    min.s32 %r21, %r26, %r26;
    mul.wide.s32 %rd12, %r3, %r21;
    or.b32 %r26, %r21, 256;
    max.u32 %r23, %r3, %r26;
    mul.lo.s32 %r19, %r26, %r26;
    setp.ne.s32 %p1, %r26, 63;
    max.u32 %r26, %r26, 32;
    setp.ne.s32 %p1, %r21, %r23;
    mad.lo.s32 %r15, %r26, %r3, %r21;
    mul.lo.u32 %r24, %r19, %r19;
    mul.wide.u32 %rd7, %r23, %r21;
    or.b32 %r20, %r23, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
