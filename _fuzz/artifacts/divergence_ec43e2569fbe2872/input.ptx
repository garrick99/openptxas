.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    sub.u32 %r21, %r3, 65536;
    add.u32 %r9, %r3, 63;
    cvt.u64.u32 %rd9, %r3;
    xor.b32 %r12, %r21, 3;
    mul.lo.s32 %r27, %r21, %r9;
    cvt.u64.u32 %rd7, %r9;
    cvt.s64.s32 %rd13, %r3;
    shr.s64 %rd9, %rd14, 63;
    shr.s32 %r6, %r21, 30;
    sub.s32 %r17, %r12, 2147483648;
    cvt.s32.s64 %r9, %rd13;
    shr.s64 %rd9, %rd13, 1;
    or.b32 %r13, %r12, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
