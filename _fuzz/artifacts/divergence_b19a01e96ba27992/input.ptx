.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    mul.wide.s32 %rd11, %r3, %r3;
    shr.s64 %rd11, %rd6, 63;
    min.u64 %rd14, %rd11, %rd6;
    mad.lo.s32 %r8, %r3, %r3, %r3;
    shl.b64 %rd8, %rd6, 30;
    xor.b32 %r19, %r8, 5;
    sub.s64 %rd15, %rd6, %rd11;
    shr.s64 %rd10, %rd6, 31;
    max.u32 %r22, %r3, 63;
    mul.lo.u32 %r18, %r22, 65536;
    mul.lo.s32 %r21, %r18, %r18;
    min.u64 %rd7, %rd8, %rd10;
    sub.s32 %r19, %r18, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
