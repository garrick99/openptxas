.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r27, %r3, 2;
    cvt.s64.s32 %rd12, %r3;
    min.u32 %r20, %r27, 0;
    min.u32 %r9, %r3, %r27;
    or.b32 %r11, %r27, %r9;
    or.b64 %rd15, %rd12, %rd12;
    setp.gt.s32 %p3, %r3, %r20;
    @%p3 shr.u32 %r19, %r20, 4;
    mul.wide.s32 %rd7, %r3, %r20;
    cvt.s64.s32 %rd9, %r11;
    setp.le.s32 %p4, %r9, 1;
    xor.b32 %r20, %r11, 2147483648;
    min.s32 %r24, %r11, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
