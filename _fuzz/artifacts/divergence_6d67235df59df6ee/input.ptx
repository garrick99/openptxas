.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r10, %r3, 2;
    cvt.s64.s32 %rd7, %r10;
    shr.s32 %r19, %r3, 3;
    min.u32 %r18, %r3, %r19;
    shr.s32 %r7, %r18, 3;
    cvt.s32.s64 %r26, %rd7;
    shr.s32 %r6, %r7, 16;
    setp.lt.s32 %p1, %r6, 5;
    @%p1 shl.b64 %rd13, %rd7, 30;
    setp.le.s32 %p2, %r6, %r10;
    @!%p2 add.u32 %r26, %r18, 255;
    shr.u32 %r21, %r19, 7;
    min.s32 %r7, %r7, %r26;
    shr.u64 %rd13, %rd13, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
