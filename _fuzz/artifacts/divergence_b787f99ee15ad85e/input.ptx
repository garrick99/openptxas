.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.up.b32 %r5, %r3, 2, 0x1f, -1;
    shfl.sync.idx.b32 %r10, %r0, 31, 0x1f, -1;
    min.u32 %r19, %r0, %r3;
    add.u32 %r10, %r19, %r10;
    setp.ne.u32 %p2, %r5, 0;
    vote.sync.ballot.b32 %r9, %p2, -1;
    shfl.sync.down.b32 %r10, %r5, 4, 0x1f, -1;
    setp.gt.u32 %p2, %r9, %r10;
    vote.sync.ballot.b32 %r11, %p2, -1;
    shfl.sync.bfly.b32 %r19, %r5, 2, 0x1f, -1;
    setp.eq.u32 %p1, %r0, %r11;
    vote.sync.ballot.b32 %r10, %p1, -1;
    shfl.sync.down.b32 %r4, %r11, 8, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
