.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r12, %r3, 15;
    mul.lo.s32 %r19, %r3, 16;
    shr.u32 %r20, %r12, 15;
    setp.eq.s32 %p1, %r12, %r3;
    @!%p1 mul.lo.u32 %r4, %r19, 31;
    min.u32 %r18, %r12, %r20;
    selp.b32 %r9, %r4, %r20, %p1;
    sub.u32 %r18, %r4, %r12;
    shr.s32 %r16, %r9, 7;
    cvt.u64.u32 %rd15, %r3;
    shl.b64 %rd7, %rd15, 1;
    mul.wide.s32 %rd14, %r12, %r20;
    mad.lo.u32 %r24, %r19, %r4, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
