    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r22, %r3, 31;
    shr.s32 %r6, %r3, 16;
    mad.lo.u32 %r6, %r3, %r3, %r22;
    cvt.u64.u32 %rd15, %r6;
    max.u32 %r13, %r3, %r22;
    and.b64 %rd15, %rd15, %rd15;
    add.s32 %r19, %r6, 32;
    add.s32 %r4, %r19, 4294967295;
    shr.u32 %r22, %r19, 2;
    mad.lo.u32 %r6, %r3, %r4, %r3;
    cvt.s64.s32 %rd5, %r3;
    setp.ge.s32 %p2, %r13, 256;
    @!%p2 and.b32 %r24, %r3, %r4;
    min.s32 %r7, %r22, 4294967295;
