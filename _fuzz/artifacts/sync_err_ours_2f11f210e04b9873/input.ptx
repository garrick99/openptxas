.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r22, %r3, 2;
    shr.u32 %r24, %r22, 2;
    mul.wide.s32 %rd12, %r24, %r22;
    min.s32 %r21, %r3, %r24;
    mad.lo.s32 %r7, %r22, %r21, %r22;
    shr.s32 %r21, %r7, 0;
    mul.lo.s32 %r20, %r24, %r24;
    max.s32 %r6, %r20, %r22;
    mul.lo.s32 %r23, %r6, 8;
    shr.s32 %r13, %r23, 2;
    shr.u32 %r12, %r3, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
