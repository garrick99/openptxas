.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    sub.s32 %r12, %r3, 256;
    max.s32 %r6, %r12, 2147483647;
    xor.b32 %r24, %r12, %r3;
    cvt.s32.s64 %r9, %rd9;
    and.b32 %r27, %r9, 3;
    mul.wide.s32 %rd9, %r27, %r3;
    and.b32 %r15, %r9, 65536;
    and.b64 %rd5, %rd9, %rd9;
    and.b32 %r14, %r15, %r24;
    or.b32 %r24, %r27, 31;
    xor.b32 %r21, %r12, %r24;
    mul.wide.s32 %rd13, %r21, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
