.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    sub.u32 %r15, %r3, 65535;
    cvt.s64.s32 %rd14, %r15;
    setp.gt.u32 %p4, %r3, %r3;
    setp.hs.u32 %p3, %r15, 7;
    @%p3 cvt.u32.u64 %r21, %rd13;
    max.s32 %r19, %r21, 0;
    min.u32 %r20, %r19, %r3;
    max.u64 %rd10, %rd14, %rd13;
    min.s32 %r9, %r15, %r21;
    xor.b32 %r27, %r19, 8;
    add.u32 %r11, %r3, %r21;
    max.u64 %rd15, %rd14, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
