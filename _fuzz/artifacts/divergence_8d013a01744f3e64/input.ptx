.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r20, %r3, 31;
    setp.le.s32 %p4, %r3, 32;
    @%p4 shl.b32 %r10, %r3, 15;
    shr.u32 %r4, %r10, 7;
    setp.le.s32 %p3, %r10, 31;
    @%p3 mul.lo.u32 %r9, %r20, 32;
    cvt.u64.u32 %rd6, %r4;
    and.b64 %rd15, %rd6, %rd6;
    mul.wide.u32 %rd10, %r4, %r4;
    max.u32 %r24, %r9, %r4;
    mul.wide.u32 %rd10, %r9, %r20;
    mul.lo.s32 %r10, %r3, 2147483648;
    setp.lt.s32 %p2, %r10, 255;
    cvt.s32.s64 %r15, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
