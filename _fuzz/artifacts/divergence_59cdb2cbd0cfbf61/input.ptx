.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r15, %r3, %r3;
    mul.wide.u32 %rd15, %r3, %r15;
    setp.eq.u32 %p2, %r15, 1;
    @%p2 mul.wide.s32 %rd8, %r15, %r15;
    sub.s32 %r19, %r15, %r15;
    min.s64 %rd8, %rd8, %rd8;
    shl.b32 %r20, %r15, 7;
    setp.le.s32 %p1, %r19, 32;
    mul.wide.s32 %rd6, %r3, %r20;
    or.b32 %r27, %r19, %r3;
    add.u32 %r22, %r20, 64;
    setp.ne.u32 %p1, %r15, %r3;
    @!%p1 and.b32 %r9, %r15, 1;
    cvt.s64.s32 %rd8, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
