.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r24, %r3, 63;
    cvt.s64.s32 %rd11, %r24;
    setp.lt.u32 %p2, %r3, %r3;
    @%p2 mad.lo.s32 %r19, %r3, %r24, %r3;
    mad.lo.u32 %r25, %r3, %r24, %r3;
    mad.lo.s32 %r17, %r19, %r19, %r19;
    and.b32 %r13, %r25, %r19;
    min.u32 %r9, %r24, 31;
    shr.u32 %r18, %r3, 16;
    add.u32 %r9, %r25, %r17;
    shr.s64 %rd7, %rd11, 63;
    cvt.u64.u32 %rd9, %r24;
    shr.s64 %rd13, %rd9, 32;
    setp.ls.u32 %p1, %r17, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
