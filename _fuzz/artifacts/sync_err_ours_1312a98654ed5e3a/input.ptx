.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r22, %r3, %r3;
    shl.b32 %r21, %r3, 16;
    sub.u32 %r25, %r21, 256;
    cvt.s64.s32 %rd5, %r3;
    max.u32 %r5, %r21, 65535;
    or.b32 %r12, %r22, 15;
    min.u32 %r8, %r5, %r5;
    sub.s32 %r6, %r5, %r8;
    or.b32 %r9, %r12, 4;
    mul.wide.u32 %rd6, %r5, %r5;
    and.b64 %rd11, %rd5, %rd5;
    shl.b32 %r18, %r9, 3;
    cvt.s32.s64 %r4, %rd6;
    and.b64 %rd11, %rd6, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
