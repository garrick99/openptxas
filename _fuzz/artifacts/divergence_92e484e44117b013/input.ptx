.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd14, %r3, %r3;
    shr.s32 %r16, %r3, 15;
    mul.lo.u32 %r13, %r16, %r16;
    xor.b32 %r4, %r3, %r16;
    mul.lo.u32 %r7, %r16, 64;
    shl.b64 %rd5, %rd14, 47;
    shr.s32 %r16, %r13, 16;
    setp.hi.u32 %p4, %r16, %r4;
    @%p4 cvt.s32.s64 %r25, %rd14;
    mad.lo.u32 %r15, %r25, %r13, %r13;
    cvt.u32.u64 %r19, %rd5;
    sub.u32 %r6, %r15, %r7;
    cvt.s64.s32 %rd7, %r6;
    cvt.u32.u64 %r21, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
