.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r17, %r3, 8;
    cvt.s64.s32 %rd6, %r3;
    add.u32 %r9, %r17, 1;
    or.b64 %rd9, %rd6, %rd6;
    max.u64 %rd6, %rd6, %rd6;
    xor.b32 %r25, %r17, %r17;
    shr.s64 %rd15, %rd9, 2;
    setp.lt.u32 %p3, %r9, 8;
    @%p3 xor.b32 %r22, %r17, %r17;
    add.s32 %r10, %r17, %r22;
    shl.b32 %r4, %r3, 3;
    mad.lo.s32 %r26, %r22, %r10, %r22;
    shr.s64 %rd5, %rd15, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
