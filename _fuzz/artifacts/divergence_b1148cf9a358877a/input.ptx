.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r20, %r3, 0;
    cvt.u64.u32 %rd15, %r20;
    shl.b32 %r18, %r3, 16;
    max.u32 %r8, %r20, %r3;
    max.u64 %rd11, %rd15, %rd15;
    and.b32 %r20, %r8, 5;
    add.u32 %r16, %r18, 32;
    max.s32 %r6, %r3, %r20;
    shl.b64 %rd5, %rd15, 2;
    setp.lo.u32 %p4, %r16, %r8;
    @!%p4 sub.u32 %r10, %r18, %r20;
    add.u32 %r6, %r20, 7;
    and.b32 %r6, %r20, %r10;
    mul.lo.u32 %r12, %r10, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
