.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r5, %r3, 65535;
    mul.wide.s32 %rd9, %r3, %r3;
    mad.lo.s32 %r21, %r3, %r5, %r3;
    mul.wide.s32 %rd10, %r21, %r21;
    mad.lo.u32 %r10, %r5, %r21, %r5;
    max.s32 %r21, %r21, 65535;
    cvt.u64.u32 %rd8, %r21;
    mul.lo.u32 %r22, %r10, %r5;
    setp.le.u32 %p4, %r10, %r21;
    @%p4 add.s32 %r19, %r21, 15;
    add.s32 %r22, %r22, %r22;
    mul.lo.u32 %r17, %r22, %r22;
    selp.b32 %r21, %r21, %r22, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
