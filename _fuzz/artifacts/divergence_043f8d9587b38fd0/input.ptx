.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    mul.lo.u64 %rd11, %rd7, %rd7;
    shr.s64 %rd11, %rd7, 0;
    mul.lo.s64 %rd14, %rd7, %rd11;
    min.s32 %r23, %r3, 32;
    shl.b64 %rd5, %rd11, 62;
    sub.s64 %rd7, %rd7, %rd11;
    setp.hi.u32 %p3, %r23, %r3;
    add.u32 %r24, %r23, %r3;
    mul.wide.s32 %rd12, %r3, %r24;
    sub.s64 %rd10, %rd11, %rd5;
    selp.b32 %r8, %r24, %r23, %p3;
    min.u32 %r9, %r23, %r8;
    setp.le.s32 %p1, %r8, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
