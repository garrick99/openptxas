.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    shl.b32 %r24, %r3, 1;
    cvt.u64.u32 %rd7, %r24;
    mul.lo.s64 %rd12, %rd13, %rd7;
    mad.lo.u32 %r18, %r24, %r24, %r3;
    and.b64 %rd12, %rd7, %rd13;
    mad.lo.u32 %r20, %r24, %r24, %r24;
    cvt.s32.s64 %r23, %rd12;
    shl.b32 %r18, %r18, 7;
    setp.hi.u32 %p2, %r3, %r24;
    @!%p2 xor.b32 %r5, %r20, %r18;
    add.s32 %r6, %r23, %r23;
    sub.u32 %r24, %r23, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
