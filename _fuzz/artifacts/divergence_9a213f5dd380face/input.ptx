.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r8, %r3, %r3, %r3;
    shr.u32 %r19, %r3, 0;
    cvt.s64.s32 %rd6, %r3;
    mul.lo.s32 %r7, %r19, %r3;
    mul.lo.s64 %rd8, %rd6, %rd6;
    add.u32 %r4, %r8, 32;
    setp.ge.s32 %p1, %r7, %r4;
    @!%p1 add.u32 %r17, %r7, %r4;
    selp.b32 %r7, %r7, %r4, %p1;
    shr.s32 %r20, %r19, 7;
    or.b32 %r9, %r20, 2147483647;
    mul.wide.s32 %rd11, %r4, %r9;
    max.u32 %r24, %r7, 16;
    shl.b64 %rd6, %rd8, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
