.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    shr.s32 %r7, %r3, 15;
    sub.u32 %r19, %r3, %r3;
    mad.lo.s32 %r18, %r19, %r19, %r7;
    cvt.s32.s64 %r7, %rd6;
    mul.lo.s32 %r10, %r18, 7;
    shl.b32 %r16, %r7, 30;
    mul.lo.s32 %r24, %r18, %r3;
    min.u32 %r17, %r18, %r16;
    shr.s64 %rd5, %rd6, 4;
    sub.u32 %r10, %r17, 65536;
    setp.ge.s32 %p4, %r19, 5;
    @%p4 min.u32 %r27, %r18, %r24;
    max.u32 %r17, %r16, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
