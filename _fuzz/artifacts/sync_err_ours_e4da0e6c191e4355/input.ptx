.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    sub.u32 %r24, %r3, 255;
    mul.lo.s32 %r9, %r24, 31;
    max.s32 %r4, %r3, %r9;
    shl.b64 %rd9, %rd13, 1;
    mul.wide.u32 %rd7, %r9, %r3;
    shl.b32 %r13, %r4, 31;
    setp.ne.s32 %p2, %r9, 64;
    @%p2 mad.lo.s32 %r13, %r9, %r9, %r24;
    and.b32 %r10, %r4, %r4;
    cvt.s32.s64 %r7, %rd13;
    sub.u32 %r24, %r13, %r3;
    min.u32 %r7, %r24, %r24;
    cvt.s64.s32 %rd14, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
