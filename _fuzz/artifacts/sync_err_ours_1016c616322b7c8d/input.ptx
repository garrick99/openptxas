.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    cvt.s32.s64 %r4, %rd11;
    sub.s32 %r6, %r3, 2;
    shr.s32 %r13, %r3, 0;
    max.u32 %r24, %r6, %r3;
    shr.u32 %r20, %r13, 4;
    shr.u64 %rd10, %rd11, 3;
    add.u32 %r18, %r24, 15;
    shr.u64 %rd10, %rd10, 63;
    shr.s32 %r6, %r6, 0;
    setp.gt.s32 %p1, %r24, %r18;
    setp.ge.u32 %p3, %r3, 1;
    @%p3 shr.s32 %r15, %r20, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
