.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r11, %r3, 255;
    sub.s32 %r24, %r11, %r11;
    add.s32 %r14, %r3, %r11;
    shr.s32 %r23, %r11, 30;
    or.b32 %r4, %r24, 63;
    setp.eq.u32 %p3, %r4, %r24;
    @!%p3 mad.lo.u32 %r22, %r14, %r24, %r3;
    min.s32 %r19, %r23, 255;
    min.s32 %r23, %r24, %r23;
    sub.s32 %r25, %r4, %r3;
    min.s32 %r14, %r22, %r24;
    min.u32 %r9, %r22, %r4;
    sub.s32 %r21, %r14, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
