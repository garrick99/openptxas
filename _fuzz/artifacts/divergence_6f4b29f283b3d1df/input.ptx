    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r25, %r3, %r3;
    mul.lo.s32 %r27, %r3, 65536;
    add.s32 %r22, %r25, 8;
    cvt.u64.u32 %rd10, %r27;
