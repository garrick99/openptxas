.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p2, %r3, %r3;
    @!%p2 xor.b32 %r22, %r3, 65536;
    max.u32 %r7, %r3, %r22;
    mul.wide.s32 %rd6, %r7, %r22;
    cvt.s64.s32 %rd15, %r7;
    cvt.s64.s32 %rd8, %r7;
    sub.s32 %r11, %r3, %r22;
    setp.ls.u32 %p4, %r11, %r7;
    add.u32 %r11, %r11, %r22;
    shl.b32 %r26, %r3, 31;
    cvt.u32.u64 %r19, %rd15;
    mul.wide.u32 %rd10, %r26, %r22;
    selp.b32 %r24, %r3, %r7, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
