.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r27, %r3, 3;
    cvt.u64.u32 %rd7, %r3;
    add.s32 %r5, %r3, 8;
    or.b64 %rd5, %rd7, %rd7;
    setp.eq.s32 %p2, %r5, 255;
    @%p2 max.u32 %r17, %r27, %r5;
    mul.lo.s32 %r11, %r5, %r27;
    and.b32 %r7, %r27, 2;
    and.b32 %r17, %r7, %r17;
    selp.b32 %r8, %r27, %r5, %p2;
    cvt.u32.u64 %r11, %rd5;
    mul.lo.u32 %r5, %r7, 2147483647;
    cvt.u64.u32 %rd6, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
