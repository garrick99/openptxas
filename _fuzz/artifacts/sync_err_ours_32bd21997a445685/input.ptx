.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r20, %r3, 63;
    mul.lo.u32 %r6, %r3, 5;
    cvt.s64.s32 %rd11, %r6;
    mul.lo.s32 %r16, %r6, %r20;
    mul.lo.u32 %r26, %r20, %r20;
    cvt.u32.u64 %r24, %rd11;
    add.u64 %rd13, %rd11, %rd11;
    cvt.s32.s64 %r8, %rd11;
    sub.s32 %r27, %r6, %r16;
    cvt.u32.u64 %r27, %rd13;
    sub.s64 %rd10, %rd13, %rd11;
    min.s32 %r7, %r16, %r16;
    mad.lo.u32 %r8, %r6, %r24, %r7;
    mul.wide.s32 %rd10, %r16, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
