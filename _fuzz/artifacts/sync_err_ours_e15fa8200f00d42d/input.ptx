.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    shr.u64 %rd13, %rd12, 16;
    shr.u64 %rd7, %rd12, 4;
    shr.u32 %r9, %r3, 7;
    max.s32 %r11, %r9, 1;
    cvt.u32.u64 %r21, %rd12;
    setp.eq.u32 %p4, %r21, %r11;
    @%p4 mul.lo.s64 %rd15, %rd12, %rd13;
    sub.u32 %r9, %r21, %r21;
    setp.gt.s32 %p3, %r3, 7;
    or.b32 %r20, %r21, %r11;
    min.s32 %r11, %r11, %r11;
    max.u32 %r23, %r9, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
