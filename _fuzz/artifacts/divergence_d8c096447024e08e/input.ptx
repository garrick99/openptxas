.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r24, %r3, 65535;
    min.u32 %r12, %r24, 4;
    cvt.s64.s32 %rd13, %r12;
    sub.u32 %r21, %r12, %r24;
    min.s32 %r21, %r12, %r3;
    add.u32 %r27, %r3, 1;
    shr.u32 %r20, %r24, 30;
    min.u32 %r26, %r3, 64;
    mul.wide.s32 %rd14, %r12, %r20;
    shl.b32 %r23, %r26, 30;
    shl.b32 %r11, %r21, 16;
    sub.s32 %r14, %r3, 1;
    shl.b32 %r26, %r24, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
