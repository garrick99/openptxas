.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r25, %r3, 1;
    mad.lo.u32 %r26, %r3, %r3, %r3;
    mul.lo.s32 %r5, %r25, 2147483648;
    sub.s32 %r20, %r25, %r25;
    cvt.u64.u32 %rd6, %r20;
    shr.u64 %rd11, %rd6, 15;
    xor.b32 %r21, %r5, 2147483648;
    cvt.u64.u32 %rd11, %r21;
    cvt.s32.s64 %r13, %rd6;
    shl.b32 %r16, %r13, 16;
    sub.s32 %r14, %r16, %r21;
    shr.u64 %rd10, %rd11, 0;
    setp.ge.u32 %p4, %r13, 32;
    @%p4 min.s32 %r6, %r5, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
