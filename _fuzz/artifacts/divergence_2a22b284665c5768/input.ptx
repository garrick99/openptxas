.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r16, %r3, %r3;
    cvt.s64.s32 %rd10, %r16;
    mul.lo.u32 %r18, %r16, 4294967295;
    setp.ge.s32 %p3, %r3, %r18;
    @%p3 min.u32 %r22, %r18, %r16;
    xor.b32 %r18, %r3, %r18;
    cvt.u64.u32 %rd7, %r16;
    max.u32 %r14, %r3, %r18;
    mul.lo.s32 %r24, %r14, %r22;
    and.b32 %r17, %r18, 255;
    mul.lo.s32 %r9, %r3, %r22;
    xor.b32 %r8, %r22, %r14;
    xor.b32 %r24, %r3, 1;
    selp.b32 %r15, %r9, %r17, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
