.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd8, %r3, %r3;
    and.b32 %r23, %r3, %r3;
    setp.lt.s32 %p2, %r3, 65535;
    setp.lt.s32 %p4, %r23, %r3;
    setp.ge.u32 %p2, %r3, %r3;
    @%p2 add.u32 %r9, %r23, 32;
    mad.lo.s32 %r11, %r9, %r9, %r23;
    mul.lo.s32 %r13, %r3, 256;
    sub.u64 %rd9, %rd8, %rd8;
    sub.u32 %r20, %r3, 65535;
    cvt.u64.u32 %rd14, %r23;
    cvt.s32.s64 %r25, %rd8;
    shr.u32 %r10, %r13, 30;
    shl.b32 %r26, %r20, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
