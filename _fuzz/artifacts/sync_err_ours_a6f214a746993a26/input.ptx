.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    cvt.s32.s64 %r9, %rd13;
    setp.ne.u32 %p1, %r3, 0;
    shl.b32 %r17, %r3, 2;
    mad.lo.u32 %r10, %r3, %r9, %r3;
    cvt.s32.s64 %r19, %rd13;
    shr.s64 %rd11, %rd13, 63;
    setp.le.u32 %p1, %r17, 2;
    @%p1 shr.u32 %r22, %r19, 3;
    shr.s64 %rd9, %rd13, 0;
    setp.ne.u32 %p1, %r3, 4;
    @%p1 min.u32 %r20, %r22, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
