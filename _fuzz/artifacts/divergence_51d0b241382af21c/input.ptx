.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r14, %r3, 7;
    mul.wide.u32 %rd9, %r14, %r3;
    sub.u64 %rd15, %rd9, %rd9;
    sub.s32 %r26, %r3, %r3;
    shl.b64 %rd5, %rd15, 0;
    shl.b32 %r26, %r26, 7;
    setp.gt.s32 %p4, %r26, %r26;
    setp.ge.s32 %p1, %r26, %r14;
    @%p1 shl.b32 %r26, %r3, 30;
    sub.s32 %r22, %r3, %r26;
    max.s32 %r14, %r14, 1;
    cvt.u64.u32 %rd10, %r14;
    cvt.u64.u32 %rd12, %r14;
    shr.s64 %rd11, %rd5, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
