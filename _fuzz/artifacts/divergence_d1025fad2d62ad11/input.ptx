.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd6, %r3, %r3;
    and.b64 %rd13, %rd6, %rd6;
    shr.u64 %rd14, %rd6, 4;
    xor.b64 %rd15, %rd14, %rd13;
    mul.lo.u64 %rd11, %rd14, %rd15;
    max.s32 %r23, %r3, 31;
    mad.lo.s32 %r12, %r3, %r23, %r3;
    mad.lo.u32 %r19, %r12, %r23, %r12;
    xor.b32 %r10, %r19, %r12;
    mad.lo.s32 %r15, %r23, %r12, %r10;
    add.u32 %r27, %r19, 7;
    min.s64 %rd14, %rd6, %rd15;
    sub.u64 %rd7, %rd13, %rd15;
    shl.b32 %r18, %r12, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
