    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r20, %r3, 2;
    sub.s32 %r21, %r20, %r3;
    cvt.u64.u32 %rd12, %r20;
    add.u32 %r7, %r20, 255;
    xor.b32 %r22, %r21, %r7;
    cvt.s32.s64 %r5, %rd12;
    and.b32 %r16, %r22, %r3;
    shr.u64 %rd13, %rd12, 62;
    mul.lo.s32 %r25, %r3, %r20;
    max.u32 %r11, %r25, %r3;
    add.s32 %r6, %r21, 4294967295;
    sub.s32 %r10, %r21, %r7;
    and.b32 %r8, %r5, 4;
