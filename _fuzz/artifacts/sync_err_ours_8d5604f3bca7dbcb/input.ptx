.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r9, %r3, %r3;
    cvt.u64.u32 %rd10, %r9;
    add.s32 %r9, %r3, %r9;
    and.b32 %r9, %r3, %r9;
    mul.wide.u32 %rd15, %r9, %r9;
    shr.s32 %r17, %r3, 0;
    cvt.u32.u64 %r22, %rd15;
    mul.lo.u32 %r6, %r17, 15;
    and.b32 %r4, %r3, 4294967295;
    mul.wide.s32 %rd13, %r9, %r17;
    add.u32 %r26, %r22, %r9;
    cvt.s64.s32 %rd10, %r9;
    add.u32 %r25, %r9, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
