.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r19, %r3, %r3;
    cvt.u64.u32 %rd11, %r3;
    and.b32 %r7, %r3, %r3;
    max.u64 %rd8, %rd11, %rd11;
    shl.b64 %rd5, %rd8, 0;
    mul.wide.u32 %rd10, %r19, %r7;
    mul.lo.s32 %r5, %r19, %r19;
    shr.s64 %rd11, %rd11, 15;
    shr.u64 %rd11, %rd5, 7;
    max.u64 %rd9, %rd11, %rd10;
    shr.s32 %r24, %r7, 1;
    sub.s32 %r18, %r24, %r24;
    max.s32 %r25, %r24, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
