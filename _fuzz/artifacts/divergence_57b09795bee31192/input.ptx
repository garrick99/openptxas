.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r17, %r3, %r3, %r3;
    setp.lt.s32 %p3, %r17, %r17;
    @!%p3 selp.b32 %r10, %r3, %r17, %p3;
    setp.ne.s32 %p1, %r17, %r10;
    @%p1 and.b32 %r19, %r10, %r3;
    xor.b32 %r27, %r3, %r10;
    setp.le.u32 %p4, %r27, 5;
    @%p4 selp.b32 %r26, %r27, %r17, %p1;
    and.b32 %r21, %r26, 64;
    xor.b32 %r21, %r27, %r26;
    setp.hi.u32 %p4, %r19, 64;
    @%p4 min.u32 %r20, %r27, %r26;
    selp.b32 %r18, %r19, %r20, %p4;
    mad.lo.s32 %r24, %r20, %r20, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
