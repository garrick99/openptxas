.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p4, %r3, 4294967295;
    @%p4 max.u32 %r22, %r3, %r3;
    setp.ge.s32 %p2, %r22, 64;
    cvt.s64.s32 %rd9, %r22;
    shr.u64 %rd15, %rd9, 2;
    setp.ge.s32 %p4, %r22, 2147483648;
    @%p4 cvt.s32.s64 %r11, %rd15;
    mad.lo.u32 %r19, %r22, %r3, %r22;
    cvt.s32.s64 %r17, %rd9;
    sub.s32 %r20, %r22, 0;
    min.s64 %rd8, %rd15, %rd15;
    shr.s64 %rd12, %rd9, 31;
    setp.gt.s32 %p4, %r17, 8;
    cvt.u32.u64 %r11, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
