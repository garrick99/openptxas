.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r19, %r3, %r3, %r3;
    sub.u32 %r17, %r3, 65535;
    add.s32 %r12, %r17, %r17;
    sub.u32 %r26, %r17, 3;
    add.s32 %r22, %r3, %r19;
    and.b32 %r8, %r17, %r22;
    cvt.s64.s32 %rd6, %r22;
    max.u32 %r12, %r3, %r3;
    mul.wide.u32 %rd7, %r8, %r12;
    min.u32 %r27, %r26, %r8;
    min.s32 %r20, %r26, %r22;
    shl.b64 %rd8, %rd6, 2;
    shr.s32 %r27, %r22, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
