.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r22, %r3, 1;
    cvt.u64.u32 %rd11, %r3;
    mad.lo.s32 %r27, %r22, %r3, %r22;
    shr.s32 %r20, %r22, 16;
    add.s32 %r11, %r27, %r22;
    and.b32 %r11, %r22, %r22;
    cvt.s32.s64 %r15, %rd11;
    shr.u32 %r5, %r15, 7;
    mul.lo.s32 %r27, %r27, %r20;
    add.s32 %r6, %r3, %r3;
    mul.wide.s32 %rd9, %r11, %r20;
    shr.u64 %rd7, %rd11, 31;
    cvt.s32.s64 %r14, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
