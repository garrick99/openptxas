    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r22, %r3, %r3, %r3;
    shr.u32 %r20, %r3, 0;
    cvt.u64.u32 %rd6, %r20;
    add.s32 %r20, %r3, 65536;
    sub.u32 %r13, %r3, %r3;
    add.u64 %rd10, %rd6, %rd6;
    shr.u32 %r11, %r22, 2;
    or.b32 %r24, %r3, 4;
    shl.b64 %rd13, %rd10, 0;
    shr.s32 %r21, %r13, 1;
    mad.lo.u32 %r6, %r13, %r24, %r3;
    xor.b32 %r16, %r20, %r22;
    setp.le.s32 %p1, %r11, 4294967295;
    @%p1 shl.b64 %rd6, %rd6, 62;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
