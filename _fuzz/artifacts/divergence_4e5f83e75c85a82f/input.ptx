.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    shr.u32 %r26, %r3, 30;
    shr.s32 %r14, %r3, 0;
    sub.s32 %r14, %r26, %r26;
    and.b32 %r20, %r26, 4294967295;
    shl.b64 %rd13, %rd6, 30;
    sub.u32 %r4, %r26, %r3;
    shr.u32 %r6, %r4, 0;
    mul.lo.s32 %r13, %r4, %r4;
    min.u32 %r17, %r20, 3;
    setp.ne.u32 %p2, %r13, %r20;
    @%p2 shr.s64 %rd15, %rd6, 30;
    setp.gt.s32 %p1, %r6, %r6;
    @%p1 cvt.s32.s64 %r18, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
