.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    clz.b32 %r14, %r3;
    bfi.b32 %r14, %r3, %r14, 31, 32;
    bfi.b32 %r13, %r14, %r3, 23, 7;
    bfe.s32 %r20, %r13, 23, 7;
    bfe.u32 %r22, %r3, 15, 31;
    or.b32 %r11, %r20, 15;
    brev.b32 %r8, %r14;
    brev.b32 %r16, %r20;
    bfi.b32 %r8, %r16, %r13, 15, 2;
    brev.b32 %r14, %r11;
    bfe.u32 %r22, %r16, 23, 31;
    bfe.s32 %r6, %r8, 24, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
