.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r14, %r3, %r3;
    and.b32 %r17, %r3, %r3;
    cvt.s64.s32 %rd6, %r14;
    cvt.u32.u64 %r13, %rd6;
    max.s32 %r22, %r14, %r3;
    min.s32 %r23, %r14, %r14;
    max.u32 %r8, %r3, %r22;
    or.b32 %r19, %r17, 3;
    setp.eq.u32 %p3, %r22, %r22;
    @!%p3 sub.s32 %r15, %r3, %r17;
    max.u32 %r7, %r3, 5;
    shl.b64 %rd7, %rd6, 30;
    setp.eq.s32 %p3, %r13, %r22;
    shl.b32 %r20, %r14, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
