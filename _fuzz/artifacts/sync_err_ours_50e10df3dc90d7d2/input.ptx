.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r19, %r3, %r3;
    cvt.u64.u32 %rd15, %r3;
    sub.u32 %r9, %r3, %r3;
    shr.u32 %r23, %r3, 15;
    sub.s32 %r24, %r9, %r19;
    shr.u32 %r18, %r19, 0;
    mul.lo.u32 %r6, %r23, 7;
    shr.s32 %r20, %r19, 16;
    mul.lo.u32 %r6, %r19, %r23;
    cvt.s32.s64 %r15, %rd15;
    mul.lo.s32 %r16, %r15, 4294967295;
    sub.u32 %r16, %r6, 32;
    setp.le.s32 %p4, %r16, 5;
    @%p4 sub.u32 %r22, %r9, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
