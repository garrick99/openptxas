.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p4, %r3, 65536;
    @%p4 shr.u32 %r5, %r3, 1;
    cvt.s64.s32 %rd15, %r3;
    selp.b32 %r25, %r5, %r5, %p4;
    mul.lo.s64 %rd14, %rd15, %rd15;
    sub.u64 %rd5, %rd15, %rd15;
    sub.s32 %r26, %r5, %r25;
    add.s32 %r25, %r26, %r3;
    max.u32 %r22, %r25, 2;
    max.s32 %r15, %r25, %r5;
    mul.wide.u32 %rd11, %r25, %r15;
    shr.s64 %rd13, %rd15, 16;
    min.u32 %r22, %r3, 15;
    or.b32 %r5, %r22, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
