.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p1, %r3, 16;
    @%p1 min.u32 %r26, %r3, 8;
    selp.b32 %r12, %r3, %r26, %p1;
    and.b32 %r5, %r26, 0;
    max.u32 %r4, %r26, 2147483648;
    shr.s32 %r12, %r4, 3;
    selp.b32 %r13, %r4, %r26, %p1;
    max.s32 %r5, %r13, 4294967295;
    or.b32 %r7, %r26, 32;
    shr.u32 %r24, %r12, 16;
    or.b32 %r20, %r12, %r3;
    shr.u32 %r9, %r12, 2;
    cvt.s64.s32 %rd7, %r7;
    shr.s32 %r10, %r13, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
