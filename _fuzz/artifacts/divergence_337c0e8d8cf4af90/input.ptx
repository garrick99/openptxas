.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r13, %r3, %r3, %r3;
    cvt.u64.u32 %rd12, %r13;
    mad.lo.u32 %r24, %r13, %r3, %r3;
    add.u64 %rd10, %rd12, %rd12;
    and.b64 %rd5, %rd12, %rd12;
    cvt.u64.u32 %rd12, %r3;
    add.u32 %r18, %r3, %r3;
    add.s32 %r13, %r3, 8;
    xor.b32 %r26, %r24, %r18;
    setp.ls.u32 %p4, %r26, 255;
    @!%p4 cvt.u32.u64 %r23, %rd12;
    setp.lt.s32 %p1, %r18, 63;
    @!%p1 xor.b32 %r9, %r24, 7;
    cvt.s64.s32 %rd15, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
