.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    shl.b64 %rd11, %rd12, 0;
    mad.lo.s32 %r17, %r3, %r3, %r3;
    mul.lo.s32 %r20, %r3, 4294967295;
    or.b64 %rd11, %rd11, %rd11;
    shl.b32 %r7, %r17, 3;
    cvt.s32.s64 %r19, %rd12;
    or.b64 %rd10, %rd12, %rd11;
    shr.u32 %r6, %r3, 2;
    and.b32 %r12, %r6, %r19;
    mad.lo.u32 %r4, %r7, %r12, %r19;
    add.s32 %r8, %r7, %r12;
    and.b32 %r8, %r8, %r19;
    setp.lo.u32 %p2, %r17, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
