.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p3, %r3, 1;
    @!%p3 xor.b32 %r15, %r3, 31;
    mad.lo.s32 %r22, %r15, %r3, %r15;
    cvt.s64.s32 %rd6, %r15;
    mul.lo.s32 %r19, %r22, %r22;
    mad.lo.s32 %r25, %r22, %r3, %r15;
    setp.eq.u32 %p2, %r19, %r22;
    @!%p2 sub.s64 %rd13, %rd6, %rd6;
    mad.lo.s32 %r14, %r25, %r19, %r15;
    setp.lo.u32 %p2, %r15, %r25;
    @%p2 selp.b32 %r17, %r15, %r25, %p2;
    shl.b32 %r21, %r25, 16;
    sub.s64 %rd6, %rd6, %rd13;
    selp.b32 %r22, %r21, %r22, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
