.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r23, %r3, %r3, %r3;
    cvt.s64.s32 %rd14, %r3;
    max.u32 %r21, %r23, %r3;
    cvt.s32.s64 %r25, %rd14;
    sub.u32 %r20, %r3, 0;
    and.b32 %r14, %r3, 0;
    shl.b64 %rd15, %rd14, 47;
    add.s64 %rd8, %rd15, %rd14;
    mad.lo.u32 %r26, %r21, %r21, %r21;
    setp.ge.s32 %p2, %r20, 2;
    @!%p2 xor.b32 %r23, %r21, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
