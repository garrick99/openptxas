.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p4, %r3, 5;
    @%p4 min.s32 %r6, %r3, %r3;
    and.b32 %r9, %r6, 255;
    sub.s32 %r8, %r3, 256;
    mad.lo.s32 %r20, %r3, %r9, %r9;
    cvt.s64.s32 %rd6, %r3;
    and.b32 %r17, %r9, %r8;
    add.s64 %rd13, %rd6, %rd6;
    min.u64 %rd7, %rd6, %rd13;
    shl.b32 %r20, %r9, 3;
    min.s32 %r27, %r8, 2147483647;
    max.s32 %r13, %r6, 2147483647;
    selp.b32 %r26, %r8, %r20, %p4;
    mad.lo.u32 %r9, %r9, %r20, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
