.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p1, %r3, 4294967295;
    @%p1 min.u32 %r16, %r3, 63;
    mul.wide.u32 %rd15, %r3, %r16;
    mul.wide.u32 %rd12, %r3, %r3;
    setp.ne.u32 %p2, %r3, %r16;
    @%p2 shr.u32 %r6, %r3, 4;
    setp.lt.u32 %p4, %r6, %r6;
    max.s32 %r5, %r16, 1;
    shr.s64 %rd15, %rd15, 2;
    mul.lo.s32 %r7, %r16, 2147483648;
    setp.ge.s32 %p2, %r3, 255;
    @!%p2 xor.b32 %r11, %r16, %r6;
    max.s32 %r11, %r7, %r3;
    or.b64 %rd12, %rd15, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
