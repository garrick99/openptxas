.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r26, %r3, 256;
    cvt.u64.u32 %rd10, %r3;
    or.b64 %rd6, %rd10, %rd10;
    mul.wide.s32 %rd9, %r3, %r26;
    max.s64 %rd7, %rd9, %rd6;
    setp.lt.s32 %p4, %r3, %r3;
    @%p4 mad.lo.s32 %r27, %r26, %r26, %r26;
    mul.wide.u32 %rd8, %r27, %r3;
    and.b32 %r14, %r27, %r27;
    min.u64 %rd8, %rd7, %rd9;
    or.b64 %rd15, %rd10, %rd8;
    max.u64 %rd11, %rd7, %rd10;
    or.b32 %r8, %r14, %r27;
    max.s32 %r6, %r3, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
