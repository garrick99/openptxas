.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r16, %r3, 0;
    setp.gt.s32 %p3, %r3, 255;
    setp.lt.u32 %p3, %r3, 255;
    @%p3 cvt.s64.s32 %rd13, %r16;
    shr.u32 %r21, %r16, 15;
    selp.b32 %r21, %r21, %r16, %p3;
    mul.wide.u32 %rd13, %r16, %r3;
    add.u32 %r24, %r21, 3;
    selp.b32 %r24, %r24, %r21, %p3;
    shr.u64 %rd15, %rd13, 31;
    setp.ge.s32 %p1, %r16, 2147483648;
    @!%p1 shr.u64 %rd9, %rd15, 32;
    shl.b64 %rd6, %rd13, 2;
    setp.eq.s32 %p4, %r21, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
