.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r26, %r3, %r3;
    setp.ls.u32 %p4, %r3, 7;
    mul.lo.s32 %r20, %r26, %r3;
    mul.lo.u32 %r19, %r3, 15;
    selp.b32 %r9, %r3, %r26, %p4;
    cvt.u64.u32 %rd15, %r26;
    mul.lo.s32 %r13, %r9, %r26;
    shr.u32 %r26, %r13, 31;
    mad.lo.u32 %r24, %r3, %r13, %r26;
    cvt.u32.u64 %r8, %rd15;
    shl.b64 %rd7, %rd15, 48;
    add.u32 %r16, %r3, %r8;
    min.s32 %r4, %r20, %r20;
    mul.wide.u32 %rd5, %r13, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
