.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    setp.le.u32 %p4, %r3, 64;
    @%p4 and.b32 %r16, %r3, 2;
    xor.b64 %rd14, %rd9, %rd9;
    max.u32 %r20, %r16, 64;
    or.b32 %r26, %r16, %r3;
    mad.lo.s32 %r20, %r26, %r26, %r16;
    mul.wide.u32 %rd8, %r3, %r20;
    max.s32 %r14, %r3, 16;
    shr.u32 %r14, %r14, 31;
    max.u64 %rd14, %rd8, %rd8;
    shl.b32 %r21, %r20, 7;
    mul.wide.u32 %rd15, %r20, %r20;
    shr.s32 %r24, %r21, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
