.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    mul.lo.u32 %r24, %r3, 2147483647;
    sub.s32 %r24, %r3, %r3;
    cvt.s32.s64 %r8, %rd7;
    mul.lo.u32 %r10, %r24, %r3;
    add.s64 %rd10, %rd7, %rd7;
    sub.s32 %r26, %r8, %r10;
    max.u32 %r17, %r8, %r10;
    cvt.u32.u64 %r15, %rd10;
    shr.u32 %r5, %r26, 7;
    mad.lo.u32 %r24, %r3, %r26, %r8;
    xor.b32 %r17, %r10, %r3;
    shl.b32 %r27, %r15, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
