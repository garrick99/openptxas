    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p4, %r3, 32;
    @!%p4 mul.lo.u32 %r24, %r3, 2147483648;
    add.s32 %r13, %r24, 63;
    max.u32 %r18, %r3, 4294967295;
    add.s32 %r8, %r18, %r13;
    shr.s32 %r19, %r8, 1;
    mul.wide.s32 %rd7, %r8, %r24;
    and.b32 %r7, %r19, 256;
    min.s32 %r4, %r24, 2147483648;
    mad.lo.u32 %r22, %r24, %r19, %r19;
    or.b32 %r22, %r8, 65535;
    sub.s32 %r26, %r22, 65535;
    shr.s64 %rd15, %rd7, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
