.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r25, %r3, %r3, %r3;
    xor.b32 %r15, %r25, 3;
    cvt.u64.u32 %rd15, %r3;
    min.u32 %r23, %r15, 65535;
    cvt.u32.u64 %r21, %rd15;
    setp.gt.u32 %p3, %r23, %r21;
    min.u32 %r17, %r3, 3;
    shr.u32 %r20, %r3, 31;
    sub.u64 %rd9, %rd15, %rd15;
    sub.u32 %r25, %r20, %r21;
    xor.b32 %r8, %r20, %r17;
    and.b32 %r20, %r17, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
