.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r18, %r3, 4;
    setp.ls.u32 %p2, %r3, 15;
    @%p2 mad.lo.u32 %r22, %r3, %r3, %r3;
    mul.wide.s32 %rd7, %r3, %r22;
    add.u32 %r6, %r3, %r22;
    or.b32 %r14, %r3, %r22;
    shr.s32 %r27, %r22, 1;
    cvt.s64.s32 %rd12, %r14;
    max.s32 %r22, %r22, %r18;
    setp.eq.u32 %p1, %r3, 16;
    mul.wide.u32 %rd11, %r22, %r27;
    shr.s32 %r8, %r22, 0;
    max.u32 %r5, %r3, %r22;
    shr.s32 %r4, %r3, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
