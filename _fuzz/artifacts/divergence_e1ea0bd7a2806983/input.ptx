.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r26, %r3, 15;
    shl.b32 %r23, %r26, 4;
    min.u32 %r17, %r3, %r23;
    cvt.u64.u32 %rd13, %r23;
    max.u32 %r15, %r26, 65536;
    add.u32 %r27, %r23, %r3;
    setp.lt.s32 %p2, %r15, %r15;
    @!%p2 cvt.s32.s64 %r18, %rd13;
    selp.b32 %r24, %r18, %r3, %p2;
    mad.lo.s32 %r9, %r24, %r23, %r23;
    cvt.u64.u32 %rd14, %r23;
    and.b32 %r12, %r9, %r18;
    min.u32 %r22, %r26, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
