.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.down.b32 %r16, %r0, 2, 0x1f, -1;
    sub.u32 %r17, %r16, %r16;
    setp.gt.u32 %p1, %r0, 15;
    vote.sync.ballot.b32 %r18, %p1, -1;
    vote.sync.any.pred %p1, %p1, -1;
    shfl.sync.down.b32 %r19, %r16, 8, 0x1f, -1;
    and.b32 %r9, %r0, %r0;
    setp.gt.u32 %p1, %r3, %r9;
    vote.sync.ballot.b32 %r4, %p1, -1;
    setp.eq.u32 %p1, %r9, %r18;
    vote.sync.ballot.b32 %r5, %p1, -1;
    and.b32 %r14, %r18, %r0;
    add.u32 %r13, %r17, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
