.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r24, %r3, 8;
    and.b32 %r25, %r24, %r24;
    cvt.s64.s32 %rd7, %r3;
    cvt.s64.s32 %rd9, %r25;
    and.b32 %r27, %r25, 1;
    setp.gt.u32 %p2, %r25, %r25;
    @%p2 and.b32 %r18, %r27, %r24;
    mul.wide.s32 %rd15, %r27, %r25;
    mul.lo.u64 %rd10, %rd9, %rd7;
    selp.b32 %r27, %r3, %r25, %p2;
    max.s32 %r20, %r27, 65535;
    mad.lo.s32 %r13, %r25, %r25, %r20;
    mad.lo.s32 %r19, %r25, %r3, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
