.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r4, %r3, 7;
    mul.lo.u32 %r14, %r3, %r3;
    mul.wide.s32 %rd10, %r14, %r4;
    and.b64 %rd5, %rd10, %rd10;
    mul.lo.u32 %r25, %r4, 255;
    max.u64 %rd11, %rd10, %rd10;
    max.u64 %rd8, %rd5, %rd5;
    cvt.s32.s64 %r25, %rd8;
    mul.wide.s32 %rd7, %r4, %r25;
    shr.u32 %r9, %r25, 0;
    max.s32 %r17, %r4, %r9;
    cvt.s64.s32 %rd8, %r9;
    setp.lt.u32 %p4, %r17, %r9;
    @%p4 max.u32 %r22, %r25, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
