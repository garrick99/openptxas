.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    add.u32 %r20, %r3, %r3;
    sub.u32 %r25, %r3, %r20;
    setp.gt.s32 %p1, %r3, 31;
    @%p1 max.s32 %r17, %r25, %r20;
    cvt.u32.u64 %r14, %rd5;
    mul.lo.u64 %rd11, %rd5, %rd5;
    add.s32 %r20, %r25, %r14;
    shl.b32 %r18, %r14, 3;
    add.s32 %r20, %r20, %r17;
    mad.lo.s32 %r26, %r20, %r18, %r3;
    mul.wide.u32 %rd14, %r20, %r20;
    max.s32 %r17, %r26, %r18;
    or.b32 %r5, %r3, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
