.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    shr.u64 %rd5, %rd14, 30;
    and.b32 %r22, %r3, %r3;
    shl.b32 %r18, %r22, 30;
    sub.u32 %r25, %r22, %r18;
    mul.wide.u32 %rd15, %r22, %r3;
    shl.b32 %r14, %r18, 7;
    setp.gt.s32 %p3, %r18, %r14;
    and.b64 %rd9, %rd5, %rd15;
    min.u32 %r24, %r18, 4;
    setp.ge.s32 %p1, %r14, 3;
    @!%p1 max.u32 %r10, %r25, 2147483648;
    selp.b32 %r4, %r14, %r10, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
