.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd12, %r3, %r3;
    xor.b32 %r4, %r3, %r3;
    setp.ge.s32 %p2, %r4, 7;
    @%p2 selp.b32 %r19, %r3, %r4, %p2;
    shr.s32 %r19, %r4, 16;
    mul.wide.u32 %rd9, %r19, %r3;
    selp.b32 %r13, %r3, %r4, %p2;
    max.s32 %r17, %r3, 5;
    mad.lo.u32 %r5, %r17, %r13, %r19;
    sub.s32 %r24, %r19, %r4;
    add.s32 %r13, %r5, %r3;
    mul.wide.s32 %rd7, %r13, %r19;
    add.u32 %r16, %r4, %r17;
    setp.le.u32 %p1, %r19, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
