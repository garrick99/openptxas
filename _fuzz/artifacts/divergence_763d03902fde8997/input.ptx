.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    setp.hi.u32 %p3, %r3, %r3;
    @%p3 mad.lo.u32 %r11, %r3, %r3, %r3;
    mul.wide.s32 %rd15, %r11, %r11;
    shl.b32 %r10, %r11, 31;
    xor.b64 %rd15, %rd15, %rd10;
    mad.lo.s32 %r9, %r11, %r3, %r10;
    selp.b32 %r15, %r9, %r9, %p3;
    selp.b32 %r13, %r10, %r9, %p3;
    selp.b32 %r14, %r15, %r9, %p3;
    or.b32 %r11, %r14, 32;
    min.u64 %rd10, %rd10, %rd10;
    setp.gt.s32 %p3, %r14, %r13;
    @!%p3 min.s32 %r15, %r11, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
