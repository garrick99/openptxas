.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p1, %r3, %r3;
    @!%p1 cvt.s64.s32 %rd10, %r3;
    mul.wide.s32 %rd7, %r3, %r3;
    mul.wide.s32 %rd13, %r3, %r3;
    min.u64 %rd15, %rd7, %rd10;
    shl.b64 %rd12, %rd13, 15;
    selp.b32 %r11, %r3, %r3, %p1;
    min.u32 %r27, %r11, %r3;
    cvt.s32.s64 %r10, %rd10;
    mul.lo.s32 %r5, %r10, %r10;
    min.u32 %r12, %r5, 0;
    cvt.s32.s64 %r17, %rd15;
    setp.le.s32 %p4, %r10, %r3;
    @!%p4 mad.lo.s32 %r25, %r5, %r3, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
