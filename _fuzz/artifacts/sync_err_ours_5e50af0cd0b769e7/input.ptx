.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    setp.gt.s32 %p1, %r3, 4;
    @!%p1 xor.b32 %r26, %r3, %r3;
    setp.ls.u32 %p4, %r26, %r3;
    @%p4 shr.u64 %rd9, %rd5, 48;
    max.s64 %rd7, %rd9, %rd5;
    setp.lt.u32 %p1, %r3, %r3;
    @%p1 sub.u32 %r19, %r3, 63;
    mad.lo.u32 %r12, %r26, %r19, %r26;
    setp.le.s32 %p1, %r12, 2;
    @!%p1 min.u64 %rd7, %rd5, %rd7;
    min.s32 %r24, %r26, %r12;
    and.b32 %r24, %r12, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
