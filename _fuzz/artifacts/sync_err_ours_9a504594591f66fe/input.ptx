.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r16, %r3, 5;
    add.s32 %r24, %r16, %r16;
    shr.u32 %r9, %r24, 7;
    mad.lo.u32 %r7, %r16, %r24, %r16;
    cvt.u64.u32 %rd11, %r24;
    shl.b32 %r21, %r9, 0;
    min.u32 %r6, %r16, %r24;
    shl.b32 %r8, %r7, 16;
    or.b32 %r16, %r9, %r21;
    mad.lo.u32 %r22, %r6, %r24, %r16;
    shl.b32 %r27, %r8, 4;
    add.s64 %rd11, %rd11, %rd11;
    mul.lo.u32 %r19, %r16, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
