.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p4, %r3, 255;
    setp.eq.u32 %p4, %r3, %r3;
    @!%p4 sub.s32 %r21, %r3, %r3;
    min.s32 %r19, %r21, 64;
    mad.lo.u32 %r25, %r21, %r21, %r3;
    cvt.u64.u32 %rd5, %r19;
    and.b32 %r7, %r25, 31;
    shr.u64 %rd13, %rd5, 62;
    max.s64 %rd13, %rd5, %rd5;
    max.u32 %r4, %r19, %r21;
    max.s64 %rd10, %rd5, %rd5;
    cvt.u32.u64 %r18, %rd10;
    setp.ge.s32 %p1, %r18, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
