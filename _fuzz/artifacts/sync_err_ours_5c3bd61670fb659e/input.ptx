.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    min.u32 %r11, %r3, 5;
    cvt.s64.s32 %rd7, %r11;
    mul.lo.s32 %r5, %r11, 8;
    shr.u64 %rd15, %rd13, 15;
    cvt.s32.s64 %r15, %rd13;
    shr.u32 %r22, %r11, 31;
    mul.lo.u32 %r20, %r15, %r15;
    add.u32 %r15, %r11, %r22;
    mul.wide.s32 %rd5, %r22, %r20;
    shr.s64 %rd6, %rd15, 16;
    sub.s32 %r5, %r3, %r11;
    or.b64 %rd14, %rd5, %rd13;
    mad.lo.u32 %r17, %r11, %r5, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
