.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r15, %r3, 16;
    cvt.s64.s32 %rd11, %r15;
    setp.ge.s32 %p2, %r15, 0;
    @%p2 shr.u32 %r22, %r3, 2;
    mad.lo.s32 %r17, %r22, %r15, %r22;
    max.s32 %r16, %r3, %r15;
    mul.wide.u32 %rd13, %r16, %r3;
    shr.s32 %r19, %r15, 16;
    and.b32 %r5, %r16, %r19;
    mul.wide.s32 %rd9, %r16, %r17;
    max.u32 %r9, %r5, %r16;
    selp.b32 %r26, %r5, %r17, %p2;
    cvt.u64.u32 %rd14, %r19;
    mul.wide.u32 %rd15, %r3, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
