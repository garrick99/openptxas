.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd5, %r3, %r3;
    max.s32 %r20, %r3, 8;
    mul.lo.u32 %r24, %r3, 32;
    add.u32 %r8, %r20, 1;
    sub.s32 %r24, %r24, %r3;
    shr.u32 %r6, %r24, 4;
    cvt.u32.u64 %r20, %rd5;
    add.s64 %rd15, %rd5, %rd5;
    min.s32 %r11, %r20, %r8;
    cvt.s32.s64 %r27, %rd15;
    mad.lo.s32 %r19, %r20, %r3, %r20;
    setp.gt.s32 %p2, %r8, %r24;
    @%p2 mul.lo.u32 %r5, %r3, 15;
    and.b32 %r7, %r27, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
