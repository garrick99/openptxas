.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r22, %r3, %r3;
    cvt.u64.u32 %rd12, %r22;
    max.u64 %rd6, %rd12, %rd12;
    setp.lt.s32 %p1, %r22, %r3;
    @%p1 add.u32 %r19, %r22, 0;
    mul.lo.s32 %r19, %r22, %r22;
    mul.wide.s32 %rd6, %r3, %r19;
    shl.b64 %rd15, %rd12, 15;
    cvt.u64.u32 %rd12, %r22;
    xor.b32 %r5, %r19, 8;
    add.u32 %r21, %r19, %r3;
    cvt.s64.s32 %rd15, %r21;
    setp.ge.s32 %p3, %r3, 0;
    @%p3 mad.lo.u32 %r8, %r19, %r19, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
