.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p1, %r3, 4;
    @%p1 cvt.s64.s32 %rd12, %r3;
    mad.lo.u32 %r22, %r3, %r3, %r3;
    add.s32 %r8, %r22, %r22;
    add.u32 %r5, %r8, %r22;
    setp.ne.u32 %p4, %r8, 64;
    add.s64 %rd15, %rd12, %rd12;
    max.u32 %r20, %r3, %r5;
    mul.lo.u32 %r6, %r3, %r5;
    cvt.s32.s64 %r24, %rd15;
    sub.s32 %r20, %r20, %r8;
    mad.lo.u32 %r13, %r24, %r24, %r24;
    sub.u32 %r10, %r5, %r20;
    sub.s64 %rd11, %rd12, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
