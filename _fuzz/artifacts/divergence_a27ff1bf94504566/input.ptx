.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    cvt.s32.s64 %r10, %rd14;
    shr.u32 %r17, %r3, 7;
    add.s32 %r21, %r3, 0;
    shr.s64 %rd15, %rd14, 4;
    xor.b64 %rd15, %rd15, %rd15;
    mad.lo.u32 %r26, %r3, %r21, %r10;
    xor.b32 %r25, %r10, %r17;
    mad.lo.u32 %r22, %r26, %r10, %r26;
    shl.b32 %r11, %r26, 15;
    mul.lo.s32 %r11, %r10, 5;
    sub.u32 %r21, %r22, %r3;
    mul.lo.u32 %r6, %r10, %r3;
    mul.lo.s32 %r20, %r22, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
