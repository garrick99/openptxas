.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r4, %r3, %r3;
    mul.lo.s32 %r11, %r3, %r4;
    and.b32 %r4, %r3, 2;
    shl.b32 %r17, %r3, 1;
    cvt.u64.u32 %rd9, %r11;
    shr.u32 %r7, %r4, 31;
    setp.ne.s32 %p2, %r7, %r7;
    selp.b32 %r19, %r7, %r11, %p2;
    cvt.s32.s64 %r23, %rd9;
    and.b32 %r26, %r23, 4;
    xor.b32 %r26, %r19, 0;
    and.b32 %r27, %r26, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
