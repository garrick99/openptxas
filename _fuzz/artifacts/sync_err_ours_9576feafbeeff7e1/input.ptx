.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r26, %r3, %r3;
    cvt.u64.u32 %rd12, %r26;
    min.s64 %rd11, %rd12, %rd12;
    sub.s32 %r11, %r3, %r26;
    mad.lo.u32 %r27, %r26, %r26, %r11;
    min.s32 %r24, %r26, 16;
    mad.lo.u32 %r22, %r24, %r26, %r24;
    shr.u32 %r21, %r22, 15;
    shr.u64 %rd12, %rd11, 63;
    max.u32 %r4, %r27, 31;
    min.s32 %r20, %r11, 31;
    cvt.s32.s64 %r10, %rd11;
    add.u32 %r7, %r11, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
