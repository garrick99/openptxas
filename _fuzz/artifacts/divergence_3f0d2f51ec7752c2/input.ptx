.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r20, %r3, 31;
    cvt.s64.s32 %rd9, %r3;
    sub.s64 %rd6, %rd9, %rd9;
    mul.lo.s32 %r17, %r20, %r20;
    min.s32 %r6, %r3, 63;
    or.b32 %r19, %r3, 256;
    setp.ge.s32 %p2, %r20, 16;
    setp.eq.u32 %p4, %r6, %r6;
    setp.hs.u32 %p4, %r20, 256;
    @!%p4 cvt.s32.s64 %r6, %rd6;
    shl.b64 %rd7, %rd9, 47;
    selp.b32 %r25, %r3, %r3, %p4;
    selp.b32 %r18, %r19, %r3, %p2;
    selp.b32 %r11, %r25, %r6, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
