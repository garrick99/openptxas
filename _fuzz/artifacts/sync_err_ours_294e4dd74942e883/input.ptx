.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r4, %r3, 64;
    add.u32 %r17, %r3, %r4;
    add.u32 %r16, %r3, 2147483648;
    or.b32 %r15, %r16, %r4;
    cvt.u64.u32 %rd6, %r15;
    shr.u32 %r5, %r15, 1;
    min.s64 %rd15, %rd6, %rd6;
    mad.lo.s32 %r23, %r17, %r3, %r4;
    shl.b32 %r23, %r4, 30;
    max.s32 %r22, %r23, %r16;
    mul.wide.s32 %rd10, %r5, %r22;
    mul.lo.u64 %rd10, %rd15, %rd10;
    setp.eq.s32 %p2, %r23, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
