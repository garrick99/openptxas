.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p1, %r3, %r3;
    @%p1 min.u32 %r20, %r3, %r3;
    min.u32 %r18, %r20, %r3;
    cvt.u64.u32 %rd13, %r18;
    sub.s32 %r24, %r20, %r18;
    and.b32 %r24, %r18, 65536;
    cvt.s32.s64 %r6, %rd13;
    cvt.u64.u32 %rd9, %r24;
    shr.u32 %r23, %r24, 1;
    shl.b64 %rd5, %rd13, 7;
    cvt.u64.u32 %rd12, %r24;
    cvt.s32.s64 %r8, %rd12;
    shr.s32 %r17, %r8, 1;
    sub.s32 %r9, %r3, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
