.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd7, %r3, %r3;
    cvt.s64.s32 %rd7, %r3;
    mad.lo.s32 %r27, %r3, %r3, %r3;
    shr.s64 %rd12, %rd7, 4;
    mad.lo.s32 %r15, %r3, %r27, %r27;
    setp.gt.s32 %p2, %r3, %r27;
    @%p2 min.s32 %r17, %r27, 5;
    cvt.s64.s32 %rd8, %r3;
    min.u32 %r18, %r17, 65536;
    sub.u32 %r25, %r18, 65536;
    shr.u64 %rd7, %rd7, 62;
    sub.u32 %r13, %r27, %r25;
    shr.u32 %r20, %r17, 4;
    shr.s64 %rd6, %rd12, 47;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
