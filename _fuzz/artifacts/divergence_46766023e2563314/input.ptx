.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd14, %r3, %r3;
    or.b32 %r8, %r3, 65535;
    shr.s32 %r7, %r8, 0;
    setp.le.u32 %p3, %r8, %r3;
    @!%p3 mul.lo.s32 %r17, %r8, 65535;
    mad.lo.s32 %r18, %r17, %r7, %r7;
    shl.b64 %rd14, %rd14, 33;
    selp.b32 %r27, %r7, %r18, %p3;
    add.u32 %r21, %r7, 256;
    shr.u32 %r6, %r27, 7;
    add.u32 %r26, %r8, %r7;
    mul.wide.s32 %rd5, %r17, %r6;
    setp.ne.s32 %p2, %r26, 3;
    @%p2 max.s32 %r14, %r8, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
