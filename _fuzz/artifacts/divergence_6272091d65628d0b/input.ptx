.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r11, %r3, 32;
    add.s32 %r15, %r3, %r3;
    cvt.s64.s32 %rd6, %r3;
    mad.lo.u32 %r7, %r15, %r11, %r15;
    shr.u32 %r4, %r15, 1;
    shr.u32 %r13, %r11, 1;
    xor.b64 %rd8, %rd6, %rd6;
    xor.b32 %r14, %r3, %r7;
    mul.wide.s32 %rd12, %r3, %r11;
    setp.lt.s32 %p1, %r11, %r3;
    @%p1 or.b32 %r6, %r4, %r7;
    sub.s32 %r13, %r6, 0;
    xor.b32 %r8, %r7, 0;
    mad.lo.u32 %r23, %r14, %r11, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
