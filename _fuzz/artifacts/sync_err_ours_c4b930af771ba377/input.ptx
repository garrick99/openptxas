.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r21, %r3, %r3;
    shl.b32 %r15, %r21, 31;
    shl.b32 %r12, %r3, 31;
    cvt.s64.s32 %rd5, %r3;
    mad.lo.s32 %r12, %r12, %r15, %r3;
    cvt.u32.u64 %r9, %rd5;
    min.u32 %r26, %r12, 255;
    sub.u32 %r12, %r3, 63;
    shr.s64 %rd12, %rd5, 31;
    mul.wide.u32 %rd15, %r9, %r15;
    sub.s32 %r19, %r3, 15;
    add.u32 %r23, %r15, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
