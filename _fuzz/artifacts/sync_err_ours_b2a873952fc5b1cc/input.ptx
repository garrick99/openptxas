.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r20, %r3, 3;
    and.b32 %r18, %r20, 1;
    sub.s32 %r16, %r18, 16;
    and.b32 %r15, %r16, 32;
    and.b32 %r11, %r15, %r20;
    mad.lo.s32 %r20, %r15, %r15, %r18;
    shl.b32 %r11, %r20, 30;
    cvt.s64.s32 %rd14, %r16;
    cvt.u64.u32 %rd8, %r18;
    shl.b64 %rd12, %rd8, 32;
    mad.lo.s32 %r17, %r18, %r16, %r18;
    mul.lo.u32 %r12, %r15, %r18;
    mad.lo.u32 %r27, %r11, %r3, %r11;
    setp.le.u32 %p4, %r3, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
