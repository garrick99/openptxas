.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r6, %r3, 15;
    cvt.u64.u32 %rd9, %r6;
    max.s64 %rd11, %rd9, %rd9;
    mul.wide.s32 %rd14, %r3, %r6;
    mul.wide.u32 %rd8, %r3, %r6;
    shr.s32 %r23, %r3, 0;
    mul.wide.s32 %rd5, %r6, %r3;
    setp.le.u32 %p4, %r23, %r3;
    max.u64 %rd7, %rd14, %rd5;
    sub.u32 %r25, %r23, %r6;
    selp.b32 %r27, %r6, %r23, %p4;
    add.s64 %rd15, %rd9, %rd5;
    max.u32 %r8, %r27, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
