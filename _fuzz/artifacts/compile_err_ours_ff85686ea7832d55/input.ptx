    ld.global.u32 %r3, [%rd2];
    add.u32 %r4, %r3, %r0;
    shfl.sync.bfly.b32 %r11, %r0, 2, 0x1f, -1;
    setp.ge.u32 %p3, %r0, 4294967295;
    vote.sync.ballot.b32 %r4, %p3, -1;
    shfl.sync.bfly.b32 %r17, %r11, 16, 0x1f, -1;
