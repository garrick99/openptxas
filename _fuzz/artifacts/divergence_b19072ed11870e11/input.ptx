.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r13, %r3, %r3;
    shr.u32 %r19, %r3, 15;
    sub.u32 %r24, %r13, %r3;
    shr.u32 %r26, %r24, 7;
    setp.ge.s32 %p2, %r13, 64;
    @%p2 xor.b32 %r11, %r24, %r26;
    max.s32 %r22, %r11, %r11;
    cvt.s64.s32 %rd8, %r24;
    cvt.s32.s64 %r21, %rd8;
    min.u32 %r22, %r26, %r11;
    mul.lo.s32 %r20, %r21, %r3;
    xor.b64 %rd12, %rd8, %rd8;
    shl.b32 %r19, %r11, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
