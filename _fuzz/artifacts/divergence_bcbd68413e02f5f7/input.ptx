.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    mul.lo.u64 %rd12, %rd5, %rd5;
    shl.b64 %rd8, %rd12, 63;
    sub.s32 %r12, %r3, 32;
    mul.lo.s64 %rd5, %rd8, %rd8;
    max.s64 %rd6, %rd12, %rd8;
    min.s32 %r4, %r12, %r3;
    mul.lo.u32 %r24, %r3, 15;
    max.u32 %r6, %r24, %r12;
    shr.s64 %rd10, %rd5, 48;
    setp.le.s32 %p1, %r3, %r6;
    @!%p1 and.b32 %r20, %r4, 63;
    max.u32 %r19, %r20, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
