.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r26, %r3, %r3;
    min.s32 %r8, %r26, 65535;
    max.s32 %r22, %r3, %r3;
    cvt.s64.s32 %rd15, %r3;
    mul.lo.s32 %r12, %r8, 0;
    setp.ge.s32 %p2, %r12, %r26;
    @%p2 mad.lo.u32 %r8, %r26, %r8, %r26;
    mul.lo.s32 %r4, %r8, %r26;
    mul.lo.u32 %r24, %r3, 65536;
    shr.s32 %r17, %r22, 1;
    min.s32 %r26, %r22, %r22;
    cvt.u32.u64 %r22, %rd15;
    mad.lo.s32 %r17, %r4, %r3, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
