.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p2, %r3, %r3;
    @%p2 shr.u32 %r12, %r3, 2;
    or.b32 %r13, %r3, %r12;
    cvt.s64.s32 %rd7, %r13;
    cvt.s32.s64 %r23, %rd7;
    setp.le.u32 %p2, %r13, %r3;
    @%p2 min.s64 %rd15, %rd7, %rd7;
    cvt.s32.s64 %r13, %rd15;
    shr.u32 %r27, %r12, 15;
    or.b32 %r5, %r27, 64;
    sub.s32 %r22, %r27, %r23;
    and.b32 %r21, %r27, %r13;
    add.s64 %rd14, %rd7, %rd15;
    min.u32 %r27, %r13, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
