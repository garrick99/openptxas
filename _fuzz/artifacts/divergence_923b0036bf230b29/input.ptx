.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r22, %r3, %r3, %r3;
    mul.wide.s32 %rd11, %r3, %r3;
    shr.s64 %rd14, %rd11, 7;
    or.b32 %r16, %r22, %r3;
    max.u32 %r22, %r16, 2;
    shl.b32 %r15, %r16, 30;
    xor.b32 %r26, %r16, %r3;
    xor.b32 %r4, %r15, 1;
    cvt.s32.s64 %r13, %rd11;
    max.u32 %r16, %r4, %r22;
    shl.b32 %r17, %r16, 15;
    setp.lo.u32 %p3, %r15, 15;
    @%p3 shr.u32 %r27, %r4, 0;
    sub.u32 %r13, %r27, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
