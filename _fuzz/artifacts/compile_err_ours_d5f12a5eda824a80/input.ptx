.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r8, %r0, %r3;
    sub.u32 %r5, %r3, %r0;
    setp.eq.u32 %p3, %r8, 65535;
    vote.sync.ballot.b32 %r9, %p3, -1;
    shfl.sync.up.b32 %r6, %r0, 2, 0x1f, -1;
    vote.sync.any.pred %p1, %p3, -1;
    vote.sync.all.pred %p2, %p1, -1;
    vote.sync.any.pred %p2, %p2, -1;
    setp.ge.u32 %p1, %r0, 2;
    vote.sync.ballot.b32 %r19, %p1, -1;
    setp.eq.u32 %p1, %r3, %r19;
    vote.sync.ballot.b32 %r13, %p1, -1;
    shfl.sync.down.b32 %r17, %r19, 4, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
