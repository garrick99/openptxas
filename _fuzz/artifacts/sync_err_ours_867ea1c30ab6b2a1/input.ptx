.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r16, %r3, 0;
    setp.lt.u32 %p4, %r3, 255;
    @%p4 add.s32 %r9, %r3, 2147483648;
    mad.lo.s32 %r4, %r16, %r9, %r9;
    max.s32 %r11, %r9, %r3;
    cvt.s64.s32 %rd10, %r9;
    xor.b32 %r24, %r3, 255;
    mul.lo.s32 %r19, %r11, %r16;
    mul.lo.u64 %rd7, %rd10, %rd10;
    min.s32 %r26, %r11, %r3;
    selp.b32 %r26, %r26, %r24, %p4;
    add.s64 %rd6, %rd7, %rd10;
    setp.lt.s32 %p4, %r16, 7;
    @%p4 mul.wide.s32 %rd15, %r4, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
