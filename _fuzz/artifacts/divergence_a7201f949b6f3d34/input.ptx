.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r27, %r3, %r3;
    and.b32 %r4, %r3, 64;
    mul.wide.s32 %rd12, %r4, %r4;
    setp.hs.u32 %p2, %r3, %r3;
    max.u32 %r14, %r3, %r4;
    shl.b32 %r9, %r4, 3;
    sub.u64 %rd5, %rd12, %rd12;
    sub.s32 %r19, %r14, 255;
    shr.u64 %rd7, %rd12, 15;
    shl.b32 %r24, %r4, 30;
    mul.wide.u32 %rd6, %r4, %r9;
    shr.u32 %r13, %r14, 16;
    mad.lo.s32 %r19, %r14, %r27, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
