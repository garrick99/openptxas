.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p3, %r3, 5;
    @%p3 and.b32 %r20, %r3, %r3;
    cvt.s64.s32 %rd6, %r3;
    cvt.u32.u64 %r24, %rd6;
    sub.s32 %r21, %r3, 255;
    setp.lt.u32 %p1, %r24, 32;
    @%p1 xor.b32 %r23, %r24, %r24;
    cvt.u32.u64 %r19, %rd6;
    add.s32 %r22, %r19, %r21;
    selp.b32 %r5, %r23, %r3, %p3;
    setp.ne.u32 %p3, %r21, %r20;
    shr.u64 %rd8, %rd6, 0;
    mul.lo.s32 %r9, %r22, %r5;
    cvt.u64.u32 %rd11, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
