.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r8, %r3, 0;
    or.b32 %r13, %r8, 8;
    min.u32 %r27, %r3, %r3;
    cvt.u64.u32 %rd8, %r13;
    shr.s32 %r6, %r8, 30;
    setp.eq.s32 %p2, %r13, 7;
    max.u32 %r27, %r6, %r3;
    setp.lt.u32 %p1, %r6, %r6;
    @%p1 mad.lo.s32 %r15, %r8, %r27, %r3;
    or.b32 %r11, %r3, %r8;
    shr.u32 %r26, %r15, 0;
    add.s32 %r8, %r3, %r8;
    shl.b32 %r18, %r26, 4;
    add.u32 %r13, %r15, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
