.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd7, %r3, %r3;
    mul.lo.s64 %rd10, %rd7, %rd7;
    setp.hi.u32 %p3, %r3, %r3;
    @!%p3 mad.lo.s32 %r16, %r3, %r3, %r3;
    mul.lo.s32 %r24, %r3, 1;
    mul.wide.s32 %rd13, %r3, %r16;
    mul.lo.u32 %r8, %r16, %r16;
    or.b32 %r13, %r24, %r24;
    cvt.u32.u64 %r23, %rd13;
    max.s32 %r16, %r13, 8;
    selp.b32 %r25, %r16, %r24, %p3;
    setp.ge.s32 %p2, %r8, 2147483648;
    and.b32 %r18, %r3, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
