.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r4, %r3, %r3;
    max.u32 %r22, %r3, 5;
    cvt.s64.s32 %rd10, %r22;
    cvt.u64.u32 %rd5, %r4;
    cvt.s32.s64 %r22, %rd5;
    xor.b32 %r8, %r4, 3;
    shr.s64 %rd14, %rd5, 7;
    min.u32 %r27, %r8, %r3;
    mad.lo.s32 %r11, %r4, %r4, %r27;
    shl.b32 %r6, %r8, 4;
    sub.u32 %r26, %r3, %r22;
    max.s32 %r6, %r8, %r6;
    and.b32 %r22, %r22, 4;
    mul.wide.s32 %rd15, %r11, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
