.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p3, %r3, %r3;
    @%p3 or.b32 %r10, %r3, %r3;
    add.u32 %r27, %r3, %r3;
    cvt.s64.s32 %rd6, %r3;
    cvt.s64.s32 %rd5, %r10;
    cvt.u64.u32 %rd15, %r3;
    sub.u32 %r19, %r27, %r3;
    mul.wide.u32 %rd7, %r3, %r19;
    mul.wide.u32 %rd6, %r10, %r19;
    max.s64 %rd14, %rd5, %rd6;
    add.s64 %rd8, %rd15, %rd15;
    shl.b64 %rd9, %rd8, 4;
    xor.b32 %r17, %r19, %r19;
    min.s64 %rd9, %rd7, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
