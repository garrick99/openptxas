.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r11, %r3, %r3;
    mul.lo.s32 %r11, %r3, %r11;
    shr.s32 %r9, %r3, 4;
    shl.b32 %r17, %r9, 4;
    mul.lo.u32 %r25, %r11, 4;
    add.u32 %r20, %r25, %r3;
    shr.s32 %r11, %r20, 16;
    sub.s32 %r22, %r20, %r11;
    mad.lo.u32 %r15, %r11, %r20, %r22;
    mul.wide.u32 %rd8, %r25, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
