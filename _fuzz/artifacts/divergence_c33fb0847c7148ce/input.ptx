.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    max.u32 %r4, %r3, 4;
    xor.b32 %r17, %r4, %r4;
    mul.lo.u32 %r15, %r17, 63;
    xor.b32 %r5, %r15, %r3;
    cvt.u32.u64 %r12, %rd9;
    shl.b32 %r17, %r3, 1;
    setp.le.s32 %p1, %r4, %r15;
    mul.wide.u32 %rd8, %r17, %r4;
    and.b32 %r8, %r12, %r4;
    and.b32 %r18, %r5, 16;
    max.u32 %r14, %r5, 63;
    sub.u32 %r19, %r18, %r17;
    sub.u32 %r9, %r14, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
