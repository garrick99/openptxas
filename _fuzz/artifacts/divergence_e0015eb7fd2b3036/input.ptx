.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r25, %r3, %r3;
    mad.lo.s32 %r27, %r3, %r3, %r25;
    shr.u32 %r7, %r25, 16;
    mul.lo.s32 %r19, %r3, %r27;
    and.b32 %r24, %r3, 256;
    min.s32 %r23, %r27, 32;
    setp.hs.u32 %p2, %r7, %r27;
    @!%p2 add.s32 %r7, %r3, 4;
    cvt.s64.s32 %rd14, %r24;
    mad.lo.u32 %r8, %r7, %r24, %r25;
    setp.hs.u32 %p1, %r24, 16;
    mul.lo.s32 %r10, %r23, %r7;
    add.u32 %r24, %r7, 1;
    min.u64 %rd13, %rd14, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
