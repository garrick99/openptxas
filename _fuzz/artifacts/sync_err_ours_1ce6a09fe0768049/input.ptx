.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r27, %r3, 3;
    xor.b32 %r23, %r27, 255;
    mul.lo.s32 %r11, %r23, 255;
    setp.ge.s32 %p3, %r23, %r27;
    @%p3 shr.u32 %r18, %r3, 3;
    mul.wide.u32 %rd7, %r3, %r11;
    mad.lo.s32 %r8, %r27, %r23, %r23;
    selp.b32 %r14, %r27, %r27, %p3;
    max.u64 %rd14, %rd7, %rd7;
    mul.wide.s32 %rd12, %r18, %r14;
    shr.u32 %r9, %r18, 7;
    min.u32 %r14, %r11, %r14;
    shr.u64 %rd6, %rd7, 47;
    mul.wide.u32 %rd12, %r3, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
