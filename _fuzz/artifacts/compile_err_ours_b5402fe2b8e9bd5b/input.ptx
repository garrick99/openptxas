.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r18, %r3, %r3;
    setp.ne.u32 %p1, %r18, 31;
    vote.sync.ballot.b32 %r10, %p1, -1;
    shfl.sync.down.b32 %r6, %r18, 4, 0x1f, -1;
    shfl.sync.down.b32 %r17, %r6, 4, 0x1f, -1;
    shfl.sync.up.b32 %r6, %r6, 2, 0x1f, -1;
    shfl.sync.down.b32 %r5, %r18, 4, 0x1f, -1;
    vote.sync.any.pred %p2, %p1, -1;
    setp.lt.u32 %p1, %r17, 7;
    vote.sync.ballot.b32 %r17, %p1, -1;
    vote.sync.any.pred %p2, %p1, -1;
    max.u32 %r8, %r3, %r0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
