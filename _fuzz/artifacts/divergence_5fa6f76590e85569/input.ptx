.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    shr.s32 %r10, %r3, 3;
    sub.s32 %r11, %r10, %r10;
    shr.s64 %rd9, %rd8, 30;
    and.b64 %rd6, %rd8, %rd9;
    min.s32 %r19, %r11, %r3;
    cvt.u32.u64 %r5, %rd6;
    setp.lo.u32 %p4, %r11, %r5;
    @%p4 min.u32 %r8, %r11, 2147483648;
    shr.s32 %r8, %r8, 30;
    max.s32 %r26, %r8, %r3;
    mul.wide.u32 %rd12, %r26, %r10;
    mad.lo.u32 %r11, %r5, %r8, %r19;
    min.s32 %r21, %r8, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
