.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    sub.u64 %rd10, %rd9, %rd9;
    and.b32 %r5, %r3, %r3;
    mad.lo.s32 %r12, %r3, %r5, %r5;
    setp.lt.s32 %p1, %r3, %r3;
    @%p1 shr.s64 %rd5, %rd10, 15;
    selp.b32 %r24, %r5, %r5, %p1;
    min.u32 %r14, %r24, %r3;
    cvt.u64.u32 %rd7, %r14;
    shr.u32 %r14, %r5, 15;
    setp.hs.u32 %p2, %r12, 8;
    add.u32 %r21, %r3, %r3;
    setp.eq.u32 %p4, %r24, %r12;
    cvt.u32.u64 %r15, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
