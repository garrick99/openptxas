.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r15, %r3, %r3;
    add.s32 %r22, %r15, %r15;
    cvt.s64.s32 %rd5, %r15;
    min.s32 %r13, %r15, 31;
    mul.lo.u32 %r18, %r13, %r13;
    mul.lo.s64 %rd10, %rd5, %rd5;
    add.s32 %r13, %r18, %r15;
    min.u32 %r22, %r13, %r15;
    setp.ge.s32 %p3, %r3, 16;
    mul.lo.s32 %r23, %r13, %r22;
    sub.s32 %r16, %r3, 15;
    sub.u32 %r23, %r13, %r22;
    add.s64 %rd9, %rd10, %rd10;
    setp.ne.s32 %p1, %r13, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
