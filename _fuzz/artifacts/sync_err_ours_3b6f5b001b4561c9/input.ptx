.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfe.u32 %r12, %r3, 1, 8;
    brev.b32 %r16, %r12;
    bfe.s32 %r10, %r16, 0, 32;
    clz.b32 %r7, %r3;
    bfi.b32 %r4, %r3, %r10, 23, 31;
    brev.b32 %r21, %r16;
    max.u32 %r19, %r10, 256;
    bfe.s32 %r11, %r3, 8, 31;
    bfe.u32 %r23, %r19, 1, 2;
    brev.b32 %r18, %r3;
    bfe.u32 %r14, %r3, 16, 16;
    popc.b32 %r15, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
