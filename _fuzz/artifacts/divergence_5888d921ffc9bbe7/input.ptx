.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p4, %r3, %r3;
    @%p4 max.s32 %r8, %r3, %r3;
    add.u32 %r9, %r3, %r8;
    shr.s32 %r16, %r9, 1;
    shr.s32 %r13, %r8, 30;
    mul.lo.s32 %r25, %r13, %r9;
    setp.ge.u32 %p1, %r16, 65535;
    @!%p1 shr.u32 %r22, %r3, 31;
    setp.ge.s32 %p1, %r8, 16;
    @%p1 sub.u32 %r4, %r16, %r3;
    min.u32 %r7, %r9, 8;
    xor.b32 %r18, %r25, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
