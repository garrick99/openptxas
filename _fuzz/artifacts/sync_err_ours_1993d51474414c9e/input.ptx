.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p3, %r3, %r3;
    @%p3 mul.wide.u32 %rd6, %r3, %r3;
    xor.b64 %rd5, %rd6, %rd6;
    setp.ne.u32 %p4, %r3, %r3;
    @%p4 or.b32 %r9, %r3, %r3;
    shl.b64 %rd12, %rd5, 15;
    shr.s64 %rd11, %rd6, 0;
    sub.u32 %r10, %r9, %r9;
    cvt.u64.u32 %rd9, %r10;
    cvt.s32.s64 %r8, %rd9;
    add.s64 %rd7, %rd9, %rd5;
    cvt.s32.s64 %r20, %rd6;
    max.s32 %r23, %r9, %r9;
    add.u32 %r17, %r9, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
