.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd10, %r3, %r3;
    min.u32 %r13, %r3, 0;
    shl.b64 %rd7, %rd10, 31;
    sub.u32 %r25, %r3, %r13;
    shr.s32 %r10, %r25, 7;
    and.b32 %r22, %r3, 63;
    add.s32 %r27, %r13, 32;
    setp.le.s32 %p4, %r22, %r10;
    @%p4 cvt.s32.s64 %r16, %rd7;
    add.u32 %r24, %r16, %r25;
    or.b32 %r9, %r13, %r24;
    sub.s32 %r10, %r16, 256;
    setp.le.u32 %p3, %r16, 0;
    @%p3 mul.wide.u32 %rd7, %r3, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
