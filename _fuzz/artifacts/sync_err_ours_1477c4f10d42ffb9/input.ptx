.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    mul.wide.u32 %rd13, %r3, %r3;
    min.u32 %r13, %r3, %r3;
    add.s32 %r16, %r3, %r13;
    or.b32 %r11, %r3, %r16;
    mul.lo.s64 %rd13, %rd13, %rd14;
    mul.wide.s32 %rd10, %r16, %r13;
    mad.lo.u32 %r14, %r11, %r11, %r3;
    max.u32 %r10, %r16, 32;
    setp.ls.u32 %p3, %r10, %r14;
    max.u64 %rd10, %rd13, %rd14;
    shr.u32 %r24, %r16, 16;
    mul.wide.s32 %rd8, %r3, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
