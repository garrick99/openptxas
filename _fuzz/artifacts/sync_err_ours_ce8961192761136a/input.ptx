.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r24, %r3, %r3;
    max.u32 %r25, %r24, %r3;
    mul.wide.u32 %rd14, %r3, %r3;
    cvt.s32.s64 %r8, %rd14;
    cvt.u32.u64 %r17, %rd14;
    min.s32 %r25, %r25, %r3;
    mul.lo.s32 %r27, %r17, 32;
    and.b32 %r26, %r27, %r17;
    mul.wide.u32 %rd14, %r27, %r3;
    sub.u32 %r4, %r24, 65535;
    mad.lo.u32 %r17, %r4, %r27, %r24;
    mad.lo.u32 %r20, %r3, %r3, %r27;
    max.u32 %r19, %r4, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
