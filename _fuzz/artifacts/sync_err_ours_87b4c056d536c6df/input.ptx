    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    or.b64 %rd5, %rd12, %rd12;
    or.b32 %r23, %r3, %r3;
    shl.b32 %r22, %r3, 15;
    mul.wide.u32 %rd14, %r23, %r3;
    and.b32 %r13, %r22, %r22;
    shr.s32 %r18, %r3, 0;
    add.u32 %r14, %r18, 7;
    setp.lt.s32 %p3, %r22, %r23;
    mul.lo.s32 %r27, %r14, 32;
    or.b32 %r14, %r3, 31;
    min.u32 %r25, %r14, 8;
    mul.lo.s32 %r26, %r25, 4294967295;
    xor.b32 %r19, %r25, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
