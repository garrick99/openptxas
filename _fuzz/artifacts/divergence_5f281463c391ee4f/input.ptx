.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r11, %r3, 0;
    xor.b32 %r6, %r3, 64;
    xor.b32 %r19, %r3, 4294967295;
    max.u32 %r22, %r11, 4;
    and.b32 %r6, %r22, %r3;
    max.s32 %r21, %r6, %r19;
    xor.b32 %r27, %r21, %r19;
    mul.lo.s32 %r21, %r21, %r27;
    cvt.s64.s32 %rd7, %r6;
    max.s32 %r8, %r21, %r6;
    mad.lo.s32 %r10, %r11, %r27, %r8;
    sub.u32 %r18, %r19, 31;
    shr.s64 %rd12, %rd7, 0;
    shl.b32 %r26, %r21, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
