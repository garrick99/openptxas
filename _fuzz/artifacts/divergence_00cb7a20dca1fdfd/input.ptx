.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r16, %r3, %r3;
    setp.lo.u32 %p1, %r16, 1;
    @%p1 mul.wide.u32 %rd5, %r16, %r16;
    shl.b64 %rd7, %rd5, 31;
    cvt.s64.s32 %rd14, %r16;
    mul.wide.u32 %rd14, %r3, %r16;
    cvt.s32.s64 %r27, %rd7;
    mul.lo.s32 %r24, %r3, 32;
    min.s64 %rd11, %rd7, %rd5;
    mul.lo.s32 %r6, %r27, %r27;
    cvt.s32.s64 %r20, %rd5;
    min.u64 %rd6, %rd7, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
