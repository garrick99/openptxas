.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p2, %r3, %r3;
    @%p2 min.u32 %r26, %r3, %r3;
    cvt.u64.u32 %rd14, %r3;
    add.u32 %r7, %r26, %r3;
    min.u32 %r26, %r7, %r3;
    shl.b32 %r10, %r26, 1;
    and.b32 %r8, %r3, %r10;
    mul.wide.u32 %rd6, %r8, %r7;
    mad.lo.s32 %r20, %r26, %r26, %r8;
    cvt.s32.s64 %r19, %rd6;
    mul.lo.u64 %rd7, %rd14, %rd6;
    add.u32 %r19, %r19, 31;
    shr.u32 %r13, %r10, 2;
    xor.b32 %r6, %r8, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
