.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r18, %r3, 4;
    add.u32 %r12, %r3, 31;
    shr.s32 %r17, %r3, 15;
    cvt.u64.u32 %rd15, %r12;
    sub.s64 %rd5, %rd15, %rd15;
    setp.ge.s32 %p1, %r12, %r12;
    mul.wide.s32 %rd13, %r18, %r12;
    mul.lo.u32 %r27, %r3, %r3;
    mad.lo.u32 %r17, %r18, %r3, %r12;
    setp.ge.s32 %p3, %r12, %r3;
    @!%p3 xor.b32 %r22, %r27, %r27;
    min.u32 %r21, %r22, %r3;
    mul.wide.u32 %rd6, %r27, %r12;
    mul.wide.s32 %rd11, %r18, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
