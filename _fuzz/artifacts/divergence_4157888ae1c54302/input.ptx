.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r16, %r3, 1;
    and.b32 %r22, %r16, %r16;
    mad.lo.s32 %r16, %r22, %r3, %r22;
    cvt.s64.s32 %rd15, %r3;
    xor.b32 %r15, %r16, 15;
    cvt.s32.s64 %r21, %rd15;
    min.s32 %r7, %r21, 4294967295;
    mad.lo.s32 %r5, %r21, %r21, %r16;
    mul.wide.u32 %rd6, %r22, %r7;
    cvt.s32.s64 %r13, %rd15;
    min.u32 %r12, %r13, 63;
    shr.s32 %r13, %r7, 15;
    add.s32 %r26, %r12, %r22;
    or.b32 %r20, %r7, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
