.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r24, %r3, %r3;
    mad.lo.s32 %r23, %r24, %r3, %r3;
    and.b32 %r4, %r23, %r3;
    shl.b32 %r26, %r23, 30;
    mul.wide.u32 %rd14, %r23, %r24;
    add.u64 %rd7, %rd14, %rd14;
    sub.s32 %r7, %r26, 65535;
    cvt.u32.u64 %r11, %rd7;
    cvt.s32.s64 %r22, %rd14;
    shr.s32 %r6, %r7, 3;
    max.u32 %r24, %r24, 2;
    mad.lo.u32 %r14, %r3, %r11, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
