.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r27, %r3, 1;
    mul.wide.s32 %rd9, %r3, %r3;
    mul.wide.s32 %rd8, %r27, %r3;
    add.s32 %r8, %r27, 7;
    sub.s32 %r10, %r27, %r3;
    mul.wide.s32 %rd15, %r10, %r10;
    shr.u64 %rd8, %rd8, 48;
    xor.b32 %r16, %r8, %r27;
    mad.lo.u32 %r20, %r27, %r10, %r3;
    cvt.u32.u64 %r12, %rd9;
    setp.gt.s32 %p2, %r20, %r27;
    @!%p2 add.u32 %r14, %r3, 31;
    shr.u32 %r18, %r16, 16;
    setp.hi.u32 %p3, %r20, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
