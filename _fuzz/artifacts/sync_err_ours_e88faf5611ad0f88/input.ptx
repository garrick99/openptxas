.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    and.b32 %r19, %r3, %r3;
    max.s32 %r21, %r3, %r19;
    and.b32 %r25, %r19, %r3;
    sub.u32 %r18, %r25, 5;
    or.b32 %r13, %r18, 65535;
    or.b64 %rd10, %rd15, %rd15;
    and.b32 %r10, %r3, %r21;
    sub.u32 %r20, %r21, %r18;
    or.b64 %rd11, %rd15, %rd15;
    shr.u32 %r20, %r13, 15;
    mul.lo.u32 %r12, %r20, 3;
    cvt.s32.s64 %r13, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
