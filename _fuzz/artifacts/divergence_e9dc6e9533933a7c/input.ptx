.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r13, %r3, 64;
    max.s32 %r14, %r3, 63;
    shl.b32 %r9, %r13, 2;
    sub.s32 %r25, %r3, 1;
    shl.b32 %r22, %r9, 31;
    mul.lo.s32 %r16, %r22, %r14;
    mul.wide.u32 %rd6, %r25, %r3;
    add.u32 %r11, %r9, %r9;
    mul.wide.s32 %rd5, %r11, %r3;
    mad.lo.s32 %r12, %r13, %r13, %r25;
    and.b32 %r21, %r11, %r16;
    min.s32 %r22, %r3, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
