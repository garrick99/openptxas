.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r19, %r3, 4;
    mul.lo.s32 %r6, %r3, %r19;
    mad.lo.s32 %r6, %r19, %r19, %r3;
    setp.ge.s32 %p2, %r6, 255;
    @!%p2 mad.lo.u32 %r12, %r19, %r19, %r6;
    selp.b32 %r14, %r19, %r12, %p2;
    shr.u32 %r10, %r19, 15;
    selp.b32 %r15, %r14, %r10, %p2;
    cvt.s64.s32 %rd9, %r12;
    mad.lo.s32 %r23, %r6, %r10, %r12;
    mad.lo.s32 %r20, %r15, %r12, %r10;
    selp.b32 %r5, %r20, %r15, %p2;
    mad.lo.u32 %r4, %r20, %r23, %r20;
    mul.wide.s32 %rd12, %r15, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
