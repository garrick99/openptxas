.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p2, %r3, 31;
    @%p2 mad.lo.u32 %r4, %r3, %r3, %r3;
    cvt.s64.s32 %rd5, %r3;
    cvt.s32.s64 %r7, %rd5;
    setp.lt.u32 %p4, %r4, 3;
    @!%p4 mul.lo.u64 %rd13, %rd5, %rd5;
    xor.b64 %rd14, %rd5, %rd13;
    shl.b32 %r8, %r3, 7;
    shr.s32 %r22, %r4, 3;
    max.s32 %r5, %r8, %r4;
    xor.b32 %r9, %r4, 4;
    setp.ne.s32 %p3, %r4, 2147483647;
    @!%p3 mad.lo.s32 %r16, %r3, %r4, %r9;
    add.u32 %r21, %r7, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
