.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p2, %r3, %r3;
    @!%p2 selp.b32 %r27, %r3, %r3, %p2;
    mul.wide.u32 %rd7, %r3, %r27;
    mul.lo.s32 %r9, %r3, 65536;
    max.u64 %rd6, %rd7, %rd7;
    selp.b32 %r6, %r3, %r9, %p2;
    xor.b32 %r18, %r9, %r3;
    shr.u32 %r5, %r6, 31;
    selp.b32 %r27, %r27, %r3, %p2;
    sub.s32 %r23, %r9, %r6;
    and.b32 %r8, %r27, %r9;
    shr.s64 %rd15, %rd6, 63;
    setp.hs.u32 %p4, %r5, 65535;
    @%p4 mul.lo.u32 %r24, %r27, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
