.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r23, %r3, 31;
    max.s32 %r9, %r23, %r23;
    min.s32 %r18, %r3, 3;
    or.b32 %r27, %r9, %r9;
    sub.u32 %r19, %r9, %r3;
    cvt.s64.s32 %rd5, %r19;
    mul.lo.s32 %r13, %r27, 64;
    shl.b32 %r10, %r18, 30;
    cvt.s32.s64 %r5, %rd5;
    max.u32 %r17, %r23, %r18;
    max.s64 %rd7, %rd5, %rd5;
    or.b32 %r20, %r17, %r9;
    add.u32 %r13, %r3, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
