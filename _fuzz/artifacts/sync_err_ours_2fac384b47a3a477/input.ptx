.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    min.u32 %r4, %r3, 31;
    shr.s32 %r14, %r4, 7;
    shr.u32 %r13, %r14, 30;
    shr.u64 %rd5, %rd7, 4;
    shr.s64 %rd7, %rd5, 2;
    max.u32 %r11, %r14, 2147483648;
    cvt.u32.u64 %r9, %rd7;
    or.b64 %rd8, %rd7, %rd5;
    cvt.u64.u32 %rd15, %r9;
    shr.u32 %r16, %r3, 0;
    sub.s64 %rd14, %rd7, %rd5;
    add.u32 %r15, %r9, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
