.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd5, %r3, %r3;
    mul.lo.s32 %r24, %r3, 65536;
    max.s32 %r20, %r24, 2147483648;
    mad.lo.u32 %r13, %r24, %r20, %r24;
    min.u32 %r24, %r24, %r3;
    add.u64 %rd6, %rd5, %rd5;
    mad.lo.u32 %r23, %r20, %r3, %r3;
    add.s64 %rd11, %rd6, %rd5;
    shl.b64 %rd14, %rd5, 48;
    mul.lo.u32 %r11, %r23, %r13;
    xor.b32 %r18, %r20, 31;
    setp.eq.s32 %p3, %r13, 32;
    @%p3 shr.u32 %r9, %r23, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
