.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    setp.ne.s32 %p2, %r3, %r3;
    @%p2 sub.s64 %rd5, %rd14, %rd14;
    cvt.u32.u64 %r7, %rd14;
    add.u64 %rd10, %rd14, %rd14;
    min.s32 %r14, %r7, %r7;
    max.s32 %r24, %r7, %r7;
    xor.b64 %rd10, %rd14, %rd5;
    sub.u32 %r25, %r14, 255;
    or.b32 %r20, %r24, %r25;
    max.s32 %r4, %r24, %r3;
    or.b32 %r5, %r25, %r24;
    max.u32 %r8, %r5, 0;
    and.b32 %r10, %r25, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
