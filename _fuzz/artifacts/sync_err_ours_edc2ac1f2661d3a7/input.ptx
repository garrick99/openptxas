.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    mad.lo.s32 %r22, %r3, %r3, %r3;
    sub.u32 %r19, %r22, %r22;
    and.b32 %r7, %r22, %r3;
    xor.b64 %rd7, %rd6, %rd6;
    min.u32 %r12, %r22, %r7;
    setp.le.s32 %p1, %r12, %r22;
    mul.lo.s32 %r18, %r22, %r7;
    add.u64 %rd9, %rd6, %rd7;
    cvt.s32.s64 %r18, %rd9;
    add.s64 %rd9, %rd9, %rd7;
    and.b32 %r12, %r18, %r18;
    mul.lo.s32 %r4, %r22, %r19;
    selp.b32 %r16, %r18, %r4, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
