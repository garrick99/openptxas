.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    cvt.s32.s64 %r4, %rd6;
    or.b32 %r20, %r4, %r3;
    cvt.s32.s64 %r27, %rd6;
    shl.b32 %r18, %r27, 3;
    setp.ge.u32 %p3, %r20, %r4;
    min.s32 %r12, %r4, 255;
    shr.u32 %r26, %r12, 0;
    max.u64 %rd6, %rd6, %rd6;
    cvt.s64.s32 %rd10, %r3;
    or.b32 %r25, %r26, 1;
    and.b32 %r18, %r20, %r25;
    min.u32 %r4, %r18, 65535;
    mad.lo.u32 %r13, %r27, %r12, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
