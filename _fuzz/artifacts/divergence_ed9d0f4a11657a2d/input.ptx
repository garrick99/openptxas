.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd5, %r3, %r3;
    mul.lo.s32 %r18, %r3, %r3;
    setp.le.s32 %p2, %r3, %r3;
    @!%p2 shl.b32 %r20, %r18, 0;
    mul.lo.u64 %rd15, %rd5, %rd5;
    selp.b32 %r11, %r20, %r18, %p2;
    or.b32 %r17, %r11, %r3;
    mul.wide.u32 %rd10, %r3, %r11;
    sub.u32 %r24, %r20, %r17;
    min.s32 %r7, %r3, %r11;
    shr.s64 %rd5, %rd5, 1;
    add.u32 %r16, %r7, %r7;
    max.u32 %r11, %r17, %r3;
    and.b32 %r14, %r7, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
