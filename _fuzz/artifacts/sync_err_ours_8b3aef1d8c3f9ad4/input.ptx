.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    cvt.u64.u32 %rd5, %r3;
    cvt.u64.u32 %rd7, %r3;
    xor.b32 %r17, %r3, 65535;
    shr.u32 %r19, %r3, 2;
    cvt.u32.u64 %r9, %rd15;
    setp.lo.u32 %p2, %r19, %r17;
    min.u32 %r22, %r19, 65535;
    selp.b32 %r24, %r19, %r19, %p2;
    shr.u32 %r25, %r9, 1;
    max.u32 %r25, %r9, 31;
    add.u32 %r25, %r25, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
