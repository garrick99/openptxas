.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    min.u32 %r17, %r3, %r3;
    xor.b32 %r5, %r3, 4;
    xor.b32 %r25, %r17, %r5;
    max.u64 %rd13, %rd8, %rd8;
    shr.s32 %r5, %r3, 30;
    mul.wide.u32 %rd5, %r5, %r5;
    max.s32 %r20, %r5, 8;
    cvt.u32.u64 %r16, %rd5;
    sub.s32 %r13, %r17, %r25;
    add.u32 %r16, %r16, 4294967295;
    min.u32 %r22, %r25, 32;
    sub.u32 %r26, %r25, 63;
    mul.lo.s32 %r23, %r22, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
