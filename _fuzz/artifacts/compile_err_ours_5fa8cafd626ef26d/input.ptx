.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p2, %r3, %r3;
    vote.sync.ballot.b32 %r12, %p2, -1;
    shfl.sync.down.b32 %r12, %r12, 1, 0x1f, -1;
    shfl.sync.down.b32 %r7, %r0, 1, 0x1f, -1;
    xor.b32 %r12, %r3, %r12;
    setp.le.u32 %p1, %r12, %r3;
    vote.sync.ballot.b32 %r5, %p1, -1;
    and.b32 %r17, %r3, %r0;
    max.u32 %r5, %r5, %r12;
    vote.sync.all.pred %p2, %p2, -1;
    shfl.sync.bfly.b32 %r7, %r3, 16, 0x1f, -1;
    max.u32 %r4, %r17, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
