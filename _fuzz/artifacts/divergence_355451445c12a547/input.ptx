.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.bfly.b32 %r16, %r0, 16, 0x1f, -1;
    setp.lt.u32 %p1, %r0, %r3;
    vote.sync.ballot.b32 %r8, %p1, -1;
    shfl.sync.up.b32 %r6, %r16, 2, 0x1f, -1;
    shfl.sync.idx.b32 %r15, %r6, 31, 0x1f, -1;
    shfl.sync.down.b32 %r7, %r16, 4, 0x1f, -1;
    add.u32 %r17, %r15, %r3;
    shfl.sync.up.b32 %r14, %r15, 2, 0x1f, -1;
    add.u32 %r6, %r17, %r7;
    setp.ne.u32 %p2, %r7, 8;
    vote.sync.ballot.b32 %r19, %p2, -1;
    xor.b32 %r17, %r16, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
