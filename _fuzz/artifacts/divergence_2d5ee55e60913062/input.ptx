.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p1, %r3, %r3;
    @%p1 cvt.s64.s32 %rd12, %r3;
    mul.wide.u32 %rd13, %r3, %r3;
    shr.s64 %rd14, %rd12, 30;
    selp.b32 %r17, %r3, %r3, %p1;
    mul.wide.u32 %rd15, %r17, %r17;
    mul.wide.u32 %rd13, %r17, %r17;
    max.u32 %r16, %r3, 2;
    mad.lo.s32 %r25, %r17, %r3, %r16;
    or.b32 %r14, %r3, %r25;
    shr.s32 %r5, %r3, 31;
    cvt.u64.u32 %rd13, %r3;
    shr.u64 %rd7, %rd12, 0;
    cvt.u64.u32 %rd13, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
