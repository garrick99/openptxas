.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r22, %r3, 15;
    setp.ne.u32 %p1, %r3, %r22;
    @!%p1 max.s32 %r8, %r3, %r22;
    setp.le.s32 %p2, %r3, 2147483647;
    @%p2 cvt.s64.s32 %rd11, %r3;
    selp.b32 %r5, %r3, %r22, %p1;
    min.s32 %r20, %r22, 3;
    cvt.u64.u32 %rd15, %r20;
    cvt.u32.u64 %r6, %rd11;
    mad.lo.s32 %r5, %r5, %r20, %r3;
    setp.gt.s32 %p3, %r5, %r5;
    @!%p3 sub.s32 %r24, %r6, 65536;
    mad.lo.u32 %r7, %r24, %r20, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
