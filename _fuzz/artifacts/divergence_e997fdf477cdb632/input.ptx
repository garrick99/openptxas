.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r19, %r3, 64;
    mad.lo.s32 %r12, %r3, %r3, %r19;
    cvt.u64.u32 %rd15, %r12;
    mul.lo.s32 %r20, %r19, 7;
    shr.u64 %rd5, %rd15, 0;
    setp.lt.u32 %p1, %r19, 31;
    @%p1 and.b32 %r27, %r20, %r3;
    cvt.s32.s64 %r21, %rd5;
    add.u32 %r16, %r19, %r20;
    shl.b64 %rd9, %rd15, 15;
    min.u32 %r21, %r3, %r19;
    cvt.u64.u32 %rd8, %r21;
    setp.gt.s32 %p1, %r20, %r20;
    @%p1 xor.b32 %r22, %r27, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
