.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r9, %r3, %r3;
    shl.b32 %r5, %r3, 7;
    xor.b32 %r20, %r9, %r3;
    and.b32 %r18, %r3, %r20;
    setp.ge.s32 %p3, %r20, %r3;
    @%p3 mad.lo.u32 %r22, %r3, %r5, %r3;
    mul.wide.s32 %rd15, %r5, %r22;
    max.u32 %r23, %r9, 63;
    min.s32 %r25, %r3, %r9;
    cvt.s32.s64 %r6, %rd15;
    add.s32 %r14, %r9, 16;
    max.s32 %r13, %r9, 4294967295;
    max.u32 %r6, %r3, %r6;
    mul.lo.u32 %r14, %r5, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
