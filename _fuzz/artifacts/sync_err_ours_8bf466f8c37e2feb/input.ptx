.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    cvt.s64.s32 %rd13, %r3;
    shl.b32 %r16, %r3, 15;
    sub.u32 %r19, %r3, %r16;
    setp.ne.s32 %p4, %r19, %r19;
    @%p4 min.u64 %rd8, %rd13, %rd13;
    cvt.u64.u32 %rd7, %r19;
    shr.s32 %r8, %r19, 1;
    selp.b32 %r27, %r8, %r8, %p4;
    setp.ge.u32 %p3, %r3, 4294967295;
    @%p3 shr.u32 %r27, %r8, 1;
    or.b64 %rd10, %rd13, %rd11;
    cvt.u32.u64 %r16, %rd10;
    cvt.u64.u32 %rd11, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
