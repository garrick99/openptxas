.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    cvt.u32.u64 %r13, %rd15;
    or.b32 %r21, %r13, 15;
    sub.u32 %r23, %r21, %r13;
    cvt.s32.s64 %r10, %rd15;
    setp.hs.u32 %p3, %r3, 65535;
    @!%p3 min.s32 %r4, %r13, 31;
    cvt.u32.u64 %r18, %rd15;
    mul.lo.u32 %r7, %r18, 15;
    or.b32 %r10, %r13, 256;
    selp.b32 %r15, %r4, %r23, %p3;
    setp.lo.u32 %p2, %r18, %r23;
    @!%p2 shr.s64 %rd9, %rd15, 62;
    min.u64 %rd7, %rd15, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
