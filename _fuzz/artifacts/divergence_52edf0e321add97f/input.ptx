.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    setp.eq.s32 %p4, %r3, %r3;
    setp.eq.s32 %p1, %r3, 256;
    @%p1 max.s32 %r24, %r3, %r3;
    shl.b64 %rd12, %rd10, 47;
    shl.b32 %r20, %r24, 7;
    mad.lo.s32 %r7, %r3, %r20, %r24;
    setp.ge.u32 %p4, %r20, 7;
    @%p4 min.u32 %r13, %r24, %r7;
    min.u32 %r4, %r7, %r20;
    or.b32 %r11, %r24, 65535;
    min.s32 %r9, %r13, %r20;
    mad.lo.s32 %r6, %r9, %r3, %r3;
    mul.wide.u32 %rd13, %r9, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
