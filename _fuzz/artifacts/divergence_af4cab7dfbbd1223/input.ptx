.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r5, %r3, 31;
    sub.u32 %r25, %r5, 16;
    sub.u32 %r12, %r5, 2147483648;
    mul.wide.s32 %rd8, %r12, %r25;
    shr.s64 %rd5, %rd8, 1;
    max.u32 %r12, %r25, %r25;
    shr.s64 %rd13, %rd8, 48;
    setp.hs.u32 %p4, %r25, 15;
    @!%p4 min.u32 %r23, %r25, %r3;
    setp.ne.s32 %p1, %r23, %r5;
    @%p1 min.s32 %r7, %r25, 32;
    or.b32 %r21, %r23, %r23;
    cvt.u64.u32 %rd14, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
