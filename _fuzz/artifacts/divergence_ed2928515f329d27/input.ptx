.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r10, %r3, 8;
    cvt.u64.u32 %rd8, %r3;
    mul.lo.u64 %rd11, %rd8, %rd8;
    sub.u32 %r23, %r3, 65536;
    xor.b64 %rd7, %rd11, %rd11;
    min.u64 %rd12, %rd11, %rd11;
    shl.b32 %r26, %r3, 7;
    setp.ge.s32 %p3, %r26, %r10;
    @%p3 cvt.s32.s64 %r4, %rd8;
    cvt.u32.u64 %r18, %rd7;
    mul.wide.u32 %rd15, %r18, %r18;
    xor.b32 %r7, %r3, 1;
    selp.b32 %r21, %r26, %r4, %p3;
    shr.u64 %rd13, %rd11, 33;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
