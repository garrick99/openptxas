.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r4, %r3, %r3;
    cvt.s64.s32 %rd6, %r3;
    max.s32 %r27, %r4, %r3;
    shr.s64 %rd12, %rd6, 2;
    shr.s64 %rd7, %rd12, 63;
    min.u32 %r17, %r27, 4;
    cvt.u64.u32 %rd6, %r17;
    xor.b64 %rd6, %rd12, %rd12;
    setp.gt.u32 %p1, %r17, 16;
    @%p1 or.b32 %r24, %r3, %r17;
    add.s32 %r26, %r27, %r3;
    min.u32 %r22, %r24, %r17;
    shr.s32 %r12, %r27, 4;
    mad.lo.s32 %r4, %r26, %r24, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
