.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    shr.u32 %r7, %r3, 3;
    setp.ne.u32 %p3, %r3, 5;
    @%p3 mul.lo.u64 %rd15, %rd10, %rd10;
    mul.lo.s64 %rd12, %rd10, %rd15;
    mul.wide.u32 %rd14, %r7, %r7;
    or.b32 %r8, %r7, %r3;
    max.s64 %rd6, %rd14, %rd12;
    add.u32 %r17, %r7, %r7;
    selp.b32 %r25, %r17, %r3, %p3;
    max.s32 %r11, %r17, 8;
    sub.s32 %r8, %r11, 65535;
    mul.lo.s32 %r14, %r25, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
