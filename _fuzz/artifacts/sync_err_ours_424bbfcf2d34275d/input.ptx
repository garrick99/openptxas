.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p3, %r3, 256;
    add.s32 %r23, %r3, %r3;
    shr.s32 %r16, %r3, 2;
    mul.wide.s32 %rd13, %r16, %r16;
    cvt.s32.s64 %r16, %rd13;
    xor.b32 %r22, %r3, %r3;
    mul.lo.u32 %r14, %r22, %r16;
    sub.u32 %r17, %r14, %r16;
    max.u64 %rd15, %rd13, %rd13;
    shr.u32 %r11, %r23, 3;
    max.s32 %r24, %r23, 4;
    mul.lo.s32 %r7, %r3, 15;
    shl.b64 %rd6, %rd13, 48;
    or.b32 %r16, %r7, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
