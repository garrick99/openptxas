.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r24, %r3, 31;
    cvt.u64.u32 %rd5, %r24;
    max.u32 %r6, %r24, %r3;
    mul.wide.u32 %rd13, %r6, %r24;
    max.u64 %rd6, %rd13, %rd13;
    min.u32 %r5, %r3, 15;
    sub.s32 %r19, %r5, %r24;
    cvt.u64.u32 %rd7, %r19;
    shr.s32 %r11, %r24, 31;
    sub.s32 %r23, %r3, %r6;
    cvt.s32.s64 %r17, %rd6;
    max.s32 %r10, %r23, %r17;
    shr.s32 %r13, %r17, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
