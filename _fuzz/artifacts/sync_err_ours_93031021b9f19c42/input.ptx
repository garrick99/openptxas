.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    setp.le.u32 %p2, %r3, %r3;
    @!%p2 cvt.u32.u64 %r19, %rd15;
    add.u32 %r22, %r19, %r19;
    selp.b32 %r7, %r3, %r19, %p2;
    shl.b32 %r9, %r19, 1;
    mul.wide.u32 %rd14, %r22, %r7;
    setp.gt.u32 %p1, %r7, %r19;
    @%p1 sub.s32 %r5, %r3, 31;
    xor.b32 %r8, %r22, %r9;
    min.u32 %r22, %r8, %r3;
    sub.u32 %r20, %r7, 15;
    and.b32 %r15, %r9, 2;
    mul.wide.u32 %rd5, %r9, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
