.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    sub.u32 %r7, %r3, %r3;
    max.s32 %r14, %r7, %r3;
    mad.lo.s32 %r8, %r3, %r3, %r14;
    or.b64 %rd5, %rd14, %rd14;
    cvt.u64.u32 %rd10, %r3;
    shl.b32 %r26, %r8, 4;
    add.s64 %rd9, %rd14, %rd10;
    max.u64 %rd11, %rd9, %rd10;
    setp.ne.u32 %p3, %r8, %r26;
    @!%p3 sub.u32 %r20, %r26, 63;
    xor.b64 %rd13, %rd10, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
