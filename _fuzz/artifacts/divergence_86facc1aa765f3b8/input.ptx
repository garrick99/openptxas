.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r20, %r3, %r3;
    min.u32 %r27, %r20, 2;
    or.b32 %r4, %r3, 255;
    sub.u32 %r13, %r20, %r3;
    and.b32 %r24, %r27, %r4;
    and.b32 %r7, %r3, 16;
    mul.wide.u32 %rd15, %r3, %r27;
    cvt.s32.s64 %r19, %rd15;
    mul.wide.s32 %rd10, %r24, %r3;
    mul.lo.s64 %rd13, %rd15, %rd15;
    mul.lo.s32 %r21, %r27, %r27;
    mad.lo.u32 %r13, %r7, %r20, %r13;
    mul.lo.u32 %r20, %r27, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
