.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p4, %r3, %r3;
    @%p4 cvt.u64.u32 %rd8, %r3;
    or.b32 %r15, %r3, 32;
    mul.wide.s32 %rd9, %r15, %r3;
    shl.b32 %r8, %r15, 16;
    sub.s32 %r27, %r15, %r15;
    max.u32 %r19, %r3, 2147483647;
    min.s64 %rd7, %rd9, %rd9;
    and.b64 %rd12, %rd8, %rd9;
    add.s64 %rd9, %rd7, %rd9;
    selp.b32 %r16, %r3, %r19, %p4;
    selp.b32 %r16, %r8, %r3, %p4;
    selp.b32 %r5, %r27, %r8, %p4;
    sub.u64 %rd8, %rd7, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
