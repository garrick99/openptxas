.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r8, %r3, 30;
    or.b32 %r9, %r3, %r3;
    mad.lo.u32 %r26, %r9, %r8, %r3;
    cvt.s64.s32 %rd7, %r9;
    mad.lo.u32 %r9, %r8, %r26, %r9;
    shr.s64 %rd12, %rd7, 16;
    max.s32 %r12, %r9, 32;
    cvt.s32.s64 %r24, %rd12;
    min.u64 %rd9, %rd7, %rd12;
    shr.u64 %rd7, %rd12, 15;
    max.u32 %r14, %r8, 2147483647;
    mul.lo.s32 %r13, %r24, %r9;
    mul.lo.u32 %r25, %r24, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
