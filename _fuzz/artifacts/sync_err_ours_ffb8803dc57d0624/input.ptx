.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    cvt.u32.u64 %r27, %rd5;
    mul.wide.u32 %rd7, %r27, %r3;
    shr.u32 %r15, %r3, 1;
    mul.lo.s32 %r11, %r3, 0;
    xor.b64 %rd12, %rd5, %rd5;
    cvt.u64.u32 %rd5, %r3;
    shr.u32 %r25, %r11, 30;
    xor.b32 %r19, %r3, 0;
    cvt.u64.u32 %rd12, %r27;
    sub.s32 %r16, %r11, 63;
    setp.lt.s32 %p2, %r25, %r25;
    shr.s32 %r22, %r19, 7;
    shr.u32 %r8, %r16, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
