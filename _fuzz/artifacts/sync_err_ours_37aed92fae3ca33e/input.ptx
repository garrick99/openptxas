.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd15, %r3, %r3;
    setp.eq.u32 %p1, %r3, %r3;
    shl.b32 %r11, %r3, 3;
    mul.lo.s32 %r8, %r3, %r11;
    mul.lo.u32 %r12, %r3, %r3;
    max.s64 %rd7, %rd15, %rd15;
    cvt.s32.s64 %r11, %rd15;
    shr.u32 %r6, %r3, 2;
    min.u32 %r22, %r6, 4;
    mad.lo.u32 %r10, %r8, %r11, %r6;
    sub.u32 %r4, %r11, 0;
    add.u32 %r6, %r10, 32;
    mad.lo.s32 %r16, %r8, %r3, %r11;
    shl.b64 %rd5, %rd7, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
