.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p3, %r3, 16;
    @%p3 selp.b32 %r25, %r3, %r3, %p3;
    mad.lo.s32 %r26, %r25, %r3, %r3;
    mad.lo.u32 %r16, %r3, %r26, %r26;
    sub.s32 %r15, %r16, %r25;
    cvt.u64.u32 %rd10, %r16;
    shl.b32 %r21, %r3, 1;
    shl.b64 %rd5, %rd10, 47;
    xor.b32 %r21, %r21, %r26;
    shr.s32 %r13, %r3, 4;
    mad.lo.u32 %r14, %r21, %r26, %r15;
    selp.b32 %r17, %r13, %r26, %p3;
    shr.s32 %r11, %r17, 4;
    add.u32 %r24, %r25, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
