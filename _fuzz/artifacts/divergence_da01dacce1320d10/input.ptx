.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p3, %r3, %r3;
    @%p3 sub.u32 %r22, %r3, %r3;
    cvt.s64.s32 %rd9, %r22;
    shl.b32 %r14, %r3, 4;
    xor.b32 %r12, %r14, %r3;
    setp.ge.s32 %p1, %r22, 63;
    @!%p1 shl.b32 %r21, %r12, 4;
    shl.b64 %rd15, %rd9, 63;
    mul.wide.u32 %rd9, %r12, %r3;
    mul.lo.u32 %r23, %r12, %r3;
    shl.b32 %r5, %r22, 30;
    sub.u64 %rd15, %rd9, %rd9;
    shr.s32 %r20, %r5, 30;
    mad.lo.s32 %r24, %r22, %r14, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
