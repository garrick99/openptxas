.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r16, %r3, 4;
    shr.s32 %r9, %r16, 0;
    mul.wide.u32 %rd5, %r9, %r16;
    setp.le.s32 %p4, %r3, %r9;
    @!%p4 mad.lo.s32 %r25, %r3, %r16, %r16;
    selp.b32 %r19, %r3, %r9, %p4;
    cvt.s32.s64 %r7, %rd5;
    sub.u32 %r9, %r19, %r9;
    mad.lo.s32 %r21, %r3, %r7, %r3;
    or.b32 %r5, %r16, %r21;
    mul.wide.s32 %rd15, %r3, %r7;
    shl.b32 %r4, %r25, 16;
    mul.lo.u32 %r24, %r4, %r3;
    min.u32 %r11, %r25, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
