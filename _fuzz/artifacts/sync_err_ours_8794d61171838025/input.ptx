.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r24, %r3, 65535;
    mul.lo.u32 %r11, %r24, 2147483647;
    mul.lo.u32 %r20, %r3, %r24;
    and.b32 %r15, %r11, %r3;
    xor.b32 %r26, %r20, %r20;
    mad.lo.s32 %r13, %r3, %r3, %r15;
    add.s32 %r15, %r20, %r24;
    sub.u32 %r15, %r26, %r26;
    mad.lo.u32 %r24, %r11, %r26, %r20;
    mul.wide.u32 %rd7, %r24, %r3;
    xor.b32 %r9, %r20, 4;
    min.u64 %rd7, %rd7, %rd7;
    shl.b64 %rd10, %rd7, 2;
    mul.wide.s32 %rd15, %r9, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
