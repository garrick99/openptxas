.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    mul.lo.u64 %rd9, %rd6, %rd6;
    mul.lo.u32 %r26, %r3, 15;
    shr.u32 %r23, %r26, 15;
    add.u32 %r27, %r3, 31;
    setp.ge.s32 %p2, %r23, %r3;
    @!%p2 mad.lo.u32 %r19, %r26, %r26, %r3;
    mul.lo.s32 %r25, %r23, 5;
    mad.lo.s32 %r4, %r19, %r25, %r19;
    selp.b32 %r4, %r27, %r27, %p2;
    min.s32 %r22, %r26, 256;
    mul.wide.u32 %rd15, %r22, %r23;
    or.b32 %r5, %r22, %r22;
    min.u32 %r9, %r22, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
