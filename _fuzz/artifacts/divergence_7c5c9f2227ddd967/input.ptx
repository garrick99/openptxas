.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r7, %r3, 4;
    mul.wide.u32 %rd14, %r3, %r7;
    xor.b64 %rd11, %rd14, %rd14;
    cvt.s32.s64 %r13, %rd11;
    mul.lo.u32 %r9, %r13, 31;
    max.u32 %r21, %r3, 63;
    mul.lo.s32 %r19, %r13, 31;
    add.u32 %r6, %r19, %r9;
    mul.lo.s32 %r16, %r13, 256;
    sub.u32 %r15, %r3, 15;
    cvt.s32.s64 %r19, %rd11;
    shr.s64 %rd11, %rd14, 0;
    max.u32 %r26, %r21, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
