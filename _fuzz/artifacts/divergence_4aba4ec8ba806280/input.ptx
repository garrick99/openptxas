.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r17, %r3, 8;
    cvt.u64.u32 %rd14, %r17;
    add.s32 %r14, %r3, %r17;
    add.s32 %r19, %r17, %r17;
    setp.lo.u32 %p1, %r3, 256;
    @%p1 shr.s32 %r6, %r17, 1;
    mad.lo.u32 %r4, %r6, %r3, %r17;
    mad.lo.s32 %r15, %r4, %r6, %r19;
    sub.s32 %r11, %r17, 1;
    setp.hs.u32 %p1, %r14, %r17;
    selp.b32 %r20, %r19, %r19, %p1;
    shl.b32 %r15, %r15, 1;
    and.b32 %r10, %r15, 2;
    mul.wide.u32 %rd7, %r10, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
