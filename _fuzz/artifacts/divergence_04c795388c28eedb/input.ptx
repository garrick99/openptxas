.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r25, %r3, 7;
    setp.le.s32 %p2, %r25, 65536;
    @!%p2 shr.s32 %r11, %r3, 4;
    mad.lo.s32 %r24, %r11, %r3, %r11;
    cvt.u64.u32 %rd7, %r3;
    sub.u32 %r17, %r11, %r11;
    min.u32 %r13, %r24, 15;
    shr.s32 %r15, %r3, 2;
    shl.b32 %r4, %r24, 2;
    mul.lo.s32 %r16, %r25, 4294967295;
    max.u32 %r25, %r16, %r16;
    min.u32 %r11, %r25, %r16;
    setp.ge.s32 %p2, %r13, %r17;
    @%p2 max.u32 %r21, %r25, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
