.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p3, %r3, %r3;
    @%p3 cvt.s64.s32 %rd14, %r3;
    cvt.s32.s64 %r11, %rd14;
    mul.lo.s32 %r26, %r11, %r11;
    setp.le.u32 %p3, %r26, %r11;
    and.b32 %r9, %r11, %r11;
    shl.b64 %rd13, %rd14, 47;
    shl.b32 %r25, %r11, 4;
    max.u32 %r25, %r11, %r9;
    and.b32 %r11, %r11, %r11;
    selp.b32 %r25, %r9, %r25, %p3;
    or.b32 %r11, %r11, %r26;
    setp.le.s32 %p2, %r26, %r25;
    @%p2 sub.s32 %r27, %r26, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
