.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r24, %r3, 65535;
    setp.ls.u32 %p3, %r3, 4;
    cvt.s64.s32 %rd7, %r24;
    max.u32 %r21, %r24, 256;
    max.s64 %rd5, %rd7, %rd7;
    shr.u32 %r24, %r21, 2;
    sub.s64 %rd10, %rd5, %rd5;
    mad.lo.u32 %r15, %r21, %r3, %r21;
    mul.lo.u32 %r12, %r15, %r24;
    shr.u32 %r17, %r21, 31;
    shr.s32 %r10, %r24, 30;
    mul.wide.s32 %rd15, %r17, %r3;
    mad.lo.s32 %r25, %r15, %r10, %r17;
    sub.u32 %r24, %r17, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
