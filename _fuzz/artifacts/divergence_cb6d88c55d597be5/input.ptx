    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r18, %r3, 31;
    setp.le.s32 %p4, %r3, %r3;
    @%p4 shl.b32 %r20, %r18, 0;
    cvt.s64.s32 %rd13, %r18;
    cvt.u32.u64 %r17, %rd13;
    selp.b32 %r11, %r20, %r17, %p4;
    setp.le.s32 %p1, %r17, 7;
    @%p1 mul.wide.s32 %rd5, %r18, %r11;
    sub.s64 %rd12, %rd13, %rd13;
    setp.eq.u32 %p2, %r17, %r11;
    @!%p2 or.b32 %r15, %r20, 2147483648;
    shl.b32 %r25, %r11, 0;
    mad.lo.u32 %r24, %r18, %r11, %r18;
    and.b32 %r5, %r15, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
