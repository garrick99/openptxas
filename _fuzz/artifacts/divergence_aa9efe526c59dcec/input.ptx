.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r8, %r3, %r0;
    min.u32 %r6, %r8, %r3;
    setp.ge.u32 %p3, %r6, 255;
    vote.sync.ballot.b32 %r17, %p3, -1;
    shfl.sync.bfly.b32 %r6, %r17, 4, 0x1f, -1;
    add.u32 %r18, %r6, %r0;
    setp.lt.u32 %p3, %r0, 0;
    vote.sync.ballot.b32 %r14, %p3, -1;
    setp.lt.u32 %p2, %r17, 3;
    vote.sync.ballot.b32 %r4, %p2, -1;
    add.u32 %r10, %r14, %r8;
    max.u32 %r19, %r17, %r8;
    min.u32 %r15, %r4, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
