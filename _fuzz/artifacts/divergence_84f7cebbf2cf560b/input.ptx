.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r20, %r3, 255;
    cvt.u64.u32 %rd15, %r20;
    min.u32 %r11, %r20, 31;
    mul.wide.s32 %rd12, %r11, %r3;
    shl.b32 %r5, %r20, 31;
    setp.hs.u32 %p3, %r11, 7;
    @%p3 and.b32 %r25, %r3, 4;
    setp.le.u32 %p2, %r5, %r3;
    @%p2 cvt.s64.s32 %rd7, %r11;
    cvt.s32.s64 %r6, %rd12;
    shl.b32 %r9, %r5, 1;
    cvt.s32.s64 %r13, %rd12;
    setp.hi.u32 %p2, %r6, 16;
    @!%p2 max.s32 %r14, %r5, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
