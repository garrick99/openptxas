.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r16, %r3, 3;
    and.b32 %r5, %r16, %r16;
    min.u32 %r4, %r16, 4;
    mad.lo.s32 %r12, %r4, %r5, %r5;
    selp.b32 %r17, %r12, %r3, %p4;
    add.u32 %r23, %r17, %r4;
    mad.lo.u32 %r27, %r5, %r23, %r17;
    cvt.s64.s32 %rd11, %r5;
    mul.wide.u32 %rd9, %r27, %r16;
    setp.hs.u32 %p3, %r23, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}