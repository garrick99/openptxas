.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd13, %r3, %r3;
    max.s32 %r14, %r3, %r3;
    mad.lo.u32 %r19, %r14, %r3, %r14;
    setp.lo.u32 %p4, %r19, 63;
    @!%p4 shr.u32 %r23, %r3, 2;
    cvt.s64.s32 %rd8, %r3;
    shl.b64 %rd13, %rd8, 2;
    mad.lo.u32 %r18, %r14, %r3, %r23;
    selp.b32 %r22, %r23, %r23, %p4;
    min.u32 %r16, %r19, 65536;
    xor.b32 %r13, %r22, %r3;
    add.s32 %r15, %r13, 8;
    min.u32 %r17, %r22, %r16;
    mul.wide.s32 %rd8, %r19, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
