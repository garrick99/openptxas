.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd15, %r3, %r3;
    setp.ne.s32 %p1, %r3, %r3;
    @!%p1 and.b32 %r21, %r3, 2147483647;
    add.u32 %r4, %r3, %r3;
    shr.s32 %r8, %r3, 0;
    add.u32 %r24, %r4, %r4;
    shl.b32 %r27, %r4, 16;
    and.b32 %r9, %r27, 5;
    mad.lo.s32 %r15, %r21, %r4, %r21;
    shr.s32 %r25, %r21, 2;
    min.s32 %r5, %r24, 65536;
    mul.wide.s32 %rd6, %r8, %r24;
    or.b32 %r23, %r8, %r3;
    and.b32 %r16, %r5, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
