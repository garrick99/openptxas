.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r12, %r3, 2147483648;
    mul.wide.u32 %rd7, %r12, %r3;
    mad.lo.u32 %r27, %r3, %r3, %r12;
    shr.u64 %rd14, %rd7, 7;
    mad.lo.u32 %r26, %r12, %r12, %r27;
    add.s32 %r17, %r12, %r3;
    min.s64 %rd14, %rd14, %rd7;
    cvt.s64.s32 %rd5, %r17;
    min.u64 %rd7, %rd5, %rd5;
    sub.s64 %rd12, %rd14, %rd14;
    mul.lo.s32 %r24, %r27, 65535;
    or.b32 %r13, %r24, 1;
    shr.u32 %r23, %r27, 3;
    max.s64 %rd5, %rd14, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
