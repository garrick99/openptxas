.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r14, %r3, %r3;
    sub.s32 %r19, %r14, %r14;
    cvt.u64.u32 %rd12, %r14;
    shr.s64 %rd6, %rd12, 33;
    setp.le.u32 %p1, %r3, %r19;
    @%p1 selp.b32 %r20, %r14, %r19, %p1;
    max.u32 %r21, %r3, %r3;
    cvt.u32.u64 %r4, %rd6;
    add.s32 %r4, %r14, 256;
    min.s32 %r26, %r4, 3;
    setp.gt.u32 %p3, %r21, %r20;
    @!%p3 mul.wide.s32 %rd8, %r21, %r20;
    setp.lt.u32 %p3, %r14, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
