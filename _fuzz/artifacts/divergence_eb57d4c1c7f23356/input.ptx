.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r12, %r3, 63;
    mad.lo.u32 %r8, %r3, %r3, %r3;
    min.u32 %r7, %r3, 65535;
    cvt.s64.s32 %rd5, %r7;
    shr.u64 %rd6, %rd5, 32;
    max.u64 %rd14, %rd5, %rd6;
    add.s64 %rd8, %rd5, %rd6;
    shl.b32 %r6, %r8, 1;
    cvt.u32.u64 %r7, %rd14;
    setp.lt.u32 %p1, %r8, %r7;
    @%p1 mul.wide.s32 %rd9, %r7, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
