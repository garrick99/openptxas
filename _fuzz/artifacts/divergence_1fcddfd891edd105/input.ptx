.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    cvt.s32.s64 %r9, %rd13;
    sub.u32 %r7, %r9, 4;
    setp.lo.u32 %p4, %r7, %r3;
    setp.ne.u32 %p2, %r7, 15;
    @%p2 selp.b32 %r14, %r9, %r9, %p4;
    cvt.s32.s64 %r16, %rd13;
    mul.wide.u32 %rd13, %r9, %r14;
    sub.u32 %r4, %r16, %r7;
    shl.b64 %rd8, %rd13, 31;
    selp.b32 %r16, %r16, %r9, %p4;
    or.b32 %r14, %r14, %r9;
    max.s64 %rd7, %rd13, %rd13;
    max.u32 %r6, %r3, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
