.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p2, %r3, %r3;
    @%p2 shr.u32 %r7, %r3, 4;
    shr.u32 %r20, %r3, 7;
    setp.hi.u32 %p4, %r7, %r7;
    @%p4 cvt.u64.u32 %rd8, %r7;
    shl.b64 %rd13, %rd8, 62;
    mul.wide.s32 %rd6, %r20, %r7;
    max.s64 %rd14, %rd8, %rd13;
    setp.lo.u32 %p1, %r20, %r20;
    @%p1 cvt.s32.s64 %r13, %rd13;
    add.s32 %r25, %r13, %r3;
    and.b64 %rd6, %rd14, %rd13;
    min.s32 %r15, %r3, %r25;
    shl.b32 %r26, %r25, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
