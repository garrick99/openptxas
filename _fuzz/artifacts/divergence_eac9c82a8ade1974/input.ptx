.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p4, %r3, %r3;
    setp.lt.s32 %p4, %r3, 4;
    @%p4 cvt.s64.s32 %rd5, %r3;
    add.s64 %rd8, %rd5, %rd5;
    cvt.u32.u64 %r25, %rd5;
    shr.s64 %rd14, %rd5, 47;
    shr.s32 %r14, %r25, 3;
    shr.s32 %r14, %r3, 30;
    mad.lo.u32 %r11, %r25, %r25, %r3;
    mad.lo.u32 %r6, %r11, %r3, %r11;
    min.s32 %r26, %r14, %r11;
    and.b32 %r16, %r3, %r11;
    sub.s64 %rd9, %rd14, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
