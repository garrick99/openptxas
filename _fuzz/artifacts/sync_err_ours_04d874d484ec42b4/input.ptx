.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p2, %r3, %r3;
    @%p2 add.s32 %r20, %r3, 2;
    shr.u32 %r22, %r20, 4;
    setp.hi.u32 %p2, %r3, 3;
    cvt.u64.u32 %rd13, %r3;
    shr.s32 %r4, %r22, 16;
    or.b32 %r27, %r22, %r22;
    min.u32 %r18, %r4, 256;
    add.u32 %r16, %r4, %r4;
    cvt.u32.u64 %r24, %rd13;
    min.u32 %r21, %r27, %r16;
    sub.s64 %rd10, %rd13, %rd13;
    shl.b64 %rd12, %rd13, 1;
    mul.wide.u32 %rd11, %r3, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
