    max.s64 %rd12, %rd13, %rd8;
    sub.s64 %rd6, %rd12, %rd13;
    min.u32 %r26, %r16, 4;
    max.s32 %r26, %r16, 2147483647;
    xor.b32 %r14, %r3, %r14;
    cvt.s64.s32 %rd15, %r14;
    setp.lt.u32 %p1, %r16, 2;
    or.b32 %r19, %r26, 4;
    sub.s64 %rd5, %rd15, %rd6;
    mul.lo.u32 %r18, %r26, 63;
