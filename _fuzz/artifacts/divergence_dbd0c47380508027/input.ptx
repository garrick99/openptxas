.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p4, %r3, 8;
    setp.hs.u32 %p4, %r3, 5;
    @%p4 add.s32 %r24, %r3, 1;
    cvt.u64.u32 %rd14, %r3;
    setp.hs.u32 %p4, %r3, 8;
    @!%p4 shr.s32 %r5, %r3, 31;
    shl.b64 %rd7, %rd14, 4;
    cvt.u64.u32 %rd14, %r5;
    setp.le.u32 %p1, %r5, %r24;
    @!%p1 sub.u64 %rd13, %rd7, %rd14;
    cvt.s64.s32 %rd6, %r3;
    mad.lo.s32 %r27, %r24, %r5, %r24;
    xor.b32 %r6, %r24, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
