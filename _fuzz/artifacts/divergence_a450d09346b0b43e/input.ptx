.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p1, %r3, 4294967295;
    @!%p1 cvt.s64.s32 %rd10, %r3;
    selp.b32 %r8, %r3, %r3, %p1;
    add.u32 %r13, %r8, 3;
    min.u32 %r18, %r3, 4294967295;
    min.u32 %r25, %r3, %r3;
    max.u32 %r27, %r25, %r13;
    shr.u32 %r24, %r8, 15;
    mul.lo.s32 %r21, %r13, 15;
    shl.b32 %r6, %r13, 2;
    max.s32 %r6, %r18, %r27;
    shr.u32 %r16, %r24, 4;
    min.u32 %r17, %r3, %r24;
    selp.b32 %r24, %r18, %r8, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
