.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r15, %r3, 2;
    or.b32 %r19, %r15, %r3;
    cvt.u64.u32 %rd8, %r3;
    shl.b32 %r17, %r19, 15;
    setp.lt.s32 %p2, %r19, 7;
    @%p2 shr.u32 %r20, %r19, 7;
    mul.lo.s32 %r5, %r17, 65536;
    sub.s32 %r7, %r19, 4294967295;
    setp.eq.s32 %p3, %r15, %r5;
    and.b32 %r17, %r7, %r5;
    add.u64 %rd7, %rd8, %rd8;
    cvt.s64.s32 %rd11, %r5;
    mad.lo.u32 %r4, %r15, %r20, %r7;
    or.b32 %r6, %r19, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
