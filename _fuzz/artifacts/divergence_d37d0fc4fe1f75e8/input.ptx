.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r25, %r3, 255;
    sub.u32 %r12, %r25, 65535;
    shl.b32 %r14, %r12, 31;
    shl.b32 %r27, %r25, 2;
    add.u32 %r19, %r27, %r12;
    min.s32 %r26, %r14, 64;
    cvt.u64.u32 %rd10, %r12;
    or.b32 %r10, %r14, 16;
    shr.u32 %r24, %r12, 4;
    and.b32 %r22, %r27, %r14;
    add.s32 %r22, %r24, 1;
    min.u32 %r11, %r25, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
