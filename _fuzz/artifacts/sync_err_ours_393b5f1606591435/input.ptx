.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    sub.u32 %r5, %r3, %r3;
    shr.u32 %r14, %r5, 30;
    shr.s32 %r26, %r5, 1;
    mad.lo.s32 %r15, %r26, %r3, %r5;
    shr.u32 %r5, %r5, 31;
    xor.b32 %r12, %r26, %r14;
    setp.hs.u32 %p3, %r3, %r5;
    @!%p3 mad.lo.s32 %r11, %r12, %r14, %r26;
    shl.b32 %r19, %r3, 4;
    xor.b32 %r15, %r5, %r12;
    add.s32 %r7, %r19, 5;
    add.s32 %r19, %r26, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
