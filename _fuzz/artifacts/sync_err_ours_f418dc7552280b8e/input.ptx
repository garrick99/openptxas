.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p4, %r3, 2;
    setp.le.u32 %p3, %r3, %r3;
    @!%p3 mul.wide.u32 %rd14, %r3, %r3;
    max.s64 %rd12, %rd14, %rd14;
    shl.b64 %rd8, %rd12, 30;
    xor.b32 %r14, %r3, %r3;
    shl.b32 %r16, %r3, 7;
    selp.b32 %r4, %r14, %r14, %p3;
    shr.u64 %rd10, %rd14, 31;
    cvt.u32.u64 %r8, %rd8;
    add.s32 %r11, %r16, 5;
    sub.s32 %r22, %r16, 2147483647;
    shl.b64 %rd6, %rd10, 32;
    shl.b32 %r22, %r16, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
