.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r22, %r3, 0;
    setp.ge.u32 %p1, %r3, %r3;
    sub.s32 %r24, %r3, %r22;
    mul.wide.u32 %rd9, %r3, %r3;
    setp.ge.s32 %p4, %r22, 255;
    @!%p4 mad.lo.s32 %r23, %r24, %r22, %r22;
    or.b32 %r19, %r22, 63;
    add.s32 %r15, %r22, %r19;
    shr.s32 %r17, %r3, 0;
    selp.b32 %r18, %r23, %r19, %p1;
    add.s32 %r14, %r3, %r22;
    min.s32 %r24, %r14, 5;
    add.u64 %rd15, %rd9, %rd9;
    mul.lo.u32 %r26, %r23, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
