.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    or.b32 %r20, %r3, 63;
    cvt.s32.s64 %r8, %rd6;
    max.u32 %r6, %r3, 0;
    sub.u32 %r14, %r3, %r6;
    add.u32 %r13, %r6, %r6;
    min.s32 %r11, %r13, %r3;
    cvt.s64.s32 %rd5, %r14;
    mad.lo.u32 %r4, %r20, %r11, %r13;
    mul.wide.u32 %rd6, %r6, %r20;
    add.s32 %r9, %r11, %r20;
    and.b32 %r12, %r14, 4294967295;
    min.u64 %rd12, %rd5, %rd5;
    max.u32 %r10, %r13, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
