.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r25, %r3, %r3;
    mul.lo.s32 %r5, %r3, %r25;
    cvt.s64.s32 %rd9, %r3;
    mad.lo.s32 %r18, %r25, %r25, %r3;
    sub.s32 %r15, %r18, %r5;
    setp.lt.u32 %p4, %r18, %r25;
    @%p4 cvt.u32.u64 %r6, %rd9;
    xor.b32 %r16, %r25, 3;
    cvt.s32.s64 %r19, %rd9;
    selp.b32 %r26, %r25, %r25, %p4;
    max.u32 %r13, %r15, %r5;
    shr.u64 %rd7, %rd9, 63;
    setp.hi.u32 %p2, %r26, %r15;
    mad.lo.s32 %r23, %r5, %r13, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
