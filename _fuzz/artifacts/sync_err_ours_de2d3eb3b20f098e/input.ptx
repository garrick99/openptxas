.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r21, %r3, 63;
    min.u32 %r20, %r3, 31;
    add.s32 %r11, %r20, %r21;
    shr.u32 %r8, %r11, 1;
    cvt.s64.s32 %rd12, %r8;
    min.s64 %rd5, %rd12, %rd12;
    setp.lt.u32 %p2, %r20, %r11;
    sub.u64 %rd13, %rd12, %rd12;
    cvt.s32.s64 %r4, %rd5;
    and.b32 %r15, %r20, %r20;
    shl.b32 %r24, %r4, 30;
    mul.wide.s32 %rd15, %r4, %r8;
    min.u32 %r9, %r3, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
