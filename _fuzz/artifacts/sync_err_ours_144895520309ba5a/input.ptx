.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    shr.s32 %r4, %r3, 3;
    setp.ge.u32 %p3, %r4, 1;
    @!%p3 shr.u32 %r12, %r3, 2;
    max.s32 %r16, %r4, 0;
    shr.u32 %r20, %r12, 1;
    and.b32 %r7, %r16, %r20;
    max.u32 %r13, %r4, %r7;
    min.u32 %r18, %r13, %r12;
    cvt.u32.u64 %r4, %rd14;
    max.u32 %r20, %r13, %r13;
    shr.s32 %r19, %r20, 7;
    and.b32 %r20, %r4, %r4;
    cvt.u32.u64 %r26, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
