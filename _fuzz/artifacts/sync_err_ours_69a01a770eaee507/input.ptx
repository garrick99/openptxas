.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    add.u32 %r23, %r3, 2147483648;
    xor.b64 %rd12, %rd13, %rd13;
    add.s32 %r24, %r3, 7;
    add.s32 %r10, %r24, %r23;
    mul.wide.s32 %rd7, %r3, %r23;
    cvt.s32.s64 %r13, %rd13;
    max.u32 %r13, %r10, %r23;
    max.s32 %r19, %r13, %r23;
    cvt.s64.s32 %rd12, %r10;
    mad.lo.s32 %r24, %r13, %r19, %r3;
    setp.le.s32 %p4, %r23, 4294967295;
    setp.gt.s32 %p3, %r10, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
