.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r24, %r3, %r3;
    mad.lo.u32 %r4, %r3, %r24, %r24;
    max.s32 %r23, %r3, %r4;
    setp.le.s32 %p2, %r24, %r23;
    mul.wide.s32 %rd10, %r24, %r24;
    min.u64 %rd12, %rd10, %rd10;
    setp.ge.u32 %p4, %r4, 255;
    sub.u64 %rd14, %rd12, %rd12;
    min.u64 %rd10, %rd14, %rd12;
    mul.wide.s32 %rd5, %r23, %r23;
    sub.u32 %r25, %r4, %r3;
    selp.b32 %r5, %r3, %r23, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
