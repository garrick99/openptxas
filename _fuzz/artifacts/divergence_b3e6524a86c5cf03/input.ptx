.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r11, %r3, 31;
    mul.wide.u32 %rd12, %r11, %r11;
    or.b32 %r13, %r11, 4;
    setp.le.s32 %p3, %r3, 4;
    @%p3 shr.s64 %rd14, %rd12, 7;
    shr.s32 %r15, %r11, 1;
    max.u64 %rd12, %rd12, %rd12;
    min.u32 %r18, %r15, %r13;
    shl.b64 %rd15, %rd12, 3;
    shr.s64 %rd10, %rd12, 2;
    sub.s32 %r17, %r11, 32;
    min.u32 %r10, %r15, 2147483647;
    setp.ge.s32 %p1, %r15, 8;
    setp.ls.u32 %p4, %r11, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
