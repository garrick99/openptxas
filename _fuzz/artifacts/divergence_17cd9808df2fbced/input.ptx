.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfi.b32 %r5, %r3, %r3, 24, 31;
    xor.b32 %r19, %r3, 3;
    clz.b32 %r15, %r3;
    bfe.s32 %r17, %r15, 8, 16;
    bfi.b32 %r7, %r15, %r19, 15, 2;
    brev.b32 %r23, %r5;
    clz.b32 %r9, %r15;
    clz.b32 %r9, %r17;
    clz.b32 %r17, %r23;
    popc.b32 %r13, %r17;
    bfe.u32 %r6, %r7, 1, 2;
    bfi.b32 %r9, %r7, %r7, 31, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
