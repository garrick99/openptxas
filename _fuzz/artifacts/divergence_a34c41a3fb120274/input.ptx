.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r23, %r3, 65535;
    shl.b32 %r7, %r3, 7;
    sub.u32 %r17, %r3, 7;
    shr.u32 %r22, %r17, 15;
    or.b32 %r23, %r3, 63;
    cvt.u64.u32 %rd8, %r17;
    max.u32 %r17, %r23, %r17;
    cvt.u64.u32 %rd14, %r3;
    sub.u32 %r18, %r23, 5;
    and.b32 %r24, %r17, %r23;
    cvt.u32.u64 %r8, %rd14;
    min.u32 %r26, %r18, %r17;
    max.u32 %r26, %r24, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
