.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r26, %r3, 255;
    shr.u32 %r16, %r3, 3;
    cvt.u64.u32 %rd12, %r3;
    sub.u32 %r18, %r26, 8;
    mul.wide.u32 %rd10, %r26, %r26;
    shl.b32 %r24, %r3, 3;
    or.b32 %r12, %r26, %r18;
    or.b32 %r23, %r24, %r26;
    max.u32 %r26, %r16, %r26;
    shr.s32 %r16, %r3, 15;
    cvt.u32.u64 %r12, %rd12;
    setp.eq.u32 %p2, %r18, %r3;
    @%p2 mul.wide.s32 %rd14, %r3, %r16;
    and.b64 %rd11, %rd14, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
