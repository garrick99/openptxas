.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p1, %r3, 2;
    @!%p1 sub.s32 %r24, %r3, %r3;
    min.u32 %r15, %r24, 1;
    setp.ls.u32 %p1, %r24, 255;
    @%p1 add.s32 %r8, %r24, %r24;
    min.u32 %r11, %r24, %r8;
    and.b32 %r26, %r24, 2147483648;
    selp.b32 %r19, %r24, %r26, %p1;
    add.s32 %r12, %r26, %r3;
    setp.ge.s32 %p1, %r24, 4294967295;
    @%p1 cvt.u64.u32 %rd7, %r15;
    xor.b32 %r16, %r15, %r19;
    cvt.s32.s64 %r4, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
