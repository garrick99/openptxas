.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r19, %r3, %r3;
    shl.b32 %r10, %r19, 30;
    sub.s32 %r10, %r19, %r10;
    setp.hi.u32 %p4, %r10, %r19;
    max.s32 %r14, %r10, 4;
    and.b32 %r13, %r19, %r3;
    cvt.u64.u32 %rd13, %r10;
    and.b32 %r7, %r13, %r3;
    selp.b32 %r20, %r14, %r13, %p4;
    cvt.u64.u32 %rd9, %r7;
    or.b32 %r27, %r14, %r19;
    min.s32 %r7, %r7, 32;
    mad.lo.s32 %r18, %r27, %r14, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
