.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r24, %r3, 2147483647;
    add.s32 %r12, %r3, 255;
    shl.b32 %r27, %r24, 3;
    or.b32 %r9, %r24, %r27;
    cvt.u64.u32 %rd7, %r27;
    or.b32 %r23, %r24, 64;
    cvt.s32.s64 %r5, %rd7;
    shl.b32 %r22, %r12, 1;
    min.u32 %r14, %r27, %r5;
    setp.gt.s32 %p3, %r22, %r24;
    @%p3 add.u32 %r4, %r24, %r3;
    cvt.s32.s64 %r23, %rd7;
    selp.b32 %r7, %r22, %r12, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
