.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd12, %r3, %r3;
    setp.eq.s32 %p2, %r3, %r3;
    @%p2 mul.wide.u32 %rd12, %r3, %r3;
    add.s64 %rd12, %rd12, %rd12;
    shl.b32 %r4, %r3, 1;
    shr.s32 %r26, %r4, 31;
    xor.b64 %rd14, %rd12, %rd12;
    add.u32 %r23, %r26, 64;
    or.b32 %r15, %r23, 5;
    min.u32 %r16, %r26, %r15;
    mad.lo.u32 %r9, %r16, %r15, %r26;
    mul.wide.s32 %rd13, %r23, %r16;
    cvt.s64.s32 %rd9, %r26;
    shr.u64 %rd14, %rd12, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
