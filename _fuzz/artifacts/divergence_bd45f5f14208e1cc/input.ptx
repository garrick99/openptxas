.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    shl.b32 %r7, %r3, 2;
    cvt.u32.u64 %r21, %rd8;
    mul.lo.u32 %r18, %r21, 255;
    mul.wide.s32 %rd7, %r18, %r3;
    xor.b64 %rd5, %rd8, %rd8;
    mad.lo.s32 %r23, %r21, %r3, %r18;
    min.s64 %rd15, %rd8, %rd5;
    mul.wide.u32 %rd8, %r3, %r18;
    setp.gt.u32 %p4, %r21, 32;
    @%p4 selp.b32 %r7, %r7, %r23, %p4;
    shr.u32 %r17, %r7, 15;
    add.s32 %r5, %r17, %r7;
    cvt.u64.u32 %rd5, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
