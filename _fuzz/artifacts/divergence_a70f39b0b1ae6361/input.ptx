.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    sub.u32 %r14, %r3, 0;
    cvt.s64.s32 %rd6, %r14;
    add.s32 %r16, %r3, %r14;
    setp.lt.u32 %p4, %r14, 64;
    @%p4 xor.b32 %r7, %r16, 32;
    and.b32 %r8, %r3, %r14;
    shl.b32 %r8, %r3, 7;
    shr.u32 %r19, %r3, 2;
    mad.lo.u32 %r6, %r7, %r14, %r8;
    add.s32 %r10, %r14, 65535;
    add.s32 %r26, %r3, 3;
    mad.lo.u32 %r25, %r16, %r3, %r14;
    sub.s32 %r13, %r6, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
