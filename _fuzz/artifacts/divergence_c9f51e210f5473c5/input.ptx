.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r19, %r3, 1;
    sub.u32 %r22, %r19, 4;
    cvt.u64.u32 %rd12, %r22;
    mad.lo.s32 %r21, %r22, %r22, %r19;
    setp.lt.s32 %p2, %r3, %r22;
    @%p2 cvt.s64.s32 %rd13, %r21;
    setp.ls.u32 %p1, %r3, 64;
    @%p1 mad.lo.s32 %r4, %r21, %r21, %r19;
    shr.u32 %r25, %r4, 30;
    shl.b32 %r26, %r4, 0;
    shr.u64 %rd5, %rd12, 33;
    shl.b64 %rd15, %rd12, 7;
    mul.wide.u32 %rd12, %r26, %r19;
    and.b32 %r7, %r26, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
