.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r22, %r3, %r3, %r3;
    setp.ls.u32 %p3, %r22, %r3;
    @%p3 xor.b32 %r11, %r22, %r22;
    mul.lo.s32 %r5, %r22, 3;
    add.s32 %r22, %r3, %r22;
    mul.wide.s32 %rd8, %r11, %r11;
    mul.wide.u32 %rd7, %r22, %r22;
    or.b32 %r27, %r11, 16;
    cvt.s32.s64 %r6, %rd8;
    cvt.u32.u64 %r22, %rd7;
    max.u32 %r21, %r11, %r3;
    add.s32 %r13, %r11, %r11;
    setp.lt.u32 %p1, %r6, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
