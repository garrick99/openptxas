.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    shl.b32 %r19, %r3, 3;
    mul.wide.s32 %rd14, %r19, %r3;
    max.u32 %r17, %r19, 255;
    mul.wide.s32 %rd14, %r3, %r3;
    setp.le.s32 %p2, %r19, 31;
    @%p2 max.s32 %r22, %r3, 5;
    cvt.u64.u32 %rd8, %r22;
    max.s32 %r14, %r3, %r22;
    cvt.s32.s64 %r25, %rd6;
    mul.lo.u64 %rd5, %rd8, %rd14;
    mul.lo.u32 %r10, %r25, 2147483648;
    and.b32 %r24, %r3, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
