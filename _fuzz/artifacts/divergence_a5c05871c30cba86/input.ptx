.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd7, %r3, %r3;
    min.u32 %r16, %r3, %r3;
    shr.s64 %rd15, %rd7, 7;
    setp.ne.u32 %p3, %r16, %r3;
    @%p3 mad.lo.s32 %r10, %r3, %r16, %r3;
    selp.b32 %r5, %r3, %r3, %p3;
    shl.b64 %rd6, %rd15, 15;
    cvt.s64.s32 %rd15, %r16;
    add.s32 %r22, %r10, %r16;
    shr.s64 %rd11, %rd15, 62;
    mul.lo.u32 %r19, %r5, %r10;
    shr.s64 %rd8, %rd15, 15;
    mul.lo.u32 %r10, %r22, 4;
    cvt.u64.u32 %rd7, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
