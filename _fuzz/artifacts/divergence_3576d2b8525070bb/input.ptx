.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r17, %r3, %r3, %r3;
    and.b32 %r26, %r17, %r17;
    mul.wide.u32 %rd10, %r3, %r26;
    setp.le.s32 %p1, %r3, %r3;
    @!%p1 mad.lo.u32 %r15, %r26, %r3, %r17;
    xor.b32 %r16, %r17, 3;
    or.b64 %rd14, %rd10, %rd10;
    add.u32 %r13, %r15, %r17;
    min.u64 %rd9, %rd14, %rd14;
    shr.u64 %rd13, %rd14, 2;
    mul.lo.s32 %r7, %r26, %r26;
    shl.b64 %rd5, %rd13, 15;
    mad.lo.u32 %r10, %r16, %r26, %r7;
    sub.s32 %r19, %r16, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
