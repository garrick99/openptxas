.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r5, %r3, 1;
    sub.s32 %r25, %r5, 256;
    mul.lo.s32 %r23, %r5, 256;
    cvt.u64.u32 %rd12, %r3;
    cvt.s32.s64 %r6, %rd12;
    max.u32 %r21, %r6, 63;
    min.s32 %r20, %r25, 5;
    shr.u32 %r20, %r3, 15;
    mul.wide.s32 %rd9, %r5, %r21;
    mad.lo.u32 %r15, %r5, %r25, %r23;
    min.u32 %r20, %r5, 2147483648;
    sub.u32 %r6, %r5, %r3;
    shr.s64 %rd6, %rd12, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
