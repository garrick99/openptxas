.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r24, %r3, 65535;
    mad.lo.s32 %r11, %r24, %r24, %r24;
    mul.wide.s32 %rd14, %r24, %r3;
    sub.s32 %r21, %r24, 4;
    shl.b64 %rd5, %rd14, 48;
    cvt.s32.s64 %r21, %rd14;
    xor.b32 %r19, %r3, %r21;
    setp.hi.u32 %p1, %r19, 0;
    @!%p1 selp.b32 %r12, %r21, %r24, %p1;
    shr.s32 %r17, %r3, 30;
    selp.b32 %r19, %r11, %r21, %p1;
    cvt.s64.s32 %rd15, %r21;
    shr.u64 %rd12, %rd5, 32;
    shl.b64 %rd12, %rd12, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
