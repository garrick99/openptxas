.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    min.u32 %r27, %r3, %r3;
    mad.lo.u32 %r23, %r27, %r3, %r3;
    shl.b32 %r26, %r23, 4;
    sub.s32 %r14, %r3, %r26;
    shr.s64 %rd8, %rd14, 15;
    mul.wide.u32 %rd5, %r27, %r23;
    cvt.s64.s32 %rd14, %r23;
    mul.wide.s32 %rd12, %r14, %r27;
    shr.u32 %r17, %r3, 3;
    add.s64 %rd8, %rd14, %rd12;
    xor.b32 %r22, %r26, 5;
    min.s64 %rd8, %rd14, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
