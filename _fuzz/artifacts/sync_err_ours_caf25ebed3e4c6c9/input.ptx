.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p2, %r3, 63;
    @!%p2 selp.b32 %r23, %r3, %r3, %p2;
    cvt.u64.u32 %rd9, %r3;
    add.s32 %r15, %r3, 255;
    setp.lt.u32 %p1, %r23, 63;
    shr.u64 %rd7, %rd9, 31;
    setp.eq.u32 %p4, %r23, 5;
    setp.lt.s32 %p1, %r15, 1;
    setp.lo.u32 %p4, %r15, 2;
    add.u32 %r4, %r23, %r15;
    shr.u64 %rd9, %rd7, 0;
    max.u32 %r4, %r15, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
