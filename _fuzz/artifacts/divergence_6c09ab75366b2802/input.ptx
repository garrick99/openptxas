.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r24, %r3, 4;
    or.b32 %r20, %r3, 4294967295;
    mul.wide.u32 %rd10, %r3, %r20;
    min.s64 %rd15, %rd10, %rd10;
    sub.u32 %r5, %r20, %r24;
    mul.lo.s32 %r5, %r24, %r20;
    mul.wide.u32 %rd11, %r5, %r3;
    add.u32 %r6, %r5, 0;
    setp.ls.u32 %p4, %r3, %r5;
    mad.lo.u32 %r9, %r24, %r24, %r20;
    shr.s32 %r24, %r6, 15;
    max.u32 %r18, %r3, %r20;
    xor.b32 %r13, %r20, 2147483647;
    selp.b32 %r24, %r20, %r9, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
