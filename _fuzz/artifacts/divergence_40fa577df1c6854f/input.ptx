.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r11, %r3, %r3;
    cvt.s64.s32 %rd7, %r11;
    add.u32 %r12, %r3, 256;
    add.s32 %r27, %r3, %r11;
    mad.lo.s32 %r11, %r3, %r27, %r27;
    mul.lo.s32 %r9, %r3, 2147483648;
    sub.u32 %r17, %r9, %r3;
    setp.lt.u32 %p2, %r3, 7;
    @!%p2 and.b32 %r15, %r3, %r12;
    mad.lo.u32 %r24, %r15, %r17, %r11;
    sub.u32 %r10, %r12, %r27;
    sub.s32 %r11, %r3, %r24;
    cvt.s64.s32 %rd7, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
