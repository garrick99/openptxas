.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r17, %r3, 5;
    mul.lo.u32 %r21, %r3, %r17;
    sub.s32 %r23, %r17, %r21;
    sub.s32 %r22, %r21, 65535;
    mul.wide.s32 %rd10, %r3, %r17;
    shl.b64 %rd6, %rd10, 7;
    xor.b32 %r15, %r17, 4;
    mul.wide.s32 %rd13, %r23, %r21;
    sub.u32 %r25, %r15, 65536;
    mul.wide.s32 %rd12, %r17, %r21;
    mul.wide.u32 %rd5, %r22, %r17;
    cvt.s32.s64 %r27, %rd10;
    mul.lo.s32 %r19, %r17, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
