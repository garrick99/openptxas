.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    min.s64 %rd14, %rd10, %rd10;
    or.b32 %r23, %r3, 255;
    mul.wide.u32 %rd6, %r23, %r23;
    shl.b32 %r9, %r23, 7;
    mul.lo.u32 %r6, %r23, %r3;
    and.b32 %r10, %r23, 16;
    add.u64 %rd6, %rd10, %rd6;
    setp.lt.s32 %p4, %r3, %r3;
    setp.le.u32 %p3, %r6, %r9;
    @%p3 cvt.s32.s64 %r17, %rd10;
    cvt.u64.u32 %rd13, %r17;
    min.u32 %r26, %r17, 2147483648;
    setp.eq.s32 %p2, %r9, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
