.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd5, %r3, %r3;
    shl.b64 %rd8, %rd5, 31;
    max.u64 %rd6, %rd5, %rd5;
    setp.ne.s32 %p1, %r3, %r3;
    sub.u32 %r21, %r3, 65536;
    mul.lo.u32 %r7, %r3, %r21;
    min.s32 %r20, %r3, %r3;
    sub.u32 %r12, %r20, %r7;
    shl.b32 %r10, %r20, 2;
    cvt.s32.s64 %r11, %rd5;
    setp.ne.u32 %p4, %r3, %r12;
    @%p4 max.s32 %r17, %r7, 3;
    min.u64 %rd6, %rd6, %rd8;
    cvt.u64.u32 %rd15, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
