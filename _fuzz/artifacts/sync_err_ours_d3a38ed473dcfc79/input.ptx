    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r24, %r3, 2;
    max.u32 %r27, %r24, 2147483647;
    cvt.s64.s32 %rd12, %r24;
    or.b32 %r8, %r3, %r3;
    mul.wide.u32 %rd9, %r27, %r24;
    sub.u32 %r23, %r24, %r8;
    sub.s32 %r18, %r3, 8;
    sub.u32 %r15, %r24, %r18;
    max.u32 %r11, %r27, %r27;
    max.u64 %rd10, %rd9, %rd12;
    mul.wide.u32 %rd9, %r8, %r23;
    add.s32 %r20, %r8, %r18;
    mul.wide.s32 %rd14, %r24, %r15;
    xor.b32 %r18, %r18, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
