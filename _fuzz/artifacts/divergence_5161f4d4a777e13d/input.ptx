.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfe.u32 %r20, %r3, 4, 4;
    bfe.s32 %r21, %r3, 8, 32;
    bfe.s32 %r6, %r3, 23, 31;
    bfe.s32 %r20, %r6, 24, 31;
    bfi.b32 %r12, %r21, %r20, 8, 31;
    bfe.u32 %r5, %r6, 16, 4;
    bfe.s32 %r5, %r6, 8, 32;
    brev.b32 %r7, %r21;
    min.u32 %r4, %r12, 2;
    bfe.s32 %r11, %r6, 24, 2;
    clz.b32 %r8, %r7;
    bfi.b32 %r4, %r6, %r5, 15, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
