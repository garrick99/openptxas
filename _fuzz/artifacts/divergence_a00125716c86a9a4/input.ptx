.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r20, %r3, %r3;
    cvt.s64.s32 %rd12, %r20;
    mul.lo.s32 %r19, %r3, %r3;
    setp.lt.s32 %p4, %r3, 15;
    @!%p4 shr.u64 %rd8, %rd12, 47;
    cvt.s32.s64 %r4, %rd12;
    and.b32 %r13, %r19, %r4;
    shr.s64 %rd12, %rd8, 63;
    cvt.u32.u64 %r16, %rd12;
    shr.s64 %rd14, %rd8, 48;
    mul.wide.s32 %rd12, %r16, %r4;
    mul.lo.s32 %r21, %r3, %r3;
    sub.s32 %r7, %r16, 4;
    selp.b32 %r12, %r7, %r4, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
