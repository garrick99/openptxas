.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r10, %r3, %r3;
    max.s32 %r22, %r10, 256;
    shr.s32 %r11, %r10, 0;
    setp.eq.u32 %p4, %r3, %r22;
    @%p4 shr.s32 %r5, %r11, 2;
    setp.ls.u32 %p1, %r22, %r3;
    cvt.s64.s32 %rd12, %r22;
    selp.b32 %r18, %r5, %r22, %p4;
    min.u64 %rd10, %rd12, %rd12;
    sub.s32 %r11, %r18, 4294967295;
    mad.lo.s32 %r21, %r5, %r22, %r5;
    mul.wide.s32 %rd6, %r22, %r22;
    min.u32 %r19, %r3, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
