.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r10, %r3, 64;
    add.s32 %r8, %r3, %r3;
    cvt.u64.u32 %rd12, %r3;
    shr.u32 %r9, %r3, 16;
    sub.u64 %rd13, %rd12, %rd12;
    max.s64 %rd8, %rd13, %rd13;
    shl.b64 %rd11, %rd13, 62;
    setp.gt.s32 %p4, %r9, 8;
    @!%p4 shr.s64 %rd14, %rd11, 31;
    add.u32 %r18, %r9, 256;
    add.u64 %rd14, %rd12, %rd8;
    setp.ge.s32 %p4, %r10, 65535;
    @!%p4 add.s32 %r14, %r10, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
