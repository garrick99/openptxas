.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    add.s32 %r23, %r3, 0;
    or.b32 %r5, %r23, %r3;
    cvt.u64.u32 %rd7, %r5;
    add.u32 %r26, %r5, 31;
    or.b64 %rd6, %rd9, %rd7;
    sub.s64 %rd13, %rd7, %rd6;
    add.u64 %rd7, %rd6, %rd6;
    setp.gt.s32 %p3, %r3, %r5;
    @%p3 shl.b32 %r27, %r26, 0;
    mad.lo.u32 %r5, %r27, %r23, %r3;
    mad.lo.u32 %r11, %r26, %r5, %r5;
    sub.s32 %r9, %r27, %r11;
    setp.eq.s32 %p4, %r5, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
