.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p1, %r3, %r3;
    @%p1 cvt.u64.u32 %rd10, %r3;
    add.s32 %r21, %r3, %r3;
    sub.u32 %r9, %r3, %r3;
    cvt.s64.s32 %rd14, %r21;
    cvt.u32.u64 %r19, %rd14;
    mul.wide.u32 %rd11, %r19, %r9;
    cvt.s64.s32 %rd8, %r19;
    mad.lo.u32 %r10, %r3, %r19, %r9;
    mul.wide.u32 %rd8, %r10, %r21;
    shr.s64 %rd7, %rd14, 16;
    setp.gt.s32 %p4, %r9, 31;
    @%p4 mul.lo.u32 %r6, %r3, 15;
    shl.b64 %rd13, %rd10, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
