.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd14, %r3, %r3;
    min.u32 %r22, %r3, %r3;
    min.s32 %r17, %r22, 3;
    cvt.s32.s64 %r11, %rd14;
    shr.u64 %rd9, %rd14, 32;
    mad.lo.s32 %r13, %r22, %r22, %r3;
    mul.wide.s32 %rd12, %r13, %r22;
    max.u64 %rd7, %rd9, %rd12;
    mad.lo.u32 %r21, %r13, %r11, %r22;
    setp.ne.s32 %p3, %r11, %r17;
    @!%p3 sub.u32 %r24, %r3, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
