.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r14, %r3, 5;
    mul.wide.s32 %rd11, %r14, %r3;
    or.b64 %rd14, %rd11, %rd11;
    cvt.s64.s32 %rd14, %r3;
    shl.b64 %rd5, %rd14, 33;
    shl.b32 %r6, %r3, 3;
    xor.b32 %r23, %r14, %r6;
    xor.b32 %r26, %r6, 31;
    mad.lo.s32 %r18, %r14, %r23, %r14;
    and.b32 %r16, %r23, 5;
    cvt.s32.s64 %r17, %rd11;
    mul.lo.u32 %r25, %r6, 8;
    mul.lo.u32 %r16, %r6, 4294967295;
    max.u64 %rd6, %rd5, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
