.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p1, %r3, 7;
    @!%p1 min.u32 %r9, %r3, %r3;
    cvt.s64.s32 %rd5, %r9;
    max.u32 %r20, %r9, %r9;
    mad.lo.s32 %r21, %r3, %r9, %r3;
    sub.s32 %r11, %r9, %r3;
    mad.lo.u32 %r7, %r3, %r21, %r9;
    cvt.u32.u64 %r19, %rd5;
    max.s32 %r12, %r19, %r7;
    shl.b64 %rd15, %rd5, 2;
    max.s32 %r21, %r7, %r12;
    max.u32 %r15, %r3, %r9;
    mad.lo.s32 %r8, %r3, %r21, %r20;
    setp.gt.u32 %p2, %r11, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
