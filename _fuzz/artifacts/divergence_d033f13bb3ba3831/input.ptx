.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r27, %r3, %r3;
    shl.b32 %r22, %r3, 15;
    mad.lo.s32 %r24, %r3, %r22, %r22;
    cvt.u64.u32 %rd11, %r24;
    mad.lo.u32 %r14, %r24, %r3, %r22;
    shr.s64 %rd10, %rd11, 1;
    cvt.s32.s64 %r24, %rd10;
    shr.s64 %rd6, %rd10, 0;
    mul.lo.u32 %r16, %r24, %r24;
    sub.s32 %r8, %r16, 4294967295;
    mul.wide.u32 %rd13, %r24, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
