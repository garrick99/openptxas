.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r23, %r3, %r3;
    sub.u32 %r20, %r23, %r23;
    xor.b32 %r25, %r23, 4294967295;
    add.s32 %r16, %r3, 4294967295;
    setp.lo.u32 %p3, %r3, %r3;
    @%p3 shr.s32 %r19, %r23, 0;
    mul.wide.u32 %rd14, %r3, %r19;
    shr.s64 %rd11, %rd14, 30;
    and.b32 %r5, %r20, %r3;
    mad.lo.u32 %r24, %r23, %r25, %r19;
    selp.b32 %r23, %r3, %r16, %p3;
    min.s64 %rd6, %rd14, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
