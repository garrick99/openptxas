.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r6, %r3, %r3;
    mul.lo.s32 %r14, %r6, 32;
    sub.u32 %r26, %r14, %r3;
    mad.lo.u32 %r7, %r26, %r14, %r26;
    cvt.s64.s32 %rd6, %r3;
    xor.b64 %rd13, %rd6, %rd6;
    cvt.u64.u32 %rd15, %r14;
    or.b32 %r19, %r6, 15;
    setp.le.u32 %p3, %r14, 3;
    @%p3 mul.lo.s64 %rd7, %rd13, %rd15;
    mad.lo.u32 %r11, %r6, %r19, %r3;
    or.b32 %r11, %r14, %r7;
    sub.u32 %r12, %r26, %r7;
    max.s64 %rd13, %rd15, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
