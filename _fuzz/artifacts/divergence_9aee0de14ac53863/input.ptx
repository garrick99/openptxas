.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r7, %r3, 1;
    setp.hi.u32 %p3, %r3, 32;
    @%p3 mad.lo.u32 %r13, %r7, %r3, %r7;
    cvt.s64.s32 %rd7, %r3;
    sub.u32 %r7, %r13, 64;
    cvt.u32.u64 %r4, %rd7;
    max.u64 %rd13, %rd7, %rd7;
    cvt.u64.u32 %rd15, %r4;
    mad.lo.u32 %r27, %r4, %r4, %r4;
    sub.u32 %r6, %r3, 4;
    shr.u64 %rd7, %rd7, 30;
    shl.b32 %r11, %r4, 31;
    mul.lo.s32 %r24, %r4, %r13;
    shr.s32 %r7, %r13, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
