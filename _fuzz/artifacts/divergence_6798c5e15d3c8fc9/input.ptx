.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p4, %r3, 4;
    @%p4 selp.b32 %r18, %r3, %r3, %p4;
    setp.ge.s32 %p1, %r3, %r3;
    setp.ge.s32 %p3, %r3, %r3;
    @%p3 mul.lo.s32 %r6, %r18, %r18;
    setp.ge.s32 %p1, %r3, %r3;
    @%p1 selp.b32 %r4, %r3, %r18, %p4;
    add.s32 %r27, %r4, %r3;
    selp.b32 %r9, %r18, %r4, %p3;
    add.s32 %r21, %r18, 65535;
    shr.u32 %r11, %r3, 4;
    cvt.u64.u32 %rd7, %r4;
    add.s32 %r12, %r11, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
