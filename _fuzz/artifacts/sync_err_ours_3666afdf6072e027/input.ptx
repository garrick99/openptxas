.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r25, %r3, %r3;
    shl.b32 %r15, %r25, 3;
    shr.s32 %r19, %r15, 3;
    shl.b32 %r4, %r3, 4;
    cvt.u64.u32 %rd11, %r25;
    min.s64 %rd15, %rd11, %rd11;
    max.s64 %rd7, %rd15, %rd15;
    shl.b32 %r27, %r3, 7;
    shr.u32 %r15, %r4, 31;
    cvt.u32.u64 %r26, %rd15;
    cvt.u32.u64 %r17, %rd11;
    sub.u32 %r8, %r17, %r19;
    cvt.u32.u64 %r27, %rd11;
    sub.u32 %r11, %r4, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
