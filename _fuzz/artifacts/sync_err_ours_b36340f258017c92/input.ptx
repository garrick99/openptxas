.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r26, %r3, 7;
    cvt.s64.s32 %rd12, %r3;
    max.s32 %r11, %r26, 256;
    min.u32 %r26, %r3, 255;
    add.s64 %rd12, %rd12, %rd12;
    cvt.u32.u64 %r19, %rd12;
    add.u32 %r4, %r19, 7;
    min.s32 %r6, %r11, 8;
    min.u32 %r21, %r19, 1;
    shr.s32 %r20, %r19, 0;
    add.s32 %r8, %r4, 2147483648;
    shr.u32 %r16, %r8, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
