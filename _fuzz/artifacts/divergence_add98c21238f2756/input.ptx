.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r17, %r3, 63;
    setp.gt.s32 %p1, %r17, %r3;
    setp.lt.s32 %p1, %r3, 0;
    @%p1 sub.u32 %r24, %r17, 65536;
    or.b32 %r11, %r24, 15;
    shl.b32 %r5, %r24, 7;
    add.u32 %r17, %r24, 32;
    max.s32 %r25, %r11, %r17;
    mul.wide.s32 %rd15, %r24, %r5;
    shr.u32 %r25, %r5, 31;
    selp.b32 %r5, %r17, %r3, %p1;
    max.s32 %r4, %r25, 31;
    mul.wide.s32 %rd6, %r24, %r4;
    shr.u32 %r8, %r4, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
