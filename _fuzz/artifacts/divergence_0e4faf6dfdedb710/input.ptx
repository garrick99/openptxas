.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r24, %r3, 5;
    sub.s32 %r9, %r3, 5;
    cvt.u64.u32 %rd10, %r9;
    shr.s32 %r27, %r3, 4;
    shr.s32 %r25, %r3, 15;
    cvt.u64.u32 %rd5, %r27;
    sub.s64 %rd13, %rd5, %rd5;
    setp.ge.s32 %p2, %r25, 3;
    @%p2 add.s32 %r16, %r9, 8;
    and.b32 %r11, %r16, %r9;
    mad.lo.u32 %r15, %r3, %r27, %r16;
    sub.u32 %r4, %r16, %r25;
    cvt.s32.s64 %r26, %rd13;
    xor.b32 %r11, %r11, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
