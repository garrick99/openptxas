.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    mad.lo.s32 %r13, %r3, %r3, %r3;
    xor.b32 %r6, %r3, 255;
    cvt.s32.s64 %r23, %rd10;
    setp.gt.s32 %p4, %r23, %r23;
    @%p4 shr.u64 %rd11, %rd10, 0;
    sub.u64 %rd15, %rd10, %rd11;
    mul.lo.s32 %r15, %r6, %r13;
    selp.b32 %r14, %r3, %r13, %p4;
    mul.wide.u32 %rd14, %r23, %r23;
    shl.b64 %rd14, %rd15, 31;
    add.u32 %r23, %r14, %r13;
    setp.le.u32 %p3, %r15, 2;
    @%p3 sub.u32 %r10, %r14, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
