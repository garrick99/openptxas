    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r17, %r3, %r3;
    mul.lo.s32 %r13, %r17, 3;
    min.s32 %r13, %r3, %r13;
    mul.wide.s32 %rd15, %r13, %r17;
    mul.lo.u32 %r25, %r13, 65536;
    and.b32 %r11, %r17, %r17;
    shr.s32 %r5, %r11, 30;
    min.s32 %r6, %r3, %r25;
    xor.b32 %r19, %r5, %r6;
    mad.lo.u32 %r26, %r5, %r13, %r3;
    max.u32 %r19, %r19, %r19;
    shr.u64 %rd6, %rd15, 47;
