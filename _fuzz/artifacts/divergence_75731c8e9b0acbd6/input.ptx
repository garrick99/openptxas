.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r7, %r3, 64;
    min.s32 %r27, %r3, %r3;
    max.s32 %r17, %r27, 7;
    or.b32 %r5, %r27, 31;
    setp.gt.s32 %p1, %r7, 32;
    and.b32 %r23, %r7, 65535;
    cvt.s64.s32 %rd8, %r3;
    cvt.s64.s32 %rd5, %r7;
    add.s32 %r13, %r7, %r5;
    min.s32 %r19, %r17, %r27;
    setp.eq.u32 %p2, %r19, %r23;
    @%p2 mul.lo.s32 %r14, %r3, 1;
    cvt.s64.s32 %rd7, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
