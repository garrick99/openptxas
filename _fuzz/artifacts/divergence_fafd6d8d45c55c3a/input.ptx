.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r5, %r3, %r3;
    cvt.u64.u32 %rd13, %r5;
    setp.ge.s32 %p3, %r3, 3;
    mad.lo.u32 %r27, %r5, %r3, %r5;
    max.s32 %r27, %r27, 256;
    and.b32 %r9, %r27, 2147483648;
    shr.u32 %r9, %r3, 2;
    max.s32 %r10, %r3, %r9;
    shr.u64 %rd8, %rd13, 15;
    min.u32 %r7, %r10, 15;
    selp.b32 %r5, %r5, %r7, %p3;
    max.u32 %r12, %r3, %r10;
    setp.lo.u32 %p1, %r9, %r10;
    @!%p1 cvt.s32.s64 %r16, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
