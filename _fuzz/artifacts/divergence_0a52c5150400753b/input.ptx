.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p1, %r3, 256;
    @!%p1 shr.s32 %r11, %r3, 2;
    mad.lo.u32 %r24, %r3, %r11, %r11;
    xor.b32 %r12, %r24, %r11;
    sub.u32 %r20, %r11, 64;
    max.u32 %r22, %r3, %r24;
    selp.b32 %r5, %r20, %r22, %p1;
    mad.lo.s32 %r13, %r22, %r5, %r20;
    add.s32 %r15, %r22, 15;
    shr.u32 %r12, %r12, 3;
    shr.u32 %r12, %r12, 7;
    mul.lo.s32 %r20, %r11, %r11;
    cvt.u64.u32 %rd15, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
