.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r16, %r3, 31;
    min.u32 %r9, %r16, %r3;
    add.s32 %r6, %r9, 5;
    shr.u32 %r13, %r16, 7;
    max.u32 %r18, %r16, %r3;
    setp.lt.u32 %p4, %r13, 3;
    @!%p4 xor.b32 %r20, %r13, %r13;
    mul.wide.s32 %rd15, %r3, %r3;
    max.u64 %rd5, %rd15, %rd15;
    max.s32 %r23, %r18, %r9;
    add.u32 %r5, %r16, %r18;
    or.b32 %r26, %r18, %r20;
    mul.wide.u32 %rd6, %r18, %r23;
    or.b32 %r6, %r6, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
