    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r12, %r3, 15;
    cvt.s64.s32 %rd9, %r12;
    and.b32 %r7, %r3, 2147483647;
