.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r7, %r3, %r3;
    mad.lo.u32 %r23, %r7, %r7, %r3;
    setp.ne.s32 %p2, %r7, 256;
    @!%p2 xor.b32 %r9, %r23, 256;
    cvt.s64.s32 %rd14, %r9;
    cvt.u64.u32 %rd15, %r9;
    mad.lo.u32 %r21, %r9, %r7, %r23;
    mad.lo.u32 %r27, %r9, %r9, %r21;
    mul.wide.u32 %rd15, %r7, %r27;
    and.b32 %r18, %r7, 255;
    shl.b64 %rd11, %rd15, 7;
    sub.s32 %r8, %r27, 4;
    selp.b32 %r20, %r3, %r23, %p2;
    cvt.s64.s32 %rd11, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
