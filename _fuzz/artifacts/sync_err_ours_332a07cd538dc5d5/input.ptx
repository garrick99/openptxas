.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r24, %r3, 65536;
    cvt.s64.s32 %rd8, %r24;
    shr.s32 %r22, %r24, 30;
    shl.b32 %r17, %r3, 7;
    shr.u64 %rd14, %rd8, 0;
    setp.ge.s32 %p4, %r3, %r22;
    setp.ne.u32 %p2, %r22, 256;
    @%p2 shr.s64 %rd8, %rd14, 62;
    mad.lo.s32 %r16, %r17, %r17, %r3;
    shr.u64 %rd14, %rd8, 4;
    mul.wide.u32 %rd5, %r3, %r17;
    mul.lo.s32 %r15, %r3, 0;
    mad.lo.u32 %r16, %r16, %r24, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
