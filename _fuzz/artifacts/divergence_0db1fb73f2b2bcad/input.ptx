.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    setp.hi.u32 %p4, %r3, 64;
    @!%p4 mul.lo.s32 %r22, %r3, 2147483648;
    setp.ge.u32 %p4, %r3, 65535;
    @%p4 mul.lo.s32 %r22, %r22, %r3;
    shr.s32 %r8, %r22, 2;
    sub.u32 %r16, %r8, %r3;
    mad.lo.s32 %r13, %r16, %r16, %r8;
    mul.wide.s32 %rd13, %r13, %r13;
    cvt.s32.s64 %r24, %rd11;
    sub.u32 %r12, %r8, 63;
    mul.lo.s32 %r27, %r24, %r24;
    mul.lo.u64 %rd10, %rd11, %rd11;
    xor.b32 %r12, %r16, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
