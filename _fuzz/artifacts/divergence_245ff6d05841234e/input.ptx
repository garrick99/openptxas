.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r21, %r3, %r3, %r3;
    cvt.s64.s32 %rd7, %r21;
    mad.lo.s32 %r14, %r21, %r3, %r3;
    sub.s64 %rd12, %rd7, %rd7;
    min.s32 %r18, %r21, %r3;
    shr.s64 %rd9, %rd7, 16;
    max.u32 %r5, %r21, 255;
    xor.b32 %r7, %r3, %r14;
    mul.wide.u32 %rd11, %r14, %r21;
    max.s64 %rd13, %rd9, %rd9;
    add.s64 %rd9, %rd11, %rd7;
    or.b32 %r7, %r7, %r5;
    and.b32 %r5, %r21, 256;
    min.u32 %r7, %r7, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
