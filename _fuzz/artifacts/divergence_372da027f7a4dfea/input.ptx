    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r19, %r3, 2147483648;
    or.b32 %r11, %r3, 4294967295;
    add.s32 %r21, %r19, %r19;
    cvt.u64.u32 %rd5, %r19;
    shr.u32 %r22, %r11, 30;
    add.u32 %r27, %r19, %r19;
    add.s32 %r10, %r22, %r27;
    add.u32 %r7, %r3, 8;
    mad.lo.u32 %r9, %r19, %r10, %r11;
    cvt.s32.s64 %r11, %rd5;
    shr.u32 %r24, %r21, 0;
    mul.lo.u32 %r6, %r22, 31;
    mad.lo.u32 %r19, %r7, %r21, %r19;
