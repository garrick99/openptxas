.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r14, %r3, 4294967295;
    max.s32 %r11, %r14, 4;
    mul.lo.s32 %r12, %r3, %r14;
    shr.s32 %r8, %r3, 3;
    mad.lo.s32 %r21, %r8, %r11, %r8;
    shr.s32 %r11, %r14, 1;
    shr.s32 %r16, %r11, 2;
    max.s32 %r8, %r11, %r21;
    shr.u32 %r19, %r11, 3;
    cvt.u64.u32 %rd11, %r3;
    add.s32 %r11, %r16, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
