.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    xor.b32 %r27, %r3, %r3;
    setp.hi.u32 %p1, %r3, 2147483647;
    shr.u32 %r14, %r3, 3;
    max.s64 %rd11, %rd10, %rd10;
    cvt.u32.u64 %r19, %rd11;
    min.u64 %rd12, %rd11, %rd11;
    mul.lo.u32 %r10, %r14, %r14;
    min.s32 %r11, %r10, 4294967295;
    mad.lo.u32 %r7, %r11, %r11, %r3;
    setp.hi.u32 %p1, %r19, %r7;
    setp.ge.u32 %p4, %r7, 7;
    @%p4 cvt.u64.u32 %rd9, %r3;
    mul.wide.u32 %rd5, %r14, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
