.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r8, %r3, 65536;
    min.u32 %r4, %r3, %r8;
    shr.u32 %r27, %r3, 7;
    or.b32 %r23, %r8, %r8;
    sub.u32 %r20, %r23, %r27;
    setp.gt.u32 %p2, %r20, %r20;
    @%p2 sub.u32 %r26, %r8, %r3;
    mul.wide.u32 %rd12, %r27, %r27;
    xor.b32 %r17, %r27, %r20;
    setp.le.u32 %p3, %r3, %r26;
    @%p3 shr.s32 %r17, %r4, 0;
    setp.lt.u32 %p3, %r23, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
