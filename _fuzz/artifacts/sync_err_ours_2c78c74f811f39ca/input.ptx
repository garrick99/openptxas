.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r5, %r3, 3;
    mad.lo.s32 %r17, %r5, %r3, %r3;
    sub.s32 %r17, %r17, %r17;
    add.u32 %r21, %r5, %r3;
    mad.lo.u32 %r7, %r3, %r17, %r3;
    mul.wide.u32 %rd14, %r17, %r21;
    and.b32 %r23, %r5, %r17;
    add.s32 %r11, %r21, %r7;
    mul.lo.u32 %r5, %r17, 4294967295;
    shl.b32 %r6, %r3, 1;
    mul.wide.u32 %rd7, %r11, %r23;
    add.u32 %r14, %r21, %r21;
    shr.u32 %r23, %r3, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
