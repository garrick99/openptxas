.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r6, %r3, 30;
    mul.wide.u32 %rd13, %r3, %r3;
    xor.b32 %r25, %r3, %r6;
    shr.u32 %r26, %r3, 3;
    cvt.u64.u32 %rd11, %r26;
    setp.eq.s32 %p3, %r26, %r25;
    @%p3 sub.u32 %r20, %r6, %r6;
    mul.lo.s32 %r16, %r6, 256;
    setp.gt.s32 %p1, %r6, 2147483647;
    @%p1 mul.wide.u32 %rd12, %r25, %r25;
    and.b32 %r10, %r16, %r3;
    shr.s64 %rd12, %rd11, 31;
    max.u32 %r15, %r20, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
