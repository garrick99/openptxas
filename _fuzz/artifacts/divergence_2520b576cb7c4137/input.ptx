.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    add.u32 %r11, %r3, 15;
    add.u32 %r5, %r11, %r11;
    add.s64 %rd7, %rd11, %rd11;
    add.u32 %r9, %r11, 32;
    shl.b64 %rd14, %rd11, 63;
    mul.wide.s32 %rd14, %r5, %r5;
    and.b32 %r16, %r11, %r3;
    sub.u32 %r18, %r11, 64;
    xor.b32 %r26, %r3, %r16;
    mul.wide.s32 %rd11, %r9, %r9;
    mad.lo.s32 %r23, %r3, %r16, %r18;
    or.b32 %r6, %r16, 65536;
    mad.lo.u32 %r20, %r23, %r5, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
