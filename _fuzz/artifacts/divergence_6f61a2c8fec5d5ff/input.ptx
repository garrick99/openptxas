.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r7, %r3, %r3;
    mul.wide.u32 %rd5, %r3, %r7;
    shl.b64 %rd14, %rd5, 15;
    add.u64 %rd13, %rd5, %rd14;
    mul.lo.u64 %rd15, %rd13, %rd13;
    shl.b32 %r20, %r3, 15;
    sub.s32 %r22, %r7, 65535;
    shl.b32 %r23, %r20, 1;
    min.u32 %r12, %r20, 2147483648;
    mad.lo.s32 %r5, %r20, %r23, %r12;
    shl.b32 %r17, %r23, 31;
    setp.lt.s32 %p3, %r3, %r23;
    mad.lo.u32 %r13, %r5, %r5, %r22;
    min.s32 %r22, %r12, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
