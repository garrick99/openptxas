.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r17, %r3, %r3;
    shr.u32 %r7, %r17, 31;
    mul.lo.u32 %r15, %r3, %r3;
    mul.lo.s32 %r10, %r17, 4294967295;
    mul.lo.s32 %r11, %r7, %r3;
    setp.ne.u32 %p1, %r10, 256;
    @%p1 cvt.s64.s32 %rd6, %r17;
    sub.s32 %r26, %r11, %r15;
    cvt.u32.u64 %r17, %rd6;
    setp.ls.u32 %p3, %r17, %r10;
    @%p3 cvt.s32.s64 %r24, %rd6;
    setp.lt.u32 %p1, %r24, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
