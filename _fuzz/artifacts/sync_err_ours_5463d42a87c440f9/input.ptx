.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r22, %r3, 4;
    cvt.u64.u32 %rd9, %r3;
    sub.u64 %rd7, %rd9, %rd9;
    min.u64 %rd12, %rd9, %rd7;
    setp.ge.u32 %p3, %r3, 65535;
    @%p3 sub.s32 %r16, %r3, %r22;
    mul.lo.u64 %rd11, %rd12, %rd12;
    cvt.u32.u64 %r26, %rd12;
    sub.s32 %r8, %r26, %r22;
    shl.b32 %r5, %r3, 1;
    or.b64 %rd9, %rd9, %rd12;
    shr.s32 %r22, %r3, 30;
    sub.s32 %r10, %r5, %r22;
    mul.lo.u32 %r5, %r8, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
