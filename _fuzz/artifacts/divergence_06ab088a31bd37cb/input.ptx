.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r13, %r3, 1;
    min.s32 %r15, %r13, %r3;
    setp.lt.s32 %p3, %r15, 15;
    sub.s32 %r17, %r3, %r13;
    min.s32 %r11, %r3, 7;
    add.u32 %r7, %r15, 16;
    mad.lo.s32 %r17, %r15, %r3, %r15;
    mul.wide.s32 %rd15, %r3, %r15;
    cvt.s32.s64 %r21, %rd15;
    mul.lo.s32 %r14, %r7, %r7;
    max.s32 %r18, %r15, 64;
    mul.lo.s32 %r8, %r18, %r21;
    mul.wide.s32 %rd6, %r18, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
