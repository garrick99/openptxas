.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r24, %r3, %r3;
    setp.ge.s32 %p1, %r24, %r3;
    @!%p1 min.s32 %r25, %r3, 5;
    cvt.u64.u32 %rd15, %r24;
    max.u32 %r5, %r24, %r25;
    max.s32 %r25, %r5, %r24;
    cvt.s32.s64 %r19, %rd15;
    cvt.u32.u64 %r20, %rd15;
    mul.wide.s32 %rd11, %r5, %r5;
    mad.lo.u32 %r25, %r3, %r3, %r5;
    max.s32 %r18, %r19, %r3;
    shl.b32 %r21, %r24, 30;
    max.u64 %rd5, %rd15, %rd11;
    max.u32 %r18, %r21, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
