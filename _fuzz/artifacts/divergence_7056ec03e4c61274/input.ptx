.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r23, %r3, %r3;
    mad.lo.u32 %r15, %r3, %r23, %r3;
    max.s32 %r14, %r15, 7;
    xor.b32 %r10, %r3, %r15;
    cvt.s64.s32 %rd14, %r3;
    cvt.u64.u32 %rd15, %r23;
    max.s32 %r21, %r3, 2;
    cvt.s32.s64 %r18, %rd15;
    and.b32 %r5, %r18, 63;
    max.u32 %r6, %r18, %r21;
    sub.s64 %rd6, %rd15, %rd14;
    mul.wide.u32 %rd11, %r3, %r5;
    setp.hs.u32 %p3, %r6, %r18;
    @!%p3 max.u32 %r7, %r23, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
