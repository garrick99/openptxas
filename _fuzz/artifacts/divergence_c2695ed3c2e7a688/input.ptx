.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r13, %r3, 4;
    or.b32 %r22, %r13, 15;
    sub.u32 %r4, %r13, %r13;
    cvt.u64.u32 %rd9, %r4;
    and.b32 %r12, %r22, %r13;
    cvt.u32.u64 %r22, %rd9;
    cvt.s32.s64 %r26, %rd9;
    shr.u64 %rd13, %rd9, 4;
    xor.b32 %r20, %r13, 15;
    shl.b64 %rd5, %rd9, 0;
    sub.u32 %r13, %r4, %r26;
    shr.s32 %r8, %r20, 31;
    setp.lt.u32 %p3, %r4, %r8;
    add.s64 %rd10, %rd9, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
