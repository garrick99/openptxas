.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r5, %r3, 0;
    cvt.u64.u32 %rd15, %r5;
    or.b32 %r24, %r5, %r3;
    add.u32 %r19, %r24, 5;
    or.b32 %r10, %r19, %r19;
    add.s32 %r21, %r24, %r10;
    or.b32 %r17, %r19, 32;
    mul.lo.u64 %rd9, %rd15, %rd15;
    shr.s64 %rd14, %rd15, 1;
    min.u32 %r5, %r17, %r19;
    cvt.s64.s32 %rd6, %r19;
    setp.eq.s32 %p1, %r5, 2147483648;
    @%p1 shl.b32 %r26, %r19, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
