.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r25, %r3, 15;
    setp.le.s32 %p1, %r25, 8;
    @%p1 cvt.u64.u32 %rd10, %r3;
    and.b32 %r9, %r25, 0;
    cvt.u64.u32 %rd9, %r3;
    setp.eq.u32 %p4, %r9, %r25;
    shr.u32 %r15, %r9, 1;
    mad.lo.u32 %r6, %r25, %r15, %r25;
    cvt.s32.s64 %r27, %rd9;
    setp.eq.u32 %p3, %r6, 31;
    cvt.s32.s64 %r4, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
