.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd14, %r3, %r3;
    cvt.u32.u64 %r10, %rd14;
    shl.b32 %r7, %r3, 0;
    mul.lo.s64 %rd9, %rd14, %rd14;
    setp.hs.u32 %p4, %r3, 8;
    @!%p4 or.b32 %r19, %r3, %r3;
    mad.lo.s32 %r4, %r10, %r19, %r3;
    xor.b32 %r17, %r7, %r4;
    max.s32 %r22, %r10, 15;
    selp.b32 %r19, %r22, %r22, %p4;
    selp.b32 %r9, %r17, %r22, %p4;
    max.u32 %r13, %r9, 65536;
    cvt.u32.u64 %r24, %rd9;
    mad.lo.u32 %r22, %r3, %r13, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
