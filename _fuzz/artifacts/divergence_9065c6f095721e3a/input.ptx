.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r11, %r3, %r3;
    cvt.u64.u32 %rd13, %r11;
    shr.s32 %r20, %r11, 31;
    max.u32 %r6, %r20, 5;
    setp.lt.s32 %p4, %r3, %r20;
    setp.lt.s32 %p2, %r20, 16;
    @!%p2 mul.lo.u32 %r6, %r11, %r11;
    setp.ge.s32 %p1, %r20, %r3;
    shr.u64 %rd9, %rd13, 33;
    min.s32 %r9, %r3, %r20;
    mul.lo.u32 %r20, %r11, 16;
    setp.eq.u32 %p2, %r20, %r11;
    @%p2 min.u32 %r15, %r20, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
