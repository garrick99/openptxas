.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p1, %r3, 0;
    sub.s32 %r15, %r3, 255;
    cvt.s64.s32 %rd9, %r3;
    add.u32 %r18, %r3, 2147483648;
    selp.b32 %r12, %r3, %r15, %p1;
    shr.u64 %rd10, %rd9, 63;
    and.b64 %rd15, %rd9, %rd9;
    sub.s32 %r12, %r3, %r12;
    cvt.u32.u64 %r5, %rd15;
    max.s32 %r21, %r15, %r3;
    add.s64 %rd8, %rd15, %rd15;
    mul.lo.s64 %rd8, %rd15, %rd15;
    setp.eq.u32 %p1, %r15, %r3;
    @%p1 mad.lo.s32 %r6, %r3, %r15, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
