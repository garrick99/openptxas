.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r25, %r3, 255;
    mul.lo.u32 %r13, %r3, 16;
    mul.wide.s32 %rd12, %r25, %r25;
    cvt.u32.u64 %r13, %rd12;
    setp.hs.u32 %p2, %r3, %r13;
    @%p2 add.s32 %r6, %r3, %r3;
    shr.u64 %rd6, %rd12, 62;
    xor.b32 %r27, %r3, %r3;
    setp.ne.s32 %p1, %r25, 1;
    @!%p1 shr.u32 %r20, %r27, 31;
    sub.u32 %r27, %r27, %r3;
    mad.lo.u32 %r11, %r3, %r6, %r25;
    min.u32 %r21, %r27, %r6;
    mul.lo.u64 %rd14, %rd12, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
