.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r7, %r3, %r3;
    mul.wide.s32 %rd14, %r7, %r7;
    mul.lo.s32 %r21, %r7, %r3;
    setp.ne.s32 %p4, %r7, %r21;
    @%p4 mul.wide.s32 %rd11, %r21, %r7;
    min.s32 %r10, %r21, 64;
    cvt.u32.u64 %r15, %rd11;
    setp.le.s32 %p1, %r7, 1;
    min.u32 %r12, %r21, %r7;
    min.u32 %r6, %r10, 256;
    add.s32 %r20, %r21, %r12;
    max.s32 %r22, %r15, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
