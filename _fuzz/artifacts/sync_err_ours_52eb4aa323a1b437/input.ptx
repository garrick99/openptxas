.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r26, %r3, %r3;
    or.b32 %r15, %r3, %r3;
    mad.lo.u32 %r13, %r15, %r15, %r3;
    min.u32 %r4, %r3, %r15;
    cvt.u64.u32 %rd9, %r13;
    mul.wide.s32 %rd9, %r3, %r26;
    shr.s64 %rd6, %rd9, 32;
    cvt.u32.u64 %r18, %rd9;
    mul.wide.u32 %rd13, %r4, %r26;
    xor.b32 %r14, %r18, 16;
    add.s32 %r7, %r26, %r13;
    shr.s32 %r21, %r4, 4;
    setp.le.u32 %p2, %r14, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
