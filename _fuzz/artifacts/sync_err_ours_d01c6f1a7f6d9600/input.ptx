.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r27, %r3, 4;
    cvt.s64.s32 %rd13, %r3;
    mad.lo.u32 %r5, %r3, %r27, %r3;
    min.s32 %r4, %r3, %r3;
    setp.eq.u32 %p4, %r5, 255;
    @!%p4 shr.s32 %r21, %r27, 31;
    mul.lo.s32 %r9, %r4, %r4;
    sub.s32 %r22, %r9, %r21;
    cvt.s64.s32 %rd7, %r22;
    mul.lo.s64 %rd12, %rd13, %rd7;
    mul.wide.u32 %rd12, %r5, %r4;
    add.u32 %r11, %r4, 31;
    setp.ne.u32 %p1, %r4, %r27;
    @!%p1 shr.u32 %r25, %r4, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
