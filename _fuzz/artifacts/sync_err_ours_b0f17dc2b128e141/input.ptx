.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    min.u32 %r6, %r3, 32;
    min.s64 %rd14, %rd6, %rd6;
    cvt.u64.u32 %rd15, %r6;
    setp.ge.s32 %p3, %r6, %r6;
    @%p3 mul.lo.u32 %r15, %r6, %r6;
    mad.lo.u32 %r13, %r6, %r6, %r15;
    xor.b64 %rd5, %rd15, %rd14;
    selp.b32 %r15, %r15, %r6, %p3;
    max.s32 %r15, %r3, %r13;
    shl.b32 %r26, %r6, 7;
    shl.b32 %r27, %r15, 7;
    or.b64 %rd13, %rd15, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
