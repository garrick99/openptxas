.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    mad.lo.s32 %r25, %r3, %r3, %r3;
    shl.b64 %rd7, %rd12, 15;
    shr.u32 %r25, %r3, 7;
    setp.le.s32 %p1, %r3, 4;
    @%p1 mad.lo.s32 %r14, %r25, %r3, %r25;
    selp.b32 %r21, %r25, %r25, %p1;
    cvt.s64.s32 %rd10, %r3;
    mul.lo.u32 %r4, %r14, %r25;
    shl.b64 %rd8, %rd7, 32;
    shr.s64 %rd6, %rd7, 31;
    mad.lo.s32 %r27, %r21, %r4, %r25;
    setp.hs.u32 %p1, %r3, 0;
    @%p1 min.s32 %r16, %r14, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
