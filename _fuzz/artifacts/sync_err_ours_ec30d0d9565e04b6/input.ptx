.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r19, %r3, 7;
    mul.lo.s32 %r21, %r19, %r19;
    sub.s32 %r19, %r19, 1;
    setp.lt.s32 %p4, %r3, %r21;
    @%p4 shr.s32 %r10, %r19, 4;
    add.u32 %r22, %r10, %r10;
    cvt.s64.s32 %rd10, %r19;
    sub.s32 %r11, %r21, %r19;
    cvt.s32.s64 %r8, %rd10;
    mul.wide.u32 %rd13, %r3, %r22;
    selp.b32 %r11, %r8, %r19, %p4;
    add.u32 %r16, %r19, %r21;
    and.b32 %r11, %r11, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
