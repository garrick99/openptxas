.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    mul.wide.s32 %rd15, %r3, %r3;
    min.u32 %r8, %r3, 0;
    shr.s64 %rd5, %rd8, 30;
    min.s32 %r25, %r8, %r3;
    setp.ls.u32 %p4, %r25, %r8;
    mad.lo.u32 %r19, %r25, %r25, %r8;
    mad.lo.s32 %r6, %r8, %r3, %r19;
    max.s64 %rd7, %rd8, %rd8;
    mad.lo.u32 %r14, %r19, %r6, %r8;
    max.s32 %r25, %r25, 65536;
    selp.b32 %r26, %r19, %r3, %p4;
    cvt.u64.u32 %rd11, %r25;
    sub.u32 %r11, %r14, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
