.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd6, %r3, %r3;
    shl.b32 %r27, %r3, 16;
    cvt.u32.u64 %r27, %rd6;
    mul.lo.s32 %r18, %r27, 5;
    setp.le.u32 %p4, %r3, %r27;
    selp.b32 %r14, %r3, %r27, %p4;
    shr.s32 %r27, %r14, 30;
    cvt.u32.u64 %r15, %rd6;
    and.b32 %r16, %r27, %r15;
    shl.b32 %r7, %r16, 31;
    mad.lo.u32 %r18, %r18, %r16, %r16;
    min.u32 %r12, %r15, 4;
    sub.s32 %r4, %r7, %r27;
    shr.u64 %rd15, %rd6, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
