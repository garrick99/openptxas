.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p4, %r3, 65536;
    cvt.u64.u32 %rd12, %r3;
    shl.b32 %r20, %r3, 31;
    and.b64 %rd15, %rd12, %rd12;
    sub.s32 %r25, %r3, 15;
    setp.gt.u32 %p2, %r3, 31;
    @%p2 shr.s32 %r11, %r3, 15;
    add.s64 %rd8, %rd15, %rd15;
    shr.s64 %rd8, %rd8, 30;
    mul.lo.s32 %r8, %r3, 65536;
    mul.lo.u32 %r9, %r11, 65535;
    min.u32 %r21, %r3, 0;
    min.u64 %rd13, %rd8, %rd12;
    sub.u32 %r13, %r9, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
