.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    min.s64 %rd8, %rd12, %rd12;
    shr.s64 %rd13, %rd8, 31;
    mul.wide.u32 %rd7, %r3, %r3;
    setp.le.u32 %p1, %r3, %r3;
    @%p1 and.b32 %r5, %r3, 64;
    xor.b32 %r4, %r5, 2;
    cvt.s64.s32 %rd14, %r3;
    sub.s64 %rd11, %rd8, %rd12;
    or.b32 %r22, %r4, %r5;
    mul.wide.s32 %rd8, %r3, %r4;
    mul.wide.u32 %rd8, %r4, %r4;
    shr.u32 %r9, %r4, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
