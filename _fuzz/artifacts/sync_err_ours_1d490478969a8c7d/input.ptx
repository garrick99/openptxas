.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    sub.u32 %r22, %r3, %r3;
    shr.s64 %rd13, %rd10, 63;
    min.s32 %r8, %r22, 256;
    sub.u32 %r18, %r22, %r8;
    max.u64 %rd10, %rd13, %rd13;
    shl.b32 %r20, %r3, 3;
    cvt.u32.u64 %r18, %rd10;
    cvt.u32.u64 %r9, %rd10;
    mad.lo.s32 %r13, %r9, %r18, %r3;
    max.s32 %r7, %r13, 5;
    cvt.u64.u32 %rd10, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
