.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p1, %r3, 16;
    @%p1 max.u32 %r16, %r3, 8;
    min.s32 %r10, %r3, %r3;
    and.b32 %r7, %r16, %r3;
    cvt.s64.s32 %rd15, %r7;
    cvt.s64.s32 %rd8, %r3;
    mul.lo.s32 %r13, %r16, %r7;
    shr.s64 %rd6, %rd8, 31;
    mul.lo.u32 %r15, %r13, %r3;
    add.u32 %r6, %r10, 31;
    cvt.u64.u32 %rd10, %r10;
    sub.s32 %r17, %r13, %r13;
    setp.ne.u32 %p4, %r3, 0;
    @%p4 add.s32 %r23, %r6, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
