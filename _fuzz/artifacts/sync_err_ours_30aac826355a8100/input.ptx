.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r6, %r3, 16;
    cvt.s64.s32 %rd7, %r3;
    shl.b64 %rd6, %rd7, 33;
    min.u64 %rd14, %rd6, %rd7;
    add.u32 %r9, %r3, 1;
    mad.lo.s32 %r14, %r6, %r9, %r3;
    min.s32 %r13, %r14, 16;
    cvt.s32.s64 %r21, %rd14;
    shr.u64 %rd15, %rd14, 62;
    cvt.u32.u64 %r26, %rd14;
    shr.u32 %r14, %r26, 31;
    mul.wide.s32 %rd7, %r13, %r21;
    max.u32 %r9, %r9, %r6;
    sub.u32 %r18, %r3, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
