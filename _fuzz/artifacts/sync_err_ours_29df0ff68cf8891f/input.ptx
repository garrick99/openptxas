.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r20, %r3, 16;
    sub.s32 %r27, %r3, 2;
    mul.lo.u32 %r26, %r27, %r3;
    cvt.u64.u32 %rd14, %r20;
    cvt.u32.u64 %r16, %rd14;
    shr.s32 %r4, %r3, 3;
    mul.lo.s32 %r15, %r4, 5;
    min.u32 %r5, %r3, %r26;
    sub.s64 %rd6, %rd14, %rd14;
    min.s64 %rd11, %rd14, %rd14;
    setp.le.s32 %p2, %r3, 4;
    @!%p2 mad.lo.u32 %r9, %r3, %r3, %r27;
    mul.wide.s32 %rd10, %r5, %r15;
    sub.s32 %r24, %r3, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
