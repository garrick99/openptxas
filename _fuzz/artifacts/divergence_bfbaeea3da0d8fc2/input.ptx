.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r18, %r3, 65535;
    setp.ge.s32 %p2, %r18, %r18;
    @%p2 mul.wide.s32 %rd10, %r18, %r3;
    shl.b32 %r6, %r3, 4;
    mul.wide.s32 %rd14, %r3, %r18;
    and.b32 %r20, %r6, 31;
    mad.lo.s32 %r12, %r18, %r6, %r18;
    mul.lo.s64 %rd8, %rd14, %rd14;
    shr.s64 %rd7, %rd10, 16;
    shr.u32 %r20, %r3, 7;
    cvt.u32.u64 %r27, %rd10;
    sub.s32 %r19, %r3, %r12;
    max.u32 %r5, %r12, 31;
    cvt.u64.u32 %rd7, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
