.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r13, %r3, 1;
    setp.lt.u32 %p4, %r3, %r13;
    @%p4 shr.s32 %r16, %r3, 31;
    mul.lo.s32 %r24, %r13, 1;
    min.s32 %r9, %r13, %r3;
    add.u32 %r11, %r13, %r3;
    shl.b32 %r7, %r13, 31;
    cvt.s64.s32 %rd7, %r13;
    cvt.s64.s32 %rd6, %r16;
    max.s64 %rd14, %rd6, %rd6;
    shr.u64 %rd8, %rd6, 15;
    cvt.s64.s32 %rd11, %r9;
    sub.u32 %r7, %r3, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
