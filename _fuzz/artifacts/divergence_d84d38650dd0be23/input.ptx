.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r27, %r3, %r3;
    cvt.u64.u32 %rd7, %r27;
    mul.lo.u32 %r18, %r3, %r3;
    mad.lo.u32 %r5, %r3, %r18, %r3;
    shr.u32 %r4, %r18, 30;
    max.u64 %rd7, %rd7, %rd7;
    mad.lo.u32 %r19, %r18, %r3, %r27;
    shr.s32 %r18, %r27, 3;
    setp.ge.u32 %p4, %r3, 32;
    @%p4 sub.s32 %r24, %r3, 7;
    shr.s64 %rd13, %rd7, 47;
    or.b64 %rd8, %rd13, %rd13;
    xor.b32 %r13, %r24, 8;
    shr.s64 %rd8, %rd7, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
