.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p4, %r3, 16;
    cvt.s64.s32 %rd11, %r3;
    mul.wide.u32 %rd6, %r3, %r3;
    cvt.s32.s64 %r22, %rd11;
    selp.b32 %r19, %r3, %r3, %p4;
    cvt.u32.u64 %r11, %rd6;
    sub.u32 %r4, %r19, %r3;
    shl.b32 %r7, %r11, 15;
    sub.u32 %r10, %r22, 32;
    shr.u64 %rd11, %rd6, 31;
    max.s64 %rd15, %rd6, %rd6;
    mad.lo.u32 %r14, %r19, %r10, %r11;
    selp.b32 %r24, %r10, %r4, %p4;
    and.b32 %r11, %r11, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
