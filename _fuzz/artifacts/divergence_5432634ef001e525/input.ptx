.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r11, %r3, %r3;
    sub.u32 %r24, %r11, 4294967295;
    mul.wide.s32 %rd10, %r11, %r11;
    cvt.s32.s64 %r8, %rd10;
    shl.b32 %r20, %r24, 30;
    mad.lo.s32 %r19, %r3, %r11, %r8;
    mul.lo.u32 %r25, %r24, %r8;
    mad.lo.s32 %r17, %r20, %r11, %r3;
    shr.u64 %rd6, %rd10, 63;
    cvt.u64.u32 %rd8, %r11;
    shr.u64 %rd10, %rd10, 16;
    mad.lo.u32 %r12, %r20, %r19, %r3;
    add.s32 %r7, %r25, 0;
    mul.lo.s32 %r16, %r25, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
