.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r10, %r3, %r3, %r3;
    cvt.s64.s32 %rd6, %r10;
    or.b32 %r4, %r10, %r3;
    shl.b64 %rd9, %rd6, 0;
    shr.s32 %r25, %r4, 16;
    mul.wide.u32 %rd7, %r10, %r25;
    cvt.u64.u32 %rd6, %r4;
    xor.b32 %r9, %r25, %r10;
    sub.u32 %r21, %r3, %r25;
    add.s32 %r16, %r10, %r25;
    setp.ge.s32 %p2, %r3, %r21;
    cvt.u64.u32 %rd10, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
