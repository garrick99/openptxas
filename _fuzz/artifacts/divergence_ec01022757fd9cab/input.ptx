.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    cvt.u32.u64 %r21, %rd8;
    shr.s64 %rd15, %rd8, 2;
    add.u64 %rd5, %rd8, %rd8;
    add.s32 %r13, %r3, 2147483647;
    shr.s64 %rd12, %rd5, 2;
    setp.ls.u32 %p3, %r21, %r13;
    @!%p3 sub.s32 %r6, %r13, 4294967295;
    max.s32 %r18, %r3, %r13;
    shr.s32 %r26, %r6, 15;
    mul.wide.u32 %rd7, %r3, %r26;
    selp.b32 %r23, %r21, %r6, %p3;
    xor.b32 %r4, %r26, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
