.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    setp.hi.u32 %p3, %r3, %r3;
    @!%p3 sub.u32 %r13, %r3, %r3;
    cvt.u32.u64 %r13, %rd15;
    shr.u32 %r5, %r3, 4;
    sub.s32 %r8, %r5, 65535;
    cvt.s64.s32 %rd9, %r8;
    cvt.s32.s64 %r24, %rd9;
    mul.lo.s32 %r10, %r8, 2;
    min.s32 %r23, %r5, %r10;
    shr.u64 %rd9, %rd9, 62;
    cvt.s32.s64 %r19, %rd9;
    mul.lo.s32 %r10, %r19, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
