.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd9, %r3, %r3;
    min.u32 %r12, %r3, %r3;
    xor.b32 %r19, %r3, 32;
    setp.gt.s32 %p2, %r19, %r3;
    @%p2 sub.s32 %r11, %r12, %r19;
    mul.lo.s32 %r18, %r3, %r19;
    and.b32 %r24, %r18, %r11;
    shr.s64 %rd15, %rd9, 1;
    mul.wide.u32 %rd7, %r18, %r18;
    mul.lo.u32 %r8, %r18, %r12;
    shr.u64 %rd13, %rd9, 47;
    mad.lo.s32 %r17, %r24, %r12, %r11;
    max.u32 %r13, %r11, %r17;
    cvt.s64.s32 %rd7, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
