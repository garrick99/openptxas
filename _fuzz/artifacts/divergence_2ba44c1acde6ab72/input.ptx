.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    shr.s32 %r25, %r3, 16;
    setp.ge.s32 %p1, %r3, 256;
    @%p1 cvt.u32.u64 %r19, %rd7;
    cvt.s32.s64 %r16, %rd7;
    and.b32 %r15, %r16, 2;
    mul.lo.u32 %r17, %r16, %r25;
    cvt.u64.u32 %rd13, %r16;
    add.s32 %r20, %r19, %r16;
    cvt.u32.u64 %r6, %rd13;
    max.u32 %r15, %r3, %r20;
    cvt.u64.u32 %rd8, %r20;
    mad.lo.s32 %r4, %r20, %r15, %r16;
    shl.b32 %r10, %r15, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
