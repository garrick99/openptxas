.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r17, %r3, %r3;
    mad.lo.s32 %r20, %r3, %r17, %r17;
    setp.ls.u32 %p2, %r3, %r20;
    @%p2 sub.s32 %r25, %r3, 4;
    cvt.s64.s32 %rd13, %r17;
    cvt.s32.s64 %r19, %rd13;
    mul.wide.u32 %rd13, %r25, %r19;
    or.b32 %r13, %r17, %r20;
    mad.lo.u32 %r15, %r17, %r19, %r17;
    shr.u64 %rd9, %rd13, 30;
    setp.eq.u32 %p3, %r19, 0;
    @!%p3 selp.b32 %r11, %r19, %r25, %p3;
    cvt.s64.s32 %rd6, %r17;
    cvt.s32.s64 %r6, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
