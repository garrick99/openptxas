.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    shr.s32 %r14, %r3, 1;
    mul.lo.s64 %rd8, %rd10, %rd10;
    add.u32 %r25, %r14, %r3;
    add.u32 %r23, %r3, %r25;
    mad.lo.u32 %r25, %r3, %r25, %r3;
    sub.u64 %rd6, %rd8, %rd10;
    cvt.s32.s64 %r4, %rd10;
    shr.s64 %rd9, %rd6, 7;
    xor.b32 %r26, %r23, 65535;
    and.b32 %r17, %r14, 4294967295;
    setp.ge.s32 %p2, %r25, %r14;
    @%p2 shl.b32 %r10, %r3, 30;
    cvt.u32.u64 %r24, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
