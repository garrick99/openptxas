.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    max.s32 %r8, %r3, %r3;
    sub.s32 %r13, %r8, 32;
    min.s32 %r11, %r13, %r13;
    shr.s64 %rd6, %rd14, 62;
    min.u32 %r9, %r11, %r11;
    sub.u32 %r11, %r3, 255;
    setp.le.s32 %p1, %r9, %r3;
    xor.b32 %r25, %r9, %r11;
    max.u32 %r7, %r13, %r13;
    selp.b32 %r17, %r7, %r13, %p1;
    shl.b64 %rd10, %rd6, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
