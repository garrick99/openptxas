.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    min.s32 %r4, %r3, 15;
    sub.s32 %r11, %r4, %r3;
    sub.s32 %r6, %r11, %r4;
    setp.le.u32 %p2, %r11, %r3;
    @%p2 sub.s64 %rd10, %rd11, %rd11;
    xor.b32 %r21, %r11, 7;
    min.s32 %r23, %r3, %r6;
    add.u32 %r15, %r3, %r4;
    and.b32 %r23, %r6, %r4;
    sub.u32 %r26, %r3, %r21;
    min.u64 %rd8, %rd11, %rd11;
    cvt.u64.u32 %rd13, %r4;
    shr.s64 %rd5, %rd10, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
