.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r24, %r3, 1;
    min.u32 %r13, %r24, %r3;
    mul.wide.s32 %rd5, %r13, %r3;
    shr.s32 %r17, %r3, 7;
    mul.lo.u64 %rd12, %rd5, %rd5;
    mul.wide.s32 %rd15, %r13, %r17;
    add.s32 %r22, %r17, 8;
    setp.gt.u32 %p1, %r22, %r3;
    max.u32 %r17, %r24, 4;
    shr.u32 %r25, %r17, 2;
    setp.ls.u32 %p1, %r25, 3;
    @%p1 selp.b32 %r9, %r22, %r25, %p1;
    mad.lo.u32 %r7, %r9, %r17, %r25;
    setp.ne.s32 %p1, %r9, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
