.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p4, %r3, 4;
    @%p4 cvt.s64.s32 %rd15, %r3;
    shr.s32 %r5, %r3, 1;
    cvt.s32.s64 %r16, %rd15;
    mul.wide.u32 %rd8, %r5, %r3;
    shl.b32 %r26, %r3, 1;
    max.u32 %r12, %r3, %r26;
    shr.u32 %r5, %r3, 4;
    max.s32 %r13, %r16, 2147483648;
    add.u32 %r20, %r26, %r12;
    xor.b32 %r11, %r3, 255;
    max.s32 %r15, %r16, 65535;
    mul.wide.s32 %rd13, %r5, %r5;
    min.s32 %r25, %r16, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
