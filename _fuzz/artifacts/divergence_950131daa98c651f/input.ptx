.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    shl.b64 %rd8, %rd5, 1;
    min.u32 %r27, %r3, 31;
    or.b32 %r8, %r27, %r27;
    mul.wide.u32 %rd13, %r27, %r3;
    xor.b32 %r10, %r3, %r8;
    shl.b32 %r12, %r8, 0;
    and.b32 %r9, %r12, 5;
    max.u64 %rd14, %rd13, %rd13;
    cvt.u32.u64 %r15, %rd5;
    cvt.s64.s32 %rd11, %r27;
    xor.b32 %r15, %r27, %r8;
    cvt.s64.s32 %rd7, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
