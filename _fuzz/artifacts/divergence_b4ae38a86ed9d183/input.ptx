.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p3, %r3, 0;
    @!%p3 cvt.u64.u32 %rd12, %r3;
    sub.s32 %r19, %r3, 64;
    shr.s32 %r8, %r19, 4;
    sub.s32 %r22, %r19, %r8;
    shl.b64 %rd7, %rd12, 31;
    sub.u32 %r9, %r19, %r3;
    mad.lo.s32 %r21, %r9, %r9, %r9;
    mul.wide.u32 %rd12, %r9, %r19;
    cvt.u32.u64 %r22, %rd7;
    shr.u32 %r19, %r21, 4;
    shr.u32 %r7, %r8, 2;
    shl.b32 %r7, %r8, 4;
    shr.s32 %r19, %r9, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
