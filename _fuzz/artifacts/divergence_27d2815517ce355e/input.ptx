.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r7, %r3, 4;
    mul.lo.s32 %r9, %r7, 31;
    min.u32 %r5, %r9, 31;
    sub.s32 %r20, %r3, %r7;
    cvt.u64.u32 %rd12, %r9;
    setp.le.s32 %p3, %r9, %r9;
    setp.hi.u32 %p4, %r3, 2147483648;
    @!%p4 shl.b32 %r7, %r3, 1;
    or.b32 %r23, %r3, %r9;
    max.s32 %r16, %r7, %r23;
    sub.s64 %rd6, %rd12, %rd12;
    setp.gt.s32 %p2, %r20, %r3;
    @%p2 or.b32 %r22, %r7, 32;
    shr.s32 %r4, %r16, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
