.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r22, %r3, 0;
    sub.s32 %r23, %r22, %r22;
    setp.ge.s32 %p3, %r3, 7;
    setp.gt.u32 %p4, %r23, 65536;
    @%p4 cvt.u64.u32 %rd10, %r22;
    add.u32 %r12, %r22, 32;
    or.b64 %rd13, %rd10, %rd10;
    max.u32 %r24, %r22, 63;
    mul.lo.u32 %r19, %r3, 5;
    sub.u32 %r21, %r12, %r22;
    or.b32 %r20, %r19, %r22;
    setp.gt.u32 %p3, %r19, %r12;
    max.s32 %r7, %r3, 0;
    cvt.u32.u64 %r5, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
