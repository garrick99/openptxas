    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r5, %r3, 7;
    cvt.u64.u32 %rd10, %r3;
    or.b32 %r16, %r5, 65535;
    add.s32 %r16, %r5, 65535;
    sub.u32 %r20, %r16, 3;
    shr.s64 %rd9, %rd10, 31;
    shr.u32 %r7, %r3, 1;
    xor.b32 %r9, %r7, 64;
    max.s32 %r6, %r3, 2147483648;
    setp.gt.u32 %p4, %r6, %r16;
    @!%p4 cvt.s64.s32 %rd11, %r6;
    mad.lo.s32 %r19, %r9, %r16, %r20;
