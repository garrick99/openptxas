.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    cvt.s32.s64 %r12, %rd13;
    sub.u64 %rd13, %rd13, %rd13;
    min.s32 %r19, %r12, %r3;
    min.s32 %r15, %r19, %r12;
    setp.eq.s32 %p2, %r19, 4294967295;
    shl.b32 %r23, %r3, 1;
    mul.wide.s32 %rd13, %r23, %r19;
    shr.s32 %r18, %r23, 1;
    selp.b32 %r22, %r18, %r12, %p2;
    mul.wide.s32 %rd15, %r15, %r18;
    or.b32 %r26, %r19, %r23;
    mul.lo.u32 %r5, %r19, %r23;
    shr.u64 %rd12, %rd15, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
