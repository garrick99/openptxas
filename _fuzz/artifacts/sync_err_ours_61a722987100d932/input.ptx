.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r15, %r3, 3;
    mul.wide.s32 %rd7, %r15, %r3;
    add.s32 %r9, %r3, %r15;
    setp.ge.u32 %p1, %r3, %r15;
    @%p1 shl.b32 %r17, %r9, 4;
    shl.b32 %r10, %r3, 30;
    mad.lo.s32 %r21, %r9, %r17, %r15;
    selp.b32 %r15, %r10, %r21, %p1;
    min.u64 %rd9, %rd7, %rd7;
    cvt.u64.u32 %rd9, %r17;
    sub.s32 %r20, %r17, 16;
    selp.b32 %r15, %r20, %r10, %p1;
    shr.s64 %rd12, %rd9, 33;
    cvt.s32.s64 %r17, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
