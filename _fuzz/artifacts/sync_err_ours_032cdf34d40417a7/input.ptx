.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r4, %r3, %r3, %r3;
    add.s32 %r13, %r3, 65536;
    cvt.u64.u32 %rd14, %r3;
    mad.lo.s32 %r4, %r13, %r13, %r4;
    max.u32 %r18, %r3, %r3;
    add.s32 %r18, %r4, 256;
    setp.lt.s32 %p3, %r13, 63;
    setp.le.s32 %p3, %r3, 1;
    @%p3 sub.s32 %r16, %r18, 2147483648;
    or.b32 %r20, %r4, 65535;
    add.u32 %r9, %r4, %r18;
    sub.u64 %rd9, %rd14, %rd14;
    mul.lo.s64 %rd10, %rd14, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
