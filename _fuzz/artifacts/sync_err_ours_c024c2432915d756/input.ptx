.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r7, %r3, 15;
    max.s32 %r7, %r7, 5;
    min.u32 %r14, %r7, 63;
    mul.lo.u32 %r15, %r3, %r7;
    shr.u32 %r5, %r14, 31;
    mul.wide.u32 %rd15, %r14, %r3;
    sub.s32 %r26, %r14, 2;
    shr.u32 %r17, %r3, 0;
    sub.u32 %r20, %r7, 65535;
    xor.b32 %r24, %r17, %r17;
    setp.ge.s32 %p1, %r14, %r20;
    @%p1 and.b32 %r4, %r24, 4294967295;
    add.s64 %rd8, %rd15, %rd15;
    min.s32 %r4, %r5, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
