.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd13, %r3, %r3;
    shl.b32 %r12, %r3, 7;
    sub.u32 %r26, %r12, 65536;
    sub.u32 %r27, %r12, 5;
    cvt.s32.s64 %r17, %rd13;
    add.s32 %r20, %r27, %r3;
    setp.eq.s32 %p3, %r27, %r26;
    max.s32 %r16, %r17, 0;
    cvt.u32.u64 %r10, %rd13;
    shr.s64 %rd10, %rd13, 4;
    sub.u64 %rd14, %rd13, %rd13;
    shr.u64 %rd14, %rd14, 0;
    or.b32 %r20, %r17, %r12;
    min.s32 %r5, %r16, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
