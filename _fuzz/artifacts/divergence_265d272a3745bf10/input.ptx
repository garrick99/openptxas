.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r25, %r3, %r3;
    or.b32 %r19, %r25, %r3;
    add.s32 %r18, %r19, 16;
    max.u32 %r16, %r19, %r19;
    min.s32 %r7, %r19, 2;
    min.s32 %r5, %r25, %r7;
    max.u32 %r8, %r5, 16;
    mad.lo.s32 %r4, %r16, %r19, %r8;
    shr.u32 %r17, %r5, 31;
    sub.u32 %r13, %r4, 255;
    cvt.u64.u32 %rd10, %r25;
    mul.wide.u32 %rd11, %r16, %r17;
    mul.wide.u32 %rd6, %r25, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
