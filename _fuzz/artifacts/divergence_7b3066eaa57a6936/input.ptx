.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd10, %r3, %r3;
    mul.wide.s32 %rd9, %r3, %r3;
    cvt.s64.s32 %rd12, %r3;
    sub.u32 %r11, %r3, %r3;
    mul.wide.u32 %rd14, %r11, %r3;
    shr.u32 %r19, %r3, 4;
    mul.wide.s32 %rd5, %r11, %r11;
    and.b32 %r10, %r3, %r19;
    min.u32 %r13, %r10, 255;
    and.b32 %r6, %r13, %r11;
    mul.wide.s32 %rd10, %r3, %r19;
    sub.s32 %r8, %r11, 2147483648;
    xor.b32 %r19, %r11, 256;
    min.s32 %r14, %r10, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
