.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r25, %r3, %r3;
    xor.b32 %r8, %r3, %r25;
    cvt.u64.u32 %rd7, %r3;
    setp.ge.s32 %p3, %r8, %r8;
    setp.ne.u32 %p3, %r3, %r8;
    @%p3 mul.lo.s64 %rd15, %rd7, %rd7;
    cvt.u32.u64 %r18, %rd15;
    mad.lo.u32 %r8, %r3, %r3, %r25;
    sub.s64 %rd12, %rd7, %rd7;
    max.u64 %rd10, %rd12, %rd15;
    max.s32 %r8, %r3, 8;
    setp.eq.s32 %p3, %r8, 7;
    @%p3 or.b32 %r25, %r3, %r3;
    selp.b32 %r25, %r18, %r18, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
