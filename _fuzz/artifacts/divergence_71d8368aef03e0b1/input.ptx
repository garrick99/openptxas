.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r7, %r3, 256;
    sub.s32 %r19, %r7, %r7;
    add.s32 %r12, %r7, %r3;
    cvt.u64.u32 %rd6, %r3;
    add.u64 %rd7, %rd6, %rd6;
    mad.lo.u32 %r7, %r3, %r12, %r12;
    and.b64 %rd13, %rd7, %rd7;
    sub.u32 %r24, %r7, %r12;
    mul.lo.u32 %r12, %r7, 63;
    and.b32 %r13, %r24, 4294967295;
    setp.gt.s32 %p3, %r19, %r24;
    @%p3 selp.b32 %r11, %r3, %r12, %p3;
    cvt.s64.s32 %rd6, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
