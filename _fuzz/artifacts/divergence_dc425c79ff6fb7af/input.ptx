.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    sub.s32 %r6, %r3, 1;
    min.s32 %r25, %r6, %r3;
    min.s32 %r22, %r6, %r3;
    cvt.u64.u32 %rd10, %r6;
    setp.gt.s32 %p1, %r25, %r3;
    setp.ge.u32 %p4, %r25, 32;
    @!%p4 shl.b32 %r21, %r6, 15;
    cvt.u64.u32 %rd10, %r3;
    xor.b32 %r7, %r3, %r6;
    shr.s32 %r17, %r6, 3;
    sub.u32 %r10, %r17, %r7;
    setp.hi.u32 %p4, %r10, 15;
    @%p4 xor.b32 %r11, %r21, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
