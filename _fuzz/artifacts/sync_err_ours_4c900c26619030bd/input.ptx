.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r15, %r3, 255;
    shl.b32 %r11, %r15, 4;
    max.u32 %r26, %r3, %r11;
    cvt.u64.u32 %rd6, %r15;
    and.b32 %r22, %r26, 256;
    or.b32 %r22, %r22, %r26;
    min.s32 %r23, %r22, %r22;
    max.s64 %rd6, %rd6, %rd6;
    xor.b32 %r22, %r26, 64;
    mad.lo.u32 %r8, %r22, %r22, %r26;
    and.b32 %r9, %r23, 4;
    shl.b32 %r7, %r23, 1;
    mul.lo.u32 %r25, %r22, 65536;
    min.u32 %r16, %r15, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
