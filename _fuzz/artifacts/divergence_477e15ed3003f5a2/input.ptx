.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r12, %r3, 4;
    cvt.u64.u32 %rd14, %r3;
    max.u32 %r7, %r3, 63;
    mul.lo.s32 %r19, %r12, %r12;
    mad.lo.u32 %r20, %r19, %r3, %r19;
    shr.u32 %r5, %r20, 0;
    mul.lo.s32 %r8, %r7, 65536;
    setp.eq.u32 %p2, %r19, %r20;
    cvt.u64.u32 %rd9, %r19;
    max.u32 %r4, %r5, %r5;
    setp.le.s32 %p2, %r7, 256;
    @%p2 mul.lo.u32 %r14, %r7, 3;
    min.s64 %rd11, %rd9, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
