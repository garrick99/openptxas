.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    min.u32 %r18, %r3, 4294967295;
    shr.u32 %r8, %r18, 16;
    cvt.s32.s64 %r23, %rd8;
    shr.u64 %rd14, %rd8, 32;
    shr.s64 %rd8, %rd8, 1;
    shr.s64 %rd14, %rd8, 32;
    or.b32 %r10, %r18, 256;
    mul.lo.u32 %r11, %r23, %r8;
    mad.lo.u32 %r6, %r23, %r8, %r23;
    min.u32 %r15, %r11, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
