.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd6, %r3, %r3;
    setp.ge.s32 %p4, %r3, 64;
    @%p4 add.s32 %r17, %r3, 0;
    max.s64 %rd6, %rd6, %rd6;
    mul.lo.s32 %r18, %r3, %r3;
    min.u32 %r10, %r3, %r17;
    shr.u32 %r13, %r10, 31;
    sub.u32 %r18, %r17, %r3;
    sub.u32 %r22, %r10, 65536;
    shr.u32 %r22, %r18, 4;
    shr.u64 %rd6, %rd6, 1;
    setp.hi.u32 %p3, %r18, %r3;
    @!%p3 sub.u32 %r26, %r13, 16;
    shr.s32 %r9, %r22, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
