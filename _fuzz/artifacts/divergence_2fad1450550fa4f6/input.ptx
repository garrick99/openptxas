.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r20, %r3, 7;
    shl.b32 %r20, %r3, 7;
    add.s32 %r15, %r20, %r3;
    sub.u32 %r22, %r15, 31;
    setp.lt.u32 %p3, %r20, 0;
    @!%p3 mul.wide.s32 %rd6, %r20, %r22;
    sub.s64 %rd14, %rd6, %rd6;
    mul.lo.u64 %rd13, %rd14, %rd14;
    mad.lo.s32 %r11, %r15, %r15, %r22;
    mad.lo.u32 %r23, %r22, %r22, %r20;
    min.u32 %r18, %r22, 1;
    setp.lt.s32 %p3, %r11, %r20;
    @%p3 shl.b32 %r7, %r20, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
