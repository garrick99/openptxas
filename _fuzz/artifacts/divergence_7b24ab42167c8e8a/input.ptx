.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd13, %r3, %r3;
    setp.ge.u32 %p1, %r3, %r3;
    setp.eq.s32 %p4, %r3, 0;
    @%p4 mad.lo.u32 %r5, %r3, %r3, %r3;
    max.u32 %r21, %r3, %r5;
    min.s32 %r13, %r21, %r5;
    mul.wide.u32 %rd11, %r5, %r21;
    mad.lo.u32 %r5, %r5, %r13, %r3;
    shr.u64 %rd11, %rd13, 15;
    mul.wide.s32 %rd7, %r13, %r21;
    min.s32 %r17, %r21, 2147483647;
    or.b32 %r22, %r3, 64;
    add.u32 %r8, %r3, 4294967295;
    max.u32 %r15, %r17, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
