.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p2, %r3, %r3;
    @%p2 or.b32 %r26, %r3, %r3;
    cvt.u64.u32 %rd6, %r3;
    xor.b32 %r17, %r26, 15;
    cvt.s64.s32 %rd8, %r3;
    shl.b32 %r25, %r17, 31;
    max.u64 %rd13, %rd6, %rd8;
    add.u32 %r4, %r25, %r26;
    mul.lo.s32 %r6, %r3, %r25;
    and.b32 %r7, %r17, %r6;
    mul.wide.s32 %rd15, %r7, %r26;
    mul.lo.s32 %r24, %r25, %r26;
    min.u64 %rd5, %rd15, %rd13;
    mul.wide.u32 %rd14, %r4, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
