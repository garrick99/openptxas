.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    mul.lo.s32 %r26, %r3, %r3;
    shl.b32 %r27, %r3, 2;
    shr.u32 %r6, %r27, 3;
    cvt.u32.u64 %r19, %rd14;
    mad.lo.s32 %r7, %r6, %r26, %r19;
    cvt.s32.s64 %r17, %rd14;
    and.b32 %r25, %r19, %r7;
    cvt.s32.s64 %r4, %rd14;
    mad.lo.u32 %r6, %r25, %r17, %r25;
    setp.eq.s32 %p1, %r7, %r19;
    @%p1 or.b64 %rd12, %rd14, %rd14;
    shr.s32 %r25, %r27, 30;
    mad.lo.u32 %r7, %r4, %r17, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
