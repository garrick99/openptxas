.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r11, %r3, 16;
    shr.s32 %r17, %r3, 30;
    setp.eq.u32 %p1, %r3, 63;
    @%p1 max.u32 %r7, %r11, %r11;
    setp.ne.u32 %p3, %r3, 3;
    @%p3 add.u32 %r5, %r7, 4;
    mul.lo.s32 %r13, %r17, 255;
    max.u32 %r22, %r3, %r13;
    sub.s32 %r6, %r7, 15;
    max.u32 %r11, %r7, 65536;
    max.u32 %r27, %r5, 3;
    add.u32 %r7, %r11, %r13;
    min.s32 %r10, %r7, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
