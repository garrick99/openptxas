.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r22, %r3, 0;
    mad.lo.s32 %r14, %r22, %r22, %r22;
    sub.u32 %r8, %r14, 4294967295;
    setp.hi.u32 %p4, %r22, 0;
    mul.lo.u32 %r26, %r3, 31;
    mul.wide.s32 %rd6, %r22, %r14;
    cvt.u64.u32 %rd12, %r14;
    add.u32 %r25, %r14, 5;
    mul.wide.s32 %rd15, %r22, %r26;
    cvt.s32.s64 %r22, %rd12;
    cvt.u64.u32 %rd15, %r26;
    mad.lo.s32 %r8, %r3, %r25, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
