.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r5, %r3, %r3;
    bfi.b32 %r22, %r3, %r5, 0, 32;
    bfi.b32 %r6, %r22, %r5, 15, 7;
    popc.b32 %r17, %r3;
    bfe.s32 %r18, %r22, 31, 31;
    bfi.b32 %r23, %r22, %r3, 16, 7;
    min.u32 %r20, %r22, %r17;
    bfi.b32 %r14, %r18, %r6, 8, 8;
    bfi.b32 %r5, %r23, %r17, 4, 24;
    clz.b32 %r19, %r17;
    bfi.b32 %r9, %r5, %r19, 0, 7;
    bfi.b32 %r14, %r5, %r22, 7, 24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
