.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r6, %r3, %r3;
    cvt.s64.s32 %rd13, %r3;
    shr.s32 %r13, %r6, 7;
    min.s32 %r14, %r3, 4;
    xor.b32 %r25, %r14, %r13;
    cvt.u64.u32 %rd14, %r25;
    min.u32 %r15, %r14, %r25;
    or.b32 %r5, %r3, %r15;
    mul.wide.u32 %rd15, %r6, %r13;
    max.s32 %r17, %r5, 16;
    add.u64 %rd14, %rd13, %rd14;
    min.s64 %rd14, %rd14, %rd15;
    max.s32 %r20, %r6, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
