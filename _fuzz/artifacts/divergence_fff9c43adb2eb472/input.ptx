.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r5, %r3, 1;
    min.u32 %r21, %r3, %r5;
    add.s32 %r26, %r21, %r21;
    setp.lo.u32 %p2, %r21, 8;
    @%p2 mul.lo.u32 %r19, %r21, %r3;
    min.u32 %r25, %r26, 65535;
    selp.b32 %r4, %r26, %r26, %p2;
    mul.wide.s32 %rd7, %r25, %r4;
    mul.wide.u32 %rd6, %r21, %r3;
    setp.gt.s32 %p2, %r19, 65535;
    @!%p2 mul.wide.s32 %rd10, %r19, %r5;
    sub.s32 %r7, %r19, 256;
    add.u32 %r7, %r21, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
