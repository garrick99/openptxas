.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r25, %r3, %r3;
    cvt.u64.u32 %rd12, %r25;
    min.u32 %r19, %r25, %r25;
    mad.lo.u32 %r24, %r25, %r25, %r25;
    mul.wide.s32 %rd8, %r19, %r25;
    xor.b32 %r6, %r3, 8;
    shr.s32 %r16, %r6, 2;
    setp.hs.u32 %p3, %r6, %r25;
    max.s32 %r11, %r6, %r19;
    or.b32 %r25, %r25, 0;
    cvt.u64.u32 %rd14, %r25;
    sub.s32 %r25, %r3, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
