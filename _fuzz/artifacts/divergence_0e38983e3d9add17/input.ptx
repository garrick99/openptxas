.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r21, %r3, %r3;
    cvt.s64.s32 %rd13, %r3;
    and.b32 %r11, %r3, 65535;
    mul.lo.u64 %rd11, %rd13, %rd13;
    shl.b32 %r11, %r11, 4;
    xor.b32 %r9, %r21, %r3;
    shl.b32 %r19, %r21, 15;
    setp.ls.u32 %p4, %r21, %r9;
    @!%p4 selp.b32 %r7, %r11, %r11, %p4;
    shr.u64 %rd6, %rd13, 16;
    shr.u64 %rd14, %rd13, 1;
    mul.lo.u32 %r22, %r9, 2147483647;
    sub.s32 %r5, %r19, %r7;
    mul.wide.u32 %rd7, %r7, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
