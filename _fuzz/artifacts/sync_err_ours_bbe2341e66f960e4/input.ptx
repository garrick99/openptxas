.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p4, %r3, 7;
    @!%p4 sub.u32 %r27, %r3, %r3;
    max.u32 %r4, %r27, 15;
    add.s32 %r16, %r27, %r4;
    cvt.u64.u32 %rd9, %r3;
    shr.s32 %r13, %r16, 1;
    min.u32 %r18, %r3, %r16;
    max.u32 %r13, %r16, %r27;
    max.u32 %r6, %r3, %r27;
    add.u32 %r22, %r6, %r27;
    add.s32 %r14, %r18, %r6;
    selp.b32 %r26, %r4, %r14, %p4;
    shr.u32 %r15, %r16, 2;
    min.u32 %r7, %r15, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
