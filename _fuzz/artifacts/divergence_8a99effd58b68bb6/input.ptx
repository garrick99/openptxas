.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r4, %r3, %r3;
    cvt.u64.u32 %rd5, %r3;
    shr.s64 %rd9, %rd5, 7;
    or.b32 %r21, %r3, %r3;
    min.s32 %r22, %r21, %r21;
    mad.lo.u32 %r18, %r22, %r3, %r4;
    xor.b32 %r12, %r3, %r4;
    max.s64 %rd12, %rd5, %rd9;
    sub.u32 %r13, %r22, %r18;
    mul.wide.u32 %rd9, %r12, %r3;
    sub.s32 %r12, %r21, 256;
    add.u32 %r27, %r22, %r18;
    cvt.u32.u64 %r26, %rd12;
    setp.eq.s32 %p1, %r27, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
