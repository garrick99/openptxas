.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p3, %r3, %r3;
    @%p3 cvt.s64.s32 %rd13, %r3;
    and.b32 %r27, %r3, %r3;
    xor.b32 %r7, %r3, %r3;
    cvt.u32.u64 %r19, %rd13;
    cvt.s32.s64 %r23, %rd13;
    shr.s64 %rd6, %rd13, 1;
    mul.lo.u32 %r22, %r23, %r27;
    mul.lo.u32 %r21, %r19, %r3;
    shl.b32 %r27, %r7, 4;
    max.u32 %r20, %r22, %r19;
    min.u32 %r4, %r19, %r20;
    sub.u32 %r15, %r3, 63;
    or.b32 %r22, %r3, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
