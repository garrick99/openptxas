.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r10, %r3, 2;
    mad.lo.s32 %r21, %r3, %r10, %r10;
    cvt.s64.s32 %rd15, %r10;
    max.s64 %rd10, %rd15, %rd15;
    setp.lo.u32 %p4, %r3, %r10;
    sub.u64 %rd5, %rd15, %rd10;
    shr.u64 %rd14, %rd15, 4;
    selp.b32 %r15, %r21, %r10, %p4;
    cvt.u64.u32 %rd7, %r15;
    mul.lo.u32 %r22, %r10, 0;
    add.u32 %r18, %r3, 31;
    mul.wide.u32 %rd11, %r18, %r10;
    mul.lo.u32 %r10, %r3, 255;
    mad.lo.s32 %r18, %r21, %r22, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
