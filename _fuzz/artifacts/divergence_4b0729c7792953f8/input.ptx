.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r9, %r3, %r3, %r3;
    mul.wide.s32 %rd9, %r3, %r9;
    add.u32 %r26, %r3, %r9;
    shr.s64 %rd15, %rd9, 30;
    max.u32 %r23, %r26, %r26;
    mad.lo.s32 %r8, %r26, %r23, %r3;
    max.s64 %rd12, %rd15, %rd15;
    mul.lo.u32 %r25, %r23, 0;
    add.s32 %r27, %r23, 1;
    mul.lo.u32 %r12, %r25, %r8;
    min.s32 %r26, %r23, %r12;
    add.s32 %r16, %r23, 8;
    max.s32 %r13, %r9, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
