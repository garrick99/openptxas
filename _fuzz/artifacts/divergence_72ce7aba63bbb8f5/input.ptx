.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd15, %r3, %r3;
    setp.ge.s32 %p2, %r3, %r3;
    add.s32 %r6, %r3, %r3;
    and.b32 %r5, %r6, %r3;
    selp.b32 %r13, %r6, %r3, %p2;
    cvt.s64.s32 %rd14, %r6;
    mul.wide.s32 %rd8, %r13, %r3;
    cvt.s64.s32 %rd7, %r3;
    min.u64 %rd14, %rd14, %rd15;
    shl.b32 %r8, %r6, 31;
    and.b64 %rd15, %rd14, %rd15;
    max.s32 %r18, %r8, %r5;
    max.u32 %r19, %r13, 63;
    mad.lo.u32 %r20, %r19, %r3, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
