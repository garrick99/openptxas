.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    cvt.u64.u32 %rd9, %r3;
    min.s32 %r20, %r3, 65536;
    mul.lo.u32 %r18, %r20, 1;
    mad.lo.u32 %r25, %r20, %r3, %r18;
    mad.lo.s32 %r9, %r18, %r18, %r18;
    setp.ne.s32 %p3, %r20, %r20;
    @%p3 sub.u32 %r8, %r9, %r3;
    shl.b32 %r5, %r20, 3;
    mul.lo.u64 %rd7, %rd7, %rd7;
    shr.s32 %r16, %r3, 3;
    min.s32 %r9, %r18, %r20;
    mad.lo.s32 %r6, %r5, %r20, %r8;
    mad.lo.s32 %r5, %r5, %r6, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
