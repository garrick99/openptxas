.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r16, %r3, 65535;
    setp.le.s32 %p4, %r16, %r3;
    @%p4 max.u32 %r13, %r3, %r3;
    and.b32 %r15, %r3, 7;
    cvt.u64.u32 %rd13, %r15;
    mad.lo.u32 %r23, %r13, %r3, %r15;
    max.u32 %r5, %r15, %r23;
    add.u32 %r4, %r3, 5;
    cvt.s64.s32 %rd13, %r16;
    max.s32 %r12, %r16, %r3;
    cvt.u32.u64 %r13, %rd13;
    min.s32 %r7, %r12, 255;
    cvt.s32.s64 %r25, %rd13;
    add.s32 %r27, %r5, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
