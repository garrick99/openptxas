.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r8, %r3, 15;
    shr.s32 %r19, %r8, 2;
    mad.lo.u32 %r6, %r3, %r3, %r3;
    shl.b32 %r5, %r19, 30;
    shr.u32 %r19, %r6, 2;
    mad.lo.u32 %r26, %r3, %r8, %r3;
    cvt.u64.u32 %rd9, %r8;
    and.b32 %r11, %r8, %r6;
    and.b32 %r27, %r5, %r6;
    setp.lt.s32 %p3, %r3, 16;
    @%p3 mul.lo.s64 %rd15, %rd9, %rd9;
    min.u32 %r22, %r8, %r19;
    and.b64 %rd7, %rd15, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
