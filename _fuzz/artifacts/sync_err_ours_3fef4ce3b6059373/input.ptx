.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r22, %r3, 255;
    add.u32 %r27, %r3, %r3;
    min.s32 %r10, %r27, 63;
    add.u32 %r15, %r22, 3;
    mad.lo.u32 %r9, %r27, %r15, %r10;
    min.u32 %r11, %r9, 64;
    or.b32 %r10, %r9, %r27;
    max.u32 %r21, %r9, %r27;
    sub.u32 %r27, %r3, %r10;
    mad.lo.s32 %r27, %r22, %r21, %r27;
    mad.lo.u32 %r16, %r21, %r22, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
