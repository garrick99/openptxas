.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfe.u32 %r7, %r3, 23, 2;
    bfi.b32 %r21, %r3, %r7, 7, 24;
    bfe.u32 %r6, %r7, 0, 1;
    bfe.s32 %r7, %r21, 0, 16;
    max.u32 %r5, %r3, 3;
    bfe.s32 %r5, %r3, 31, 2;
    bfe.s32 %r9, %r5, 31, 32;
    sub.u32 %r21, %r9, 255;
    bfe.s32 %r19, %r5, 24, 1;
    bfi.b32 %r16, %r9, %r5, 7, 4;
    bfe.u32 %r21, %r9, 1, 1;
    bfe.u32 %r22, %r5, 0, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
