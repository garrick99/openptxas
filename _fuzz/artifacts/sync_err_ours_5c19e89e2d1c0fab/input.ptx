.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r24, %r3, 30;
    min.s32 %r12, %r3, 2147483648;
    min.u32 %r17, %r3, %r3;
    cvt.u64.u32 %rd7, %r17;
    max.u32 %r14, %r17, 63;
    and.b32 %r9, %r3, %r14;
    shl.b64 %rd6, %rd7, 15;
    add.s32 %r26, %r24, %r17;
    shr.s64 %rd8, %rd6, 3;
    min.u32 %r8, %r12, %r9;
    and.b64 %rd10, %rd7, %rd7;
    sub.s32 %r25, %r12, %r17;
    xor.b32 %r8, %r14, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
