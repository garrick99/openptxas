.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r20, %r3, %r3;
    setp.gt.s32 %p3, %r3, %r3;
    mad.lo.u32 %r10, %r3, %r20, %r20;
    cvt.u64.u32 %rd8, %r3;
    mul.lo.u32 %r18, %r20, 2;
    shr.u64 %rd11, %rd8, 31;
    setp.ge.s32 %p2, %r3, 4294967295;
    max.s64 %rd13, %rd8, %rd11;
    sub.u32 %r6, %r3, %r10;
    shl.b32 %r7, %r20, 1;
    setp.ge.s32 %p2, %r6, 2;
    @!%p2 mul.lo.u32 %r11, %r6, 32;
    add.s32 %r23, %r3, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
