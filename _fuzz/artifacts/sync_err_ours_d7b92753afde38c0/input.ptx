.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    and.b32 %r24, %r3, %r3;
    add.s32 %r12, %r24, %r3;
    mul.lo.u32 %r27, %r24, 64;
    cvt.u64.u32 %rd8, %r27;
    shr.u32 %r23, %r24, 30;
    shr.s32 %r4, %r24, 0;
    min.s64 %rd8, %rd7, %rd8;
    and.b64 %rd7, %rd7, %rd8;
    setp.le.s32 %p2, %r27, %r3;
    max.s32 %r27, %r12, %r4;
    mul.lo.s32 %r18, %r23, %r24;
    shr.s32 %r5, %r24, 1;
    shr.s32 %r17, %r18, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
