.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    min.s32 %r21, %r3, 15;
    shr.u64 %rd6, %rd10, 31;
    add.s32 %r21, %r21, 5;
    setp.gt.u32 %p3, %r21, 16;
    sub.s32 %r20, %r21, 256;
    xor.b32 %r10, %r20, 1;
    setp.lt.u32 %p3, %r3, %r10;
    @%p3 max.u32 %r8, %r20, %r10;
    setp.lo.u32 %p1, %r20, 65536;
    setp.hi.u32 %p2, %r21, %r21;
    xor.b32 %r5, %r3, %r21;
    add.s32 %r22, %r3, %r3;
    cvt.s64.s32 %rd10, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
