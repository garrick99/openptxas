.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r17, %r3, %r3;
    sub.s32 %r12, %r17, 255;
    shl.b32 %r21, %r3, 4;
    mad.lo.s32 %r23, %r21, %r3, %r17;
    add.u32 %r23, %r3, %r12;
    add.u32 %r24, %r23, %r21;
    min.u32 %r8, %r24, %r23;
    shr.s32 %r8, %r24, 7;
    shr.s32 %r20, %r21, 30;
    shl.b32 %r23, %r20, 30;
    setp.hi.u32 %p1, %r20, 16;
    sub.s32 %r11, %r20, %r12;
    cvt.u64.u32 %rd6, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
