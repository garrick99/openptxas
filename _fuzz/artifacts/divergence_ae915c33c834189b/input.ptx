.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p3, %r3, %r3;
    @%p3 max.u32 %r19, %r3, 8;
    sub.s32 %r24, %r3, %r19;
    sub.u32 %r18, %r19, 63;
    add.s32 %r26, %r3, %r19;
    shr.u32 %r17, %r19, 0;
    shr.s32 %r20, %r19, 2;
    setp.gt.s32 %p1, %r3, 255;
    max.u32 %r8, %r3, %r17;
    setp.le.u32 %p1, %r3, 5;
    @!%p1 sub.s32 %r19, %r3, 2;
    add.s32 %r22, %r17, 31;
    max.s32 %r26, %r24, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
