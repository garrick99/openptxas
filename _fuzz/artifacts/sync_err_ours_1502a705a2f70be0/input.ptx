.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r23, %r3, %r3;
    cvt.u64.u32 %rd8, %r3;
    mul.lo.s32 %r17, %r23, %r3;
    mul.wide.u32 %rd7, %r3, %r3;
    mad.lo.s32 %r20, %r23, %r17, %r23;
    mad.lo.u32 %r4, %r23, %r20, %r17;
    max.s32 %r10, %r4, %r23;
    cvt.s64.s32 %rd15, %r17;
    cvt.s64.s32 %rd13, %r4;
    shr.u32 %r7, %r23, 1;
    mul.lo.u64 %rd12, %rd8, %rd13;
    shr.s32 %r19, %r7, 15;
    add.s64 %rd5, %rd12, %rd15;
    mul.lo.u64 %rd7, %rd15, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
