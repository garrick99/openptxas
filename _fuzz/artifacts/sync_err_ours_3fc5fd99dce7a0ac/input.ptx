.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r14, %r3, 63;
    sub.u32 %r9, %r3, 4294967295;
    sub.s32 %r16, %r3, 16;
    setp.le.s32 %p4, %r16, %r3;
    @%p4 or.b32 %r13, %r14, %r16;
    cvt.s64.s32 %rd15, %r13;
    mul.lo.s32 %r11, %r14, %r14;
    sub.u32 %r16, %r14, 1;
    max.s32 %r10, %r14, %r13;
    mul.wide.u32 %rd12, %r9, %r3;
    min.u32 %r21, %r11, %r13;
    xor.b32 %r17, %r14, %r9;
    shr.u32 %r22, %r9, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
