.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r18, %r3, 3;
    or.b32 %r9, %r18, 255;
    mul.lo.s32 %r17, %r18, 5;
    cvt.u64.u32 %rd12, %r17;
    add.s64 %rd9, %rd12, %rd12;
    add.u32 %r4, %r18, 256;
    setp.eq.s32 %p2, %r18, 7;
    @%p2 xor.b32 %r10, %r4, 65536;
    shr.u32 %r13, %r3, 1;
    cvt.u64.u32 %rd5, %r9;
    min.s64 %rd5, %rd9, %rd9;
    mul.lo.s64 %rd15, %rd12, %rd12;
    shr.u32 %r21, %r10, 31;
    add.u32 %r21, %r10, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
