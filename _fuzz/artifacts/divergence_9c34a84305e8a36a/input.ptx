.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r21, %r3, 15;
    add.u32 %r18, %r3, %r21;
    cvt.u64.u32 %rd6, %r18;
    min.s32 %r26, %r3, 255;
    xor.b32 %r24, %r18, 2;
    shr.s32 %r27, %r18, 15;
    min.s32 %r21, %r24, 1;
    mul.wide.u32 %rd9, %r24, %r26;
    cvt.s32.s64 %r22, %rd6;
    and.b64 %rd8, %rd6, %rd6;
    cvt.u64.u32 %rd9, %r27;
    setp.le.u32 %p3, %r22, 7;
    @%p3 min.u32 %r19, %r26, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
