.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r11, %r3, %r3;
    cvt.s64.s32 %rd14, %r3;
    min.u32 %r4, %r3, 7;
    max.u32 %r9, %r11, %r4;
    cvt.u64.u32 %rd12, %r9;
    mul.wide.s32 %rd6, %r11, %r9;
    shr.s32 %r4, %r4, 1;
    mad.lo.u32 %r4, %r11, %r9, %r3;
    cvt.s32.s64 %r27, %rd12;
    mad.lo.u32 %r12, %r9, %r4, %r3;
    add.s32 %r4, %r11, %r27;
    xor.b32 %r13, %r11, %r11;
    max.u32 %r21, %r4, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
