.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    or.b32 %r16, %r3, %r3;
    add.s32 %r10, %r16, %r3;
    max.s32 %r27, %r10, %r16;
    shl.b32 %r26, %r3, 15;
    min.u32 %r16, %r3, 7;
    xor.b32 %r14, %r10, %r16;
    cvt.u64.u32 %rd15, %r27;
    min.u64 %rd8, %rd15, %rd7;
    xor.b64 %rd11, %rd8, %rd7;
    shr.s64 %rd6, %rd15, 48;
    min.u32 %r16, %r26, 16;
    sub.u32 %r8, %r27, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
