.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r19, %r3, 255;
    setp.lo.u32 %p1, %r3, 2147483647;
    cvt.u64.u32 %rd9, %r3;
    setp.le.u32 %p1, %r3, %r19;
    @%p1 max.u32 %r13, %r19, %r3;
    setp.eq.s32 %p4, %r19, %r19;
    max.s64 %rd12, %rd9, %rd9;
    sub.u32 %r14, %r13, 8;
    or.b64 %rd13, %rd9, %rd12;
    setp.ne.s32 %p4, %r19, 65535;
    @%p4 mul.wide.u32 %rd14, %r3, %r19;
    setp.gt.u32 %p2, %r14, 8;
    @%p2 add.s32 %r13, %r13, 0;
    mul.wide.s32 %rd11, %r13, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
