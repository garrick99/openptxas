.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r26, %r3, %r3;
    cvt.u64.u32 %rd10, %r3;
    shl.b32 %r15, %r3, 3;
    cvt.s32.s64 %r22, %rd10;
    and.b32 %r4, %r3, %r26;
    shl.b32 %r14, %r15, 30;
    mul.lo.u64 %rd5, %rd10, %rd10;
    sub.s32 %r21, %r26, 63;
    mul.wide.s32 %rd12, %r3, %r22;
    shr.s64 %rd11, %rd12, 0;
    shl.b32 %r18, %r3, 2;
    mul.lo.s32 %r14, %r18, 255;
    mad.lo.u32 %r23, %r4, %r18, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
