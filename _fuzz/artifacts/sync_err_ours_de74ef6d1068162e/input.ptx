.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    sub.u32 %r24, %r3, 32;
    min.s32 %r12, %r3, %r3;
    sub.s32 %r17, %r3, %r24;
    sub.s64 %rd11, %rd15, %rd15;
    mul.wide.u32 %rd12, %r12, %r12;
    xor.b32 %r12, %r3, 7;
    shr.s32 %r10, %r12, 3;
    and.b32 %r7, %r24, %r3;
    max.s32 %r20, %r24, %r12;
    shr.u32 %r20, %r7, 30;
    shr.u32 %r12, %r20, 3;
    shr.u64 %rd14, %rd12, 31;
    min.u32 %r24, %r17, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
