.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r24, %r3, 4;
    add.s32 %r24, %r3, 256;
    max.u32 %r27, %r3, 2147483648;
    mul.wide.u32 %rd6, %r24, %r24;
    max.s64 %rd6, %rd6, %rd6;
    mad.lo.u32 %r26, %r24, %r27, %r24;
    setp.eq.s32 %p3, %r3, %r3;
    @!%p3 cvt.s32.s64 %r22, %rd6;
    selp.b32 %r22, %r24, %r26, %p3;
    shr.u32 %r27, %r3, 30;
    mul.wide.s32 %rd5, %r3, %r26;
    mul.wide.u32 %rd14, %r26, %r22;
    mad.lo.u32 %r13, %r22, %r24, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
