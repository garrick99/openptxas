.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r10, %r3, 8;
    cvt.u64.u32 %rd5, %r10;
    mul.wide.s32 %rd7, %r3, %r3;
    and.b64 %rd8, %rd7, %rd5;
    cvt.u32.u64 %r26, %rd5;
    shr.u64 %rd12, %rd5, 48;
    shl.b32 %r19, %r26, 3;
    max.s32 %r22, %r3, %r10;
    mad.lo.s32 %r8, %r26, %r22, %r22;
    shr.s64 %rd12, %rd8, 31;
    or.b32 %r18, %r19, %r8;
    shl.b64 %rd10, %rd5, 2;
    mad.lo.s32 %r11, %r8, %r26, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
