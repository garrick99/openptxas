.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r5, %r3, %r3;
    xor.b32 %r11, %r5, %r5;
    setp.ne.s32 %p1, %r3, %r3;
    @!%p1 min.s32 %r7, %r3, %r5;
    cvt.u64.u32 %rd12, %r7;
    mul.wide.s32 %rd6, %r5, %r3;
    setp.lt.s32 %p1, %r5, %r7;
    @!%p1 cvt.u32.u64 %r9, %rd12;
    mul.wide.u32 %rd8, %r11, %r3;
    sub.u32 %r13, %r9, %r7;
    and.b32 %r20, %r3, %r13;
    shr.s32 %r26, %r13, 15;
    sub.s64 %rd12, %rd8, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
