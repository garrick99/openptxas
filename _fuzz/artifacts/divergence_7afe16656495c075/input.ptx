.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r19, %r3, %r3;
    cvt.u64.u32 %rd8, %r19;
    mad.lo.u32 %r17, %r3, %r3, %r3;
    shr.s32 %r20, %r3, 2;
    max.s32 %r24, %r19, %r19;
    shr.u64 %rd10, %rd8, 7;
    max.s32 %r14, %r3, 256;
    setp.le.u32 %p1, %r17, %r19;
    @%p1 cvt.s64.s32 %rd9, %r3;
    and.b32 %r23, %r3, 7;
    shr.s64 %rd6, %rd10, 1;
    min.u32 %r17, %r20, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
