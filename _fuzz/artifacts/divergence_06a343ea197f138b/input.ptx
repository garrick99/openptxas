.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p1, %r3, 4;
    mad.lo.s32 %r8, %r3, %r3, %r3;
    setp.ge.s32 %p2, %r3, %r8;
    @%p2 cvt.u64.u32 %rd5, %r8;
    sub.u32 %r6, %r3, %r3;
    cvt.u32.u64 %r22, %rd5;
    sub.u32 %r15, %r22, 2147483647;
    and.b32 %r20, %r15, %r15;
    and.b32 %r25, %r15, 31;
    cvt.u32.u64 %r19, %rd5;
    shr.s64 %rd7, %rd5, 4;
    min.s32 %r16, %r20, %r19;
    cvt.u32.u64 %r9, %rd5;
    sub.s64 %rd7, %rd7, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
