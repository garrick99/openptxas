.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p1, %r0, 4294967295;
    vote.sync.ballot.b32 %r10, %p1, -1;
    setp.ne.u32 %p2, %r3, 7;
    vote.sync.ballot.b32 %r12, %p2, -1;
    shfl.sync.up.b32 %r10, %r12, 8, 0x1f, -1;
    setp.eq.u32 %p1, %r12, %r3;
    vote.sync.ballot.b32 %r4, %p1, -1;
    shfl.sync.up.b32 %r7, %r3, 8, 0x1f, -1;
    vote.sync.all.pred %p1, %p1, -1;
    shfl.sync.bfly.b32 %r16, %r7, 16, 0x1f, -1;
    and.b32 %r17, %r4, %r3;
    setp.ne.u32 %p2, %r16, 1;
    vote.sync.ballot.b32 %r12, %p2, -1;
    xor.b32 %r7, %r3, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
