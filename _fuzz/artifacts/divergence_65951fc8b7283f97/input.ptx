.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r26, %r3, %r3;
    sub.u32 %r26, %r26, %r3;
    setp.ge.s32 %p4, %r26, %r26;
    @%p4 selp.b32 %r19, %r26, %r3, %p4;
    min.s32 %r22, %r19, %r3;
    selp.b32 %r5, %r3, %r3, %p4;
    add.u32 %r11, %r26, %r26;
    min.s32 %r23, %r11, 64;
    mul.lo.s32 %r9, %r19, %r26;
    selp.b32 %r23, %r3, %r26, %p4;
    cvt.u64.u32 %rd13, %r9;
    min.s32 %r17, %r11, 32;
    selp.b32 %r27, %r9, %r26, %p4;
    shr.s64 %rd8, %rd13, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
