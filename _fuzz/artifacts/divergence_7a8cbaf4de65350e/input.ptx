.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    mul.lo.s32 %r20, %r3, %r3;
    mul.wide.s32 %rd13, %r20, %r20;
    shr.s32 %r24, %r20, 4;
    shr.u32 %r13, %r3, 7;
    setp.ge.s32 %p4, %r24, 65535;
    @%p4 cvt.s32.s64 %r12, %rd9;
    mad.lo.s32 %r6, %r12, %r12, %r20;
    shr.u32 %r24, %r24, 7;
    or.b32 %r14, %r13, %r3;
    max.u32 %r4, %r12, 64;
    or.b64 %rd5, %rd9, %rd9;
    and.b64 %rd14, %rd5, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
