    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r24, %r3, 16;
    cvt.s64.s32 %rd11, %r24;
    mad.lo.s32 %r26, %r3, %r3, %r24;
    setp.gt.s32 %p4, %r24, 65535;
    @%p4 mul.lo.s32 %r6, %r3, %r26;
    cvt.s32.s64 %r22, %rd11;
    max.u64 %rd15, %rd11, %rd11;
    shr.s32 %r25, %r3, 31;
    selp.b32 %r15, %r26, %r22, %p4;
    shl.b32 %r22, %r6, 3;
    add.s32 %r20, %r26, 2147483647;
    mul.lo.u64 %rd7, %rd11, %rd15;
    cvt.s64.s32 %rd7, %r26;
    mul.wide.s32 %rd11, %r6, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
