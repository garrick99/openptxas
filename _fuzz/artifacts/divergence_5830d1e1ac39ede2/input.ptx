.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r11, %r3, 1;
    sub.u32 %r17, %r11, %r3;
    cvt.u64.u32 %rd12, %r11;
    max.u32 %r26, %r3, %r11;
    add.s32 %r14, %r17, 0;
    setp.ne.s32 %p3, %r26, %r14;
    @!%p3 shr.u64 %rd14, %rd12, 4;
    mad.lo.u32 %r11, %r26, %r3, %r26;
    and.b32 %r8, %r3, 31;
    add.s32 %r22, %r14, %r14;
    setp.ls.u32 %p3, %r26, 65536;
    @%p3 shr.s64 %rd8, %rd12, 30;
    setp.le.s32 %p1, %r26, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
