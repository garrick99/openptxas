.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r4, %r3, %r3;
    mul.wide.u32 %rd15, %r3, %r3;
    shl.b64 %rd7, %rd15, 4;
    max.u64 %rd10, %rd15, %rd15;
    and.b32 %r9, %r3, %r4;
    shl.b32 %r14, %r4, 2;
    cvt.s64.s32 %rd7, %r3;
    max.u32 %r26, %r3, 7;
    shr.u64 %rd7, %rd7, 16;
    xor.b32 %r4, %r9, 8;
    sub.s64 %rd14, %rd10, %rd7;
    cvt.s64.s32 %rd11, %r4;
    shl.b32 %r14, %r26, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
