.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p2, %r3, 1;
    @!%p2 sub.s32 %r23, %r3, %r3;
    mul.lo.u32 %r10, %r3, %r23;
    and.b32 %r14, %r10, %r23;
    shr.s32 %r27, %r14, 3;
    shl.b32 %r19, %r23, 2;
    selp.b32 %r15, %r19, %r3, %p2;
    shl.b32 %r25, %r3, 31;
    selp.b32 %r22, %r23, %r15, %p2;
    mul.wide.u32 %rd10, %r19, %r22;
    sub.u32 %r7, %r23, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
