.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    mul.wide.s32 %rd5, %r3, %r3;
    mul.lo.s32 %r5, %r3, %r3;
    cvt.s32.s64 %r11, %rd7;
    cvt.s64.s32 %rd15, %r11;
    setp.ge.s32 %p2, %r11, 32;
    @%p2 shl.b64 %rd5, %rd15, 2;
    shr.s64 %rd7, %rd15, 30;
    cvt.s64.s32 %rd13, %r5;
    mul.wide.s32 %rd6, %r5, %r3;
    shr.s32 %r11, %r3, 16;
    mul.wide.u32 %rd9, %r5, %r3;
    max.s32 %r11, %r5, %r5;
    max.s32 %r26, %r11, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
