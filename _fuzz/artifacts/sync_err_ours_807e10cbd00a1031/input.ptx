.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    shr.s64 %rd13, %rd9, 2;
    setp.eq.s32 %p3, %r3, 16;
    @!%p3 shr.u32 %r8, %r3, 16;
    and.b32 %r5, %r8, %r8;
    shr.s32 %r7, %r8, 0;
    and.b32 %r10, %r8, %r8;
    mul.wide.s32 %rd12, %r8, %r10;
    xor.b32 %r5, %r8, %r8;
    shr.u32 %r13, %r8, 4;
    cvt.s64.s32 %rd13, %r8;
    add.s32 %r9, %r5, %r10;
    mul.lo.s32 %r15, %r3, 3;
    mul.lo.s64 %rd12, %rd9, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
