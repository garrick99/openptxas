.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd15, %r3, %r3;
    setp.gt.s32 %p3, %r3, 1;
    @%p3 shl.b32 %r17, %r3, 3;
    add.u64 %rd14, %rd15, %rd15;
    cvt.u64.u32 %rd14, %r3;
    shl.b32 %r26, %r17, 0;
    cvt.u64.u32 %rd15, %r17;
    mul.lo.u32 %r8, %r26, %r17;
    min.u32 %r10, %r8, %r3;
    add.s32 %r5, %r17, 4;
    and.b64 %rd7, %rd15, %rd14;
    mul.lo.u32 %r13, %r17, 255;
    sub.u32 %r4, %r10, %r17;
    cvt.s32.s64 %r25, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
