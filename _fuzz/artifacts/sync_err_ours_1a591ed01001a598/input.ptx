.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd9, %r3, %r3;
    mul.wide.u32 %rd7, %r3, %r3;
    max.s64 %rd14, %rd7, %rd7;
    mad.lo.s32 %r17, %r3, %r3, %r3;
    shl.b32 %r6, %r17, 30;
    xor.b32 %r25, %r3, %r17;
    xor.b32 %r25, %r6, %r25;
    sub.u64 %rd14, %rd7, %rd14;
    max.s32 %r10, %r17, %r25;
    min.s64 %rd7, %rd14, %rd14;
    shl.b32 %r10, %r17, 16;
    add.u64 %rd12, %rd9, %rd9;
    shr.u32 %r22, %r6, 0;
    shl.b32 %r15, %r10, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
