.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r7, %r3, 31;
    cvt.u64.u32 %rd8, %r3;
    setp.gt.s32 %p1, %r3, 65536;
    @%p1 shl.b32 %r20, %r3, 3;
    add.s32 %r16, %r7, 15;
    min.u32 %r4, %r16, 2147483648;
    max.u32 %r9, %r7, %r20;
    and.b32 %r9, %r20, 65535;
    add.s32 %r16, %r16, %r9;
    selp.b32 %r13, %r3, %r4, %p1;
    setp.eq.u32 %p3, %r7, 4294967295;
    min.u32 %r27, %r4, 2147483648;
    sub.s32 %r10, %r16, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
