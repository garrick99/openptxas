.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    sub.u64 %rd5, %rd5, %rd5;
    cvt.u64.u32 %rd15, %r3;
    cvt.s64.s32 %rd15, %r3;
    setp.le.u32 %p3, %r3, 7;
    @!%p3 mul.lo.s32 %r16, %r3, 3;
    shl.b64 %rd15, %rd5, 1;
    mul.wide.u32 %rd12, %r16, %r3;
    max.u32 %r11, %r3, 63;
    min.u32 %r16, %r3, %r11;
    and.b32 %r6, %r3, 65535;
    min.u64 %rd9, %rd12, %rd15;
    sub.u64 %rd13, %rd5, %rd12;
    shr.s32 %r20, %r6, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
