.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r16, %r3, 1;
    min.u32 %r9, %r3, 31;
    cvt.s64.s32 %rd7, %r16;
    mul.lo.u64 %rd10, %rd7, %rd7;
    mad.lo.s32 %r6, %r3, %r9, %r3;
    cvt.u32.u64 %r22, %rd10;
    shr.s32 %r18, %r3, 15;
    cvt.s64.s32 %rd10, %r18;
    max.s32 %r13, %r9, %r16;
    sub.s32 %r8, %r16, %r22;
    add.s32 %r4, %r18, %r6;
    mad.lo.u32 %r24, %r6, %r4, %r4;
    min.u64 %rd12, %rd10, %rd10;
    mul.lo.s64 %rd5, %rd10, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
