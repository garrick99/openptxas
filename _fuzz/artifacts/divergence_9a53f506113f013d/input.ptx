.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p3, %r3, 4;
    @%p3 mul.lo.u32 %r9, %r3, %r3;
    mul.lo.s32 %r13, %r9, %r9;
    add.u32 %r16, %r3, %r13;
    add.s32 %r6, %r3, 5;
    selp.b32 %r21, %r13, %r16, %p3;
    mul.wide.u32 %rd7, %r21, %r3;
    cvt.u64.u32 %rd8, %r16;
    cvt.u32.u64 %r26, %rd8;
    cvt.u32.u64 %r22, %rd7;
    sub.u32 %r23, %r13, 4294967295;
    min.u32 %r20, %r6, %r22;
    add.s64 %rd9, %rd8, %rd8;
    mul.wide.u32 %rd6, %r13, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
