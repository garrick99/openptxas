.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r17, %r3, 255;
    min.s32 %r5, %r3, 32;
    mul.wide.u32 %rd11, %r3, %r17;
    max.s64 %rd9, %rd11, %rd11;
    max.u32 %r22, %r5, 31;
    setp.lt.u32 %p2, %r3, %r17;
    @!%p2 sub.u32 %r22, %r3, %r17;
    max.u64 %rd14, %rd9, %rd11;
    mul.lo.u32 %r16, %r17, %r22;
    cvt.s32.s64 %r26, %rd9;
    add.s32 %r10, %r17, 4;
    max.s64 %rd15, %rd9, %rd11;
    or.b32 %r24, %r10, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
