.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r17, %r0, %r0;
    shfl.sync.bfly.b32 %r6, %r17, 4, 0x1f, -1;
    setp.gt.u32 %p3, %r6, %r17;
    vote.sync.ballot.b32 %r9, %p3, -1;
    and.b32 %r14, %r0, %r6;
    shfl.sync.bfly.b32 %r16, %r0, 16, 0x1f, -1;
    setp.ge.u32 %p1, %r3, 31;
    vote.sync.ballot.b32 %r18, %p1, -1;
    vote.sync.all.pred %p1, %p1, -1;
    shfl.sync.up.b32 %r19, %r14, 4, 0x1f, -1;
    or.b32 %r9, %r6, %r18;
    or.b32 %r15, %r0, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
