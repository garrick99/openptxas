.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    max.s32 %r10, %r3, 1;
    mad.lo.s32 %r5, %r10, %r10, %r10;
    shr.u32 %r25, %r3, 16;
    shl.b32 %r16, %r25, 0;
    mul.wide.u32 %rd8, %r5, %r10;
    max.s32 %r9, %r10, 65536;
    max.u32 %r22, %r3, %r9;
    max.u64 %rd14, %rd8, %rd10;
    sub.s32 %r19, %r22, %r9;
    add.u32 %r16, %r16, %r9;
    max.s32 %r4, %r25, %r22;
    mul.lo.s64 %rd8, %rd14, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
