.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    min.s32 %r18, %r3, %r3;
    shl.b64 %rd11, %rd9, 30;
    and.b64 %rd8, %rd9, %rd9;
    min.u32 %r12, %r18, %r18;
    mul.wide.u32 %rd6, %r18, %r12;
    shl.b64 %rd15, %rd6, 47;
    mul.lo.u64 %rd12, %rd8, %rd6;
    setp.le.u32 %p2, %r18, %r3;
    @!%p2 cvt.s64.s32 %rd13, %r18;
    add.u32 %r16, %r3, %r12;
    max.u32 %r7, %r16, %r18;
    setp.lt.s32 %p3, %r3, %r18;
    @%p3 shr.s32 %r19, %r18, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
