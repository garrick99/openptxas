.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r15, %r3, 4;
    sub.s32 %r20, %r3, 65536;
    max.u32 %r12, %r15, 0;
    cvt.s64.s32 %rd15, %r12;
    sub.s32 %r6, %r15, 31;
    xor.b32 %r11, %r6, %r3;
    or.b32 %r23, %r15, %r12;
    min.u32 %r12, %r3, %r11;
    setp.ls.u32 %p3, %r11, 16;
    @%p3 sub.u32 %r14, %r3, %r6;
    cvt.s64.s32 %rd15, %r11;
    selp.b32 %r7, %r20, %r23, %p3;
    add.s32 %r5, %r11, %r23;
    mad.lo.u32 %r27, %r7, %r5, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
