.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    shr.u64 %rd8, %rd5, 33;
    mul.wide.s32 %rd5, %r3, %r3;
    add.u32 %r24, %r3, %r3;
    shl.b64 %rd12, %rd5, 1;
    mad.lo.u32 %r7, %r24, %r24, %r24;
    shl.b64 %rd12, %rd12, 16;
    mul.wide.s32 %rd7, %r24, %r7;
    min.s32 %r9, %r3, 65536;
    mad.lo.s32 %r27, %r24, %r24, %r7;
    shr.u32 %r13, %r3, 16;
    min.u32 %r22, %r27, %r24;
    xor.b64 %rd9, %rd8, %rd8;
    min.u32 %r4, %r22, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
