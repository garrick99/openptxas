.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r20, %r3, %r3;
    setp.lt.u32 %p3, %r20, 32;
    @%p3 and.b32 %r8, %r20, %r3;
    shl.b32 %r6, %r8, 0;
    cvt.s64.s32 %rd11, %r6;
    cvt.s64.s32 %rd13, %r20;
    cvt.u64.u32 %rd14, %r20;
    setp.gt.u32 %p2, %r3, %r8;
    @%p2 max.u32 %r16, %r6, %r8;
    cvt.s64.s32 %rd9, %r8;
    sub.s32 %r24, %r8, %r6;
    selp.b32 %r15, %r24, %r8, %p2;
    add.u32 %r23, %r6, 7;
    selp.b32 %r16, %r23, %r23, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
