.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r11, %r3, %r3;
    xor.b32 %r15, %r11, 256;
    max.s32 %r22, %r15, %r11;
    setp.ne.s32 %p3, %r11, 32;
    @%p3 mul.lo.s32 %r21, %r22, %r22;
    sub.s32 %r11, %r21, 3;
    selp.b32 %r25, %r3, %r21, %p3;
    mad.lo.u32 %r18, %r25, %r15, %r21;
    xor.b32 %r21, %r21, %r15;
    mad.lo.s32 %r19, %r15, %r15, %r18;
    selp.b32 %r25, %r19, %r19, %p3;
    cvt.u64.u32 %rd9, %r18;
    or.b32 %r27, %r19, 64;
    max.s32 %r21, %r15, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
