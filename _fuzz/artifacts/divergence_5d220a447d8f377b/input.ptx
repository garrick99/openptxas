.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r21, %r3, 3;
    or.b32 %r5, %r3, 63;
    mul.lo.u32 %r25, %r21, %r5;
    mad.lo.u32 %r27, %r5, %r25, %r25;
    mul.lo.u32 %r19, %r25, 1;
    max.s32 %r22, %r27, 2;
    xor.b32 %r4, %r19, %r5;
    setp.lt.u32 %p1, %r21, 16;
    @!%p1 shr.s32 %r23, %r22, 0;
    and.b32 %r9, %r27, %r5;
    cvt.u64.u32 %rd12, %r27;
    setp.lt.s32 %p1, %r3, 64;
    @%p1 mul.lo.u32 %r6, %r5, 7;
    mul.lo.s32 %r17, %r3, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
