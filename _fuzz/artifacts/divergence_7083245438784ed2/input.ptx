.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r11, %r3, %r3;
    shr.u32 %r9, %r3, 15;
    cvt.s64.s32 %rd12, %r11;
    shr.s64 %rd8, %rd12, 63;
    or.b32 %r14, %r3, %r11;
    cvt.s32.s64 %r21, %rd12;
    cvt.s64.s32 %rd5, %r9;
    max.s32 %r26, %r21, 255;
    min.u32 %r15, %r14, 16;
    sub.s32 %r11, %r26, %r9;
    add.u32 %r15, %r21, 16;
    mul.lo.u32 %r4, %r3, %r11;
    add.s32 %r25, %r26, 1;
    min.u32 %r10, %r3, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
