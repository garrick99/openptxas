.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p4, %r3, %r3;
    @!%p4 shr.u32 %r9, %r3, 3;
    cvt.u64.u32 %rd15, %r3;
    add.u32 %r23, %r3, 16;
    max.s32 %r9, %r3, %r9;
    mul.lo.s64 %rd6, %rd15, %rd15;
    min.s32 %r23, %r23, %r9;
    add.s32 %r8, %r9, %r9;
    or.b32 %r26, %r23, 15;
    selp.b32 %r5, %r26, %r9, %p4;
    cvt.s32.s64 %r17, %rd15;
    and.b32 %r24, %r5, 2;
    mad.lo.s32 %r9, %r9, %r26, %r8;
    add.u32 %r13, %r5, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
