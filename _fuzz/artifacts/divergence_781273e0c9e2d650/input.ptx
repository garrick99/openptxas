.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    or.b32 %r17, %r3, %r3;
    cvt.s64.s32 %rd14, %r3;
    mul.wide.s32 %rd11, %r3, %r17;
    add.s32 %r26, %r17, 4;
    mad.lo.s32 %r26, %r17, %r3, %r17;
    mul.wide.u32 %rd13, %r17, %r3;
    setp.hs.u32 %p3, %r26, %r3;
    @!%p3 xor.b32 %r14, %r3, 8;
    shl.b64 %rd11, %rd14, 4;
    mul.wide.u32 %rd6, %r14, %r26;
    shr.s32 %r25, %r26, 1;
    max.s32 %r10, %r14, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
