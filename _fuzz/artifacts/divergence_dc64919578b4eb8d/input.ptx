.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r4, %r3, %r3;
    mad.lo.u32 %r6, %r3, %r4, %r4;
    mul.wide.u32 %rd6, %r6, %r4;
    setp.ne.u32 %p2, %r3, %r4;
    @%p2 shl.b32 %r15, %r4, 2;
    setp.ge.u32 %p3, %r3, 63;
    @%p3 xor.b32 %r17, %r3, %r6;
    add.s32 %r16, %r4, 5;
    mul.wide.u32 %rd10, %r16, %r16;
    mad.lo.s32 %r10, %r17, %r15, %r15;
    mul.lo.u32 %r6, %r17, 65535;
    sub.u32 %r4, %r15, %r15;
    max.u32 %r22, %r6, 65535;
    add.u32 %r22, %r22, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
