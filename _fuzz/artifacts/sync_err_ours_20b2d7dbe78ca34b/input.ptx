.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p2, %r3, 7;
    max.s32 %r9, %r3, %r3;
    mul.lo.u32 %r13, %r9, 65536;
    max.u32 %r23, %r3, %r13;
    xor.b32 %r9, %r3, 0;
    cvt.s64.s32 %rd10, %r23;
    mul.lo.u32 %r9, %r23, %r13;
    mad.lo.s32 %r21, %r9, %r23, %r3;
    mad.lo.u32 %r13, %r21, %r21, %r13;
    mul.lo.s64 %rd12, %rd10, %rd10;
    add.s64 %rd11, %rd12, %rd12;
    shr.s32 %r20, %r3, 4;
    shr.s32 %r10, %r23, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
