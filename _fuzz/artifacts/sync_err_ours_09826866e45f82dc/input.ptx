.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r5, %r3, 30;
    max.u32 %r27, %r3, %r3;
    add.u32 %r16, %r27, %r5;
    mul.lo.s32 %r24, %r27, 32;
    add.u32 %r18, %r16, 2;
    cvt.s64.s32 %rd10, %r18;
    add.u32 %r22, %r16, %r24;
    max.s32 %r9, %r27, 8;
    shr.u32 %r16, %r18, 2;
    shr.u64 %rd11, %rd10, 16;
    cvt.u64.u32 %rd13, %r22;
    shr.s32 %r8, %r3, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
