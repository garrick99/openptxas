.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r17, %r3, 2;
    sub.u32 %r27, %r3, %r17;
    mul.lo.u32 %r23, %r17, 255;
    cvt.u64.u32 %rd13, %r17;
    shr.u32 %r19, %r17, 2;
    shl.b32 %r10, %r27, 1;
    mad.lo.u32 %r9, %r19, %r10, %r19;
    and.b32 %r26, %r10, %r9;
    setp.ne.u32 %p2, %r26, %r17;
    cvt.s32.s64 %r4, %rd13;
    setp.hi.u32 %p1, %r23, 255;
    @%p1 add.s32 %r12, %r9, 63;
    mul.lo.s32 %r23, %r9, 256;
    mul.lo.s32 %r25, %r27, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
