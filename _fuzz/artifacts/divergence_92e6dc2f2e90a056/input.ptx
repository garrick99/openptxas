.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r18, %r3, 255;
    setp.lt.s32 %p4, %r3, 7;
    @%p4 mul.lo.s32 %r12, %r18, %r18;
    mad.lo.s32 %r20, %r18, %r3, %r3;
    mul.lo.u32 %r11, %r12, %r20;
    mad.lo.u32 %r17, %r3, %r11, %r12;
    or.b32 %r4, %r3, 63;
    and.b32 %r9, %r4, 4;
    min.s32 %r19, %r9, %r9;
    add.u32 %r10, %r17, %r4;
    cvt.s64.s32 %rd13, %r4;
    setp.le.s32 %p4, %r12, 65536;
    @%p4 mul.wide.s32 %rd6, %r17, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
