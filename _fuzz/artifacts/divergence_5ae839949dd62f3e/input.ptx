.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r21, %r3, 5;
    add.u32 %r9, %r21, %r3;
    setp.le.s32 %p1, %r3, 1;
    mul.wide.s32 %rd14, %r3, %r3;
    shr.s64 %rd9, %rd14, 1;
    shl.b32 %r24, %r21, 3;
    min.s64 %rd15, %rd9, %rd9;
    add.s32 %r15, %r24, 255;
    cvt.s64.s32 %rd6, %r9;
    min.u32 %r7, %r15, 1;
    xor.b32 %r4, %r3, 2147483647;
    xor.b32 %r25, %r7, %r15;
    setp.hs.u32 %p4, %r3, 0;
    @!%p4 mad.lo.s32 %r5, %r24, %r25, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
