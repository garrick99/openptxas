.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p1, %r3, %r3;
    cvt.u64.u32 %rd6, %r3;
    mul.wide.u32 %rd8, %r3, %r3;
    setp.ne.s32 %p1, %r3, %r3;
    @%p1 mul.wide.u32 %rd12, %r3, %r3;
    mul.wide.u32 %rd12, %r3, %r3;
    mul.lo.s32 %r4, %r3, 64;
    shl.b32 %r5, %r4, 0;
    xor.b32 %r7, %r5, 255;
    max.s32 %r4, %r4, 255;
    min.s64 %rd5, %rd6, %rd12;
    shr.u32 %r17, %r3, 0;
    shr.u64 %rd11, %rd12, 1;
    min.u32 %r22, %r17, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
