.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    add.s32 %r18, %r3, 5;
    mul.wide.s32 %rd12, %r18, %r18;
    mad.lo.s32 %r6, %r3, %r18, %r3;
    max.s32 %r10, %r3, 16;
    cvt.s32.s64 %r13, %rd12;
    sub.u32 %r11, %r10, %r18;
    mul.wide.u32 %rd6, %r13, %r13;
    setp.lt.u32 %p4, %r6, 4;
    add.u32 %r10, %r11, %r18;
    mad.lo.s32 %r16, %r18, %r18, %r10;
    add.u32 %r17, %r6, 7;
    shr.u32 %r14, %r16, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
