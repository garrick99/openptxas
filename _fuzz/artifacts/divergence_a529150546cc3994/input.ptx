.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    mad.lo.u32 %r4, %r3, %r3, %r3;
    and.b32 %r9, %r4, 1;
    mul.lo.s32 %r27, %r3, %r9;
    add.s32 %r10, %r27, %r4;
    max.u32 %r4, %r10, %r9;
    mul.lo.s64 %rd5, %rd10, %rd10;
    max.u32 %r18, %r10, 3;
    cvt.s64.s32 %rd9, %r27;
    cvt.u64.u32 %rd6, %r4;
    cvt.s32.s64 %r9, %rd9;
    mad.lo.u32 %r17, %r9, %r18, %r9;
    and.b32 %r11, %r18, 1;
    shr.s32 %r15, %r10, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
