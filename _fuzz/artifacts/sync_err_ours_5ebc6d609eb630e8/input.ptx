.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r10, %r3, 4;
    cvt.u64.u32 %rd9, %r3;
    setp.ne.s32 %p4, %r3, 65536;
    mul.wide.u32 %rd14, %r3, %r3;
    cvt.s32.s64 %r16, %rd14;
    and.b32 %r27, %r3, %r3;
    sub.u32 %r12, %r10, %r10;
    shr.s32 %r10, %r27, 15;
    sub.s32 %r11, %r10, 0;
    add.u32 %r18, %r10, %r3;
    shl.b32 %r23, %r16, 3;
    shr.s32 %r6, %r18, 2;
    mad.lo.s32 %r6, %r18, %r27, %r27;
    setp.gt.u32 %p3, %r6, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
