.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p4, %r3, %r3;
    xor.b32 %r20, %r3, 2147483648;
    sub.u32 %r20, %r3, %r3;
    cvt.s64.s32 %rd6, %r3;
    setp.gt.u32 %p1, %r20, 5;
    @%p1 add.u32 %r24, %r3, %r20;
    mul.lo.u32 %r5, %r24, %r24;
    mad.lo.s32 %r24, %r3, %r3, %r5;
    and.b32 %r17, %r24, %r24;
    max.s32 %r25, %r3, %r3;
    sub.s32 %r25, %r20, 3;
    mad.lo.s32 %r22, %r17, %r20, %r17;
    setp.lo.u32 %p3, %r25, 8;
    @!%p3 add.s32 %r13, %r22, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
