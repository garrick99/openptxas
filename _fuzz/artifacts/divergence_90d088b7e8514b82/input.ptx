.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r21, %r3, 32;
    or.b32 %r22, %r3, 0;
    max.u32 %r16, %r22, 63;
    or.b32 %r8, %r3, %r16;
    add.u32 %r26, %r8, 1;
    shr.s32 %r27, %r8, 31;
    setp.gt.s32 %p3, %r16, 2147483648;
    @%p3 mul.wide.u32 %rd14, %r27, %r22;
    setp.eq.s32 %p4, %r8, 32;
    @!%p4 cvt.u32.u64 %r25, %rd14;
    setp.le.s32 %p1, %r21, 64;
    @%p1 selp.b32 %r25, %r27, %r8, %p4;
    min.s32 %r20, %r16, 255;
    xor.b32 %r24, %r8, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
