.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r11, %r3, 15;
    add.s32 %r11, %r3, %r3;
    shl.b32 %r15, %r3, 30;
    cvt.u64.u32 %rd5, %r11;
    and.b32 %r15, %r11, 2;
    mul.lo.u32 %r22, %r11, 32;
    mul.lo.s32 %r12, %r11, %r22;
    shr.s64 %rd8, %rd5, 31;
    mad.lo.s32 %r10, %r22, %r11, %r12;
    min.u32 %r9, %r10, 4;
    sub.s32 %r16, %r10, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
