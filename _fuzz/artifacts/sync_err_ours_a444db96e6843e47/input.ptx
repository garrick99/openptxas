.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r25, %r3, %r3;
    max.u32 %r25, %r25, 2;
    cvt.s64.s32 %rd5, %r25;
    setp.lo.u32 %p4, %r3, 256;
    @%p4 shr.s32 %r17, %r3, 7;
    setp.lt.u32 %p4, %r25, 32;
    @!%p4 max.u32 %r20, %r25, 8;
    sub.u32 %r22, %r25, 8;
    cvt.s32.s64 %r12, %rd5;
    cvt.u32.u64 %r21, %rd5;
    shl.b64 %rd13, %rd5, 32;
    setp.lt.s32 %p4, %r21, 64;
    @%p4 min.s32 %r25, %r22, 2147483647;
    shr.u64 %rd7, %rd13, 62;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
