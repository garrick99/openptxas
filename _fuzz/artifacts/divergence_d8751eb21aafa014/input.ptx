.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    cvt.u32.u64 %r20, %rd12;
    min.u64 %rd7, %rd12, %rd12;
    mul.wide.u32 %rd8, %r3, %r3;
    xor.b64 %rd8, %rd7, %rd12;
    or.b32 %r6, %r3, %r20;
    setp.lt.s32 %p1, %r6, %r20;
    cvt.s32.s64 %r12, %rd7;
    shr.u64 %rd6, %rd12, 2;
    max.s32 %r5, %r6, %r12;
    sub.u64 %rd8, %rd7, %rd12;
    cvt.s32.s64 %r18, %rd6;
    selp.b32 %r22, %r6, %r20, %p1;
    max.u32 %r4, %r5, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
