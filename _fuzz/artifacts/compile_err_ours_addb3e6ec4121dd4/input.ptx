.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.up.b32 %r12, %r3, 1, 0x1f, -1;
    sub.u32 %r14, %r3, %r0;
    setp.eq.u32 %p3, %r12, %r14;
    vote.sync.ballot.b32 %r17, %p3, -1;
    shfl.sync.up.b32 %r18, %r17, 4, 0x1f, -1;
    and.b32 %r5, %r17, %r14;
    add.u32 %r6, %r5, %r3;
    setp.le.u32 %p2, %r5, %r0;
    vote.sync.ballot.b32 %r16, %p2, -1;
    setp.eq.u32 %p1, %r14, 1;
    vote.sync.ballot.b32 %r7, %p1, -1;
    setp.le.u32 %p1, %r6, %r7;
    vote.sync.ballot.b32 %r8, %p1, -1;
    vote.sync.all.pred %p3, %p2, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
