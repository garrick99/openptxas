.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    mul.lo.u32 %r27, %r3, %r3;
    and.b32 %r4, %r27, %r27;
    mul.wide.u32 %rd11, %r27, %r27;
    mul.wide.u32 %rd14, %r4, %r27;
    min.s32 %r17, %r27, 65535;
    add.s64 %rd9, %rd5, %rd14;
    mad.lo.s32 %r9, %r4, %r4, %r4;
    cvt.s32.s64 %r20, %rd11;
    cvt.s32.s64 %r26, %rd14;
    max.s32 %r6, %r4, %r3;
    mad.lo.s32 %r13, %r3, %r4, %r27;
    shl.b32 %r10, %r9, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
