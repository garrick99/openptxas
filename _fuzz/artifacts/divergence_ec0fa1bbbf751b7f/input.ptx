.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd13, %r3, %r3;
    setp.eq.s32 %p4, %r3, 15;
    @%p4 mul.lo.u32 %r23, %r3, 64;
    sub.s32 %r7, %r3, %r23;
    min.s32 %r5, %r7, 32;
    and.b32 %r6, %r3, %r5;
    sub.s32 %r21, %r5, 2;
    mul.lo.u32 %r16, %r7, %r23;
    cvt.u64.u32 %rd10, %r7;
    shr.u32 %r9, %r5, 3;
    cvt.s32.s64 %r22, %rd13;
    shr.s32 %r7, %r7, 3;
    min.u32 %r10, %r21, 5;
    mul.lo.s32 %r9, %r6, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
