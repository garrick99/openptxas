.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    min.u64 %rd10, %rd13, %rd13;
    mul.lo.u32 %r25, %r3, %r3;
    shl.b32 %r6, %r25, 0;
    min.u32 %r20, %r25, 255;
    mul.wide.s32 %rd15, %r20, %r25;
    and.b32 %r14, %r20, 63;
    add.u32 %r14, %r14, %r25;
    cvt.u64.u32 %rd7, %r3;
    shl.b32 %r17, %r3, 31;
    mul.lo.u64 %rd7, %rd15, %rd15;
    add.u32 %r13, %r20, %r25;
    mad.lo.u32 %r16, %r3, %r6, %r20;
    min.s32 %r25, %r6, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
