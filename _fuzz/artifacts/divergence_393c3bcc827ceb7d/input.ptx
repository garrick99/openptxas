.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r5, %r3, %r3, %r3;
    cvt.u64.u32 %rd11, %r3;
    sub.u32 %r7, %r3, %r5;
    setp.ge.u32 %p3, %r3, 63;
    @%p3 min.s32 %r14, %r3, %r7;
    add.s32 %r24, %r5, %r7;
    setp.ge.u32 %p1, %r24, 65535;
    @%p1 max.s32 %r20, %r14, %r24;
    cvt.s64.s32 %rd13, %r20;
    sub.u32 %r12, %r24, %r7;
    cvt.u32.u64 %r4, %rd13;
    min.s32 %r18, %r12, %r4;
    setp.hi.u32 %p3, %r14, 15;
    setp.lt.s32 %p4, %r5, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
