.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r21, %r3, %r3;
    min.s32 %r12, %r3, 4294967295;
    and.b32 %r23, %r3, 8;
    add.s32 %r19, %r3, %r23;
    cvt.s64.s32 %rd14, %r19;
    mad.lo.s32 %r24, %r12, %r23, %r12;
    cvt.u64.u32 %rd9, %r12;
    mul.lo.s32 %r11, %r21, 31;
    mad.lo.s32 %r10, %r21, %r21, %r19;
    mul.wide.u32 %rd6, %r3, %r10;
    mul.wide.u32 %rd15, %r12, %r24;
    min.u32 %r26, %r10, 64;
    and.b32 %r19, %r19, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
