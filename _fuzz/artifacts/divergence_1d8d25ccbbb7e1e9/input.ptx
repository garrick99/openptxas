.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    brev.b32 %r15, %r3;
    bfe.u32 %r12, %r3, 0, 31;
    max.u32 %r11, %r3, %r15;
    brev.b32 %r4, %r3;
    xor.b32 %r12, %r4, 32;
    max.u32 %r22, %r4, 0;
    clz.b32 %r16, %r12;
    bfi.b32 %r5, %r22, %r15, 1, 31;
    bfi.b32 %r14, %r11, %r12, 23, 32;
    bfe.u32 %r4, %r4, 31, 32;
    popc.b32 %r5, %r16;
    bfe.s32 %r7, %r15, 1, 24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
