.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    min.u32 %r16, %r3, %r3;
    mul.wide.s32 %rd9, %r3, %r16;
    cvt.u32.u64 %r19, %rd10;
    or.b32 %r23, %r3, %r16;
    cvt.s32.s64 %r25, %rd10;
    setp.le.u32 %p2, %r3, %r23;
    and.b32 %r17, %r19, %r3;
    mul.lo.s32 %r13, %r19, %r16;
    min.s32 %r6, %r23, %r17;
    shr.u64 %rd13, %rd9, 7;
    setp.lo.u32 %p4, %r19, %r3;
    @%p4 shr.u32 %r6, %r19, 16;
    shr.s64 %rd11, %rd13, 62;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
