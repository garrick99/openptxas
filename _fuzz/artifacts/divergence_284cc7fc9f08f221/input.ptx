.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r6, %r3, %r3;
    or.b32 %r26, %r3, %r6;
    xor.b32 %r4, %r3, 32;
    shr.u32 %r21, %r3, 1;
    setp.ne.s32 %p1, %r26, %r21;
    @%p1 mul.lo.s32 %r23, %r6, 2147483647;
    and.b32 %r5, %r4, 2147483648;
    cvt.s64.s32 %rd13, %r21;
    cvt.u64.u32 %rd15, %r23;
    cvt.u32.u64 %r19, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
