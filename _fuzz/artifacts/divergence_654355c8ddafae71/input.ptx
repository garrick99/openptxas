.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r21, %r3, 31;
    cvt.s64.s32 %rd6, %r21;
    add.u32 %r4, %r3, %r3;
    sub.s32 %r27, %r3, 32;
    shr.s32 %r5, %r27, 31;
    add.u32 %r26, %r5, %r27;
    sub.u32 %r4, %r21, %r26;
    add.s32 %r23, %r3, %r3;
    mul.lo.s32 %r21, %r26, %r21;
    shr.s32 %r27, %r21, 31;
    setp.le.s32 %p1, %r5, %r26;
    @!%p1 max.s64 %rd8, %rd6, %rd6;
    mul.wide.u32 %rd9, %r5, %r26;
    cvt.s32.s64 %r8, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
