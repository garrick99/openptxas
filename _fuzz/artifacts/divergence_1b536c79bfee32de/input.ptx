.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r27, %r3, 256;
    mul.wide.s32 %rd13, %r27, %r3;
    max.u32 %r26, %r27, 15;
    shr.s32 %r7, %r3, 2;
    and.b32 %r16, %r27, %r7;
    cvt.s64.s32 %rd5, %r27;
    add.s32 %r20, %r16, %r7;
    mad.lo.u32 %r14, %r7, %r7, %r27;
    mul.lo.u32 %r15, %r20, 32;
    xor.b32 %r8, %r26, %r7;
    mul.lo.s64 %rd6, %rd13, %rd13;
    and.b32 %r19, %r26, %r27;
    add.s64 %rd7, %rd6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
