.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    cvt.u32.u64 %r9, %rd8;
    setp.ge.s32 %p4, %r9, %r3;
    @!%p4 shl.b32 %r10, %r3, 3;
    sub.s32 %r4, %r10, 256;
    shr.u32 %r9, %r3, 2;
    add.u32 %r23, %r4, 64;
    mul.wide.s32 %rd9, %r4, %r9;
    setp.le.s32 %p2, %r4, %r4;
    @%p2 xor.b64 %rd15, %rd8, %rd9;
    max.u32 %r5, %r23, 255;
    sub.u32 %r26, %r5, 16;
    cvt.u32.u64 %r27, %rd9;
    cvt.s32.s64 %r15, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
