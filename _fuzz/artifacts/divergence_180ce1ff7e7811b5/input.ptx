.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r15, %r3, 1;
    sub.u32 %r25, %r15, %r3;
    setp.lo.u32 %p3, %r15, 4;
    setp.ne.u32 %p1, %r15, 5;
    @%p1 add.u32 %r11, %r15, %r25;
    shr.s32 %r27, %r11, 30;
    min.s32 %r22, %r25, 65535;
    mul.wide.s32 %rd11, %r11, %r11;
    setp.lt.u32 %p3, %r15, %r11;
    @!%p3 mad.lo.u32 %r5, %r27, %r25, %r22;
    mul.lo.u32 %r11, %r27, %r15;
    mul.lo.s32 %r20, %r11, %r22;
    max.u32 %r10, %r22, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
