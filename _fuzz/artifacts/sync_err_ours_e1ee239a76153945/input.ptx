.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    sub.s32 %r4, %r3, %r3;
    cvt.u32.u64 %r16, %rd10;
    shr.u32 %r14, %r3, 0;
    mul.wide.s32 %rd12, %r4, %r4;
    mul.lo.s32 %r23, %r14, 16;
    shr.s64 %rd13, %rd10, 4;
    sub.s64 %rd7, %rd12, %rd12;
    shr.s64 %rd15, %rd12, 16;
    setp.lt.s32 %p3, %r3, 8;
    @!%p3 sub.u32 %r14, %r4, %r14;
    xor.b32 %r21, %r14, %r16;
    shr.u32 %r4, %r4, 30;
    max.s32 %r21, %r14, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
