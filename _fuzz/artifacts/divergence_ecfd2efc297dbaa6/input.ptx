.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r15, %r3, 16;
    setp.ne.u32 %p2, %r15, 64;
    setp.lt.s32 %p2, %r15, %r15;
    @%p2 cvt.s64.s32 %rd14, %r3;
    max.s32 %r25, %r3, 16;
    cvt.s32.s64 %r16, %rd14;
    mul.lo.u32 %r4, %r25, %r15;
    shl.b32 %r26, %r15, 2;
    shr.u32 %r18, %r25, 1;
    sub.s64 %rd5, %rd14, %rd14;
    sub.u32 %r23, %r26, 0;
    add.s64 %rd7, %rd5, %rd14;
    xor.b32 %r25, %r15, 65536;
    cvt.s32.s64 %r18, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
