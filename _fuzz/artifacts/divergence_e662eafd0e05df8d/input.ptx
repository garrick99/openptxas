.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd12, %r3, %r3;
    add.u32 %r27, %r3, 0;
    shl.b32 %r10, %r27, 30;
    cvt.s64.s32 %rd11, %r3;
    setp.gt.s32 %p1, %r3, %r27;
    @%p1 mad.lo.u32 %r16, %r10, %r27, %r27;
    mul.wide.u32 %rd15, %r10, %r16;
    setp.eq.s32 %p4, %r3, 3;
    @!%p4 and.b32 %r9, %r10, %r3;
    add.s32 %r13, %r10, 16;
    setp.ge.s32 %p1, %r13, %r3;
    @!%p1 add.u32 %r19, %r27, 32;
    setp.le.u32 %p4, %r19, 1;
    @!%p4 shr.u32 %r22, %r3, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
