.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    sub.u32 %r19, %r3, 256;
    mul.wide.u32 %rd8, %r19, %r19;
    min.s64 %rd13, %rd8, %rd8;
    mad.lo.u32 %r9, %r19, %r3, %r3;
    min.u64 %rd6, %rd13, %rd8;
    cvt.s32.s64 %r24, %rd6;
    xor.b64 %rd11, %rd6, %rd8;
    cvt.s32.s64 %r27, %rd8;
    min.u32 %r7, %r24, 0;
    max.s32 %r12, %r7, 4294967295;
    shr.u32 %r24, %r19, 16;
    mul.lo.u32 %r16, %r3, 65536;
    xor.b64 %rd14, %rd11, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
