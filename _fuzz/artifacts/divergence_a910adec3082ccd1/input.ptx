.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r8, %r3, 16;
    cvt.u64.u32 %rd7, %r8;
    max.u64 %rd5, %rd7, %rd7;
    mad.lo.u32 %r23, %r3, %r3, %r8;
    mad.lo.s32 %r18, %r3, %r8, %r23;
    mul.lo.s32 %r15, %r3, %r8;
    setp.ge.s32 %p3, %r18, 63;
    @%p3 sub.s32 %r7, %r18, %r3;
    cvt.s64.s32 %rd7, %r8;
    mul.lo.s32 %r26, %r3, %r8;
    shr.s32 %r19, %r7, 16;
    setp.hi.u32 %p3, %r23, %r26;
    @!%p3 and.b64 %rd9, %rd7, %rd7;
    add.s32 %r12, %r7, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
