.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r6, %r3, 2;
    setp.hi.u32 %p2, %r3, %r6;
    @%p2 cvt.s64.s32 %rd11, %r6;
    setp.eq.s32 %p2, %r3, 255;
    add.s64 %rd9, %rd11, %rd11;
    mul.lo.u32 %r17, %r3, 4294967295;
    max.s32 %r13, %r6, %r17;
    setp.ge.u32 %p1, %r6, %r17;
    @!%p1 mul.lo.u32 %r18, %r17, 4294967295;
    shr.s64 %rd5, %rd9, 63;
    sub.u32 %r12, %r18, %r3;
    max.s32 %r25, %r17, %r18;
    min.u32 %r11, %r3, %r17;
    or.b32 %r6, %r17, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
