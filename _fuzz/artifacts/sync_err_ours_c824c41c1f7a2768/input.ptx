.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd6, %r3, %r3;
    or.b32 %r25, %r3, 0;
    setp.le.s32 %p1, %r3, 8;
    mul.lo.u64 %rd15, %rd6, %rd6;
    xor.b32 %r15, %r25, %r3;
    mul.lo.u32 %r19, %r25, 31;
    mad.lo.u32 %r6, %r25, %r25, %r25;
    selp.b32 %r6, %r3, %r6, %p1;
    min.s32 %r8, %r6, %r6;
    add.s32 %r27, %r25, %r3;
    shr.s64 %rd8, %rd6, 2;
    setp.lt.u32 %p3, %r25, 32;
    mad.lo.u32 %r4, %r6, %r27, %r15;
    mul.lo.u64 %rd8, %rd6, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
