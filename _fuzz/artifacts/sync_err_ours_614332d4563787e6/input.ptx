.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    cvt.s32.s64 %r15, %rd15;
    min.u32 %r4, %r3, 7;
    or.b32 %r9, %r4, %r15;
    max.u32 %r22, %r4, %r4;
    add.s32 %r12, %r4, %r9;
    cvt.u64.u32 %rd13, %r15;
    mul.lo.s32 %r13, %r9, %r12;
    shr.s64 %rd10, %rd15, 1;
    mad.lo.s32 %r20, %r22, %r4, %r12;
    cvt.u64.u32 %rd11, %r22;
    shr.u32 %r11, %r9, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
