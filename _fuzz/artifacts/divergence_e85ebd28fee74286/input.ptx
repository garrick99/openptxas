.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r4, %r3, %r3, %r3;
    cvt.u64.u32 %rd6, %r3;
    setp.lt.s32 %p2, %r3, 65536;
    @%p2 cvt.u32.u64 %r23, %rd6;
    mul.wide.u32 %rd5, %r3, %r4;
    shr.u32 %r21, %r4, 16;
    mad.lo.s32 %r26, %r4, %r4, %r3;
    mul.lo.s32 %r14, %r23, 0;
    and.b32 %r12, %r26, 3;
    shr.u32 %r10, %r3, 3;
    min.s32 %r20, %r23, 4294967295;
    mad.lo.u32 %r8, %r3, %r21, %r12;
    add.s32 %r27, %r23, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
