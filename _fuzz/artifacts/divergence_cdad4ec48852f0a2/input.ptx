.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p3, %r3, 2147483647;
    vote.sync.ballot.b32 %r7, %p3, -1;
    shfl.sync.idx.b32 %r17, %r7, 7, 0x1f, -1;
    shfl.sync.up.b32 %r15, %r0, 1, 0x1f, -1;
    sub.u32 %r18, %r7, %r7;
    add.u32 %r8, %r3, %r7;
    shfl.sync.bfly.b32 %r8, %r3, 1, 0x1f, -1;
    min.u32 %r15, %r3, %r18;
