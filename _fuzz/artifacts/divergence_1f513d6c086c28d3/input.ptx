.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd12, %r3, %r3;
    add.s32 %r25, %r3, 4294967295;
    mul.wide.u32 %rd10, %r25, %r25;
    mul.wide.u32 %rd13, %r3, %r25;
    shr.u32 %r27, %r25, 31;
    cvt.u32.u64 %r26, %rd10;
    mul.lo.u32 %r21, %r27, 7;
    shr.s64 %rd8, %rd10, 0;
    cvt.s64.s32 %rd5, %r25;
    min.s32 %r24, %r26, %r26;
    mad.lo.u32 %r27, %r24, %r3, %r21;
    mul.wide.u32 %rd6, %r24, %r27;
    shr.u32 %r7, %r24, 3;
    mad.lo.s32 %r5, %r21, %r3, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
