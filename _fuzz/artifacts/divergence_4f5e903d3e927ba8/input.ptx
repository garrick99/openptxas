.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r18, %r3, 2;
    cvt.u64.u32 %rd15, %r3;
    cvt.s32.s64 %r25, %rd15;
    max.s32 %r9, %r18, 5;
    mul.lo.s32 %r21, %r25, 256;
    shr.u64 %rd6, %rd15, 48;
    shr.u32 %r22, %r18, 0;
    or.b64 %rd14, %rd15, %rd6;
    setp.le.u32 %p1, %r18, 63;
    @%p1 and.b32 %r19, %r22, 5;
    mul.wide.u32 %rd10, %r21, %r3;
    and.b64 %rd11, %rd14, %rd10;
    setp.lt.u32 %p1, %r21, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
