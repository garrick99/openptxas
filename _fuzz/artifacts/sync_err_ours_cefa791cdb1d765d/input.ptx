.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p4, %r3, %r3;
    @%p4 sub.s32 %r16, %r3, %r3;
    mul.wide.u32 %rd5, %r3, %r3;
    mad.lo.s32 %r17, %r16, %r3, %r3;
    add.s32 %r10, %r3, 63;
    max.s64 %rd9, %rd5, %rd5;
    max.u32 %r16, %r17, %r10;
    setp.lo.u32 %p2, %r16, %r10;
    or.b32 %r21, %r16, %r10;
    xor.b32 %r13, %r16, %r10;
    sub.u32 %r9, %r16, %r10;
    mad.lo.u32 %r9, %r13, %r3, %r9;
    max.s32 %r21, %r21, %r21;
    mad.lo.s32 %r10, %r16, %r10, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
