.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r24, %r3, %r3;
    cvt.u64.u32 %rd5, %r3;
    min.u32 %r21, %r3, %r24;
    sub.u32 %r20, %r3, 64;
    xor.b32 %r5, %r3, 65535;
    setp.lt.u32 %p4, %r20, 32;
    @%p4 shr.u32 %r10, %r24, 1;
    cvt.u32.u64 %r19, %rd5;
    mul.wide.s32 %rd5, %r20, %r19;
    shr.s32 %r24, %r5, 15;
    mul.lo.u32 %r8, %r21, %r21;
    shr.s64 %rd9, %rd5, 33;
    shr.u64 %rd5, %rd5, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
