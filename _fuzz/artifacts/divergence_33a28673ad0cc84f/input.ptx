.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r11, %r3, 5;
    cvt.u64.u32 %rd6, %r11;
    xor.b32 %r20, %r3, %r11;
    cvt.s32.s64 %r12, %rd6;
    cvt.s64.s32 %rd11, %r3;
    setp.eq.u32 %p2, %r20, 0;
    @!%p2 xor.b64 %rd15, %rd11, %rd11;
    mul.lo.u32 %r14, %r20, %r12;
    mad.lo.u32 %r18, %r12, %r12, %r3;
    mul.wide.u32 %rd11, %r20, %r12;
    selp.b32 %r15, %r12, %r3, %p2;
    mul.lo.u32 %r11, %r3, %r3;
    add.s32 %r13, %r11, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
