.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfi.b32 %r10, %r3, %r3, 23, 8;
    bfi.b32 %r19, %r10, %r3, 0, 4;
    clz.b32 %r5, %r10;
    clz.b32 %r23, %r19;
    bfi.b32 %r18, %r19, %r10, 31, 7;
    bfi.b32 %r8, %r23, %r5, 31, 4;
    bfe.s32 %r13, %r18, 7, 8;
    sub.u32 %r16, %r8, %r13;
    bfe.s32 %r17, %r16, 24, 32;
    clz.b32 %r7, %r19;
    or.b32 %r16, %r17, %r19;
    bfe.u32 %r23, %r10, 7, 24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
