.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    shl.b64 %rd5, %rd14, 1;
    cvt.u32.u64 %r10, %rd5;
    add.s32 %r12, %r10, %r3;
    cvt.s64.s32 %rd8, %r3;
    add.s32 %r27, %r10, 15;
    cvt.s64.s32 %rd5, %r3;
    shr.u64 %rd12, %rd5, 47;
    shr.s32 %r11, %r10, 31;
    min.s32 %r21, %r12, %r12;
    cvt.s64.s32 %rd7, %r3;
    max.u32 %r19, %r12, %r11;
    mul.wide.u32 %rd5, %r10, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
