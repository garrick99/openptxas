.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r27, %r3, %r3;
    cvt.u64.u32 %rd13, %r3;
    mul.lo.s32 %r18, %r27, 31;
    setp.lt.s32 %p2, %r27, 32;
    @!%p2 max.s32 %r20, %r18, 3;
    setp.ge.u32 %p2, %r18, %r27;
    @%p2 cvt.s64.s32 %rd7, %r20;
    shr.s32 %r10, %r18, 3;
    sub.s64 %rd14, %rd7, %rd13;
    cvt.s64.s32 %rd6, %r27;
    shr.s64 %rd13, %rd7, 63;
    setp.hi.u32 %p2, %r27, %r10;
    @%p2 shl.b32 %r14, %r10, 2;
    shl.b64 %rd14, %rd6, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
