.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r4, %r3, %r3;
    mul.wide.s32 %rd5, %r4, %r3;
    shl.b32 %r26, %r4, 3;
    mul.wide.u32 %rd13, %r3, %r4;
    cvt.s32.s64 %r25, %rd13;
    cvt.u32.u64 %r21, %rd5;
    cvt.s64.s32 %rd15, %r25;
    mad.lo.s32 %r12, %r26, %r3, %r3;
    mul.lo.u32 %r10, %r25, 64;
    sub.u64 %rd15, %rd5, %rd13;
    add.u64 %rd5, %rd13, %rd13;
    or.b32 %r4, %r21, 15;
    shl.b32 %r27, %r12, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
