.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p2, %r3, 15;
    @%p2 max.u32 %r21, %r3, 5;
    add.s32 %r23, %r21, 31;
    setp.ge.s32 %p2, %r23, 65536;
    @%p2 min.s32 %r9, %r3, 8;
    min.u32 %r17, %r3, 15;
    min.u32 %r22, %r23, 1;
    add.s32 %r14, %r21, %r23;
    sub.u32 %r12, %r9, %r3;
    mul.lo.s32 %r18, %r22, %r14;
    add.u32 %r23, %r22, 3;
    mul.lo.u32 %r16, %r23, 8;
    setp.lt.s32 %p3, %r14, 255;
    @!%p3 max.u32 %r5, %r16, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
