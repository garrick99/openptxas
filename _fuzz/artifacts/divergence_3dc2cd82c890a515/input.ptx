.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r26, %r3, 0;
    mul.lo.s32 %r16, %r3, 4294967295;
    setp.hi.u32 %p4, %r16, 2;
    @%p4 max.u32 %r13, %r16, %r26;
    cvt.u64.u32 %rd12, %r13;
    and.b32 %r19, %r13, %r13;
    min.u32 %r9, %r3, 2;
    add.u64 %rd15, %rd12, %rd12;
    xor.b32 %r18, %r16, 256;
    setp.le.s32 %p1, %r26, 65536;
    @%p1 mul.wide.s32 %rd11, %r3, %r19;
    mul.wide.u32 %rd5, %r16, %r13;
    shr.u64 %rd10, %rd15, 30;
    mad.lo.s32 %r12, %r13, %r9, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
