.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfi.b32 %r18, %r3, %r3, 15, 4;
    popc.b32 %r23, %r18;
    bfe.s32 %r21, %r3, 0, 2;
    bfe.u32 %r13, %r18, 16, 24;
    clz.b32 %r17, %r23;
    bfe.s32 %r6, %r17, 4, 2;
    prmt.b32 %r11, %r3, %r23, 12816;
    bfe.u32 %r23, %r18, 4, 24;
    and.b32 %r5, %r18, 256;
    prmt.b32 %r8, %r23, %r21, 48059;
    popc.b32 %r4, %r23;
    brev.b32 %r17, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
