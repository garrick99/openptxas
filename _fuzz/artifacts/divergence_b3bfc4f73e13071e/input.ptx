.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r23, %r3, 15;
    shl.b32 %r13, %r3, 3;
    shr.u32 %r24, %r23, 15;
    mul.lo.s32 %r12, %r24, 5;
    mul.lo.u32 %r7, %r12, 3;
    mul.lo.s32 %r22, %r23, 2147483648;
    cvt.s64.s32 %rd10, %r12;
    setp.hi.u32 %p2, %r7, %r22;
    sub.s32 %r18, %r12, %r24;
    sub.u32 %r13, %r22, %r23;
    shr.u32 %r24, %r12, 7;
    xor.b32 %r13, %r13, 256;
    add.s32 %r6, %r22, 32;
    or.b32 %r4, %r6, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
