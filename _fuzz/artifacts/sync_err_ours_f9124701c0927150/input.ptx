.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p2, %r3, 5;
    @%p2 mul.wide.s32 %rd7, %r3, %r3;
    cvt.s32.s64 %r26, %rd7;
    mul.wide.s32 %rd15, %r3, %r3;
    shr.s64 %rd12, %rd7, 33;
    shl.b64 %rd8, %rd7, 7;
    setp.le.s32 %p3, %r26, 255;
    @%p3 add.s32 %r27, %r26, %r3;
    sub.s32 %r6, %r27, %r26;
    or.b32 %r19, %r26, %r27;
    max.u32 %r17, %r3, 8;
    mul.wide.u32 %rd6, %r19, %r26;
    mul.lo.s32 %r23, %r27, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
