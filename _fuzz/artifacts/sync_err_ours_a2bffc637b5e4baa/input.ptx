.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r19, %r3, 7;
    max.u32 %r4, %r19, 32;
    cvt.u64.u32 %rd12, %r19;
    mad.lo.s32 %r21, %r4, %r4, %r4;
    add.u32 %r11, %r19, 8;
    min.s32 %r9, %r4, 5;
    mul.wide.u32 %rd8, %r21, %r3;
    add.u32 %r15, %r4, 4;
    add.s32 %r25, %r4, %r3;
    max.u32 %r24, %r21, %r9;
    cvt.s32.s64 %r17, %rd8;
    cvt.u64.u32 %rd11, %r3;
    sub.s32 %r20, %r19, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
