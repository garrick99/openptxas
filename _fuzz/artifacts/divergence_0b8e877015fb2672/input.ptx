.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r9, %r3, 3;
    cvt.u64.u32 %rd6, %r3;
    mul.lo.u32 %r26, %r3, %r9;
    xor.b32 %r21, %r26, 65535;
    or.b32 %r27, %r21, 3;
    mul.lo.u32 %r11, %r9, %r21;
    mul.wide.u32 %rd13, %r26, %r3;
    max.u32 %r13, %r26, %r27;
    add.u32 %r26, %r27, 15;
    min.u32 %r27, %r11, %r9;
    min.u32 %r10, %r9, 4;
    shr.s64 %rd11, %rd6, 48;
    cvt.s64.s32 %rd11, %r3;
    or.b32 %r20, %r3, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
