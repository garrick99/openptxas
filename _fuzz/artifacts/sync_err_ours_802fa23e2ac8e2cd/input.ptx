.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    sub.s32 %r6, %r3, 31;
    min.s32 %r10, %r6, %r6;
    min.s32 %r22, %r10, %r3;
    and.b32 %r21, %r22, %r3;
    mad.lo.s32 %r4, %r6, %r3, %r10;
    mul.lo.s32 %r7, %r22, %r22;
    add.s32 %r22, %r4, %r22;
    min.u32 %r24, %r7, %r22;
    setp.le.u32 %p1, %r4, %r21;
    @%p1 mul.lo.u32 %r23, %r4, 31;
    max.s32 %r18, %r7, 3;
    setp.gt.u32 %p2, %r23, 4;
    @%p2 mul.lo.u32 %r13, %r21, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
