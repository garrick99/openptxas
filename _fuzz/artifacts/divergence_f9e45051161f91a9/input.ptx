.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r9, %r3, 3;
    setp.hi.u32 %p3, %r3, %r9;
    @!%p3 or.b32 %r20, %r9, %r3;
    mad.lo.s32 %r12, %r3, %r9, %r9;
    and.b32 %r7, %r20, %r12;
    cvt.u64.u32 %rd15, %r7;
    setp.eq.u32 %p1, %r7, 65536;
    @%p1 cvt.s64.s32 %rd6, %r7;
    and.b32 %r13, %r3, 65535;
    max.s32 %r26, %r13, %r7;
    shl.b32 %r27, %r7, 16;
    or.b32 %r22, %r20, 2;
    setp.le.s32 %p1, %r26, 256;
    xor.b32 %r4, %r20, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
