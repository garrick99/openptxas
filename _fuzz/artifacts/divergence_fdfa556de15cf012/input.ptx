.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r19, %r3, 7;
    min.u32 %r10, %r19, %r19;
    min.u32 %r16, %r10, 0;
    min.s32 %r4, %r16, %r3;
    sub.u32 %r25, %r3, %r3;
    cvt.s64.s32 %rd5, %r4;
    min.u32 %r16, %r16, %r16;
    setp.gt.s32 %p1, %r4, 8;
    @%p1 min.u32 %r9, %r25, %r10;
    sub.s64 %rd13, %rd5, %rd5;
    cvt.s32.s64 %r7, %rd5;
    setp.ne.s32 %p2, %r16, 65535;
    or.b32 %r13, %r25, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
