.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    mul.lo.s32 %r12, %r3, 64;
    min.u32 %r8, %r3, 15;
    shl.b32 %r12, %r12, 1;
    shr.s64 %rd8, %rd9, 33;
    mul.lo.s32 %r19, %r12, %r3;
    cvt.u64.u32 %rd5, %r19;
    and.b32 %r15, %r3, %r8;
    mul.lo.s32 %r15, %r12, 2147483648;
    setp.ge.u32 %p1, %r19, 2147483647;
    @%p1 selp.b32 %r24, %r15, %r12, %p1;
    min.u32 %r16, %r24, 16;
    and.b32 %r6, %r19, %r8;
    min.u64 %rd8, %rd9, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
