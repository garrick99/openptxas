.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    or.b32 %r23, %r3, %r3;
    or.b32 %r9, %r23, %r3;
    shl.b64 %rd13, %rd15, 33;
    sub.u64 %rd15, %rd13, %rd15;
    min.u64 %rd14, %rd13, %rd13;
    cvt.u32.u64 %r6, %rd14;
    add.s32 %r11, %r3, %r23;
    shr.u64 %rd9, %rd15, 31;
    setp.ne.u32 %p3, %r11, 7;
    @%p3 cvt.s32.s64 %r4, %rd9;
    min.s64 %rd8, %rd13, %rd9;
    setp.gt.s32 %p2, %r6, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
