.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p3, %r3, 3;
    @!%p3 cvt.u64.u32 %rd15, %r3;
    min.u32 %r27, %r3, 65535;
    shr.s32 %r25, %r3, 3;
    sub.u32 %r21, %r27, %r3;
    mad.lo.u32 %r15, %r3, %r21, %r21;
    shr.u32 %r26, %r27, 0;
    sub.s32 %r14, %r26, 2;
    mad.lo.s32 %r16, %r27, %r27, %r15;
    add.u32 %r13, %r3, %r16;
    setp.ge.s32 %p3, %r13, 4;
    @%p3 mad.lo.s32 %r24, %r15, %r16, %r16;
    min.u64 %rd6, %rd15, %rd15;
    cvt.s32.s64 %r18, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
