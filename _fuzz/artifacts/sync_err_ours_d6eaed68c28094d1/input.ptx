.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r9, %r3, 31;
    sub.u32 %r20, %r3, %r9;
    max.u32 %r4, %r20, 8;
    mul.wide.s32 %rd14, %r4, %r20;
    setp.ne.u32 %p3, %r3, 5;
    @%p3 max.u32 %r12, %r4, 8;
    mul.wide.s32 %rd8, %r3, %r3;
    mul.lo.s64 %rd8, %rd8, %rd14;
    min.u32 %r5, %r20, 31;
    setp.lt.u32 %p1, %r9, %r3;
    @!%p1 cvt.u64.u32 %rd9, %r9;
    mul.wide.s32 %rd7, %r12, %r4;
    mul.lo.s32 %r13, %r4, 4;
    sub.u64 %rd13, %rd8, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
