.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r18, %r3, 64;
    setp.ge.u32 %p4, %r3, %r3;
    @%p4 selp.b32 %r6, %r18, %r3, %p4;
    shr.s32 %r16, %r6, 15;
    max.s32 %r4, %r18, %r18;
    cvt.s64.s32 %rd11, %r3;
    shr.u32 %r13, %r18, 30;
    max.s32 %r27, %r16, 4294967295;
    mul.lo.u32 %r19, %r18, 4;
    sub.s32 %r17, %r6, 65535;
    or.b32 %r12, %r4, %r16;
    min.s32 %r13, %r4, %r17;
    sub.u32 %r4, %r27, 32;
    and.b64 %rd13, %rd11, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
