.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r20, %r3, 256;
    shr.s32 %r18, %r20, 0;
    cvt.u64.u32 %rd13, %r18;
    min.u32 %r4, %r3, 31;
    min.u32 %r23, %r20, %r4;
    setp.eq.s32 %p4, %r18, 1;
    @!%p4 mul.lo.s32 %r6, %r20, %r3;
    cvt.u64.u32 %rd9, %r3;
    max.s32 %r19, %r6, 7;
    add.u32 %r10, %r20, 63;
    max.s32 %r15, %r4, 31;
    mad.lo.u32 %r8, %r23, %r23, %r20;
    add.u32 %r14, %r19, %r3;
    add.s32 %r22, %r8, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
