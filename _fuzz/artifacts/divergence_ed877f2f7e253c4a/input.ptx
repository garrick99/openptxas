.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    mul.lo.s32 %r9, %r3, %r3;
    add.s32 %r8, %r3, %r9;
    sub.u64 %rd11, %rd13, %rd13;
    and.b32 %r12, %r8, %r9;
    add.u32 %r9, %r12, %r12;
    add.u32 %r27, %r12, 5;
    min.s32 %r18, %r12, 7;
    mul.lo.s64 %rd9, %rd11, %rd11;
    setp.ls.u32 %p1, %r18, %r18;
    mul.wide.u32 %rd14, %r27, %r9;
    shr.u32 %r4, %r12, 31;
    and.b32 %r6, %r27, 65535;
    setp.gt.s32 %p2, %r12, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
