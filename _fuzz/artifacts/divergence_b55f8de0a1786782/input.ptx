.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r14, %r3, %r3, %r3;
    setp.ge.s32 %p1, %r3, 63;
    @%p1 cvt.u64.u32 %rd8, %r14;
    max.u64 %rd7, %rd8, %rd8;
    shr.s64 %rd5, %rd7, 62;
    setp.ne.s32 %p1, %r3, 0;
    add.u32 %r24, %r14, 0;
    mul.lo.s32 %r21, %r14, %r3;
    setp.hi.u32 %p4, %r21, 32;
    @%p4 cvt.u32.u64 %r11, %rd7;
    add.u32 %r12, %r24, %r21;
    xor.b32 %r15, %r11, %r11;
    mul.wide.u32 %rd10, %r21, %r11;
    cvt.s32.s64 %r20, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
