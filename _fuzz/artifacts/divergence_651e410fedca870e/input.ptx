.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r22, %r3, %r3;
    mad.lo.s32 %r14, %r22, %r3, %r3;
    setp.gt.s32 %p1, %r22, %r3;
    min.u32 %r24, %r3, %r22;
    sub.u32 %r17, %r22, %r22;
    cvt.s64.s32 %rd9, %r17;
    setp.eq.u32 %p3, %r3, %r22;
    @%p3 or.b32 %r11, %r22, %r17;
    mul.lo.u32 %r17, %r14, 7;
    cvt.u64.u32 %rd11, %r24;
    shr.u32 %r23, %r17, 31;
    cvt.u64.u32 %rd13, %r11;
    mad.lo.s32 %r5, %r23, %r11, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
