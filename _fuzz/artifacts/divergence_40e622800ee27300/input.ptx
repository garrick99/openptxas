.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r6, %r3, %r3, %r3;
    min.u32 %r18, %r3, 4294967295;
    setp.le.u32 %p3, %r3, 255;
    @%p3 cvt.s64.s32 %rd15, %r18;
    max.u32 %r13, %r18, 64;
    setp.lt.u32 %p3, %r6, %r6;
    cvt.s32.s64 %r13, %rd15;
    shr.u64 %rd7, %rd15, 2;
    mad.lo.u32 %r15, %r3, %r18, %r3;
    cvt.s32.s64 %r6, %rd15;
    min.u32 %r19, %r6, %r13;
    setp.le.u32 %p3, %r13, 65535;
    mul.lo.s32 %r19, %r6, 2;
    mul.lo.u32 %r10, %r13, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
