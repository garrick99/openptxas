.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    setp.eq.u32 %p3, %r3, %r3;
    mul.lo.s32 %r4, %r3, %r3;
    cvt.s32.s64 %r13, %rd13;
    shl.b32 %r18, %r13, 3;
    shr.u64 %rd10, %rd13, 30;
    shr.u32 %r7, %r4, 7;
    shr.s64 %rd14, %rd10, 3;
    mul.wide.s32 %rd8, %r3, %r18;
    or.b64 %rd7, %rd14, %rd10;
    min.s64 %rd6, %rd10, %rd14;
    selp.b32 %r16, %r4, %r7, %p3;
    setp.eq.s32 %p3, %r4, 1;
    setp.hs.u32 %p3, %r18, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
