.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r13, %r3, %r3;
    mul.wide.u32 %rd5, %r3, %r3;
    setp.ge.s32 %p1, %r13, 4;
    shr.s32 %r7, %r13, 4;
    setp.eq.s32 %p3, %r7, 3;
    selp.b32 %r20, %r3, %r7, %p3;
    cvt.s32.s64 %r9, %rd5;
    min.u32 %r19, %r7, 256;
    mul.lo.s32 %r19, %r20, 16;
    max.u32 %r5, %r9, %r3;
    shl.b64 %rd9, %rd5, 16;
    cvt.s32.s64 %r7, %rd9;
    add.u32 %r11, %r3, %r5;
    selp.b32 %r21, %r7, %r5, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
