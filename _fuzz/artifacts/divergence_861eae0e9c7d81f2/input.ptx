.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd14, %r3, %r3;
    setp.ls.u32 %p4, %r3, %r3;
    setp.lt.u32 %p4, %r3, %r3;
    @%p4 mul.lo.u32 %r26, %r3, 1;
    add.u64 %rd6, %rd14, %rd14;
    sub.u32 %r23, %r3, %r3;
    add.s32 %r22, %r3, %r23;
    setp.gt.s32 %p1, %r22, 1;
    mul.lo.u32 %r15, %r23, 4294967295;
    setp.lo.u32 %p1, %r23, %r26;
    @%p1 sub.u64 %rd10, %rd6, %rd6;
    add.s32 %r14, %r26, 64;
    sub.u32 %r16, %r3, %r26;
    shr.s32 %r10, %r16, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
