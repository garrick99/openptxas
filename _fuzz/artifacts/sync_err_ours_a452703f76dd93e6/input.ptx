.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r22, %r3, 65536;
    and.b32 %r21, %r22, 8;
    mad.lo.u32 %r17, %r21, %r3, %r3;
    min.s32 %r25, %r22, %r22;
    xor.b32 %r20, %r25, 64;
    add.s32 %r24, %r22, %r22;
    add.s32 %r18, %r21, %r20;
    mad.lo.u32 %r21, %r24, %r17, %r20;
    add.s32 %r11, %r17, %r18;
    setp.eq.s32 %p4, %r21, %r17;
    add.u32 %r25, %r3, %r20;
    or.b32 %r21, %r18, 64;
    sub.u32 %r13, %r20, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
