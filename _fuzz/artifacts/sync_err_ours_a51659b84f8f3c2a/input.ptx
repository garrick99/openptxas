.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    max.u32 %r11, %r3, 1;
    shr.u32 %r6, %r11, 15;
    or.b32 %r21, %r11, 0;
    add.s32 %r13, %r6, %r21;
    mul.lo.u32 %r23, %r6, 4294967295;
    cvt.s32.s64 %r15, %rd11;
    setp.ne.u32 %p2, %r21, %r23;
    shl.b32 %r22, %r3, 1;
    mul.lo.s32 %r16, %r23, %r22;
    max.u32 %r8, %r11, %r15;
    xor.b32 %r5, %r13, 255;
    min.u32 %r4, %r13, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
