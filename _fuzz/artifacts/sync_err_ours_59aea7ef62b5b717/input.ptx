.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    mul.lo.s64 %rd14, %rd7, %rd7;
    mul.lo.s32 %r17, %r3, %r3;
    mad.lo.u32 %r11, %r3, %r3, %r17;
    shr.u32 %r21, %r11, 1;
    add.s32 %r11, %r11, 256;
    mul.lo.u32 %r24, %r3, %r11;
    min.s32 %r22, %r17, 3;
    max.s32 %r16, %r3, %r17;
    mul.wide.u32 %rd5, %r11, %r16;
    add.u32 %r12, %r17, %r21;
    add.s32 %r10, %r12, %r3;
    mad.lo.u32 %r10, %r22, %r17, %r22;
    mul.lo.s32 %r8, %r24, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
