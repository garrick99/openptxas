.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r4, %r3, 3;
    max.s32 %r24, %r4, 2147483647;
    max.u32 %r24, %r24, 32;
    cvt.u64.u32 %rd6, %r24;
    mul.lo.s32 %r27, %r3, %r3;
    shl.b32 %r15, %r4, 16;
    cvt.u32.u64 %r17, %rd6;
    or.b32 %r20, %r15, %r17;
    shr.u32 %r27, %r17, 15;
    cvt.s32.s64 %r16, %rd6;
    min.u32 %r16, %r17, %r24;
    min.u32 %r22, %r20, 255;
    and.b32 %r8, %r17, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
