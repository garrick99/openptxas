.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r20, %r3, %r3, %r3;
    max.u32 %r14, %r20, 15;
    and.b32 %r16, %r3, %r3;
    cvt.u64.u32 %rd12, %r14;
    and.b32 %r23, %r14, 256;
    shr.s32 %r25, %r20, 1;
    shl.b64 %rd8, %rd12, 30;
    cvt.u32.u64 %r25, %rd8;
    or.b64 %rd9, %rd8, %rd12;
    mad.lo.s32 %r11, %r20, %r23, %r23;
    or.b32 %r6, %r20, 3;
    mul.lo.u64 %rd13, %rd8, %rd8;
    min.s32 %r13, %r14, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
