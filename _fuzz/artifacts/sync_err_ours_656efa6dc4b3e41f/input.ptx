.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    max.s32 %r20, %r3, 16;
    sub.u32 %r5, %r3, %r20;
    shr.u32 %r17, %r3, 30;
    and.b32 %r17, %r5, %r5;
    shl.b32 %r24, %r3, 2;
    setp.le.u32 %p3, %r3, %r17;
    add.u32 %r14, %r24, 5;
    shl.b64 %rd13, %rd7, 1;
    add.u32 %r7, %r24, %r5;
    max.s32 %r22, %r17, %r5;
    shr.u32 %r7, %r5, 30;
    add.s32 %r26, %r14, %r24;
    cvt.u32.u64 %r19, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
