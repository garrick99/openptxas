.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r7, %r3, 0;
    setp.le.s32 %p4, %r7, %r7;
    or.b32 %r21, %r3, %r3;
    min.u32 %r5, %r3, %r7;
    mul.lo.s32 %r6, %r5, 31;
    add.s32 %r4, %r3, %r3;
    cvt.s64.s32 %rd15, %r5;
    shr.u64 %rd5, %rd15, 32;
    selp.b32 %r8, %r4, %r7, %p4;
    shr.u32 %r6, %r7, 15;
    or.b32 %r13, %r4, %r5;
    shr.u32 %r18, %r7, 30;
    mul.wide.s32 %rd9, %r3, %r4;
    and.b32 %r14, %r13, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
