.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    add.u64 %rd15, %rd9, %rd9;
    max.u64 %rd9, %rd9, %rd15;
    max.s32 %r14, %r3, %r3;
    setp.gt.s32 %p4, %r14, 16;
    add.u32 %r12, %r14, %r14;
    shl.b32 %r7, %r14, 4;
    shr.u32 %r25, %r12, 3;
    selp.b32 %r20, %r14, %r14, %p4;
    min.s32 %r11, %r12, 65535;
    xor.b32 %r18, %r12, %r25;
    max.u64 %rd7, %rd15, %rd9;
    add.u32 %r22, %r11, %r3;
    sub.s32 %r26, %r7, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
