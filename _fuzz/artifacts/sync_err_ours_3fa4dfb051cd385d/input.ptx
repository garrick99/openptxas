.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r6, %r3, %r3;
    mul.lo.s32 %r22, %r6, 31;
    sub.s32 %r7, %r3, %r6;
    shl.b32 %r8, %r6, 4;
    cvt.s64.s32 %rd14, %r22;
    xor.b32 %r10, %r8, %r8;
    cvt.s32.s64 %r15, %rd14;
    mul.lo.s32 %r20, %r10, %r7;
    cvt.u32.u64 %r24, %rd14;
    min.u32 %r22, %r7, %r20;
    min.s32 %r10, %r10, 256;
    max.s32 %r25, %r6, %r6;
    max.u32 %r14, %r22, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
