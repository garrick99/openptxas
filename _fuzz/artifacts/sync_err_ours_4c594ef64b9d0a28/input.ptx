.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    shl.b32 %r17, %r3, 15;
    max.s32 %r6, %r3, %r3;
    sub.u32 %r15, %r6, 32;
    shr.u32 %r15, %r3, 0;
    shl.b32 %r7, %r15, 4;
    setp.hi.u32 %p1, %r7, 255;
    cvt.s64.s32 %rd8, %r3;
    cvt.s64.s32 %rd13, %r15;
    mad.lo.u32 %r20, %r7, %r6, %r3;
    shr.s32 %r26, %r20, 30;
    shr.s32 %r26, %r20, 4;
    mul.lo.u64 %rd12, %rd11, %rd8;
    shl.b64 %rd8, %rd11, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
