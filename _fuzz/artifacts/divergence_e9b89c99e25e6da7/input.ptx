.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p4, %r3, 32;
    @%p4 shr.s32 %r19, %r3, 4;
    mul.lo.u32 %r12, %r3, %r19;
    mad.lo.s32 %r23, %r12, %r19, %r12;
    xor.b32 %r22, %r3, %r19;
    min.s32 %r4, %r22, %r3;
    shr.s32 %r25, %r23, 16;
    setp.lt.s32 %p3, %r4, %r23;
    @%p3 mul.lo.u32 %r13, %r12, %r23;
    cvt.u64.u32 %rd8, %r23;
    mul.lo.s32 %r19, %r13, 1;
    add.u32 %r5, %r13, 31;
    add.s32 %r5, %r25, 256;
    add.s32 %r21, %r5, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
