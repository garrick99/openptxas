.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    mul.lo.s32 %r17, %r3, 3;
    and.b32 %r27, %r3, %r17;
    cvt.s32.s64 %r4, %rd7;
    cvt.u64.u32 %rd5, %r4;
    mul.lo.s32 %r25, %r17, 64;
    setp.ls.u32 %p1, %r17, 256;
    max.s32 %r24, %r4, %r17;
    shr.s64 %rd11, %rd7, 0;
    cvt.u64.u32 %rd9, %r4;
    shr.s64 %rd9, %rd9, 32;
    cvt.s64.s32 %rd12, %r3;
    selp.b32 %r5, %r25, %r3, %p1;
    or.b32 %r12, %r5, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
