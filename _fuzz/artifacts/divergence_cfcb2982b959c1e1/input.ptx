.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r18, %r3, 32;
    setp.ls.u32 %p3, %r18, 2;
    @%p3 shl.b32 %r11, %r3, 0;
    selp.b32 %r27, %r18, %r3, %p3;
    sub.u32 %r14, %r18, %r27;
    setp.eq.u32 %p3, %r11, 0;
    @!%p3 mul.lo.s32 %r11, %r14, 32;
    xor.b32 %r9, %r18, %r14;
    mad.lo.u32 %r4, %r11, %r3, %r3;
    cvt.u64.u32 %rd7, %r18;
    selp.b32 %r19, %r3, %r27, %p3;
    max.u32 %r10, %r3, %r9;
    setp.lt.u32 %p2, %r14, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
