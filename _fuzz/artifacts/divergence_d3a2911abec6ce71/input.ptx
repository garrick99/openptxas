.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r20, %r3, 4294967295;
    mul.wide.s32 %rd15, %r3, %r20;
    mad.lo.u32 %r19, %r3, %r20, %r3;
    mad.lo.s32 %r5, %r3, %r3, %r3;
    mul.wide.u32 %rd6, %r20, %r5;
    shr.s64 %rd15, %rd6, 2;
    xor.b32 %r17, %r3, %r5;
    max.s32 %r14, %r17, 15;
    max.u32 %r8, %r14, %r5;
    mul.wide.u32 %rd9, %r19, %r19;
    add.s32 %r18, %r20, %r8;
    max.s32 %r4, %r3, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
