.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r4, %r3, %r3, %r3;
    setp.eq.u32 %p2, %r4, 4;
    @!%p2 mul.wide.s32 %rd14, %r3, %r4;
    sub.u32 %r27, %r4, 65535;
    mul.lo.s32 %r19, %r27, 16;
    add.u32 %r25, %r27, %r3;
    setp.hs.u32 %p3, %r27, %r4;
    @!%p3 cvt.s32.s64 %r15, %rd14;
    min.s64 %rd6, %rd14, %rd14;
    shl.b32 %r20, %r25, 15;
    shl.b32 %r26, %r15, 1;
    max.s32 %r19, %r3, %r19;
    add.s32 %r4, %r15, %r27;
    add.s32 %r15, %r15, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
