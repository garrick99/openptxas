.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r14, %r3, 30;
    max.s32 %r27, %r14, 4294967295;
    add.s32 %r8, %r3, 65535;
    sub.u32 %r25, %r14, %r27;
    xor.b32 %r9, %r3, %r14;
    add.u32 %r24, %r8, 2147483648;
    sub.u32 %r6, %r24, %r14;
    xor.b32 %r14, %r3, 2;
    cvt.u64.u32 %rd5, %r14;
    mul.wide.u32 %rd11, %r24, %r3;
    mad.lo.u32 %r21, %r6, %r24, %r14;
    max.s32 %r7, %r6, %r14;
    mad.lo.s32 %r11, %r14, %r25, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
