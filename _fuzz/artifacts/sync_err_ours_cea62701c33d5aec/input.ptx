.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r16, %r3, %r3;
    mad.lo.u32 %r23, %r16, %r3, %r16;
    mul.wide.s32 %rd7, %r16, %r3;
    add.s32 %r11, %r23, 63;
    shr.u32 %r19, %r3, 7;
    sub.s32 %r20, %r11, %r23;
    mul.wide.u32 %rd6, %r3, %r3;
    min.s64 %rd14, %rd6, %rd6;
    shl.b32 %r5, %r19, 7;
    shr.u64 %rd11, %rd7, 7;
    shr.s64 %rd9, %rd11, 30;
    mul.wide.u32 %rd8, %r16, %r19;
    setp.ge.s32 %p1, %r20, 32;
    mad.lo.s32 %r4, %r20, %r11, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
