.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r25, %r3, 3;
    min.u32 %r14, %r3, 256;
    mul.lo.s32 %r18, %r3, %r25;
    sub.s32 %r5, %r18, 65536;
    max.s32 %r5, %r5, %r14;
    setp.ge.s32 %p4, %r5, 255;
    max.s32 %r18, %r25, %r14;
    sub.u32 %r5, %r3, 31;
    add.u32 %r4, %r14, %r5;
    mul.wide.s32 %rd15, %r14, %r18;
    cvt.s64.s32 %rd8, %r25;
    cvt.u64.u32 %rd7, %r18;
    min.u32 %r16, %r3, %r3;
    max.u32 %r11, %r3, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
