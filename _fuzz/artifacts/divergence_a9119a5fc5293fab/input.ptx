.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r21, %r3, 2;
    setp.hs.u32 %p4, %r3, 65535;
    @%p4 max.u32 %r26, %r3, %r3;
    shr.u32 %r4, %r3, 3;
    shr.s32 %r15, %r4, 7;
    cvt.u64.u32 %rd6, %r26;
    cvt.u64.u32 %rd11, %r26;
    cvt.u32.u64 %r23, %rd11;
    max.u32 %r5, %r3, 3;
    setp.hi.u32 %p3, %r21, 16;
    or.b32 %r8, %r23, 3;
    cvt.u32.u64 %r26, %rd6;
    setp.ne.u32 %p3, %r15, 65535;
    @!%p3 cvt.u32.u64 %r6, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
