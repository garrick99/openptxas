.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r24, %r3, %r3;
    shr.u32 %r10, %r24, 31;
    mul.wide.u32 %rd13, %r10, %r10;
    sub.s32 %r5, %r24, 5;
    cvt.u32.u64 %r4, %rd13;
    or.b64 %rd12, %rd13, %rd13;
    and.b32 %r19, %r4, %r3;
    xor.b32 %r17, %r5, %r24;
    min.u32 %r14, %r19, 3;
    shr.s64 %rd9, %rd12, 63;
    mad.lo.s32 %r26, %r14, %r3, %r17;
    or.b32 %r16, %r14, 4294967295;
    mul.wide.s32 %rd11, %r5, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
