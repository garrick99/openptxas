.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r24, %r3, %r3;
    min.s32 %r4, %r24, 16;
    sub.u32 %r8, %r3, %r24;
    cvt.s64.s32 %rd15, %r4;
    shr.u32 %r16, %r4, 1;
    shr.s64 %rd12, %rd15, 7;
    mul.lo.s32 %r27, %r3, 7;
    setp.ls.u32 %p2, %r8, %r16;
    setp.hs.u32 %p3, %r24, %r3;
    @%p3 sub.s64 %rd10, %rd12, %rd15;
    add.u64 %rd14, %rd15, %rd10;
    selp.b32 %r17, %r3, %r3, %p2;
    shr.s32 %r21, %r8, 7;
    mul.lo.u32 %r14, %r17, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
