.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r6, %r3, 3;
    mul.wide.u32 %rd7, %r3, %r3;
    cvt.u64.u32 %rd13, %r6;
    setp.ge.s32 %p4, %r6, 5;
    @%p4 add.u64 %rd12, %rd13, %rd13;
    min.s32 %r16, %r6, 1;
    max.u32 %r17, %r16, 5;
    cvt.s32.s64 %r26, %rd13;
    sub.u32 %r10, %r3, %r3;
    shr.s32 %r25, %r6, 15;
    min.s64 %rd10, %rd12, %rd7;
    shr.u32 %r18, %r3, 2;
    cvt.u32.u64 %r21, %rd12;
    shl.b64 %rd15, %rd7, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
