.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r23, %r3, 32;
    setp.hs.u32 %p4, %r23, %r23;
    @!%p4 selp.b32 %r4, %r23, %r23, %p4;
    shr.s32 %r21, %r23, 1;
    sub.u32 %r11, %r21, %r3;
    min.u32 %r15, %r21, 4294967295;
    cvt.u64.u32 %rd14, %r23;
    mad.lo.u32 %r6, %r21, %r23, %r15;
    selp.b32 %r27, %r23, %r23, %p4;
    shr.s64 %rd7, %rd14, 62;
    mul.wide.u32 %rd12, %r3, %r6;
    shr.u32 %r5, %r11, 31;
    mad.lo.u32 %r11, %r15, %r5, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
