.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r13, %r3, %r3;
    shr.s32 %r19, %r13, 2;
    min.u32 %r22, %r3, %r3;
    sub.u32 %r17, %r3, 8;
    setp.le.s32 %p4, %r17, %r17;
    @%p4 shr.u32 %r24, %r3, 2;
    add.s32 %r25, %r19, 1;
    xor.b32 %r19, %r24, 64;
    cvt.u64.u32 %rd15, %r25;
    setp.lt.u32 %p4, %r19, %r24;
    @!%p4 mad.lo.s32 %r9, %r17, %r3, %r13;
    min.s32 %r23, %r25, %r19;
    setp.lt.s32 %p1, %r17, 16;
    @!%p1 min.u32 %r7, %r9, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
