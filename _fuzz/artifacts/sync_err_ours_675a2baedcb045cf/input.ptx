.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r9, %r3, %r3;
    cvt.u64.u32 %rd7, %r3;
    mul.wide.s32 %rd14, %r3, %r9;
    shr.u64 %rd13, %rd7, 4;
    setp.eq.s32 %p2, %r9, 2;
    @%p2 selp.b32 %r27, %r3, %r3, %p2;
    mul.lo.u32 %r17, %r9, 64;
    xor.b32 %r5, %r27, %r9;
    add.u32 %r7, %r3, %r3;
    add.u32 %r6, %r17, %r27;
    shr.s64 %rd10, %rd7, 47;
    sub.s32 %r20, %r6, 16;
    or.b32 %r13, %r17, %r6;
    max.s32 %r27, %r20, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
