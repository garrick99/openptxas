.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r7, %r3, %r3, %r3;
    cvt.u64.u32 %rd13, %r3;
    xor.b32 %r4, %r3, %r3;
    shr.s64 %rd9, %rd13, 31;
    shr.u32 %r7, %r7, 0;
    max.s32 %r19, %r7, 63;
    shl.b32 %r14, %r4, 1;
    cvt.s32.s64 %r17, %rd13;
    shl.b32 %r27, %r7, 30;
    mul.lo.u32 %r7, %r27, 4294967295;
    or.b32 %r8, %r19, %r3;
    shl.b32 %r25, %r27, 30;
    and.b32 %r21, %r4, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
