.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r14, %r3, %r3, %r3;
    xor.b32 %r6, %r14, %r3;
    cvt.u64.u32 %rd13, %r3;
    cvt.s32.s64 %r10, %rd13;
    mad.lo.u32 %r16, %r10, %r14, %r10;
    shl.b64 %rd7, %rd13, 47;
    mad.lo.s32 %r25, %r6, %r3, %r3;
    and.b32 %r16, %r14, 255;
    sub.s32 %r14, %r16, %r16;
    setp.hi.u32 %p1, %r25, %r25;
    @!%p1 cvt.u32.u64 %r7, %rd7;
    shr.s32 %r26, %r6, 3;
    cvt.s32.s64 %r25, %rd13;
    shr.u32 %r16, %r7, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
