.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p4, %r3, 3;
    @%p4 and.b32 %r9, %r3, 65535;
    add.s32 %r25, %r3, 64;
    sub.u32 %r5, %r9, %r9;
    shr.s32 %r14, %r3, 7;
    mul.lo.u32 %r20, %r25, %r25;
    mul.wide.u32 %rd8, %r3, %r3;
    shl.b32 %r8, %r14, 7;
    or.b32 %r20, %r3, %r14;
    max.s32 %r13, %r20, 65536;
    shl.b64 %rd11, %rd8, 1;
    mul.lo.s32 %r21, %r20, 32;
    setp.lo.u32 %p3, %r21, 31;
    @%p3 min.s32 %r18, %r25, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
