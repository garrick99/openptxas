    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r18, %r3, 1;
    mul.lo.s32 %r10, %r3, %r3;
    add.u32 %r6, %r10, %r10;
    setp.ge.u32 %p4, %r6, %r18;
    @%p4 sub.u32 %r13, %r6, %r18;
    shl.b32 %r16, %r13, 0;
    cvt.s64.s32 %rd12, %r3;
    add.u32 %r22, %r6, %r13;
    setp.eq.u32 %p1, %r10, %r18;
    @%p1 mad.lo.u32 %r17, %r6, %r22, %r10;
    add.s32 %r21, %r22, %r18;
    setp.ls.u32 %p2, %r21, 2147483648;
    @%p2 add.u64 %rd9, %rd12, %rd12;
    mul.wide.u32 %rd11, %r21, %r6;
