.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r10, %r3, 15;
    shr.s32 %r15, %r3, 31;
    setp.ne.s32 %p3, %r10, 255;
    setp.lo.u32 %p3, %r15, %r3;
    @!%p3 cvt.u64.u32 %rd12, %r10;
    add.u64 %rd6, %rd12, %rd12;
    add.s32 %r21, %r10, 8;
    xor.b32 %r15, %r15, %r3;
    cvt.u32.u64 %r6, %rd12;
    cvt.s64.s32 %rd9, %r15;
    sub.s32 %r26, %r10, %r10;
    setp.gt.s32 %p2, %r3, 31;
    @!%p2 and.b32 %r4, %r26, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
