.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r7, %r3, %r3, %r3;
    mad.lo.u32 %r13, %r7, %r3, %r3;
    cvt.s64.s32 %rd8, %r7;
    max.u32 %r22, %r7, 4;
    cvt.u64.u32 %rd5, %r7;
    shr.u64 %rd12, %rd5, 7;
    sub.s64 %rd8, %rd12, %rd12;
    shr.u32 %r25, %r22, 3;
    max.u32 %r24, %r3, 32;
    add.s32 %r27, %r22, 63;
    cvt.u64.u32 %rd13, %r25;
    setp.gt.u32 %p4, %r27, %r25;
    @%p4 add.s32 %r18, %r24, %r22;
    min.s32 %r16, %r18, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
