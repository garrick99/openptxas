.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    shl.b64 %rd14, %rd13, 7;
    min.s32 %r24, %r3, 4;
    shr.s64 %rd10, %rd14, 33;
    shr.u32 %r15, %r3, 15;
    shr.s32 %r4, %r15, 1;
    or.b32 %r14, %r4, %r3;
    shr.u32 %r14, %r4, 3;
    xor.b32 %r11, %r14, %r24;
    max.u32 %r17, %r24, 32;
    add.u32 %r14, %r3, 31;
    cvt.u64.u32 %rd14, %r14;
    mul.lo.s32 %r6, %r14, %r17;
    mul.wide.u32 %rd8, %r11, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
