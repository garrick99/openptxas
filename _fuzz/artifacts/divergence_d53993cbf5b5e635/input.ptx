.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r4, %r3, 5;
    mul.wide.u32 %rd12, %r4, %r4;
    mul.lo.s32 %r18, %r3, %r4;
    min.s64 %rd7, %rd12, %rd12;
    min.u32 %r6, %r4, %r18;
    add.s64 %rd11, %rd7, %rd7;
    min.u32 %r8, %r3, 5;
    mul.wide.u32 %rd13, %r6, %r6;
    sub.u32 %r14, %r18, %r8;
    cvt.s64.s32 %rd7, %r3;
    setp.eq.u32 %p2, %r18, %r4;
    @%p2 add.u32 %r17, %r8, 1;
    shl.b64 %rd14, %rd7, 7;
    mul.wide.u32 %rd6, %r8, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
