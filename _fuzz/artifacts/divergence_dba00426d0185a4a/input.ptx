.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    min.u32 %r6, %r3, 15;
    mad.lo.u32 %r15, %r6, %r3, %r3;
    mul.lo.s32 %r6, %r6, 15;
    add.s32 %r13, %r15, %r3;
    or.b32 %r14, %r3, %r15;
    xor.b64 %rd11, %rd11, %rd11;
    and.b32 %r7, %r6, 16;
    max.s32 %r24, %r15, 2147483647;
    add.s64 %rd13, %rd11, %rd11;
    mul.lo.s32 %r12, %r24, 2147483648;
    and.b32 %r16, %r14, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
