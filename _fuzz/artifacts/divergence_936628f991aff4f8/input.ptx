.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r7, %r3, %r3;
    cvt.s64.s32 %rd5, %r3;
    mul.lo.u32 %r21, %r3, %r7;
    xor.b32 %r22, %r21, %r3;
    shl.b32 %r6, %r7, 30;
    xor.b64 %rd15, %rd5, %rd5;
    min.s32 %r24, %r22, 4;
    add.s32 %r20, %r6, 255;
    sub.s32 %r15, %r7, 4294967295;
    add.s64 %rd11, %rd15, %rd15;
    mul.lo.u32 %r8, %r20, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
