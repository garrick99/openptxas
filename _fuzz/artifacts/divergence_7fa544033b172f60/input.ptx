.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r10, %r3, %r3;
    setp.ge.s32 %p2, %r10, 3;
    @%p2 min.u32 %r13, %r3, %r3;
    cvt.u64.u32 %rd5, %r13;
    max.s32 %r23, %r10, 8;
    cvt.s32.s64 %r19, %rd5;
    cvt.s32.s64 %r13, %rd5;
    mul.lo.u32 %r6, %r3, %r10;
    selp.b32 %r27, %r19, %r6, %p2;
    setp.hi.u32 %p2, %r27, 65536;
    @!%p2 shr.s32 %r9, %r27, 15;
    selp.b32 %r15, %r9, %r9, %p2;
    shr.u32 %r11, %r9, 7;
    max.u32 %r25, %r19, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
