.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r17, %r3, 255;
    setp.hs.u32 %p4, %r3, %r17;
    xor.b32 %r24, %r17, 1;
    mul.wide.s32 %rd12, %r17, %r17;
    setp.gt.u32 %p3, %r24, %r17;
    @%p3 and.b32 %r10, %r3, 7;
    and.b32 %r21, %r3, 32;
    cvt.u64.u32 %rd15, %r10;
    sub.s32 %r21, %r17, %r24;
    add.u32 %r11, %r24, %r21;
    setp.lt.s32 %p1, %r24, 7;
    @%p1 sub.u32 %r23, %r3, %r11;
    cvt.s32.s64 %r7, %rd15;
    cvt.s64.s32 %rd11, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
