.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r11, %r3, %r3;
    max.u32 %r13, %r3, %r11;
    mul.wide.s32 %rd14, %r13, %r3;
    cvt.s64.s32 %rd7, %r13;
    min.u64 %rd8, %rd7, %rd14;
    setp.gt.s32 %p2, %r11, %r11;
    @%p2 cvt.u64.u32 %rd13, %r13;
    mul.lo.s32 %r27, %r3, %r13;
    min.u32 %r23, %r27, %r3;
    add.s32 %r22, %r27, %r13;
    xor.b32 %r11, %r23, 5;
    max.s64 %rd6, %rd14, %rd7;
    mad.lo.s32 %r9, %r11, %r23, %r11;
    sub.s64 %rd6, %rd14, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
