.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r4, %r3, %r3;
    add.u32 %r21, %r4, 63;
    and.b32 %r13, %r21, 1;
    xor.b32 %r18, %r13, %r21;
    mul.wide.s32 %rd9, %r13, %r4;
    shl.b32 %r19, %r3, 1;
    setp.hi.u32 %p4, %r19, 7;
    @%p4 xor.b32 %r7, %r4, %r18;
    or.b32 %r8, %r19, %r19;
    and.b32 %r27, %r7, %r19;
    mad.lo.u32 %r17, %r21, %r13, %r21;
    cvt.u32.u64 %r5, %rd9;
    shr.s32 %r26, %r18, 15;
    and.b32 %r20, %r13, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
