.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r22, %r3, 7;
    setp.ge.s32 %p4, %r22, %r3;
    cvt.s64.s32 %rd11, %r3;
    mul.lo.s32 %r21, %r22, 31;
    setp.lt.s32 %p2, %r21, 1;
    @%p2 mad.lo.s32 %r26, %r3, %r3, %r22;
    mul.lo.s32 %r10, %r26, %r3;
    mul.wide.u32 %rd10, %r21, %r10;
    add.u64 %rd10, %rd10, %rd11;
    mul.lo.s32 %r7, %r22, %r21;
    setp.ge.s32 %p1, %r21, 15;
    @%p1 and.b32 %r7, %r10, %r21;
    mad.lo.s32 %r17, %r26, %r3, %r22;
    cvt.s32.s64 %r15, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
