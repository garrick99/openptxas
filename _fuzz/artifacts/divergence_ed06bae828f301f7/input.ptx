.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r24, %r3, 4294967295;
    mul.lo.u32 %r24, %r24, 2;
    mul.lo.u32 %r13, %r24, 65536;
    cvt.u64.u32 %rd9, %r24;
    mul.wide.u32 %rd11, %r3, %r24;
    shr.u32 %r18, %r13, 30;
    mul.wide.u32 %rd11, %r3, %r13;
    mul.lo.s64 %rd12, %rd11, %rd9;
    mad.lo.u32 %r5, %r3, %r13, %r13;
    xor.b32 %r22, %r18, 1;
    mul.wide.s32 %rd13, %r22, %r5;
    shl.b32 %r17, %r13, 4;
    mul.wide.s32 %rd14, %r17, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
