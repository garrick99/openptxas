.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    shr.s32 %r14, %r3, 30;
    max.u32 %r17, %r3, 8;
    and.b32 %r15, %r3, 1;
    cvt.s64.s32 %rd12, %r14;
    shl.b32 %r25, %r14, 0;
    setp.ne.u32 %p2, %r3, 63;
    @%p2 cvt.s64.s32 %rd12, %r25;
    cvt.s32.s64 %r12, %rd8;
    shr.s32 %r23, %r12, 7;
    mul.wide.u32 %rd11, %r25, %r12;
    selp.b32 %r24, %r15, %r17, %p2;
    and.b32 %r16, %r12, %r17;
    setp.ge.u32 %p3, %r15, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
