.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r5, %r3, 3;
    shr.s32 %r24, %r3, 4;
    shl.b32 %r14, %r5, 31;
    cvt.u64.u32 %rd9, %r14;
    shr.s32 %r6, %r3, 31;
    setp.ls.u32 %p3, %r6, %r24;
    @%p3 sub.s32 %r4, %r24, %r6;
    min.u32 %r21, %r4, 256;
    and.b64 %rd15, %rd9, %rd9;
    max.u32 %r17, %r3, 3;
    shl.b32 %r17, %r4, 0;
    setp.eq.u32 %p2, %r17, %r21;
    @%p2 or.b32 %r21, %r17, 65536;
    mul.lo.u32 %r6, %r3, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
