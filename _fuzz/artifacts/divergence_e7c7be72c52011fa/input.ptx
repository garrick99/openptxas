.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r5, %r3, 16;
    sub.s32 %r6, %r5, %r3;
    shr.s32 %r8, %r5, 7;
    xor.b32 %r8, %r6, 4;
    cvt.s64.s32 %rd9, %r8;
    cvt.s32.s64 %r18, %rd9;
    setp.ne.u32 %p1, %r8, 0;
    @%p1 selp.b32 %r13, %r3, %r6, %p1;
    shr.u32 %r14, %r6, 15;
    cvt.u64.u32 %rd5, %r6;
    max.s32 %r13, %r3, 15;
    shr.s32 %r27, %r18, 3;
    mad.lo.s32 %r19, %r13, %r8, %r3;
    cvt.s64.s32 %rd7, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
