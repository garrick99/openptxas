.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r5, %r3, %r3;
    mul.lo.s32 %r17, %r5, %r3;
    setp.le.u32 %p2, %r5, 5;
    mul.wide.u32 %rd14, %r5, %r3;
    shl.b64 %rd9, %rd14, 0;
    mul.wide.u32 %rd8, %r3, %r3;
    sub.u64 %rd10, %rd14, %rd9;
    max.s32 %r7, %r3, 255;
    min.u32 %r8, %r17, %r3;
    selp.b32 %r26, %r7, %r7, %p2;
    selp.b32 %r13, %r17, %r26, %p2;
    add.u32 %r6, %r13, %r26;
    xor.b32 %r19, %r26, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
