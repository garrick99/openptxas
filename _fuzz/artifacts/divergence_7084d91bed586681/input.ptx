.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r5, %r3, 4;
    sub.u32 %r17, %r5, %r3;
    sub.u32 %r5, %r3, 0;
    xor.b32 %r4, %r3, %r3;
    setp.lo.u32 %p1, %r5, %r17;
    @%p1 min.u32 %r27, %r4, %r5;
    mul.wide.s32 %rd5, %r5, %r27;
    max.u32 %r21, %r4, %r4;
    add.s32 %r24, %r3, %r5;
    cvt.u64.u32 %rd6, %r4;
    and.b32 %r23, %r27, %r24;
    cvt.u64.u32 %rd5, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
