.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    add.u64 %rd9, %rd7, %rd7;
    and.b32 %r26, %r3, 31;
    shl.b64 %rd15, %rd7, 0;
    add.u32 %r14, %r3, %r3;
    min.u32 %r15, %r26, %r14;
    min.u32 %r14, %r14, 1;
    min.u32 %r15, %r26, 256;
    mul.wide.s32 %rd14, %r15, %r26;
    mad.lo.s32 %r26, %r3, %r26, %r14;
    and.b32 %r7, %r14, %r15;
    sub.u32 %r9, %r15, 63;
    shr.s32 %r8, %r3, 1;
    sub.u32 %r20, %r26, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
