.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p4, %r3, 64;
    @%p4 cvt.s64.s32 %rd10, %r3;
    sub.s64 %rd5, %rd10, %rd10;
    min.s32 %r4, %r3, 15;
    cvt.s32.s64 %r9, %rd10;
    mad.lo.u32 %r9, %r4, %r4, %r3;
    cvt.u64.u32 %rd7, %r9;
    shl.b32 %r8, %r4, 2;
    setp.ne.s32 %p2, %r8, 7;
    @%p2 shr.s64 %rd10, %rd7, 32;
    mad.lo.s32 %r10, %r3, %r4, %r4;
    sub.s32 %r21, %r3, %r9;
    cvt.s64.s32 %rd13, %r4;
    add.u32 %r18, %r3, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
