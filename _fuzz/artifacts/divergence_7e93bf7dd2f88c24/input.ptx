.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r21, %r3, 4;
    add.u32 %r24, %r3, 0;
    min.u32 %r14, %r24, %r3;
    setp.le.u32 %p4, %r3, 7;
    @%p4 add.s32 %r24, %r3, 64;
    mul.lo.s32 %r23, %r3, 65535;
    cvt.u64.u32 %rd11, %r23;
    add.s64 %rd11, %rd11, %rd11;
    xor.b32 %r11, %r23, 16;
    cvt.u32.u64 %r17, %rd11;
    shr.s32 %r7, %r21, 30;
    shr.u32 %r19, %r7, 30;
    add.s32 %r18, %r14, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
