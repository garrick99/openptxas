.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r20, %r3, 7;
    cvt.u64.u32 %rd7, %r20;
    min.u32 %r26, %r20, 5;
    mul.lo.s32 %r8, %r20, 255;
    max.s32 %r24, %r3, 3;
    max.u64 %rd12, %rd7, %rd7;
    min.s64 %rd9, %rd12, %rd7;
    setp.hi.u32 %p4, %r8, %r26;
    @!%p4 sub.u32 %r12, %r8, 2147483648;
    shl.b32 %r13, %r8, 16;
    mad.lo.u32 %r20, %r3, %r20, %r13;
    cvt.s32.s64 %r15, %rd9;
    shl.b64 %rd8, %rd12, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
