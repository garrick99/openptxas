.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r11, %r3, 7;
    setp.hi.u32 %p1, %r11, %r3;
    shr.s32 %r27, %r3, 15;
    shr.u32 %r26, %r3, 4;
    xor.b32 %r22, %r11, %r3;
    shl.b32 %r19, %r26, 7;
    mul.wide.s32 %rd11, %r26, %r11;
    shr.s32 %r10, %r22, 3;
    min.u32 %r24, %r11, %r11;
    mul.wide.u32 %rd15, %r26, %r24;
    mad.lo.u32 %r9, %r19, %r27, %r24;
    max.u32 %r21, %r3, %r24;
    setp.gt.s32 %p2, %r24, %r22;
    @!%p2 mul.lo.s32 %r18, %r9, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
