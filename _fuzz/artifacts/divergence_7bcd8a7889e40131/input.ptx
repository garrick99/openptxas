.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r20, %r3, %r3;
    mul.wide.s32 %rd9, %r20, %r3;
    add.u64 %rd7, %rd9, %rd9;
    max.u64 %rd7, %rd7, %rd9;
    shr.u64 %rd10, %rd7, 63;
    setp.hi.u32 %p1, %r3, 5;
    @%p1 mul.lo.s32 %r5, %r3, %r3;
    or.b32 %r20, %r5, %r3;
    setp.lt.u32 %p2, %r5, %r3;
    @%p2 mul.wide.s32 %rd12, %r3, %r5;
    shr.u32 %r12, %r5, 30;
    shr.u32 %r13, %r20, 1;
    mad.lo.s32 %r13, %r3, %r20, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
