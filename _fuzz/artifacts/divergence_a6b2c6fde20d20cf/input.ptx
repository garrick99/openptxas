.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r4, %r3, %r3;
    xor.b32 %r21, %r3, %r4;
    mad.lo.s32 %r26, %r21, %r3, %r4;
    cvt.s64.s32 %rd12, %r21;
    shl.b64 %rd6, %rd12, 33;
    and.b32 %r25, %r26, %r3;
    max.s32 %r18, %r4, 3;
    shr.u32 %r18, %r26, 2;
    max.s32 %r20, %r18, %r3;
    xor.b32 %r10, %r26, %r20;
    shr.s32 %r5, %r3, 3;
    mul.lo.u32 %r24, %r4, 1;
    min.s32 %r21, %r10, %r26;
    max.u32 %r7, %r5, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
