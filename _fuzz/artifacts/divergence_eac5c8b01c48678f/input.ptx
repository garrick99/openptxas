.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p4, %r3, %r3;
    mad.lo.s32 %r19, %r3, %r3, %r3;
    setp.ne.s32 %p4, %r3, %r3;
    @%p4 cvt.u64.u32 %rd11, %r19;
    and.b32 %r9, %r3, 32;
    xor.b32 %r13, %r3, 0;
    cvt.u64.u32 %rd15, %r9;
    shr.s32 %r16, %r3, 15;
    cvt.u64.u32 %rd15, %r9;
    cvt.s32.s64 %r17, %rd11;
    and.b64 %rd9, %rd15, %rd11;
    mul.lo.s32 %r11, %r17, 32;
    or.b32 %r23, %r17, 2;
    max.s64 %rd8, %rd9, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
