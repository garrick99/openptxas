.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd13, %r3, %r3;
    setp.le.u32 %p3, %r3, 65535;
    mad.lo.u32 %r6, %r3, %r3, %r3;
    cvt.u64.u32 %rd14, %r6;
    mul.wide.u32 %rd8, %r6, %r6;
    mul.lo.s32 %r20, %r6, %r6;
    or.b32 %r23, %r20, 4;
    shr.u32 %r13, %r20, 0;
    and.b32 %r16, %r13, %r20;
    add.s32 %r7, %r16, 2;
    sub.s32 %r15, %r3, %r13;
    max.u32 %r23, %r7, 0;
    cvt.s32.s64 %r18, %rd8;
    or.b32 %r20, %r3, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
