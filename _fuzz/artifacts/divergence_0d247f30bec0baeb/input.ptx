.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r23, %r3, 0;
    min.s32 %r7, %r3, %r3;
    or.b32 %r15, %r7, 2147483648;
    sub.u32 %r16, %r7, 7;
    max.u32 %r24, %r16, %r16;
    shl.b32 %r27, %r23, 2;
    sub.s32 %r8, %r27, %r3;
    shr.u32 %r5, %r16, 2;
    mul.lo.u32 %r9, %r5, %r16;
    setp.ls.u32 %p4, %r7, %r24;
    setp.ge.s32 %p1, %r3, %r16;
    @!%p1 mul.lo.u32 %r22, %r7, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
