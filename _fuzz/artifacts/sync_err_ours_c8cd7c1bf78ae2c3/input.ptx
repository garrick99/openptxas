    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r5, %r3, %r3;
    mul.lo.u32 %r16, %r5, 2;
    min.s32 %r4, %r16, 4294967295;
    min.u32 %r19, %r3, %r3;
    cvt.s64.s32 %rd6, %r5;
    shl.b32 %r19, %r19, 4;
    setp.ge.s32 %p1, %r19, %r16;
    @%p1 shr.s32 %r12, %r3, 1;
    shl.b64 %rd9, %rd6, 0;
    sub.u32 %r22, %r19, 2147483647;
    setp.le.s32 %p1, %r22, 1;
    @%p1 sub.s64 %rd15, %rd9, %rd6;
    setp.ls.u32 %p1, %r4, %r4;
