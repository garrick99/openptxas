.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r26, %r3, %r3;
    mul.lo.s32 %r6, %r26, 5;
    max.u32 %r6, %r3, 4294967295;
    cvt.u64.u32 %rd7, %r6;
    shr.u32 %r11, %r6, 4;
    cvt.u32.u64 %r20, %rd7;
    or.b32 %r25, %r20, 5;
    mul.wide.u32 %rd12, %r6, %r26;
    add.u64 %rd12, %rd7, %rd12;
    sub.u32 %r21, %r11, %r3;
    shl.b32 %r12, %r26, 3;
    sub.s32 %r6, %r3, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
