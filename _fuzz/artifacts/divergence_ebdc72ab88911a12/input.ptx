.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfi.b32 %r18, %r3, %r3, 16, 32;
    bfe.u32 %r5, %r3, 0, 1;
    bfe.s32 %r6, %r18, 15, 4;
    bfe.s32 %r5, %r6, 1, 4;
    bfi.b32 %r12, %r3, %r6, 24, 31;
    min.u32 %r15, %r12, 16;
    bfe.u32 %r13, %r12, 0, 24;
    bfe.u32 %r19, %r5, 8, 4;
    bfi.b32 %r5, %r6, %r12, 16, 31;
    bfi.b32 %r5, %r18, %r13, 23, 8;
    bfe.u32 %r5, %r18, 31, 2;
    bfi.b32 %r20, %r18, %r15, 8, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
