.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r9, %r3, %r3;
    setp.ls.u32 %p3, %r9, 8;
    @%p3 sub.s32 %r26, %r3, %r3;
    mad.lo.u32 %r19, %r9, %r26, %r9;
    cvt.s64.s32 %rd6, %r9;
    setp.eq.s32 %p4, %r26, 31;
    min.s32 %r10, %r3, 1;
    shr.s64 %rd9, %rd6, 33;
    selp.b32 %r22, %r9, %r3, %p4;
    setp.ge.s32 %p3, %r9, %r10;
    add.s32 %r24, %r9, %r9;
    selp.b32 %r11, %r19, %r22, %p4;
    mul.lo.s32 %r13, %r26, 3;
    shl.b32 %r8, %r13, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
