.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r12, %r3, %r3;
    cvt.u64.u32 %rd5, %r12;
    mad.lo.u32 %r24, %r12, %r12, %r3;
    and.b32 %r24, %r24, 65535;
    shr.s32 %r19, %r24, 3;
    sub.s32 %r10, %r12, 2147483647;
    max.u32 %r17, %r24, %r19;
    max.u32 %r25, %r19, 3;
    sub.u32 %r23, %r17, %r19;
    shr.u32 %r6, %r10, 4;
    or.b32 %r24, %r12, 4294967295;
    mul.lo.u64 %rd10, %rd5, %rd5;
    setp.le.s32 %p2, %r6, 7;
    @%p2 mul.lo.u32 %r7, %r24, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
