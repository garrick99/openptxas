.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r18, %r3, 1;
    min.s32 %r25, %r18, 32;
    cvt.u64.u32 %rd10, %r18;
    add.s32 %r27, %r18, %r18;
    cvt.s64.s32 %rd13, %r25;
    shr.s32 %r5, %r3, 3;
    add.u32 %r26, %r3, 255;
    sub.s32 %r26, %r18, 16;
    mul.wide.s32 %rd14, %r5, %r27;
    and.b32 %r22, %r25, 7;
    shr.u32 %r23, %r22, 4;
    shr.u64 %rd9, %rd14, 33;
    mad.lo.s32 %r13, %r5, %r5, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
