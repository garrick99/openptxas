.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p3, %r3, 5;
    @%p3 and.b32 %r10, %r3, %r3;
    cvt.s64.s32 %rd10, %r10;
    add.u32 %r15, %r3, %r3;
    cvt.u32.u64 %r9, %rd10;
    mul.wide.u32 %rd11, %r15, %r15;
    xor.b64 %rd12, %rd11, %rd11;
    shl.b64 %rd7, %rd12, 1;
    cvt.u32.u64 %r7, %rd7;
    mul.lo.u64 %rd6, %rd11, %rd7;
    xor.b32 %r27, %r7, %r7;
    add.u64 %rd14, %rd11, %rd11;
    shr.u32 %r23, %r7, 0;
    min.u32 %r4, %r9, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
