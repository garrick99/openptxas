.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r19, %r3, %r3;
    setp.le.s32 %p4, %r3, %r19;
    @%p4 selp.b32 %r22, %r19, %r19, %p4;
    shr.s32 %r9, %r19, 4;
    mul.wide.u32 %rd11, %r22, %r9;
    min.s32 %r10, %r19, 5;
    shr.u64 %rd14, %rd11, 7;
    mul.lo.u32 %r6, %r3, 32;
    or.b32 %r11, %r9, %r6;
    add.s32 %r9, %r9, %r22;
    and.b32 %r12, %r11, %r10;
    add.s32 %r9, %r6, 64;
    shr.u32 %r14, %r6, 2;
    min.s32 %r6, %r12, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
