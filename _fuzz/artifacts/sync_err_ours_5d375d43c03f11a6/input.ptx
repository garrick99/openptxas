.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r19, %r3, 7;
    max.u32 %r22, %r3, %r3;
    shl.b32 %r4, %r3, 0;
    max.s32 %r25, %r4, %r3;
    sub.s32 %r9, %r22, 8;
    sub.u32 %r13, %r22, 1;
    max.s32 %r4, %r3, 255;
    cvt.u64.u32 %rd14, %r25;
    shl.b32 %r23, %r22, 31;
    add.s32 %r18, %r19, %r25;
    min.u32 %r8, %r23, 8;
    setp.ne.s32 %p1, %r18, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
