.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r13, %r3, 4294967295;
    xor.b32 %r21, %r13, %r3;
    xor.b32 %r10, %r3, 2147483648;
    add.u32 %r21, %r3, %r21;
    shr.s32 %r26, %r21, 3;
    setp.ge.u32 %p2, %r26, 4;
    @!%p2 mad.lo.s32 %r20, %r3, %r21, %r21;
    mul.wide.u32 %rd10, %r3, %r13;
    setp.hs.u32 %p1, %r21, %r20;
    @%p1 add.u32 %r4, %r20, %r3;
    mad.lo.u32 %r24, %r3, %r21, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
