.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r6, %r3, 4294967295;
    setp.le.s32 %p3, %r3, 7;
    @%p3 or.b32 %r20, %r3, %r6;
    cvt.s64.s32 %rd5, %r6;
    shr.u32 %r22, %r20, 16;
    and.b32 %r10, %r20, 2;
    shl.b64 %rd11, %rd5, 7;
    mul.wide.s32 %rd15, %r6, %r22;
    cvt.u32.u64 %r13, %rd11;
    setp.le.s32 %p2, %r6, 3;
    add.s32 %r8, %r10, 65536;
    selp.b32 %r13, %r10, %r8, %p3;
    min.u32 %r13, %r20, %r20;
    xor.b32 %r14, %r10, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
