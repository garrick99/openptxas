.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    shr.u32 %r17, %r3, 31;
    or.b32 %r5, %r3, 64;
    shr.u32 %r18, %r5, 30;
    mad.lo.s32 %r17, %r5, %r3, %r17;
    max.u64 %rd5, %rd7, %rd7;
    setp.gt.u32 %p4, %r18, %r17;
    @%p4 or.b32 %r15, %r17, %r3;
    selp.b32 %r5, %r18, %r5, %p4;
    selp.b32 %r6, %r3, %r15, %p4;
    max.u32 %r18, %r18, %r15;
    mul.wide.u32 %rd11, %r18, %r18;
    max.s32 %r13, %r18, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
