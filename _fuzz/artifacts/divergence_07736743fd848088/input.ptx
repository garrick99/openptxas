.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    mad.lo.s32 %r23, %r3, %r3, %r3;
    setp.eq.u32 %p4, %r23, 8;
    @%p4 mul.wide.u32 %rd14, %r3, %r23;
    add.s32 %r9, %r23, 255;
    cvt.u64.u32 %rd5, %r9;
    sub.u32 %r18, %r3, %r3;
    mad.lo.u32 %r18, %r9, %r23, %r23;
    mul.lo.s32 %r14, %r9, %r18;
    selp.b32 %r21, %r18, %r9, %p4;
    mad.lo.s32 %r16, %r23, %r21, %r23;
    shl.b32 %r24, %r23, 0;
    sub.s64 %rd5, %rd6, %rd14;
    shr.s32 %r25, %r16, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
