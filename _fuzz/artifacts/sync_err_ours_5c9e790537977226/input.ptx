.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r12, %r3, 0;
    max.u32 %r21, %r3, 256;
    sub.s32 %r23, %r21, %r3;
    shl.b32 %r24, %r12, 0;
    mul.lo.u32 %r16, %r23, %r12;
    cvt.u64.u32 %rd12, %r21;
    sub.s32 %r21, %r12, 32;
    mul.wide.u32 %rd8, %r21, %r12;
    shr.s64 %rd7, %rd8, 4;
    min.u32 %r5, %r24, %r16;
    cvt.u32.u64 %r7, %rd7;
    and.b32 %r15, %r16, %r23;
    cvt.s32.s64 %r13, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
