.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r21, %r3, %r3;
    cvt.u64.u32 %rd8, %r3;
    setp.le.s32 %p2, %r21, %r21;
    @%p2 shr.s32 %r11, %r3, 31;
    selp.b32 %r23, %r3, %r11, %p2;
    setp.ne.u32 %p3, %r23, 4294967295;
    sub.s64 %rd10, %rd8, %rd8;
    mul.lo.u32 %r7, %r23, 63;
    selp.b32 %r19, %r3, %r7, %p2;
    mul.wide.s32 %rd11, %r21, %r19;
    sub.u32 %r21, %r19, %r21;
    sub.s32 %r14, %r19, %r23;
    min.u32 %r14, %r14, 63;
    shr.u64 %rd15, %rd11, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
