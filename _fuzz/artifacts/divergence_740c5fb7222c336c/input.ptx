.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r14, %r3, %r3;
    mul.lo.u32 %r22, %r14, 4;
    setp.ne.s32 %p4, %r22, %r3;
    @%p4 min.s32 %r14, %r3, 4;
    sub.u32 %r14, %r22, 7;
    selp.b32 %r17, %r14, %r3, %p4;
    mul.wide.s32 %rd13, %r22, %r17;
    add.u32 %r25, %r14, 8;
    setp.ls.u32 %p3, %r17, 4294967295;
    setp.gt.s32 %p4, %r22, %r25;
    @%p4 min.s32 %r8, %r3, 3;
    shr.s64 %rd7, %rd13, 0;
    or.b32 %r6, %r25, %r17;
    sub.u32 %r24, %r8, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
