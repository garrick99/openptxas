.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r21, %r3, %r3;
    mul.lo.u32 %r15, %r21, %r21;
    mul.lo.s32 %r22, %r3, %r15;
    cvt.s64.s32 %rd6, %r22;
    or.b32 %r23, %r22, 63;
    shr.u32 %r4, %r23, 2;
    max.s32 %r18, %r22, %r23;
    shr.u32 %r21, %r18, 15;
    shr.u32 %r4, %r3, 7;
    mad.lo.u32 %r21, %r18, %r22, %r21;
    max.s32 %r26, %r23, %r22;
    and.b32 %r18, %r15, %r22;
    shr.s64 %rd14, %rd6, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
