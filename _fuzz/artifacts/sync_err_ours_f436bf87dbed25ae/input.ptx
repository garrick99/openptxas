.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r5, %r3, 4294967295;
    cvt.u64.u32 %rd10, %r3;
    add.u32 %r12, %r5, 2;
    mul.wide.s32 %rd10, %r5, %r12;
    or.b32 %r5, %r5, %r12;
    and.b32 %r25, %r3, %r12;
    or.b32 %r5, %r25, %r12;
    cvt.s32.s64 %r21, %rd10;
    min.u32 %r25, %r3, %r21;
    cvt.s32.s64 %r21, %rd10;
    min.s32 %r16, %r25, %r21;
    add.s32 %r20, %r25, 8;
    mul.wide.s32 %rd11, %r3, %r20;
    xor.b32 %r20, %r5, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
