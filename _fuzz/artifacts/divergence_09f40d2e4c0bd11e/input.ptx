.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    sub.u32 %r6, %r3, 7;
    min.u32 %r20, %r6, 15;
    add.s32 %r6, %r6, %r3;
    shr.s32 %r22, %r6, 0;
    shl.b32 %r8, %r20, 15;
    xor.b32 %r25, %r22, %r8;
    shl.b64 %rd11, %rd8, 48;
    shr.u64 %rd10, %rd8, 4;
    mad.lo.u32 %r18, %r20, %r20, %r25;
    shr.u32 %r23, %r22, 3;
    max.s32 %r17, %r6, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
