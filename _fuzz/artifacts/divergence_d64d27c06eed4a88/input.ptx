.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r20, %r3, %r3;
    min.u32 %r11, %r3, 256;
    max.u32 %r10, %r11, %r3;
    shr.u32 %r23, %r3, 1;
    setp.le.s32 %p3, %r3, 65536;
    setp.hs.u32 %p2, %r3, 255;
    mul.lo.u32 %r8, %r11, %r10;
    mul.lo.s32 %r21, %r23, 65536;
    setp.gt.s32 %p1, %r8, 64;
    selp.b32 %r22, %r21, %r3, %p1;
    min.u32 %r8, %r22, 2147483648;
    mad.lo.s32 %r14, %r21, %r21, %r10;
    min.u32 %r11, %r20, 65536;
    mul.wide.s32 %rd8, %r21, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
