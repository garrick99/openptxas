.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r25, %r3, %r3;
    cvt.s64.s32 %rd9, %r25;
    setp.hi.u32 %p3, %r3, 31;
    @!%p3 add.u32 %r19, %r25, %r25;
    mul.lo.u32 %r22, %r25, %r19;
    mul.wide.u32 %rd14, %r25, %r3;
    max.s32 %r7, %r3, %r3;
    mul.wide.s32 %rd9, %r3, %r3;
    mad.lo.s32 %r25, %r7, %r25, %r7;
    min.s32 %r17, %r7, 0;
    setp.le.s32 %p1, %r19, %r3;
    or.b32 %r5, %r17, %r19;
    max.s32 %r11, %r7, %r25;
    selp.b32 %r20, %r22, %r17, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
