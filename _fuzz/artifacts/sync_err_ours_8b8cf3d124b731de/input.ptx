.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r11, %r3, %r0;
    shfl.sync.up.b32 %r9, %r0, 2, 0x1f, -1;
    shfl.sync.idx.b32 %r17, %r3, 7, 0x1f, -1;
    add.u32 %r10, %r17, %r9;
    shfl.sync.up.b32 %r18, %r17, 1, 0x1f, -1;
    shfl.sync.up.b32 %r15, %r0, 4, 0x1f, -1;
    sub.u32 %r5, %r9, %r0;
    min.u32 %r10, %r3, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
