.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r24, %r3, 63;
    mad.lo.s32 %r17, %r3, %r24, %r24;
    shr.s32 %r10, %r24, 1;
    sub.s32 %r24, %r17, %r24;
    sub.s32 %r20, %r17, %r3;
    cvt.u64.u32 %rd9, %r20;
    and.b32 %r25, %r17, %r24;
    add.s64 %rd14, %rd9, %rd9;
    max.s32 %r23, %r20, %r24;
    mul.wide.u32 %rd11, %r25, %r24;
    shr.u32 %r4, %r20, 1;
    setp.le.s32 %p1, %r24, %r25;
    @%p1 mul.lo.s32 %r20, %r24, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
