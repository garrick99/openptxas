.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    cvt.s64.s32 %rd5, %r3;
    min.u32 %r11, %r3, 0;
    cvt.s32.s64 %r27, %rd8;
    min.u32 %r18, %r11, %r27;
    shr.s32 %r17, %r27, 16;
    shl.b64 %rd13, %rd8, 63;
    shr.s64 %rd13, %rd8, 0;
    min.u32 %r4, %r18, 5;
    min.u64 %rd8, %rd13, %rd8;
    mad.lo.s32 %r21, %r11, %r11, %r11;
    min.s32 %r27, %r27, %r17;
    mul.lo.s32 %r25, %r27, 65535;
    or.b32 %r12, %r4, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
