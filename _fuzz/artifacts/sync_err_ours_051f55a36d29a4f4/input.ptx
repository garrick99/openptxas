.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd6, %r3, %r3;
    shl.b32 %r11, %r3, 2;
    sub.s32 %r20, %r11, %r3;
    max.s32 %r5, %r20, 32;
    sub.u32 %r13, %r20, 7;
    max.s32 %r25, %r3, %r3;
    sub.u32 %r19, %r13, %r25;
    and.b64 %rd13, %rd6, %rd6;
    or.b64 %rd10, %rd6, %rd6;
    setp.gt.s32 %p3, %r19, %r25;
    @%p3 shr.u32 %r13, %r13, 15;
    selp.b32 %r7, %r19, %r19, %p3;
    and.b32 %r9, %r3, %r13;
    shr.s64 %rd12, %rd13, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
