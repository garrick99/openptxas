.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r12, %r3, 256;
    or.b32 %r19, %r3, %r12;
    mul.lo.u32 %r25, %r19, %r19;
    cvt.u64.u32 %rd10, %r3;
    cvt.u32.u64 %r4, %rd10;
    xor.b32 %r11, %r4, %r19;
    setp.lo.u32 %p3, %r12, %r25;
    selp.b32 %r14, %r4, %r3, %p3;
    and.b32 %r19, %r3, %r3;
    add.u64 %rd12, %rd10, %rd10;
    mul.lo.u32 %r16, %r4, %r12;
    min.s32 %r20, %r4, 15;
    max.s32 %r7, %r12, %r11;
    selp.b32 %r20, %r25, %r4, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
