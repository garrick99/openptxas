.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p4, %r3, %r3;
    @%p4 or.b32 %r20, %r3, %r3;
    mad.lo.s32 %r26, %r20, %r3, %r20;
    selp.b32 %r11, %r26, %r3, %p4;
    mul.wide.s32 %rd6, %r3, %r11;
    sub.u32 %r26, %r11, %r3;
    xor.b32 %r20, %r11, 32;
    setp.ge.s32 %p3, %r3, 255;
    @%p3 shr.u64 %rd5, %rd6, 7;
    shr.s64 %rd6, %rd5, 4;
    mad.lo.s32 %r14, %r3, %r11, %r11;
    cvt.s64.s32 %rd9, %r26;
    max.u32 %r27, %r14, 5;
    min.u32 %r11, %r26, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
