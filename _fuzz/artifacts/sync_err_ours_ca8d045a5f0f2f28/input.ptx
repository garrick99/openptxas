.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r10, %r3, 4;
    mad.lo.s32 %r25, %r10, %r3, %r10;
    shr.s32 %r13, %r3, 31;
    mad.lo.s32 %r11, %r25, %r13, %r13;
    mul.wide.u32 %rd6, %r10, %r3;
    cvt.u64.u32 %rd7, %r13;
    shr.s32 %r19, %r11, 15;
    setp.gt.u32 %p4, %r11, 65536;
    add.u32 %r5, %r25, 255;
    mad.lo.s32 %r13, %r19, %r13, %r19;
    max.u32 %r22, %r13, %r3;
    mul.lo.s32 %r13, %r11, %r5;
    cvt.s64.s32 %rd11, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
