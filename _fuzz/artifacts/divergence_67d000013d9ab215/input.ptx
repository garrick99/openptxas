.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r16, %r3, %r3, %r3;
    setp.ne.s32 %p2, %r16, %r16;
    @%p2 mad.lo.u32 %r11, %r16, %r3, %r3;
    mul.wide.s32 %rd6, %r11, %r3;
    mul.lo.u32 %r9, %r16, %r3;
    mul.lo.u64 %rd8, %rd6, %rd6;
    mul.wide.s32 %rd11, %r16, %r16;
    setp.lt.s32 %p1, %r11, 16;
    @!%p1 add.u64 %rd8, %rd8, %rd8;
    shl.b32 %r5, %r9, 1;
    mad.lo.u32 %r19, %r3, %r3, %r11;
    setp.ne.u32 %p1, %r16, 64;
    @!%p1 xor.b32 %r14, %r9, 256;
    add.u32 %r27, %r11, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
