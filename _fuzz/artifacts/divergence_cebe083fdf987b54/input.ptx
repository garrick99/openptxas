.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r23, %r3, 255;
    mul.lo.u32 %r27, %r23, 8;
    max.s32 %r15, %r27, %r27;
    min.u32 %r14, %r23, 16;
    mad.lo.s32 %r13, %r23, %r15, %r3;
    mul.lo.u32 %r8, %r23, 31;
    shr.u32 %r9, %r27, 3;
    mul.lo.s32 %r22, %r13, 4294967295;
    max.u32 %r12, %r15, 64;
    sub.u32 %r25, %r22, %r9;
    cvt.s64.s32 %rd6, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
