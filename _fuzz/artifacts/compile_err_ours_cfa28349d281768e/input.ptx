.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r19, %r3, %r0;
    shfl.sync.idx.b32 %r16, %r3, 31, 0x1f, -1;
    min.u32 %r4, %r16, %r16;
    min.u32 %r11, %r3, %r3;
    or.b32 %r9, %r16, %r16;
    xor.b32 %r19, %r16, %r16;
    setp.ne.u32 %p2, %r11, 16;
    vote.sync.ballot.b32 %r9, %p2, -1;
    vote.sync.any.pred %p2, %p2, -1;
    and.b32 %r13, %r0, %r0;
    shfl.sync.bfly.b32 %r8, %r11, 16, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
