.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p1, %r3, 255;
    @%p1 cvt.s64.s32 %rd5, %r3;
    setp.eq.s32 %p4, %r3, 2;
    @%p4 mul.lo.s32 %r12, %r3, %r3;
    shr.u64 %rd13, %rd5, 32;
    mul.lo.u32 %r11, %r12, 65536;
    or.b32 %r18, %r3, 256;
    setp.ne.u32 %p2, %r12, %r3;
    @%p2 shr.s64 %rd9, %rd13, 7;
    setp.lt.u32 %p2, %r18, %r3;
    @%p2 selp.b32 %r4, %r18, %r18, %p1;
    mad.lo.u32 %r4, %r18, %r3, %r11;
    mul.wide.s32 %rd14, %r4, %r3;
    mul.wide.u32 %rd7, %r11, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
