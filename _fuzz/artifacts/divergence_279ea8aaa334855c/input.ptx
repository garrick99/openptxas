.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r9, %r3, %r3;
    mad.lo.s32 %r21, %r3, %r3, %r3;
    cvt.s64.s32 %rd15, %r9;
    max.u32 %r8, %r21, %r9;
    add.u64 %rd11, %rd15, %rd15;
    setp.le.s32 %p2, %r8, 4;
    max.u32 %r24, %r8, %r8;
    add.u32 %r9, %r3, %r3;
    add.u32 %r24, %r9, %r24;
    mul.wide.u32 %rd5, %r8, %r9;
    xor.b32 %r4, %r21, %r9;
    and.b32 %r22, %r8, %r24;
    setp.lt.u32 %p2, %r21, %r24;
    @%p2 mad.lo.s32 %r25, %r8, %r8, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
