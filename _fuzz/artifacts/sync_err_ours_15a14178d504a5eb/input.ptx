.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    mul.lo.s32 %r9, %r3, 3;
    mul.lo.s32 %r11, %r9, %r9;
    shr.u32 %r8, %r3, 30;
    cvt.u32.u64 %r15, %rd9;
    sub.s32 %r11, %r9, %r15;
    mul.wide.u32 %rd6, %r9, %r11;
    shl.b32 %r10, %r15, 31;
    shl.b64 %rd7, %rd9, 30;
    shr.s32 %r21, %r10, 15;
    mad.lo.s32 %r13, %r15, %r11, %r3;
    xor.b32 %r12, %r13, %r15;
    min.u64 %rd10, %rd6, %rd9;
    shr.s32 %r10, %r21, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
