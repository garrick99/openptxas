.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r4, %r3, 16;
    xor.b32 %r19, %r4, 65536;
    cvt.u64.u32 %rd14, %r3;
    setp.eq.s32 %p3, %r4, %r4;
    @%p3 cvt.s64.s32 %rd7, %r4;
    mad.lo.u32 %r7, %r3, %r3, %r19;
    shr.u64 %rd13, %rd14, 1;
    min.u32 %r12, %r4, %r19;
    shr.s32 %r5, %r7, 0;
    sub.u32 %r21, %r19, %r19;
    sub.u32 %r18, %r19, %r19;
    sub.s32 %r21, %r19, %r3;
    setp.lt.s32 %p4, %r3, %r5;
    @%p4 xor.b32 %r8, %r3, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
