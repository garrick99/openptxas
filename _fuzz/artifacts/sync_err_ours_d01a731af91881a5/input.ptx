.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    shr.u64 %rd14, %rd12, 3;
    min.u32 %r13, %r3, %r3;
    cvt.s32.s64 %r17, %rd14;
    shl.b64 %rd14, %rd14, 16;
    or.b32 %r10, %r3, 255;
    add.s32 %r17, %r3, 5;
    mul.wide.u32 %rd6, %r17, %r3;
    shl.b64 %rd6, %rd14, 63;
    max.s32 %r11, %r3, %r3;
    mul.wide.u32 %rd6, %r10, %r3;
    cvt.u32.u64 %r14, %rd6;
    mul.lo.u32 %r12, %r3, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
