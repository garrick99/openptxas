.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    mul.lo.s64 %rd5, %rd10, %rd10;
    sub.u32 %r5, %r3, 64;
    shr.s64 %rd5, %rd10, 48;
    sub.s64 %rd8, %rd5, %rd5;
    shr.u32 %r7, %r5, 2;
    shr.u64 %rd5, %rd10, 15;
    cvt.u64.u32 %rd8, %r7;
    min.s32 %r26, %r3, 4294967295;
    sub.u32 %r23, %r7, %r7;
    shr.u32 %r22, %r7, 0;
    shr.s64 %rd5, %rd8, 15;
    sub.s32 %r27, %r26, 7;
    sub.u32 %r17, %r23, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
