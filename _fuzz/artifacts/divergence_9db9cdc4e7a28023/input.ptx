.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd7, %r3, %r3;
    cvt.s64.s32 %rd11, %r3;
    shr.s32 %r7, %r3, 30;
    shr.u32 %r25, %r3, 15;
    cvt.u64.u32 %rd5, %r7;
    sub.s32 %r19, %r3, 0;
    xor.b32 %r9, %r7, %r25;
    min.u32 %r15, %r9, 4;
    setp.le.u32 %p1, %r7, 255;
    @!%p1 max.u32 %r12, %r25, %r15;
    mul.wide.u32 %rd5, %r15, %r12;
    min.u32 %r18, %r9, 32;
    mul.lo.s32 %r19, %r7, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
