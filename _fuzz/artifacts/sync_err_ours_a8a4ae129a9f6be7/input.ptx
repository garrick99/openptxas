.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r7, %r3, %r3;
    mul.lo.u32 %r11, %r3, %r7;
    add.u32 %r12, %r11, 255;
    shr.u32 %r7, %r7, 0;
    min.s32 %r14, %r12, %r3;
    mad.lo.s32 %r20, %r14, %r12, %r11;
    setp.gt.s32 %p4, %r7, %r12;
    @!%p4 mul.wide.s32 %rd15, %r11, %r7;
    mul.wide.u32 %rd6, %r12, %r11;
    max.s32 %r22, %r20, %r7;
    add.u32 %r10, %r12, 1;
    shr.u64 %rd9, %rd15, 1;
    setp.hi.u32 %p3, %r12, 255;
    @!%p3 mul.wide.u32 %rd14, %r7, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
