.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r16, %r3, 3;
    xor.b32 %r26, %r16, %r3;
    mad.lo.u32 %r24, %r16, %r26, %r3;
    mul.lo.u32 %r24, %r24, %r26;
    shr.s32 %r22, %r24, 2;
    min.s32 %r19, %r16, %r16;
    max.s32 %r26, %r26, %r3;
    setp.lt.u32 %p3, %r26, 256;
    shr.s32 %r10, %r16, 30;
    mad.lo.s32 %r8, %r26, %r19, %r3;
    shl.b32 %r4, %r10, 1;
    mul.lo.u32 %r23, %r16, 8;
    shl.b32 %r21, %r3, 15;
    selp.b32 %r24, %r24, %r21, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
