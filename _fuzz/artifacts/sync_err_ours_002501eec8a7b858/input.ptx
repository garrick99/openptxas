.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r8, %r3, %r3;
    max.s32 %r8, %r3, %r8;
    setp.gt.u32 %p3, %r8, %r8;
    @%p3 sub.u32 %r7, %r3, %r3;
    max.s32 %r17, %r8, %r7;
    setp.hs.u32 %p2, %r7, %r17;
    @!%p2 mul.wide.u32 %rd13, %r7, %r8;
    min.u32 %r10, %r17, %r3;
    min.u32 %r13, %r7, %r8;
    mul.lo.u32 %r21, %r7, 32;
    cvt.s32.s64 %r26, %rd13;
    min.u32 %r27, %r8, %r21;
    sub.s32 %r19, %r7, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
