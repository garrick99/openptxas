.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p3, %r3, %r3;
    @!%p3 or.b32 %r17, %r3, %r3;
    mul.lo.s32 %r16, %r3, 255;
    setp.eq.s32 %p4, %r16, %r17;
    @%p4 shr.s32 %r17, %r16, 7;
    mul.lo.u32 %r20, %r16, %r3;
    mad.lo.s32 %r21, %r16, %r3, %r16;
    cvt.u64.u32 %rd13, %r17;
    min.s32 %r5, %r21, %r3;
    cvt.s32.s64 %r19, %rd13;
    mul.wide.u32 %rd10, %r3, %r19;
    mad.lo.s32 %r11, %r16, %r17, %r16;
    min.s32 %r21, %r16, %r21;
    sub.u32 %r27, %r5, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
