.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    mul.wide.s32 %rd13, %r3, %r3;
    mul.lo.u32 %r4, %r3, %r3;
    min.u64 %rd7, %rd13, %rd13;
    or.b32 %r16, %r3, 5;
    cvt.u64.u32 %rd14, %r3;
    cvt.s64.s32 %rd8, %r4;
    xor.b32 %r25, %r4, %r16;
    setp.le.s32 %p1, %r3, %r25;
    @%p1 shr.u32 %r19, %r16, 3;
    mul.lo.u64 %rd9, %rd8, %rd12;
    mul.lo.s32 %r21, %r19, 5;
    cvt.s64.s32 %rd13, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
