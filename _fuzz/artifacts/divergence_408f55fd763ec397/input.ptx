.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r11, %r3, %r3, %r3;
    min.s32 %r24, %r11, %r11;
    min.s32 %r17, %r24, %r24;
    max.s32 %r14, %r11, %r17;
    shr.u32 %r17, %r24, 0;
    setp.gt.s32 %p3, %r3, 8;
    sub.s32 %r22, %r24, 8;
    cvt.s64.s32 %rd9, %r14;
    setp.eq.s32 %p3, %r22, 65535;
    @!%p3 selp.b32 %r15, %r22, %r17, %p3;
    shr.u32 %r21, %r15, 4;
    mad.lo.u32 %r26, %r24, %r15, %r17;
    max.u32 %r20, %r15, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
