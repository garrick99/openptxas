.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r6, %r3, %r3;
    mul.wide.u32 %rd8, %r6, %r3;
    xor.b32 %r5, %r6, 2147483647;
    add.s32 %r26, %r6, %r5;
    setp.lt.s32 %p3, %r6, 7;
    @!%p3 min.u32 %r25, %r5, 65535;
    shr.u32 %r15, %r6, 0;
    mul.lo.s64 %rd12, %rd8, %rd8;
    cvt.u32.u64 %r27, %rd8;
    mad.lo.u32 %r14, %r3, %r3, %r5;
    or.b32 %r18, %r15, %r14;
    sub.u64 %rd6, %rd8, %rd8;
    mul.lo.u32 %r27, %r25, %r3;
    add.s32 %r19, %r25, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
