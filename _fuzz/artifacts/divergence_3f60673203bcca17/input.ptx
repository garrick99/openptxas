.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r9, %r3, %r3;
    min.u32 %r25, %r9, %r3;
    cvt.s64.s32 %rd13, %r25;
    add.u32 %r24, %r3, %r25;
    cvt.s64.s32 %rd5, %r25;
    shr.u32 %r17, %r3, 2;
    xor.b32 %r19, %r3, %r25;
    shr.u64 %rd6, %rd5, 3;
    shl.b64 %rd5, %rd6, 1;
    min.s32 %r9, %r25, 7;
    max.u32 %r24, %r25, %r17;
    setp.ge.u32 %p1, %r17, 256;
    @%p1 and.b32 %r12, %r24, %r25;
    max.s32 %r17, %r3, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
