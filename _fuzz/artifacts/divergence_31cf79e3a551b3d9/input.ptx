.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r17, %r3, 3;
    max.s32 %r9, %r17, %r3;
    setp.gt.u32 %p2, %r17, 8;
    @%p2 sub.u32 %r11, %r3, %r9;
    add.u32 %r21, %r9, 8;
    shr.u32 %r5, %r9, 15;
    selp.b32 %r21, %r9, %r9, %p2;
    min.u32 %r12, %r21, 8;
    add.s32 %r23, %r17, %r5;
    max.u32 %r5, %r9, 8;
    setp.ne.s32 %p3, %r5, 4;
    @%p3 xor.b32 %r25, %r11, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
