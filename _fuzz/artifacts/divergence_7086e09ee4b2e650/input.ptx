.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd6, %r3, %r3;
    mul.wide.u32 %rd7, %r3, %r3;
    setp.gt.u32 %p4, %r3, 7;
    @%p4 cvt.u32.u64 %r18, %rd6;
    selp.b32 %r14, %r3, %r3, %p4;
    cvt.u32.u64 %r4, %rd6;
    setp.ge.s32 %p2, %r3, %r3;
    setp.gt.s32 %p2, %r3, %r18;
    @%p2 cvt.s32.s64 %r9, %rd7;
    setp.eq.s32 %p1, %r3, 64;
    @%p1 and.b32 %r19, %r18, 7;
    selp.b32 %r14, %r19, %r3, %p1;
    cvt.s64.s32 %rd7, %r4;
    max.u32 %r23, %r9, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
