.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd6, %r3, %r3;
    add.s32 %r23, %r3, 255;
    shr.s32 %r26, %r23, 30;
    mul.lo.s32 %r25, %r3, 64;
    min.u32 %r16, %r23, %r25;
    max.u32 %r17, %r25, %r16;
    sub.u32 %r14, %r16, 64;
    add.u32 %r9, %r26, %r26;
    mul.wide.u32 %rd10, %r9, %r17;
    add.s64 %rd13, %rd6, %rd6;
    mul.lo.u32 %r21, %r16, %r26;
    sub.s64 %rd5, %rd6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
