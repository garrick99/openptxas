.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r17, %r3, 4294967295;
    mad.lo.u32 %r26, %r3, %r3, %r3;
    and.b32 %r4, %r17, 32;
    cvt.s64.s32 %rd9, %r4;
    min.u64 %rd6, %rd9, %rd9;
    shl.b32 %r13, %r26, 30;
    shr.s64 %rd6, %rd6, 32;
    mul.wide.u32 %rd15, %r26, %r3;
    or.b32 %r21, %r13, 2147483647;
    min.u32 %r13, %r17, %r13;
    cvt.u64.u32 %rd8, %r3;
    setp.hi.u32 %p4, %r13, %r3;
    @%p4 sub.u32 %r10, %r17, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
