.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r24, %r3, 16;
    max.u32 %r9, %r3, 65536;
    mul.wide.u32 %rd6, %r24, %r9;
    or.b32 %r7, %r9, 4;
    setp.gt.u32 %p2, %r9, 65535;
    mul.wide.s32 %rd14, %r7, %r3;
    max.s32 %r24, %r3, %r9;
    shl.b64 %rd12, %rd14, 16;
    selp.b32 %r17, %r9, %r3, %p2;
    add.s32 %r11, %r3, %r7;
    mul.wide.s32 %rd12, %r24, %r9;
    xor.b32 %r5, %r17, 4;
    shr.u64 %rd11, %rd14, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
