.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    add.s32 %r24, %r3, %r3;
    setp.le.u32 %p3, %r3, 2147483647;
    @%p3 min.s32 %r25, %r24, 8;
    add.s32 %r23, %r25, %r25;
    xor.b32 %r12, %r3, 2147483648;
    max.u64 %rd12, %rd7, %rd7;
    mul.lo.u64 %rd10, %rd12, %rd12;
    setp.lt.s32 %p1, %r3, 32;
    min.s32 %r12, %r23, %r23;
    min.u32 %r5, %r3, 2;
    shr.s32 %r5, %r23, 1;
    max.s32 %r18, %r3, %r23;
    setp.ge.u32 %p3, %r12, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
