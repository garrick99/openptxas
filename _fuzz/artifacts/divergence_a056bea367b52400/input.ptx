.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r24, %r3, 255;
    cvt.s64.s32 %rd10, %r24;
    or.b32 %r23, %r24, %r3;
    add.u32 %r16, %r3, 256;
    min.s32 %r17, %r3, %r3;
    setp.ge.s32 %p1, %r23, 4;
    @!%p1 mul.lo.u32 %r24, %r17, 63;
    add.s32 %r13, %r16, %r17;
    min.s32 %r26, %r16, %r3;
    max.s32 %r4, %r26, 64;
    mul.lo.u32 %r6, %r24, 8;
    mul.wide.s32 %rd15, %r13, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
