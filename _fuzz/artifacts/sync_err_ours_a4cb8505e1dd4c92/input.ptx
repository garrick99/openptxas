.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd14, %r3, %r3;
    mul.lo.u32 %r5, %r3, %r3;
    mul.lo.s32 %r13, %r3, 16;
    cvt.s32.s64 %r12, %rd14;
    max.u32 %r26, %r13, %r3;
    add.u32 %r10, %r3, %r26;
    add.s32 %r14, %r10, 0;
    sub.s64 %rd10, %rd14, %rd14;
    cvt.u32.u64 %r22, %rd14;
    sub.u32 %r17, %r3, %r3;
    cvt.u64.u32 %rd10, %r26;
    sub.s32 %r17, %r10, 15;
    cvt.s32.s64 %r10, %rd10;
    setp.lt.s32 %p4, %r5, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
