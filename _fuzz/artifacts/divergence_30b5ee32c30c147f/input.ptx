.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r13, %r3, 2;
    and.b32 %r11, %r13, 255;
    and.b32 %r18, %r13, %r3;
    cvt.s64.s32 %rd8, %r13;
    shr.s64 %rd10, %rd8, 32;
    cvt.s32.s64 %r6, %rd10;
    cvt.u64.u32 %rd11, %r6;
    setp.lt.s32 %p4, %r3, %r13;
    @!%p4 min.s64 %rd8, %rd8, %rd11;
    shl.b32 %r17, %r11, 4;
    selp.b32 %r18, %r13, %r3, %p4;
    shr.s64 %rd12, %rd10, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
