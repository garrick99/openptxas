.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r7, %r3, 2147483648;
    add.u32 %r20, %r7, %r3;
    mul.wide.u32 %rd5, %r3, %r7;
    and.b32 %r24, %r7, %r3;
    add.s64 %rd15, %rd5, %rd5;
    shr.s32 %r16, %r7, 3;
    setp.lt.s32 %p2, %r7, 5;
    @%p2 shr.u32 %r6, %r7, 1;
    sub.u64 %rd12, %rd5, %rd5;
    mul.lo.s32 %r10, %r7, 4;
    cvt.s32.s64 %r17, %rd12;
    and.b64 %rd13, %rd12, %rd15;
    max.s32 %r11, %r16, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
