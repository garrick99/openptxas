.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    shr.s32 %r26, %r3, 3;
    and.b64 %rd8, %rd8, %rd8;
    mul.lo.s32 %r12, %r26, 8;
    shr.u32 %r13, %r26, 4;
    shr.u64 %rd13, %rd8, 0;
    shr.u32 %r12, %r3, 31;
    cvt.u32.u64 %r12, %rd13;
    mul.wide.u32 %rd7, %r26, %r3;
    min.s32 %r8, %r26, %r3;
    or.b32 %r4, %r13, %r8;
    sub.s64 %rd7, %rd8, %rd8;
    setp.lt.u32 %p4, %r3, 255;
    @%p4 selp.b32 %r21, %r12, %r26, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
