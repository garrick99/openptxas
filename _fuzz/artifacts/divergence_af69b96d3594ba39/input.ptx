.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r27, %r3, %r3;
    sub.s32 %r10, %r27, 32;
    cvt.s64.s32 %rd11, %r3;
    max.s32 %r14, %r27, 16;
    min.s32 %r20, %r27, %r3;
    xor.b32 %r9, %r27, 1;
    shl.b32 %r20, %r20, 7;
    setp.hi.u32 %p3, %r10, 63;
    sub.s32 %r21, %r27, 5;
    sub.u32 %r20, %r3, 5;
    shr.s32 %r20, %r9, 7;
    and.b32 %r25, %r10, %r14;
    min.u64 %rd7, %rd11, %rd11;
    add.s32 %r14, %r10, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
