.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r5, %r3, 256;
    mul.wide.s32 %rd10, %r3, %r5;
    mul.wide.s32 %rd9, %r5, %r3;
    setp.eq.s32 %p3, %r3, %r3;
    @%p3 shr.u32 %r9, %r5, 16;
    min.s32 %r25, %r5, %r3;
    add.s32 %r15, %r25, 0;
    max.s32 %r15, %r9, 2;
    mul.wide.u32 %rd14, %r5, %r3;
    selp.b32 %r23, %r9, %r15, %p3;
    min.u64 %rd15, %rd14, %rd14;
    setp.lo.u32 %p4, %r3, %r25;
    add.u32 %r8, %r25, %r5;
    sub.u32 %r16, %r15, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
