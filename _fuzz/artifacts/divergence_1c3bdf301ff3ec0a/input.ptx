.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p4, %r3, 65535;
    @%p4 cvt.u64.u32 %rd14, %r3;
    or.b64 %rd13, %rd14, %rd14;
    mul.lo.u64 %rd9, %rd13, %rd13;
    mul.lo.s32 %r21, %r3, 2147483647;
    max.u32 %r11, %r21, %r21;
    cvt.s32.s64 %r20, %rd14;
    add.u32 %r5, %r11, %r20;
    mul.wide.u32 %rd15, %r3, %r11;
    mul.lo.s64 %rd12, %rd13, %rd13;
    add.u32 %r16, %r20, %r21;
    max.u32 %r8, %r3, %r3;
    add.s32 %r21, %r5, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
