.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r7, %r3, 63;
    shr.u32 %r26, %r7, 31;
    setp.lt.u32 %p1, %r3, 256;
    @!%p1 shl.b32 %r24, %r7, 0;
    cvt.s64.s32 %rd9, %r24;
    cvt.u64.u32 %rd14, %r24;
    mul.lo.s64 %rd7, %rd9, %rd14;
    setp.lo.u32 %p1, %r3, %r24;
    @%p1 add.u32 %r19, %r3, %r7;
    shl.b32 %r4, %r26, 0;
    setp.gt.s32 %p2, %r4, 2147483648;
    @%p2 max.u32 %r27, %r24, 4294967295;
    sub.u32 %r7, %r24, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
