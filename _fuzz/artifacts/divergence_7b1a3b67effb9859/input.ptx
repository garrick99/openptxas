.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r4, %r3, 32;
    mad.lo.s32 %r9, %r4, %r4, %r4;
    cvt.s64.s32 %rd5, %r3;
    add.s64 %rd11, %rd5, %rd5;
    max.u32 %r13, %r4, 7;
    add.s64 %rd14, %rd11, %rd5;
    shr.u32 %r6, %r9, 0;
    shl.b32 %r12, %r6, 2;
    shr.s32 %r24, %r13, 3;
    mul.wide.u32 %rd5, %r12, %r4;
    mul.lo.s32 %r21, %r6, %r24;
    max.s32 %r13, %r12, 2147483647;
    setp.le.s32 %p2, %r21, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
