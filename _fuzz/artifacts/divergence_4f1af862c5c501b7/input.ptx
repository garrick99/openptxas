    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r5, %r3, 65536;
    sub.s32 %r4, %r3, 1;
    or.b32 %r21, %r4, 3;
    setp.lt.s32 %p1, %r3, 31;
    @!%p1 selp.b32 %r16, %r21, %r5, %p1;
    cvt.s64.s32 %rd7, %r16;
    shl.b32 %r26, %r4, 4;
    setp.lo.u32 %p3, %r5, 2;
    mul.lo.u32 %r24, %r21, %r16;
    max.s32 %r19, %r5, %r3;
    mul.lo.s32 %r9, %r4, 0;
    max.s32 %r6, %r19, 2147483647;
    cvt.u64.u32 %rd8, %r26;
    xor.b32 %r26, %r24, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
