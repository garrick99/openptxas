.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r18, %r3, %r3;
    max.u32 %r15, %r3, %r18;
    shr.s32 %r22, %r15, 1;
    mul.wide.s32 %rd11, %r18, %r22;
    setp.gt.s32 %p4, %r3, 4;
    mad.lo.s32 %r8, %r15, %r3, %r3;
    selp.b32 %r26, %r22, %r18, %p4;
    sub.u32 %r15, %r15, 64;
    selp.b32 %r18, %r26, %r18, %p4;
    min.u32 %r14, %r8, %r18;
    or.b32 %r19, %r3, %r3;
    setp.lo.u32 %p1, %r26, %r26;
    @%p1 cvt.u32.u64 %r19, %rd11;
    mul.lo.u32 %r19, %r19, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
