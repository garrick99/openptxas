.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r22, %r3, %r3, %r3;
    min.s32 %r13, %r3, %r22;
    mul.wide.u32 %rd6, %r3, %r13;
    mul.wide.s32 %rd5, %r22, %r13;
    cvt.u64.u32 %rd9, %r13;
    shl.b32 %r16, %r22, 3;
    shr.s32 %r22, %r16, 2;
    cvt.u64.u32 %rd13, %r3;
    setp.ne.s32 %p2, %r16, %r22;
    @%p2 shl.b32 %r6, %r16, 7;
    sub.u32 %r5, %r6, 5;
    sub.s32 %r19, %r16, 3;
    mul.wide.s32 %rd13, %r3, %r19;
    mul.lo.u32 %r4, %r19, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
