.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    mul.lo.s32 %r23, %r3, %r3;
    add.u32 %r13, %r23, %r23;
    mad.lo.s32 %r15, %r3, %r3, %r3;
    setp.lo.u32 %p2, %r15, %r13;
    setp.lo.u32 %p3, %r13, %r13;
    @%p3 mad.lo.u32 %r18, %r13, %r3, %r23;
    min.u32 %r17, %r18, %r13;
    mad.lo.u32 %r8, %r13, %r13, %r23;
    setp.le.s32 %p4, %r18, 7;
    @%p4 cvt.s32.s64 %r22, %rd12;
    min.s32 %r15, %r23, 3;
    or.b32 %r21, %r17, 5;
    shr.s64 %rd13, %rd12, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
