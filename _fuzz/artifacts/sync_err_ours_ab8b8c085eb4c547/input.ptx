.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    shl.b32 %r17, %r3, 2;
    cvt.s32.s64 %r22, %rd7;
    sub.s32 %r4, %r3, %r22;
    shr.s32 %r24, %r3, 0;
    cvt.u64.u32 %rd6, %r4;
    cvt.s32.s64 %r21, %rd6;
    mul.wide.u32 %rd13, %r3, %r17;
    shl.b32 %r6, %r22, 2;
    mul.lo.s64 %rd8, %rd6, %rd7;
    shl.b64 %rd6, %rd6, 15;
    mad.lo.s32 %r8, %r17, %r24, %r3;
    max.u32 %r9, %r4, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
