.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    xor.b64 %rd9, %rd14, %rd14;
    setp.eq.u32 %p4, %r3, %r3;
    @%p4 mad.lo.s32 %r11, %r3, %r3, %r3;
    shr.u64 %rd10, %rd9, 32;
    shr.u64 %rd5, %rd9, 30;
    sub.s64 %rd9, %rd5, %rd14;
    xor.b32 %r15, %r11, %r3;
    shr.u32 %r6, %r15, 2;
    add.s32 %r25, %r6, %r6;
    sub.s64 %rd15, %rd14, %rd14;
    cvt.u32.u64 %r16, %rd5;
    mul.lo.s32 %r16, %r3, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
