.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd10, %r3, %r3;
    setp.hi.u32 %p4, %r3, %r3;
    add.s32 %r14, %r3, %r3;
    max.s32 %r7, %r14, 4294967295;
    selp.b32 %r17, %r14, %r14, %p4;
    shr.s32 %r15, %r14, 1;
    shr.u32 %r21, %r14, 30;
    and.b32 %r5, %r17, 2;
    mad.lo.s32 %r25, %r14, %r7, %r17;
    max.s32 %r24, %r3, %r3;
    mul.lo.s32 %r9, %r14, %r17;
    mul.wide.u32 %rd11, %r21, %r5;
    shr.s32 %r23, %r14, 15;
    mul.wide.u32 %rd5, %r21, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
