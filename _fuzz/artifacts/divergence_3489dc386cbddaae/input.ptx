.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r7, %r3, 16;
    cvt.u64.u32 %rd14, %r3;
    sub.s32 %r17, %r3, %r7;
    sub.u32 %r26, %r7, %r17;
    mul.wide.s32 %rd7, %r26, %r7;
    add.u32 %r27, %r7, 1;
    cvt.u64.u32 %rd8, %r17;
    and.b32 %r11, %r3, 255;
    mul.wide.u32 %rd8, %r17, %r11;
    max.s32 %r6, %r26, %r27;
    mul.lo.s32 %r16, %r7, 5;
    sub.s32 %r21, %r17, 256;
    mul.lo.s32 %r22, %r6, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
