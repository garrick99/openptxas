.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    shr.s64 %rd14, %rd11, 2;
    cvt.s32.s64 %r15, %rd11;
    max.u32 %r16, %r15, %r3;
    cvt.s64.s32 %rd7, %r15;
    shl.b32 %r6, %r16, 0;
    setp.ne.s32 %p3, %r6, 63;
    setp.lt.s32 %p1, %r3, 5;
    @%p1 shl.b64 %rd8, %rd7, 2;
    add.u32 %r9, %r15, %r16;
    mul.wide.s32 %rd13, %r6, %r3;
    mad.lo.u32 %r19, %r6, %r16, %r16;
    shr.s64 %rd10, %rd7, 7;
    add.u32 %r5, %r6, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
