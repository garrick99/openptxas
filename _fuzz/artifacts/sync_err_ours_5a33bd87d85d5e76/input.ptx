.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r4, %r3, %r3, %r3;
    shl.b32 %r27, %r4, 7;
    or.b32 %r13, %r4, %r4;
    add.u32 %r10, %r4, %r4;
    mul.lo.s32 %r22, %r3, 16;
    sub.u32 %r18, %r22, %r4;
    cvt.u64.u32 %rd10, %r22;
    sub.u32 %r8, %r18, 4;
    cvt.s32.s64 %r17, %rd10;
    setp.ge.u32 %p1, %r4, %r18;
    @%p1 sub.u32 %r13, %r8, %r4;
    add.u32 %r22, %r13, 256;
    cvt.s32.s64 %r4, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
