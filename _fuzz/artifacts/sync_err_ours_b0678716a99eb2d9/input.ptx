.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    setp.eq.s32 %p1, %r3, %r3;
    min.u32 %r14, %r3, %r3;
    shr.u32 %r16, %r14, 31;
    cvt.s32.s64 %r17, %rd11;
    sub.s32 %r24, %r16, 63;
    max.s32 %r27, %r14, 1;
    sub.u32 %r22, %r14, %r16;
    shr.u32 %r4, %r16, 3;
    setp.gt.u32 %p1, %r24, %r4;
    @%p1 max.s32 %r20, %r16, %r22;
    add.u32 %r25, %r17, %r20;
    shl.b32 %r6, %r27, 7;
    min.s32 %r18, %r17, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
