.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    shr.s32 %r13, %r3, 7;
    shr.s64 %rd15, %rd11, 3;
    add.u32 %r20, %r3, 3;
    cvt.s32.s64 %r9, %rd15;
    sub.s32 %r6, %r13, %r9;
    mad.lo.u32 %r24, %r3, %r3, %r20;
    setp.eq.u32 %p4, %r3, 64;
    min.u32 %r27, %r9, 256;
    cvt.u32.u64 %r20, %rd15;
    setp.gt.s32 %p2, %r6, 3;
    @%p2 min.s32 %r8, %r24, 64;
    or.b64 %rd9, %rd11, %rd15;
    min.s32 %r13, %r6, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
