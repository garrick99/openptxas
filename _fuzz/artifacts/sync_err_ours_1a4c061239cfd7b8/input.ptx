.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r17, %r3, %r3;
    or.b32 %r27, %r3, %r3;
    shl.b32 %r11, %r17, 15;
    shr.s32 %r12, %r3, 31;
    sub.s32 %r18, %r3, %r17;
    mul.wide.u32 %rd10, %r18, %r11;
    shr.u32 %r26, %r3, 30;
    max.u32 %r14, %r3, %r27;
    sub.u64 %rd15, %rd10, %rd10;
    xor.b32 %r26, %r12, 65536;
    mad.lo.u32 %r9, %r27, %r14, %r12;
    and.b32 %r18, %r3, %r12;
    mad.lo.s32 %r10, %r12, %r18, %r9;
    shl.b32 %r23, %r9, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
