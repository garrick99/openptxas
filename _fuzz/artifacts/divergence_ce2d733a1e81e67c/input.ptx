.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    shr.s64 %rd14, %rd10, 3;
    shl.b32 %r21, %r3, 2;
    cvt.u64.u32 %rd8, %r3;
    add.u64 %rd10, %rd8, %rd8;
    setp.hs.u32 %p2, %r21, %r3;
    @!%p2 shr.u32 %r12, %r3, 30;
    max.u32 %r11, %r21, %r12;
    setp.lo.u32 %p4, %r3, 256;
    @!%p4 add.u64 %rd10, %rd14, %rd14;
    mad.lo.u32 %r11, %r21, %r11, %r3;
    min.u32 %r9, %r3, %r11;
    shr.u64 %rd7, %rd14, 0;
    max.u32 %r6, %r9, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
