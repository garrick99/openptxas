.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r4, %r3, 255;
    cvt.s64.s32 %rd10, %r3;
    shl.b64 %rd12, %rd10, 48;
    mul.lo.u32 %r9, %r4, %r4;
    xor.b32 %r22, %r3, 65536;
    shr.s32 %r15, %r9, 0;
    shr.s32 %r12, %r9, 16;
    setp.lt.s32 %p2, %r12, %r9;
    @!%p2 mul.lo.s32 %r5, %r3, 3;
    setp.ls.u32 %p2, %r15, 1;
    @%p2 or.b32 %r23, %r22, 5;
    sub.u32 %r26, %r23, 4;
    or.b64 %rd8, %rd12, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
