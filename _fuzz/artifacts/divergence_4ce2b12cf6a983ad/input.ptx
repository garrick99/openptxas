.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r18, %r3, 2147483648;
    shr.u32 %r6, %r18, 0;
    add.s32 %r8, %r6, %r6;
    cvt.u64.u32 %rd8, %r8;
    mul.wide.u32 %rd5, %r8, %r18;
    cvt.u64.u32 %rd15, %r18;
    mul.lo.s32 %r9, %r3, 3;
    and.b32 %r16, %r6, 8;
    shr.u64 %rd7, %rd15, 33;
    max.u32 %r16, %r18, %r6;
    cvt.u64.u32 %rd8, %r18;
    sub.s64 %rd15, %rd15, %rd7;
    mul.wide.u32 %rd13, %r8, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
