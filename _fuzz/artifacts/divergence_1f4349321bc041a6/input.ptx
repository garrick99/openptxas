.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p2, %r3, %r3;
    setp.ne.s32 %p3, %r3, %r3;
    @%p3 cvt.s64.s32 %rd11, %r3;
    cvt.u32.u64 %r19, %rd11;
    shr.s64 %rd11, %rd11, 7;
    setp.le.s32 %p1, %r19, %r19;
    @%p1 mul.wide.s32 %rd13, %r19, %r19;
    max.u32 %r10, %r19, 63;
    shr.u32 %r17, %r19, 3;
    mul.lo.u32 %r17, %r3, %r3;
    shl.b32 %r22, %r19, 7;
    mul.lo.s32 %r20, %r22, %r19;
    mul.lo.s32 %r13, %r3, %r19;
    setp.ls.u32 %p4, %r19, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
