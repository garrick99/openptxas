.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd12, %r3, %r3;
    cvt.u32.u64 %r11, %rd12;
    mul.lo.s32 %r19, %r3, 64;
    shr.s64 %rd7, %rd12, 47;
    cvt.s64.s32 %rd10, %r19;
    shr.s32 %r5, %r11, 7;
    add.u32 %r7, %r11, %r19;
    xor.b32 %r14, %r7, 65535;
    mul.lo.s32 %r17, %r11, %r5;
    mul.lo.u32 %r13, %r3, 16;
    setp.lt.u32 %p1, %r14, 65536;
    @%p1 cvt.u32.u64 %r27, %rd7;
    setp.hs.u32 %p2, %r11, 63;
    @%p2 or.b32 %r8, %r11, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
