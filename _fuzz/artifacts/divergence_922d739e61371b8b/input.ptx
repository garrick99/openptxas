.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p3, %r3, 1;
    @%p3 mad.lo.u32 %r15, %r3, %r3, %r3;
    cvt.s64.s32 %rd6, %r15;
    or.b32 %r4, %r15, %r3;
    max.u32 %r27, %r4, %r15;
    setp.ne.s32 %p3, %r15, 7;
    shr.s32 %r8, %r4, 30;
    mul.lo.u64 %rd10, %rd6, %rd6;
    max.s32 %r25, %r27, %r3;
    cvt.u32.u64 %r7, %rd10;
    cvt.s32.s64 %r13, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
