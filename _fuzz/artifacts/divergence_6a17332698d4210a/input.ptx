.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r15, %r3, 4;
    sub.s32 %r16, %r3, %r3;
    max.s32 %r16, %r15, %r15;
    sub.u32 %r27, %r16, 0;
    shr.s32 %r14, %r27, 4;
    setp.eq.s32 %p4, %r16, 32;
    mad.lo.u32 %r24, %r14, %r15, %r27;
    sub.s32 %r24, %r27, %r3;
    setp.ge.u32 %p1, %r15, 8;
    @%p1 mad.lo.u32 %r24, %r14, %r15, %r24;
    shr.s32 %r10, %r15, 15;
    mad.lo.s32 %r10, %r27, %r14, %r14;
    add.u32 %r5, %r3, 255;
    max.s32 %r19, %r10, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
