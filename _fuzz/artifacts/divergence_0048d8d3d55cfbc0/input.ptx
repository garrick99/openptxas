.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    setp.hi.u32 %p4, %r3, %r3;
    @%p4 sub.u32 %r8, %r3, 255;
    setp.gt.u32 %p4, %r8, %r3;
    @!%p4 sub.u32 %r13, %r3, 65536;
    setp.lo.u32 %p4, %r8, 2147483648;
    setp.ge.s32 %p1, %r8, 2147483648;
    @%p1 and.b32 %r21, %r8, %r8;
    mul.wide.u32 %rd6, %r8, %r3;
    mul.lo.u32 %r14, %r3, %r13;
    mul.wide.u32 %rd9, %r13, %r14;
    mad.lo.u32 %r17, %r13, %r14, %r21;
    mul.wide.u32 %rd12, %r8, %r17;
    mad.lo.u32 %r17, %r13, %r3, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
