.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r9, %r3, 15;
    cvt.s64.s32 %rd5, %r3;
    mul.lo.s32 %r10, %r9, %r9;
    mul.lo.u64 %rd15, %rd5, %rd5;
    mul.lo.u32 %r10, %r9, 65535;
    shl.b64 %rd12, %rd5, 30;
    min.u32 %r26, %r9, 31;
    cvt.s64.s32 %rd11, %r10;
    mul.lo.u32 %r12, %r3, 256;
    shr.s64 %rd8, %rd15, 33;
    shl.b32 %r20, %r10, 0;
    shr.u32 %r5, %r12, 15;
    cvt.s32.s64 %r18, %rd11;
    shr.s64 %rd7, %rd5, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
