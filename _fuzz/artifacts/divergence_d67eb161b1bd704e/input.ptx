.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r19, %r3, 256;
    xor.b32 %r23, %r3, %r3;
    cvt.s64.s32 %rd11, %r19;
    sub.s32 %r11, %r3, 65535;
    add.s32 %r24, %r3, 256;
    shr.s64 %rd13, %rd11, 30;
    cvt.s64.s32 %rd6, %r19;
    mul.wide.u32 %rd5, %r24, %r11;
    setp.ne.s32 %p2, %r3, %r23;
    @!%p2 and.b32 %r10, %r3, %r24;
    shl.b32 %r4, %r10, 3;
    selp.b32 %r16, %r10, %r19, %p2;
    sub.u64 %rd6, %rd13, %rd13;
    shr.s32 %r15, %r4, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
