.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r7, %r3, %r3;
    cvt.u64.u32 %rd12, %r7;
    cvt.s64.s32 %rd5, %r7;
    sub.u32 %r27, %r3, %r7;
    max.u64 %rd13, %rd5, %rd5;
    mad.lo.u32 %r18, %r7, %r27, %r3;
    shl.b64 %rd5, %rd12, 7;
    add.u32 %r15, %r7, 15;
    add.s32 %r22, %r18, %r18;
    mul.lo.u32 %r6, %r18, %r3;
    mul.lo.u32 %r7, %r7, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
