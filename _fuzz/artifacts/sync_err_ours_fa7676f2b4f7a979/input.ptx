.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    mul.wide.u32 %rd13, %r3, %r3;
    cvt.s32.s64 %r24, %rd13;
    mad.lo.s32 %r6, %r24, %r3, %r3;
    cvt.s32.s64 %r18, %rd13;
    and.b32 %r6, %r18, %r24;
    shl.b64 %rd14, %rd13, 48;
    min.u32 %r21, %r3, %r18;
    shr.s32 %r4, %r21, 3;
    min.u32 %r21, %r4, 8;
    setp.ne.u32 %p3, %r3, 0;
    @!%p3 shr.u64 %rd8, %rd14, 3;
    mul.lo.u64 %rd14, %rd13, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
