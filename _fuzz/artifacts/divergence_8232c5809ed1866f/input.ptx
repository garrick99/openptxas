.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p1, %r3, 2147483647;
    @!%p1 max.s32 %r7, %r3, %r3;
    add.s32 %r15, %r7, 0;
    sub.s32 %r8, %r15, %r15;
    or.b32 %r27, %r3, %r7;
    or.b32 %r16, %r7, 4294967295;
    cvt.u64.u32 %rd14, %r8;
    cvt.u32.u64 %r26, %rd14;
    and.b64 %rd14, %rd14, %rd14;
    sub.u32 %r7, %r26, %r16;
    mul.wide.s32 %rd5, %r3, %r27;
    sub.s32 %r26, %r26, %r27;
    mul.wide.s32 %rd8, %r15, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
