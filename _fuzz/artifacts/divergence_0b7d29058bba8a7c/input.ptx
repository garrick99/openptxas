.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    max.u64 %rd10, %rd11, %rd11;
    cvt.u32.u64 %r5, %rd10;
    setp.lt.u32 %p3, %r5, %r5;
    @%p3 cvt.s32.s64 %r11, %rd11;
    cvt.u64.u32 %rd14, %r11;
    shr.s32 %r17, %r5, 31;
    min.s32 %r5, %r5, 4;
    xor.b32 %r4, %r3, %r3;
    cvt.s32.s64 %r23, %rd10;
    max.s32 %r14, %r11, 4294967295;
    cvt.s64.s32 %rd12, %r14;
    or.b32 %r26, %r11, %r4;
    mad.lo.u32 %r4, %r23, %r11, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
