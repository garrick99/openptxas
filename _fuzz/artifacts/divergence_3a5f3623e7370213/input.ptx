.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p1, %r3, %r3;
    @%p1 sub.s32 %r9, %r3, %r3;
    mad.lo.s32 %r5, %r3, %r3, %r9;
    sub.u32 %r5, %r5, %r3;
    add.s32 %r4, %r9, 4;
    sub.s32 %r19, %r3, 8;
    xor.b32 %r23, %r4, %r19;
    setp.eq.s32 %p4, %r9, %r5;
    @!%p4 sub.s32 %r15, %r23, 7;
    shr.s32 %r26, %r19, 15;
    cvt.s64.s32 %rd9, %r23;
    and.b32 %r17, %r26, 32;
    selp.b32 %r26, %r3, %r17, %p4;
    setp.lt.u32 %p3, %r9, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
