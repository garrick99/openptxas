.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    max.u32 %r13, %r3, 32;
    setp.ge.s32 %p3, %r13, %r3;
    add.s32 %r16, %r3, 64;
    setp.eq.s32 %p1, %r13, %r13;
    @!%p1 max.s64 %rd9, %rd15, %rd15;
    min.s64 %rd8, %rd15, %rd9;
    sub.s64 %rd12, %rd15, %rd9;
    mul.lo.s32 %r27, %r16, %r16;
    mul.lo.u32 %r17, %r16, 31;
    mad.lo.u32 %r19, %r17, %r16, %r3;
    min.s32 %r9, %r27, 256;
    shr.u32 %r24, %r17, 7;
    xor.b32 %r11, %r3, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
