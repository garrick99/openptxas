.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    max.u32 %r25, %r3, %r3;
    cvt.u32.u64 %r6, %rd8;
    mad.lo.s32 %r22, %r3, %r3, %r25;
    mul.lo.u32 %r25, %r6, %r22;
    mul.lo.u32 %r5, %r22, %r6;
    cvt.s64.s32 %rd11, %r25;
    mad.lo.u32 %r22, %r22, %r22, %r5;
    max.u32 %r22, %r3, 31;
    shr.u64 %rd8, %rd11, 7;
    mad.lo.u32 %r17, %r6, %r6, %r5;
    mad.lo.u32 %r9, %r5, %r22, %r25;
    sub.u32 %r5, %r17, %r25;
    setp.lt.s32 %p2, %r3, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
