.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r23, %r3, %r3;
    and.b32 %r10, %r3, 65535;
    mul.lo.s32 %r8, %r10, 64;
    sub.u32 %r19, %r10, 65536;
    cvt.u64.u32 %rd11, %r10;
    min.u32 %r9, %r23, 15;
    shl.b32 %r22, %r23, 15;
    setp.gt.s32 %p2, %r3, 65536;
    @!%p2 mul.wide.s32 %rd14, %r22, %r22;
    or.b32 %r7, %r8, 32;
    cvt.u32.u64 %r27, %rd11;
    setp.ne.u32 %p4, %r8, %r10;
    mad.lo.s32 %r20, %r27, %r10, %r19;
    and.b32 %r21, %r27, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
