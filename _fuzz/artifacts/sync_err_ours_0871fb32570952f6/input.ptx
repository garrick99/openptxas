.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p4, %r3, 3;
    add.u32 %r25, %r3, 7;
    cvt.s64.s32 %rd13, %r3;
    max.u32 %r24, %r25, %r25;
    max.s32 %r9, %r25, %r24;
    and.b32 %r10, %r9, %r24;
    mul.wide.s32 %rd6, %r24, %r9;
    max.s32 %r26, %r25, %r9;
    shr.u32 %r20, %r3, 16;
    selp.b32 %r18, %r20, %r25, %p4;
    setp.hi.u32 %p3, %r9, 256;
    @%p3 min.s32 %r24, %r20, 63;
    xor.b32 %r19, %r25, %r9;
    selp.b32 %r10, %r18, %r18, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
