.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r8, %r3, %r3;
    min.u32 %r9, %r8, %r3;
    setp.ne.s32 %p2, %r9, 63;
    @%p2 cvt.u64.u32 %rd11, %r9;
    mul.wide.s32 %rd9, %r9, %r8;
    selp.b32 %r6, %r9, %r9, %p2;
    setp.ne.s32 %p1, %r8, %r8;
    @%p1 mad.lo.u32 %r21, %r8, %r6, %r8;
    and.b64 %rd6, %rd11, %rd9;
    mul.wide.u32 %rd6, %r6, %r9;
    max.u32 %r27, %r21, %r8;
    mul.lo.s32 %r19, %r9, %r8;
    xor.b32 %r14, %r6, %r19;
    setp.le.s32 %p3, %r19, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
