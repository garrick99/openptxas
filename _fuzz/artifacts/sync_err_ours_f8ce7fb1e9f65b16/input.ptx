.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r15, %r3, %r3;
    cvt.u64.u32 %rd13, %r3;
    max.u32 %r27, %r15, 7;
    min.s32 %r4, %r27, %r27;
    xor.b32 %r26, %r3, %r15;
    cvt.u64.u32 %rd10, %r4;
    add.s64 %rd11, %rd13, %rd10;
    shl.b32 %r21, %r4, 31;
    sub.s64 %rd13, %rd13, %rd11;
    setp.le.s32 %p3, %r26, 16;
    shr.u64 %rd10, %rd11, 0;
    cvt.u64.u32 %rd5, %r21;
    add.u32 %r18, %r15, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
