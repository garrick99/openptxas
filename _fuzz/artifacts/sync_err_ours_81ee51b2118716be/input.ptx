.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r23, %r3, 8;
    mad.lo.s32 %r6, %r23, %r3, %r3;
    mad.lo.s32 %r9, %r6, %r3, %r23;
    mul.wide.u32 %rd9, %r9, %r9;
    and.b32 %r5, %r3, %r6;
    sub.s32 %r17, %r9, %r6;
    or.b64 %rd12, %rd9, %rd9;
    and.b32 %r10, %r23, %r17;
    mul.wide.u32 %rd10, %r5, %r6;
    shr.s64 %rd13, %rd9, 16;
    add.s32 %r23, %r5, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
