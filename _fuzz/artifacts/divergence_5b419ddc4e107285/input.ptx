.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r14, %r3, %r3;
    cvt.s64.s32 %rd11, %r14;
    setp.lo.u32 %p2, %r3, %r3;
    @%p2 sub.s32 %r25, %r3, %r14;
    shr.s32 %r22, %r25, 4;
    mul.lo.u32 %r22, %r25, %r3;
    add.s32 %r14, %r22, %r22;
    mul.wide.u32 %rd11, %r25, %r22;
    shr.u32 %r17, %r14, 7;
    cvt.s32.s64 %r7, %rd11;
    sub.u32 %r19, %r14, %r22;
    add.u32 %r20, %r22, %r3;
    mad.lo.u32 %r6, %r14, %r17, %r22;
    shr.u64 %rd5, %rd11, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
