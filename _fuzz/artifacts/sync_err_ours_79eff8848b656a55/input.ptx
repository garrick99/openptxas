.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    setp.gt.s32 %p3, %r3, 2147483647;
    min.s32 %r15, %r3, 32;
    cvt.u32.u64 %r8, %rd6;
    xor.b32 %r11, %r3, %r3;
    cvt.u64.u32 %rd11, %r8;
    shr.u32 %r12, %r8, 4;
    min.s32 %r9, %r8, 3;
    sub.s32 %r19, %r15, 4;
    shr.s64 %rd12, %rd11, 2;
    setp.lt.s32 %p3, %r19, 256;
    @%p3 add.s32 %r23, %r19, 7;
    mul.lo.s32 %r18, %r8, %r12;
    cvt.u32.u64 %r6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
