.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p1, %r3, 7;
    @%p1 sub.s32 %r21, %r3, 255;
    cvt.s64.s32 %rd13, %r21;
    add.u32 %r25, %r21, 5;
    shr.s32 %r20, %r21, 1;
    setp.ne.s32 %p2, %r21, 2147483647;
    shl.b32 %r22, %r25, 2;
    mul.wide.s32 %rd12, %r3, %r22;
    cvt.s64.s32 %rd11, %r3;
    add.u32 %r24, %r21, 65535;
    and.b64 %rd8, %rd13, %rd13;
    selp.b32 %r18, %r3, %r20, %p1;
    mul.lo.s32 %r13, %r3, %r22;
    shr.s64 %rd13, %rd12, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
