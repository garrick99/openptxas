.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r17, %r3, 16;
    or.b32 %r13, %r3, %r3;
    setp.ne.s32 %p2, %r13, %r17;
    @!%p2 mul.wide.u32 %rd14, %r3, %r13;
    and.b32 %r16, %r17, %r13;
    selp.b32 %r13, %r3, %r13, %p2;
    shl.b32 %r26, %r17, 0;
    shr.s32 %r5, %r17, 7;
    or.b64 %rd11, %rd14, %rd14;
    selp.b32 %r14, %r5, %r17, %p2;
    mul.wide.u32 %rd8, %r14, %r13;
    cvt.s64.s32 %rd14, %r5;
    cvt.s32.s64 %r9, %rd11;
    and.b32 %r21, %r9, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
