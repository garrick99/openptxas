.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r4, %r3, %r3;
    cvt.u64.u32 %rd9, %r3;
    cvt.u64.u32 %rd15, %r4;
    or.b32 %r17, %r4, %r4;
    cvt.u64.u32 %rd14, %r17;
    cvt.s64.s32 %rd10, %r3;
    shr.s32 %r11, %r4, 2;
    shl.b32 %r26, %r4, 0;
    shr.s64 %rd14, %rd10, 32;
    mul.wide.u32 %rd8, %r4, %r3;
    cvt.u64.u32 %rd7, %r26;
    sub.u32 %r8, %r26, %r26;
    cvt.u32.u64 %r13, %rd10;
    shr.s64 %rd10, %rd10, 62;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
