.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r5, %r3, 4294967295;
    cvt.u64.u32 %rd9, %r3;
    or.b32 %r20, %r5, %r3;
    cvt.s32.s64 %r13, %rd9;
    setp.hi.u32 %p1, %r20, 3;
    sub.u64 %rd12, %rd9, %rd9;
    sub.u32 %r27, %r20, %r13;
    shr.u32 %r7, %r27, 16;
    selp.b32 %r22, %r13, %r13, %p1;
    max.s32 %r21, %r22, %r27;
    mad.lo.s32 %r8, %r20, %r21, %r21;
    setp.gt.u32 %p4, %r5, 31;
    setp.ge.u32 %p3, %r21, %r5;
    @%p3 add.u32 %r16, %r7, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
