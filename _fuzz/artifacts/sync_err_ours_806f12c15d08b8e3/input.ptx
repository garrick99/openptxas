.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r11, %r3, 256;
    sub.s32 %r20, %r3, 32;
    mul.wide.u32 %rd11, %r20, %r3;
    setp.ls.u32 %p1, %r20, 65535;
    shl.b32 %r9, %r3, 0;
    shr.u64 %rd6, %rd11, 0;
    shl.b32 %r19, %r20, 30;
    add.s32 %r10, %r11, %r19;
    sub.u64 %rd10, %rd6, %rd11;
    cvt.s64.s32 %rd11, %r3;
    sub.u32 %r9, %r3, %r19;
    and.b32 %r22, %r10, %r11;
    mul.wide.u32 %rd9, %r10, %r3;
    min.s32 %r7, %r22, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
