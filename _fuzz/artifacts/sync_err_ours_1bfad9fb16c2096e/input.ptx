.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r5, %r3, %r3, %r3;
    mul.wide.s32 %rd7, %r3, %r3;
    shl.b32 %r7, %r5, 1;
    mul.wide.s32 %rd12, %r3, %r5;
    min.s32 %r19, %r5, 255;
    sub.s32 %r9, %r5, 2;
    and.b32 %r26, %r3, 256;
    max.s32 %r21, %r3, 255;
    setp.lt.u32 %p4, %r9, %r9;
    mul.wide.s32 %rd13, %r7, %r9;
    setp.ge.u32 %p2, %r9, 0;
    @%p2 mul.wide.s32 %rd8, %r9, %r9;
    add.s32 %r25, %r26, 7;
    add.s32 %r23, %r9, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
