.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    or.b32 %r26, %r3, %r3;
    shl.b32 %r9, %r26, 16;
    add.u32 %r25, %r26, %r3;
    cvt.s32.s64 %r22, %rd5;
    cvt.u64.u32 %rd11, %r9;
    shr.u32 %r25, %r9, 4;
    xor.b32 %r16, %r26, %r3;
    setp.ne.s32 %p2, %r3, %r3;
    sub.u32 %r8, %r22, %r3;
    shl.b32 %r18, %r25, 16;
    setp.le.u32 %p1, %r9, 7;
    and.b64 %rd9, %rd11, %rd11;
    min.s32 %r16, %r22, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
