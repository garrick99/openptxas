    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r24, %r3, 4294967295;
    setp.hs.u32 %p4, %r3, %r24;
    @%p4 cvt.s64.s32 %rd11, %r24;
    max.s32 %r16, %r3, 2147483647;
    mad.lo.s32 %r5, %r24, %r16, %r24;
    xor.b32 %r6, %r5, %r16;
    setp.ge.u32 %p3, %r6, 256;
    @%p3 mul.wide.s32 %rd6, %r16, %r5;
    mul.wide.s32 %rd15, %r6, %r5;
    shl.b64 %rd13, %rd11, 1;
    and.b32 %r24, %r16, 2147483648;
    cvt.u64.u32 %rd7, %r3;
    and.b32 %r26, %r16, 2147483647;
    max.s32 %r22, %r16, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
