.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd5, %r3, %r3;
    max.u32 %r6, %r3, %r3;
    setp.lt.s32 %p3, %r3, 4294967295;
    @!%p3 mul.lo.s32 %r23, %r6, 65536;
    cvt.u64.u32 %rd5, %r23;
    shl.b64 %rd5, %rd5, 63;
    cvt.u32.u64 %r19, %rd5;
    max.s32 %r19, %r3, 2;
    add.u64 %rd5, %rd5, %rd5;
    mad.lo.s32 %r25, %r6, %r6, %r19;
    cvt.u64.u32 %rd13, %r6;
    mad.lo.u32 %r5, %r25, %r23, %r6;
    cvt.s32.s64 %r9, %rd5;
    min.s32 %r19, %r25, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
