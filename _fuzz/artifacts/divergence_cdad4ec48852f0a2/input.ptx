    vote.sync.ballot.b32 %r15, %p3, -1;
    shfl.sync.down.b32 %r11, %r3, 8, 0x1f, -1;
    shfl.sync.idx.b32 %r16, %r17, 15, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
