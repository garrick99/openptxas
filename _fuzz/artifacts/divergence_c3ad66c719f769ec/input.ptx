.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r23, %r3, %r3, %r3;
    max.u32 %r10, %r3, %r23;
    sub.u32 %r19, %r10, %r23;
    mul.wide.u32 %rd7, %r23, %r19;
    shr.s32 %r22, %r10, 3;
    add.u32 %r6, %r23, %r22;
    shr.s64 %rd14, %rd7, 7;
    mul.lo.u32 %r12, %r23, 4294967295;
    mul.wide.u32 %rd7, %r22, %r19;
    shr.s32 %r5, %r6, 2;
    shr.u32 %r8, %r5, 7;
    min.s32 %r4, %r3, %r10;
    mul.lo.u32 %r16, %r19, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
