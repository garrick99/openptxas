.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r21, %r3, %r3;
    cvt.u64.u32 %rd13, %r21;
    or.b64 %rd14, %rd13, %rd13;
    sub.s64 %rd7, %rd14, %rd14;
    cvt.u32.u64 %r4, %rd14;
    mul.wide.s32 %rd9, %r21, %r4;
    max.u32 %r21, %r3, %r4;
    max.s32 %r27, %r4, %r3;
    mul.lo.u32 %r4, %r3, %r4;
    min.u32 %r26, %r21, 32;
    add.s32 %r15, %r26, %r3;
    add.s32 %r15, %r27, %r15;
    xor.b32 %r21, %r26, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
