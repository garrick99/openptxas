    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    mul.wide.u32 %rd5, %r3, %r3;
    setp.gt.s32 %p4, %r3, 32;
    @!%p4 and.b32 %r22, %r3, %r3;
    min.s32 %r15, %r3, 4294967295;
    add.u32 %r7, %r15, %r15;
    min.s64 %rd12, %rd5, %rd5;
    sub.u32 %r19, %r22, 16;
    mad.lo.u32 %r24, %r15, %r7, %r22;
    selp.b32 %r9, %r3, %r22, %p4;
    add.s32 %r21, %r3, %r24;
    selp.b32 %r15, %r19, %r21, %p4;
    shl.b64 %rd11, %rd9, 31;
    cvt.u32.u64 %r27, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
