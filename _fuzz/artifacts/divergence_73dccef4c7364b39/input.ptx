.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r18, %r3, %r3;
    xor.b32 %r14, %r18, 1;
    mad.lo.s32 %r26, %r18, %r18, %r18;
    cvt.s64.s32 %rd11, %r26;
    or.b64 %rd13, %rd11, %rd11;
    mul.lo.u32 %r11, %r3, %r18;
    max.u32 %r22, %r18, 2147483647;
    mad.lo.s32 %r21, %r26, %r14, %r11;
    mul.lo.s32 %r4, %r3, %r18;
    max.u32 %r22, %r3, 1;
    cvt.s32.s64 %r11, %rd11;
    mul.lo.u32 %r16, %r18, %r4;
    xor.b64 %rd8, %rd11, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
