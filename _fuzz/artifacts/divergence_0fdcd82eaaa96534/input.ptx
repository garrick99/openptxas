.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r4, %r3, 7;
    and.b32 %r6, %r4, 65535;
    max.s32 %r15, %r4, 255;
    cvt.s64.s32 %rd12, %r6;
    setp.ne.u32 %p2, %r15, %r6;
    @%p2 mul.wide.s32 %rd9, %r6, %r3;
    setp.gt.s32 %p4, %r15, %r6;
    @!%p4 mul.wide.u32 %rd15, %r15, %r15;
    mul.lo.s32 %r13, %r3, %r4;
    cvt.u32.u64 %r16, %rd15;
    setp.gt.s32 %p2, %r3, %r3;
    @!%p2 cvt.s64.s32 %rd7, %r13;
    mul.lo.u64 %rd14, %rd15, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
