.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p3, %r3, 64;
    shr.u32 %r13, %r3, 30;
    setp.lo.u32 %p2, %r13, 4294967295;
    and.b32 %r9, %r3, %r3;
    max.s32 %r6, %r13, 255;
    sub.u32 %r14, %r3, 7;
    max.u32 %r20, %r6, 7;
    shr.s32 %r6, %r9, 0;
    mad.lo.u32 %r12, %r20, %r3, %r13;
    or.b32 %r5, %r20, 16;
    setp.lt.s32 %p3, %r12, %r14;
    setp.hs.u32 %p2, %r12, 4294967295;
    @!%p2 mul.lo.u32 %r26, %r3, %r6;
    add.u32 %r22, %r20, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
