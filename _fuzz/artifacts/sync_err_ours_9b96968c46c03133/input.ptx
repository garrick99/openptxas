.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r15, %r3, 8;
    sub.s32 %r25, %r3, %r15;
    cvt.s64.s32 %rd10, %r3;
    sub.s32 %r7, %r15, %r3;
    sub.s32 %r26, %r15, 65536;
    add.s32 %r21, %r7, 0;
    sub.u32 %r6, %r25, 63;
    shr.u32 %r24, %r26, 0;
    xor.b32 %r19, %r15, %r25;
    shr.u64 %rd7, %rd10, 4;
    mul.wide.u32 %rd5, %r3, %r21;
    mad.lo.u32 %r10, %r3, %r15, %r24;
    xor.b32 %r26, %r10, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
