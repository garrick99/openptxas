.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r26, %r3, %r3, %r3;
    setp.le.s32 %p1, %r3, 1;
    @%p1 mul.lo.u32 %r21, %r26, %r26;
    min.u32 %r8, %r21, %r3;
    or.b32 %r27, %r21, %r8;
    min.u32 %r5, %r3, 1;
    sub.u32 %r10, %r21, 4294967295;
    add.s32 %r10, %r21, 256;
    sub.s32 %r10, %r3, %r21;
    max.s32 %r20, %r10, 5;
    selp.b32 %r21, %r8, %r27, %p1;
    mul.wide.u32 %rd8, %r21, %r8;
    or.b32 %r17, %r21, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
