.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r6, %r3, %r3;
    and.b32 %r11, %r3, %r6;
    max.s32 %r25, %r11, 65535;
    xor.b32 %r24, %r11, 4;
    max.u32 %r12, %r11, %r6;
    sub.s32 %r21, %r6, %r25;
    mad.lo.s32 %r25, %r24, %r6, %r11;
    xor.b32 %r25, %r21, %r21;
    setp.ne.u32 %p3, %r11, %r6;
    setp.eq.s32 %p2, %r3, %r11;
    @%p2 selp.b32 %r24, %r6, %r21, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
