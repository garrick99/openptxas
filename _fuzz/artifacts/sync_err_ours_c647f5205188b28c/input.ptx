.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    cvt.s32.s64 %r9, %rd10;
    and.b32 %r26, %r3, %r9;
    shr.s32 %r24, %r3, 30;
    mul.wide.u32 %rd8, %r26, %r9;
    cvt.s32.s64 %r16, %rd10;
    shr.s32 %r9, %r24, 3;
    or.b64 %rd5, %rd10, %rd8;
    mul.lo.u64 %rd11, %rd10, %rd10;
    shl.b32 %r18, %r16, 3;
    mad.lo.u32 %r19, %r16, %r9, %r24;
    shl.b32 %r5, %r24, 30;
    sub.u32 %r27, %r5, 65535;
    add.s32 %r26, %r24, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
