.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r27, %r3, 32;
    min.s32 %r8, %r3, 16;
    mul.lo.s32 %r20, %r3, 31;
    cvt.u64.u32 %rd13, %r8;
    shr.u64 %rd13, %rd13, 30;
    sub.u32 %r25, %r3, %r8;
    min.u32 %r27, %r27, %r8;
    cvt.s64.s32 %rd12, %r27;
    min.s32 %r4, %r25, %r25;
    mad.lo.u32 %r22, %r27, %r25, %r27;
    mul.wide.u32 %rd13, %r8, %r3;
    cvt.s32.s64 %r14, %rd12;
    cvt.u64.u32 %rd10, %r22;
    min.s32 %r6, %r4, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
