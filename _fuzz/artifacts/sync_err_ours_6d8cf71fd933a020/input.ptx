.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    max.s64 %rd14, %rd9, %rd9;
    shl.b32 %r8, %r3, 4;
    sub.u32 %r7, %r3, 1;
    shr.u32 %r21, %r3, 1;
    shr.s64 %rd11, %rd9, 1;
    and.b64 %rd5, %rd14, %rd14;
    cvt.s32.s64 %r25, %rd9;
    sub.u32 %r15, %r3, %r7;
    min.s32 %r27, %r8, %r7;
    sub.u64 %rd11, %rd9, %rd11;
    shl.b32 %r15, %r27, 3;
    shl.b32 %r24, %r15, 1;
    sub.s32 %r6, %r15, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
