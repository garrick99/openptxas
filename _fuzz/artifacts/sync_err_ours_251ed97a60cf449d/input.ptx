.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    xor.b32 %r20, %r3, %r3;
    mul.wide.u32 %rd6, %r20, %r3;
    sub.u32 %r4, %r3, %r20;
    sub.u32 %r12, %r20, 255;
    mul.wide.s32 %rd14, %r20, %r20;
    and.b32 %r19, %r12, %r4;
    max.u32 %r25, %r4, %r3;
    add.s32 %r14, %r12, %r25;
    cvt.u32.u64 %r17, %rd7;
    sub.u32 %r16, %r14, %r17;
    mad.lo.s32 %r7, %r14, %r19, %r14;
    xor.b32 %r16, %r20, %r4;
    mul.lo.s32 %r17, %r4, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
