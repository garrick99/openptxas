.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    mul.lo.s32 %r25, %r3, %r3;
    xor.b32 %r6, %r25, 2147483648;
    sub.u32 %r27, %r6, %r25;
    shr.s32 %r26, %r25, 0;
    cvt.u64.u32 %rd14, %r3;
    shr.u64 %rd6, %rd14, 1;
    setp.gt.u32 %p3, %r27, %r27;
    @%p3 sub.s64 %rd5, %rd9, %rd14;
    min.u64 %rd9, %rd5, %rd9;
    max.u32 %r12, %r25, %r25;
    setp.eq.s32 %p1, %r26, %r3;
    @%p1 mad.lo.u32 %r17, %r27, %r25, %r6;
    shr.u32 %r25, %r6, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
