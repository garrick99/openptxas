.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r22, %r3, 256;
    cvt.s64.s32 %rd6, %r22;
    mul.lo.u32 %r24, %r22, %r3;
    mul.lo.s32 %r7, %r24, 5;
    shl.b32 %r18, %r7, 3;
    shr.s32 %r23, %r24, 7;
    cvt.s64.s32 %rd6, %r24;
    shr.s64 %rd14, %rd6, 15;
    mul.lo.u32 %r27, %r23, 255;
    cvt.s32.s64 %r25, %rd14;
    min.s32 %r14, %r25, 16;
    shl.b32 %r18, %r3, 4;
    mad.lo.u32 %r9, %r14, %r3, %r3;
    max.u32 %r26, %r14, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
