.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.down.b32 %r12, %r0, 4, 0x1f, -1;
    shfl.sync.up.b32 %r15, %r3, 4, 0x1f, -1;
    max.u32 %r13, %r3, %r12;
    shfl.sync.idx.b32 %r18, %r0, 31, 0x1f, -1;
    shfl.sync.idx.b32 %r10, %r3, 1, 0x1f, -1;
    add.u32 %r11, %r0, %r10;
    setp.ge.u32 %p2, %r0, %r11;
    vote.sync.ballot.b32 %r10, %p2, -1;
    setp.lt.u32 %p2, %r18, %r13;
    vote.sync.ballot.b32 %r6, %p2, -1;
    setp.ne.u32 %p1, %r3, 2;
    vote.sync.ballot.b32 %r18, %p1, -1;
    setp.eq.u32 %p2, %r6, 8;
    vote.sync.ballot.b32 %r11, %p2, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
