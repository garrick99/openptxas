.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    mul.wide.u32 %rd7, %r3, %r3;
    mul.lo.s32 %r5, %r3, %r3;
    setp.gt.s32 %p2, %r3, 64;
    @!%p2 shl.b64 %rd10, %rd7, 48;
    shr.u32 %r12, %r5, 1;
    max.s32 %r16, %r5, 2147483648;
    shl.b64 %rd8, %rd15, 48;
    xor.b32 %r26, %r3, 2147483647;
    cvt.s32.s64 %r7, %rd15;
    min.s32 %r6, %r12, 256;
    shl.b64 %rd10, %rd10, 3;
    min.u32 %r9, %r5, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
