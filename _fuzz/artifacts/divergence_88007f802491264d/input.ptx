.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    setp.le.s32 %p2, %r3, %r3;
    add.s32 %r11, %r3, 64;
    mul.lo.s32 %r18, %r11, %r3;
    shl.b64 %rd9, %rd10, 48;
    shr.s32 %r25, %r18, 7;
    setp.eq.s32 %p1, %r18, 65535;
    @%p1 shl.b32 %r25, %r11, 0;
    setp.eq.s32 %p2, %r3, 2;
    min.s32 %r7, %r25, %r18;
    setp.gt.u32 %p3, %r18, %r25;
    @%p3 mad.lo.s32 %r16, %r7, %r11, %r3;
    selp.b32 %r24, %r18, %r7, %p2;
    and.b32 %r12, %r7, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
