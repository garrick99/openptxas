.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r26, %r3, %r3;
    mad.lo.u32 %r24, %r26, %r3, %r3;
    cvt.s64.s32 %rd15, %r26;
    mul.lo.s64 %rd9, %rd15, %rd15;
    min.u64 %rd11, %rd15, %rd9;
    mul.wide.u32 %rd9, %r24, %r3;
    setp.eq.s32 %p1, %r3, 0;
    min.u32 %r25, %r24, %r3;
    setp.le.s32 %p3, %r3, 256;
    xor.b32 %r21, %r24, %r25;
    shl.b32 %r10, %r24, 31;
    min.u32 %r26, %r24, 7;
    add.u32 %r5, %r21, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
