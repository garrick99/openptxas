.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r26, %r3, 4294967295;
    cvt.u64.u32 %rd15, %r26;
    mul.lo.s32 %r20, %r3, %r26;
    mul.lo.s32 %r14, %r3, %r3;
    xor.b32 %r17, %r14, %r3;
    mul.wide.u32 %rd10, %r14, %r20;
    shr.u32 %r10, %r17, 31;
    shr.s64 %rd5, %rd15, 63;
    mul.lo.u64 %rd13, %rd15, %rd15;
    cvt.u32.u64 %r15, %rd15;
    sub.s64 %rd9, %rd15, %rd15;
    max.s32 %r12, %r3, 255;
    setp.lt.s32 %p4, %r3, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
