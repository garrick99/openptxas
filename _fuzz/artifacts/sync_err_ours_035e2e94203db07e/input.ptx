.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    cvt.s32.s64 %r8, %rd8;
    add.s32 %r10, %r8, %r3;
    shl.b32 %r21, %r3, 7;
    cvt.u32.u64 %r23, %rd8;
    shl.b64 %rd7, %rd8, 31;
    shr.u32 %r15, %r21, 3;
    min.u64 %rd8, %rd7, %rd8;
    shr.s32 %r22, %r15, 31;
    shl.b64 %rd15, %rd8, 30;
    add.u32 %r27, %r22, %r8;
    max.s32 %r9, %r22, %r22;
    max.u32 %r27, %r21, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
