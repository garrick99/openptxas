.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r25, %r3, 3;
    setp.le.u32 %p1, %r3, 2;
    @%p1 min.u32 %r11, %r3, 65535;
    mul.wide.s32 %rd15, %r3, %r11;
    setp.eq.s32 %p4, %r11, 255;
    @%p4 mad.lo.s32 %r25, %r25, %r3, %r25;
    mul.lo.s32 %r6, %r25, 65536;
    and.b32 %r7, %r25, %r11;
    max.s32 %r5, %r25, %r3;
    sub.u32 %r18, %r11, %r5;
    mad.lo.u32 %r7, %r7, %r6, %r18;
    xor.b32 %r6, %r7, %r18;
    max.u32 %r20, %r3, %r3;
    cvt.u32.u64 %r10, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
