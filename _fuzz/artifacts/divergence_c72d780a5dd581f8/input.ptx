.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd13, %r3, %r3;
    mul.lo.u32 %r5, %r3, 256;
    add.s32 %r4, %r5, 15;
    add.s32 %r21, %r3, %r5;
    mad.lo.u32 %r12, %r5, %r4, %r21;
    setp.ge.s32 %p1, %r4, %r12;
    @%p1 mad.lo.u32 %r22, %r21, %r4, %r3;
    selp.b32 %r17, %r12, %r3, %p1;
    sub.u64 %rd8, %rd13, %rd13;
    add.s32 %r9, %r4, %r12;
    xor.b64 %rd9, %rd8, %rd13;
    shr.s64 %rd12, %rd8, 15;
    setp.ne.u32 %p1, %r9, 65536;
    @!%p1 and.b32 %r18, %r21, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
