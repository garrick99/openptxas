.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r19, %r3, %r3, %r3;
    min.u32 %r25, %r19, %r3;
    mul.wide.u32 %rd6, %r25, %r19;
    mul.wide.u32 %rd8, %r19, %r3;
    max.s32 %r18, %r25, 65536;
    setp.eq.s32 %p4, %r3, 2147483647;
    @%p4 and.b32 %r22, %r3, 7;
    setp.lo.u32 %p1, %r3, %r19;
    @%p1 max.u32 %r20, %r19, %r3;
    setp.eq.s32 %p2, %r22, 7;
    @!%p2 mad.lo.s32 %r4, %r22, %r19, %r3;
    cvt.s32.s64 %r16, %rd8;
    or.b32 %r8, %r4, %r20;
    shl.b32 %r22, %r8, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
