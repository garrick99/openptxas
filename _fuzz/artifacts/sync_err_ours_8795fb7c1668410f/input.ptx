.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    min.u32 %r16, %r3, %r3;
    or.b32 %r20, %r16, %r3;
    sub.u32 %r24, %r3, %r20;
    add.u32 %r16, %r3, %r24;
    sub.u32 %r18, %r16, 63;
    min.s32 %r16, %r24, 3;
    and.b32 %r22, %r3, %r18;
    cvt.s64.s32 %rd6, %r20;
    shr.u64 %rd10, %rd6, 48;
    cvt.u32.u64 %r21, %rd10;
    sub.u32 %r16, %r22, 32;
    shl.b64 %rd11, %rd10, 4;
    sub.s32 %r21, %r3, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
