.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    cvt.s32.s64 %r23, %rd14;
    sub.u64 %rd6, %rd14, %rd14;
    setp.hs.u32 %p4, %r3, %r3;
    @!%p4 sub.u32 %r18, %r23, 7;
    mul.wide.s32 %rd11, %r3, %r3;
    mul.wide.u32 %rd12, %r18, %r3;
    xor.b64 %rd15, %rd14, %rd6;
    shr.s32 %r11, %r18, 3;
    mad.lo.u32 %r15, %r18, %r11, %r18;
    shr.s32 %r17, %r11, 31;
    add.s32 %r8, %r15, %r15;
    mad.lo.u32 %r27, %r8, %r23, %r17;
    shr.u32 %r16, %r15, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
