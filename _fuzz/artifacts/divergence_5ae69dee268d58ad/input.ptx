.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p1, %r3, 2147483647;
    @%p1 mul.wide.s32 %rd5, %r3, %r3;
    min.s64 %rd10, %rd5, %rd5;
    cvt.s32.s64 %r26, %rd5;
    setp.gt.s32 %p3, %r26, 31;
    @%p3 or.b32 %r17, %r3, %r3;
    sub.s32 %r6, %r26, 3;
    sub.s32 %r21, %r3, 4;
    shr.s64 %rd14, %rd10, 63;
    mul.wide.u32 %rd10, %r17, %r17;
    add.u32 %r7, %r26, %r21;
    setp.lt.u32 %p1, %r26, %r21;
    @%p1 sub.s32 %r25, %r17, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
