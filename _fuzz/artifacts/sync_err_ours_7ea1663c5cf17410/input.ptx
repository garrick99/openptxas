.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r26, %r3, %r3, %r3;
    add.s32 %r15, %r26, %r3;
    xor.b32 %r13, %r15, %r15;
    min.u32 %r23, %r26, %r13;
    add.u32 %r8, %r26, 0;
    sub.u32 %r14, %r8, %r26;
    or.b32 %r15, %r8, 31;
    and.b32 %r11, %r3, 255;
    mad.lo.s32 %r23, %r26, %r11, %r26;
    mul.wide.u32 %rd5, %r26, %r23;
    shr.s32 %r14, %r14, 0;
    mul.wide.s32 %rd6, %r26, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
