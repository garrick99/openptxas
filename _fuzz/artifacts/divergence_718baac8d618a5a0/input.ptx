.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p3, %r3, 3;
    @%p3 sub.s32 %r13, %r3, 8;
    cvt.s64.s32 %rd14, %r13;
    shr.u32 %r23, %r13, 2;
    shr.u32 %r10, %r23, 31;
    add.s64 %rd11, %rd14, %rd14;
    mad.lo.u32 %r15, %r13, %r23, %r3;
    or.b32 %r15, %r3, %r23;
    shr.s64 %rd10, %rd11, 31;
    add.u32 %r26, %r15, %r10;
    sub.s32 %r25, %r23, 255;
    max.s32 %r5, %r10, %r23;
    cvt.s32.s64 %r20, %rd11;
    add.s32 %r17, %r13, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
