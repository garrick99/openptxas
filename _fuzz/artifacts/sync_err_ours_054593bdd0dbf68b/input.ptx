.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p4, %r3, %r3;
    @!%p4 shl.b32 %r13, %r3, 4;
    mul.wide.s32 %rd10, %r13, %r13;
    min.u64 %rd13, %rd10, %rd10;
    add.s32 %r18, %r13, %r13;
    max.s64 %rd13, %rd10, %rd13;
    max.s64 %rd5, %rd10, %rd13;
    min.u32 %r20, %r3, 8;
    selp.b32 %r12, %r20, %r13, %p4;
    shl.b32 %r7, %r13, 0;
    mul.lo.u32 %r24, %r13, 2147483647;
    max.u32 %r18, %r3, 2;
    mul.wide.s32 %rd14, %r12, %r12;
    add.u32 %r22, %r18, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
