.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfi.b32 %r20, %r3, %r3, 0, 24;
    bfi.b32 %r18, %r3, %r20, 7, 32;
    bfe.u32 %r23, %r3, 16, 24;
    sub.u32 %r13, %r20, %r18;
    bfi.b32 %r19, %r13, %r3, 16, 16;
    bfi.b32 %r18, %r19, %r19, 24, 32;
    bfi.b32 %r8, %r19, %r3, 16, 4;
    clz.b32 %r5, %r13;
    bfe.s32 %r13, %r5, 23, 8;
    bfi.b32 %r20, %r23, %r19, 7, 4;
    bfe.u32 %r17, %r20, 7, 7;
    bfe.s32 %r17, %r20, 23, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
