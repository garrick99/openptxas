.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r20, %r3, 1;
    mul.lo.u32 %r4, %r3, %r20;
    shr.s32 %r20, %r20, 2;
    max.u32 %r16, %r4, %r4;
    shr.s32 %r26, %r16, 15;
    add.u32 %r7, %r4, 0;
    mul.lo.s32 %r8, %r16, %r3;
    shl.b32 %r9, %r3, 7;
    mul.lo.s32 %r5, %r8, %r3;
    add.u32 %r26, %r26, %r4;
    add.s32 %r10, %r8, 1;
    max.u32 %r10, %r3, 0;
    setp.le.s32 %p2, %r4, 64;
    @%p2 add.s32 %r17, %r8, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
