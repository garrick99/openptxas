    @!%p3 mul.lo.s32 %r4, %r3, 4;
    add.s32 %r26, %r4, 2147483648;
    cvt.s64.s32 %rd15, %r15;
    cvt.s64.s32 %rd10, %r3;
    shr.s32 %r27, %r26, 15;
    cvt.s32.s64 %r20, %rd10;
    or.b32 %r5, %r21, 64;
    sub.u32 %r22, %r7, 63;
    mad.lo.s32 %r23, %r21, %r4, %r20;
