.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r9, %r3, 0;
    shr.u32 %r4, %r9, 15;
    setp.le.s32 %p2, %r3, %r9;
    cvt.u64.u32 %rd7, %r3;
    shr.s64 %rd15, %rd7, 1;
    shr.s32 %r27, %r9, 16;
    sub.u32 %r18, %r9, 2;
    min.s32 %r19, %r9, %r9;
    cvt.s32.s64 %r24, %rd7;
    max.s32 %r17, %r24, %r9;
    shr.s32 %r8, %r18, 15;
    min.u32 %r15, %r27, %r8;
    xor.b32 %r5, %r8, %r27;
    mad.lo.s32 %r23, %r18, %r18, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
