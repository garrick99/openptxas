.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd12, %r3, %r3;
    shl.b64 %rd13, %rd12, 30;
    min.s64 %rd9, %rd13, %rd13;
    xor.b32 %r21, %r3, %r3;
    max.s32 %r13, %r21, %r21;
    add.u32 %r18, %r13, 8;
    max.s32 %r8, %r18, %r21;
    shr.s64 %rd14, %rd9, 48;
    cvt.s64.s32 %rd10, %r3;
    min.u32 %r19, %r18, %r18;
    shr.s32 %r19, %r8, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
