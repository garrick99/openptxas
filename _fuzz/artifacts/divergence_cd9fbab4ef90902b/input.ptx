.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    min.u32 %r23, %r3, 31;
    and.b32 %r16, %r3, %r23;
    cvt.s64.s32 %rd15, %r3;
    sub.u32 %r15, %r23, 255;
    setp.lo.u32 %p3, %r3, 64;
    @!%p3 add.s32 %r16, %r23, 4294967295;
    min.s32 %r17, %r3, %r23;
    mad.lo.u32 %r18, %r3, %r3, %r15;
    setp.ne.u32 %p3, %r23, 31;
    @%p3 add.s32 %r21, %r18, 2147483647;
    xor.b32 %r19, %r16, 4;
    mad.lo.s32 %r17, %r16, %r23, %r16;
    sub.u32 %r23, %r17, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
