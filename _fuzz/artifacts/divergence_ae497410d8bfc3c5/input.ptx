.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p4, %r3, %r3;
    @!%p4 shr.s32 %r26, %r3, 31;
    sub.u32 %r8, %r26, 4294967295;
    setp.hi.u32 %p4, %r8, %r8;
    @!%p4 cvt.s64.s32 %rd11, %r3;
    cvt.s32.s64 %r20, %rd11;
    shr.s32 %r11, %r8, 31;
    setp.gt.u32 %p3, %r20, 32;
    @%p3 sub.s64 %rd15, %rd11, %rd11;
    shl.b32 %r12, %r11, 30;
    sub.s64 %rd7, %rd15, %rd15;
    setp.eq.u32 %p4, %r26, %r12;
    @!%p4 mad.lo.u32 %r22, %r8, %r12, %r3;
    setp.lt.s32 %p4, %r20, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
