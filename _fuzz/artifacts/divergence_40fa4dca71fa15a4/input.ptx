.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r13, %r3, 16;
    mul.wide.u32 %rd14, %r3, %r13;
    min.s32 %r14, %r3, 5;
    shr.s64 %rd15, %rd14, 32;
    sub.s64 %rd15, %rd14, %rd15;
    setp.gt.s32 %p1, %r3, 5;
    max.u32 %r19, %r3, %r13;
    cvt.u32.u64 %r7, %rd15;
    cvt.s64.s32 %rd11, %r14;
    mul.wide.s32 %rd14, %r19, %r7;
    max.u32 %r4, %r3, 64;
    mul.wide.s32 %rd9, %r13, %r19;
    selp.b32 %r21, %r19, %r14, %p1;
    shr.s64 %rd15, %rd11, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
