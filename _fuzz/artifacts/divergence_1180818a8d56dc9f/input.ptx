.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    shr.s64 %rd7, %rd13, 47;
    shr.u32 %r22, %r3, 3;
    cvt.s32.s64 %r4, %rd13;
    sub.s32 %r27, %r22, %r22;
    mul.lo.u32 %r24, %r3, 8;
    max.s64 %rd9, %rd7, %rd13;
    mul.lo.u32 %r18, %r4, %r27;
    cvt.s64.s32 %rd9, %r4;
    cvt.s32.s64 %r17, %rd7;
    setp.ls.u32 %p2, %r18, 8;
    @%p2 mul.lo.u32 %r9, %r3, %r18;
    shr.u32 %r6, %r9, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
