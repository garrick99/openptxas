.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r22, %r3, 16;
    mul.wide.u32 %rd15, %r22, %r22;
    sub.u32 %r25, %r22, %r3;
    shl.b64 %rd15, %rd15, 32;
    cvt.s32.s64 %r4, %rd15;
    mul.lo.u32 %r26, %r3, 32;
    shr.u32 %r16, %r4, 2;
    sub.u64 %rd6, %rd15, %rd15;
    add.u32 %r27, %r16, 2;
    min.s32 %r26, %r22, %r27;
    mad.lo.u32 %r12, %r27, %r4, %r25;
    setp.ge.s32 %p2, %r22, 1;
    @!%p2 add.s32 %r14, %r3, %r3;
    or.b32 %r20, %r16, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
