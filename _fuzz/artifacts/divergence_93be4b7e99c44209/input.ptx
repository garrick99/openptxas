.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r8, %r3, %r3, %r3;
    setp.le.s32 %p3, %r8, %r3;
    @%p3 add.u32 %r7, %r3, 255;
    or.b32 %r19, %r7, %r8;
    and.b32 %r14, %r19, 16;
    setp.lo.u32 %p4, %r8, %r14;
    @%p4 selp.b32 %r16, %r8, %r19, %p4;
    setp.ge.u32 %p1, %r14, 255;
    setp.ge.s32 %p1, %r3, %r7;
    @%p1 cvt.s64.s32 %rd8, %r16;
    shr.s32 %r5, %r16, 1;
    setp.eq.u32 %p2, %r8, 65536;
    @%p2 sub.s64 %rd14, %rd8, %rd8;
    sub.s32 %r8, %r16, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
