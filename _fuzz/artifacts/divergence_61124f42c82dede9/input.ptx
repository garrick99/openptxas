.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r20, %r3, 0;
    setp.ge.s32 %p3, %r20, %r20;
    setp.lt.u32 %p2, %r20, %r3;
    @!%p2 shl.b32 %r9, %r3, 30;
    max.s32 %r22, %r20, %r9;
    shr.u32 %r16, %r22, 16;
    mul.wide.s32 %rd9, %r22, %r22;
    shr.u32 %r17, %r9, 3;
    sub.s32 %r7, %r16, %r3;
    shr.u32 %r14, %r16, 1;
    sub.u32 %r10, %r14, %r22;
    setp.eq.u32 %p2, %r17, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
