.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    sub.u32 %r24, %r3, %r3;
    max.u32 %r5, %r24, 7;
    shr.u32 %r9, %r24, 7;
    setp.gt.u32 %p1, %r5, %r9;
    @%p1 shr.u32 %r13, %r5, 31;
    selp.b32 %r6, %r3, %r9, %p1;
    add.s32 %r18, %r6, 65536;
    max.s64 %rd12, %rd14, %rd14;
    cvt.u32.u64 %r23, %rd14;
    mul.lo.u32 %r13, %r6, %r5;
    mul.lo.u32 %r8, %r5, %r13;
    shr.u32 %r26, %r5, 15;
    selp.b32 %r9, %r8, %r24, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
