.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd13, %r3, %r3;
    and.b32 %r10, %r3, %r3;
    setp.le.s32 %p1, %r10, 4294967295;
    sub.s32 %r14, %r3, 15;
    max.s64 %rd7, %rd13, %rd13;
    setp.gt.s32 %p1, %r14, %r3;
    shr.u32 %r7, %r14, 1;
    max.s32 %r11, %r3, 2147483648;
    mul.wide.s32 %rd5, %r7, %r7;
    setp.lo.u32 %p1, %r3, 256;
    mul.wide.s32 %rd7, %r10, %r11;
    sub.s32 %r27, %r14, %r7;
    shl.b64 %rd9, %rd13, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
