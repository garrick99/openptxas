.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    shl.b64 %rd10, %rd5, 0;
    shr.u32 %r9, %r3, 15;
    mul.lo.s32 %r15, %r9, %r9;
    mad.lo.s32 %r23, %r9, %r3, %r9;
    xor.b32 %r15, %r9, %r15;
    max.u64 %rd14, %rd10, %rd10;
    cvt.u32.u64 %r13, %rd5;
    cvt.s32.s64 %r20, %rd5;
    shr.s32 %r16, %r20, 3;
    shr.s32 %r15, %r3, 3;
    add.s32 %r10, %r9, %r9;
    max.s32 %r18, %r10, 65536;
    shl.b32 %r23, %r9, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
