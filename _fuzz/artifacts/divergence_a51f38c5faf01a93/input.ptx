.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r25, %r3, %r3, %r3;
    cvt.u64.u32 %rd12, %r3;
    min.u32 %r6, %r3, %r25;
    cvt.u32.u64 %r9, %rd12;
    max.u32 %r17, %r3, 1;
    max.u32 %r20, %r6, %r6;
    cvt.s32.s64 %r10, %rd12;
    cvt.s64.s32 %rd5, %r10;
    cvt.s32.s64 %r19, %rd5;
    sub.s32 %r5, %r9, %r9;
    or.b32 %r23, %r6, %r17;
    sub.u32 %r16, %r20, 2;
    cvt.s32.s64 %r27, %rd5;
    mul.lo.u32 %r18, %r17, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
