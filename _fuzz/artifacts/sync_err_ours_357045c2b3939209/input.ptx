.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r25, %r3, 4294967295;
    or.b32 %r27, %r25, %r25;
    setp.lt.s32 %p4, %r25, 2147483647;
    setp.eq.u32 %p4, %r27, %r25;
    @%p4 max.s32 %r14, %r27, %r25;
    add.s32 %r21, %r27, %r3;
    cvt.u64.u32 %rd14, %r21;
    mul.lo.s64 %rd9, %rd14, %rd14;
    xor.b32 %r20, %r14, %r14;
    max.s32 %r25, %r14, %r3;
    setp.le.u32 %p2, %r20, %r25;
    @%p2 sub.s32 %r5, %r20, 8;
    mul.wide.s32 %rd6, %r5, %r25;
    setp.le.s32 %p4, %r14, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
