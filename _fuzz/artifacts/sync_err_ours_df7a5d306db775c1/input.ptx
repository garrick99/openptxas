.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r8, %r3, %r3;
    sub.u32 %r19, %r3, %r3;
    add.s32 %r10, %r19, 4;
    setp.le.s32 %p3, %r19, %r19;
    @%p3 cvt.u64.u32 %rd7, %r10;
    mul.wide.u32 %rd6, %r19, %r8;
    max.s32 %r14, %r10, 2147483648;
    cvt.s32.s64 %r12, %rd6;
    shl.b32 %r23, %r12, 3;
    mul.lo.s64 %rd10, %rd7, %rd7;
    xor.b32 %r12, %r3, %r19;
    setp.gt.u32 %p3, %r3, 63;
    add.u32 %r12, %r14, %r3;
    shl.b64 %rd8, %rd6, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
