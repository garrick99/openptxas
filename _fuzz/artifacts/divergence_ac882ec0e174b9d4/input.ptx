.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r18, %r3, 3;
    mul.wide.u32 %rd8, %r18, %r18;
    and.b32 %r23, %r18, 7;
    setp.lo.u32 %p4, %r3, %r18;
    setp.hs.u32 %p3, %r23, %r18;
    @%p3 mul.lo.u32 %r22, %r23, %r23;
    or.b32 %r6, %r23, 2147483648;
    selp.b32 %r16, %r22, %r3, %p3;
    sub.u64 %rd13, %rd8, %rd8;
    selp.b32 %r18, %r23, %r16, %p4;
    mul.lo.u32 %r10, %r18, 15;
    setp.ne.u32 %p4, %r3, 0;
    add.s32 %r18, %r3, %r22;
    mul.wide.u32 %rd14, %r22, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
