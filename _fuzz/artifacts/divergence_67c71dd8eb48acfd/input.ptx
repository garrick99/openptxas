.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r21, %r3, 63;
    max.u32 %r9, %r3, 256;
    cvt.s64.s32 %rd13, %r9;
    min.u32 %r5, %r3, %r3;
    setp.le.u32 %p2, %r5, %r9;
    @!%p2 selp.b32 %r24, %r21, %r9, %p2;
    cvt.u64.u32 %rd10, %r24;
    mul.lo.u64 %rd8, %rd10, %rd10;
    mul.wide.s32 %rd6, %r5, %r9;
    xor.b64 %rd6, %rd13, %rd10;
    and.b32 %r17, %r24, %r9;
    cvt.s32.s64 %r19, %rd13;
    sub.u64 %rd12, %rd6, %rd8;
    mul.lo.s32 %r17, %r17, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
