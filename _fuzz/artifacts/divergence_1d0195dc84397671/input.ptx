.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    setp.ls.u32 %p2, %r3, 64;
    mad.lo.s32 %r22, %r3, %r3, %r3;
    and.b32 %r9, %r22, %r3;
    mul.lo.s32 %r23, %r9, 255;
    shr.u32 %r5, %r23, 7;
    mad.lo.u32 %r5, %r23, %r3, %r22;
    min.u32 %r18, %r23, 1;
    shr.s32 %r12, %r22, 3;
    mad.lo.u32 %r11, %r3, %r9, %r12;
    cvt.s32.s64 %r11, %rd6;
    setp.eq.u32 %p3, %r18, 32;
    @%p3 add.s32 %r26, %r11, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
