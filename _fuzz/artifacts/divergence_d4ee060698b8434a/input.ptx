.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r23, %r3, 31;
    min.u32 %r11, %r23, 256;
    min.s32 %r25, %r23, 2147483648;
    setp.le.s32 %p4, %r25, %r23;
    @%p4 mul.wide.s32 %rd9, %r25, %r25;
    mul.wide.s32 %rd14, %r11, %r11;
    max.s32 %r21, %r23, 5;
    or.b32 %r27, %r23, 4;
    shr.s32 %r19, %r25, 31;
    mad.lo.s32 %r17, %r23, %r21, %r27;
    and.b64 %rd8, %rd9, %rd14;
    or.b32 %r20, %r17, %r25;
    mul.wide.s32 %rd13, %r19, %r20;
    selp.b32 %r17, %r17, %r19, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
