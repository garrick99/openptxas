.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r5, %r3, 3;
    and.b32 %r27, %r5, %r3;
    shl.b32 %r5, %r5, 30;
    max.s32 %r16, %r27, 15;
    cvt.u64.u32 %rd8, %r3;
    cvt.s32.s64 %r13, %rd8;
    max.u32 %r14, %r5, %r27;
    mul.wide.u32 %rd13, %r3, %r13;
    mad.lo.s32 %r15, %r27, %r27, %r5;
    sub.s32 %r7, %r16, %r16;
    add.s32 %r7, %r5, %r5;
    cvt.u32.u64 %r19, %rd13;
    mad.lo.s32 %r15, %r5, %r27, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
