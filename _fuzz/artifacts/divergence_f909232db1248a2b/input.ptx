.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r4, %r3, 2;
    setp.lo.u32 %p1, %r3, %r4;
    @%p1 cvt.s64.s32 %rd6, %r3;
    selp.b32 %r9, %r4, %r4, %p1;
    mul.lo.u32 %r18, %r9, %r3;
    shr.u64 %rd15, %rd6, 16;
    cvt.s32.s64 %r25, %rd15;
    cvt.u64.u32 %rd8, %r4;
    shr.u32 %r4, %r3, 15;
    shr.s64 %rd7, %rd8, 30;
    mul.wide.s32 %rd5, %r3, %r4;
    sub.s32 %r24, %r3, %r18;
    and.b32 %r25, %r24, 2147483647;
    cvt.s32.s64 %r12, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
