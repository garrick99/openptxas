.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r15, %r3, 2;
    cvt.u64.u32 %rd13, %r3;
    mad.lo.u32 %r17, %r15, %r3, %r15;
    cvt.u64.u32 %rd6, %r3;
    shl.b64 %rd7, %rd13, 1;
    min.u32 %r4, %r3, 32;
    sub.u32 %r26, %r15, %r15;
    shr.s32 %r8, %r3, 4;
    shr.s64 %rd9, %rd7, 3;
    mul.lo.u32 %r20, %r17, 16;
    add.s32 %r7, %r3, %r20;
    add.u32 %r11, %r20, 31;
    shl.b32 %r24, %r4, 7;
    xor.b64 %rd8, %rd7, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
