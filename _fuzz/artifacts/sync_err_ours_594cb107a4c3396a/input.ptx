.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r6, %r3, 2;
    mad.lo.s32 %r5, %r6, %r6, %r3;
    mul.wide.u32 %rd10, %r5, %r3;
    add.s32 %r14, %r5, %r5;
    mul.lo.u32 %r20, %r3, %r3;
    sub.u32 %r21, %r3, %r20;
    cvt.u64.u32 %rd12, %r3;
    min.s64 %rd11, %rd12, %rd12;
    xor.b32 %r10, %r21, %r3;
    cvt.u32.u64 %r16, %rd11;
    or.b32 %r11, %r21, %r21;
    max.s32 %r7, %r20, 65536;
    or.b32 %r17, %r11, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
