.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r4, %r3, 0;
    shr.u32 %r20, %r3, 1;
    max.s32 %r14, %r3, %r20;
    mad.lo.s32 %r27, %r3, %r4, %r20;
    sub.u32 %r7, %r27, 4;
    or.b32 %r22, %r4, %r27;
    xor.b32 %r11, %r27, %r14;
    mul.wide.s32 %rd5, %r4, %r11;
    shr.u32 %r14, %r14, 31;
    setp.le.s32 %p4, %r27, %r27;
    @%p4 sub.u32 %r17, %r22, 65536;
    add.s32 %r18, %r17, 63;
    mul.lo.u32 %r10, %r27, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
