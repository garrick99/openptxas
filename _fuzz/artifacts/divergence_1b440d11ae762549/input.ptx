    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd5, %r3, %r3;
    mul.wide.u32 %rd13, %r3, %r3;
    min.u32 %r9, %r3, 2147483648;
    shl.b64 %rd10, %rd5, 63;
    sub.s32 %r5, %r9, %r9;
    shr.u32 %r18, %r9, 15;
    add.s32 %r14, %r3, %r9;
    mul.lo.u64 %rd15, %rd13, %rd13;
    shl.b32 %r12, %r14, 1;
    shl.b64 %rd10, %rd15, 30;
    mul.wide.u32 %rd13, %r18, %r3;
    add.u32 %r22, %r18, %r18;
    mad.lo.u32 %r6, %r9, %r22, %r12;
    xor.b32 %r22, %r18, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
