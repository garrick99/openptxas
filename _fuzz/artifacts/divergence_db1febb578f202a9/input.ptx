.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r17, %r3, 64;
    mul.wide.u32 %rd9, %r17, %r17;
    min.u32 %r25, %r17, 65536;
    mul.wide.s32 %rd14, %r17, %r17;
    mul.wide.s32 %rd14, %r3, %r25;
    sub.s32 %r22, %r25, %r17;
    max.s32 %r25, %r25, %r3;
    min.u64 %rd6, %rd9, %rd9;
    shl.b32 %r27, %r3, 30;
    shl.b64 %rd11, %rd9, 63;
    or.b32 %r8, %r27, %r27;
    cvt.s64.s32 %rd15, %r17;
    sub.u32 %r11, %r17, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
