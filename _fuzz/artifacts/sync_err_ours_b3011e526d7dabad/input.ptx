.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r10, %r3, %r3;
    cvt.u64.u32 %rd7, %r3;
    shl.b64 %rd7, %rd7, 15;
    mul.lo.u32 %r6, %r10, %r10;
    and.b32 %r8, %r10, %r3;
    sub.u32 %r6, %r8, %r3;
    mul.lo.u64 %rd6, %rd7, %rd7;
    mad.lo.s32 %r8, %r8, %r6, %r6;
    sub.u64 %rd12, %rd6, %rd7;
    mul.lo.u32 %r19, %r10, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
