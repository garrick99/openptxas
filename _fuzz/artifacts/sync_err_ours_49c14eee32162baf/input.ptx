.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r6, %r3, 15;
    or.b32 %r13, %r3, %r3;
    setp.eq.s32 %p4, %r13, %r13;
    cvt.u64.u32 %rd13, %r13;
    min.s32 %r14, %r3, %r3;
    min.u32 %r13, %r3, %r13;
    min.s32 %r23, %r3, %r14;
    shr.s64 %rd15, %rd13, 0;
    setp.lt.u32 %p2, %r13, 2;
    mad.lo.u32 %r25, %r6, %r23, %r14;
    shr.s32 %r26, %r3, 0;
    xor.b64 %rd7, %rd13, %rd15;
    xor.b32 %r5, %r26, %r26;
    cvt.s32.s64 %r19, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
