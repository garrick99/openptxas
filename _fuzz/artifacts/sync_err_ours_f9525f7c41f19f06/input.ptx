.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p3, %r3, 63;
    selp.b32 %r15, %r3, %r3, %p3;
    max.u32 %r4, %r15, %r15;
    selp.b32 %r21, %r3, %r3, %p3;
    max.s32 %r26, %r3, 4;
    cvt.u64.u32 %rd13, %r3;
    shl.b64 %rd15, %rd13, 48;
    setp.ge.u32 %p1, %r15, %r15;
    @%p1 min.u32 %r10, %r4, %r15;
    sub.u32 %r8, %r15, %r15;
    max.s32 %r9, %r26, %r4;
    or.b32 %r22, %r9, 0;
    max.u64 %rd12, %rd15, %rd13;
    add.s32 %r27, %r15, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
