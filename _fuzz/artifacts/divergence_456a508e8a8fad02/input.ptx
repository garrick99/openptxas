.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfe.s32 %r19, %r3, 7, 2;
    max.u32 %r13, %r19, %r19;
    bfi.b32 %r22, %r19, %r13, 8, 2;
    bfi.b32 %r16, %r3, %r22, 1, 8;
    clz.b32 %r17, %r16;
    clz.b32 %r17, %r17;
    bfe.u32 %r22, %r19, 4, 24;
    brev.b32 %r22, %r13;
    bfi.b32 %r10, %r16, %r19, 4, 31;
    brev.b32 %r20, %r17;
    bfe.s32 %r8, %r17, 8, 8;
    bfe.u32 %r9, %r16, 16, 24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
