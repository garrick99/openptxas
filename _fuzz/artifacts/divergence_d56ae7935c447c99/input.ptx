.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd8, %r3, %r3;
    cvt.s32.s64 %r8, %rd8;
    setp.le.s32 %p4, %r8, %r3;
    max.u32 %r15, %r8, %r3;
    shl.b32 %r22, %r15, 7;
    and.b32 %r19, %r22, 4;
    add.s32 %r14, %r3, %r8;
    shl.b64 %rd9, %rd8, 16;
    cvt.u32.u64 %r27, %rd8;
    shr.s32 %r11, %r19, 16;
    shr.s64 %rd12, %rd9, 32;
    max.s32 %r15, %r22, 0;
    xor.b64 %rd14, %rd12, %rd8;
    mad.lo.s32 %r6, %r11, %r14, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
