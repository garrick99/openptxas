.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    min.u32 %r26, %r3, %r3;
    mul.lo.u32 %r12, %r3, %r3;
    and.b32 %r9, %r26, 16;
    mul.lo.s32 %r5, %r3, %r9;
    xor.b32 %r4, %r3, 255;
    min.s32 %r22, %r26, 4;
    shl.b32 %r20, %r5, 4;
    min.u32 %r8, %r22, %r20;
    min.s32 %r21, %r20, %r9;
    xor.b64 %rd14, %rd11, %rd11;
    mul.lo.u32 %r16, %r22, %r26;
    max.u32 %r24, %r20, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
