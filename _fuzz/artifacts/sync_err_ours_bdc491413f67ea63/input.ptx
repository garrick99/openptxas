.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    and.b64 %rd11, %rd7, %rd7;
    shr.s32 %r24, %r3, 15;
    sub.s32 %r23, %r3, %r24;
    mul.wide.u32 %rd11, %r3, %r24;
    cvt.s64.s32 %rd10, %r24;
    setp.lo.u32 %p1, %r3, 5;
    min.s64 %rd15, %rd7, %rd11;
    shr.s32 %r7, %r3, 16;
    xor.b64 %rd8, %rd15, %rd11;
    selp.b32 %r16, %r3, %r23, %p1;
    add.s32 %r6, %r7, %r16;
    sub.u32 %r11, %r23, 32;
    max.u64 %rd13, %rd11, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
