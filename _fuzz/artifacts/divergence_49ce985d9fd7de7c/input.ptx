.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd6, %r3, %r3;
    sub.s32 %r14, %r3, 4;
    add.s32 %r6, %r3, 31;
    shr.u64 %rd6, %rd6, 62;
    shl.b64 %rd9, %rd6, 62;
    cvt.s32.s64 %r20, %rd9;
    setp.ge.s32 %p2, %r14, %r3;
    setp.gt.u32 %p2, %r14, 31;
    @%p2 shr.s64 %rd8, %rd9, 7;
    shr.s32 %r7, %r6, 16;
    selp.b32 %r11, %r3, %r3, %p2;
    selp.b32 %r8, %r3, %r3, %p2;
    cvt.s32.s64 %r10, %rd8;
    cvt.s64.s32 %rd9, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
