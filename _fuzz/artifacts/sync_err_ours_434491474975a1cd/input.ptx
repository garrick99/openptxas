.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r15, %r3, %r3, %r3;
    mad.lo.u32 %r18, %r3, %r3, %r15;
    and.b32 %r15, %r18, 16;
    or.b32 %r9, %r15, %r3;
    max.u32 %r23, %r18, %r3;
    mul.wide.s32 %rd14, %r23, %r23;
    cvt.s64.s32 %rd11, %r15;
    add.u64 %rd6, %rd14, %rd11;
    add.u32 %r19, %r18, %r9;
    and.b32 %r12, %r15, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
