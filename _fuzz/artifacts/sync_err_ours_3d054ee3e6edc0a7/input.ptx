.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    cvt.u32.u64 %r6, %rd6;
    shl.b32 %r27, %r3, 31;
    or.b32 %r11, %r27, %r27;
    shr.u32 %r26, %r27, 15;
    shr.u64 %rd13, %rd6, 1;
    shr.u32 %r23, %r3, 31;
    min.u32 %r22, %r23, 3;
    shr.s32 %r10, %r27, 2;
    cvt.s32.s64 %r13, %rd13;
    shr.u64 %rd6, %rd6, 32;
    shr.u32 %r23, %r26, 15;
    shr.s32 %r25, %r22, 0;
    sub.u32 %r8, %r25, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
