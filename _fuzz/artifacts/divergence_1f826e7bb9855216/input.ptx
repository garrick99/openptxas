.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r15, %r3, 3;
    sub.s32 %r13, %r15, %r15;
    max.s32 %r21, %r3, %r15;
    mad.lo.u32 %r6, %r3, %r21, %r21;
    mul.lo.u32 %r13, %r13, 64;
    mul.lo.u32 %r7, %r6, %r13;
    shl.b32 %r9, %r13, 30;
    add.s32 %r13, %r3, 255;
    xor.b32 %r21, %r6, 5;
    add.u32 %r6, %r21, 4294967295;
    mad.lo.u32 %r24, %r3, %r15, %r15;
    mul.wide.u32 %rd7, %r9, %r24;
    mul.lo.s32 %r11, %r13, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
