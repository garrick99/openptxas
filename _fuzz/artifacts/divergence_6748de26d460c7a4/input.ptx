.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r16, %r3, %r3;
    cvt.s64.s32 %rd6, %r3;
    shl.b32 %r24, %r16, 3;
    max.s32 %r18, %r24, %r24;
    min.s32 %r14, %r24, 4294967295;
    or.b32 %r16, %r3, 16;
    setp.ne.s32 %p1, %r16, %r14;
    shl.b32 %r26, %r18, 3;
    or.b32 %r12, %r16, %r18;
    cvt.u32.u64 %r8, %rd6;
    setp.lt.u32 %p1, %r8, %r12;
    @%p1 add.u32 %r20, %r18, 8;
    cvt.u64.u32 %rd11, %r8;
    cvt.s64.s32 %rd12, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
