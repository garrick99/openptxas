.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    shr.s32 %r24, %r3, 30;
    min.s32 %r10, %r24, %r24;
    cvt.u64.u32 %rd11, %r3;
    shl.b64 %rd15, %rd11, 7;
    or.b32 %r12, %r10, %r3;
    cvt.s32.s64 %r19, %rd13;
    sub.s32 %r5, %r24, 3;
    xor.b32 %r7, %r3, %r19;
    cvt.u32.u64 %r15, %rd11;
    max.u32 %r4, %r15, %r5;
    shr.s32 %r18, %r19, 2;
    shl.b64 %rd5, %rd15, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
