.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p4, %r3, 5;
    @!%p4 or.b32 %r17, %r3, %r3;
    selp.b32 %r22, %r3, %r17, %p4;
    max.u32 %r11, %r17, %r22;
    xor.b32 %r20, %r3, %r17;
    cvt.u64.u32 %rd15, %r22;
    mul.wide.s32 %rd9, %r3, %r17;
    shr.u32 %r21, %r11, 4;
    max.s32 %r15, %r20, 16;
    xor.b32 %r26, %r21, %r22;
    and.b32 %r9, %r26, %r11;
    cvt.u64.u32 %rd6, %r3;
    max.s32 %r11, %r21, 64;
    shr.u64 %rd12, %rd9, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
