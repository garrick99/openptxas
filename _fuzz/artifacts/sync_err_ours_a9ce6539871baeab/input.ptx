.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    setp.ne.s32 %p3, %r3, 3;
    @!%p3 shr.s32 %r15, %r3, 15;
    min.s32 %r7, %r3, %r3;
    cvt.s64.s32 %rd14, %r7;
    cvt.u32.u64 %r4, %rd6;
    min.u32 %r12, %r3, %r15;
    min.s32 %r21, %r3, %r7;
    max.u32 %r17, %r4, %r21;
    xor.b64 %rd12, %rd14, %rd14;
    min.s32 %r25, %r4, 8;
    min.s32 %r23, %r15, 0;
    setp.hi.u32 %p4, %r25, 8;
    @%p4 selp.b32 %r16, %r21, %r15, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
