.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r11, %r3, 63;
    mul.wide.u32 %rd8, %r11, %r3;
    max.s64 %rd12, %rd8, %rd8;
    shr.s32 %r20, %r3, 0;
    or.b32 %r7, %r3, %r11;
    and.b32 %r25, %r7, 4;
    cvt.u64.u32 %rd14, %r7;
    shr.u32 %r24, %r25, 2;
    xor.b32 %r9, %r24, %r24;
    add.s32 %r23, %r11, 16;
    and.b64 %rd11, %rd12, %rd14;
    setp.ge.s32 %p3, %r23, %r24;
    @!%p3 shr.s32 %r6, %r25, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
