.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    mul.wide.s32 %rd6, %r3, %r3;
    shr.s32 %r5, %r3, 1;
    mul.lo.s32 %r5, %r5, 2147483647;
    shl.b64 %rd11, %rd6, 62;
    shr.u32 %r11, %r3, 15;
    mul.lo.s32 %r13, %r3, 255;
    min.u32 %r19, %r11, 4294967295;
    shr.u32 %r15, %r11, 30;
    setp.hs.u32 %p1, %r13, %r19;
    @!%p1 shr.u32 %r14, %r15, 2;
    setp.gt.s32 %p1, %r3, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
