.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r21, %r3, 64;
    shr.s32 %r19, %r21, 31;
    or.b32 %r26, %r3, 4294967295;
    shl.b32 %r26, %r3, 7;
    cvt.u64.u32 %rd6, %r26;
    shr.u32 %r27, %r3, 31;
    mul.lo.s32 %r8, %r3, 63;
    shr.u64 %rd10, %rd6, 1;
    shl.b64 %rd10, %rd10, 31;
    mul.wide.u32 %rd9, %r21, %r19;
    setp.ge.u32 %p4, %r3, %r26;
    @%p4 shr.s32 %r4, %r19, 4;
    max.s32 %r19, %r4, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
