.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r10, %r3, 7;
    setp.gt.s32 %p3, %r3, 255;
    mul.wide.u32 %rd9, %r3, %r10;
    max.u32 %r24, %r3, 4294967295;
    or.b32 %r16, %r10, %r24;
    cvt.u64.u32 %rd11, %r16;
    cvt.s64.s32 %rd14, %r16;
    min.s64 %rd5, %rd9, %rd11;
    shr.s64 %rd13, %rd11, 47;
    shr.s32 %r16, %r24, 0;
    sub.s64 %rd7, %rd5, %rd14;
    mul.wide.u32 %rd8, %r10, %r24;
    or.b32 %r8, %r24, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
