.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r25, %r3, 5;
    setp.ge.u32 %p2, %r25, 63;
    @!%p2 selp.b32 %r20, %r3, %r3, %p2;
    and.b32 %r23, %r3, 15;
    setp.eq.u32 %p3, %r20, %r23;
    @%p3 sub.u32 %r8, %r23, %r23;
    add.u32 %r15, %r20, 63;
    or.b32 %r11, %r23, %r25;
    shr.s32 %r7, %r11, 3;
    cvt.u64.u32 %rd12, %r20;
    shr.u32 %r5, %r3, 1;
    shr.u32 %r24, %r5, 0;
    sub.u32 %r19, %r20, %r5;
    mad.lo.u32 %r19, %r15, %r15, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
