.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r10, %r3, %r3;
    mul.wide.s32 %rd11, %r10, %r3;
    add.s32 %r7, %r3, 5;
    or.b32 %r18, %r7, 32;
    sub.u32 %r15, %r18, %r18;
    sub.s64 %rd15, %rd11, %rd11;
    sub.s32 %r27, %r18, 5;
    sub.u64 %rd5, %rd15, %rd15;
    shr.u32 %r7, %r15, 1;
    shr.u64 %rd9, %rd11, 30;
    min.u32 %r7, %r10, 31;
    cvt.u64.u32 %rd11, %r18;
    setp.lt.u32 %p4, %r10, 16;
    @!%p4 xor.b32 %r12, %r3, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
