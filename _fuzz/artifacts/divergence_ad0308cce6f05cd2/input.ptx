.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r24, %r3, 32;
    min.u32 %r11, %r3, %r24;
    cvt.s64.s32 %rd10, %r3;
    cvt.u64.u32 %rd11, %r24;
    max.u64 %rd12, %rd11, %rd10;
    shr.u64 %rd9, %rd11, 16;
    shr.s64 %rd12, %rd9, 15;
    cvt.s32.s64 %r12, %rd12;
    mul.lo.s64 %rd7, %rd9, %rd12;
    cvt.s32.s64 %r15, %rd11;
    sub.u32 %r25, %r12, %r15;
    max.s32 %r19, %r15, %r25;
    cvt.u32.u64 %r7, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
