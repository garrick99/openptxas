.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    shl.b64 %rd7, %rd10, 31;
    shl.b32 %r20, %r3, 7;
    mul.lo.u32 %r19, %r20, 65535;
    mul.lo.s32 %r24, %r3, %r3;
    max.s32 %r13, %r20, %r19;
    add.s32 %r12, %r20, 255;
    shr.u32 %r22, %r19, 0;
    add.u32 %r12, %r22, 4294967295;
    mul.lo.u32 %r17, %r20, 7;
    mul.lo.s32 %r6, %r20, %r17;
    max.u64 %rd7, %rd7, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
