.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p3, %r3, 63;
    setp.lt.u32 %p3, %r3, 31;
    @%p3 shl.b32 %r25, %r3, 1;
    cvt.u64.u32 %rd14, %r3;
    setp.gt.s32 %p4, %r3, 256;
    @%p4 or.b32 %r13, %r3, %r25;
    mul.lo.s32 %r19, %r13, 65536;
    sub.u32 %r16, %r19, 16;
    shl.b32 %r18, %r13, 31;
    sub.s32 %r17, %r16, %r13;
    mul.lo.u32 %r18, %r18, %r16;
    add.s32 %r6, %r16, %r17;
    mul.lo.u32 %r17, %r25, 1;
    shr.s32 %r14, %r16, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
