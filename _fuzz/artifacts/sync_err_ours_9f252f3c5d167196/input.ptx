.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r4, %r3, 256;
    mad.lo.u32 %r23, %r4, %r4, %r3;
    cvt.u64.u32 %rd8, %r3;
    add.u32 %r6, %r3, %r4;
    max.s32 %r12, %r6, 5;
    min.u32 %r11, %r4, 8;
    and.b32 %r20, %r11, %r3;
    add.u32 %r22, %r20, %r23;
    mul.wide.s32 %rd7, %r23, %r20;
    mad.lo.u32 %r8, %r6, %r11, %r23;
    setp.ge.s32 %p1, %r3, 2147483648;
    and.b64 %rd9, %rd8, %rd7;
    add.u32 %r26, %r8, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
