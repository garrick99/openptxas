.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    mad.lo.s32 %r8, %r3, %r3, %r3;
    cvt.u32.u64 %r14, %rd11;
    shr.s64 %rd7, %rd11, 4;
    max.s32 %r20, %r14, %r8;
    setp.lo.u32 %p2, %r3, %r20;
    sub.u32 %r11, %r14, %r14;
    or.b32 %r26, %r11, %r8;
    mul.wide.s32 %rd13, %r20, %r11;
    xor.b32 %r17, %r3, %r20;
    add.u32 %r15, %r14, %r26;
    cvt.u64.u32 %rd15, %r11;
    cvt.s32.s64 %r26, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
