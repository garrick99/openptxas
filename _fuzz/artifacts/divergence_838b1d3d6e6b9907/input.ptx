    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r11, %r3, 4294967295;
    cvt.s64.s32 %rd9, %r3;
