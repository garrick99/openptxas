.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r9, %r3, 32;
    cvt.u64.u32 %rd10, %r3;
    shl.b32 %r25, %r9, 2;
    shr.u64 %rd14, %rd10, 15;
    shl.b64 %rd12, %rd10, 47;
    cvt.u64.u32 %rd12, %r25;
    mul.wide.s32 %rd14, %r9, %r9;
    add.u64 %rd15, %rd14, %rd14;
    or.b32 %r6, %r25, 1;
    cvt.u64.u32 %rd10, %r3;
    mul.lo.u32 %r22, %r9, 65535;
    cvt.u64.u32 %rd10, %r6;
    setp.ls.u32 %p2, %r9, 7;
    @!%p2 max.u32 %r5, %r22, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
