.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r13, %r3, 7;
    setp.hi.u32 %p4, %r13, 8;
    @%p4 mul.lo.u32 %r20, %r3, 4;
    mul.wide.s32 %rd14, %r13, %r13;
    setp.eq.u32 %p3, %r3, %r20;
    @%p3 min.s32 %r23, %r13, 3;
    mad.lo.u32 %r19, %r23, %r20, %r23;
    max.s32 %r11, %r13, %r23;
    and.b32 %r20, %r3, 2;
    setp.le.u32 %p2, %r11, %r11;
    @%p2 cvt.u32.u64 %r11, %rd14;
    max.u32 %r21, %r19, %r11;
    sub.s32 %r20, %r3, %r19;
    shl.b64 %rd6, %rd14, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
