.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p2, %r3, %r3;
    @%p2 or.b32 %r9, %r3, 4294967295;
    or.b32 %r22, %r9, %r9;
    selp.b32 %r14, %r22, %r9, %p2;
    or.b32 %r22, %r22, 65536;
    mad.lo.s32 %r20, %r3, %r3, %r14;
    cvt.u64.u32 %rd11, %r22;
    cvt.u64.u32 %rd6, %r22;
    shr.s32 %r16, %r22, 15;
    shl.b32 %r26, %r16, 16;
    selp.b32 %r6, %r16, %r3, %p2;
    mul.lo.s64 %rd9, %rd11, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
