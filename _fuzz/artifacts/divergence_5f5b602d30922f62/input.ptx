.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r10, %r3, %r3;
    cvt.s64.s32 %rd15, %r3;
    mul.wide.u32 %rd12, %r10, %r3;
    sub.u32 %r16, %r10, 31;
    shr.s64 %rd11, %rd15, 0;
    sub.s32 %r23, %r3, 8;
    min.s64 %rd5, %rd11, %rd12;
    cvt.s64.s32 %rd14, %r23;
    min.s32 %r23, %r16, %r10;
    setp.ge.s32 %p2, %r3, 16;
    @%p2 mul.wide.u32 %rd10, %r10, %r16;
    setp.le.u32 %p2, %r23, %r3;
    @!%p2 shl.b32 %r24, %r16, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
