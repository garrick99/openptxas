.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r26, %r3, 2;
    cvt.u64.u32 %rd7, %r3;
    cvt.u32.u64 %r9, %rd7;
    cvt.u64.u32 %rd6, %r9;
    mad.lo.u32 %r9, %r26, %r3, %r9;
    setp.lt.s32 %p1, %r26, %r26;
    @%p1 shl.b64 %rd5, %rd7, 62;
    setp.ge.s32 %p4, %r9, 2;
    @%p4 max.s32 %r18, %r3, 256;
    min.s64 %rd7, %rd6, %rd7;
    selp.b32 %r23, %r3, %r18, %p1;
    add.s32 %r23, %r23, %r9;
    setp.ne.s32 %p4, %r26, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
