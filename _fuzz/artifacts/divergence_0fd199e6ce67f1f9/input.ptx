.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd11, %r3, %r3;
    or.b32 %r9, %r3, %r3;
    setp.ls.u32 %p4, %r9, %r3;
    @%p4 shr.u64 %rd11, %rd11, 33;
    setp.lt.s32 %p1, %r9, 8;
    @%p1 mul.wide.s32 %rd10, %r3, %r9;
    shr.s64 %rd9, %rd11, 31;
    selp.b32 %r15, %r3, %r9, %p4;
    setp.eq.u32 %p3, %r15, %r3;
    shr.s64 %rd12, %rd9, 15;
    cvt.u32.u64 %r13, %rd12;
    selp.b32 %r17, %r9, %r3, %p3;
    setp.lo.u32 %p1, %r3, 8;
    @%p1 selp.b32 %r4, %r15, %r17, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
