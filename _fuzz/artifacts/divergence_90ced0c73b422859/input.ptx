.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r18, %r3, %r3;
    mul.lo.u32 %r6, %r3, %r3;
    mul.wide.s32 %rd9, %r6, %r6;
    shr.s32 %r13, %r3, 1;
    mad.lo.s32 %r5, %r3, %r6, %r6;
    mad.lo.u32 %r11, %r6, %r18, %r13;
    setp.lt.u32 %p3, %r3, %r6;
    @%p3 selp.b32 %r22, %r5, %r18, %p3;
    min.u32 %r17, %r6, %r5;
    setp.ne.s32 %p4, %r3, 65535;
    @%p4 cvt.u32.u64 %r16, %rd9;
    setp.le.u32 %p2, %r11, 7;
    @!%p2 add.u32 %r15, %r22, %r18;
    add.s32 %r24, %r22, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
