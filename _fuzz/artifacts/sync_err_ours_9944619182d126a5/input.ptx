.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    shl.b32 %r21, %r3, 3;
    max.u32 %r19, %r21, %r3;
    shr.u64 %rd13, %rd8, 16;
    shr.s32 %r22, %r21, 4;
    and.b32 %r5, %r3, %r19;
    and.b32 %r8, %r3, 7;
    shr.s32 %r19, %r21, 2;
    shl.b32 %r9, %r22, 2;
    add.s32 %r11, %r9, 255;
    and.b32 %r6, %r22, 7;
    or.b32 %r21, %r8, 64;
    min.u32 %r21, %r8, 65535;
    max.u64 %rd6, %rd13, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
