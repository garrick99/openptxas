.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p1, %r3, 16;
    @!%p1 sub.s32 %r13, %r3, %r3;
    setp.le.s32 %p1, %r13, 2147483648;
    setp.hi.u32 %p1, %r13, 1;
    @%p1 add.u32 %r10, %r3, 4294967295;
    xor.b32 %r10, %r3, %r3;
    selp.b32 %r18, %r13, %r13, %p1;
    cvt.u64.u32 %rd13, %r18;
    add.u32 %r26, %r10, %r13;
    cvt.s32.s64 %r18, %rd13;
    min.u32 %r9, %r18, 65535;
    shr.s32 %r22, %r18, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
