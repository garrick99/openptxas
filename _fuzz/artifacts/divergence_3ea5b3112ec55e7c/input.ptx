.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r26, %r3, %r3;
    cvt.u64.u32 %rd10, %r26;
    setp.ne.u32 %p4, %r3, 7;
    @%p4 shr.u64 %rd13, %rd10, 33;
    min.u32 %r17, %r3, 65536;
    mul.lo.s32 %r26, %r3, 65536;
    shr.s32 %r22, %r17, 0;
    mul.wide.u32 %rd7, %r17, %r26;
    min.u32 %r17, %r22, %r22;
    setp.eq.s32 %p2, %r26, 65536;
    @%p2 mad.lo.s32 %r17, %r3, %r3, %r17;
    sub.s32 %r5, %r26, %r17;
    or.b32 %r6, %r26, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
