.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    max.s32 %r13, %r3, 16;
    or.b32 %r8, %r3, 8;
    cvt.u32.u64 %r12, %rd5;
    sub.s64 %rd7, %rd5, %rd5;
    cvt.s32.s64 %r13, %rd7;
    shr.u32 %r15, %r8, 16;
    xor.b32 %r5, %r8, %r15;
    add.s32 %r20, %r12, %r13;
    shr.s32 %r6, %r20, 7;
    shr.s32 %r26, %r13, 7;
    mad.lo.s32 %r27, %r6, %r8, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
