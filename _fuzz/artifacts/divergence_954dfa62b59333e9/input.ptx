.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p4, %r3, 4;
    @!%p4 xor.b32 %r21, %r3, %r3;
    setp.ne.s32 %p1, %r3, %r21;
    @%p1 mul.wide.s32 %rd8, %r21, %r3;
    mul.wide.u32 %rd15, %r21, %r3;
    min.u32 %r17, %r3, 15;
    cvt.u64.u32 %rd12, %r17;
    mul.lo.s32 %r11, %r17, %r3;
    add.s32 %r4, %r17, 16;
    sub.u32 %r26, %r4, 2;
    max.s32 %r8, %r4, 2147483648;
    shr.s32 %r16, %r11, 2;
    mul.wide.u32 %rd15, %r21, %r4;
    max.s32 %r20, %r21, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
