.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    mad.lo.u32 %r20, %r3, %r3, %r3;
    shr.s32 %r23, %r20, 2;
    mul.lo.s64 %rd12, %rd8, %rd8;
    or.b32 %r19, %r23, %r20;
    shr.s64 %rd14, %rd12, 62;
    or.b32 %r27, %r23, %r3;
    mul.wide.u32 %rd5, %r19, %r20;
    mad.lo.s32 %r27, %r19, %r23, %r23;
    shl.b64 %rd13, %rd12, 32;
    shr.u64 %rd15, %rd13, 1;
    mad.lo.s32 %r16, %r19, %r20, %r3;
    max.s32 %r9, %r19, 65536;
    cvt.u64.u32 %rd14, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
