.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r24, %r3, %r3;
    shr.u32 %r10, %r24, 15;
    cvt.u64.u32 %rd9, %r10;
    sub.u64 %rd14, %rd9, %rd9;
    shr.s32 %r27, %r24, 1;
    setp.eq.u32 %p4, %r27, 8;
    @!%p4 shr.u64 %rd10, %rd14, 33;
    shr.s32 %r24, %r24, 1;
    mul.lo.u32 %r13, %r3, %r3;
    mul.lo.u32 %r14, %r13, 4;
    shr.u32 %r23, %r3, 0;
    and.b32 %r16, %r3, %r14;
    sub.u32 %r13, %r27, %r3;
    cvt.s32.s64 %r5, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
