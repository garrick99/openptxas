.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    shr.s64 %rd13, %rd9, 32;
    add.s32 %r13, %r3, %r3;
    or.b32 %r17, %r3, %r3;
    or.b64 %rd12, %rd9, %rd9;
    shl.b32 %r14, %r3, 16;
    shr.u32 %r22, %r13, 3;
    cvt.s32.s64 %r15, %rd13;
    max.s32 %r9, %r17, 63;
    shl.b32 %r19, %r22, 15;
    and.b64 %rd14, %rd13, %rd9;
    and.b32 %r13, %r13, %r9;
    mul.lo.s32 %r25, %r17, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
