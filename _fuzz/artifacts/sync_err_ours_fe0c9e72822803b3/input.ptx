.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    mul.wide.s32 %rd12, %r3, %r3;
    min.s32 %r23, %r3, %r3;
    shr.s64 %rd6, %rd12, 48;
    cvt.u32.u64 %r8, %rd6;
    cvt.u32.u64 %r11, %rd6;
    shl.b32 %r26, %r8, 15;
    shr.u32 %r27, %r11, 4;
    mad.lo.s32 %r24, %r11, %r23, %r27;
    add.s32 %r6, %r26, %r8;
    and.b32 %r14, %r24, %r26;
    and.b32 %r7, %r24, %r26;
    shr.u32 %r6, %r11, 0;
    mad.lo.s32 %r24, %r7, %r27, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
