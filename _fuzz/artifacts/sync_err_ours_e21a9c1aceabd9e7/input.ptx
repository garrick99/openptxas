.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r11, %r3, 15;
    cvt.s64.s32 %rd15, %r11;
    mul.wide.s32 %rd5, %r3, %r3;
    mul.wide.u32 %rd6, %r3, %r3;
    and.b32 %r26, %r3, %r11;
    sub.s32 %r20, %r11, %r26;
    shr.s64 %rd6, %rd6, 4;
    shr.s32 %r4, %r26, 0;
    shl.b32 %r13, %r20, 3;
    cvt.u32.u64 %r10, %rd5;
    min.u32 %r10, %r4, 65536;
    add.s32 %r21, %r13, %r11;
    add.s32 %r26, %r3, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
