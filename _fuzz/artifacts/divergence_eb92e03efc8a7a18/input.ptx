.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r20, %r3, 15;
    min.s32 %r26, %r20, 5;
    cvt.s64.s32 %rd13, %r3;
    cvt.u32.u64 %r9, %rd13;
    sub.s32 %r16, %r9, %r20;
    mad.lo.u32 %r24, %r16, %r3, %r9;
    mul.lo.u32 %r11, %r26, %r16;
    shr.s32 %r26, %r3, 31;
    setp.ne.s32 %p1, %r24, %r20;
    @%p1 max.u32 %r6, %r9, 256;
    cvt.u32.u64 %r26, %rd13;
    sub.u32 %r18, %r16, 7;
    sub.u32 %r6, %r20, 65535;
    max.s32 %r14, %r18, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
