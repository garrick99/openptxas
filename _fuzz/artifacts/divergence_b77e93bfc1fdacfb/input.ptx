.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r8, %r3, 1;
    shl.b32 %r26, %r8, 16;
    mad.lo.u32 %r12, %r8, %r26, %r8;
    shr.u32 %r23, %r26, 1;
    mad.lo.s32 %r8, %r3, %r8, %r23;
    cvt.s64.s32 %rd13, %r12;
    max.s32 %r12, %r12, %r26;
    shl.b64 %rd9, %rd13, 48;
    and.b64 %rd14, %rd13, %rd13;
    mul.wide.s32 %rd8, %r3, %r12;
    shr.u64 %rd12, %rd9, 62;
    setp.le.s32 %p4, %r26, %r23;
    @%p4 min.u32 %r10, %r3, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
