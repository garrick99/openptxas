.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p4, %r3, %r3;
    @%p4 and.b32 %r16, %r3, 16;
    and.b32 %r13, %r3, %r3;
    setp.lo.u32 %p4, %r16, 3;
    @!%p4 max.s32 %r17, %r13, %r16;
    cvt.s64.s32 %rd8, %r13;
    setp.gt.s32 %p3, %r17, 8;
    @!%p3 xor.b32 %r7, %r16, %r13;
    shr.u32 %r5, %r3, 3;
    add.s32 %r16, %r5, %r7;
    cvt.u64.u32 %rd7, %r3;
    xor.b64 %rd14, %rd7, %rd8;
    sub.s32 %r12, %r16, %r3;
    setp.le.s32 %p3, %r17, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
