.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    or.b32 %r18, %r3, %r3;
    sub.u32 %r16, %r3, 4294967295;
    setp.eq.s32 %p3, %r16, %r3;
    @%p3 sub.u32 %r20, %r16, 2147483648;
    shl.b32 %r27, %r20, 3;
    shr.s32 %r23, %r27, 3;
    mul.lo.s32 %r16, %r27, 1;
    shr.s32 %r17, %r23, 4;
    cvt.u64.u32 %rd7, %r18;
    cvt.u64.u32 %rd5, %r27;
    mul.lo.u64 %rd6, %rd9, %rd7;
    add.s32 %r20, %r18, %r16;
    and.b32 %r13, %r16, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
