.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r16, %r3, 1;
    add.s32 %r9, %r16, %r16;
    min.u32 %r17, %r9, 4294967295;
    mul.wide.s32 %rd8, %r16, %r9;
    mul.lo.s32 %r18, %r17, %r17;
    add.u32 %r21, %r17, %r16;
    cvt.u64.u32 %rd11, %r18;
    mul.wide.s32 %rd5, %r17, %r3;
    max.u32 %r6, %r3, 2147483648;
    mul.wide.s32 %rd9, %r16, %r17;
    setp.hs.u32 %p1, %r3, 3;
    @%p1 and.b32 %r19, %r16, 2;
    or.b64 %rd13, %rd8, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
