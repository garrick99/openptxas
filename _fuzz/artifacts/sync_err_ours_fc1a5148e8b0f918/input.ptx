.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd8, %r3, %r3;
    shr.u64 %rd12, %rd8, 31;
    max.s32 %r26, %r3, %r3;
    xor.b32 %r14, %r3, 65536;
    max.s64 %rd7, %rd12, %rd12;
    min.u32 %r12, %r3, %r3;
    max.u32 %r23, %r3, 4;
    mul.lo.s32 %r7, %r3, 4294967295;
    or.b32 %r17, %r23, %r23;
    max.s32 %r19, %r3, 3;
    mul.wide.u32 %rd8, %r23, %r12;
    cvt.u64.u32 %rd7, %r14;
    shr.s64 %rd11, %rd12, 32;
    add.u32 %r9, %r14, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
