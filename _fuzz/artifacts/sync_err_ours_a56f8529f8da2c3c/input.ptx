.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r6, %r3, 7;
    sub.s32 %r18, %r6, 64;
    min.u32 %r13, %r18, %r6;
    cvt.s64.s32 %rd7, %r6;
    xor.b32 %r22, %r18, %r3;
    mul.lo.u32 %r16, %r6, %r3;
    min.s64 %rd7, %rd7, %rd7;
    sub.u32 %r11, %r22, %r22;
    sub.u32 %r23, %r3, 64;
    shl.b32 %r18, %r11, 3;
    sub.u32 %r7, %r22, 31;
    shr.u32 %r16, %r16, 30;
    cvt.s32.s64 %r8, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
