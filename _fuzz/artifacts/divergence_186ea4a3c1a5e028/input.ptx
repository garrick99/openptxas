.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    add.s32 %r10, %r3, %r3;
    shr.u32 %r12, %r10, 0;
    mul.wide.s32 %rd9, %r10, %r3;
    sub.s64 %rd7, %rd6, %rd6;
    xor.b32 %r16, %r12, %r12;
    add.u32 %r25, %r16, 7;
    add.u32 %r26, %r3, %r3;
    cvt.u32.u64 %r14, %rd7;
    shr.u32 %r7, %r14, 3;
    cvt.u64.u32 %rd8, %r7;
    add.u64 %rd10, %rd9, %rd8;
    cvt.u32.u64 %r13, %rd9;
    mul.lo.s32 %r21, %r26, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
