.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    mul.lo.s32 %r15, %r3, 4294967295;
    or.b32 %r14, %r3, 64;
    setp.hs.u32 %p2, %r14, %r14;
    @!%p2 cvt.s32.s64 %r19, %rd6;
    shr.u32 %r18, %r3, 16;
    add.s32 %r18, %r14, %r19;
    add.s32 %r10, %r14, %r3;
    min.u32 %r11, %r19, %r14;
    cvt.u32.u64 %r21, %rd6;
    and.b64 %rd12, %rd6, %rd6;
    sub.s32 %r13, %r18, 16;
    xor.b32 %r7, %r3, %r21;
    mad.lo.u32 %r9, %r14, %r13, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
