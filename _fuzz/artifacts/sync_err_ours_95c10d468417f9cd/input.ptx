.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r8, %r3, 1;
    cvt.s64.s32 %rd15, %r8;
    mad.lo.u32 %r8, %r3, %r8, %r8;
    cvt.s64.s32 %rd8, %r3;
    mul.wide.s32 %rd15, %r3, %r8;
    add.u64 %rd11, %rd8, %rd8;
    xor.b32 %r15, %r3, %r3;
    xor.b32 %r22, %r15, %r3;
    add.s32 %r22, %r8, 15;
    or.b32 %r4, %r8, %r22;
    mul.lo.u64 %rd13, %rd8, %rd15;
    cvt.u64.u32 %rd11, %r3;
    setp.ge.s32 %p4, %r15, %r4;
    @!%p4 cvt.u32.u64 %r23, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
