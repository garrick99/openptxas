.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r12, %r3, 0;
    mul.wide.s32 %rd6, %r12, %r12;
    mul.lo.s32 %r26, %r12, 2147483648;
    add.u64 %rd6, %rd6, %rd6;
    setp.le.s32 %p3, %r26, 2147483648;
    @%p3 sub.s32 %r12, %r12, 7;
    mul.wide.u32 %rd8, %r12, %r12;
    setp.ge.s32 %p4, %r26, 7;
    add.u32 %r20, %r12, %r12;
    cvt.s64.s32 %rd5, %r12;
    mad.lo.u32 %r23, %r26, %r3, %r12;
    add.u32 %r4, %r12, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
