.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r22, %r3, 15;
    add.u32 %r23, %r22, 31;
    sub.u32 %r14, %r22, %r23;
    cvt.u64.u32 %rd10, %r23;
    min.s32 %r21, %r14, 7;
    cvt.u32.u64 %r4, %rd10;
    mul.wide.u32 %rd14, %r3, %r22;
    mul.lo.s64 %rd11, %rd10, %rd14;
    shr.u32 %r16, %r4, 7;
    add.s64 %rd15, %rd14, %rd11;
    min.u32 %r10, %r14, %r16;
    min.s64 %rd13, %rd14, %rd15;
    mad.lo.s32 %r26, %r21, %r16, %r4;
    setp.gt.s32 %p2, %r4, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
