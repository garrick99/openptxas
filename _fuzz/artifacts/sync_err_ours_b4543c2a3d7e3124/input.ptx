.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    min.u64 %rd9, %rd11, %rd11;
    max.s32 %r20, %r3, %r3;
    mad.lo.s32 %r25, %r3, %r3, %r3;
    sub.u32 %r13, %r20, 256;
    mul.wide.u32 %rd8, %r25, %r3;
    min.s32 %r20, %r25, %r20;
    mul.wide.s32 %rd12, %r13, %r3;
    mul.wide.u32 %rd13, %r3, %r3;
    sub.s32 %r20, %r3, %r3;
    shr.s64 %rd14, %rd11, 15;
    max.u32 %r5, %r3, %r25;
    shl.b32 %r4, %r3, 1;
    cvt.s64.s32 %rd13, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
