.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    add.s32 %r16, %r3, %r3;
    min.s32 %r21, %r3, %r3;
    mul.wide.s32 %rd15, %r21, %r3;
    mad.lo.u32 %r22, %r21, %r3, %r21;
    add.s32 %r23, %r22, 1;
    setp.lt.s32 %p3, %r22, %r23;
    max.u32 %r25, %r16, 0;
    xor.b64 %rd8, %rd15, %rd5;
    setp.lt.s32 %p2, %r25, %r22;
    @%p2 cvt.s32.s64 %r27, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
