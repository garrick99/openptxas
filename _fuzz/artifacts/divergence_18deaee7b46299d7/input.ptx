.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd8, %r3, %r3;
    max.s32 %r22, %r3, 255;
    cvt.s64.s32 %rd8, %r22;
    max.s32 %r12, %r22, 65535;
    shr.s32 %r7, %r12, 31;
    add.u32 %r17, %r3, %r12;
    xor.b32 %r13, %r7, 65536;
    xor.b32 %r12, %r17, 64;
    mul.lo.u32 %r15, %r13, %r13;
    mul.wide.s32 %rd12, %r12, %r17;
    max.s32 %r21, %r22, 16;
    cvt.u32.u64 %r11, %rd8;
    mul.lo.s64 %rd9, %rd12, %rd12;
    shr.u32 %r5, %r22, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
