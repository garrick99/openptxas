.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    mul.lo.u64 %rd5, %rd7, %rd7;
    shr.u64 %rd15, %rd7, 33;
    shr.s64 %rd8, %rd15, 48;
    or.b32 %r8, %r3, %r3;
    cvt.u32.u64 %r17, %rd5;
    cvt.u32.u64 %r15, %rd5;
    mul.lo.u32 %r16, %r17, %r8;
    shr.u32 %r24, %r8, 0;
    sub.u64 %rd8, %rd5, %rd15;
    and.b32 %r23, %r3, %r3;
    shr.u32 %r10, %r15, 4;
    or.b32 %r14, %r8, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
