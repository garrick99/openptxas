.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    shl.b32 %r15, %r3, 31;
    min.u32 %r21, %r15, 65536;
    mad.lo.u32 %r19, %r3, %r15, %r21;
    shr.s64 %rd9, %rd5, 31;
    mad.lo.s32 %r10, %r3, %r21, %r15;
    mul.wide.s32 %rd5, %r10, %r21;
    cvt.u64.u32 %rd7, %r10;
    setp.le.s32 %p3, %r10, 64;
    @!%p3 add.u32 %r25, %r10, 0;
    mul.wide.s32 %rd5, %r15, %r10;
    shr.u64 %rd11, %rd7, 15;
    min.s64 %rd7, %rd7, %rd5;
    min.s32 %r16, %r25, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
