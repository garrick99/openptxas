.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r12, %r3, %r3;
    cvt.u64.u32 %rd8, %r12;
    xor.b32 %r13, %r3, %r12;
    sub.s32 %r21, %r3, 4;
    mul.lo.u32 %r7, %r13, %r13;
    add.s32 %r4, %r3, %r12;
    setp.le.s32 %p4, %r4, 2;
    @!%p4 cvt.s64.s32 %rd10, %r4;
    mul.lo.u32 %r12, %r3, 4294967295;
    mul.wide.u32 %rd14, %r7, %r4;
    mul.wide.s32 %rd13, %r21, %r4;
    sub.s32 %r13, %r12, %r4;
    shl.b64 %rd15, %rd13, 33;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
