.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd8, %r3, %r3;
    mad.lo.s32 %r8, %r3, %r3, %r3;
    min.s32 %r16, %r8, 2147483648;
    mul.lo.u32 %r26, %r16, %r16;
    sub.u32 %r16, %r8, %r16;
    shr.s64 %rd7, %rd8, 32;
    add.s64 %rd14, %rd8, %rd8;
    max.u64 %rd8, %rd7, %rd14;
    max.s32 %r4, %r8, 64;
    mad.lo.u32 %r13, %r3, %r8, %r16;
    and.b32 %r6, %r13, 32;
    mul.lo.s32 %r11, %r3, 255;
    setp.ge.u32 %p3, %r16, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
