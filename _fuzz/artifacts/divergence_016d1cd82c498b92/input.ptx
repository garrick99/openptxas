.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r17, %r3, %r3;
    setp.ge.s32 %p2, %r3, 31;
    @%p2 mul.wide.s32 %rd11, %r3, %r17;
    cvt.s32.s64 %r22, %rd11;
    mul.wide.u32 %rd5, %r17, %r3;
    add.u64 %rd7, %rd11, %rd5;
    shl.b32 %r24, %r17, 4;
    mul.lo.u32 %r5, %r24, 4294967295;
    and.b32 %r16, %r5, %r3;
    mul.lo.u32 %r10, %r24, %r24;
    shr.u32 %r6, %r17, 2;
    xor.b32 %r23, %r3, 64;
    shl.b64 %rd13, %rd5, 7;
    selp.b32 %r26, %r3, %r5, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
