.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p2, %r3, 65536;
    @%p2 selp.b32 %r25, %r3, %r3, %p2;
    and.b32 %r25, %r25, %r25;
    setp.gt.s32 %p2, %r25, %r25;
    mul.lo.s32 %r4, %r3, %r25;
    sub.s32 %r12, %r4, %r4;
    mul.wide.u32 %rd9, %r25, %r3;
    min.u32 %r21, %r25, 4;
    shr.s64 %rd15, %rd9, 33;
    mul.wide.s32 %rd12, %r4, %r3;
    mad.lo.u32 %r4, %r25, %r21, %r12;
    selp.b32 %r9, %r12, %r3, %p2;
    mad.lo.u32 %r15, %r21, %r4, %r9;
    shr.u64 %rd9, %rd12, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
