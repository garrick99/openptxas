.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r21, %r3, %r3;
    add.s32 %r14, %r21, %r21;
    max.u32 %r6, %r21, 31;
    cvt.s64.s32 %rd5, %r3;
    add.s32 %r7, %r3, %r21;
    cvt.s64.s32 %rd7, %r7;
    cvt.s64.s32 %rd5, %r21;
    min.s32 %r19, %r6, %r14;
    add.u32 %r12, %r7, 5;
    xor.b32 %r13, %r21, 4294967295;
    shl.b32 %r14, %r12, 15;
    xor.b32 %r21, %r12, %r3;
    shr.u32 %r16, %r21, 2;
    mul.wide.s32 %rd7, %r14, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
