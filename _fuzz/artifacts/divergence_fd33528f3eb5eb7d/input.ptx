.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r24, %r3, %r3, %r3;
    cvt.s64.s32 %rd5, %r3;
    min.s32 %r5, %r24, 1;
    cvt.u32.u64 %r19, %rd5;
    cvt.u32.u64 %r19, %rd5;
    min.u32 %r26, %r3, %r5;
    mul.lo.u32 %r5, %r5, %r26;
    setp.lt.s32 %p1, %r24, %r5;
    shr.s64 %rd13, %rd5, 47;
    shr.s32 %r16, %r26, 4;
    shr.u32 %r9, %r24, 16;
    and.b32 %r9, %r16, %r16;
    sub.s32 %r17, %r9, %r19;
    cvt.u64.u32 %rd5, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
