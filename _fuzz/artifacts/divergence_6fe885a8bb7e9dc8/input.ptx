.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r26, %r3, 4;
    setp.le.u32 %p1, %r26, 0;
    @%p1 mul.lo.s32 %r11, %r26, %r26;
    or.b32 %r9, %r3, %r26;
    mul.wide.s32 %rd10, %r11, %r3;
    selp.b32 %r11, %r11, %r9, %p1;
    min.s32 %r15, %r11, %r26;
    shr.s32 %r26, %r11, 0;
    sub.s32 %r24, %r9, %r9;
    add.s32 %r22, %r24, %r26;
    min.s64 %rd5, %rd10, %rd10;
    mul.lo.s32 %r8, %r26, 4;
    mul.wide.u32 %rd7, %r26, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
