.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r21, %r3, 32;
    and.b32 %r12, %r3, %r21;
    cvt.s64.s32 %rd11, %r12;
    setp.ne.u32 %p3, %r3, 8;
    setp.ne.s32 %p1, %r3, 7;
    min.u32 %r7, %r3, %r3;
    cvt.s32.s64 %r20, %rd11;
    sub.s32 %r26, %r7, %r20;
    xor.b32 %r4, %r3, %r21;
    mul.wide.u32 %rd6, %r3, %r20;
    add.s64 %rd10, %rd11, %rd6;
    max.s32 %r27, %r12, 1;
    selp.b32 %r7, %r26, %r3, %p3;
    add.s32 %r25, %r26, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
