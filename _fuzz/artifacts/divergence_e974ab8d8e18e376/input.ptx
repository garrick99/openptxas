.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r9, %r3, %r3;
    sub.u32 %r14, %r3, 65536;
    mul.wide.u32 %rd6, %r3, %r14;
    cvt.s32.s64 %r6, %rd6;
    max.u32 %r25, %r14, 7;
    mad.lo.s32 %r6, %r25, %r25, %r3;
    sub.u64 %rd15, %rd6, %rd6;
    setp.ge.s32 %p4, %r9, 65536;
    @!%p4 selp.b32 %r23, %r6, %r6, %p4;
    min.s32 %r25, %r23, %r9;
    sub.u32 %r27, %r3, %r25;
    cvt.u32.u64 %r22, %rd15;
    mul.lo.u32 %r20, %r23, 2;
    setp.le.u32 %p4, %r25, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
