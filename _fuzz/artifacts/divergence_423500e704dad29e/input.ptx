.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r9, %r3, 256;
    setp.gt.s32 %p1, %r3, %r3;
    @%p1 shl.b32 %r21, %r9, 31;
    xor.b32 %r23, %r3, %r9;
    cvt.u64.u32 %rd11, %r23;
    shl.b32 %r10, %r23, 30;
    mul.wide.s32 %rd5, %r21, %r23;
    setp.gt.s32 %p3, %r21, 64;
    cvt.s64.s32 %rd11, %r3;
    min.u32 %r6, %r21, 63;
    shl.b32 %r14, %r23, 1;
    shr.s32 %r22, %r6, 2;
    mul.wide.s32 %rd13, %r21, %r23;
    min.s32 %r23, %r21, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
