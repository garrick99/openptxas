.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r6, %r3, %r3;
    shr.u32 %r13, %r3, 7;
    max.u32 %r20, %r3, %r13;
    cvt.u64.u32 %rd8, %r3;
    mul.wide.u32 %rd10, %r20, %r13;
    min.s32 %r11, %r20, %r3;
    min.s32 %r7, %r13, 3;
    max.s32 %r4, %r3, %r13;
    mad.lo.s32 %r15, %r20, %r13, %r20;
    setp.ge.u32 %p1, %r7, %r3;
    @%p1 min.u32 %r26, %r11, %r11;
    shl.b32 %r6, %r4, 1;
    xor.b32 %r22, %r7, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
