.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    shr.s32 %r23, %r3, 3;
    add.u32 %r9, %r23, 65535;
    add.s64 %rd6, %rd11, %rd11;
    xor.b32 %r18, %r9, %r23;
    max.u64 %rd12, %rd11, %rd6;
    sub.u32 %r17, %r23, %r9;
    mul.lo.s32 %r14, %r23, 4;
    min.u64 %rd11, %rd6, %rd6;
    shl.b32 %r14, %r3, 1;
    cvt.s64.s32 %rd5, %r17;
    shl.b32 %r24, %r14, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
