.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    min.u32 %r17, %r3, %r3;
    add.u32 %r26, %r3, %r3;
    shr.s32 %r20, %r26, 7;
    setp.lt.s32 %p4, %r26, %r3;
    @!%p4 xor.b32 %r11, %r20, 0;
    setp.ge.s32 %p1, %r26, 1;
    @%p1 mul.wide.s32 %rd12, %r26, %r11;
    add.u32 %r25, %r11, 65535;
    max.u32 %r11, %r25, 5;
    mul.wide.u32 %rd11, %r11, %r3;
    setp.eq.s32 %p1, %r17, 16;
    selp.b32 %r22, %r11, %r11, %p4;
    cvt.u32.u64 %r5, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
