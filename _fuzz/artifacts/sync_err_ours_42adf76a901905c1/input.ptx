.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    and.b32 %r4, %r3, %r3;
    shr.s32 %r24, %r4, 15;
    sub.u64 %rd5, %rd13, %rd13;
    mul.lo.s64 %rd11, %rd5, %rd5;
    mul.lo.u32 %r23, %r24, %r4;
    sub.s32 %r25, %r4, 8;
    mul.lo.s32 %r18, %r3, %r4;
    mul.lo.u32 %r5, %r3, 32;
    mul.lo.s32 %r18, %r24, %r18;
    cvt.u32.u64 %r8, %rd13;
    sub.u32 %r18, %r8, 32;
    mad.lo.u32 %r24, %r24, %r5, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
