.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r11, %r3, %r3;
    mad.lo.s32 %r6, %r11, %r11, %r11;
    max.u32 %r15, %r11, %r6;
    sub.u32 %r15, %r3, %r15;
    mad.lo.u32 %r8, %r3, %r6, %r3;
    setp.le.s32 %p1, %r6, 255;
    @%p1 shl.b32 %r12, %r3, 2;
    sub.s32 %r9, %r11, %r15;
    shr.u32 %r27, %r3, 3;
    mul.lo.s32 %r18, %r15, 7;
    max.s32 %r23, %r6, 31;
    mul.lo.u32 %r25, %r23, 32;
    mad.lo.s32 %r23, %r15, %r27, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
