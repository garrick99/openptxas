.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r23, %r3, %r3;
    add.s32 %r17, %r23, 2;
    mad.lo.s32 %r13, %r17, %r17, %r23;
    sub.u32 %r9, %r17, 0;
    sub.s32 %r16, %r17, 65536;
    or.b32 %r21, %r17, %r13;
    setp.le.s32 %p3, %r17, 32;
    @%p3 mul.wide.s32 %rd13, %r17, %r13;
    setp.eq.u32 %p3, %r3, %r9;
    @!%p3 cvt.s32.s64 %r25, %rd13;
    cvt.u32.u64 %r13, %rd13;
    setp.hi.u32 %p3, %r9, %r21;
    @%p3 shl.b32 %r12, %r16, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
