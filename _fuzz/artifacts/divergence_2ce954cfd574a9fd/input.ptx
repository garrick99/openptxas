.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r9, %r3, %r3;
    bfe.s32 %r10, %r3, 8, 31;
    bfi.b32 %r13, %r10, %r10, 23, 7;
    bfi.b32 %r21, %r3, %r13, 7, 7;
    bfe.u32 %r5, %r21, 16, 1;
    bfe.u32 %r17, %r21, 23, 1;
    popc.b32 %r20, %r13;
    brev.b32 %r19, %r17;
    bfe.s32 %r13, %r13, 15, 24;
    clz.b32 %r23, %r13;
    bfe.s32 %r16, %r21, 31, 8;
    clz.b32 %r8, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
