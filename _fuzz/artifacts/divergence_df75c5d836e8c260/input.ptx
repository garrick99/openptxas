.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r17, %r3, 1;
    setp.le.s32 %p2, %r17, %r3;
    @!%p2 mad.lo.u32 %r22, %r17, %r3, %r3;
    add.u32 %r15, %r17, %r22;
    or.b32 %r15, %r3, 256;
    mul.wide.u32 %rd11, %r3, %r3;
    max.u32 %r23, %r17, 4;
    min.s64 %rd12, %rd11, %rd11;
    or.b32 %r16, %r22, %r3;
    and.b32 %r10, %r16, %r16;
    sub.s32 %r15, %r23, 5;
    mul.wide.s32 %rd12, %r23, %r16;
    sub.s32 %r23, %r16, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
