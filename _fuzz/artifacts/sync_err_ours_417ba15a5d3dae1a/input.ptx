.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r23, %r3, 1;
    cvt.s64.s32 %rd5, %r23;
    or.b32 %r25, %r23, %r3;
    mul.lo.s64 %rd7, %rd5, %rd5;
    setp.gt.s32 %p2, %r25, 3;
    @%p2 max.u32 %r12, %r3, %r25;
    xor.b32 %r27, %r23, %r23;
    mul.lo.u64 %rd8, %rd7, %rd5;
    mad.lo.u32 %r16, %r23, %r3, %r3;
    shr.s64 %rd14, %rd5, 48;
    shr.s64 %rd13, %rd5, 0;
    add.u32 %r24, %r16, %r27;
    max.u32 %r16, %r23, %r12;
    mad.lo.s32 %r9, %r24, %r27, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
