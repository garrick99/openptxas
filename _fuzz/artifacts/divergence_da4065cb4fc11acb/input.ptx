.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r19, %r3, %r3, %r3;
    mul.wide.s32 %rd15, %r3, %r3;
    and.b32 %r12, %r3, 3;
    max.u32 %r16, %r12, %r12;
    add.u32 %r8, %r12, 16;
    setp.ls.u32 %p3, %r16, %r19;
    @!%p3 and.b32 %r7, %r12, 65536;
    max.u64 %rd5, %rd15, %rd15;
    add.s32 %r6, %r12, %r7;
    mul.lo.s32 %r21, %r19, %r6;
    min.u32 %r15, %r6, 2147483648;
    selp.b32 %r19, %r21, %r15, %p3;
    setp.le.u32 %p3, %r3, 256;
    @%p3 or.b32 %r23, %r19, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
