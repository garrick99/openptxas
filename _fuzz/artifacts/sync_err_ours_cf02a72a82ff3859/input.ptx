.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    cvt.u64.u32 %rd7, %r3;
    xor.b32 %r21, %r3, %r3;
    and.b64 %rd13, %rd7, %rd7;
    min.u32 %r12, %r21, %r3;
    mul.lo.u64 %rd5, %rd11, %rd7;
    shr.s64 %rd6, %rd7, 3;
    cvt.u32.u64 %r21, %rd13;
    shr.u64 %rd15, %rd11, 31;
    sub.s64 %rd8, %rd6, %rd15;
    shr.s64 %rd15, %rd13, 7;
    cvt.u32.u64 %r13, %rd15;
    cvt.u64.u32 %rd14, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
