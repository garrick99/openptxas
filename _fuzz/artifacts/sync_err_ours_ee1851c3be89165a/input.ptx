.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd11, %r3, %r3;
    min.s64 %rd13, %rd11, %rd11;
    add.s32 %r13, %r3, 255;
    max.s32 %r10, %r13, %r3;
    max.u32 %r25, %r13, 4294967295;
    cvt.s32.s64 %r17, %rd13;
    xor.b32 %r20, %r3, %r13;
    mul.lo.u64 %rd8, %rd11, %rd11;
    shr.u64 %rd7, %rd11, 16;
    sub.s32 %r4, %r13, 15;
    add.s32 %r23, %r13, 31;
    shr.s64 %rd7, %rd13, 63;
    or.b32 %r19, %r23, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
