    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r15, %r3, 2147483647;
    mul.wide.s32 %rd12, %r15, %r15;
    cvt.u32.u64 %r12, %rd12;
    shr.u64 %rd10, %rd12, 2;
    shl.b32 %r16, %r15, 16;
    setp.ge.u32 %p3, %r16, 2147483648;
    @%p3 selp.b32 %r26, %r16, %r15, %p3;
    shl.b32 %r22, %r3, 4;
    and.b32 %r13, %r26, %r26;
    shr.s32 %r16, %r16, 15;
    mul.lo.u32 %r20, %r16, %r22;
    and.b32 %r14, %r20, %r13;
    setp.ge.s32 %p2, %r16, 1;
