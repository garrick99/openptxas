.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r24, %r3, 65536;
    mad.lo.s32 %r26, %r3, %r24, %r24;
    add.s32 %r8, %r24, 32;
    mul.lo.u32 %r19, %r26, %r24;
    mul.lo.u32 %r8, %r24, %r8;
    add.u32 %r17, %r8, %r3;
    max.s32 %r5, %r24, 4294967295;
    cvt.s64.s32 %rd14, %r5;
    cvt.u64.u32 %rd7, %r5;
    cvt.u32.u64 %r11, %rd14;
    max.s32 %r27, %r5, 31;
    and.b32 %r17, %r24, 63;
    mad.lo.u32 %r19, %r5, %r8, %r3;
    and.b32 %r17, %r11, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
