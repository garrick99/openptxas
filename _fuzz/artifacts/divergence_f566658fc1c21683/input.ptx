.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p4, %r3, %r3;
    @%p4 xor.b32 %r7, %r3, %r3;
    min.u32 %r25, %r7, 31;
    and.b32 %r23, %r3, 255;
    cvt.s64.s32 %rd9, %r23;
    selp.b32 %r15, %r23, %r3, %p4;
    max.s32 %r14, %r3, 256;
    and.b64 %rd7, %rd9, %rd9;
    or.b64 %rd14, %rd9, %rd9;
    shr.s32 %r11, %r23, 15;
    shr.u32 %r12, %r7, 2;
    mul.lo.u32 %r5, %r23, 1;
    mad.lo.u32 %r21, %r5, %r15, %r7;
    sub.s64 %rd10, %rd7, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
