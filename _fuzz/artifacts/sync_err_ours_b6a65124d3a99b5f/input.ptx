.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd14, %r3, %r3;
    or.b32 %r17, %r3, %r3;
    and.b32 %r18, %r3, 0;
    min.u32 %r23, %r17, 16;
    cvt.s32.s64 %r24, %rd14;
    sub.u32 %r21, %r18, %r24;
    min.u32 %r4, %r24, %r23;
    mul.lo.u32 %r23, %r23, 3;
    shr.s64 %rd14, %rd14, 30;
    cvt.u32.u64 %r11, %rd14;
    or.b32 %r4, %r11, %r3;
    add.s64 %rd6, %rd14, %rd14;
    sub.s32 %r21, %r11, %r4;
    or.b32 %r5, %r24, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
