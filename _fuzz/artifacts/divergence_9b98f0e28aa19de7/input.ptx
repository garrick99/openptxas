.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    setp.gt.s32 %p4, %r3, %r3;
    @!%p4 shr.s64 %rd15, %rd13, 3;
    mad.lo.u32 %r7, %r3, %r3, %r3;
    cvt.u32.u64 %r11, %rd13;
    selp.b32 %r23, %r3, %r3, %p4;
    cvt.s64.s32 %rd10, %r23;
    shr.s64 %rd13, %rd13, 62;
    shr.u32 %r17, %r23, 16;
    selp.b32 %r27, %r23, %r17, %p4;
    shr.u32 %r16, %r7, 0;
    mul.wide.s32 %rd9, %r16, %r17;
    sub.u32 %r12, %r17, %r7;
    mul.wide.u32 %rd15, %r12, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
