    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r27, %r3, 2147483648;
    cvt.s64.s32 %rd13, %r27;
    add.s64 %rd12, %rd13, %rd13;
    mad.lo.s32 %r11, %r3, %r27, %r27;
    max.u32 %r6, %r3, %r11;
    cvt.u32.u64 %r16, %rd13;
    max.u32 %r25, %r16, 4;
    max.u32 %r7, %r3, %r27;
    shr.s32 %r21, %r6, 3;
    mad.lo.s32 %r24, %r25, %r6, %r16;
    add.u32 %r6, %r6, %r11;
    setp.ge.s32 %p2, %r11, %r3;
