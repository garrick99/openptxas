.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    cvt.s32.s64 %r11, %rd6;
    sub.u32 %r21, %r11, 4;
    shl.b64 %rd13, %rd6, 2;
    shr.u32 %r12, %r11, 4;
    mul.wide.u32 %rd10, %r12, %r11;
    min.s32 %r26, %r12, 32;
    shl.b64 %rd14, %rd13, 0;
    shr.s64 %rd14, %rd6, 30;
    min.u32 %r19, %r12, 0;
    shr.u64 %rd14, %rd14, 15;
    max.s32 %r24, %r26, 4;
    mul.lo.s64 %rd15, %rd6, %rd6;
    mul.wide.u32 %rd12, %r24, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
