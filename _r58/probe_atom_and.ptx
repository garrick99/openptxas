.version 9.0
.target sm_120
.address_size 64

.visible .entry atom_and_min(.param .u64 p_out, .param .u32 mask) {
    .reg .u32 %r<4>;
    .reg .u64 %rd<3>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_out];
    ld.param.u32 %r1, [mask];
    or.b32 %r2, %r0, 0xFF000000;
    atom.global.and.b32 %r3, [%rd0], %r1;
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    st.global.u32 [%rd2], %r3;
    ret;
}
