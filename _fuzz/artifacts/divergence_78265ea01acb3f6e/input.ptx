.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r13, %r3, 8;
    min.s32 %r23, %r13, %r3;
    cvt.u64.u32 %rd8, %r3;
    shr.s64 %rd7, %rd8, 63;
    min.u64 %rd8, %rd8, %rd7;
    mul.lo.u64 %rd7, %rd8, %rd7;
    max.u32 %r25, %r23, 65536;
    max.s32 %r20, %r23, %r23;
    setp.le.s32 %p3, %r25, 2147483647;
    @%p3 sub.s32 %r9, %r25, %r20;
    cvt.u32.u64 %r7, %rd8;
    mul.wide.s32 %rd6, %r25, %r23;
    mul.wide.s32 %rd13, %r20, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
