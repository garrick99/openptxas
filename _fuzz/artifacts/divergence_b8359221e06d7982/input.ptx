.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r25, %r3, %r3;
    min.u32 %r4, %r25, 65535;
    cvt.s64.s32 %rd10, %r25;
    setp.gt.s32 %p1, %r3, %r25;
    @%p1 mul.lo.s32 %r26, %r3, 64;
    shr.u32 %r5, %r4, 3;
    sub.s32 %r18, %r25, 5;
    cvt.u32.u64 %r23, %rd10;
    mul.lo.u32 %r18, %r18, %r3;
    setp.gt.u32 %p2, %r25, 65535;
    setp.le.s32 %p4, %r5, 64;
    cvt.s64.s32 %rd10, %r18;
    selp.b32 %r27, %r23, %r26, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
