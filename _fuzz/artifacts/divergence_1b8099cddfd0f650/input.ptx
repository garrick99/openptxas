.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r27, %r3, %r3;
    setp.gt.u32 %p3, %r3, 8;
    @%p3 min.u32 %r13, %r3, 4294967295;
    add.s32 %r27, %r3, %r13;
    cvt.s64.s32 %rd13, %r27;
    xor.b32 %r8, %r13, 255;
    cvt.s32.s64 %r23, %rd13;
    shl.b32 %r27, %r3, 2;
    cvt.u64.u32 %rd6, %r23;
    sub.s32 %r6, %r27, %r8;
    shr.u32 %r25, %r3, 31;
    sub.s32 %r7, %r13, %r27;
    mad.lo.u32 %r9, %r23, %r3, %r27;
    selp.b32 %r10, %r27, %r8, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
