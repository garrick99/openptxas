.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r17, %r3, %r3;
    min.u32 %r27, %r3, %r3;
    setp.gt.s32 %p3, %r27, 5;
    mul.lo.s32 %r20, %r27, 5;
    setp.eq.s32 %p4, %r20, 16;
    setp.le.s32 %p3, %r27, 4;
    @%p3 add.u32 %r8, %r20, %r20;
    shr.u32 %r22, %r20, 7;
    setp.ge.u32 %p2, %r27, 63;
    @%p2 min.s32 %r27, %r8, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
