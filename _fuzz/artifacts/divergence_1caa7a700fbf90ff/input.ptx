.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    mul.lo.u32 %r23, %r3, %r3;
    cvt.s64.s32 %rd9, %r23;
    add.u32 %r14, %r23, %r3;
    add.s64 %rd8, %rd13, %rd9;
    shl.b32 %r23, %r3, 0;
    cvt.s64.s32 %rd6, %r14;
    max.u32 %r24, %r14, %r3;
    and.b32 %r17, %r3, 15;
    setp.ne.u32 %p2, %r17, %r23;
    @%p2 add.u32 %r7, %r24, %r14;
    mad.lo.s32 %r20, %r3, %r14, %r17;
    max.s32 %r23, %r14, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
