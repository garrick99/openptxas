.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r16, %r3, 7;
    mul.wide.u32 %rd12, %r16, %r16;
    shr.s32 %r16, %r3, 0;
    shr.s32 %r24, %r3, 15;
    min.s32 %r25, %r3, %r16;
    cvt.u32.u64 %r13, %rd12;
    setp.gt.s32 %p3, %r3, 8;
    @%p3 shr.s32 %r20, %r13, 0;
    mul.lo.s32 %r25, %r25, 256;
    xor.b32 %r6, %r16, 2147483648;
    sub.u32 %r26, %r24, %r6;
    mad.lo.s32 %r17, %r16, %r3, %r24;
    add.u64 %rd8, %rd12, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
