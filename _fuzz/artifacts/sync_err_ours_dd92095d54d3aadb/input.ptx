.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r16, %r3, 7;
    setp.ls.u32 %p1, %r16, %r16;
    @!%p1 cvt.s64.s32 %rd9, %r3;
    mul.lo.s32 %r16, %r3, %r3;
    setp.ge.s32 %p1, %r16, 15;
    @!%p1 min.s64 %rd8, %rd9, %rd9;
    and.b32 %r4, %r3, %r3;
    shl.b32 %r21, %r4, 2;
    mul.wide.s32 %rd9, %r4, %r4;
    min.u32 %r15, %r21, 4294967295;
    or.b64 %rd10, %rd8, %rd9;
    shr.s32 %r10, %r4, 1;
    add.u32 %r8, %r10, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
