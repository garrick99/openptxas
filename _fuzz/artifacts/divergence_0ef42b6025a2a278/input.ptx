.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r18, %r3, 2;
    mad.lo.s32 %r19, %r3, %r3, %r18;
    shr.u32 %r27, %r18, 15;
    xor.b32 %r27, %r18, %r3;
    max.s32 %r26, %r19, %r19;
    or.b32 %r27, %r26, %r19;
    mad.lo.u32 %r22, %r27, %r27, %r27;
    mad.lo.u32 %r22, %r22, %r27, %r27;
    xor.b32 %r16, %r18, %r26;
    mul.lo.s32 %r9, %r26, 8;
    cvt.u64.u32 %rd7, %r19;
    mul.wide.u32 %rd8, %r22, %r16;
    max.s32 %r18, %r27, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
