.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r15, %r3, 16;
    mad.lo.u32 %r12, %r3, %r3, %r3;
    mad.lo.s32 %r14, %r15, %r12, %r3;
    xor.b32 %r20, %r14, %r15;
    cvt.s64.s32 %rd9, %r15;
    setp.ge.u32 %p1, %r3, %r14;
    shr.u32 %r24, %r3, 1;
    max.s64 %rd10, %rd9, %rd9;
    sub.s32 %r7, %r24, 65536;
    mad.lo.u32 %r14, %r7, %r15, %r14;
    mad.lo.u32 %r10, %r20, %r20, %r12;
    selp.b32 %r10, %r12, %r15, %p1;
    max.s32 %r24, %r15, 2;
    min.u32 %r4, %r15, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
