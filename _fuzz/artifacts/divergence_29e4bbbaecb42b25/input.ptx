.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    cvt.s64.s32 %rd12, %r3;
    mul.wide.s32 %rd13, %r3, %r3;
    max.u32 %r8, %r3, 65535;
    max.s32 %r7, %r8, %r3;
    shl.b32 %r4, %r7, 0;
    setp.lo.u32 %p2, %r7, 5;
    sub.s32 %r16, %r4, 4;
    shr.s32 %r8, %r7, 7;
    shr.s32 %r11, %r7, 1;
    min.u64 %rd13, %rd13, %rd12;
    shr.u64 %rd13, %rd13, 62;
    min.u32 %r22, %r16, %r8;
    max.s32 %r5, %r4, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
