.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r11, %r3, 255;
    sub.u32 %r9, %r11, 32;
    shr.s32 %r25, %r9, 3;
    setp.lt.s32 %p4, %r25, 32;
    sub.u32 %r13, %r3, 256;
    shl.b32 %r24, %r25, 7;
    cvt.s64.s32 %rd6, %r9;
    or.b32 %r5, %r25, %r24;
    shl.b32 %r4, %r3, 0;
    add.u32 %r5, %r24, %r11;
    shl.b32 %r12, %r24, 4;
    cvt.s32.s64 %r9, %rd6;
    add.s32 %r19, %r4, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
