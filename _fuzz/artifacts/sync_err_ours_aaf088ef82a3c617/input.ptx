.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r8, %r3, %r3;
    add.s32 %r23, %r8, %r3;
    max.s32 %r13, %r8, %r23;
    shr.s32 %r25, %r23, 0;
    and.b32 %r8, %r8, %r3;
    cvt.s64.s32 %rd10, %r3;
    setp.gt.s32 %p3, %r23, %r13;
    @%p3 min.u64 %rd5, %rd10, %rd10;
    cvt.s64.s32 %rd14, %r3;
    shr.u32 %r10, %r23, 2;
    mul.lo.s32 %r8, %r13, %r23;
    add.u64 %rd8, %rd5, %rd5;
    sub.s32 %r4, %r8, %r8;
    xor.b32 %r24, %r4, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
