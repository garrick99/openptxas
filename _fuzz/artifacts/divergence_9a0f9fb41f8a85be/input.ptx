.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p1, %r3, 4294967295;
    @%p1 shl.b32 %r4, %r3, 2;
    min.u32 %r15, %r4, %r4;
    add.s32 %r25, %r4, %r3;
    mad.lo.s32 %r18, %r4, %r4, %r15;
    mad.lo.s32 %r23, %r3, %r4, %r25;
    or.b32 %r9, %r23, %r3;
    shl.b32 %r10, %r18, 2;
    and.b32 %r13, %r18, %r4;
    selp.b32 %r12, %r10, %r3, %p1;
    shr.s32 %r22, %r15, 16;
    min.u32 %r10, %r10, 16;
    mul.lo.s32 %r26, %r3, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
