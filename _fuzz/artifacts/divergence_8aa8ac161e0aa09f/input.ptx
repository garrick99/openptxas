.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p2, %r3, 64;
    shr.s32 %r20, %r3, 15;
    or.b32 %r20, %r3, %r20;
    cvt.s64.s32 %rd10, %r20;
    cvt.u32.u64 %r18, %rd10;
    and.b32 %r26, %r20, 16;
    sub.u64 %rd12, %rd10, %rd10;
    shr.s32 %r13, %r18, 4;
    add.s32 %r21, %r13, 64;
    or.b32 %r15, %r13, %r13;
    and.b64 %rd11, %rd12, %rd12;
    shr.s64 %rd10, %rd11, 31;
    cvt.u64.u32 %rd8, %r21;
    setp.eq.s32 %p3, %r13, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
