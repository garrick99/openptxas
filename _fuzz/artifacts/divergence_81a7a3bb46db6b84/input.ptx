.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd5, %r3, %r3;
    mul.lo.s32 %r9, %r3, %r3;
    setp.gt.s32 %p1, %r9, %r9;
    setp.ne.u32 %p3, %r9, %r3;
    @%p3 max.s32 %r15, %r9, %r3;
    min.s32 %r17, %r15, 31;
    mad.lo.u32 %r4, %r3, %r3, %r17;
    selp.b32 %r18, %r3, %r4, %p3;
    selp.b32 %r24, %r18, %r15, %p1;
    max.u32 %r12, %r3, %r15;
    setp.le.s32 %p2, %r9, 16;
    setp.eq.u32 %p1, %r4, %r3;
    @%p1 sub.s32 %r19, %r17, %r9;
    mul.wide.u32 %rd14, %r15, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
