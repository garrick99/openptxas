.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r21, %r3, %r3;
    min.u32 %r25, %r3, 1;
    add.u32 %r14, %r3, %r21;
    cvt.u64.u32 %rd8, %r14;
    mad.lo.s32 %r23, %r14, %r25, %r3;
    cvt.u32.u64 %r18, %rd8;
    min.u32 %r25, %r23, %r3;
    xor.b32 %r17, %r18, 16;
    setp.lo.u32 %p1, %r17, %r21;
    xor.b32 %r16, %r21, %r21;
    mad.lo.s32 %r19, %r16, %r25, %r3;
    mad.lo.u32 %r5, %r18, %r21, %r17;
    add.s32 %r7, %r16, %r18;
    or.b32 %r5, %r25, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
