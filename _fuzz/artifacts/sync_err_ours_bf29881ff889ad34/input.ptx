.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r4, %r3, 30;
    max.u32 %r20, %r3, %r3;
    mad.lo.s32 %r19, %r3, %r4, %r20;
    max.u32 %r14, %r19, %r19;
    mul.wide.s32 %rd14, %r14, %r19;
    mul.lo.s32 %r26, %r20, 4;
    mad.lo.s32 %r6, %r20, %r4, %r14;
    mad.lo.u32 %r8, %r20, %r3, %r4;
    min.u64 %rd13, %rd14, %rd14;
    mad.lo.s32 %r26, %r19, %r6, %r26;
    shr.u32 %r27, %r8, 4;
    shr.u32 %r27, %r26, 15;
    and.b32 %r5, %r27, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
