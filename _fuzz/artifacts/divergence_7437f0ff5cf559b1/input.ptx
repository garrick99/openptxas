.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r19, %r3, 0;
    mul.lo.u32 %r18, %r19, %r3;
    shl.b32 %r12, %r18, 4;
    shl.b32 %r27, %r18, 2;
    mul.lo.s32 %r12, %r3, %r12;
    max.s32 %r17, %r27, 0;
    cvt.u64.u32 %rd8, %r18;
    max.u32 %r22, %r12, %r12;
    setp.ge.s32 %p4, %r17, 4;
    shl.b32 %r5, %r18, 7;
    sub.u32 %r16, %r22, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
