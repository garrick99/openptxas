.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r4, %r3, %r3;
    shl.b32 %r24, %r3, 4;
    cvt.s64.s32 %rd10, %r24;
    shr.s32 %r11, %r3, 16;
    shl.b32 %r14, %r24, 7;
    max.s64 %rd9, %rd10, %rd10;
    sub.u32 %r9, %r3, %r3;
    sub.s32 %r27, %r14, %r9;
    cvt.u64.u32 %rd8, %r14;
    min.u32 %r13, %r24, %r27;
    mul.lo.u64 %rd11, %rd10, %rd10;
    setp.ls.u32 %p3, %r14, 8;
    @!%p3 or.b32 %r18, %r24, 64;
    add.s32 %r8, %r18, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
