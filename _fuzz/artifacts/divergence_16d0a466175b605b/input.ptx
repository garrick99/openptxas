.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p4, %r3, 8;
    setp.ls.u32 %p2, %r3, %r3;
    @%p2 mul.lo.s32 %r6, %r3, %r3;
    mul.lo.s32 %r21, %r6, 16;
    mad.lo.s32 %r11, %r6, %r21, %r21;
    shl.b32 %r8, %r11, 1;
    min.s32 %r25, %r6, %r11;
    min.u32 %r8, %r3, %r8;
    mul.lo.s32 %r25, %r8, %r11;
    mul.wide.s32 %rd11, %r8, %r8;
    mad.lo.u32 %r6, %r11, %r21, %r25;
    shr.s64 %rd14, %rd11, 16;
    shl.b32 %r9, %r8, 30;
    mad.lo.u32 %r5, %r8, %r11, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
