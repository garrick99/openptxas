.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r25, %r3, 30;
    sub.u32 %r22, %r25, %r25;
    add.s32 %r10, %r22, %r3;
    and.b32 %r21, %r3, %r25;
    cvt.u64.u32 %rd9, %r22;
    sub.s32 %r10, %r25, %r3;
    setp.lt.u32 %p3, %r10, %r22;
    @%p3 xor.b32 %r11, %r21, %r25;
    cvt.u32.u64 %r21, %rd9;
    max.u32 %r19, %r22, %r25;
    cvt.s32.s64 %r26, %rd9;
    add.s32 %r19, %r22, %r11;
    add.s32 %r12, %r19, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
