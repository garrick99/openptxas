.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r25, %r3, %r3, %r3;
    sub.u32 %r23, %r25, 65535;
    shr.u32 %r12, %r3, 3;
    cvt.u64.u32 %rd10, %r23;
    or.b32 %r20, %r25, %r23;
    and.b32 %r19, %r23, 65536;
    or.b64 %rd13, %rd10, %rd10;
    max.u32 %r5, %r12, %r19;
    cvt.s64.s32 %rd14, %r19;
    max.s32 %r24, %r12, %r12;
    mul.lo.u32 %r5, %r12, %r25;
    min.s64 %rd9, %rd10, %rd14;
    mad.lo.u32 %r7, %r12, %r19, %r19;
    min.s32 %r16, %r5, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
