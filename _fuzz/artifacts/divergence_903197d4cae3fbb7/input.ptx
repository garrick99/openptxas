.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r27, %r3, 4;
    sub.u32 %r18, %r27, %r3;
    mul.lo.s32 %r13, %r18, 4;
    cvt.s64.s32 %rd7, %r18;
    shr.u32 %r19, %r27, 3;
    add.u32 %r13, %r18, 31;
    sub.s32 %r7, %r18, %r18;
    and.b32 %r8, %r7, %r18;
    max.u32 %r16, %r3, 63;
    min.u32 %r17, %r27, %r18;
    and.b32 %r17, %r17, 1;
    shr.s32 %r21, %r19, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
