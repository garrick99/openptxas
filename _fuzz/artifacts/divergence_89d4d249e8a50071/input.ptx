    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r5, %r3, 0;
    add.s32 %r5, %r5, %r5;
    cvt.u64.u32 %rd11, %r5;
    add.s32 %r17, %r5, 4294967295;
