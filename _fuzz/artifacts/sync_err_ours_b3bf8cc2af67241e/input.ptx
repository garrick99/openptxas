.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    shr.s32 %r7, %r3, 4;
    add.u32 %r9, %r7, 255;
    min.u32 %r4, %r9, 65536;
    shl.b32 %r6, %r3, 30;
    setp.hs.u32 %p2, %r6, 64;
    @%p2 xor.b32 %r17, %r4, %r7;
    sub.u32 %r19, %r3, %r6;
    and.b32 %r19, %r17, %r9;
    shr.u32 %r4, %r6, 4;
    min.s64 %rd5, %rd5, %rd5;
    mad.lo.s32 %r20, %r7, %r6, %r7;
    mad.lo.s32 %r7, %r19, %r6, %r7;
    or.b32 %r8, %r20, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
