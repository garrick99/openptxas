.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd7, %r3, %r3;
    or.b32 %r10, %r3, 4;
    setp.eq.s32 %p4, %r10, %r10;
    @%p4 min.s64 %rd8, %rd7, %rd7;
    and.b32 %r12, %r10, 4;
    mad.lo.u32 %r16, %r12, %r10, %r3;
    sub.s32 %r10, %r12, 2147483647;
    add.u32 %r9, %r12, %r16;
    and.b32 %r19, %r3, 4;
    mad.lo.u32 %r9, %r12, %r10, %r12;
    setp.eq.u32 %p4, %r16, 65535;
    @%p4 mul.wide.s32 %rd7, %r12, %r19;
    setp.lt.u32 %p3, %r10, 2147483648;
    @%p3 cvt.s32.s64 %r21, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
