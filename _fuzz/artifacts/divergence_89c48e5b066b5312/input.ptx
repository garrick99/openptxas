.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r15, %r3, 30;
    cvt.s64.s32 %rd10, %r3;
    shr.u32 %r24, %r15, 1;
    add.s32 %r16, %r15, 16;
    sub.s64 %rd15, %rd10, %rd10;
    max.s32 %r26, %r16, 0;
    min.s64 %rd8, %rd10, %rd10;
    mul.lo.s32 %r9, %r24, %r16;
    cvt.s32.s64 %r14, %rd10;
    max.u64 %rd10, %rd15, %rd15;
    max.s32 %r5, %r16, %r24;
    or.b64 %rd8, %rd8, %rd10;
    max.s64 %rd5, %rd8, %rd8;
    add.s32 %r21, %r26, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
