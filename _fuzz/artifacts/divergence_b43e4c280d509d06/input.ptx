.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd5, %r3, %r3;
    shr.u32 %r27, %r3, 16;
    max.u32 %r7, %r27, 0;
    shr.u32 %r13, %r3, 30;
    setp.ne.s32 %p4, %r27, %r27;
    setp.hs.u32 %p2, %r3, %r27;
    @!%p2 max.u32 %r19, %r3, 32;
    selp.b32 %r26, %r13, %r7, %p2;
    shr.s64 %rd9, %rd5, 63;
    mad.lo.u32 %r24, %r7, %r26, %r27;
    mul.lo.s32 %r25, %r26, %r26;
    mul.lo.s32 %r24, %r7, %r19;
    setp.gt.s32 %p3, %r19, 16;
    setp.gt.u32 %p3, %r24, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
