.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p4, %r3, 256;
    @%p4 shl.b32 %r9, %r3, 0;
    shr.s32 %r17, %r9, 7;
    cvt.s64.s32 %rd13, %r17;
    mad.lo.u32 %r25, %r17, %r9, %r9;
    setp.hs.u32 %p4, %r25, %r25;
    shr.u32 %r20, %r3, 15;
    shr.u32 %r19, %r17, 15;
    cvt.u64.u32 %rd5, %r9;
    add.u32 %r26, %r25, 2147483648;
    selp.b32 %r9, %r17, %r19, %p4;
    sub.s64 %rd7, %rd13, %rd5;
    mul.lo.s32 %r22, %r9, %r17;
    max.s32 %r17, %r20, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
