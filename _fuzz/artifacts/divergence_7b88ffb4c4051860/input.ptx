.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    add.s32 %r8, %r3, %r3;
    mul.lo.u64 %rd15, %rd15, %rd15;
    cvt.s32.s64 %r8, %rd15;
    and.b32 %r4, %r8, 15;
    sub.s32 %r25, %r4, 8;
    xor.b32 %r10, %r3, %r8;
    setp.gt.s32 %p4, %r10, 4294967295;
    @%p4 min.u32 %r20, %r4, %r4;
    mad.lo.s32 %r27, %r4, %r20, %r8;
    mul.lo.s32 %r24, %r4, 5;
    cvt.s64.s32 %rd12, %r20;
    and.b32 %r15, %r24, %r20;
    min.u32 %r10, %r27, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
