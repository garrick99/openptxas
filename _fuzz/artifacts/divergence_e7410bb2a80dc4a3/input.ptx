.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    setp.lt.u32 %p3, %r3, 65536;
    @!%p3 sub.u32 %r23, %r3, 2;
    mad.lo.u32 %r14, %r3, %r3, %r3;
    shr.s64 %rd13, %rd13, 63;
    shl.b32 %r10, %r3, 4;
    setp.ge.u32 %p1, %r3, %r23;
    @!%p1 mul.lo.u32 %r19, %r14, 31;
    sub.u32 %r17, %r19, 63;
    add.u64 %rd11, %rd13, %rd13;
    min.s64 %rd12, %rd11, %rd11;
    add.s32 %r22, %r14, %r10;
    shl.b32 %r14, %r17, 4;
    mul.lo.s64 %rd13, %rd11, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
