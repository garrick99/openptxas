.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p1, %r3, 7;
    @!%p1 shr.u32 %r16, %r3, 30;
    max.s32 %r23, %r16, 2;
    min.s32 %r19, %r16, %r3;
    shl.b32 %r15, %r16, 31;
    min.s32 %r10, %r3, %r16;
    mul.lo.u32 %r19, %r15, 65535;
    selp.b32 %r13, %r23, %r3, %p1;
    cvt.s64.s32 %rd11, %r13;
    shr.u64 %rd14, %rd11, 2;
    cvt.s32.s64 %r13, %rd14;
    selp.b32 %r6, %r15, %r23, %p1;
    cvt.u32.u64 %r16, %rd11;
    sub.s32 %r26, %r23, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
