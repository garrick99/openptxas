.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r23, %r3, %r3;
    setp.ne.u32 %p4, %r3, %r3;
    @%p4 shr.s32 %r5, %r3, 16;
    min.s32 %r14, %r23, 64;
    xor.b32 %r19, %r14, %r3;
    cvt.s64.s32 %rd7, %r3;
    cvt.u64.u32 %rd13, %r3;
    mul.wide.u32 %rd10, %r14, %r23;
    cvt.u32.u64 %r19, %rd13;
    cvt.s32.s64 %r13, %rd7;
    selp.b32 %r15, %r5, %r3, %p4;
    mul.lo.u64 %rd5, %rd10, %rd10;
    cvt.u64.u32 %rd14, %r15;
    mad.lo.s32 %r5, %r13, %r3, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
