.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r10, %r3, %r3;
    and.b32 %r7, %r3, %r3;
    setp.le.s32 %p3, %r3, 5;
    @%p3 sub.u32 %r14, %r7, 16;
    cvt.u64.u32 %rd14, %r7;
    max.s32 %r22, %r3, 2147483647;
    sub.s32 %r5, %r3, 256;
    shl.b32 %r9, %r22, 16;
    shr.s64 %rd8, %rd14, 15;
    mul.lo.u32 %r19, %r5, 0;
    mul.lo.u64 %rd12, %rd14, %rd8;
    setp.gt.s32 %p2, %r7, 1;
    add.s32 %r21, %r5, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
