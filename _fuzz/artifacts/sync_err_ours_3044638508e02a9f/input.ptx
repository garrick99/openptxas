.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r16, %r3, %r3;
    min.s32 %r15, %r3, %r3;
    or.b32 %r17, %r3, 0;
    cvt.s64.s32 %rd15, %r16;
    add.s64 %rd7, %rd15, %rd15;
    or.b32 %r9, %r16, %r15;
    shr.s32 %r6, %r3, 7;
    cvt.u64.u32 %rd12, %r9;
    setp.hi.u32 %p2, %r16, 2147483647;
    @%p2 shl.b32 %r15, %r9, 0;
    sub.u32 %r10, %r17, %r16;
    max.u64 %rd5, %rd12, %rd7;
    shl.b32 %r11, %r3, 2;
    or.b32 %r4, %r9, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
