    mad.lo.s32 %r7, %r16, %r16, %r14;
    mul.lo.u32 %r21, %r25, %r3;
    shr.s64 %rd15, %rd11, 62;
    min.u32 %r17, %r3, %r21;
    sub.s32 %r17, %r14, 65536;
