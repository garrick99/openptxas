    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    xor.b32 %r21, %r3, %r3;
    xor.b32 %r22, %r3, 1;
    xor.b32 %r19, %r3, %r3;
    mul.lo.s32 %r26, %r19, 4294967295;
    max.u32 %r18, %r19, %r22;
    mul.lo.u64 %rd6, %rd14, %rd14;
    or.b32 %r7, %r18, 64;
    shr.s32 %r10, %r19, 7;
    cvt.s32.s64 %r19, %rd6;
    setp.gt.u32 %p4, %r3, %r10;
    max.s32 %r14, %r22, 15;
    setp.ne.s32 %p4, %r3, 2147483648;
    @%p4 shr.s64 %rd5, %rd6, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
