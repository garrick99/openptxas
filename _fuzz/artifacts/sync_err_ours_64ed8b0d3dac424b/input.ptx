.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    mul.lo.s32 %r9, %r3, %r3;
    add.u32 %r19, %r9, %r3;
    setp.lt.u32 %p1, %r9, 64;
    mad.lo.u32 %r23, %r9, %r3, %r19;
    min.u32 %r25, %r23, 65535;
    setp.le.s32 %p1, %r25, %r9;
    min.u32 %r22, %r23, 7;
    mul.wide.u32 %rd11, %r23, %r25;
    sub.s64 %rd8, %rd10, %rd11;
    add.s32 %r17, %r23, 5;
    xor.b32 %r13, %r9, %r25;
    add.u32 %r24, %r25, 256;
    mad.lo.u32 %r21, %r24, %r9, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
