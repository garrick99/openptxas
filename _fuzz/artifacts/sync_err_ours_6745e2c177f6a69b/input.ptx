.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r19, %r3, 15;
    add.u32 %r24, %r19, %r19;
    cvt.u64.u32 %rd7, %r3;
    cvt.u32.u64 %r15, %rd7;
    mul.lo.u32 %r9, %r24, 1;
    mad.lo.u32 %r20, %r3, %r3, %r9;
    mad.lo.s32 %r17, %r19, %r19, %r20;
    add.u64 %rd8, %rd7, %rd7;
    cvt.s32.s64 %r10, %rd7;
    xor.b32 %r23, %r24, %r9;
    mul.lo.s32 %r11, %r19, %r15;
    max.s32 %r21, %r15, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
