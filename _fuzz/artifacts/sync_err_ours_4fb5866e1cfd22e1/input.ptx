.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r25, %r3, 0;
    mul.wide.u32 %rd9, %r3, %r3;
    add.u32 %r23, %r25, 63;
    sub.u32 %r24, %r25, %r25;
    xor.b32 %r15, %r25, %r3;
    shr.u64 %rd8, %rd9, 15;
    min.u32 %r12, %r23, 63;
    xor.b32 %r20, %r15, %r12;
    shl.b64 %rd11, %rd8, 32;
    xor.b64 %rd15, %rd9, %rd11;
    shl.b64 %rd15, %rd11, 15;
    add.s32 %r16, %r15, 65536;
    sub.u32 %r18, %r3, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
