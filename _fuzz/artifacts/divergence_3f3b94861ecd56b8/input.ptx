.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p2, %r3, 65536;
    mad.lo.s32 %r26, %r3, %r3, %r3;
    add.s32 %r9, %r26, %r3;
    cvt.u64.u32 %rd10, %r9;
    selp.b32 %r4, %r9, %r26, %p2;
    mad.lo.u32 %r6, %r3, %r4, %r4;
    cvt.s64.s32 %rd11, %r6;
    setp.lo.u32 %p4, %r3, 63;
    @%p4 sub.u64 %rd5, %rd11, %rd11;
    setp.ge.u32 %p4, %r9, 8;
    @%p4 shl.b32 %r12, %r9, 2;
    mad.lo.u32 %r7, %r26, %r3, %r9;
    cvt.u32.u64 %r10, %rd5;
    shl.b32 %r6, %r10, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
