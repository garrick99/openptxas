.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r5, %r3, 3;
    shr.u32 %r19, %r5, 2;
    add.s32 %r14, %r5, 63;
    cvt.u64.u32 %rd7, %r5;
    min.u64 %rd8, %rd7, %rd7;
    min.u32 %r27, %r19, 7;
    or.b32 %r18, %r3, 4294967295;
    setp.gt.u32 %p3, %r14, 0;
    @%p3 max.s32 %r27, %r19, %r27;
    mul.lo.s32 %r27, %r27, %r27;
    setp.ge.u32 %p2, %r19, %r27;
    @%p2 mul.lo.u32 %r23, %r3, %r27;
    sub.u32 %r18, %r19, %r3;
    shl.b32 %r6, %r27, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
