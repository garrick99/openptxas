.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r6, %r3, %r3, %r3;
    add.s32 %r19, %r3, 16;
    mul.wide.s32 %rd14, %r19, %r3;
    or.b32 %r10, %r6, 8;
    min.s32 %r13, %r10, %r3;
    and.b32 %r17, %r10, %r3;
    shl.b32 %r16, %r19, 3;
    shr.s64 %rd14, %rd14, 33;
    sub.s32 %r24, %r16, %r17;
    add.u32 %r20, %r13, %r17;
    max.u32 %r27, %r6, %r17;
    shl.b32 %r12, %r27, 15;
    add.s32 %r11, %r16, 31;
    setp.ge.s32 %p1, %r17, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
