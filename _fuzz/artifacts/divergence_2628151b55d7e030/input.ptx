.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r25, %r3, %r3;
    xor.b32 %r23, %r25, 0;
    mul.lo.u32 %r16, %r25, 5;
    mad.lo.u32 %r8, %r25, %r25, %r25;
    shl.b32 %r16, %r8, 1;
    shr.u32 %r18, %r16, 0;
    cvt.s64.s32 %rd7, %r18;
    sub.s32 %r7, %r16, 256;
    add.s32 %r5, %r3, 2;
    xor.b32 %r25, %r18, 4;
    setp.ge.s32 %p2, %r23, 1;
    @%p2 or.b32 %r22, %r7, 2147483647;
    sub.s32 %r24, %r5, 65535;
    mul.lo.s32 %r13, %r22, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
