.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r23, %r3, %r3;
    max.u32 %r25, %r23, %r23;
    setp.lt.u32 %p3, %r23, %r3;
    @!%p3 add.s32 %r14, %r3, 16;
    shr.u32 %r21, %r3, 15;
    mul.wide.s32 %rd11, %r14, %r14;
    shr.u32 %r27, %r25, 31;
    cvt.s32.s64 %r11, %rd11;
    setp.le.s32 %p4, %r3, 4;
    @!%p4 shl.b32 %r19, %r14, 2;
    shr.u64 %rd9, %rd11, 4;
    and.b32 %r13, %r11, %r27;
    shl.b64 %rd6, %rd11, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
