.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r20, %r3, 0;
    mul.lo.u32 %r20, %r3, 15;
    cvt.u64.u32 %rd14, %r3;
    add.u32 %r7, %r20, %r3;
    min.u32 %r10, %r3, %r7;
    shr.s32 %r27, %r20, 31;
    mad.lo.s32 %r24, %r10, %r10, %r10;
    max.s64 %rd7, %rd14, %rd14;
    and.b32 %r12, %r3, 63;
    shr.s64 %rd11, %rd7, 63;
    setp.ge.s32 %p4, %r12, %r7;
    @%p4 selp.b32 %r5, %r3, %r24, %p4;
    add.u32 %r10, %r20, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
