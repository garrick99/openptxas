.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r9, %r3, 31;
    setp.gt.s32 %p3, %r9, 65536;
    cvt.s64.s32 %rd10, %r9;
    min.u32 %r14, %r3, 7;
    cvt.s32.s64 %r13, %rd10;
    cvt.s64.s32 %rd15, %r9;
    shr.s64 %rd14, %rd10, 2;
    add.s64 %rd6, %rd10, %rd15;
    setp.eq.u32 %p2, %r3, %r13;
    @%p2 sub.s32 %r22, %r9, %r13;
    mul.lo.u32 %r17, %r22, %r9;
    selp.b32 %r27, %r22, %r22, %p2;
    setp.gt.u32 %p4, %r22, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
