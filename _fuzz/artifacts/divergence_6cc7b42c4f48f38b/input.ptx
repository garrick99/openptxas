.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r22, %r3, %r3;
    setp.ge.u32 %p2, %r3, %r22;
    @!%p2 selp.b32 %r26, %r22, %r3, %p2;
    mul.wide.u32 %rd10, %r26, %r3;
    cvt.u32.u64 %r9, %rd10;
    cvt.u64.u32 %rd5, %r9;
    mul.lo.u32 %r24, %r26, %r26;
    shr.u64 %rd6, %rd5, 15;
    mad.lo.s32 %r23, %r26, %r22, %r22;
    min.s32 %r10, %r23, 1;
    mad.lo.s32 %r26, %r9, %r9, %r24;
    mul.lo.s32 %r18, %r24, %r23;
    selp.b32 %r23, %r24, %r10, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
