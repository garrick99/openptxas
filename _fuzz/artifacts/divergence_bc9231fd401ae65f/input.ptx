.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r27, %r3, %r3, %r3;
    or.b32 %r27, %r27, 7;
    mul.wide.s32 %rd7, %r27, %r27;
    mad.lo.s32 %r11, %r27, %r3, %r27;
    min.s32 %r4, %r3, 64;
    cvt.s32.s64 %r5, %rd7;
    setp.ne.u32 %p3, %r27, %r5;
    @%p3 sub.s32 %r18, %r3, 0;
    add.u32 %r24, %r4, %r3;
    cvt.s64.s32 %rd14, %r5;
    min.u64 %rd5, %rd7, %rd7;
    max.u32 %r19, %r11, %r18;
    shl.b64 %rd5, %rd5, 15;
    selp.b32 %r19, %r24, %r18, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
