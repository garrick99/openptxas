    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfe.u32 %r9, %r3, 7, 8;
    popc.b32 %r18, %r9;
    popc.b32 %r15, %r9;
    sub.u32 %r6, %r9, %r15;
    bfe.s32 %r23, %r18, 16, 32;
    popc.b32 %r8, %r3;
    and.b32 %r20, %r8, %r9;
    bfi.b32 %r8, %r9, %r15, 23, 31;
    clz.b32 %r23, %r3;
    clz.b32 %r20, %r3;
    bfe.s32 %r14, %r18, 24, 7;
    prmt.b32 %r21, %r3, %r20, 17476;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
