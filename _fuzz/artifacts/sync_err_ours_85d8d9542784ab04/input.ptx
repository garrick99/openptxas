.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r13, %r3, 63;
    sub.s32 %r22, %r3, %r13;
    add.u32 %r15, %r13, %r13;
    add.s32 %r16, %r15, %r22;
    mul.wide.u32 %rd11, %r16, %r13;
    add.u32 %r20, %r16, %r16;
    cvt.s32.s64 %r4, %rd11;
    sub.u64 %rd15, %rd11, %rd11;
    mul.wide.u32 %rd13, %r22, %r3;
    mul.lo.s32 %r23, %r3, 64;
    mul.lo.s32 %r11, %r15, 31;
    mul.wide.s32 %rd10, %r4, %r11;
    shr.u32 %r19, %r15, 3;
    xor.b32 %r7, %r4, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
