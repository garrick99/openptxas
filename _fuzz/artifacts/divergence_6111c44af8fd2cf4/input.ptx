.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p4, %r3, %r3;
    @%p4 add.s32 %r8, %r3, 16;
    mad.lo.s32 %r8, %r8, %r8, %r8;
    min.u32 %r27, %r3, %r3;
    cvt.s64.s32 %rd7, %r8;
    cvt.u32.u64 %r15, %rd7;
    shr.s32 %r11, %r8, 16;
    and.b32 %r6, %r11, %r8;
    setp.ne.s32 %p1, %r3, %r27;
    shl.b32 %r13, %r11, 4;
    min.u32 %r24, %r11, %r11;
    and.b32 %r16, %r6, %r24;
    shl.b64 %rd13, %rd7, 1;
    mul.lo.s32 %r8, %r13, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
