.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r13, %r3, 4;
    add.u32 %r16, %r13, %r3;
    setp.lt.u32 %p4, %r16, 32;
    sub.u32 %r7, %r3, %r13;
    and.b32 %r7, %r16, %r16;
    cvt.u64.u32 %rd11, %r16;
    cvt.s64.s32 %rd14, %r16;
    cvt.s64.s32 %rd15, %r16;
    min.u32 %r6, %r13, %r16;
    min.s32 %r6, %r16, %r3;
    min.u32 %r11, %r7, 15;
    max.s32 %r15, %r11, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
