.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r7, %r3, 64;
    max.u32 %r10, %r7, %r3;
    cvt.s64.s32 %rd8, %r10;
    or.b32 %r26, %r10, 1;
    sub.s32 %r14, %r3, %r26;
    mul.lo.u32 %r14, %r14, %r3;
    shl.b32 %r9, %r10, 4;
    mul.lo.s32 %r25, %r14, %r14;
    sub.s32 %r10, %r26, %r10;
    xor.b64 %rd11, %rd8, %rd8;
    shr.u64 %rd13, %rd11, 15;
    min.s32 %r10, %r26, 2147483648;
    setp.ge.s32 %p3, %r7, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
