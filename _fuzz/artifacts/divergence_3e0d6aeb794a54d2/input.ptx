    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r7, %r3, 64;
    setp.ne.u32 %p4, %r3, %r3;
    @%p4 add.s32 %r17, %r7, 2147483648;
    sub.s32 %r20, %r3, %r7;
    mul.lo.s32 %r5, %r7, 4;
    cvt.u64.u32 %rd9, %r20;
    add.s64 %rd12, %rd9, %rd9;
    setp.ne.s32 %p1, %r3, %r7;
    or.b32 %r27, %r3, %r3;
    or.b32 %r9, %r27, 15;
    mad.lo.u32 %r23, %r20, %r20, %r20;
    cvt.s32.s64 %r6, %rd9;
    sub.u32 %r5, %r17, %r9;
