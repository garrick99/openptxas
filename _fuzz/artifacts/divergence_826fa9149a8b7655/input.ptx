.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p2, %r3, 31;
    @%p2 or.b32 %r7, %r3, 256;
    shr.s32 %r6, %r3, 7;
    min.u32 %r21, %r6, 65536;
    cvt.s64.s32 %rd15, %r3;
    cvt.s64.s32 %rd14, %r21;
    max.u64 %rd12, %rd14, %rd15;
    shl.b32 %r17, %r7, 4;
    max.s32 %r10, %r21, %r6;
    max.u64 %rd15, %rd15, %rd14;
    and.b32 %r14, %r10, 4294967295;
    setp.ge.s32 %p2, %r6, %r3;
    @%p2 mad.lo.u32 %r16, %r17, %r17, %r10;
    mul.lo.u64 %rd8, %rd15, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
