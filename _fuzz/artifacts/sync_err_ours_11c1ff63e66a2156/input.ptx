.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r19, %r3, %r3, %r3;
    add.s32 %r19, %r19, %r19;
    cvt.u64.u32 %rd6, %r3;
    shl.b32 %r13, %r19, 7;
    cvt.u32.u64 %r20, %rd6;
    sub.u64 %rd12, %rd6, %rd6;
    shr.s64 %rd8, %rd12, 30;
    setp.lt.s32 %p2, %r3, 256;
    or.b32 %r6, %r3, 8;
    add.u32 %r14, %r13, %r13;
    shr.u64 %rd13, %rd6, 33;
    shl.b32 %r27, %r6, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
