.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    brev.b32 %r22, %r3;
    clz.b32 %r22, %r22;
    xor.b32 %r21, %r22, %r3;
    bfi.b32 %r14, %r3, %r21, 8, 16;
    clz.b32 %r11, %r21;
    popc.b32 %r17, %r21;
    max.u32 %r6, %r21, 255;
    brev.b32 %r6, %r6;
    bfi.b32 %r11, %r21, %r11, 7, 31;
    and.b32 %r15, %r11, 16;
    bfe.s32 %r15, %r15, 8, 4;
    prmt.b32 %r16, %r14, %r17, 12816;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
