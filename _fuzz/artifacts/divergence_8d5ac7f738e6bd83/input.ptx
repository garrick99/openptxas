.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    min.u32 %r9, %r3, 65536;
    mul.lo.u32 %r25, %r9, 2147483647;
    setp.le.s32 %p2, %r3, 15;
    @%p2 xor.b32 %r27, %r25, %r9;
    add.s32 %r24, %r25, 4294967295;
    sub.s32 %r13, %r25, %r9;
    shl.b32 %r20, %r3, 4;
    min.u64 %rd6, %rd12, %rd12;
    setp.lo.u32 %p1, %r9, %r13;
    @%p1 and.b32 %r22, %r24, 4;
    setp.eq.s32 %p4, %r9, 256;
    @%p4 add.u32 %r19, %r24, 256;
    min.u32 %r22, %r25, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
