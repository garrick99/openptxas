    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r27, %r3, 1;
    mul.lo.u32 %r7, %r27, %r3;
    sub.u32 %r6, %r7, %r3;
    mad.lo.u32 %r25, %r27, %r27, %r6;
    cvt.u64.u32 %rd11, %r7;
    sub.u32 %r18, %r7, 2147483648;
    add.s32 %r7, %r3, 5;
    add.s32 %r11, %r27, 0;
    mul.lo.u64 %rd15, %rd11, %rd11;
    min.u64 %rd9, %rd11, %rd11;
    shr.s64 %rd10, %rd9, 30;
    add.s64 %rd7, %rd9, %rd10;
    setp.ge.s32 %p4, %r25, 7;
    @%p4 mad.lo.s32 %r25, %r11, %r6, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
