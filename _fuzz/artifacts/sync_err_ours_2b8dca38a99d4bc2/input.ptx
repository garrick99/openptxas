.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r9, %r3, 2147483647;
    shr.s32 %r8, %r3, 0;
    mul.wide.s32 %rd9, %r3, %r8;
    or.b32 %r27, %r8, %r8;
    shl.b64 %rd5, %rd9, 30;
    mul.wide.s32 %rd9, %r8, %r8;
    setp.ge.s32 %p4, %r8, %r9;
    @!%p4 max.u32 %r6, %r3, 255;
    mad.lo.u32 %r13, %r27, %r8, %r6;
    setp.gt.s32 %p4, %r8, %r3;
    @%p4 shr.s32 %r20, %r6, 1;
    shr.u32 %r14, %r9, 15;
    cvt.s32.s64 %r18, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
