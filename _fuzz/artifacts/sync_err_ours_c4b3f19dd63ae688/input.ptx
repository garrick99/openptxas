.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r6, %r3, 65535;
    cvt.u64.u32 %rd7, %r6;
    add.s32 %r14, %r3, 256;
    max.s32 %r9, %r3, %r14;
    shr.u32 %r11, %r6, 7;
    min.s32 %r16, %r9, 4294967295;
    mad.lo.u32 %r25, %r11, %r9, %r11;
    mul.lo.u64 %rd5, %rd7, %rd7;
    xor.b32 %r21, %r11, 1;
    shr.s32 %r6, %r14, 2;
    sub.s32 %r22, %r14, 63;
    shl.b64 %rd5, %rd7, 4;
    and.b32 %r4, %r25, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
