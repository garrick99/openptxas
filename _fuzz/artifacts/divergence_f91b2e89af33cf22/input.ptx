.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd9, %r3, %r3;
    mul.wide.u32 %rd12, %r3, %r3;
    or.b32 %r15, %r3, 8;
    cvt.s32.s64 %r19, %rd9;
    setp.gt.s32 %p1, %r15, %r19;
    @%p1 mul.wide.u32 %rd9, %r19, %r3;
    setp.hi.u32 %p1, %r19, %r19;
    shl.b64 %rd14, %rd9, 31;
    or.b32 %r14, %r15, %r19;
    min.u32 %r27, %r3, 2;
    shl.b64 %rd5, %rd14, 3;
    shl.b64 %rd15, %rd14, 15;
    mad.lo.u32 %r7, %r27, %r15, %r19;
    add.u64 %rd11, %rd15, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
