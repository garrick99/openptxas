.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p1, %r3, %r3;
    @%p1 mad.lo.s32 %r11, %r3, %r3, %r3;
    shr.u32 %r13, %r3, 2;
    max.s32 %r23, %r11, %r11;
    and.b32 %r7, %r23, 3;
    cvt.s64.s32 %rd13, %r13;
    cvt.s64.s32 %rd10, %r11;
    min.u32 %r15, %r7, 65535;
    min.s32 %r21, %r23, %r3;
    add.u32 %r16, %r23, %r7;
    or.b64 %rd14, %rd10, %rd10;
    mad.lo.u32 %r8, %r15, %r3, %r11;
    cvt.s32.s64 %r9, %rd10;
    min.s32 %r21, %r15, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
