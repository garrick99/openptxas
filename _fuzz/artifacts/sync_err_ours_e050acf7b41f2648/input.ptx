.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd9, %r3, %r3;
    setp.ge.s32 %p3, %r3, 255;
    @!%p3 and.b32 %r8, %r3, 64;
    shr.u32 %r14, %r8, 15;
    max.s32 %r27, %r14, %r3;
    min.s32 %r16, %r8, %r27;
    or.b32 %r27, %r27, 255;
    add.u32 %r19, %r8, %r16;
    shr.u32 %r26, %r19, 15;
    shr.u32 %r25, %r26, 15;
    cvt.s32.s64 %r20, %rd9;
    mul.wide.s32 %rd9, %r3, %r3;
    selp.b32 %r25, %r19, %r26, %p3;
    shl.b32 %r18, %r8, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
