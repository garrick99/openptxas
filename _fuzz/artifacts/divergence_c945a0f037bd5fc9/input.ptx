    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd8, %r3, %r3;
    setp.le.u32 %p1, %r3, 32;
    @%p1 sub.s32 %r25, %r3, %r3;
    add.s64 %rd6, %rd8, %rd8;
    selp.b32 %r26, %r25, %r3, %p1;
    max.u32 %r26, %r26, 2147483648;
    min.s32 %r5, %r3, %r3;
    min.s32 %r23, %r3, %r5;
