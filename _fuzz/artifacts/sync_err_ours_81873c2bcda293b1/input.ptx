.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r19, %r3, %r3, %r3;
    mad.lo.u32 %r11, %r19, %r3, %r3;
    mul.wide.u32 %rd9, %r19, %r3;
    or.b32 %r21, %r19, 3;
    setp.ne.s32 %p4, %r11, %r11;
    @!%p4 selp.b32 %r17, %r3, %r21, %p4;
    min.s64 %rd12, %rd9, %rd9;
    cvt.s32.s64 %r7, %rd12;
    mul.lo.s32 %r7, %r21, 64;
    min.u64 %rd11, %rd9, %rd12;
    mul.wide.s32 %rd5, %r7, %r17;
    max.s32 %r18, %r7, %r7;
    cvt.u64.u32 %rd12, %r7;
    selp.b32 %r8, %r19, %r17, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
