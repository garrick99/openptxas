.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r19, %r3, %r3;
    mad.lo.u32 %r16, %r19, %r19, %r19;
    setp.eq.u32 %p3, %r16, %r3;
    @%p3 xor.b32 %r24, %r3, 65535;
    mad.lo.s32 %r15, %r3, %r24, %r3;
    shr.u32 %r14, %r19, 0;
    mul.wide.s32 %rd5, %r19, %r15;
    max.u32 %r16, %r3, 3;
    selp.b32 %r25, %r24, %r14, %p3;
    shl.b64 %rd9, %rd5, 2;
    cvt.u32.u64 %r12, %rd9;
    mul.lo.u32 %r8, %r16, %r19;
    xor.b32 %r22, %r25, 31;
    mul.wide.s32 %rd14, %r24, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
