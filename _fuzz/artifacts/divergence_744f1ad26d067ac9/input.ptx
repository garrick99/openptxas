    mad.lo.s32 %r12, %r17, %r17, %r12;
    selp.b32 %r13, %r12, %r10, %p3;
    mul.lo.u32 %r13, %r7, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
