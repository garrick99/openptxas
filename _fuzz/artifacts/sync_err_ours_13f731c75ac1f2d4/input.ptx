.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r27, %r3, %r3;
    cvt.s64.s32 %rd13, %r3;
    max.u64 %rd14, %rd13, %rd13;
    mul.wide.s32 %rd11, %r3, %r27;
    setp.ge.s32 %p4, %r3, 255;
    @%p4 shr.s32 %r25, %r27, 2;
    xor.b32 %r18, %r27, %r3;
    add.u32 %r16, %r27, %r3;
    min.s32 %r23, %r16, %r27;
    or.b32 %r7, %r27, %r23;
    shr.s32 %r5, %r23, 16;
    mul.wide.s32 %rd6, %r18, %r7;
    min.u32 %r6, %r5, 255;
    setp.lt.u32 %p2, %r7, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
