    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r11, %r3, 255;
    mul.lo.u32 %r6, %r11, 64;
    xor.b32 %r24, %r6, %r6;
    xor.b32 %r26, %r3, 2147483648;
    setp.gt.s32 %p2, %r6, 2147483648;
    setp.ls.u32 %p2, %r6, %r3;
    @%p2 shr.s32 %r13, %r26, 30;
    selp.b32 %r25, %r13, %r26, %p2;
    sub.u32 %r7, %r11, 15;
    setp.ls.u32 %p4, %r7, %r13;
    @%p4 or.b32 %r25, %r24, 256;
    shl.b32 %r6, %r7, 15;
    mul.lo.u32 %r22, %r7, 5;
    mad.lo.s32 %r20, %r13, %r7, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
