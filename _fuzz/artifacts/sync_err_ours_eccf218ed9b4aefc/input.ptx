.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r22, %r3, %r3;
    shr.s32 %r25, %r3, 1;
    max.s32 %r11, %r22, 65536;
    cvt.s64.s32 %rd5, %r11;
    shr.u64 %rd13, %rd5, 2;
    setp.le.s32 %p1, %r11, %r11;
    @%p1 max.u64 %rd10, %rd5, %rd13;
    cvt.s32.s64 %r21, %rd10;
    sub.u32 %r6, %r11, %r25;
    cvt.u64.u32 %rd6, %r25;
    max.s32 %r4, %r11, 64;
    min.u32 %r9, %r4, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
