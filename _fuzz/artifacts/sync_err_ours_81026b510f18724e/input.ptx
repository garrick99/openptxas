.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    add.s32 %r27, %r3, %r3;
    setp.lo.u32 %p4, %r27, 0;
    min.s32 %r16, %r27, %r3;
    mul.lo.s32 %r21, %r3, 16;
    mul.wide.u32 %rd6, %r3, %r27;
    shr.u32 %r24, %r16, 4;
    and.b32 %r19, %r27, %r24;
    mad.lo.u32 %r9, %r16, %r19, %r21;
    setp.lt.s32 %p2, %r19, 31;
    cvt.u64.u32 %rd15, %r24;
    sub.u32 %r14, %r3, 4;
    or.b32 %r16, %r14, %r3;
    sub.s64 %rd11, %rd10, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
