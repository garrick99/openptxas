.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r15, %r3, %r3, %r3;
    cvt.u64.u32 %rd13, %r15;
    shl.b64 %rd6, %rd13, 31;
    setp.ge.u32 %p4, %r3, %r15;
    xor.b64 %rd6, %rd13, %rd13;
    or.b64 %rd14, %rd13, %rd13;
    min.u32 %r21, %r15, 5;
    mul.lo.s64 %rd10, %rd14, %rd13;
    cvt.s64.s32 %rd5, %r15;
    shr.u32 %r5, %r3, 2;
    shr.s64 %rd8, %rd10, 32;
    add.s32 %r19, %r15, %r5;
    min.s64 %rd8, %rd13, %rd10;
    shr.u64 %rd14, %rd8, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
