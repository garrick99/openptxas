.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    shl.b32 %r20, %r3, 4;
    min.s32 %r17, %r20, 3;
    cvt.u64.u32 %rd12, %r17;
    shl.b32 %r18, %r20, 31;
    sub.u32 %r24, %r17, %r3;
    shr.u32 %r24, %r24, 3;
    shr.s64 %rd9, %rd12, 16;
    sub.s32 %r10, %r20, 32;
    or.b32 %r14, %r10, %r18;
    cvt.s32.s64 %r10, %rd9;
    min.s64 %rd14, %rd13, %rd13;
    xor.b32 %r19, %r17, %r20;
    mad.lo.s32 %r16, %r10, %r3, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
