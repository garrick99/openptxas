.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    min.u32 %r26, %r3, %r3;
    setp.lt.s32 %p2, %r3, %r3;
    @%p2 add.u32 %r24, %r3, %r3;
    mad.lo.s32 %r8, %r26, %r3, %r26;
    shr.s64 %rd10, %rd12, 30;
    setp.le.s32 %p3, %r8, %r3;
    @!%p3 sub.s32 %r21, %r8, %r24;
    shr.u64 %rd13, %rd12, 31;
    selp.b32 %r4, %r26, %r24, %p3;
    setp.ge.s32 %p1, %r26, %r24;
    @%p1 add.u32 %r9, %r21, %r4;
    max.u32 %r5, %r4, 5;
    mad.lo.u32 %r22, %r24, %r9, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
