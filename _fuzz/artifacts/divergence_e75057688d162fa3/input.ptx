.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r24, %r3, %r3;
    min.u32 %r7, %r3, %r24;
    add.s32 %r8, %r3, %r3;
    xor.b32 %r19, %r7, %r24;
    add.u32 %r10, %r19, 4;
    cvt.s64.s32 %rd5, %r7;
    max.u32 %r14, %r24, 64;
    sub.s32 %r24, %r19, 16;
    cvt.s32.s64 %r13, %rd5;
    max.s32 %r4, %r14, 2;
    max.s32 %r10, %r14, 255;
    shl.b64 %rd10, %rd5, 2;
    cvt.u64.u32 %rd7, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
