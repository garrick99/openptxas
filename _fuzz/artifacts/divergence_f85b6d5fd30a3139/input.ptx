.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    max.s32 %r17, %r3, 4294967295;
    mul.wide.u32 %rd8, %r3, %r3;
    shr.s64 %rd7, %rd15, 7;
    mul.wide.s32 %rd12, %r3, %r3;
    shr.u32 %r21, %r17, 7;
    max.u32 %r19, %r3, %r17;
    cvt.s32.s64 %r25, %rd12;
    mul.lo.s32 %r19, %r17, 4294967295;
    mad.lo.s32 %r14, %r19, %r17, %r21;
    add.s32 %r7, %r14, %r17;
    shr.s32 %r17, %r14, 31;
    or.b64 %rd12, %rd8, %rd7;
    max.s64 %rd9, %rd7, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
