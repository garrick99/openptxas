    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p3, %r3, 2147483647;
    setp.hi.u32 %p4, %r3, 32;
    shl.b32 %r13, %r3, 16;
    add.u32 %r8, %r3, 5;
    mul.wide.u32 %rd10, %r13, %r3;
    sub.s32 %r21, %r13, 64;
    mad.lo.s32 %r4, %r3, %r13, %r3;
    min.u32 %r21, %r21, %r3;
    mul.lo.u32 %r20, %r3, 65536;
    mul.lo.u32 %r17, %r21, %r8;
    shr.u32 %r25, %r4, 30;
    shr.s32 %r24, %r21, 7;
    setp.lt.u32 %p1, %r25, %r25;
    mul.lo.s32 %r27, %r8, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
