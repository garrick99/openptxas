.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r10, %r3, 8;
    add.u32 %r6, %r10, 15;
    mul.wide.s32 %rd9, %r3, %r3;
    setp.eq.s32 %p4, %r10, 3;
    @%p4 selp.b32 %r23, %r6, %r3, %p4;
    mul.lo.u32 %r11, %r6, %r23;
    mad.lo.u32 %r27, %r10, %r11, %r6;
    sub.s64 %rd5, %rd9, %rd9;
    or.b32 %r15, %r27, 4;
    mul.wide.u32 %rd6, %r11, %r3;
    and.b32 %r15, %r6, %r11;
    setp.ne.u32 %p4, %r6, 1;
    min.u32 %r9, %r10, %r15;
    mul.lo.u32 %r15, %r3, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
