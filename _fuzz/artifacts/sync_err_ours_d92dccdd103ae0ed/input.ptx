.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    shr.u64 %rd6, %rd13, 16;
    shl.b64 %rd11, %rd6, 48;
    mul.wide.u32 %rd8, %r3, %r3;
    mad.lo.s32 %r26, %r3, %r3, %r3;
    shl.b32 %r16, %r26, 0;
    max.u32 %r17, %r3, 0;
    xor.b32 %r8, %r26, %r16;
    min.u32 %r27, %r17, 65535;
    xor.b32 %r12, %r3, %r27;
    add.s32 %r9, %r27, 65535;
    mul.lo.u64 %rd8, %rd8, %rd8;
    and.b32 %r20, %r26, 2;
    and.b64 %rd15, %rd13, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
