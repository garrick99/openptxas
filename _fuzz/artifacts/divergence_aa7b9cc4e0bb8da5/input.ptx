.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd8, %r3, %r3;
    cvt.s64.s32 %rd14, %r3;
    add.s32 %r6, %r3, 63;
    setp.eq.s32 %p1, %r6, 31;
    @%p1 min.u32 %r12, %r3, 3;
    or.b32 %r8, %r3, 3;
    min.u32 %r16, %r12, %r6;
    or.b32 %r9, %r16, 63;
    sub.s32 %r11, %r6, 2;
    sub.u32 %r18, %r8, 256;
    shr.u32 %r5, %r16, 30;
    shl.b32 %r8, %r5, 15;
    min.s32 %r24, %r5, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
