.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfi.b32 %r23, %r3, %r3, 0, 4;
    bfi.b32 %r10, %r23, %r3, 8, 31;
    clz.b32 %r8, %r3;
    max.u32 %r16, %r10, 31;
    clz.b32 %r13, %r16;
    max.u32 %r18, %r16, 16;
    sub.u32 %r10, %r13, 7;
    bfi.b32 %r21, %r10, %r8, 15, 24;
    prmt.b32 %r14, %r13, %r8, 17493;
    brev.b32 %r4, %r18;
    bfe.s32 %r16, %r21, 31, 31;
    bfi.b32 %r14, %r16, %r4, 4, 7;
    ld.param.u64 %rd3, [p_out];
