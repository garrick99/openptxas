.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    min.u32 %r11, %r3, %r3;
    mul.lo.s32 %r22, %r11, %r11;
    cvt.u32.u64 %r7, %rd6;
    shr.s64 %rd12, %rd6, 30;
    sub.u64 %rd12, %rd6, %rd12;
    sub.u32 %r10, %r22, %r22;
    shr.u32 %r8, %r11, 0;
    add.u32 %r7, %r7, 32;
    max.u32 %r17, %r11, 65535;
    max.u64 %rd12, %rd6, %rd12;
    min.u32 %r22, %r11, 4;
    cvt.u64.u32 %rd7, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
