.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r5, %r3, %r3;
    sub.s32 %r18, %r5, %r5;
    setp.ge.u32 %p3, %r3, %r5;
    @%p3 and.b32 %r20, %r3, %r18;
    setp.eq.s32 %p2, %r20, 4;
    selp.b32 %r19, %r18, %r20, %p2;
    cvt.u64.u32 %rd14, %r19;
    and.b32 %r13, %r5, %r20;
    max.u32 %r5, %r13, %r19;
    xor.b32 %r15, %r5, 65535;
    or.b32 %r26, %r15, 3;
    mul.lo.s32 %r24, %r26, %r3;
    shr.u64 %rd5, %rd14, 32;
    shr.u64 %rd8, %rd5, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
