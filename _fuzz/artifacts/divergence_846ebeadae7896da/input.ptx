.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    or.b32 %r16, %r3, %r3;
    add.u32 %r17, %r16, 2147483648;
    mul.lo.s32 %r24, %r3, 64;
    mad.lo.u32 %r5, %r17, %r17, %r3;
    or.b32 %r13, %r17, %r5;
    cvt.u64.u32 %rd10, %r3;
    mul.wide.u32 %rd7, %r5, %r13;
    setp.ge.s32 %p3, %r5, %r16;
    @%p3 max.u32 %r7, %r13, %r3;
    shl.b64 %rd6, %rd8, 31;
    mul.wide.u32 %rd11, %r5, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
