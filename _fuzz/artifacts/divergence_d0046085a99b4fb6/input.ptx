.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.bfly.b32 %r8, %r3, 8, 0x1f, -1;
    shfl.sync.down.b32 %r5, %r0, 4, 0x1f, -1;
    setp.gt.u32 %p1, %r5, 3;
    vote.sync.ballot.b32 %r5, %p1, -1;
    or.b32 %r15, %r0, %r3;
    shfl.sync.down.b32 %r16, %r3, 4, 0x1f, -1;
    setp.ne.u32 %p2, %r5, 15;
    vote.sync.ballot.b32 %r9, %p2, -1;
    shfl.sync.idx.b32 %r10, %r0, 0, 0x1f, -1;
    sub.u32 %r14, %r5, %r3;
    sub.u32 %r7, %r15, %r9;
    shfl.sync.down.b32 %r11, %r5, 16, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
