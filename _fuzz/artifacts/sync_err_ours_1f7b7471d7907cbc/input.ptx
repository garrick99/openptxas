.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r27, %r3, %r3;
    setp.ls.u32 %p3, %r27, 8;
    @%p3 and.b32 %r27, %r27, %r3;
    shr.u32 %r27, %r27, 1;
    add.u32 %r5, %r3, %r3;
    mul.lo.s32 %r25, %r27, 4294967295;
    shr.u32 %r16, %r3, 31;
    selp.b32 %r16, %r5, %r3, %p3;
    cvt.u64.u32 %rd11, %r5;
    max.s32 %r15, %r3, %r5;
    shr.u32 %r14, %r27, 31;
    setp.eq.s32 %p4, %r16, %r25;
    @!%p4 cvt.u32.u64 %r16, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
