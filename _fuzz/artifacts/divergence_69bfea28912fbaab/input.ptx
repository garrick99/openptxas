.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r11, %r3, %r3, %r3;
    and.b32 %r11, %r11, 5;
    cvt.u64.u32 %rd11, %r3;
    min.s64 %rd12, %rd11, %rd11;
    or.b32 %r27, %r3, 5;
    sub.u32 %r6, %r3, 2147483647;
    shl.b32 %r17, %r3, 3;
    xor.b64 %rd14, %rd11, %rd11;
    sub.s32 %r20, %r17, 255;
    max.u32 %r15, %r6, %r17;
    or.b32 %r15, %r3, 4294967295;
    setp.le.s32 %p3, %r3, %r6;
    @%p3 xor.b32 %r14, %r11, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
