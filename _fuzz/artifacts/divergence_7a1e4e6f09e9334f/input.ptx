.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r27, %r3, 31;
    cvt.u64.u32 %rd15, %r3;
    or.b32 %r22, %r3, %r27;
    min.u32 %r15, %r22, %r22;
    cvt.s64.s32 %rd7, %r22;
    add.s32 %r13, %r3, 7;
    setp.lt.s32 %p3, %r15, %r13;
    @!%p3 max.u32 %r24, %r22, %r13;
    mul.wide.u32 %rd15, %r3, %r15;
    setp.lt.s32 %p1, %r24, 15;
    mul.lo.s32 %r15, %r24, %r13;
    mad.lo.u32 %r23, %r13, %r22, %r24;
    or.b32 %r4, %r3, %r13;
    shr.u32 %r25, %r24, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
