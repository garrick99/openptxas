.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    shr.u64 %rd10, %rd10, 31;
    add.u32 %r7, %r3, %r3;
    shr.u64 %rd11, %rd10, 62;
    mul.wide.u32 %rd8, %r3, %r7;
    max.u32 %r27, %r7, 2;
    cvt.u64.u32 %rd12, %r3;
    mul.lo.s64 %rd11, %rd10, %rd12;
    max.u32 %r8, %r7, %r27;
    or.b32 %r15, %r7, %r8;
    shr.u32 %r27, %r3, 15;
    cvt.u32.u64 %r21, %rd12;
    max.u32 %r12, %r15, %r21;
    cvt.s32.s64 %r16, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
