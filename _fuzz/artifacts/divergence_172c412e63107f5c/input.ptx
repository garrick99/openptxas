.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hi.u32 %p4, %r3, %r3;
    @!%p4 add.u32 %r20, %r3, %r3;
    mad.lo.u32 %r17, %r20, %r3, %r3;
    cvt.s64.s32 %rd8, %r17;
    shl.b64 %rd6, %rd8, 62;
    setp.ls.u32 %p2, %r20, %r20;
    @%p2 min.u64 %rd8, %rd6, %rd8;
    add.s32 %r23, %r3, %r17;
    max.s32 %r13, %r23, %r3;
    selp.b32 %r23, %r17, %r17, %p4;
    mad.lo.u32 %r27, %r23, %r20, %r20;
    cvt.u32.u64 %r14, %rd6;
    shr.u32 %r7, %r17, 31;
    add.s32 %r11, %r14, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
