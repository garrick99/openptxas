.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r9, %r3, 2147483647;
    mul.wide.u32 %rd5, %r3, %r9;
    mul.wide.u32 %rd5, %r3, %r9;
    shl.b64 %rd13, %rd5, 2;
    cvt.s64.s32 %rd13, %r9;
    max.s32 %r20, %r9, %r9;
    mul.wide.u32 %rd7, %r3, %r3;
    shr.u64 %rd11, %rd7, 4;
    sub.s32 %r19, %r9, %r20;
    min.s32 %r21, %r9, 5;
    shl.b32 %r7, %r9, 4;
    mul.wide.u32 %rd10, %r20, %r3;
    setp.gt.u32 %p2, %r20, 4294967295;
    cvt.s64.s32 %rd13, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
