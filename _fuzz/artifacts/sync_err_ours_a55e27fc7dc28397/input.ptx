.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r13, %r3, 64;
    mul.lo.s32 %r27, %r13, 5;
    min.s32 %r10, %r27, 63;
    setp.le.s32 %p3, %r3, %r10;
    @%p3 mul.wide.s32 %rd12, %r13, %r3;
    and.b32 %r19, %r3, 5;
    mul.wide.u32 %rd12, %r10, %r13;
    shl.b64 %rd14, %rd12, 62;
    setp.lt.s32 %p1, %r10, %r3;
    cvt.u32.u64 %r6, %rd14;
    add.u64 %rd8, %rd12, %rd12;
    setp.ls.u32 %p1, %r6, 255;
    cvt.s32.s64 %r21, %rd14;
    cvt.u32.u64 %r25, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
