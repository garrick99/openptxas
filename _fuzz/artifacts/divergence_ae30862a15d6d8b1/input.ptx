.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd10, %r3, %r3;
    add.s64 %rd13, %rd10, %rd10;
    cvt.u32.u64 %r7, %rd10;
    setp.gt.u32 %p4, %r7, 8;
    @!%p4 add.u64 %rd6, %rd13, %rd10;
    shr.s64 %rd15, %rd10, 47;
    or.b32 %r23, %r7, 16;
    mad.lo.u32 %r7, %r3, %r7, %r23;
    add.s64 %rd11, %rd13, %rd10;
    cvt.s32.s64 %r7, %rd6;
    cvt.u64.u32 %rd13, %r3;
    shr.s32 %r7, %r7, 7;
    cvt.u64.u32 %rd9, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
