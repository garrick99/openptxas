.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    xor.b32 %r11, %r3, %r3;
    cvt.s64.s32 %rd11, %r3;
    add.s32 %r14, %r3, 2147483648;
    mul.lo.s64 %rd11, %rd11, %rd15;
    mul.lo.s32 %r22, %r3, %r3;
    add.u32 %r4, %r3, 4294967295;
    shr.s32 %r26, %r4, 4;
    mul.wide.u32 %rd6, %r4, %r14;
    min.s32 %r9, %r14, %r14;
    sub.s64 %rd9, %rd15, %rd11;
    setp.lt.s32 %p1, %r14, 63;
    @%p1 cvt.s32.s64 %r15, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
