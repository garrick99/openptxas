    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    clz.b32 %r7, %r3;
    popc.b32 %r4, %r3;
    bfe.s32 %r22, %r7, 4, 1;
    bfe.u32 %r14, %r4, 16, 4;
    popc.b32 %r16, %r4;
    bfe.u32 %r4, %r7, 23, 32;
    bfi.b32 %r22, %r3, %r14, 0, 24;
    bfe.s32 %r16, %r16, 0, 31;
    bfi.b32 %r7, %r14, %r16, 24, 16;
    bfe.u32 %r11, %r16, 4, 32;
    bfe.u32 %r10, %r4, 8, 16;
    prmt.b32 %r22, %r4, %r16, 17476;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
