.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd5, %r3, %r3;
    shr.s32 %r6, %r3, 7;
    min.s32 %r26, %r6, %r3;
    setp.gt.u32 %p2, %r6, 31;
    @%p2 shr.s32 %r10, %r26, 16;
    setp.lo.u32 %p1, %r10, %r6;
    @%p1 mad.lo.u32 %r5, %r3, %r26, %r10;
    mul.lo.s32 %r18, %r10, 32;
    cvt.s32.s64 %r11, %rd5;
    shl.b32 %r18, %r11, 16;
    min.s32 %r25, %r18, 3;
    setp.le.u32 %p3, %r10, %r10;
    and.b32 %r19, %r26, 4;
    mul.lo.u32 %r6, %r10, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
