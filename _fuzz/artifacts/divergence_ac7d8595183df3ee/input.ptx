.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p4, %r3, %r3;
    setp.eq.s32 %p4, %r3, 16;
    @!%p4 cvt.s64.s32 %rd14, %r3;
    shl.b64 %rd6, %rd14, 33;
    selp.b32 %r10, %r3, %r3, %p4;
    selp.b32 %r26, %r10, %r3, %p4;
    mul.wide.u32 %rd7, %r10, %r26;
    add.u64 %rd14, %rd6, %rd7;
    setp.le.s32 %p1, %r26, 2;
    setp.lt.u32 %p4, %r3, %r26;
    cvt.s64.s32 %rd6, %r26;
    selp.b32 %r8, %r26, %r26, %p4;
    cvt.s32.s64 %r21, %rd6;
    min.u64 %rd8, %rd6, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
