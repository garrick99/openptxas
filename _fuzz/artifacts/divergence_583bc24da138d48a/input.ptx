.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r21, %r3, 3;
    cvt.s64.s32 %rd6, %r3;
    min.s32 %r16, %r3, %r21;
    xor.b32 %r5, %r16, %r16;
    mul.wide.u32 %rd6, %r5, %r21;
    setp.hs.u32 %p4, %r16, %r3;
    @%p4 cvt.u64.u32 %rd15, %r3;
    mul.lo.s32 %r4, %r21, %r21;
    max.u32 %r24, %r5, 64;
    mul.lo.u32 %r5, %r4, %r3;
    min.s32 %r25, %r3, %r5;
    or.b32 %r5, %r24, 1;
    or.b64 %rd11, %rd15, %rd15;
    add.u32 %r4, %r24, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
