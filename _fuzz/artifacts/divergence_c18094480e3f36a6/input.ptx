.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r20, %r3, 7;
    max.u32 %r6, %r3, 2;
    sub.s32 %r23, %r20, %r6;
    mul.lo.u32 %r14, %r23, 5;
    sub.u32 %r22, %r20, %r14;
    cvt.s64.s32 %rd11, %r20;
    shl.b64 %rd9, %rd11, 0;
    shr.s32 %r26, %r23, 3;
    max.s32 %r4, %r20, %r6;
    shr.s32 %r13, %r14, 30;
    cvt.s64.s32 %rd9, %r3;
    setp.eq.u32 %p3, %r26, 2;
    @!%p3 shr.s32 %r22, %r23, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
