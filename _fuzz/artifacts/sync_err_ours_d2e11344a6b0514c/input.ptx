.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    add.s32 %r6, %r3, 16;
    sub.s32 %r23, %r6, %r6;
    sub.u32 %r11, %r3, %r3;
    mad.lo.u32 %r9, %r23, %r23, %r11;
    shl.b64 %rd12, %rd13, 30;
    xor.b32 %r20, %r9, %r9;
    and.b32 %r17, %r20, %r3;
    cvt.u64.u32 %rd10, %r11;
    max.u64 %rd12, %rd12, %rd12;
    shl.b32 %r21, %r20, 0;
    setp.ls.u32 %p2, %r9, 1;
    @!%p2 cvt.u64.u32 %rd9, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
