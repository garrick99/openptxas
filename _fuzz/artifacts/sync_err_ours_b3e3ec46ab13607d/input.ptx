.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r22, %r3, %r3;
    cvt.u64.u32 %rd5, %r22;
    max.s32 %r19, %r3, 0;
    shl.b64 %rd15, %rd5, 15;
    shr.s64 %rd15, %rd15, 16;
    xor.b32 %r7, %r22, %r19;
    or.b32 %r23, %r22, %r3;
    shr.u64 %rd12, %rd5, 3;
    sub.u32 %r17, %r22, %r19;
    max.u64 %rd6, %rd12, %rd15;
    shl.b32 %r11, %r23, 3;
    max.s32 %r22, %r23, 1;
    cvt.u64.u32 %rd8, %r7;
    or.b64 %rd6, %rd6, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
