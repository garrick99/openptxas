.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p1, %r3, %r3;
    @%p1 shl.b32 %r13, %r3, 2;
    cvt.u64.u32 %rd5, %r13;
    shl.b64 %rd6, %rd5, 31;
    mul.lo.s32 %r4, %r13, 2147483648;
    add.u32 %r6, %r3, 63;
    max.u64 %rd10, %rd5, %rd5;
    shr.s64 %rd15, %rd5, 2;
    shr.s32 %r16, %r13, 31;
    shl.b64 %rd7, %rd10, 48;
    and.b32 %r20, %r3, %r16;
    shl.b32 %r18, %r16, 7;
    xor.b32 %r6, %r16, %r3;
    shl.b64 %rd14, %rd5, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
