.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r14, %r3, %r3;
    mul.wide.s32 %rd5, %r3, %r3;
    and.b32 %r4, %r3, 5;
    mul.lo.s32 %r20, %r14, %r14;
    mul.wide.s32 %rd8, %r4, %r14;
    sub.u32 %r18, %r3, %r4;
    max.s32 %r24, %r14, %r18;
    sub.u32 %r14, %r4, 4;
    add.u32 %r18, %r14, %r24;
    shl.b64 %rd15, %rd8, 63;
    mul.lo.s32 %r19, %r18, 0;
    mad.lo.u32 %r13, %r24, %r4, %r24;
    setp.eq.s32 %p4, %r20, %r18;
    setp.hi.u32 %p2, %r18, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
