    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r4, %r3, 65536;
    mul.wide.u32 %rd10, %r3, %r3;
    add.s32 %r26, %r3, %r4;
    sub.u32 %r16, %r3, %r3;
    max.u32 %r16, %r26, 63;
    or.b32 %r11, %r4, 4294967295;
    cvt.u32.u64 %r5, %rd10;
    add.s32 %r11, %r4, 2147483648;
    add.u32 %r11, %r3, %r26;
    shl.b32 %r18, %r4, 31;
    min.u32 %r6, %r4, 65536;
    setp.gt.s32 %p2, %r26, 4294967295;
    @!%p2 shr.s32 %r9, %r11, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
