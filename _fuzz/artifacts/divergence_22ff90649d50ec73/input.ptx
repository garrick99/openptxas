.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r13, %r3, %r3, %r3;
    mul.wide.s32 %rd13, %r3, %r13;
    cvt.s32.s64 %r23, %rd13;
    and.b32 %r18, %r13, %r13;
    cvt.u32.u64 %r17, %rd13;
    max.u32 %r20, %r18, %r13;
    mad.lo.s32 %r6, %r18, %r20, %r17;
    mul.wide.u32 %rd15, %r18, %r23;
    xor.b32 %r26, %r18, %r13;
    setp.ne.u32 %p3, %r23, 2;
    @!%p3 shr.s32 %r24, %r18, 16;
    and.b32 %r22, %r18, %r13;
    shr.s32 %r13, %r17, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
