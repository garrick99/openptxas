.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r16, %r3, %r3;
    cvt.u64.u32 %rd7, %r16;
    mul.wide.s32 %rd7, %r16, %r3;
    min.u64 %rd9, %rd7, %rd7;
    setp.gt.s32 %p1, %r16, 65536;
    @%p1 max.s32 %r13, %r16, 2147483648;
    cvt.u64.u32 %rd12, %r16;
    shl.b32 %r8, %r16, 30;
    add.u64 %rd10, %rd12, %rd7;
    min.u32 %r19, %r16, 0;
    sub.u32 %r12, %r13, %r13;
    min.u32 %r21, %r16, %r13;
    mul.wide.u32 %rd7, %r19, %r8;
    cvt.s32.s64 %r23, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
