    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r22, %r3, %r3;
    add.s32 %r8, %r3, %r3;
    setp.hs.u32 %p3, %r22, 2147483648;
    @%p3 max.s32 %r19, %r22, 4294967295;
    mul.wide.u32 %rd5, %r3, %r3;
    setp.gt.u32 %p1, %r19, %r19;
    min.s32 %r6, %r19, %r8;
    add.s64 %rd6, %rd5, %rd5;
    min.s32 %r5, %r6, %r6;
    cvt.u32.u64 %r13, %rd6;
