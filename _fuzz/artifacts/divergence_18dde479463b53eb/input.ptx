.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r21, %r3, 0;
    add.s32 %r23, %r3, %r21;
    cvt.s64.s32 %rd15, %r21;
    max.s32 %r7, %r23, 65535;
    min.s32 %r20, %r7, 65536;
    shr.s64 %rd7, %rd15, 63;
    setp.ls.u32 %p1, %r21, %r7;
    @!%p1 shr.s32 %r25, %r21, 3;
    mul.lo.u32 %r24, %r23, %r25;
    xor.b32 %r4, %r20, 63;
    add.s32 %r6, %r7, 15;
    mad.lo.u32 %r7, %r7, %r4, %r25;
    cvt.s64.s32 %rd5, %r25;
    shr.s32 %r9, %r6, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
