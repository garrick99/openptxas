.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r14, %r3, %r3;
    shl.b32 %r21, %r14, 4;
    shl.b32 %r14, %r21, 1;
    sub.s32 %r17, %r3, %r21;
    mul.wide.s32 %rd8, %r21, %r21;
    shr.u64 %rd13, %rd8, 31;
    add.s32 %r19, %r21, %r3;
    min.u32 %r7, %r14, 5;
    shr.u32 %r5, %r17, 30;
    mul.wide.s32 %rd14, %r17, %r7;
    add.u32 %r14, %r5, 0;
    xor.b64 %rd11, %rd14, %rd14;
    or.b32 %r6, %r19, %r7;
    sub.u32 %r24, %r7, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
