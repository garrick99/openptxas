.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    shl.b64 %rd6, %rd5, 0;
    mul.lo.s64 %rd8, %rd6, %rd5;
    xor.b32 %r8, %r3, 65535;
    shl.b32 %r14, %r8, 16;
    setp.lt.u32 %p3, %r14, 2147483648;
    add.u32 %r5, %r3, %r8;
    and.b32 %r23, %r8, %r14;
    or.b32 %r24, %r5, %r3;
    min.s32 %r9, %r14, 63;
    mul.wide.u32 %rd12, %r14, %r3;
    sub.u64 %rd13, %rd5, %rd8;
    add.u32 %r11, %r3, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
