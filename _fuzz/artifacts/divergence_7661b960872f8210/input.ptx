    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r4, %r3, 2147483647;
    mul.wide.u32 %rd7, %r3, %r3;
    shr.u64 %rd9, %rd7, 30;
    setp.le.s32 %p1, %r4, 2;
    @%p1 mul.wide.u32 %rd13, %r3, %r4;
    min.s64 %rd12, %rd13, %rd9;
    xor.b32 %r27, %r4, %r3;
    mul.wide.s32 %rd9, %r4, %r3;
    setp.lt.u32 %p2, %r27, %r4;
    sub.u32 %r19, %r4, %r4;
    or.b64 %rd7, %rd12, %rd9;
    selp.b32 %r4, %r19, %r27, %p1;
    xor.b32 %r26, %r4, 15;
    cvt.s32.s64 %r18, %rd13;
    ld.param.u64 %rd3, [p_out];
