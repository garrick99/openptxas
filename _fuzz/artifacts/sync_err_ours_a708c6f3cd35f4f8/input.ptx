.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p3, %r3, %r3;
    @!%p3 max.u32 %r26, %r3, %r3;
    shr.s32 %r6, %r26, 15;
    add.u32 %r19, %r6, 256;
    cvt.u64.u32 %rd7, %r6;
    setp.eq.s32 %p4, %r26, %r19;
    mad.lo.s32 %r14, %r26, %r6, %r26;
    cvt.u32.u64 %r12, %rd7;
    max.s32 %r4, %r26, %r14;
    cvt.s32.s64 %r27, %rd7;
    shr.u32 %r22, %r12, 0;
    xor.b32 %r20, %r14, 65535;
    cvt.u32.u64 %r9, %rd7;
    max.s32 %r21, %r14, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
