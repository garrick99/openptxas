.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r5, %r3, 15;
    min.u32 %r12, %r5, %r3;
    max.s32 %r7, %r12, 64;
    max.s32 %r5, %r3, %r3;
    cvt.s64.s32 %rd11, %r12;
    sub.u32 %r23, %r3, 256;
    max.u32 %r5, %r5, %r7;
    cvt.u32.u64 %r27, %rd11;
    cvt.s32.s64 %r18, %rd11;
    min.s32 %r13, %r27, %r5;
    mul.lo.u32 %r21, %r27, %r23;
    shr.s32 %r19, %r7, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
