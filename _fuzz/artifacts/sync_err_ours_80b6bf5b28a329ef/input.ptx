.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    shl.b32 %r24, %r3, 30;
    add.u32 %r12, %r24, 2147483647;
    setp.ne.s32 %p2, %r24, %r3;
    xor.b32 %r7, %r24, %r12;
    and.b32 %r8, %r3, %r3;
    add.s32 %r7, %r24, %r12;
    shr.u64 %rd9, %rd13, 32;
    sub.u32 %r24, %r8, 63;
    selp.b32 %r4, %r7, %r3, %p2;
    xor.b32 %r6, %r3, %r8;
    cvt.u64.u32 %rd15, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
