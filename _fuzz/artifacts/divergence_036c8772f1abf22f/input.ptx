.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r10, %r3, 5;
    setp.ne.s32 %p1, %r3, %r3;
    @%p1 cvt.u64.u32 %rd14, %r3;
    shr.u64 %rd10, %rd14, 15;
    setp.hi.u32 %p2, %r3, 64;
    max.s32 %r11, %r10, 15;
    sub.s32 %r24, %r10, 1;
    setp.lt.s32 %p1, %r3, 8;
    @%p1 sub.u32 %r7, %r3, %r11;
    mul.lo.s32 %r13, %r24, 5;
    or.b32 %r7, %r10, %r3;
    cvt.u32.u64 %r20, %rd14;
    selp.b32 %r13, %r13, %r10, %p2;
    shr.s64 %rd15, %rd14, 33;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
