.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r19, %r3, 256;
    shr.s32 %r9, %r19, 16;
    or.b32 %r22, %r9, 256;
    cvt.s64.s32 %rd14, %r3;
    cvt.u32.u64 %r7, %rd14;
    mul.lo.u32 %r25, %r9, 5;
    mul.wide.s32 %rd5, %r19, %r25;
    min.s32 %r23, %r22, %r25;
    mad.lo.s32 %r11, %r19, %r7, %r7;
    min.s32 %r21, %r9, %r11;
    add.u32 %r7, %r21, %r7;
    setp.hi.u32 %p3, %r9, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
