.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd12, %r3, %r3;
    xor.b32 %r6, %r3, 16;
    shr.s32 %r27, %r3, 31;
    and.b32 %r17, %r27, %r27;
    setp.lt.s32 %p3, %r6, %r3;
    @%p3 mul.wide.u32 %rd9, %r17, %r6;
    add.u32 %r6, %r17, %r3;
    shl.b64 %rd7, %rd9, 31;
    shl.b64 %rd9, %rd12, 62;
    mul.lo.s32 %r11, %r3, 8;
    mul.lo.u64 %rd9, %rd9, %rd7;
    sub.u32 %r7, %r17, %r17;
    shl.b32 %r16, %r6, 31;
    cvt.u32.u64 %r16, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
