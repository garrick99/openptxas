.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r13, %r3, 63;
    xor.b32 %r16, %r13, %r13;
    cvt.u64.u32 %rd13, %r16;
    or.b32 %r20, %r13, 15;
    min.s64 %rd8, %rd13, %rd13;
    and.b64 %rd11, %rd8, %rd8;
    add.u32 %r26, %r13, %r13;
    mul.wide.s32 %rd12, %r20, %r13;
    min.s32 %r20, %r13, %r26;
    shl.b32 %r26, %r20, 31;
    shr.u32 %r14, %r16, 3;
    mul.wide.u32 %rd10, %r14, %r20;
    setp.le.s32 %p4, %r20, %r16;
    @%p4 add.u32 %r18, %r14, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
