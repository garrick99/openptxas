.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r4, %r3, 255;
    setp.ne.s32 %p1, %r3, %r4;
    @%p1 and.b32 %r26, %r3, %r4;
    selp.b32 %r14, %r4, %r3, %p1;
    mul.lo.s32 %r6, %r4, %r14;
    sub.s32 %r8, %r26, 64;
    shr.u32 %r16, %r8, 7;
    min.u32 %r23, %r3, 2147483648;
    mul.wide.s32 %rd7, %r23, %r4;
    or.b32 %r13, %r8, 8;
    selp.b32 %r26, %r3, %r8, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
