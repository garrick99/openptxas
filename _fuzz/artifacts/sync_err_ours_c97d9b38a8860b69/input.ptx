.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r14, %r3, %r3;
    add.s32 %r22, %r14, 4;
    add.u32 %r15, %r3, 15;
    sub.u32 %r7, %r14, %r15;
    mad.lo.s32 %r23, %r7, %r3, %r7;
    shr.s32 %r10, %r22, 16;
    or.b32 %r5, %r7, 31;
    mul.wide.u32 %rd5, %r15, %r10;
    setp.ne.s32 %p1, %r23, %r15;
    @%p1 selp.b32 %r10, %r15, %r15, %p1;
    mul.wide.u32 %rd6, %r3, %r5;
    min.u32 %r4, %r22, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
