.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r17, %r3, 63;
    cvt.u64.u32 %rd5, %r17;
    min.s32 %r8, %r3, %r17;
    xor.b32 %r20, %r17, 65535;
    or.b64 %rd5, %rd5, %rd5;
    shl.b64 %rd13, %rd5, 4;
    mul.wide.s32 %rd11, %r8, %r20;
    cvt.u32.u64 %r14, %rd5;
    setp.ne.s32 %p2, %r20, 8;
    cvt.s32.s64 %r13, %rd5;
    and.b32 %r19, %r13, %r20;
    mul.wide.s32 %rd13, %r13, %r13;
    shl.b32 %r24, %r13, 7;
    add.u64 %rd7, %rd13, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
