.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r9, %r3, 4294967295;
    cvt.u64.u32 %rd9, %r3;
    cvt.u32.u64 %r17, %rd9;
    sub.s32 %r27, %r17, 4294967295;
    shl.b64 %rd10, %rd9, 15;
    shr.u32 %r11, %r9, 3;
    setp.lt.u32 %p2, %r17, 4;
    @!%p2 mul.lo.s64 %rd7, %rd10, %rd10;
    cvt.u32.u64 %r19, %rd9;
    mul.lo.u32 %r16, %r9, %r17;
    xor.b32 %r23, %r11, 2;
    mul.lo.s32 %r7, %r17, 31;
    setp.eq.s32 %p3, %r11, %r7;
    cvt.u32.u64 %r10, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
