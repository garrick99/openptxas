.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r16, %r3, %r3, %r3;
    mad.lo.s32 %r10, %r3, %r3, %r3;
    min.u32 %r21, %r10, %r10;
    add.u32 %r21, %r21, %r10;
    and.b32 %r15, %r10, 4294967295;
    shl.b32 %r22, %r3, 3;
    min.u32 %r21, %r10, %r22;
    setp.gt.s32 %p4, %r16, %r3;
    @!%p4 mul.lo.s32 %r18, %r22, %r10;
    cvt.u64.u32 %rd10, %r18;
    shr.u32 %r4, %r16, 16;
    shr.u32 %r7, %r15, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
