    max.u64 %rd7, %rd10, %rd10;
    sub.s32 %r25, %r25, %r22;
    shr.s32 %r10, %r4, 31;
    max.s32 %r10, %r27, 2147483647;
    shl.b64 %rd12, %rd7, 7;
