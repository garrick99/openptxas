.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r7, %r3, 16;
    setp.ls.u32 %p1, %r3, 5;
    cvt.u64.u32 %rd6, %r3;
    min.u32 %r8, %r3, 3;
    shr.u64 %rd15, %rd6, 16;
    cvt.s32.s64 %r19, %rd6;
    sub.s32 %r13, %r7, 4294967295;
    cvt.u64.u32 %rd5, %r13;
    mul.wide.u32 %rd12, %r7, %r19;
    max.s64 %rd6, %rd5, %rd12;
    mul.lo.u32 %r27, %r8, %r7;
    max.u32 %r10, %r19, 256;
    shr.u64 %rd15, %rd15, 47;
    cvt.u64.u32 %rd15, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
