.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r24, %r3, 3;
    mad.lo.u32 %r21, %r24, %r3, %r3;
    setp.gt.u32 %p4, %r24, 3;
    mul.wide.u32 %rd5, %r21, %r3;
    min.u32 %r13, %r3, 31;
    add.s32 %r27, %r3, %r21;
    shr.u32 %r9, %r13, 30;
    and.b64 %rd15, %rd5, %rd5;
    selp.b32 %r26, %r9, %r27, %p4;
    xor.b32 %r7, %r9, %r3;
    sub.s32 %r13, %r7, %r13;
    or.b64 %rd11, %rd5, %rd5;
    setp.gt.u32 %p3, %r27, %r24;
    @%p3 and.b32 %r5, %r27, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
