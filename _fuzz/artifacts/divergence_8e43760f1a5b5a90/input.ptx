.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p2, %r3, 0;
    @!%p2 max.u32 %r8, %r3, %r3;
    cvt.u64.u32 %rd8, %r8;
    sub.u32 %r4, %r8, %r8;
    min.u32 %r8, %r8, %r3;
    setp.ge.s32 %p2, %r4, 64;
    @!%p2 or.b32 %r11, %r8, %r4;
    sub.s32 %r20, %r4, 3;
    mad.lo.u32 %r27, %r3, %r11, %r20;
    max.u32 %r5, %r4, 1;
    mul.lo.u32 %r18, %r3, 16;
    mad.lo.u32 %r19, %r20, %r27, %r3;
    shr.s64 %rd15, %rd8, 0;
    max.u32 %r23, %r11, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
