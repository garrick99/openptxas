.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r4, %r3, 15;
    cvt.s64.s32 %rd15, %r4;
    and.b32 %r27, %r4, %r4;
    shr.s64 %rd5, %rd15, 1;
    shl.b32 %r24, %r4, 15;
    mul.wide.s32 %rd6, %r4, %r27;
    min.u32 %r20, %r4, %r27;
    mad.lo.u32 %r27, %r27, %r20, %r27;
    setp.eq.u32 %p1, %r20, 2;
    setp.gt.s32 %p2, %r20, 256;
    selp.b32 %r9, %r24, %r4, %p1;
    shr.u32 %r26, %r3, 7;
    cvt.u32.u64 %r15, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
