.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    mad.lo.u32 %r26, %r3, %r3, %r3;
    setp.lt.u32 %p4, %r26, 4;
    @%p4 max.s32 %r4, %r3, %r26;
    min.u32 %r9, %r4, %r3;
    shr.s32 %r27, %r3, 0;
    cvt.u64.u32 %rd13, %r26;
    shr.s64 %rd8, %rd13, 48;
    shl.b64 %rd5, %rd14, 62;
    mul.wide.s32 %rd7, %r26, %r3;
    sub.s32 %r23, %r26, %r3;
    min.s32 %r14, %r23, %r26;
    selp.b32 %r16, %r14, %r27, %p4;
    mad.lo.u32 %r12, %r14, %r14, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
