.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    add.u32 %r9, %r3, %r3;
    shr.s64 %rd12, %rd9, 4;
    cvt.u32.u64 %r15, %rd9;
    or.b32 %r22, %r15, %r9;
    setp.lt.s32 %p2, %r9, 2147483648;
    mad.lo.s32 %r23, %r9, %r3, %r22;
    mad.lo.u32 %r12, %r3, %r3, %r22;
    mul.wide.u32 %rd13, %r23, %r9;
    shr.s32 %r25, %r12, 1;
    min.u32 %r25, %r9, 63;
    cvt.s64.s32 %rd14, %r22;
    min.u32 %r7, %r23, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
