.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r8, %r3, %r0;
    shfl.sync.bfly.b32 %r7, %r0, 16, 0x1f, -1;
    shfl.sync.idx.b32 %r17, %r3, 15, 0x1f, -1;
    max.u32 %r12, %r17, %r17;
    and.b32 %r17, %r8, %r17;
    setp.lt.u32 %p1, %r17, %r12;
    vote.sync.ballot.b32 %r4, %p1, -1;
    min.u32 %r18, %r7, %r4;
    shfl.sync.idx.b32 %r8, %r8, 1, 0x1f, -1;
    shfl.sync.idx.b32 %r13, %r18, 15, 0x1f, -1;
    setp.ge.u32 %p1, %r7, 255;
    vote.sync.ballot.b32 %r12, %p1, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
