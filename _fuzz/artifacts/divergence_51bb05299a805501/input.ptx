.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r17, %r3, %r3;
    mad.lo.u32 %r10, %r17, %r17, %r3;
    sub.u32 %r19, %r3, %r17;
    cvt.u64.u32 %rd15, %r17;
    max.s32 %r27, %r17, 32;
    setp.ls.u32 %p4, %r10, 4294967295;
    @!%p4 mul.wide.s32 %rd11, %r10, %r19;
    mad.lo.u32 %r14, %r27, %r19, %r19;
    and.b32 %r19, %r19, 31;
    setp.hi.u32 %p4, %r17, 63;
    @!%p4 selp.b32 %r15, %r3, %r17, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
