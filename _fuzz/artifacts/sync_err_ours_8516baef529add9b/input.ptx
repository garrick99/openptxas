    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r11, %r3, 2147483647;
    shr.u32 %r15, %r11, 2;
    shl.b32 %r22, %r15, 0;
    cvt.s64.s32 %rd13, %r15;
    mul.wide.s32 %rd9, %r11, %r3;
    min.u64 %rd13, %rd9, %rd13;
    sub.u32 %r20, %r3, 256;
    cvt.s64.s32 %rd5, %r11;
    cvt.u32.u64 %r10, %rd5;
    or.b64 %rd15, %rd13, %rd5;
    shl.b32 %r9, %r10, 7;
    xor.b32 %r6, %r9, 15;
    shr.u32 %r5, %r20, 3;
    max.u32 %r21, %r10, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
