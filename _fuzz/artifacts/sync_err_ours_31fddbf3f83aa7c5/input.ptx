.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p3, %r3, %r3;
    @%p3 cvt.u64.u32 %rd8, %r3;
    selp.b32 %r11, %r3, %r3, %p3;
    max.s32 %r23, %r11, 0;
    mul.wide.s32 %rd7, %r11, %r23;
    mul.lo.s32 %r9, %r11, 2147483648;
    mul.lo.s64 %rd8, %rd8, %rd7;
    xor.b32 %r5, %r11, %r3;
    add.s32 %r22, %r9, 15;
    mul.lo.s32 %r26, %r23, %r9;
    mul.lo.s64 %rd13, %rd7, %rd8;
    or.b64 %rd9, %rd7, %rd8;
    and.b32 %r4, %r22, %r3;
    mul.wide.s32 %rd8, %r23, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
