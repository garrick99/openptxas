.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    max.u32 %r5, %r3, 1;
    setp.lt.s32 %p1, %r3, %r3;
    @!%p1 shr.s32 %r9, %r5, 15;
    min.u32 %r18, %r5, %r3;
    shl.b32 %r16, %r3, 15;
    mad.lo.s32 %r19, %r16, %r9, %r18;
    sub.u32 %r16, %r19, 63;
    add.u32 %r18, %r18, 4;
    mad.lo.u32 %r8, %r16, %r3, %r18;
    add.u32 %r12, %r16, 0;
    mul.wide.u32 %rd14, %r9, %r9;
    max.u32 %r4, %r12, %r3;
    setp.ne.s32 %p1, %r12, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
