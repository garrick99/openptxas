.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r14, %r3, 4294967295;
    setp.lo.u32 %p1, %r14, 2147483647;
    @!%p1 selp.b32 %r6, %r14, %r3, %p1;
    cvt.u64.u32 %rd9, %r14;
    max.u32 %r16, %r3, %r14;
    shr.u32 %r11, %r16, 2;
    shr.u64 %rd9, %rd9, 33;
    shr.u32 %r9, %r6, 7;
    shl.b32 %r26, %r9, 15;
    shr.s64 %rd8, %rd9, 3;
    setp.ne.s32 %p3, %r16, %r26;
    @%p3 cvt.u64.u32 %rd6, %r11;
    mul.lo.u32 %r8, %r3, %r11;
    max.u32 %r6, %r9, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
