.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r5, %r3, 7;
    sub.s32 %r19, %r5, 2;
    setp.gt.u32 %p1, %r3, 3;
    @%p1 xor.b32 %r24, %r5, %r19;
    cvt.u64.u32 %rd14, %r5;
    shr.u32 %r21, %r3, 16;
    setp.gt.u32 %p1, %r21, 1;
    @!%p1 shl.b64 %rd9, %rd14, 62;
    xor.b32 %r16, %r5, %r24;
    selp.b32 %r16, %r3, %r21, %p1;
    shl.b64 %rd14, %rd9, 30;
    max.u32 %r6, %r21, %r24;
    setp.ge.s32 %p3, %r21, %r21;
    @!%p3 mul.wide.s32 %rd14, %r5, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
