.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p2, %r3, 65536;
    setp.eq.s32 %p4, %r3, %r3;
    mul.lo.u32 %r18, %r3, %r3;
    mad.lo.u32 %r25, %r18, %r18, %r3;
    cvt.u64.u32 %rd13, %r3;
    max.s32 %r27, %r3, 4294967295;
    setp.eq.s32 %p2, %r25, 0;
    shr.s64 %rd15, %rd13, 32;
    mad.lo.s32 %r7, %r25, %r25, %r25;
    setp.le.u32 %p2, %r27, %r3;
    setp.hi.u32 %p4, %r25, %r7;
    setp.gt.u32 %p1, %r7, 1;
    @%p1 shr.s32 %r18, %r25, 7;
    xor.b64 %rd7, %rd15, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
