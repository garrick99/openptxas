.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd11, %r3, %r3;
    setp.gt.s32 %p3, %r3, %r3;
    shl.b64 %rd10, %rd11, 1;
    min.u32 %r25, %r3, %r3;
    setp.le.s32 %p2, %r25, %r25;
    @%p2 mul.lo.u32 %r10, %r3, %r25;
    xor.b32 %r11, %r25, %r3;
    mad.lo.u32 %r17, %r11, %r10, %r25;
    shr.s32 %r17, %r17, 16;
    shr.s32 %r26, %r17, 7;
    xor.b32 %r23, %r3, 32;
    selp.b32 %r20, %r26, %r23, %p2;
    mul.lo.u64 %rd8, %rd11, %rd10;
    setp.hs.u32 %p2, %r20, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
