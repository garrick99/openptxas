.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r20, %r3, %r3;
    shl.b32 %r13, %r20, 15;
    mul.lo.u32 %r25, %r3, 2;
    cvt.u64.u32 %rd12, %r3;
    max.u32 %r14, %r13, %r3;
    setp.lo.u32 %p1, %r14, %r13;
    @%p1 xor.b32 %r8, %r13, 65535;
    setp.lt.u32 %p2, %r8, 16;
    setp.gt.s32 %p3, %r20, %r13;
    @%p3 mad.lo.u32 %r14, %r20, %r8, %r25;
    max.s32 %r24, %r8, 256;
    shr.u32 %r19, %r14, 30;
    mad.lo.s32 %r10, %r19, %r25, %r3;
    mad.lo.u32 %r14, %r14, %r10, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
