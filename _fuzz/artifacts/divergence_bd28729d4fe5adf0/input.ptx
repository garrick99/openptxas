.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p2, %r3, 8;
    @%p2 mul.wide.u32 %rd11, %r3, %r3;
    mul.lo.u64 %rd6, %rd11, %rd11;
    selp.b32 %r21, %r3, %r3, %p2;
    sub.u32 %r23, %r3, %r3;
    mul.lo.s32 %r20, %r21, 4294967295;
    min.u32 %r14, %r20, 7;
    add.u32 %r16, %r21, %r3;
    min.u32 %r11, %r21, 2;
    max.s32 %r23, %r3, 255;
    mul.lo.s64 %rd7, %rd11, %rd11;
    min.u64 %rd6, %rd7, %rd7;
    shr.s64 %rd12, %rd11, 31;
    cvt.u32.u64 %r7, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
