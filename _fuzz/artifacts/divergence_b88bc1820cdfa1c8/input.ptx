.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    add.s32 %r20, %r3, 2147483648;
    xor.b64 %rd10, %rd7, %rd7;
    mul.wide.s32 %rd5, %r20, %r20;
    max.u32 %r4, %r20, 2;
    shl.b64 %rd12, %rd10, 3;
    cvt.s64.s32 %rd15, %r20;
    mad.lo.s32 %r11, %r4, %r4, %r20;
    mul.lo.u64 %rd8, %rd10, %rd7;
    cvt.u64.u32 %rd7, %r4;
    mul.wide.u32 %rd8, %r20, %r20;
    mul.lo.s32 %r5, %r11, 65536;
    setp.gt.u32 %p4, %r20, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
