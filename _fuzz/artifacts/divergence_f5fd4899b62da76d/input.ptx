.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r6, %r3, %r3;
    max.s32 %r9, %r6, 32;
    mad.lo.u32 %r23, %r3, %r3, %r3;
    and.b32 %r23, %r6, %r9;
    max.s32 %r21, %r9, 31;
    shl.b32 %r5, %r6, 4;
    setp.ls.u32 %p1, %r3, 16;
    @!%p1 max.u32 %r27, %r23, %r9;
    cvt.u64.u32 %rd10, %r27;
    shl.b32 %r21, %r27, 2;
    and.b32 %r21, %r6, %r21;
    shr.s32 %r21, %r21, 4;
    setp.eq.s32 %p3, %r9, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
