.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r14, %r3, 3;
    max.s32 %r7, %r14, 256;
    sub.s32 %r22, %r7, %r14;
    shr.u32 %r4, %r3, 4;
    sub.s32 %r19, %r7, 2147483647;
    add.u32 %r20, %r3, 5;
    shr.s32 %r22, %r7, 1;
    setp.gt.s32 %p3, %r4, %r22;
    @!%p3 add.s32 %r27, %r3, 63;
    max.u32 %r15, %r27, %r22;
    or.b32 %r25, %r15, %r19;
    min.u32 %r16, %r4, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
