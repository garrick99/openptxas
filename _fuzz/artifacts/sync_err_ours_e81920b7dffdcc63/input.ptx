.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    setp.gt.s32 %p2, %r3, 8;
    @!%p2 cvt.s32.s64 %r18, %rd11;
    mul.lo.u32 %r4, %r3, 65536;
    min.u32 %r20, %r3, %r18;
    or.b32 %r18, %r4, %r3;
    cvt.s64.s32 %rd12, %r20;
    selp.b32 %r14, %r3, %r20, %p2;
    cvt.s32.s64 %r6, %rd12;
    setp.gt.s32 %p3, %r6, 31;
    @!%p3 max.u32 %r16, %r18, 64;
    add.s32 %r18, %r16, 2147483648;
    cvt.u32.u64 %r4, %rd11;
    mul.lo.s64 %rd7, %rd11, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
