.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    shl.b32 %r21, %r3, 30;
    shl.b64 %rd10, %rd14, 2;
    min.u64 %rd5, %rd14, %rd10;
    cvt.s32.s64 %r10, %rd14;
    mad.lo.u32 %r15, %r21, %r10, %r3;
    shr.u32 %r8, %r3, 16;
    cvt.s32.s64 %r18, %rd10;
    mul.wide.u32 %rd7, %r21, %r8;
    shr.s64 %rd13, %rd5, 15;
    mad.lo.s32 %r26, %r15, %r15, %r10;
    max.u32 %r6, %r10, %r26;
    shl.b32 %r20, %r10, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
