.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r11, %r3, 2147483647;
    setp.hs.u32 %p3, %r11, 8;
    @%p3 cvt.s64.s32 %rd8, %r11;
    selp.b32 %r26, %r11, %r3, %p3;
    sub.u64 %rd12, %rd8, %rd8;
    setp.hs.u32 %p1, %r3, 255;
    @!%p1 shr.u64 %rd8, %rd8, 2;
    shr.u32 %r4, %r26, 4;
    mul.lo.s32 %r6, %r3, %r26;
    xor.b32 %r8, %r11, 5;
    mad.lo.u32 %r24, %r11, %r11, %r11;
    setp.le.u32 %p1, %r3, %r8;
    @%p1 selp.b32 %r8, %r24, %r4, %p1;
    or.b32 %r19, %r3, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
