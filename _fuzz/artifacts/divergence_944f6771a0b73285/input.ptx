.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r9, %r3, %r3;
    mul.wide.u32 %rd5, %r9, %r9;
    shl.b64 %rd14, %rd5, 0;
    shl.b64 %rd12, %rd5, 16;
    min.u32 %r14, %r3, 3;
    shr.u64 %rd10, %rd5, 7;
    or.b32 %r22, %r3, 63;
    mad.lo.s32 %r27, %r3, %r14, %r22;
    add.s32 %r13, %r9, %r9;
    or.b32 %r27, %r27, %r3;
    and.b64 %rd12, %rd12, %rd10;
    mul.lo.u32 %r9, %r9, %r14;
    and.b32 %r23, %r22, 2;
    or.b32 %r10, %r27, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
