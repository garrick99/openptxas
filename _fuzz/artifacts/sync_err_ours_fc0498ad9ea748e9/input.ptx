.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    or.b32 %r9, %r3, 256;
    max.s32 %r21, %r3, 15;
    setp.gt.s32 %p4, %r3, %r9;
    @%p4 shr.s32 %r11, %r3, 3;
    cvt.s32.s64 %r20, %rd11;
    max.s64 %rd7, %rd11, %rd11;
    or.b32 %r11, %r21, %r21;
    cvt.u32.u64 %r20, %rd7;
    min.s32 %r15, %r20, %r21;
    setp.lt.s32 %p3, %r20, 31;
    @!%p3 add.s32 %r18, %r3, %r11;
    selp.b32 %r14, %r11, %r21, %p3;
    add.s32 %r23, %r9, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
