.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r22, %r3, %r3;
    shr.u32 %r8, %r22, 15;
    mul.lo.s32 %r9, %r8, %r22;
    shr.s32 %r5, %r8, 4;
    or.b32 %r12, %r8, %r9;
    cvt.u64.u32 %rd14, %r22;
    add.u32 %r15, %r12, %r8;
    add.s32 %r16, %r5, 2147483648;
    add.u32 %r8, %r8, %r22;
    max.u32 %r26, %r15, 16;
    or.b32 %r24, %r15, 3;
    mad.lo.s32 %r15, %r12, %r9, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
