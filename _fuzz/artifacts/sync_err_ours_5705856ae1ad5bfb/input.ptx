.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd9, %r3, %r3;
    cvt.u32.u64 %r17, %rd9;
    sub.s32 %r23, %r17, 2147483647;
    shr.u32 %r14, %r17, 15;
    setp.le.s32 %p3, %r17, 0;
    @!%p3 cvt.s64.s32 %rd7, %r14;
    sub.s64 %rd11, %rd9, %rd9;
    shl.b32 %r8, %r14, 0;
    add.u64 %rd15, %rd7, %rd9;
    shr.u32 %r21, %r8, 0;
    shr.u32 %r4, %r17, 15;
    or.b32 %r11, %r21, %r21;
    add.s32 %r5, %r21, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
