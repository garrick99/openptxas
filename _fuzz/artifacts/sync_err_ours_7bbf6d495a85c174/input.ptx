.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r16, %r3, 0;
    min.u32 %r25, %r3, %r16;
    min.s32 %r22, %r25, 2;
    shr.s32 %r26, %r16, 16;
    max.s32 %r24, %r25, %r26;
    cvt.s64.s32 %rd8, %r25;
    cvt.u64.u32 %rd15, %r16;
    add.s32 %r4, %r3, %r25;
    min.u32 %r22, %r22, %r16;
    mul.wide.u32 %rd5, %r22, %r24;
    shr.s32 %r6, %r4, 3;
    add.u32 %r18, %r4, %r16;
    and.b32 %r27, %r24, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
