.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p4, %r3, %r3;
    cvt.s64.s32 %rd14, %r3;
    selp.b32 %r5, %r3, %r3, %p4;
    mul.lo.u32 %r26, %r5, 8;
    shr.u64 %rd9, %rd14, 30;
    shr.s64 %rd9, %rd9, 63;
    shl.b32 %r21, %r5, 3;
    and.b32 %r24, %r26, %r21;
    max.s32 %r22, %r26, %r3;
    cvt.s32.s64 %r5, %rd14;
    shr.s64 %rd15, %rd9, 32;
    mad.lo.s32 %r24, %r26, %r5, %r21;
    mul.lo.u32 %r20, %r24, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
