.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r7, %r3, %r3;
    setp.le.s32 %p1, %r7, 2;
    @%p1 cvt.u64.u32 %rd7, %r7;
    max.s64 %rd14, %rd7, %rd7;
    max.s32 %r6, %r3, %r3;
    add.u32 %r17, %r6, %r7;
    shl.b32 %r27, %r6, 31;
    or.b32 %r18, %r3, %r17;
    min.s32 %r8, %r7, 31;
    mul.lo.u32 %r26, %r17, 4;
    cvt.u64.u32 %rd12, %r27;
    shr.s64 %rd12, %rd7, 30;
    mul.lo.u32 %r13, %r8, %r27;
    shl.b64 %rd12, %rd7, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
