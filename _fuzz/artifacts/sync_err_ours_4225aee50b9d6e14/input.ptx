.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r18, %r3, 8;
    mul.lo.u32 %r24, %r3, %r3;
    cvt.s64.s32 %rd6, %r18;
    shl.b64 %rd14, %rd6, 2;
    mul.wide.u32 %rd14, %r3, %r3;
    and.b32 %r9, %r24, 255;
    setp.eq.s32 %p3, %r3, 15;
    @%p3 min.s64 %rd9, %rd6, %rd6;
    mad.lo.s32 %r23, %r18, %r9, %r24;
    mul.wide.u32 %rd11, %r23, %r18;
    selp.b32 %r25, %r24, %r18, %p3;
    add.s32 %r5, %r25, %r25;
    max.u32 %r14, %r24, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
