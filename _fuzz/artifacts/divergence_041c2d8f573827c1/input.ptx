.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p4, %r3, %r3;
    @%p4 cvt.s64.s32 %rd8, %r3;
    min.u32 %r6, %r3, 4;
    mul.lo.u32 %r9, %r6, %r6;
    min.u32 %r12, %r9, 65535;
    mul.wide.s32 %rd13, %r6, %r3;
    shr.u32 %r23, %r3, 2;
    shr.s32 %r16, %r9, 1;
    add.s32 %r15, %r12, %r12;
    shr.u64 %rd5, %rd13, 62;
    and.b32 %r13, %r15, 3;
    and.b32 %r10, %r12, %r15;
    add.s32 %r22, %r13, 32;
    setp.eq.u32 %p1, %r15, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
