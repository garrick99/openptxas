.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r21, %r3, %r3;
    shl.b32 %r16, %r3, 31;
    add.u32 %r10, %r3, %r16;
    mul.lo.u32 %r10, %r10, 32;
    cvt.s64.s32 %rd11, %r21;
    sub.u32 %r4, %r16, 65536;
    shl.b32 %r18, %r21, 31;
    mul.lo.s32 %r17, %r3, 2;
    shr.s32 %r22, %r18, 1;
    xor.b32 %r18, %r18, %r22;
    add.u32 %r12, %r18, 256;
    cvt.u32.u64 %r20, %rd11;
    shr.s64 %rd6, %rd11, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
