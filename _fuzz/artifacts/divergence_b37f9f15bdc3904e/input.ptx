.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    add.u32 %r19, %r3, 4;
    cvt.u32.u64 %r14, %rd8;
    min.s32 %r19, %r3, %r14;
    shl.b32 %r20, %r14, 7;
    setp.le.u32 %p4, %r14, %r19;
    @!%p4 min.u64 %rd12, %rd8, %rd8;
    shr.s64 %rd15, %rd8, 32;
    mul.wide.s32 %rd10, %r3, %r3;
    cvt.u32.u64 %r15, %rd10;
    cvt.s32.s64 %r24, %rd8;
    shr.s32 %r19, %r19, 15;
    add.u32 %r11, %r3, 32;
    max.s32 %r18, %r15, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
