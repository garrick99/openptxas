.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p4, %r3, 16;
    @!%p4 max.u32 %r5, %r3, %r3;
    or.b32 %r26, %r3, %r3;
    min.s32 %r9, %r26, 16;
    or.b32 %r26, %r3, %r26;
    add.s32 %r14, %r26, 4;
    sub.s32 %r9, %r14, %r3;
    selp.b32 %r15, %r14, %r3, %p4;
    setp.ge.s32 %p3, %r5, %r14;
    @!%p3 cvt.s64.s32 %rd10, %r15;
    setp.le.s32 %p1, %r15, %r14;
    @!%p1 max.s32 %r13, %r14, 15;
    min.u32 %r15, %r9, %r9;
    cvt.s64.s32 %rd8, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
