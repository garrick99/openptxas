.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r9, %r3, %r3;
    mul.lo.u32 %r24, %r9, %r9;
    shr.s32 %r18, %r9, 3;
    and.b32 %r10, %r3, %r18;
    setp.eq.u32 %p3, %r3, %r10;
    @%p3 shr.s32 %r10, %r10, 16;
    sub.s32 %r10, %r24, 5;
    cvt.s64.s32 %rd10, %r9;
    setp.hs.u32 %p4, %r10, %r18;
    @%p4 cvt.u32.u64 %r13, %rd10;
    mad.lo.s32 %r9, %r3, %r18, %r10;
    shl.b32 %r11, %r9, 30;
    mul.lo.s32 %r5, %r9, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
