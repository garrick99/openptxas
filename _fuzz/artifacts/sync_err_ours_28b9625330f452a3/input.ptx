.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r22, %r3, %r3;
    mad.lo.u32 %r26, %r3, %r3, %r3;
    mul.lo.u32 %r4, %r3, %r26;
    shl.b32 %r16, %r22, 30;
    mul.wide.s32 %rd13, %r16, %r26;
    min.u64 %rd7, %rd13, %rd13;
    sub.u64 %rd8, %rd7, %rd7;
    shr.s32 %r26, %r26, 3;
    min.u32 %r10, %r4, %r22;
    mul.wide.u32 %rd8, %r4, %r22;
    shl.b32 %r13, %r16, 2;
    shl.b64 %rd14, %rd7, 15;
    mul.lo.s32 %r8, %r26, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
