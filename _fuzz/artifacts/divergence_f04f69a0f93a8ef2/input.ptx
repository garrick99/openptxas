.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r27, %r3, 1;
    mad.lo.u32 %r9, %r27, %r27, %r27;
    cvt.u64.u32 %rd7, %r27;
    mul.lo.u32 %r13, %r3, %r3;
    xor.b32 %r8, %r13, %r3;
    setp.ge.u32 %p3, %r8, 255;
    @%p3 sub.u32 %r20, %r27, 16;
    selp.b32 %r26, %r9, %r27, %p3;
    mul.lo.u64 %rd14, %rd7, %rd7;
    mad.lo.s32 %r10, %r27, %r26, %r13;
    selp.b32 %r6, %r13, %r9, %p3;
    min.u32 %r13, %r20, %r20;
    setp.le.s32 %p3, %r26, 65535;
    @!%p3 min.s32 %r26, %r27, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
