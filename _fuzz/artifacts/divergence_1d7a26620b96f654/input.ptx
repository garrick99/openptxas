.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    or.b32 %r4, %r3, %r3;
    or.b32 %r25, %r3, %r4;
    cvt.s32.s64 %r26, %rd10;
    setp.lo.u32 %p2, %r3, %r26;
    @!%p2 mul.lo.s32 %r10, %r3, %r25;
    cvt.s64.s32 %rd14, %r10;
    mul.wide.s32 %rd7, %r25, %r26;
    setp.hs.u32 %p1, %r4, 2147483647;
    @%p1 add.s32 %r9, %r3, %r25;
    add.s64 %rd11, %rd7, %rd10;
    mul.lo.s64 %rd6, %rd14, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
