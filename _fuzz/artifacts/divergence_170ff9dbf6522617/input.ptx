.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r10, %r3, 30;
    shr.u32 %r12, %r10, 2;
    cvt.u64.u32 %rd15, %r12;
    shl.b64 %rd15, %rd15, 32;
    mad.lo.u32 %r15, %r3, %r10, %r12;
    min.u32 %r27, %r3, 1;
    shr.u32 %r8, %r10, 1;
    shr.u32 %r21, %r10, 2;
    shl.b32 %r6, %r10, 4;
    add.s32 %r26, %r15, 7;
    sub.s32 %r14, %r6, 5;
    max.u32 %r7, %r12, %r8;
    max.s32 %r17, %r12, %r8;
    max.s32 %r9, %r8, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
