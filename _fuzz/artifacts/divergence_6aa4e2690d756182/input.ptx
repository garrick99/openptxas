.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p2, %r3, 4;
    @%p2 cvt.s64.s32 %rd6, %r3;
    cvt.u64.u32 %rd14, %r3;
    cvt.u32.u64 %r25, %rd6;
    mul.lo.s32 %r27, %r25, 4;
    shr.u32 %r11, %r27, 4;
    add.u32 %r26, %r11, %r11;
    sub.u32 %r9, %r27, 8;
    min.u32 %r7, %r25, %r25;
    mad.lo.u32 %r20, %r25, %r27, %r11;
    sub.u32 %r6, %r20, 4294967295;
    min.u32 %r20, %r6, %r9;
    setp.lt.s32 %p1, %r11, 2147483647;
    sub.s64 %rd9, %rd14, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
