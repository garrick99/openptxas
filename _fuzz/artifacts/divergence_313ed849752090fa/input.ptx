.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    shr.s32 %r25, %r3, 7;
    setp.gt.s32 %p4, %r25, 0;
    xor.b32 %r27, %r3, %r3;
    cvt.s64.s32 %rd10, %r25;
    cvt.u32.u64 %r18, %rd5;
    setp.le.s32 %p1, %r25, 2;
    max.u32 %r24, %r18, 5;
    min.u32 %r16, %r18, %r25;
    add.s32 %r8, %r3, %r24;
    mul.lo.s32 %r19, %r8, %r8;
    shl.b32 %r5, %r18, 31;
    xor.b64 %rd10, %rd5, %rd5;
    cvt.u64.u32 %rd8, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
