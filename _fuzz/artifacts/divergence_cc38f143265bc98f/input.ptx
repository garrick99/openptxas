.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r26, %r3, 0;
    max.s32 %r23, %r26, %r26;
    add.s32 %r18, %r23, 65535;
    setp.ne.u32 %p2, %r3, 4294967295;
    @%p2 add.s32 %r22, %r18, 16;
    mul.wide.s32 %rd6, %r22, %r18;
    and.b32 %r23, %r22, %r18;
    cvt.u32.u64 %r6, %rd6;
    add.s32 %r10, %r22, 0;
    mul.wide.u32 %rd9, %r3, %r18;
    sub.u32 %r20, %r6, %r22;
    mul.lo.s32 %r9, %r20, %r20;
    sub.s32 %r13, %r22, %r20;
    selp.b32 %r20, %r22, %r13, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
