.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r15, %r3, %r3;
    mul.lo.u32 %r27, %r3, %r3;
    add.s32 %r18, %r3, %r15;
    cvt.u64.u32 %rd13, %r18;
    sub.u64 %rd15, %rd13, %rd13;
    cvt.u32.u64 %r11, %rd13;
    shr.u32 %r6, %r27, 31;
    min.u32 %r9, %r18, %r18;
    max.s32 %r4, %r18, 0;
    xor.b64 %rd15, %rd15, %rd15;
    mad.lo.s32 %r6, %r9, %r4, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
