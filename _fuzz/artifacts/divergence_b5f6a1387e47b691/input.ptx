    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p3, %r3, 5;
    cvt.u64.u32 %rd5, %r3;
    and.b32 %r22, %r3, %r3;
    add.u32 %r13, %r3, 4294967295;
    min.s32 %r7, %r22, 8;
    min.u32 %r21, %r13, 31;
    sub.s32 %r15, %r22, 8;
    cvt.u32.u64 %r11, %rd5;
    sub.s64 %rd5, %rd5, %rd5;
    shl.b64 %rd15, %rd5, 15;
    sub.s32 %r25, %r7, %r11;
    mul.lo.u32 %r21, %r13, %r25;
    mad.lo.s32 %r18, %r21, %r13, %r21;
    add.u32 %r15, %r15, %r18;
