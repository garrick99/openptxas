.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    mul.wide.u32 %rd6, %r3, %r3;
    cvt.s64.s32 %rd9, %r3;
    sub.u32 %r23, %r3, %r3;
    or.b32 %r9, %r3, %r3;
    shl.b64 %rd5, %rd6, 33;
    cvt.s32.s64 %r13, %rd6;
    and.b64 %rd13, %rd6, %rd6;
    setp.gt.s32 %p2, %r23, %r9;
    @%p2 shr.s32 %r19, %r9, 16;
    cvt.u32.u64 %r14, %rd13;
    xor.b64 %rd11, %rd9, %rd9;
    setp.ge.u32 %p1, %r19, %r14;
    mul.lo.s32 %r21, %r13, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
