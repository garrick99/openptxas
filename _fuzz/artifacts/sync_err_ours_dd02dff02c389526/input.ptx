.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r27, %r3, 5;
    max.s32 %r20, %r27, %r27;
    cvt.s64.s32 %rd10, %r3;
    shr.s32 %r5, %r27, 3;
    shr.u32 %r11, %r3, 31;
    sub.u32 %r20, %r5, 3;
    min.s32 %r23, %r20, %r20;
    sub.s32 %r20, %r5, %r23;
    sub.u32 %r9, %r23, %r27;
    max.u32 %r17, %r20, 0;
    xor.b32 %r9, %r27, 2;
    sub.u32 %r6, %r27, 1;
    min.s32 %r19, %r27, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
