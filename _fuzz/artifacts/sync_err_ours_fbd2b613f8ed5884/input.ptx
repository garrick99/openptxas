.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r10, %r3, 31;
    cvt.u64.u32 %rd9, %r3;
    cvt.u64.u32 %rd12, %r3;
    add.s32 %r20, %r3, 63;
    mul.wide.u32 %rd13, %r10, %r10;
    mad.lo.s32 %r22, %r3, %r20, %r20;
    mul.wide.u32 %rd5, %r20, %r3;
    mul.wide.u32 %rd12, %r22, %r3;
    mul.wide.s32 %rd5, %r3, %r3;
    shr.s32 %r14, %r20, 1;
    shr.s32 %r17, %r20, 2;
    max.s32 %r23, %r14, %r3;
    min.u32 %r9, %r10, 4294967295;
    and.b32 %r17, %r10, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
