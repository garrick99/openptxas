.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r27, %r3, 65535;
    mul.lo.s32 %r25, %r3, 64;
    mul.wide.u32 %rd9, %r27, %r27;
    shr.u32 %r12, %r3, 16;
    sub.u64 %rd12, %rd9, %rd9;
    or.b32 %r24, %r25, 15;
    add.u64 %rd14, %rd9, %rd12;
    shr.s64 %rd14, %rd12, 32;
    setp.ne.u32 %p3, %r27, %r27;
    @!%p3 add.s32 %r22, %r25, 2147483648;
    selp.b32 %r14, %r27, %r22, %p3;
    shr.s32 %r22, %r12, 4;
    selp.b32 %r14, %r25, %r25, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
