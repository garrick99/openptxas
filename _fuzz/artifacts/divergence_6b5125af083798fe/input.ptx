.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r15, %r3, 3;
    shr.u32 %r23, %r3, 16;
    shr.u32 %r9, %r3, 1;
    cvt.s64.s32 %rd6, %r23;
    max.s32 %r26, %r15, 32;
    cvt.u64.u32 %rd14, %r3;
    xor.b32 %r5, %r9, %r26;
    setp.lt.s32 %p3, %r15, 15;
    @%p3 sub.u32 %r18, %r3, 63;
    shl.b32 %r25, %r5, 1;
    or.b32 %r21, %r9, %r26;
    xor.b32 %r13, %r9, 63;
    mul.lo.s32 %r15, %r15, %r25;
    add.u64 %rd8, %rd6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
