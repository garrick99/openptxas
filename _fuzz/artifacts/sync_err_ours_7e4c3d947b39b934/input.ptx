.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r15, %r3, 31;
    mad.lo.u32 %r5, %r3, %r3, %r15;
    cvt.u64.u32 %rd5, %r3;
    and.b64 %rd6, %rd5, %rd5;
    add.s64 %rd11, %rd6, %rd5;
    min.s32 %r14, %r15, 4;
    setp.gt.u32 %p4, %r3, %r3;
    @%p4 mul.wide.u32 %rd5, %r14, %r5;
    or.b64 %rd13, %rd6, %rd11;
    min.s32 %r7, %r3, %r14;
    xor.b32 %r7, %r5, 4;
    shl.b32 %r19, %r3, 0;
    cvt.u32.u64 %r13, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
