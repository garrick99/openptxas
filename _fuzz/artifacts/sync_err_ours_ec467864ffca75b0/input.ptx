.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r11, %r3, %r3;
    cvt.s64.s32 %rd14, %r3;
    add.s32 %r24, %r11, %r3;
    min.u32 %r25, %r3, %r3;
    shr.u32 %r4, %r24, 1;
    shr.s32 %r21, %r11, 4;
    add.s64 %rd13, %rd14, %rd14;
    and.b32 %r9, %r25, 0;
    cvt.s32.s64 %r17, %rd13;
    mul.wide.s32 %rd5, %r3, %r21;
    shl.b32 %r14, %r4, 7;
    shr.s32 %r8, %r14, 3;
    add.u32 %r10, %r21, 31;
    cvt.s64.s32 %rd6, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
