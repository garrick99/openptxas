.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r27, %r3, %r3;
    min.s32 %r13, %r3, %r27;
    or.b32 %r25, %r3, %r27;
    shr.s32 %r11, %r13, 0;
    setp.ge.s32 %p4, %r25, %r11;
    @%p4 max.s32 %r11, %r11, 16;
    setp.lt.u32 %p1, %r13, 4;
    @!%p1 max.s32 %r21, %r25, %r3;
    cvt.s64.s32 %rd9, %r21;
    mul.wide.u32 %rd14, %r3, %r11;
    sub.s32 %r27, %r13, 8;
    min.s32 %r13, %r27, %r27;
    add.u32 %r8, %r27, 0;
    selp.b32 %r19, %r21, %r27, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
