.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    mul.lo.u32 %r11, %r3, %r3;
    mad.lo.u32 %r13, %r3, %r3, %r11;
    cvt.s64.s32 %rd15, %r3;
    setp.eq.s32 %p2, %r13, %r11;
    @%p2 shl.b32 %r6, %r11, 0;
    shr.s32 %r13, %r13, 1;
    cvt.u64.u32 %rd13, %r11;
    shr.u32 %r16, %r13, 15;
    add.s32 %r4, %r13, %r11;
    shr.s32 %r10, %r13, 0;
    sub.u32 %r7, %r13, 7;
    shr.s64 %rd6, %rd10, 32;
    add.s32 %r24, %r6, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
