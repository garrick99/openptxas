.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r4, %r3, %r3, %r3;
    and.b32 %r23, %r4, 63;
    setp.lo.u32 %p1, %r23, 4294967295;
    @%p1 add.s32 %r12, %r23, 3;
    mad.lo.s32 %r9, %r23, %r4, %r3;
    cvt.s64.s32 %rd15, %r12;
    shl.b32 %r6, %r9, 2;
    or.b32 %r22, %r23, 1;
    sub.s64 %rd15, %rd15, %rd15;
    xor.b32 %r15, %r12, %r9;
    selp.b32 %r20, %r4, %r23, %p1;
    setp.ne.u32 %p2, %r6, %r9;
    @!%p2 cvt.s64.s32 %rd9, %r22;
    cvt.u32.u64 %r12, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
