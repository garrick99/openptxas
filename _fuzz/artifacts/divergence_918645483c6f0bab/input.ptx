.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r7, %r3, 255;
    setp.lt.u32 %p3, %r7, %r7;
    @%p3 cvt.s64.s32 %rd13, %r3;
    shr.s32 %r12, %r7, 16;
    shl.b32 %r5, %r7, 4;
    mul.wide.u32 %rd11, %r12, %r3;
    mul.lo.u32 %r15, %r5, %r7;
    and.b32 %r4, %r5, 256;
    xor.b32 %r9, %r12, %r12;
    sub.u32 %r13, %r12, %r9;
    and.b32 %r12, %r3, %r4;
    cvt.s32.s64 %r19, %rd13;
    add.u64 %rd10, %rd11, %rd13;
    mad.lo.s32 %r21, %r4, %r5, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
