.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    add.u32 %r8, %r3, %r3;
    and.b32 %r14, %r3, %r3;
    mul.wide.s32 %rd9, %r8, %r14;
    setp.gt.s32 %p1, %r8, 7;
    @%p1 mul.wide.s32 %rd12, %r8, %r3;
    shl.b32 %r11, %r3, 1;
    mad.lo.s32 %r18, %r14, %r14, %r8;
    sub.u32 %r16, %r3, 4294967295;
    sub.u32 %r15, %r18, %r11;
    shr.s32 %r10, %r16, 4;
    sub.s32 %r27, %r3, %r16;
    cvt.s32.s64 %r10, %rd14;
    setp.eq.s32 %p1, %r18, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
