.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r15, %r3, 31;
    and.b32 %r12, %r3, 4;
    and.b32 %r14, %r3, 2;
    setp.hi.u32 %p1, %r12, %r3;
    setp.gt.u32 %p2, %r12, 256;
    @%p2 selp.b32 %r20, %r15, %r3, %p2;
    cvt.u64.u32 %rd15, %r3;
    cvt.s64.s32 %rd9, %r14;
    min.s32 %r21, %r14, 16;
    add.u32 %r18, %r15, 1;
    max.u32 %r18, %r14, 1;
    setp.hi.u32 %p1, %r18, 256;
    @%p1 or.b32 %r17, %r14, 0;
    mul.wide.u32 %rd7, %r12, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
