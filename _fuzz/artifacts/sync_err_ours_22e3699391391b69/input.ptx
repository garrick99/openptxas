.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r4, %r3, %r3, %r3;
    shl.b32 %r22, %r3, 7;
    shl.b32 %r9, %r4, 2;
    cvt.u64.u32 %rd12, %r3;
    min.s32 %r24, %r4, %r22;
    add.s32 %r21, %r22, 63;
    min.u32 %r27, %r9, %r22;
    shr.s32 %r27, %r9, 30;
    cvt.s32.s64 %r26, %rd12;
    shr.s32 %r8, %r26, 4;
    xor.b32 %r23, %r24, 31;
    setp.ge.u32 %p3, %r22, %r27;
    cvt.s64.s32 %rd15, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
