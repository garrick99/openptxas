.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r24, %r3, 3;
    cvt.s64.s32 %rd11, %r24;
    add.s64 %rd6, %rd11, %rd11;
    max.u32 %r23, %r3, %r24;
    cvt.u32.u64 %r20, %rd6;
    sub.s64 %rd10, %rd6, %rd11;
    min.u32 %r25, %r23, 15;
    sub.s64 %rd6, %rd11, %rd10;
    sub.u64 %rd9, %rd11, %rd6;
    mad.lo.u32 %r11, %r25, %r23, %r25;
    add.s64 %rd15, %rd6, %rd6;
    mul.lo.u32 %r10, %r3, 4294967295;
    or.b64 %rd11, %rd15, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
