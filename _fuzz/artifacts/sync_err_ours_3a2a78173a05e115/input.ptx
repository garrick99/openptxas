.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    max.u32 %r24, %r3, 63;
    mad.lo.s32 %r9, %r3, %r24, %r24;
    xor.b32 %r17, %r3, %r9;
    max.s32 %r12, %r17, %r9;
    mul.wide.s32 %rd15, %r3, %r9;
    add.s32 %r20, %r24, %r3;
    setp.ls.u32 %p3, %r17, %r9;
    shr.s32 %r20, %r9, 16;
    shr.u32 %r15, %r12, 15;
    mul.wide.u32 %rd14, %r9, %r12;
    mul.wide.u32 %rd9, %r9, %r15;
    mul.wide.u32 %rd9, %r24, %r9;
    mul.wide.s32 %rd8, %r12, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
