.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p4, %r3, 0;
    @!%p4 sub.s32 %r17, %r3, %r3;
    selp.b32 %r5, %r17, %r17, %p4;
    mul.wide.s32 %rd5, %r3, %r17;
    selp.b32 %r12, %r5, %r5, %p4;
    add.s32 %r15, %r3, %r3;
    shl.b64 %rd9, %rd5, 62;
    sub.u32 %r15, %r3, %r5;
    add.u32 %r20, %r3, 4294967295;
    setp.eq.u32 %p1, %r17, %r17;
    @%p1 max.u32 %r17, %r20, 255;
    mul.wide.u32 %rd5, %r17, %r12;
    mul.wide.s32 %rd13, %r20, %r20;
    min.u32 %r10, %r17, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
