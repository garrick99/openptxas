.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    min.s32 %r19, %r3, %r3;
    cvt.u64.u32 %rd15, %r19;
    cvt.u64.u32 %rd10, %r19;
    cvt.s64.s32 %rd6, %r19;
    sub.s32 %r23, %r3, %r19;
    or.b64 %rd14, %rd10, %rd6;
    cvt.u32.u64 %r21, %rd14;
    mad.lo.s32 %r14, %r21, %r21, %r21;
    and.b32 %r4, %r19, 16;
    setp.gt.s32 %p1, %r4, %r4;
    @%p1 mad.lo.u32 %r6, %r14, %r23, %r21;
    max.u32 %r8, %r14, %r6;
    and.b64 %rd8, %rd15, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
