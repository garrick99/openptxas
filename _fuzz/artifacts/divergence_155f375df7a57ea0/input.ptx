    mul.lo.u32 %r20, %r17, 5;
    and.b32 %r7, %r15, 4294967295;
    and.b32 %r11, %r3, %r7;
    add.u32 %r15, %r23, %r23;
    or.b32 %r25, %r17, %r20;
    max.u32 %r10, %r20, 2147483647;
