.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r12, %r3, %r3;
    add.s32 %r8, %r12, 65536;
    mul.wide.u32 %rd9, %r3, %r12;
    min.s32 %r27, %r12, %r3;
    sub.u32 %r17, %r8, %r3;
    max.s32 %r20, %r12, 63;
    xor.b32 %r10, %r27, 16;
    shr.u64 %rd15, %rd9, 0;
    sub.u32 %r7, %r8, %r10;
    mul.wide.u32 %rd8, %r27, %r10;
    setp.le.s32 %p2, %r3, 4294967295;
    @%p2 shl.b32 %r14, %r12, 7;
    min.u64 %rd12, %rd9, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
