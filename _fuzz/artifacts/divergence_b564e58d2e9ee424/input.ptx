.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r5, %r3, 16;
    cvt.u64.u32 %rd8, %r5;
    mul.lo.s32 %r10, %r3, %r3;
    sub.s64 %rd6, %rd8, %rd8;
    cvt.u32.u64 %r16, %rd8;
    setp.gt.u32 %p1, %r5, %r16;
    min.u32 %r19, %r3, %r10;
    mul.wide.u32 %rd6, %r5, %r3;
    add.u32 %r26, %r5, 65535;
    add.u32 %r5, %r26, %r19;
    max.u32 %r13, %r3, %r3;
    min.u32 %r18, %r3, 16;
    mad.lo.s32 %r7, %r26, %r3, %r5;
    mul.lo.u32 %r12, %r16, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
