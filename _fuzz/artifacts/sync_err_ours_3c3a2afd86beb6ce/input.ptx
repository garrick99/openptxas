.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    mul.wide.u32 %rd9, %r3, %r3;
    max.u32 %r17, %r3, 64;
    shr.u32 %r16, %r3, 3;
    mul.wide.s32 %rd13, %r3, %r3;
    min.u32 %r18, %r16, %r16;
    or.b64 %rd9, %rd13, %rd15;
    add.s32 %r27, %r16, %r16;
    or.b32 %r15, %r18, %r18;
    or.b32 %r7, %r16, %r27;
    shr.u32 %r26, %r18, 7;
    mul.lo.s32 %r17, %r7, 15;
    mul.wide.u32 %rd8, %r3, %r17;
    shr.s64 %rd13, %rd15, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
