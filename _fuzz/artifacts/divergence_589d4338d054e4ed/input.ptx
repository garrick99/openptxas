.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    mul.wide.u32 %rd10, %r3, %r3;
    max.s32 %r25, %r3, %r3;
    shr.u32 %r9, %r25, 16;
    sub.s32 %r18, %r9, %r25;
    mad.lo.s32 %r16, %r18, %r25, %r3;
    and.b32 %r22, %r16, 5;
    sub.s64 %rd6, %rd12, %rd10;
    or.b32 %r16, %r16, 7;
    and.b32 %r7, %r18, %r3;
    shl.b32 %r5, %r7, 0;
    setp.lt.u32 %p2, %r3, 2;
    @%p2 max.u32 %r27, %r7, %r18;
    min.s32 %r8, %r3, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
