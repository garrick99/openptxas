.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r27, %r3, 3;
    cvt.u64.u32 %rd5, %r3;
    add.u32 %r21, %r27, %r27;
    shl.b32 %r15, %r27, 2;
    cvt.s32.s64 %r11, %rd5;
    min.s32 %r15, %r27, %r15;
    cvt.s64.s32 %rd14, %r21;
    sub.s64 %rd15, %rd14, %rd5;
    shr.u64 %rd6, %rd14, 62;
    mad.lo.u32 %r4, %r21, %r3, %r15;
    mul.lo.s32 %r26, %r21, 3;
    add.u32 %r25, %r4, %r26;
    sub.u32 %r4, %r27, 63;
    max.s32 %r18, %r11, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
