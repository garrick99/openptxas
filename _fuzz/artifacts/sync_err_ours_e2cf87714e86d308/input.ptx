.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd13, %r3, %r3;
    sub.s32 %r24, %r3, 256;
    max.s32 %r10, %r3, 5;
    sub.u32 %r19, %r10, 15;
    shr.u64 %rd6, %rd13, 2;
    min.s32 %r25, %r19, %r24;
    add.s32 %r18, %r24, %r3;
    setp.hi.u32 %p4, %r3, 0;
    @!%p4 min.s32 %r8, %r19, 256;
    and.b32 %r17, %r18, %r25;
    max.s32 %r13, %r24, %r3;
    and.b64 %rd10, %rd6, %rd6;
    max.u32 %r10, %r18, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
