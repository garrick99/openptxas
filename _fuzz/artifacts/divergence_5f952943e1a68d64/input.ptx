.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r22, %r3, 7;
    cvt.s64.s32 %rd12, %r22;
    shr.u64 %rd11, %rd12, 33;
    max.u64 %rd14, %rd12, %rd11;
    setp.eq.u32 %p4, %r22, %r3;
    @!%p4 or.b32 %r17, %r3, 2147483648;
    max.u32 %r26, %r17, 5;
    max.u32 %r24, %r3, %r3;
    cvt.u32.u64 %r20, %rd14;
    max.s32 %r14, %r26, %r24;
    mad.lo.u32 %r15, %r24, %r17, %r20;
    max.s64 %rd6, %rd12, %rd14;
    setp.ne.s32 %p1, %r14, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
