.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    shr.u32 %r9, %r3, 15;
    add.u32 %r4, %r9, 65536;
    sub.s32 %r24, %r9, %r4;
    or.b64 %rd9, %rd12, %rd12;
    shr.u32 %r10, %r4, 3;
    mad.lo.u32 %r18, %r3, %r24, %r9;
    shr.u64 %rd13, %rd12, 33;
    xor.b32 %r26, %r3, %r24;
    xor.b32 %r27, %r10, 65536;
    xor.b32 %r11, %r18, 8;
    min.u64 %rd7, %rd12, %rd13;
    and.b32 %r7, %r24, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
