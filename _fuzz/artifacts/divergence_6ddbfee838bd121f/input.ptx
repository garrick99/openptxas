.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r10, %r3, %r3;
    setp.le.u32 %p1, %r3, 63;
    @!%p1 sub.u32 %r9, %r10, 32;
    mad.lo.s32 %r26, %r9, %r10, %r10;
    cvt.s64.s32 %rd13, %r9;
    shr.u32 %r19, %r3, 2;
    mul.lo.u32 %r23, %r10, 4294967295;
    and.b64 %rd15, %rd13, %rd13;
    setp.le.u32 %p3, %r3, %r23;
    @%p3 and.b32 %r5, %r19, %r3;
    max.s64 %rd5, %rd13, %rd15;
    setp.gt.u32 %p4, %r10, %r23;
    @!%p4 cvt.s32.s64 %r4, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
