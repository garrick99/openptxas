.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r20, %r3, 1;
    cvt.s64.s32 %rd6, %r20;
    max.s32 %r26, %r3, 0;
    mad.lo.u32 %r8, %r26, %r3, %r26;
    add.u32 %r4, %r8, %r8;
    cvt.s64.s32 %rd11, %r8;
    add.s32 %r18, %r8, 8;
    mul.wide.u32 %rd8, %r3, %r4;
    mul.lo.s64 %rd13, %rd11, %rd8;
    xor.b32 %r23, %r20, %r8;
    min.s64 %rd7, %rd11, %rd13;
    min.u32 %r25, %r23, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
