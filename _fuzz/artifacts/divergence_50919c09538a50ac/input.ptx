.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r20, %r3, %r3, %r3;
    sub.s32 %r8, %r20, %r3;
    shl.b32 %r22, %r20, 16;
    cvt.u64.u32 %rd11, %r22;
    xor.b32 %r24, %r22, 3;
    sub.s64 %rd5, %rd11, %rd11;
    min.u32 %r7, %r3, 1;
    setp.lt.u32 %p4, %r24, %r22;
    setp.lo.u32 %p4, %r7, %r3;
    @%p4 max.s64 %rd8, %rd5, %rd5;
    mul.wide.s32 %rd13, %r8, %r24;
    setp.eq.u32 %p4, %r8, 16;
    and.b32 %r17, %r24, %r7;
    min.s32 %r9, %r3, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
