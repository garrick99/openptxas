.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r23, %r3, 32;
    cvt.s64.s32 %rd14, %r3;
    mad.lo.s32 %r9, %r3, %r3, %r3;
    cvt.u32.u64 %r8, %rd14;
    shl.b32 %r24, %r23, 30;
    shr.s32 %r17, %r23, 4;
    mul.lo.s32 %r26, %r24, 4294967295;
    mul.wide.s32 %rd14, %r9, %r3;
    add.s32 %r12, %r3, 4294967295;
    setp.le.u32 %p3, %r26, %r8;
    @!%p3 sub.s64 %rd11, %rd14, %rd14;
    add.s32 %r27, %r3, %r12;
    selp.b32 %r14, %r23, %r26, %p3;
    selp.b32 %r12, %r8, %r17, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
