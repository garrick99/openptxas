.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r19, %r3, 4294967295;
    shr.u32 %r8, %r19, 0;
    add.s32 %r9, %r3, %r19;
    min.u32 %r27, %r3, %r3;
    setp.eq.s32 %p4, %r19, 255;
    setp.ne.s32 %p4, %r19, %r19;
    @!%p4 mad.lo.u32 %r4, %r9, %r3, %r3;
    cvt.u64.u32 %rd5, %r27;
    xor.b32 %r14, %r3, %r8;
    min.u32 %r24, %r27, %r9;
    setp.ls.u32 %p3, %r9, 2147483648;
    xor.b32 %r8, %r19, %r24;
    xor.b32 %r24, %r19, 16;
    selp.b32 %r18, %r9, %r14, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
