.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r14, %r3, %r3;
    shr.u32 %r24, %r3, 16;
    xor.b32 %r7, %r14, 7;
    cvt.s64.s32 %rd15, %r14;
    max.s32 %r22, %r3, %r7;
    mad.lo.u32 %r5, %r24, %r7, %r7;
    min.u32 %r7, %r7, 255;
    sub.u32 %r27, %r5, %r5;
    min.s32 %r10, %r3, %r24;
    shl.b64 %rd5, %rd15, 4;
    sub.s32 %r17, %r7, %r3;
    add.s32 %r27, %r7, 255;
    shr.s32 %r11, %r22, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
