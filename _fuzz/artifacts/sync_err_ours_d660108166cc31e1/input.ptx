.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r17, %r3, 16;
    mad.lo.u32 %r18, %r3, %r17, %r3;
    mul.wide.u32 %rd11, %r3, %r17;
    mul.wide.s32 %rd7, %r18, %r17;
    shr.u32 %r8, %r17, 4;
    add.s64 %rd6, %rd11, %rd11;
    mad.lo.u32 %r27, %r18, %r8, %r18;
    shr.s64 %rd5, %rd7, 32;
    shl.b64 %rd14, %rd6, 1;
    add.u32 %r17, %r18, 65535;
    min.u64 %rd7, %rd14, %rd5;
    shl.b32 %r25, %r27, 4;
    add.s64 %rd12, %rd11, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
