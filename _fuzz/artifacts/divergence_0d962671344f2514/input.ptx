.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    and.b32 %r13, %r3, 255;
    mul.lo.s64 %rd8, %rd5, %rd5;
    xor.b32 %r21, %r3, 32;
    cvt.u64.u32 %rd11, %r21;
    shl.b32 %r13, %r13, 3;
    shr.u32 %r23, %r21, 0;
    max.s32 %r21, %r21, 1;
    min.u32 %r21, %r23, %r13;
    mad.lo.u32 %r8, %r3, %r3, %r21;
    shr.s32 %r10, %r8, 15;
    cvt.u64.u32 %rd13, %r21;
    setp.eq.u32 %p2, %r21, 256;
    @%p2 cvt.s32.s64 %r9, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
