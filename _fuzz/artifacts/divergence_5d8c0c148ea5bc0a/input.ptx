.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r6, %r3, 15;
    setp.eq.s32 %p1, %r6, 256;
    @%p1 mul.wide.u32 %rd5, %r3, %r6;
    sub.u32 %r18, %r3, 255;
    sub.s32 %r16, %r18, %r6;
    selp.b32 %r27, %r18, %r18, %p1;
    and.b64 %rd6, %rd5, %rd5;
    max.s32 %r14, %r3, %r27;
    sub.u32 %r19, %r18, 3;
    min.s32 %r21, %r16, %r27;
    selp.b32 %r13, %r27, %r19, %p1;
    and.b32 %r23, %r27, 4294967295;
    cvt.u32.u64 %r12, %rd5;
    or.b32 %r11, %r23, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
