.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    shr.u32 %r5, %r3, 31;
    or.b32 %r23, %r3, %r5;
    shr.s64 %rd11, %rd14, 4;
    shl.b32 %r14, %r23, 1;
    mul.lo.u32 %r8, %r3, 2147483648;
    setp.lt.u32 %p1, %r5, %r23;
    @%p1 cvt.s64.s32 %rd11, %r3;
    sub.u64 %rd13, %rd11, %rd11;
    selp.b32 %r9, %r5, %r5, %p1;
    setp.gt.s32 %p4, %r5, %r14;
    @%p4 sub.u64 %rd10, %rd11, %rd14;
    max.s32 %r19, %r5, 0;
    shr.u32 %r27, %r19, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
