.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r22, %r3, %r3;
    max.s32 %r12, %r3, %r3;
    max.u32 %r26, %r3, %r22;
    mul.wide.u32 %rd12, %r3, %r22;
    sub.s32 %r7, %r26, 0;
    cvt.u32.u64 %r27, %rd12;
    or.b32 %r27, %r27, 1;
    setp.lt.s32 %p3, %r3, %r26;
    @%p3 max.u32 %r5, %r12, 8;
    mad.lo.u32 %r22, %r3, %r22, %r3;
    xor.b32 %r8, %r7, %r27;
    xor.b32 %r14, %r7, %r22;
    setp.le.s32 %p1, %r27, 255;
    sub.s32 %r23, %r14, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
