.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r23, %r3, 65535;
    cvt.u64.u32 %rd10, %r23;
    mul.wide.u32 %rd10, %r23, %r23;
    cvt.s64.s32 %rd8, %r3;
    mad.lo.s32 %r11, %r23, %r23, %r3;
    shr.u64 %rd9, %rd8, 16;
    mul.wide.s32 %rd15, %r23, %r23;
    setp.lt.s32 %p2, %r11, %r23;
    @%p2 max.u32 %r8, %r23, 65536;
    setp.eq.u32 %p3, %r11, 4;
    @%p3 add.s32 %r7, %r11, 15;
    max.u32 %r9, %r23, %r8;
    or.b32 %r11, %r23, %r23;
    mul.lo.u32 %r13, %r8, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
