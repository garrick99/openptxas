.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p1, %r3, %r3;
    sub.s32 %r8, %r3, 255;
    mul.lo.s32 %r8, %r8, 2147483648;
    selp.b32 %r21, %r3, %r8, %p1;
    cvt.s64.s32 %rd10, %r21;
    add.u32 %r12, %r21, 8;
    mul.lo.s32 %r21, %r12, 4;
    and.b64 %rd11, %rd10, %rd10;
    xor.b32 %r4, %r12, 0;
    or.b64 %rd8, %rd11, %rd10;
    cvt.u32.u64 %r22, %rd11;
    or.b32 %r10, %r12, %r8;
    mad.lo.s32 %r27, %r21, %r8, %r21;
    mul.lo.s32 %r16, %r21, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
