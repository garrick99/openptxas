.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r20, %r3, 31;
    cvt.u64.u32 %rd13, %r3;
    shl.b64 %rd12, %rd13, 48;
    sub.s32 %r24, %r3, %r20;
    setp.ls.u32 %p4, %r24, 64;
    @%p4 cvt.s32.s64 %r18, %rd12;
    cvt.s64.s32 %rd10, %r20;
    mul.lo.u32 %r17, %r18, %r20;
    max.s32 %r20, %r17, 7;
    shl.b32 %r5, %r24, 15;
    shr.u32 %r9, %r24, 30;
    min.u64 %rd10, %rd12, %rd12;
    sub.u32 %r26, %r18, 256;
    xor.b32 %r9, %r17, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
