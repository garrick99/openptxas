.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r17, %r3, 2;
    mad.lo.s32 %r10, %r17, %r3, %r17;
    add.u32 %r9, %r10, %r3;
    cvt.s64.s32 %rd8, %r17;
    mad.lo.u32 %r26, %r17, %r9, %r17;
    cvt.u64.u32 %rd8, %r9;
    max.s32 %r16, %r9, 4;
    add.u32 %r11, %r16, %r17;
    and.b32 %r7, %r10, %r3;
    setp.gt.s32 %p3, %r10, 3;
    min.s32 %r19, %r17, %r17;
    max.s32 %r24, %r7, %r7;
    and.b32 %r13, %r19, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
