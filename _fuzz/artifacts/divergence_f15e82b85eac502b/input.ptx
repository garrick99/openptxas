.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p1, %r3, 65535;
    cvt.u64.u32 %rd10, %r3;
    mul.lo.s32 %r6, %r3, %r3;
    cvt.u32.u64 %r26, %rd10;
    selp.b32 %r22, %r6, %r6, %p1;
    add.u32 %r12, %r6, 1;
    sub.u64 %rd11, %rd10, %rd10;
    sub.s32 %r21, %r12, 16;
    sub.s32 %r21, %r6, %r22;
    mul.wide.s32 %rd5, %r6, %r6;
    max.u32 %r13, %r3, %r3;
    setp.lo.u32 %p4, %r6, %r3;
    @%p4 mul.lo.u32 %r5, %r21, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
