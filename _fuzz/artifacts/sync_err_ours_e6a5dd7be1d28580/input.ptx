    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r25, %r3, 5;
    cvt.s64.s32 %rd5, %r3;
    max.u32 %r24, %r25, 4294967295;
    shl.b32 %r19, %r24, 1;
    mul.wide.u32 %rd12, %r19, %r19;
    mul.wide.u32 %rd11, %r19, %r3;
    shl.b64 %rd14, %rd11, 4;
    cvt.u64.u32 %rd7, %r19;
