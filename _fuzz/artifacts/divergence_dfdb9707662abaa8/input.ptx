.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    sub.s32 %r14, %r3, %r3;
    and.b32 %r15, %r14, %r14;
    sub.s32 %r15, %r3, %r14;
    add.s32 %r18, %r15, 7;
    mad.lo.u32 %r25, %r3, %r15, %r18;
    max.u32 %r9, %r15, 7;
    xor.b64 %rd9, %rd8, %rd8;
    shr.s32 %r16, %r3, 4;
    mul.lo.s32 %r10, %r3, %r18;
    mul.lo.u64 %rd7, %rd8, %rd9;
    cvt.u32.u64 %r16, %rd7;
    max.u32 %r16, %r9, 3;
    mul.lo.u64 %rd12, %rd7, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
