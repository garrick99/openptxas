.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r24, %r3, %r3, %r3;
    add.s32 %r11, %r3, 2;
    cvt.u64.u32 %rd14, %r24;
    xor.b32 %r20, %r24, %r11;
    shr.s32 %r19, %r24, 0;
    add.u32 %r22, %r24, 3;
    xor.b32 %r7, %r24, %r11;
    add.u32 %r6, %r24, %r20;
    add.s32 %r8, %r20, %r3;
    setp.lo.u32 %p3, %r19, 63;
    max.u32 %r4, %r24, %r19;
    add.s32 %r13, %r22, 65536;
    mul.lo.s32 %r10, %r24, %r3;
    setp.le.s32 %p3, %r19, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
