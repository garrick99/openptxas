.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r21, %r3, %r3;
    mul.wide.u32 %rd6, %r21, %r21;
    mul.wide.s32 %rd8, %r21, %r3;
    min.u32 %r5, %r21, 2147483647;
    mad.lo.u32 %r27, %r5, %r5, %r5;
    xor.b64 %rd8, %rd8, %rd6;
    mul.wide.u32 %rd14, %r3, %r5;
    max.u32 %r4, %r3, 8;
    or.b32 %r20, %r21, %r27;
    cvt.s64.s32 %rd10, %r20;
    shr.u32 %r25, %r27, 15;
    setp.gt.s32 %p3, %r5, 256;
    @%p3 selp.b32 %r20, %r20, %r25, %p3;
    xor.b32 %r6, %r25, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
