.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r5, %r3, %r3;
    sub.u32 %r23, %r5, %r5;
    min.s32 %r21, %r5, 4;
    cvt.s64.s32 %rd6, %r23;
    shr.u64 %rd14, %rd6, 32;
    cvt.u64.u32 %rd14, %r3;
    xor.b32 %r11, %r5, 256;
    shr.s32 %r24, %r11, 7;
    cvt.s32.s64 %r20, %rd6;
    shl.b32 %r22, %r21, 2;
    setp.le.s32 %p2, %r20, %r11;
    @%p2 cvt.u32.u64 %r8, %rd14;
    add.s32 %r10, %r22, 0;
    sub.u32 %r19, %r5, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
