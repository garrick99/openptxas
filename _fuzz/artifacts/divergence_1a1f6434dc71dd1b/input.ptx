.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r24, %r3, 255;
    min.u32 %r22, %r3, 256;
    shl.b32 %r17, %r3, 2;
    mad.lo.s32 %r22, %r17, %r22, %r22;
    or.b32 %r21, %r17, 5;
    cvt.u64.u32 %rd7, %r3;
    shl.b32 %r11, %r22, 7;
    xor.b32 %r24, %r17, %r11;
    mul.wide.u32 %rd11, %r24, %r17;
    shr.u64 %rd14, %rd7, 2;
    sub.u64 %rd10, %rd11, %rd11;
    setp.ne.s32 %p4, %r21, 3;
    @!%p4 min.s32 %r22, %r21, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
