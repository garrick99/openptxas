.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfi.b32 %r11, %r3, %r3, 16, 1;
    bfe.s32 %r14, %r3, 7, 32;
    bfe.u32 %r20, %r11, 24, 2;
    bfe.u32 %r9, %r11, 31, 2;
    bfe.s32 %r4, %r20, 1, 24;
    min.u32 %r16, %r20, %r20;
    clz.b32 %r23, %r9;
    and.b32 %r19, %r14, 7;
    brev.b32 %r6, %r9;
    clz.b32 %r17, %r3;
    popc.b32 %r9, %r9;
    min.u32 %r11, %r20, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
