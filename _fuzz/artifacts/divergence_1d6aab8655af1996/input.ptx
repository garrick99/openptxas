.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p2, %r3, 65535;
    cvt.s64.s32 %rd5, %r3;
    mul.lo.s32 %r18, %r3, %r3;
    setp.le.u32 %p3, %r18, 5;
    selp.b32 %r10, %r18, %r3, %p2;
    min.s32 %r23, %r18, %r10;
    xor.b64 %rd8, %rd5, %rd5;
    selp.b32 %r5, %r18, %r10, %p3;
    sub.u32 %r12, %r10, %r10;
    xor.b32 %r24, %r3, 256;
    mul.lo.u32 %r13, %r3, %r24;
    sub.u32 %r11, %r13, 8;
    setp.ge.u32 %p1, %r23, 65536;
    setp.lo.u32 %p1, %r3, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
