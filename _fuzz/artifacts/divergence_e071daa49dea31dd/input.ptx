.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r10, %r3, %r3;
    cvt.u64.u32 %rd14, %r10;
    shr.s64 %rd12, %rd14, 7;
    add.s64 %rd5, %rd14, %rd14;
    add.u32 %r26, %r3, %r10;
    max.u32 %r6, %r3, 0;
    add.u64 %rd12, %rd5, %rd5;
    setp.ls.u32 %p3, %r3, 255;
    @%p3 selp.b32 %r5, %r26, %r10, %p3;
    shr.u64 %rd12, %rd5, 7;
    shl.b32 %r18, %r10, 3;
    shr.s64 %rd14, %rd12, 33;
    mul.lo.u32 %r16, %r18, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
