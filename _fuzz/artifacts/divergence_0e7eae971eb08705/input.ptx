.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r22, %r3, %r3;
    shr.s32 %r21, %r22, 16;
    cvt.u64.u32 %rd12, %r21;
    setp.le.s32 %p3, %r3, 3;
    @%p3 mul.wide.s32 %rd5, %r22, %r22;
    cvt.s32.s64 %r10, %rd5;
    mad.lo.s32 %r7, %r22, %r22, %r3;
    min.u32 %r9, %r21, %r22;
    max.s32 %r17, %r10, 4294967295;
    setp.eq.s32 %p3, %r3, %r9;
    @!%p3 mad.lo.u32 %r12, %r10, %r21, %r21;
    add.s64 %rd5, %rd5, %rd12;
    mul.lo.u32 %r7, %r17, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
