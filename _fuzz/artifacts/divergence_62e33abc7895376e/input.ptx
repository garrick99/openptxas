.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p1, %r3, 65535;
    @!%p1 max.s32 %r23, %r3, %r3;
    cvt.u64.u32 %rd5, %r3;
    min.u32 %r14, %r3, 7;
    selp.b32 %r8, %r3, %r3, %p1;
    mad.lo.s32 %r20, %r23, %r23, %r14;
    cvt.u64.u32 %rd10, %r20;
    add.u32 %r26, %r23, 3;
    selp.b32 %r12, %r20, %r8, %p1;
    shr.u32 %r14, %r23, 16;
    cvt.s32.s64 %r5, %rd10;
    shl.b32 %r5, %r3, 7;
    setp.ge.u32 %p2, %r3, %r8;
    @!%p2 max.s32 %r6, %r12, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
