.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r15, %r3, 2147483648;
    mul.wide.s32 %rd13, %r3, %r15;
    and.b32 %r24, %r3, 255;
    sub.s64 %rd6, %rd13, %rd13;
    shl.b32 %r26, %r15, 2;
    max.u32 %r7, %r3, 4;
    shr.u64 %rd10, %rd6, 3;
    or.b64 %rd11, %rd13, %rd10;
    mul.wide.u32 %rd7, %r26, %r7;
    min.s64 %rd7, %rd11, %rd6;
    add.u32 %r17, %r24, 16;
    sub.s64 %rd7, %rd13, %rd10;
    cvt.u32.u64 %r11, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
