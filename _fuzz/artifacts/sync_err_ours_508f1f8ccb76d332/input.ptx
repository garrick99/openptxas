.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r20, %r3, 65536;
    shr.s32 %r7, %r3, 4;
    cvt.s64.s32 %rd6, %r3;
    max.u32 %r16, %r7, %r3;
    shr.u32 %r11, %r7, 31;
    sub.s32 %r9, %r7, %r16;
    xor.b32 %r20, %r3, 2;
    and.b32 %r21, %r9, %r7;
    shr.u32 %r9, %r9, 3;
    add.s32 %r5, %r21, %r20;
    setp.ne.u32 %p3, %r21, %r11;
    @%p3 selp.b32 %r21, %r3, %r21, %p3;
    shr.s32 %r4, %r3, 2;
    min.u32 %r23, %r5, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
