.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    cvt.u32.u64 %r21, %rd14;
    or.b32 %r4, %r21, %r3;
    cvt.u64.u32 %rd15, %r3;
    mul.lo.s32 %r12, %r21, 65536;
    cvt.u32.u64 %r26, %rd15;
    add.s32 %r11, %r3, %r4;
    shl.b32 %r12, %r11, 30;
    and.b32 %r27, %r12, %r11;
    add.u32 %r11, %r3, %r12;
    max.u32 %r27, %r11, %r3;
    setp.lt.s32 %p3, %r21, 0;
    @%p3 shl.b64 %rd5, %rd15, 33;
    xor.b64 %rd13, %rd15, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
