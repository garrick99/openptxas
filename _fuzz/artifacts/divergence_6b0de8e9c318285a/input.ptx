.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r17, %r3, 3;
    mul.wide.u32 %rd9, %r3, %r3;
    max.u32 %r15, %r17, 2;
    setp.ls.u32 %p4, %r3, %r17;
    @%p4 xor.b32 %r26, %r15, %r15;
    cvt.u64.u32 %rd14, %r15;
    mul.lo.u32 %r13, %r26, %r26;
    cvt.u32.u64 %r6, %rd14;
    shr.u32 %r22, %r26, 16;
    mul.lo.s32 %r13, %r26, %r17;
    xor.b32 %r17, %r17, %r3;
    max.s32 %r13, %r13, %r22;
    cvt.s64.s32 %rd12, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
