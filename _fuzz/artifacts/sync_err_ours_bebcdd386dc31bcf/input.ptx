    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    setp.gt.s32 %p4, %r3, %r3;
    cvt.s32.s64 %r20, %rd10;
    mul.wide.s32 %rd7, %r20, %r20;
    and.b32 %r14, %r20, 15;
    add.u32 %r13, %r3, 2147483647;
    cvt.s32.s64 %r7, %rd10;
    shl.b64 %rd8, %rd7, 32;
    cvt.s32.s64 %r17, %rd8;
    min.s32 %r18, %r13, %r3;
    and.b32 %r12, %r20, 65536;
    cvt.u32.u64 %r13, %rd8;
    mad.lo.s32 %r19, %r14, %r7, %r18;
    max.s64 %rd15, %rd8, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
