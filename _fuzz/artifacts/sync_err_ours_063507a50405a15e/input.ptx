.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r4, %r3, 2;
    mad.lo.s32 %r24, %r4, %r4, %r4;
    add.u32 %r18, %r4, %r4;
    cvt.u64.u32 %rd12, %r24;
    mul.wide.s32 %rd13, %r18, %r24;
    add.s32 %r14, %r4, 3;
    mul.wide.s32 %rd15, %r24, %r18;
    mul.wide.u32 %rd6, %r18, %r18;
    max.s32 %r27, %r3, %r4;
    or.b32 %r18, %r4, 2147483648;
    mul.wide.u32 %rd11, %r3, %r14;
    cvt.u32.u64 %r12, %rd12;
    setp.gt.s32 %p4, %r4, 65535;
    setp.ge.s32 %p3, %r27, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
