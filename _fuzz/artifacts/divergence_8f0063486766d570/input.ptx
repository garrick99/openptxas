    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r4, %r3, 1;
    min.u32 %r22, %r3, 65536;
    setp.ne.s32 %p4, %r4, 0;
    @!%p4 min.u32 %r27, %r22, 2147483647;
    mul.wide.u32 %rd10, %r4, %r4;
    mad.lo.s32 %r19, %r27, %r4, %r3;
    mul.lo.s32 %r13, %r19, %r19;
    cvt.u32.u64 %r26, %rd10;
    xor.b64 %rd5, %rd10, %rd10;
    shr.u32 %r14, %r19, 7;
    mul.wide.u32 %rd10, %r27, %r14;
    or.b32 %r23, %r26, %r14;
    xor.b64 %rd14, %rd10, %rd10;
    shr.u64 %rd13, %rd10, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
