.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    add.s32 %r15, %r3, %r3;
    shl.b64 %rd11, %rd13, 16;
    sub.u32 %r10, %r3, %r15;
    min.s32 %r24, %r3, 1;
    sub.u32 %r9, %r15, %r24;
    sub.s32 %r20, %r9, 5;
    add.s32 %r18, %r9, %r9;
    sub.u32 %r18, %r10, 3;
    mad.lo.u32 %r5, %r20, %r20, %r9;
    cvt.u32.u64 %r17, %rd11;
    sub.s32 %r10, %r24, 4;
    shl.b32 %r25, %r20, 1;
    shr.u32 %r25, %r24, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
