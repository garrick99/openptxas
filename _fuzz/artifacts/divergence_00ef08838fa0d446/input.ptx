.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    sub.u64 %rd5, %rd14, %rd14;
    mul.lo.u32 %r25, %r3, %r3;
    shr.s32 %r20, %r3, 30;
    and.b64 %rd13, %rd5, %rd14;
    shl.b64 %rd11, %rd14, 30;
    shl.b32 %r25, %r3, 2;
    shr.u32 %r10, %r20, 16;
    cvt.u32.u64 %r10, %rd14;
    sub.u32 %r7, %r10, 64;
    xor.b32 %r14, %r7, 64;
    mul.lo.s32 %r15, %r20, %r20;
    shr.s64 %rd10, %rd5, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
