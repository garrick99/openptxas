.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r27, %r3, 7;
    max.u32 %r19, %r27, 4;
    cvt.s64.s32 %rd14, %r19;
    max.u32 %r14, %r19, %r27;
    shl.b32 %r22, %r27, 15;
    max.s32 %r20, %r22, 255;
    max.u32 %r14, %r14, %r22;
    setp.ge.u32 %p3, %r20, %r20;
    @!%p3 shr.u32 %r24, %r22, 4;
    shr.u64 %rd7, %rd14, 2;
    sub.s32 %r16, %r19, %r24;
    selp.b32 %r27, %r19, %r3, %p3;
    and.b32 %r14, %r22, %r14;
    shr.u32 %r9, %r24, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
