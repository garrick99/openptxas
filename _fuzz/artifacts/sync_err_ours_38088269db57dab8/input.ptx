.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r22, %r3, %r3;
    shl.b32 %r7, %r3, 4;
    add.s32 %r14, %r7, 2147483648;
    setp.lt.u32 %p2, %r22, 32;
    setp.ge.s32 %p1, %r3, 63;
    setp.hs.u32 %p1, %r22, %r22;
    mad.lo.u32 %r11, %r7, %r7, %r7;
    mul.lo.s32 %r6, %r7, %r11;
    setp.ne.u32 %p4, %r22, %r14;
    @%p4 add.s32 %r20, %r11, 2147483648;
    sub.u32 %r12, %r11, 3;
    max.u32 %r18, %r6, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
