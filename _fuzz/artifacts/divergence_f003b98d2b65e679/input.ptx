.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    mul.lo.s32 %r8, %r3, %r3;
    sub.u32 %r4, %r8, %r3;
    or.b64 %rd11, %rd12, %rd12;
    sub.u32 %r10, %r3, 2;
    max.s32 %r4, %r4, 65535;
    cvt.u64.u32 %rd6, %r8;
    mul.lo.s32 %r20, %r4, %r8;
    shr.u32 %r16, %r4, 1;
    shr.s64 %rd8, %rd12, 7;
    mad.lo.s32 %r7, %r20, %r8, %r16;
    cvt.s32.s64 %r16, %rd11;
    or.b32 %r21, %r8, %r8;
    min.u32 %r9, %r7, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
