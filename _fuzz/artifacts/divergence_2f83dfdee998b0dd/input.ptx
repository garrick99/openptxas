.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r8, %r3, %r3;
    cvt.u64.u32 %rd5, %r3;
    mul.lo.u32 %r4, %r8, 4;
    mul.lo.u32 %r17, %r8, %r4;
    min.u64 %rd9, %rd5, %rd5;
    min.s32 %r24, %r8, %r3;
    add.s32 %r17, %r3, %r4;
    mad.lo.u32 %r11, %r8, %r24, %r3;
    shl.b64 %rd5, %rd9, 16;
    and.b32 %r26, %r4, 255;
    max.u32 %r18, %r3, 5;
    min.s32 %r15, %r8, 256;
    shr.s64 %rd7, %rd9, 1;
    cvt.u32.u64 %r16, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
