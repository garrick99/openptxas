.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r23, %r3, 65535;
    mul.lo.u32 %r5, %r3, 2147483648;
    cvt.s64.s32 %rd13, %r5;
    or.b32 %r6, %r23, %r3;
    and.b32 %r24, %r3, %r3;
    add.s32 %r8, %r6, %r6;
    max.s32 %r20, %r24, 2;
    cvt.s32.s64 %r14, %rd13;
    max.u32 %r21, %r14, %r14;
    mul.lo.s32 %r12, %r5, %r14;
    cvt.s32.s64 %r25, %rd13;
    shl.b64 %rd10, %rd13, 0;
    max.u32 %r16, %r8, %r3;
    max.u32 %r16, %r12, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
