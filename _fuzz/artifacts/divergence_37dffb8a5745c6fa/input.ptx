.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    add.s64 %rd9, %rd14, %rd14;
    cvt.s32.s64 %r7, %rd14;
    shr.u64 %rd12, %rd9, 62;
    or.b32 %r23, %r7, 0;
    cvt.u32.u64 %r23, %rd14;
    setp.ge.s32 %p2, %r7, %r3;
    @!%p2 or.b32 %r12, %r23, %r7;
    selp.b32 %r27, %r23, %r12, %p2;
    sub.u64 %rd7, %rd14, %rd14;
    and.b32 %r19, %r3, %r12;
    shr.s32 %r12, %r3, 0;
    shr.s32 %r11, %r27, 3;
    min.u32 %r4, %r23, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
