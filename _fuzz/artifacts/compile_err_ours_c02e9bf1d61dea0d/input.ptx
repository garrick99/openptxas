.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p2, %r3, %r0;
    vote.sync.ballot.b32 %r10, %p2, -1;
    and.b32 %r16, %r10, %r0;
    shfl.sync.idx.b32 %r17, %r16, 31, 0x1f, -1;
    shfl.sync.idx.b32 %r4, %r0, 15, 0x1f, -1;
    and.b32 %r13, %r16, %r0;
    sub.u32 %r11, %r4, %r3;
    add.u32 %r15, %r11, %r17;
    vote.sync.any.pred %p1, %p2, -1;
    and.b32 %r5, %r0, %r0;
    sub.u32 %r13, %r17, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
