.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    cvt.u64.u32 %rd9, %r3;
    cvt.u32.u64 %r21, %rd9;
    add.u32 %r24, %r3, %r3;
    xor.b32 %r11, %r3, %r3;
    shl.b64 %rd7, %rd9, 7;
    setp.eq.u32 %p3, %r24, %r24;
    @%p3 mul.lo.u32 %r23, %r24, 65535;
    setp.ge.s32 %p2, %r21, 255;
    add.u32 %r10, %r3, 256;
    min.u32 %r8, %r11, 256;
    cvt.s64.s32 %rd13, %r8;
    max.s32 %r4, %r11, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
