.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd14, %r3, %r3;
    sub.s32 %r25, %r3, 65535;
    cvt.u32.u64 %r9, %rd14;
    cvt.s32.s64 %r23, %rd14;
    mad.lo.s32 %r24, %r25, %r25, %r25;
    cvt.u64.u32 %rd9, %r25;
    add.u32 %r7, %r24, %r9;
    add.s32 %r21, %r7, %r7;
    sub.u32 %r19, %r24, 65535;
    setp.ne.u32 %p2, %r24, 1;
    or.b32 %r4, %r25, %r21;
    setp.ne.s32 %p1, %r9, %r4;
    @%p1 add.u32 %r4, %r9, 4;
    add.s32 %r20, %r7, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
