.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p2, %r3, %r3;
    @!%p2 mul.wide.u32 %rd14, %r3, %r3;
    mul.lo.s64 %rd14, %rd14, %rd14;
    cvt.u32.u64 %r19, %rd14;
    cvt.u64.u32 %rd14, %r19;
    shl.b64 %rd9, %rd14, 7;
    setp.ne.u32 %p4, %r3, 256;
    @%p4 min.u32 %r6, %r19, 2;
    selp.b32 %r14, %r3, %r6, %p4;
    add.u64 %rd11, %rd9, %rd14;
    mul.lo.s32 %r26, %r19, %r6;
    max.s64 %rd12, %rd11, %rd11;
    sub.s32 %r15, %r6, 255;
    max.s64 %rd8, %rd14, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
