.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p2, %r3, %r3;
    @%p2 mad.lo.u32 %r6, %r3, %r3, %r3;
    sub.s32 %r11, %r6, %r3;
    and.b32 %r20, %r3, 0;
    min.s32 %r18, %r3, 63;
    mad.lo.u32 %r24, %r6, %r6, %r6;
    sub.s32 %r26, %r18, %r3;
    add.u32 %r16, %r6, %r24;
    min.u32 %r21, %r11, %r20;
    cvt.u64.u32 %rd9, %r6;
    cvt.u32.u64 %r14, %rd9;
    max.u32 %r14, %r26, %r20;
    or.b32 %r5, %r16, %r20;
    shl.b64 %rd11, %rd9, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
