.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r20, %r3, 4294967295;
    setp.lo.u32 %p3, %r3, 32;
    @%p3 mul.wide.s32 %rd10, %r20, %r3;
    shr.u32 %r22, %r20, 31;
    sub.s32 %r16, %r20, 255;
    cvt.s64.s32 %rd8, %r16;
    min.s32 %r24, %r20, %r22;
    shl.b64 %rd9, %rd8, 16;
    or.b32 %r13, %r24, %r16;
    shr.s32 %r22, %r22, 15;
    mad.lo.u32 %r17, %r16, %r22, %r20;
    setp.lt.u32 %p2, %r3, 256;
    @%p2 max.s32 %r5, %r22, 65535;
    add.u32 %r17, %r16, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
