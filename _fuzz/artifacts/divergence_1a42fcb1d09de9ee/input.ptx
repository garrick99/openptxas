.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    cvt.u32.u64 %r21, %rd15;
    mul.lo.s64 %rd6, %rd15, %rd15;
    mad.lo.s32 %r11, %r3, %r21, %r21;
    shl.b32 %r14, %r11, 15;
    mul.wide.u32 %rd9, %r11, %r14;
    mul.wide.u32 %rd15, %r11, %r3;
    min.u32 %r15, %r11, %r14;
    and.b32 %r4, %r11, %r15;
    cvt.u64.u32 %rd10, %r15;
    mul.lo.s32 %r21, %r11, 32;
    setp.ne.s32 %p3, %r4, %r15;
    @!%p3 mul.lo.u32 %r23, %r14, %r4;
    or.b32 %r5, %r14, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
