.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r25, %r3, 3;
    add.s32 %r6, %r25, 32;
    shr.s32 %r23, %r6, 3;
    setp.le.u32 %p2, %r25, %r3;
    @!%p2 mul.wide.u32 %rd5, %r23, %r25;
    shr.u32 %r7, %r6, 16;
    shr.s32 %r12, %r3, 3;
    shl.b32 %r17, %r25, 1;
    cvt.s64.s32 %rd7, %r17;
    min.s32 %r9, %r3, 4294967295;
    shr.u32 %r20, %r9, 15;
    mad.lo.u32 %r16, %r23, %r9, %r7;
    mad.lo.s32 %r20, %r20, %r3, %r3;
    selp.b32 %r13, %r25, %r3, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
