.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r4, %r3, %r3;
    cvt.u64.u32 %rd13, %r3;
    mul.wide.s32 %rd14, %r3, %r3;
    xor.b32 %r26, %r4, 31;
    shr.s32 %r25, %r26, 15;
    mul.wide.s32 %rd7, %r3, %r4;
    mad.lo.s32 %r12, %r3, %r26, %r26;
    shr.u32 %r17, %r4, 2;
    mad.lo.s32 %r23, %r17, %r17, %r25;
    cvt.s32.s64 %r27, %rd7;
    min.u64 %rd13, %rd13, %rd14;
    mad.lo.u32 %r9, %r26, %r27, %r25;
    mad.lo.s32 %r13, %r23, %r25, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
