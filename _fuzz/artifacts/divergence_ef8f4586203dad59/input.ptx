.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r9, %r3, 255;
    or.b32 %r14, %r3, %r9;
    shr.u32 %r20, %r3, 1;
    cvt.s64.s32 %rd14, %r20;
    cvt.u32.u64 %r12, %rd14;
    shl.b32 %r22, %r9, 0;
    shl.b64 %rd8, %rd14, 30;
    shl.b32 %r15, %r3, 16;
    or.b32 %r22, %r9, %r3;
    sub.s32 %r17, %r15, %r12;
    cvt.s64.s32 %rd15, %r9;
    mad.lo.s32 %r20, %r9, %r14, %r12;
    max.u32 %r23, %r3, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
