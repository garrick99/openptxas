.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r22, %r3, 4294967295;
    cvt.s64.s32 %rd10, %r22;
    add.s32 %r15, %r22, %r3;
    max.u32 %r9, %r15, %r3;
    max.s32 %r10, %r22, %r3;
    and.b32 %r4, %r9, %r22;
    setp.hi.u32 %p1, %r3, 31;
    @!%p1 max.u32 %r11, %r22, %r3;
    setp.hi.u32 %p1, %r10, %r9;
    @%p1 shl.b32 %r18, %r11, 4;
    xor.b32 %r6, %r10, %r4;
    shr.u64 %rd7, %rd10, 30;
    add.s64 %rd10, %rd7, %rd7;
    min.u32 %r25, %r10, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
