.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p3, %r3, %r3;
    @%p3 mul.lo.s32 %r7, %r3, 255;
    and.b32 %r23, %r3, 31;
    add.s32 %r22, %r7, 32;
    mul.lo.u32 %r25, %r22, %r3;
    and.b32 %r19, %r25, 256;
    mul.wide.u32 %rd11, %r19, %r19;
    xor.b32 %r26, %r19, %r23;
    add.u32 %r15, %r19, 1;
    shl.b64 %rd7, %rd11, 47;
    cvt.s32.s64 %r27, %rd11;
    mul.wide.u32 %rd14, %r7, %r25;
    selp.b32 %r10, %r19, %r7, %p3;
    add.u32 %r15, %r7, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
