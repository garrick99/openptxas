.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r14, %r3, %r3;
    mad.lo.u32 %r21, %r3, %r14, %r14;
    mul.wide.u32 %rd15, %r14, %r21;
    or.b32 %r14, %r3, 65536;
    shr.u64 %rd8, %rd15, 1;
    or.b32 %r17, %r14, %r3;
    min.s32 %r26, %r21, %r21;
    cvt.s32.s64 %r11, %rd15;
    mad.lo.u32 %r22, %r26, %r11, %r17;
    max.s32 %r4, %r11, %r3;
    setp.hi.u32 %p4, %r11, 8;
    setp.ge.u32 %p1, %r11, %r17;
    @%p1 min.u32 %r12, %r14, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
