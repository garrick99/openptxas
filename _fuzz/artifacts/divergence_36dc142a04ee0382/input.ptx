.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r17, %r3, %r3;
    cvt.s64.s32 %rd9, %r17;
    setp.gt.u32 %p4, %r3, 16;
    @%p4 mad.lo.u32 %r10, %r3, %r3, %r3;
    setp.lt.s32 %p3, %r17, 63;
    shr.s64 %rd7, %rd9, 47;
    selp.b32 %r23, %r10, %r10, %p3;
    setp.hs.u32 %p3, %r23, 65536;
    @%p3 mul.lo.s32 %r26, %r23, 5;
    shr.s64 %rd15, %rd7, 1;
    min.s32 %r5, %r26, %r26;
    xor.b32 %r25, %r23, 65536;
    mul.wide.u32 %rd8, %r5, %r3;
    and.b32 %r13, %r26, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
