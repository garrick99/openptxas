.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r4, %r3, 32;
    cvt.s64.s32 %rd7, %r4;
    sub.u64 %rd13, %rd7, %rd7;
    xor.b32 %r15, %r4, 5;
    mad.lo.u32 %r21, %r15, %r15, %r3;
    shl.b64 %rd15, %rd13, 16;
    min.u64 %rd7, %rd15, %rd15;
    mul.lo.s32 %r9, %r4, 2147483648;
    setp.hs.u32 %p4, %r4, 2147483647;
    @!%p4 shr.s32 %r19, %r3, 7;
    mad.lo.u32 %r16, %r3, %r19, %r19;
    setp.le.u32 %p1, %r21, %r21;
    @%p1 min.u32 %r14, %r3, %r19;
    mul.lo.u32 %r17, %r21, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
