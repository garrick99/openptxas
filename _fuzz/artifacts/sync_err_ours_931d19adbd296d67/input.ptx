.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r18, %r3, 5;
    mul.lo.s32 %r11, %r18, %r18;
    mad.lo.u32 %r24, %r3, %r3, %r11;
    min.s32 %r5, %r11, %r24;
    cvt.u64.u32 %rd9, %r11;
    setp.ge.s32 %p2, %r18, %r5;
    @!%p2 add.u32 %r8, %r5, %r18;
    mad.lo.s32 %r20, %r8, %r24, %r11;
    selp.b32 %r21, %r24, %r11, %p2;
    or.b64 %rd6, %rd9, %rd9;
    mad.lo.s32 %r22, %r18, %r21, %r8;
    cvt.s64.s32 %rd13, %r5;
    sub.s32 %r22, %r5, %r21;
    and.b32 %r5, %r20, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
