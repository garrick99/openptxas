.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    sub.u32 %r23, %r3, 5;
    shr.s32 %r8, %r23, 7;
    min.s64 %rd8, %rd9, %rd9;
    xor.b32 %r15, %r3, %r8;
    cvt.u64.u32 %rd9, %r8;
    cvt.s64.s32 %rd10, %r3;
    shr.u64 %rd7, %rd8, 2;
    shr.s32 %r17, %r8, 0;
    cvt.s64.s32 %rd7, %r15;
    shl.b32 %r18, %r23, 15;
    max.s32 %r24, %r8, %r18;
    shl.b32 %r20, %r24, 0;
    or.b64 %rd7, %rd10, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
