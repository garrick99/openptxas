.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    setp.gt.u32 %p3, %r3, 16;
    @%p3 selp.b32 %r13, %r3, %r3, %p3;
    sub.u32 %r12, %r13, %r13;
    shr.s32 %r27, %r13, 2;
    setp.ge.s32 %p3, %r3, %r27;
    max.u64 %rd8, %rd9, %rd9;
    or.b64 %rd6, %rd9, %rd8;
    or.b32 %r24, %r27, 2;
    add.s32 %r9, %r24, %r12;
    mul.wide.u32 %rd8, %r27, %r9;
    or.b32 %r22, %r27, %r24;
    shl.b64 %rd7, %rd9, 47;
    shr.s32 %r20, %r27, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
