.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r12, %r3, 3;
    bfi.b32 %r14, %r12, %r12, 0, 32;
    brev.b32 %r21, %r12;
    popc.b32 %r9, %r21;
    bfe.u32 %r12, %r21, 8, 1;
    bfi.b32 %r15, %r9, %r3, 24, 7;
    clz.b32 %r5, %r9;
    brev.b32 %r7, %r21;
    bfe.s32 %r16, %r12, 16, 1;
    bfi.b32 %r7, %r12, %r15, 8, 1;
    min.u32 %r21, %r5, 0;
    bfi.b32 %r13, %r21, %r15, 23, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
