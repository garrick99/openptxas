.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r25, %r3, %r3;
    cvt.s64.s32 %rd5, %r3;
    min.u32 %r13, %r3, 15;
    shr.s64 %rd15, %rd5, 7;
    mul.lo.s32 %r23, %r13, 8;
    min.s32 %r12, %r13, 65536;
    xor.b32 %r13, %r25, %r12;
    max.s32 %r8, %r13, %r12;
    setp.hs.u32 %p3, %r23, %r12;
    @!%p3 shl.b32 %r14, %r8, 16;
    shr.s64 %rd11, %rd15, 48;
    cvt.s64.s32 %rd7, %r3;
    max.u32 %r11, %r12, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
