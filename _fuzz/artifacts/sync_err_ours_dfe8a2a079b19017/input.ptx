.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r23, %r3, 7;
    shr.s32 %r27, %r23, 15;
    xor.b32 %r17, %r27, 31;
    mad.lo.u32 %r12, %r23, %r3, %r23;
    mad.lo.u32 %r22, %r23, %r17, %r17;
    cvt.u64.u32 %rd14, %r17;
    sub.u32 %r26, %r22, 256;
    add.s32 %r20, %r3, %r22;
    mul.wide.u32 %rd8, %r23, %r12;
    min.u32 %r11, %r20, %r22;
    add.u32 %r8, %r17, 65535;
    mad.lo.u32 %r19, %r20, %r17, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
