.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r11, %r3, 255;
    mad.lo.u32 %r24, %r11, %r11, %r3;
    min.u32 %r10, %r3, %r11;
    max.u32 %r24, %r10, 7;
    mul.wide.s32 %rd5, %r11, %r10;
    mul.wide.s32 %rd14, %r10, %r24;
    or.b64 %rd15, %rd5, %rd5;
    min.s32 %r5, %r3, %r11;
    xor.b32 %r13, %r24, 16;
    xor.b32 %r19, %r13, %r24;
    shr.s32 %r27, %r24, 2;
    min.u32 %r17, %r27, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
