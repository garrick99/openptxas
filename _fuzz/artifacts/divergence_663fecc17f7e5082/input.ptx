.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd6, %r3, %r3;
    shl.b32 %r6, %r3, 3;
    setp.eq.s32 %p4, %r3, 65536;
    @%p4 min.u32 %r19, %r3, 1;
    setp.hs.u32 %p1, %r6, 32;
    @%p1 and.b32 %r21, %r6, 3;
    or.b32 %r7, %r21, %r3;
    mul.lo.u64 %rd15, %rd6, %rd6;
    shr.u64 %rd14, %rd6, 2;
    sub.s64 %rd14, %rd15, %rd14;
    selp.b32 %r7, %r19, %r21, %p4;
    cvt.u32.u64 %r27, %rd14;
    xor.b32 %r10, %r19, %r27;
    and.b32 %r4, %r10, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
