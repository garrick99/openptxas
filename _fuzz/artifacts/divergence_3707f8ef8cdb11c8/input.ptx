.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd7, %r3, %r3;
    max.s32 %r10, %r3, 1;
    shr.s64 %rd14, %rd7, 32;
    cvt.u32.u64 %r20, %rd7;
    setp.gt.u32 %p2, %r3, %r10;
    add.s32 %r17, %r10, 65535;
    setp.eq.u32 %p3, %r3, 32;
    @%p3 or.b32 %r23, %r10, 4294967295;
    mul.lo.s32 %r25, %r10, %r20;
    mul.lo.s64 %rd7, %rd7, %rd14;
    max.s32 %r26, %r20, 63;
    mul.lo.s32 %r23, %r3, 2147483647;
    setp.le.s32 %p2, %r20, %r17;
    @%p2 shl.b32 %r7, %r23, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
