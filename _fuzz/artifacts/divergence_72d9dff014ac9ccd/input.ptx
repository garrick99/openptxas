.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.down.b32 %r14, %r0, 4, 0x1f, -1;
    shfl.sync.up.b32 %r14, %r3, 16, 0x1f, -1;
    xor.b32 %r9, %r14, %r3;
    shfl.sync.idx.b32 %r4, %r9, 31, 0x1f, -1;
    shfl.sync.up.b32 %r18, %r4, 1, 0x1f, -1;
    setp.ge.u32 %p2, %r0, 15;
    vote.sync.ballot.b32 %r8, %p2, -1;
    or.b32 %r8, %r3, %r9;
    shfl.sync.up.b32 %r6, %r3, 16, 0x1f, -1;
    setp.gt.u32 %p1, %r3, %r4;
    vote.sync.ballot.b32 %r16, %p1, -1;
    setp.ne.u32 %p3, %r0, 255;
    vote.sync.ballot.b32 %r17, %p3, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
