.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r12, %r3, 0;
    max.u32 %r15, %r12, %r3;
    shl.b32 %r22, %r15, 2;
    and.b32 %r8, %r12, 65535;
    cvt.s64.s32 %rd14, %r22;
    setp.ne.s32 %p4, %r15, %r12;
    @%p4 max.u32 %r17, %r8, %r3;
    min.u32 %r26, %r17, 8;
    max.u32 %r22, %r17, 32;
    min.s64 %rd15, %rd14, %rd14;
    mul.lo.s32 %r27, %r15, 65535;
    mul.lo.u32 %r18, %r22, 0;
    sub.u64 %rd13, %rd14, %rd15;
    or.b32 %r12, %r8, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
