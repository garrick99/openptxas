.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd7, %r3, %r3;
    setp.ne.s32 %p2, %r3, 255;
    min.u32 %r16, %r3, 255;
    cvt.s32.s64 %r24, %rd7;
    xor.b64 %rd12, %rd7, %rd7;
    shl.b32 %r23, %r3, 4;
    cvt.s32.s64 %r12, %rd12;
    shr.u32 %r17, %r12, 4;
    shl.b32 %r17, %r24, 1;
    shr.u64 %rd5, %rd12, 32;
    or.b32 %r4, %r12, 15;
    shr.u32 %r23, %r16, 2;
    xor.b32 %r23, %r3, %r24;
    sub.s32 %r12, %r23, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
