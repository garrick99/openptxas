.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.bfly.b32 %r15, %r3, 1, 0x1f, -1;
    setp.lt.u32 %p3, %r3, 255;
    vote.sync.ballot.b32 %r9, %p3, -1;
    shfl.sync.bfly.b32 %r7, %r15, 4, 0x1f, -1;
    vote.sync.any.pred %p3, %p3, -1;
    shfl.sync.bfly.b32 %r14, %r7, 16, 0x1f, -1;
    setp.ne.u32 %p2, %r9, 4294967295;
    vote.sync.ballot.b32 %r14, %p2, -1;
    sub.u32 %r9, %r14, %r7;
    add.u32 %r15, %r14, %r14;
    shfl.sync.bfly.b32 %r17, %r7, 16, 0x1f, -1;
    max.u32 %r5, %r7, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
