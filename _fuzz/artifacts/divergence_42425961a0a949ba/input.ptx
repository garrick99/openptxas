.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    shl.b64 %rd10, %rd8, 63;
    mad.lo.s32 %r4, %r3, %r3, %r3;
    cvt.s64.s32 %rd8, %r3;
    shr.u32 %r7, %r4, 16;
    or.b32 %r19, %r7, %r4;
    add.s32 %r24, %r7, 7;
    sub.s32 %r5, %r7, %r19;
    shl.b64 %rd14, %rd10, 30;
    shl.b32 %r17, %r3, 3;
    setp.gt.u32 %p3, %r3, %r4;
    @!%p3 min.s32 %r19, %r4, %r4;
    cvt.s64.s32 %rd10, %r17;
    max.s32 %r17, %r24, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
