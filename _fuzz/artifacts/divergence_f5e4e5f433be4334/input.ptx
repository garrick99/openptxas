.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    setp.ne.s32 %p1, %r3, 3;
    @%p1 mul.wide.u32 %rd6, %r3, %r3;
    setp.gt.u32 %p2, %r3, 8;
    @%p2 add.s32 %r9, %r3, 4294967295;
    cvt.s32.s64 %r11, %rd6;
    shr.s32 %r23, %r3, 0;
    cvt.s32.s64 %r7, %rd6;
    shr.u64 %rd15, %rd10, 63;
    shl.b32 %r7, %r3, 2;
    setp.ge.u32 %p1, %r7, 65535;
    @!%p1 selp.b32 %r24, %r3, %r23, %p1;
    mul.lo.s32 %r7, %r7, %r23;
    add.s32 %r21, %r7, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
