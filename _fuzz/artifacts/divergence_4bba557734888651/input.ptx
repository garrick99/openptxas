.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r15, %r3, 2147483647;
    setp.hs.u32 %p4, %r15, 63;
    @%p4 shr.s32 %r25, %r3, 15;
    mad.lo.u32 %r11, %r3, %r25, %r3;
    cvt.s64.s32 %rd12, %r11;
    max.s32 %r20, %r25, %r25;
    selp.b32 %r5, %r3, %r20, %p4;
    shl.b64 %rd5, %rd12, 15;
    mul.wide.u32 %rd6, %r3, %r25;
    add.u32 %r16, %r20, %r3;
    sub.u64 %rd6, %rd6, %rd6;
    mad.lo.s32 %r4, %r16, %r20, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
