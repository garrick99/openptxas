.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r24, %r3, %r3;
    min.s32 %r27, %r24, 31;
    add.u32 %r8, %r27, 64;
    min.u32 %r21, %r3, 32;
    mul.wide.u32 %rd11, %r24, %r24;
    mul.lo.u32 %r6, %r21, %r8;
    cvt.s32.s64 %r10, %rd11;
    shr.s64 %rd7, %rd11, 2;
    mad.lo.s32 %r8, %r3, %r10, %r10;
    sub.s32 %r4, %r24, %r8;
    cvt.u64.u32 %rd15, %r10;
    xor.b32 %r18, %r21, 15;
    shr.s32 %r9, %r6, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
