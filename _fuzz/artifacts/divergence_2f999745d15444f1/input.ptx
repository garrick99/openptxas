.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r19, %r3, 30;
    cvt.u64.u32 %rd12, %r3;
    min.u32 %r9, %r3, %r3;
    shl.b64 %rd12, %rd12, 30;
    max.s32 %r13, %r3, %r9;
    mad.lo.s32 %r9, %r13, %r19, %r19;
    sub.s32 %r11, %r19, %r3;
    min.u32 %r25, %r11, 15;
    setp.le.s32 %p3, %r11, %r25;
    mul.lo.s32 %r22, %r19, %r25;
    min.u32 %r7, %r22, %r13;
    mul.lo.u64 %rd9, %rd12, %rd12;
    setp.ne.s32 %p2, %r13, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
