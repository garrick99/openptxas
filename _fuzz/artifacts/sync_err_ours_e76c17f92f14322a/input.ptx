.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p3, %r3, %r3;
    @!%p3 selp.b32 %r24, %r3, %r3, %p3;
    and.b32 %r25, %r3, 16;
    setp.eq.u32 %p3, %r24, 2147483648;
    sub.u32 %r11, %r3, %r25;
    mad.lo.u32 %r20, %r25, %r25, %r25;
    cvt.s64.s32 %rd12, %r24;
    mad.lo.s32 %r21, %r24, %r24, %r20;
    shr.s32 %r16, %r20, 2;
    selp.b32 %r4, %r16, %r20, %p3;
    xor.b32 %r26, %r11, %r24;
    min.s64 %rd9, %rd12, %rd12;
    mul.lo.u32 %r10, %r16, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
