.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd12, %r3, %r3;
    add.s32 %r8, %r3, %r3;
    or.b64 %rd8, %rd12, %rd12;
    xor.b32 %r6, %r8, %r8;
    min.u32 %r7, %r3, 4294967295;
    shl.b32 %r19, %r8, 7;
    mad.lo.u32 %r17, %r3, %r8, %r3;
    max.u32 %r12, %r19, %r17;
    shr.s64 %rd14, %rd8, 62;
    min.u32 %r25, %r3, 64;
    mad.lo.s32 %r5, %r25, %r12, %r12;
    mul.wide.s32 %rd6, %r8, %r12;
    setp.hi.u32 %p1, %r7, 0;
    @%p1 mad.lo.s32 %r24, %r6, %r12, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
