.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r17, %r3, 16;
    setp.le.s32 %p1, %r3, %r3;
    cvt.s64.s32 %rd14, %r3;
    shl.b32 %r11, %r17, 7;
    selp.b32 %r4, %r3, %r17, %p1;
    shr.u64 %rd14, %rd14, 30;
    mad.lo.u32 %r17, %r17, %r17, %r4;
    shr.s64 %rd13, %rd14, 3;
    selp.b32 %r6, %r11, %r4, %p1;
    add.u32 %r20, %r4, 65535;
    and.b32 %r23, %r3, %r11;
    selp.b32 %r9, %r20, %r6, %p1;
    or.b32 %r26, %r20, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
