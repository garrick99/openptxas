.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r23, %r3, 8;
    max.u32 %r25, %r23, %r3;
    shr.s32 %r11, %r3, 4;
    or.b32 %r16, %r23, %r11;
    mad.lo.u32 %r22, %r11, %r16, %r11;
    add.s32 %r10, %r16, %r16;
    mul.wide.s32 %rd5, %r10, %r22;
    setp.gt.s32 %p4, %r3, 63;
    @%p4 cvt.s32.s64 %r18, %rd5;
    mad.lo.s32 %r8, %r22, %r3, %r22;
    mul.lo.s32 %r6, %r23, 0;
    max.s32 %r13, %r3, 65536;
    setp.gt.u32 %p3, %r16, 2147483648;
    @%p3 cvt.s64.s32 %rd8, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
