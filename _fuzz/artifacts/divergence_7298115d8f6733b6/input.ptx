.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r4, %r3, %r3;
    and.b32 %r7, %r4, %r4;
    cvt.u64.u32 %rd12, %r3;
    mad.lo.s32 %r6, %r7, %r3, %r3;
    sub.u32 %r18, %r3, 256;
    setp.ge.s32 %p3, %r7, 4;
    @%p3 shr.s64 %rd11, %rd12, 63;
    max.u32 %r27, %r7, %r6;
    max.u32 %r17, %r3, 256;
    min.u32 %r24, %r18, %r6;
    shr.u32 %r21, %r3, 7;
    sub.u32 %r6, %r21, %r18;
    max.s32 %r24, %r18, 2147483647;
    max.u64 %rd12, %rd11, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
