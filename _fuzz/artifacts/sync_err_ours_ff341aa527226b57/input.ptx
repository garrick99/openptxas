.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r19, %r3, 4;
    mul.lo.s32 %r24, %r3, %r3;
    mad.lo.u32 %r8, %r24, %r19, %r24;
    cvt.u64.u32 %rd13, %r24;
    mul.wide.s32 %rd8, %r19, %r19;
    cvt.s64.s32 %rd7, %r19;
    setp.ge.s32 %p4, %r8, 4;
    shr.u32 %r16, %r19, 16;
    min.u32 %r20, %r8, 3;
    xor.b32 %r14, %r20, %r8;
    min.u64 %rd7, %rd7, %rd8;
    shr.s64 %rd6, %rd8, 0;
    or.b32 %r20, %r14, 2147483648;
    shl.b32 %r17, %r20, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
