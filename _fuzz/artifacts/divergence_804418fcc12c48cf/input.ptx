.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    mad.lo.s32 %r21, %r3, %r3, %r3;
    mad.lo.s32 %r18, %r21, %r3, %r3;
    max.s32 %r25, %r21, %r18;
    min.u64 %rd10, %rd8, %rd8;
    shr.s64 %rd7, %rd10, 4;
    cvt.u64.u32 %rd8, %r3;
    shl.b64 %rd12, %rd10, 2;
    add.u64 %rd14, %rd10, %rd10;
    and.b32 %r7, %r21, 256;
    shr.u64 %rd7, %rd10, 47;
    cvt.s32.s64 %r11, %rd12;
    shr.u64 %rd6, %rd8, 33;
    mul.wide.u32 %rd5, %r21, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
