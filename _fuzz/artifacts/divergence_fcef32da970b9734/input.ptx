.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    mul.lo.s64 %rd7, %rd5, %rd5;
    sub.s32 %r9, %r3, %r3;
    xor.b32 %r17, %r3, 3;
    shl.b32 %r11, %r17, 31;
    shr.s64 %rd13, %rd7, 7;
    min.u32 %r26, %r3, %r11;
    sub.u32 %r23, %r17, 64;
    cvt.u32.u64 %r17, %rd13;
    mul.lo.s32 %r7, %r3, 32;
    cvt.s64.s32 %rd9, %r9;
    setp.ge.u32 %p2, %r26, %r9;
    @%p2 add.u32 %r20, %r17, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
