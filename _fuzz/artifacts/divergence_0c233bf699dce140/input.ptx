.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r16, %r3, 4;
    max.s32 %r17, %r16, %r3;
    mul.lo.u32 %r20, %r17, %r16;
    setp.gt.u32 %p2, %r20, %r16;
    @%p2 shr.u32 %r17, %r17, 0;
    mul.lo.u32 %r9, %r20, 32;
    sub.u32 %r17, %r17, 1;
    setp.lt.s32 %p2, %r3, 63;
    @%p2 mad.lo.s32 %r17, %r16, %r3, %r20;
    cvt.u64.u32 %rd5, %r9;
    min.s32 %r5, %r20, %r20;
    selp.b32 %r9, %r9, %r20, %p2;
    shr.u64 %rd6, %rd5, 62;
    add.u64 %rd6, %rd6, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
