.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r18, %r3, 3;
    cvt.s64.s32 %rd7, %r18;
    mul.lo.s32 %r24, %r3, %r3;
    and.b32 %r21, %r18, 4294967295;
    mul.lo.u32 %r19, %r24, %r21;
    min.u32 %r15, %r21, 63;
    xor.b32 %r18, %r24, %r18;
    mad.lo.s32 %r15, %r15, %r19, %r24;
    cvt.s64.s32 %rd12, %r19;
    shr.s64 %rd12, %rd7, 0;
    shr.s64 %rd14, %rd12, 16;
    max.s32 %r22, %r15, %r19;
    sub.u64 %rd8, %rd12, %rd7;
    cvt.s64.s32 %rd13, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
