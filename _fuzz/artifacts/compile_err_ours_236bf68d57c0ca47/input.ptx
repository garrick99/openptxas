.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p3, %r0, 3;
    vote.sync.ballot.b32 %r16, %p3, -1;
    add.u32 %r5, %r16, %r16;
    shfl.sync.down.b32 %r8, %r5, 4, 0x1f, -1;
    setp.le.u32 %p2, %r3, %r8;
    vote.sync.ballot.b32 %r17, %p2, -1;
    add.u32 %r11, %r0, %r16;
    add.u32 %r5, %r3, %r16;
    shfl.sync.down.b32 %r18, %r3, 2, 0x1f, -1;
    vote.sync.all.pred %p3, %p3, -1;
    shfl.sync.down.b32 %r6, %r16, 4, 0x1f, -1;
    vote.sync.all.pred %p3, %p2, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
