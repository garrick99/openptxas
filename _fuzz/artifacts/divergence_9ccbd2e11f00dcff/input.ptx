.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p4, %r3, %r3;
    max.u32 %r5, %r3, %r3;
    shr.u32 %r8, %r3, 30;
    shr.u32 %r4, %r8, 4;
    add.u32 %r17, %r8, %r5;
    and.b32 %r16, %r8, %r17;
    and.b32 %r5, %r8, %r5;
    cvt.u64.u32 %rd10, %r4;
    cvt.u32.u64 %r14, %rd10;
    mul.lo.u64 %rd12, %rd10, %rd10;
    cvt.u32.u64 %r27, %rd12;
    add.u32 %r11, %r17, 4;
    cvt.u32.u64 %r8, %rd10;
    selp.b32 %r4, %r5, %r11, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
