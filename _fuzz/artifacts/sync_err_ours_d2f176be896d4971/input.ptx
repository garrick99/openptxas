.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    cvt.s32.s64 %r13, %rd5;
    or.b32 %r4, %r13, %r3;
    and.b32 %r11, %r13, 64;
    shl.b32 %r21, %r4, 15;
    setp.hs.u32 %p3, %r21, 31;
    @!%p3 add.u32 %r4, %r3, 65536;
    shl.b64 %rd13, %rd5, 31;
    setp.gt.s32 %p2, %r11, %r4;
    @!%p2 min.s32 %r16, %r3, %r11;
    cvt.u32.u64 %r26, %rd13;
    xor.b32 %r17, %r13, %r16;
    and.b32 %r20, %r11, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
