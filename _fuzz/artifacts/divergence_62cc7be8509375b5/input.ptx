.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    sub.s32 %r17, %r3, 16;
    mul.wide.u32 %rd8, %r3, %r17;
    and.b64 %rd10, %rd12, %rd8;
    add.s32 %r7, %r17, %r3;
    max.u32 %r6, %r7, 3;
    max.u32 %r24, %r17, %r7;
    min.u32 %r18, %r17, %r17;
    shl.b64 %rd8, %rd10, 47;
    shl.b64 %rd8, %rd10, 62;
    shl.b32 %r7, %r24, 15;
    mul.wide.u32 %rd10, %r17, %r17;
    max.u32 %r11, %r17, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
