.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    mul.lo.u32 %r16, %r3, 0;
    cvt.s64.s32 %rd14, %r16;
    and.b32 %r11, %r3, 255;
    sub.u32 %r20, %r11, 3;
    cvt.s64.s32 %rd14, %r16;
    mul.wide.s32 %rd6, %r20, %r20;
    and.b64 %rd15, %rd14, %rd14;
    and.b32 %r10, %r20, 7;
    add.u32 %r12, %r10, 4;
    add.s32 %r26, %r10, 7;
    setp.ne.s32 %p3, %r20, %r20;
    @%p3 add.s32 %r17, %r20, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
