.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    mul.wide.s32 %rd7, %r3, %r3;
    or.b64 %rd12, %rd6, %rd7;
    setp.gt.s32 %p2, %r3, %r3;
    @%p2 shl.b64 %rd9, %rd7, 15;
    mul.wide.u32 %rd5, %r3, %r3;
    selp.b32 %r10, %r3, %r3, %p2;
    max.s32 %r22, %r3, 4;
    min.u32 %r10, %r22, %r10;
    max.u64 %rd9, %rd9, %rd7;
    cvt.u64.u32 %rd8, %r22;
    cvt.u32.u64 %r12, %rd9;
    and.b32 %r15, %r3, 2147483648;
    setp.ge.s32 %p4, %r10, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
