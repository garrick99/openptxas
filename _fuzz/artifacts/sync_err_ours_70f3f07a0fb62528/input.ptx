.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r26, %r3, 2;
    mad.lo.s32 %r27, %r26, %r26, %r26;
    mad.lo.s32 %r21, %r27, %r3, %r3;
    mul.lo.s32 %r14, %r3, %r3;
    cvt.u64.u32 %rd5, %r26;
    mul.lo.u32 %r24, %r26, %r26;
    shr.u64 %rd5, %rd5, 30;
    sub.s32 %r11, %r27, %r24;
    mul.lo.s32 %r26, %r21, %r27;
    min.u32 %r8, %r11, %r11;
    shr.s64 %rd5, %rd5, 15;
    mad.lo.u32 %r20, %r8, %r24, %r11;
    sub.s32 %r25, %r14, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
