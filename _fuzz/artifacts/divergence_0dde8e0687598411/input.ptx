.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p1, %r3, 15;
    @!%p1 cvt.s64.s32 %rd7, %r3;
    max.s64 %rd15, %rd7, %rd7;
    or.b64 %rd5, %rd7, %rd15;
    max.s32 %r20, %r3, 16;
    cvt.u32.u64 %r20, %rd15;
    mul.wide.s32 %rd8, %r3, %r3;
    max.s32 %r25, %r20, 64;
    shl.b32 %r23, %r25, 16;
    sub.s32 %r4, %r25, %r20;
    mul.wide.u32 %rd6, %r25, %r20;
    setp.eq.s32 %p1, %r4, %r25;
    shl.b32 %r21, %r20, 1;
    cvt.u32.u64 %r22, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
