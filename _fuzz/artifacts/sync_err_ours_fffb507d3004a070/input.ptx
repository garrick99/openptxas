.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r27, %r3, 7;
    min.s32 %r5, %r27, %r3;
    mad.lo.s32 %r12, %r27, %r5, %r5;
    setp.ge.s32 %p1, %r27, %r12;
    @%p1 shr.s32 %r24, %r5, 2;
    shr.s32 %r23, %r24, 2;
    max.s32 %r26, %r27, 31;
    or.b32 %r16, %r3, 5;
    cvt.u64.u32 %rd10, %r23;
    and.b32 %r18, %r26, %r3;
    min.s32 %r19, %r27, %r12;
    mul.lo.u32 %r25, %r18, 15;
    add.u32 %r27, %r27, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
