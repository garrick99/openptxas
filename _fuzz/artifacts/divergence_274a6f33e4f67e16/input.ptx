.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r26, %r3, %r3;
    cvt.s64.s32 %rd15, %r3;
    cvt.s32.s64 %r16, %rd15;
    setp.lo.u32 %p1, %r16, 2;
    @%p1 mul.lo.u32 %r17, %r26, %r3;
    mul.lo.s32 %r18, %r3, %r17;
    min.s32 %r15, %r3, %r3;
    cvt.u64.u32 %rd11, %r17;
    shr.s32 %r8, %r16, 7;
    cvt.u32.u64 %r23, %rd11;
    shr.u32 %r6, %r17, 3;
    shr.u64 %rd14, %rd15, 62;
    mul.wide.u32 %rd13, %r17, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
