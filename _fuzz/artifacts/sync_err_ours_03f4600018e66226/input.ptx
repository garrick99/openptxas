.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r7, %r3, 30;
    shr.s32 %r5, %r3, 16;
    mad.lo.s32 %r27, %r5, %r7, %r3;
    cvt.u64.u32 %rd11, %r3;
    xor.b32 %r10, %r5, %r7;
    add.s32 %r27, %r27, 2;
    add.u32 %r8, %r10, 65536;
    cvt.u32.u64 %r6, %rd11;
    shl.b64 %rd10, %rd11, 16;
    cvt.s32.s64 %r22, %rd10;
    sub.s32 %r26, %r3, %r10;
    mul.wide.u32 %rd14, %r10, %r22;
    mad.lo.u32 %r21, %r7, %r7, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
