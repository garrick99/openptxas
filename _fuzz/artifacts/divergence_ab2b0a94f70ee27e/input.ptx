.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p3, %r3, 0;
    @%p3 shr.u32 %r19, %r3, 16;
    mad.lo.s32 %r14, %r3, %r3, %r19;
    selp.b32 %r22, %r3, %r14, %p3;
    add.s32 %r23, %r19, %r22;
    sub.s32 %r19, %r19, 3;
    shr.s32 %r21, %r19, 7;
    cvt.u64.u32 %rd15, %r22;
    mul.wide.u32 %rd14, %r23, %r22;
    shr.u32 %r24, %r3, 2;
    mul.wide.u32 %rd5, %r23, %r24;
    min.u32 %r22, %r24, %r21;
    mul.lo.u32 %r13, %r14, %r21;
    shr.s64 %rd8, %rd15, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
