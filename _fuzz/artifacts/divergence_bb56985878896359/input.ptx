.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r21, %r3, 7;
    setp.ge.s32 %p4, %r3, 65536;
    @%p4 cvt.s64.s32 %rd9, %r3;
    mul.wide.s32 %rd5, %r21, %r21;
    shr.u32 %r20, %r3, 0;
    selp.b32 %r11, %r20, %r21, %p4;
    cvt.u64.u32 %rd9, %r21;
    max.u32 %r9, %r20, 255;
    or.b32 %r13, %r9, 15;
    and.b32 %r8, %r20, 4294967295;
    mul.lo.s32 %r17, %r13, 65536;
    mul.lo.u32 %r26, %r17, %r9;
    add.s32 %r18, %r3, %r13;
    or.b32 %r7, %r20, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
