.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r8, %r3, %r3, %r3;
    cvt.s64.s32 %rd7, %r8;
    cvt.u64.u32 %rd9, %r8;
    cvt.u32.u64 %r21, %rd9;
    shl.b64 %rd9, %rd9, 48;
    mul.lo.u32 %r18, %r8, %r3;
    mul.lo.s32 %r18, %r21, %r8;
    mul.wide.u32 %rd7, %r21, %r18;
    mul.lo.s32 %r13, %r8, %r8;
    setp.le.s32 %p3, %r13, 63;
    @%p3 shr.s64 %rd10, %rd7, 48;
    cvt.s32.s64 %r9, %rd10;
    mul.lo.u32 %r7, %r9, %r18;
    mul.wide.u32 %rd7, %r18, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
