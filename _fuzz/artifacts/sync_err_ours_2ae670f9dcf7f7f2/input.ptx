.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r6, %r3, 15;
    setp.lt.u32 %p2, %r3, 4;
    add.u32 %r21, %r6, %r6;
    cvt.u64.u32 %rd15, %r6;
    max.u64 %rd15, %rd15, %rd15;
    sub.s32 %r14, %r3, 16;
    setp.lt.s32 %p3, %r6, 16;
    @%p3 mul.lo.u32 %r19, %r3, 3;
    min.u32 %r27, %r19, %r21;
    cvt.u32.u64 %r6, %rd15;
    mul.wide.s32 %rd13, %r3, %r6;
    shl.b64 %rd6, %rd13, 7;
    cvt.s64.s32 %rd11, %r21;
    selp.b32 %r14, %r14, %r19, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
