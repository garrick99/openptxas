.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r27, %r3, %r3;
    setp.ls.u32 %p1, %r3, 63;
    @%p1 mul.lo.u32 %r16, %r27, %r27;
    mul.lo.u32 %r12, %r3, %r27;
    setp.ne.s32 %p1, %r16, 1;
    cvt.u64.u32 %rd14, %r16;
    and.b64 %rd13, %rd14, %rd14;
    mad.lo.s32 %r16, %r12, %r27, %r27;
    mul.lo.s64 %rd14, %rd14, %rd13;
    shr.s32 %r12, %r3, 3;
    sub.u32 %r13, %r3, 15;
    mul.lo.s32 %r18, %r13, %r13;
    shl.b32 %r11, %r16, 1;
    min.s32 %r4, %r16, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
