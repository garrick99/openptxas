.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hi.u32 %p2, %r3, %r3;
    @%p2 cvt.s64.s32 %rd10, %r3;
    selp.b32 %r15, %r3, %r3, %p2;
    add.s32 %r26, %r15, %r15;
    cvt.s32.s64 %r7, %rd10;
    xor.b32 %r9, %r26, %r26;
    and.b32 %r11, %r26, %r26;
    max.u32 %r12, %r11, 65536;
    shr.s32 %r22, %r11, 31;
    xor.b64 %rd6, %rd10, %rd10;
    shl.b64 %rd12, %rd6, 62;
    min.u32 %r10, %r3, %r22;
    max.s64 %rd8, %rd6, %rd6;
    or.b64 %rd10, %rd6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
