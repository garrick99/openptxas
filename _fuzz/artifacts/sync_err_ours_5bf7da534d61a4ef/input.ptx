.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r15, %r3, %r3;
    or.b32 %r18, %r3, 3;
    min.u32 %r25, %r3, 0;
    or.b32 %r22, %r15, %r3;
    add.s32 %r23, %r25, %r18;
    sub.u32 %r10, %r22, 32;
    cvt.s64.s32 %rd7, %r3;
    shr.u64 %rd11, %rd7, 0;
    mul.lo.s32 %r4, %r15, 16;
    cvt.u32.u64 %r18, %rd7;
    setp.le.u32 %p3, %r25, 64;
    @!%p3 shr.u64 %rd8, %rd7, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
