.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r26, %r3, %r3, %r3;
    cvt.u64.u32 %rd7, %r3;
    and.b32 %r7, %r3, 31;
    cvt.u32.u64 %r14, %rd7;
    shr.s64 %rd15, %rd7, 33;
    cvt.u64.u32 %rd15, %r26;
    cvt.s64.s32 %rd5, %r3;
    mad.lo.u32 %r8, %r7, %r14, %r26;
    min.u32 %r5, %r3, 32;
    xor.b32 %r7, %r8, %r7;
    setp.le.u32 %p3, %r8, 5;
    setp.lt.u32 %p2, %r7, %r26;
    @%p2 shr.s32 %r12, %r5, 31;
    setp.lt.s32 %p1, %r26, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
