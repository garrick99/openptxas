.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd10, %r3, %r3;
    setp.ne.s32 %p3, %r3, 3;
    @!%p3 mul.lo.s32 %r5, %r3, 64;
    add.s32 %r20, %r3, 64;
    min.u32 %r21, %r3, %r3;
    cvt.s32.s64 %r15, %rd10;
    and.b32 %r20, %r15, 15;
    xor.b32 %r14, %r20, 65535;
    shl.b64 %rd9, %rd10, 48;
    shr.u64 %rd6, %rd9, 16;
    sub.s32 %r21, %r21, %r5;
    setp.le.u32 %p4, %r5, %r21;
    @%p4 selp.b32 %r25, %r20, %r5, %p4;
    mad.lo.s32 %r24, %r14, %r15, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
