.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r17, %r3, %r3;
    cvt.s64.s32 %rd14, %r17;
    mul.wide.u32 %rd10, %r3, %r17;
    setp.eq.s32 %p2, %r3, %r17;
    @%p2 cvt.u32.u64 %r26, %rd10;
    max.s32 %r10, %r3, 64;
    shr.u32 %r16, %r26, 1;
    shl.b32 %r13, %r26, 0;
    selp.b32 %r22, %r16, %r13, %p2;
    mad.lo.s32 %r25, %r22, %r10, %r17;
    or.b32 %r10, %r17, %r16;
    max.u32 %r24, %r16, %r16;
    setp.gt.u32 %p2, %r3, %r24;
    @%p2 max.s32 %r25, %r24, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
