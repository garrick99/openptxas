.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p2, %r3, 2147483647;
    @!%p2 cvt.u64.u32 %rd12, %r3;
    mul.wide.u32 %rd11, %r3, %r3;
    or.b32 %r17, %r3, %r3;
    and.b32 %r9, %r3, %r17;
    setp.lt.s32 %p4, %r17, %r9;
    @%p4 max.u32 %r12, %r3, %r17;
    setp.ge.s32 %p3, %r9, %r12;
    @!%p3 sub.s32 %r20, %r9, 4294967295;
    min.s32 %r17, %r20, %r12;
    shr.u64 %rd9, %rd12, 4;
    sub.s32 %r22, %r17, 7;
    sub.s32 %r18, %r17, 0;
    cvt.u32.u64 %r13, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
