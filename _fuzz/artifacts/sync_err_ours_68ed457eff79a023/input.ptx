.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    min.u32 %r21, %r3, %r3;
    mad.lo.s32 %r22, %r21, %r21, %r21;
    sub.s64 %rd9, %rd6, %rd6;
    cvt.u64.u32 %rd5, %r22;
    mad.lo.u32 %r4, %r21, %r22, %r21;
    mad.lo.u32 %r15, %r3, %r3, %r4;
    mad.lo.s32 %r11, %r21, %r4, %r15;
    shl.b32 %r20, %r15, 4;
    mad.lo.s32 %r14, %r11, %r4, %r20;
    and.b64 %rd14, %rd9, %rd5;
    add.s64 %rd5, %rd5, %rd6;
    sub.u32 %r8, %r20, %r11;
    shr.s64 %rd13, %rd14, 48;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
