.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r21, %r3, 31;
    shl.b32 %r5, %r3, 0;
    mul.wide.s32 %rd11, %r5, %r5;
    add.u32 %r10, %r21, %r21;
    sub.s32 %r5, %r21, %r10;
    min.u64 %rd6, %rd11, %rd11;
    xor.b32 %r19, %r10, 64;
    sub.u32 %r21, %r19, %r5;
    sub.s32 %r5, %r19, %r5;
    xor.b32 %r15, %r5, 5;
    mul.wide.s32 %rd5, %r5, %r3;
    cvt.s32.s64 %r17, %rd11;
    setp.ge.s32 %p2, %r15, %r17;
    @!%p2 or.b32 %r13, %r3, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
