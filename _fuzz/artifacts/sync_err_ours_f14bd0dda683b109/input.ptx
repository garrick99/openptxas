.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd12, %r3, %r3;
    cvt.s32.s64 %r12, %rd12;
    mul.wide.u32 %rd15, %r3, %r12;
    add.u32 %r24, %r12, %r3;
    min.u32 %r24, %r3, %r24;
    setp.ge.u32 %p2, %r12, %r3;
    @%p2 sub.u32 %r27, %r24, 255;
    selp.b32 %r25, %r27, %r12, %p2;
    mul.lo.u32 %r16, %r24, %r12;
    and.b32 %r21, %r24, %r25;
    and.b64 %rd10, %rd12, %rd12;
    shr.u32 %r18, %r21, 15;
    add.s32 %r14, %r27, %r21;
    shr.s32 %r13, %r18, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
