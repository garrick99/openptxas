.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r8, %r3, 3;
    sub.u32 %r25, %r3, %r3;
    max.s32 %r23, %r3, 7;
    sub.s32 %r27, %r23, 4294967295;
    and.b32 %r5, %r25, %r27;
    cvt.u64.u32 %rd7, %r3;
    mad.lo.s32 %r16, %r27, %r25, %r23;
    sub.s32 %r13, %r16, 15;
    mul.lo.s64 %rd8, %rd7, %rd7;
    mad.lo.u32 %r26, %r27, %r23, %r16;
    xor.b32 %r25, %r23, 32;
    shr.s32 %r9, %r23, 2;
    sub.u64 %rd14, %rd7, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
