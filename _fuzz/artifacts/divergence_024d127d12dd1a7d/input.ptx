.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r20, %r3, 255;
    mul.wide.u32 %rd11, %r20, %r3;
    sub.u32 %r15, %r20, %r20;
    setp.le.s32 %p4, %r20, %r20;
    @%p4 add.u32 %r9, %r20, %r3;
    shr.u32 %r19, %r15, 2;
    min.s32 %r27, %r15, 15;
    selp.b32 %r20, %r3, %r9, %p4;
    mul.wide.u32 %rd14, %r19, %r19;
    min.s32 %r16, %r3, %r3;
    min.u32 %r20, %r19, 65535;
    shr.u32 %r11, %r9, 2;
    setp.ge.s32 %p2, %r19, %r16;
    @%p2 cvt.s32.s64 %r4, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
