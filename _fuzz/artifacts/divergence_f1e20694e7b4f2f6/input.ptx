    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r23, %r3, 63;
    cvt.s64.s32 %rd5, %r3;
    setp.ls.u32 %p2, %r23, 4294967295;
    @%p2 shr.s32 %r15, %r23, 15;
    shr.u64 %rd13, %rd5, 15;
    mad.lo.s32 %r24, %r3, %r23, %r15;
    mul.wide.s32 %rd15, %r15, %r3;
    shl.b32 %r20, %r24, 0;
    add.u32 %r18, %r20, %r15;
    selp.b32 %r11, %r15, %r18, %p2;
    mad.lo.u32 %r17, %r3, %r3, %r15;
    setp.eq.s32 %p1, %r17, %r15;
    @%p1 add.s32 %r12, %r20, %r15;
    or.b32 %r25, %r12, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
