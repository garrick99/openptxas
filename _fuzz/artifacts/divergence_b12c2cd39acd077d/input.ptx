.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd14, %r3, %r3;
    add.u32 %r12, %r3, 2147483647;
    and.b32 %r5, %r12, %r12;
    xor.b32 %r14, %r12, 31;
    min.s32 %r19, %r3, %r14;
    sub.s32 %r8, %r14, %r5;
    setp.gt.s32 %p4, %r12, %r8;
    @%p4 sub.u32 %r16, %r8, 0;
    and.b64 %rd14, %rd14, %rd14;
    mad.lo.u32 %r15, %r16, %r16, %r5;
    mul.wide.u32 %rd11, %r19, %r5;
    max.s64 %rd12, %rd14, %rd11;
    max.u64 %rd10, %rd11, %rd11;
    shr.s64 %rd12, %rd10, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
