.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd6, %r3, %r3;
    xor.b64 %rd6, %rd6, %rd6;
    and.b32 %r4, %r3, %r3;
    sub.u32 %r26, %r4, 63;
    shl.b64 %rd13, %rd6, 4;
    max.s64 %rd12, %rd6, %rd13;
    mad.lo.u32 %r15, %r3, %r3, %r26;
    shr.s32 %r19, %r4, 31;
    cvt.u32.u64 %r6, %rd12;
    mad.lo.u32 %r23, %r4, %r15, %r6;
    setp.lt.s32 %p2, %r19, %r23;
    @%p2 sub.s32 %r9, %r19, %r15;
    shr.u64 %rd15, %rd12, 16;
    selp.b32 %r18, %r23, %r9, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
