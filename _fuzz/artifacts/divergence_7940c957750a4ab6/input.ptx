.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p1, %r3, 256;
    @%p1 or.b32 %r5, %r3, 65536;
    cvt.s64.s32 %rd5, %r5;
    or.b32 %r4, %r3, %r3;
    setp.gt.u32 %p1, %r3, %r3;
    @!%p1 max.u32 %r13, %r5, %r5;
    max.u64 %rd5, %rd5, %rd5;
    add.s32 %r10, %r4, %r13;
    sub.s32 %r24, %r10, 4294967295;
    shl.b32 %r25, %r3, 0;
    or.b32 %r7, %r10, 16;
    or.b32 %r16, %r25, 7;
    cvt.u64.u32 %rd14, %r10;
    selp.b32 %r19, %r24, %r10, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
