.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r15, %r3, 30;
    cvt.u64.u32 %rd6, %r15;
    mad.lo.s32 %r5, %r15, %r15, %r3;
    min.s32 %r11, %r5, %r3;
    max.s32 %r8, %r3, %r11;
    shr.u64 %rd13, %rd6, 48;
    setp.le.s32 %p4, %r11, 3;
    @%p4 mul.lo.u32 %r24, %r5, %r11;
    setp.ne.u32 %p2, %r11, 65535;
    @!%p2 min.u32 %r18, %r11, 4;
    selp.b32 %r15, %r11, %r11, %p4;
    or.b32 %r8, %r11, %r5;
    setp.gt.u32 %p1, %r18, 65535;
    mad.lo.u32 %r18, %r18, %r8, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
