.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r4, %r3, %r3;
    shl.b32 %r16, %r4, 31;
    shr.u32 %r22, %r3, 0;
    shl.b32 %r4, %r4, 7;
    mul.lo.s32 %r21, %r16, 63;
    cvt.u64.u32 %rd13, %r16;
    mul.wide.s32 %rd6, %r3, %r3;
    shr.u64 %rd7, %rd13, 31;
    setp.ge.u32 %p1, %r22, 2147483648;
    @%p1 sub.u32 %r16, %r4, 16;
    mul.wide.u32 %rd9, %r3, %r4;
    and.b32 %r4, %r16, %r4;
    setp.lt.u32 %p4, %r22, 8;
    cvt.s64.s32 %rd7, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
