.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    cvt.s32.s64 %r15, %rd15;
    shl.b64 %rd10, %rd15, 47;
    setp.lo.u32 %p3, %r3, %r15;
    @!%p3 xor.b64 %rd13, %rd10, %rd15;
    or.b32 %r25, %r15, 65535;
    shr.s64 %rd13, %rd15, 3;
    shr.s64 %rd7, %rd13, 32;
    setp.ge.s32 %p1, %r25, %r15;
    mul.lo.u64 %rd7, %rd13, %rd15;
    cvt.u64.u32 %rd9, %r15;
    setp.ne.u32 %p1, %r15, 65535;
    @!%p1 sub.s32 %r20, %r3, %r25;
    selp.b32 %r24, %r20, %r15, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
