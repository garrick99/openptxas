.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r17, %r3, %r3;
    cvt.s64.s32 %rd15, %r3;
    mul.lo.u64 %rd10, %rd15, %rd15;
    or.b32 %r8, %r17, 5;
    add.u64 %rd15, %rd10, %rd10;
    and.b32 %r20, %r17, 2147483648;
    shr.s32 %r13, %r8, 30;
    max.u32 %r9, %r3, %r8;
    or.b32 %r20, %r20, 15;
    shl.b32 %r6, %r20, 15;
    sub.s32 %r9, %r8, 63;
    mad.lo.s32 %r8, %r20, %r13, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
