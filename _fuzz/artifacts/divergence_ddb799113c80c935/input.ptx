.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r11, %r3, 32;
    or.b32 %r19, %r11, %r11;
    setp.ne.s32 %p1, %r19, 2147483647;
    add.u32 %r13, %r3, 2147483647;
    and.b32 %r17, %r3, 0;
    setp.eq.s32 %p4, %r11, 63;
    @%p4 min.u32 %r20, %r13, 2;
    cvt.s64.s32 %rd11, %r20;
    shl.b32 %r15, %r3, 7;
    max.u32 %r19, %r17, 7;
    add.u32 %r21, %r13, %r11;
    setp.lo.u32 %p1, %r15, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
