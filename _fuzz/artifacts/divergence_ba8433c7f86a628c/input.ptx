.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r24, %r3, 32;
    cvt.u64.u32 %rd11, %r3;
    or.b32 %r26, %r3, %r3;
    shl.b32 %r23, %r24, 4;
    shl.b32 %r8, %r23, 3;
    shl.b64 %rd7, %rd11, 3;
    cvt.s32.s64 %r14, %rd7;
    max.u64 %rd12, %rd7, %rd11;
    mul.lo.s32 %r18, %r3, 3;
    sub.s32 %r6, %r3, 63;
    max.s32 %r8, %r14, %r24;
    setp.ge.s32 %p4, %r3, %r24;
    @%p4 cvt.u32.u64 %r14, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
