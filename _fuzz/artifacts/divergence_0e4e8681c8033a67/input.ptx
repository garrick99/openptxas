.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r11, %r3, 31;
    min.u32 %r15, %r3, %r3;
    max.u32 %r10, %r15, 256;
    setp.lt.u32 %p4, %r11, 255;
    @%p4 or.b32 %r21, %r15, %r10;
    setp.hs.u32 %p4, %r21, 31;
    cvt.u64.u32 %rd14, %r21;
    sub.s64 %rd14, %rd14, %rd14;
    sub.u32 %r6, %r3, 2147483648;
    or.b32 %r17, %r10, 0;
    add.s64 %rd13, %rd14, %rd14;
    cvt.u32.u64 %r16, %rd14;
    shr.u32 %r19, %r10, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
