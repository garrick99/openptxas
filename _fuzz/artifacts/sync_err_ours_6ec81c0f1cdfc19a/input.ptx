.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r11, %r3, 3;
    add.u32 %r19, %r11, %r11;
    shr.s32 %r25, %r19, 15;
    add.s32 %r15, %r3, %r3;
    mul.wide.u32 %rd10, %r25, %r19;
    cvt.s64.s32 %rd13, %r25;
    or.b32 %r9, %r3, 256;
    shr.s32 %r8, %r15, 2;
    shr.u32 %r15, %r19, 2;
    mad.lo.s32 %r17, %r3, %r15, %r9;
    add.s32 %r22, %r8, %r19;
    min.s32 %r9, %r15, %r9;
    or.b32 %r17, %r15, %r3;
    cvt.u32.u64 %r15, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
