.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r21, %r3, %r3;
    mul.lo.u32 %r6, %r3, %r3;
    max.s32 %r18, %r3, 32;
    mul.wide.s32 %rd8, %r6, %r18;
    or.b32 %r15, %r6, 255;
    mul.wide.u32 %rd11, %r15, %r3;
    shl.b32 %r23, %r21, 15;
    mad.lo.u32 %r10, %r18, %r3, %r3;
    min.u32 %r9, %r18, %r10;
    add.s32 %r12, %r9, 255;
    mul.lo.u32 %r5, %r12, %r9;
    and.b32 %r8, %r3, %r3;
    setp.ge.s32 %p1, %r9, %r6;
    @!%p1 max.u32 %r17, %r12, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
