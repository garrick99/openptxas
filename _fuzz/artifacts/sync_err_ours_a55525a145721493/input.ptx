.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r27, %r3, %r3;
    cvt.u64.u32 %rd9, %r3;
    mad.lo.s32 %r22, %r3, %r27, %r27;
    shr.u64 %rd11, %rd9, 4;
    setp.le.s32 %p3, %r22, %r27;
    @%p3 and.b32 %r8, %r27, 8;
    add.s32 %r9, %r27, %r22;
    add.u32 %r24, %r22, 1;
    min.u64 %rd15, %rd9, %rd11;
    shr.s32 %r21, %r24, 3;
    mul.lo.u64 %rd8, %rd11, %rd9;
    mul.lo.u32 %r9, %r8, %r9;
    selp.b32 %r25, %r3, %r9, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
