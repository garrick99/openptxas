.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r17, %r3, %r3;
    mad.lo.u32 %r10, %r3, %r3, %r17;
    mad.lo.u32 %r6, %r17, %r3, %r10;
    setp.lt.u32 %p4, %r6, 63;
    sub.u32 %r4, %r3, 64;
    mul.lo.u32 %r13, %r4, 65536;
    cvt.u64.u32 %rd13, %r10;
    max.u32 %r26, %r3, 255;
    mul.wide.s32 %rd7, %r4, %r4;
    setp.ge.u32 %p2, %r17, 65536;
    @!%p2 and.b32 %r15, %r26, %r26;
    mad.lo.u32 %r12, %r10, %r13, %r4;
    cvt.s64.s32 %rd14, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
