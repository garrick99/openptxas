.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r5, %r3, %r3;
    cvt.s64.s32 %rd14, %r5;
    shl.b64 %rd11, %rd14, 7;
    add.s64 %rd13, %rd11, %rd11;
    sub.s64 %rd8, %rd14, %rd14;
    setp.ls.u32 %p3, %r3, 255;
    @%p3 shl.b32 %r8, %r3, 2;
    sub.u32 %r13, %r3, 8;
    max.u64 %rd5, %rd14, %rd13;
    or.b32 %r6, %r5, %r5;
    max.s32 %r7, %r5, %r8;
    cvt.s32.s64 %r18, %rd13;
    cvt.s64.s32 %rd10, %r6;
    sub.s32 %r11, %r13, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
