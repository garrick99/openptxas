    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r21, %r3, 16;
    mul.wide.s32 %rd14, %r21, %r21;
    shr.s64 %rd5, %rd14, 30;
    setp.le.u32 %p4, %r21, %r3;
    @!%p4 sub.u64 %rd15, %rd14, %rd14;
    shl.b32 %r13, %r3, 16;
    selp.b32 %r27, %r13, %r21, %p4;
    mad.lo.u32 %r22, %r13, %r27, %r13;
    shl.b64 %rd12, %rd15, 48;
    min.u32 %r18, %r13, 3;
    sub.u32 %r21, %r3, 2147483648;
    selp.b32 %r5, %r18, %r18, %p4;
    max.u32 %r12, %r18, 65535;
    mul.wide.u32 %rd14, %r18, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
