.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r21, %r3, %r3;
    setp.le.s32 %p1, %r3, %r21;
    @!%p1 add.s32 %r5, %r21, 1;
    mad.lo.u32 %r5, %r21, %r3, %r21;
    cvt.u64.u32 %rd8, %r3;
    shr.u32 %r17, %r5, 4;
    cvt.u64.u32 %rd9, %r3;
    min.s32 %r19, %r21, 63;
    max.s64 %rd10, %rd8, %rd8;
    cvt.s64.s32 %rd13, %r17;
    sub.s32 %r26, %r19, 256;
    xor.b32 %r22, %r3, %r26;
    selp.b32 %r7, %r3, %r5, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
