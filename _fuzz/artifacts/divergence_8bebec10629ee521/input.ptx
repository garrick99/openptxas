.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r11, %r3, 32;
    mul.wide.s32 %rd10, %r11, %r3;
    setp.ge.s32 %p2, %r11, %r11;
    @!%p2 shr.s32 %r20, %r11, 4;
    selp.b32 %r21, %r3, %r20, %p2;
    add.u64 %rd14, %rd10, %rd10;
    shr.u64 %rd8, %rd14, 32;
    mul.lo.u32 %r11, %r20, %r20;
    cvt.u32.u64 %r27, %rd8;
    xor.b32 %r9, %r20, %r20;
    max.s32 %r13, %r11, 5;
    max.s64 %rd6, %rd8, %rd10;
    cvt.s32.s64 %r24, %rd8;
    max.s32 %r17, %r3, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
