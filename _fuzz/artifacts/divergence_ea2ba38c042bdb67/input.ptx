.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r26, %r3, %r3;
    sub.u32 %r22, %r26, %r3;
    max.s32 %r14, %r26, 4294967295;
    shr.u32 %r14, %r3, 1;
    cvt.s64.s32 %rd5, %r3;
    sub.s32 %r7, %r26, %r3;
    mul.lo.s32 %r16, %r7, 63;
    add.s32 %r21, %r3, 8;
    add.u64 %rd15, %rd5, %rd5;
    and.b32 %r14, %r22, 5;
    mul.wide.s32 %rd12, %r16, %r3;
    min.s64 %rd8, %rd15, %rd15;
    sub.u32 %r8, %r26, 63;
    or.b32 %r5, %r7, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
