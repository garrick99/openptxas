.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r18, %r3, %r3;
    cvt.u64.u32 %rd12, %r3;
    setp.gt.s32 %p4, %r3, %r3;
    @%p4 mul.wide.s32 %rd9, %r3, %r3;
    mul.lo.u32 %r4, %r3, 0;
    add.u32 %r24, %r3, 2147483648;
    cvt.s64.s32 %rd15, %r18;
    shr.u64 %rd6, %rd12, 31;
    min.s32 %r18, %r24, %r18;
    xor.b64 %rd9, %rd6, %rd6;
    min.u32 %r11, %r18, %r24;
    setp.lt.u32 %p1, %r3, 3;
    @%p1 add.s32 %r25, %r4, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
