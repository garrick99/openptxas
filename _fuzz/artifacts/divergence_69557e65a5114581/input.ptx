.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r23, %r3, %r3;
    popc.b32 %r5, %r23;
    popc.b32 %r5, %r5;
    popc.b32 %r16, %r5;
    bfi.b32 %r22, %r16, %r16, 4, 2;
    bfe.s32 %r10, %r22, 15, 8;
    bfe.s32 %r20, %r3, 7, 1;
    brev.b32 %r8, %r10;
    popc.b32 %r13, %r20;
    max.u32 %r4, %r10, 31;
    popc.b32 %r14, %r22;
    clz.b32 %r22, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
