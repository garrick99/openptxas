.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    setp.gt.u32 %p4, %r3, %r3;
    @!%p4 sub.u32 %r5, %r3, %r3;
    setp.hi.u32 %p1, %r3, 63;
    @%p1 shl.b32 %r14, %r3, 16;
    mul.wide.u32 %rd5, %r3, %r5;
    setp.le.u32 %p4, %r3, 65535;
    @%p4 selp.b32 %r25, %r14, %r5, %p4;
    shl.b64 %rd7, %rd11, 62;
    setp.eq.u32 %p3, %r25, 2;
    @!%p3 mul.wide.s32 %rd15, %r14, %r25;
    shr.u64 %rd15, %rd15, 31;
    sub.s32 %r7, %r14, %r25;
    shl.b64 %rd12, %rd15, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
