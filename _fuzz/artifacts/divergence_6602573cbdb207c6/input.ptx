.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p2, %r3, %r3;
    @!%p2 max.s32 %r23, %r3, %r3;
    mad.lo.s32 %r18, %r23, %r3, %r3;
    cvt.u64.u32 %rd8, %r18;
    min.s32 %r15, %r23, %r18;
    and.b64 %rd14, %rd8, %rd8;
    shr.u64 %rd13, %rd14, 62;
    xor.b32 %r7, %r15, 2;
    mul.wide.u32 %rd5, %r18, %r3;
    mad.lo.s32 %r16, %r23, %r15, %r23;
    shr.u32 %r19, %r18, 0;
    sub.u32 %r4, %r16, 2147483647;
    sub.s64 %rd6, %rd8, %rd13;
    add.s32 %r20, %r18, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
