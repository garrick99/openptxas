.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r18, %r3, %r3;
    mul.wide.u32 %rd15, %r18, %r3;
    add.u32 %r17, %r3, 65536;
    shr.s32 %r10, %r17, 16;
    cvt.s64.s32 %rd9, %r3;
    shr.s64 %rd13, %rd15, 63;
    shl.b64 %rd9, %rd13, 2;
    mul.wide.u32 %rd9, %r18, %r18;
    setp.le.s32 %p3, %r3, %r17;
    @%p3 cvt.u32.u64 %r6, %rd15;
    add.u32 %r17, %r10, %r3;
    xor.b32 %r21, %r18, %r17;
    shr.s64 %rd8, %rd13, 47;
    selp.b32 %r15, %r17, %r10, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
