.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r12, %r3, 2147483648;
    cvt.u64.u32 %rd7, %r12;
    max.s32 %r13, %r12, %r12;
    shr.s64 %rd15, %rd7, 31;
    shr.s32 %r26, %r3, 4;
    shl.b64 %rd8, %rd15, 2;
    shr.s32 %r20, %r3, 1;
    cvt.u64.u32 %rd15, %r12;
    mul.lo.s32 %r15, %r13, %r12;
    max.s32 %r6, %r20, %r15;
    shl.b64 %rd10, %rd8, 63;
    cvt.s32.s64 %r16, %rd8;
    setp.lt.u32 %p3, %r26, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
