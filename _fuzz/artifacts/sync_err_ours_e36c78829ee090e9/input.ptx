.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r21, %r3, %r3;
    max.s32 %r4, %r3, %r21;
    max.s32 %r4, %r21, %r4;
    cvt.s64.s32 %rd13, %r4;
    max.u32 %r23, %r3, %r4;
    sub.s64 %rd8, %rd13, %rd13;
    min.u64 %rd6, %rd13, %rd13;
    cvt.u32.u64 %r19, %rd8;
    min.s32 %r11, %r19, 4294967295;
    max.u32 %r6, %r4, %r4;
    min.s32 %r27, %r6, %r21;
    add.u32 %r14, %r19, 4;
    add.s64 %rd15, %rd6, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
