.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r11, %r3, %r3, %r3;
    mad.lo.s32 %r18, %r11, %r11, %r3;
    min.s32 %r23, %r11, %r18;
    setp.le.s32 %p4, %r23, %r18;
    mul.wide.u32 %rd14, %r23, %r18;
    and.b32 %r12, %r18, 15;
    max.s32 %r13, %r12, 2147483648;
    min.u64 %rd8, %rd14, %rd14;
    selp.b32 %r4, %r11, %r12, %p4;
    shr.u32 %r17, %r23, 3;
    shl.b64 %rd11, %rd8, 3;
    sub.u32 %r23, %r23, %r4;
    and.b32 %r17, %r3, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
