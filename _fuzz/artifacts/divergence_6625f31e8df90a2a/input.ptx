.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r25, %r3, %r3;
    min.u32 %r17, %r25, %r3;
    max.u32 %r18, %r3, %r3;
    sub.u32 %r5, %r18, %r18;
    setp.gt.s32 %p4, %r17, 255;
    @!%p4 mad.lo.u32 %r9, %r3, %r3, %r17;
    cvt.s64.s32 %rd12, %r18;
    shr.s32 %r16, %r9, 4;
    and.b32 %r27, %r9, %r25;
    mad.lo.u32 %r17, %r16, %r9, %r25;
    shr.u32 %r21, %r5, 15;
    xor.b32 %r20, %r25, %r3;
    max.s32 %r15, %r9, %r25;
    shl.b64 %rd6, %rd12, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
