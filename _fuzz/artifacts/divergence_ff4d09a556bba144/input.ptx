.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    cvt.u32.u64 %r26, %rd13;
    mul.lo.u32 %r11, %r3, %r26;
    sub.u32 %r11, %r11, %r26;
    mad.lo.s32 %r21, %r26, %r3, %r3;
    and.b64 %rd13, %rd13, %rd13;
    mad.lo.s32 %r27, %r3, %r26, %r11;
    shr.s64 %rd12, %rd13, 32;
    mul.lo.s64 %rd13, %rd13, %rd13;
    cvt.s32.s64 %r9, %rd12;
    max.u32 %r18, %r27, 1;
    xor.b32 %r24, %r26, %r21;
    and.b32 %r25, %r18, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
