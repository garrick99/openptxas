.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p4, %r3, 65535;
    setp.ne.s32 %p1, %r3, %r3;
    @%p1 sub.u32 %r4, %r3, %r3;
    cvt.s64.s32 %rd14, %r4;
    xor.b32 %r16, %r4, %r3;
    mad.lo.u32 %r9, %r3, %r3, %r3;
    min.s32 %r10, %r4, %r9;
    max.u32 %r20, %r9, %r9;
    add.s32 %r6, %r10, %r9;
    setp.lt.s32 %p2, %r3, 255;
    mul.wide.u32 %rd13, %r9, %r6;
    sub.s32 %r11, %r20, 15;
    shr.u64 %rd6, %rd14, 63;
    xor.b32 %r12, %r6, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
