.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r7, %r3, 4;
    sub.s32 %r23, %r3, %r3;
    cvt.s64.s32 %rd7, %r7;
    cvt.s32.s64 %r19, %rd7;
    max.s64 %rd7, %rd7, %rd7;
    setp.lt.s32 %p4, %r3, %r3;
    @%p4 cvt.s64.s32 %rd9, %r23;
    shl.b32 %r7, %r23, 15;
    xor.b32 %r4, %r7, 5;
    min.s32 %r8, %r3, %r4;
    shr.s64 %rd13, %rd7, 3;
    mul.wide.u32 %rd14, %r7, %r7;
    and.b64 %rd11, %rd9, %rd13;
    cvt.u32.u64 %r13, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
