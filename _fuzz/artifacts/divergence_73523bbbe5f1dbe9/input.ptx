.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r27, %r3, %r3, %r3;
    min.u32 %r23, %r3, 5;
    mul.lo.u32 %r5, %r23, %r23;
    min.s32 %r15, %r27, %r5;
    and.b32 %r7, %r3, 15;
    mad.lo.u32 %r19, %r5, %r7, %r15;
    cvt.s64.s32 %rd13, %r27;
    add.u32 %r12, %r19, 65535;
    mad.lo.s32 %r20, %r3, %r5, %r5;
    min.u32 %r13, %r20, %r23;
    cvt.s64.s32 %rd12, %r7;
    shr.u64 %rd7, %rd12, 4;
    max.u32 %r10, %r27, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
