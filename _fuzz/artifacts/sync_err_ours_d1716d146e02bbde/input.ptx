.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r17, %r3, %r3, %r3;
    add.u32 %r4, %r3, 255;
    shl.b32 %r18, %r3, 16;
    mul.lo.s32 %r8, %r17, 4;
    sub.u32 %r5, %r18, 3;
    shr.u32 %r21, %r8, 16;
    cvt.s64.s32 %rd12, %r3;
    shr.u32 %r4, %r3, 3;
    cvt.s32.s64 %r19, %rd12;
    max.u32 %r4, %r21, %r8;
    mad.lo.u32 %r5, %r18, %r5, %r4;
    shr.u32 %r8, %r19, 4;
    min.s32 %r11, %r5, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
