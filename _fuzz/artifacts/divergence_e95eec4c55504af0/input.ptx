.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r17, %r3, 0;
    setp.ge.u32 %p4, %r3, %r17;
    @%p4 mul.lo.u32 %r18, %r3, 255;
    mul.lo.u32 %r26, %r18, 8;
    and.b32 %r12, %r26, 2147483648;
    or.b32 %r26, %r12, 32;
    setp.gt.u32 %p3, %r26, 256;
    sub.s32 %r8, %r3, %r12;
    cvt.s64.s32 %rd8, %r8;
    setp.ge.u32 %p1, %r3, 15;
    @!%p1 mad.lo.s32 %r9, %r17, %r3, %r17;
    mad.lo.u32 %r20, %r17, %r8, %r12;
    min.s32 %r15, %r12, 32;
    selp.b32 %r6, %r9, %r9, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
