.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r6, %r3, 31;
    cvt.u64.u32 %rd8, %r3;
    shr.u32 %r9, %r6, 1;
    mul.wide.u32 %rd7, %r9, %r6;
    max.u32 %r15, %r3, %r9;
    mul.lo.u32 %r17, %r15, 32;
    shr.u64 %rd12, %rd7, 0;
    shl.b32 %r4, %r3, 7;
    mul.wide.u32 %rd13, %r15, %r3;
    max.u32 %r17, %r4, %r9;
    mad.lo.u32 %r5, %r15, %r15, %r17;
    xor.b32 %r12, %r3, %r9;
    min.u32 %r21, %r12, 65535;
    mad.lo.s32 %r21, %r3, %r9, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
