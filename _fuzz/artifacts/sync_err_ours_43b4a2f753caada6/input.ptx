.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r19, %r3, %r3;
    shl.b32 %r18, %r3, 3;
    max.u32 %r13, %r18, %r18;
    sub.u32 %r7, %r3, 2;
    max.u32 %r10, %r18, %r13;
    cvt.s64.s32 %rd15, %r10;
    cvt.s64.s32 %rd5, %r3;
    cvt.s32.s64 %r19, %rd5;
    min.u32 %r13, %r7, 8;
    mad.lo.u32 %r4, %r19, %r19, %r10;
    add.u32 %r22, %r18, 4294967295;
    mul.lo.u32 %r14, %r19, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
