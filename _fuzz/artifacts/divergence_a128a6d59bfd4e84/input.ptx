    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r8, %r3, %r3;
    setp.lt.s32 %p1, %r3, 2;
    @%p1 shr.u32 %r25, %r3, 1;
    setp.eq.s32 %p1, %r8, %r3;
    cvt.s64.s32 %rd9, %r8;
    cvt.s32.s64 %r4, %rd9;
    cvt.u64.u32 %rd14, %r3;
    and.b32 %r8, %r4, %r25;
    mul.wide.u32 %rd7, %r8, %r3;
    or.b32 %r19, %r8, 2147483648;
    add.s64 %rd13, %rd14, %rd7;
    mul.lo.u32 %r8, %r3, %r19;
    mul.wide.u32 %rd11, %r25, %r4;
    min.s32 %r22, %r19, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
