    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r23, %r3, 4;
    add.u32 %r18, %r23, %r3;
    mad.lo.s32 %r22, %r23, %r18, %r23;
    cvt.s64.s32 %rd6, %r23;
    mul.lo.s32 %r15, %r18, %r22;
    shr.s64 %rd6, %rd6, 30;
    mul.lo.s32 %r5, %r3, 2;
    add.s32 %r20, %r5, %r3;
    min.u32 %r11, %r5, 2;
    min.s64 %rd12, %rd6, %rd6;
    cvt.u32.u64 %r14, %rd6;
    add.s32 %r4, %r20, 4294967295;
    cvt.s64.s32 %rd15, %r20;
    min.u32 %r16, %r23, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
