.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    shr.u64 %rd15, %rd6, 1;
    mul.lo.s32 %r11, %r3, %r3;
    shr.s64 %rd7, %rd15, 2;
    sub.s32 %r16, %r3, 16;
    cvt.s64.s32 %rd14, %r16;
    mul.wide.u32 %rd7, %r3, %r11;
    setp.gt.u32 %p3, %r3, %r3;
    setp.eq.s32 %p1, %r11, %r16;
    @%p1 cvt.s32.s64 %r26, %rd15;
    setp.lo.u32 %p1, %r16, %r16;
    @!%p1 shr.u64 %rd13, %rd15, 30;
    shr.s64 %rd15, %rd14, 15;
    setp.ne.u32 %p4, %r3, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
