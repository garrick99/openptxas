.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r5, %r3, 65535;
    clz.b32 %r7, %r5;
    bfe.u32 %r8, %r7, 24, 16;
    bfi.b32 %r11, %r5, %r7, 0, 8;
    or.b32 %r17, %r7, %r3;
    clz.b32 %r14, %r17;
    bfi.b32 %r18, %r11, %r5, 7, 16;
    popc.b32 %r21, %r7;
    bfe.u32 %r22, %r11, 4, 32;
    bfe.s32 %r11, %r14, 0, 2;
    clz.b32 %r23, %r21;
    max.u32 %r4, %r3, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
