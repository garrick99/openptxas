.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r9, %r3, %r3;
    or.b32 %r15, %r9, %r9;
    shr.u32 %r9, %r3, 2;
    cvt.u64.u32 %rd10, %r3;
    setp.ne.s32 %p1, %r9, 7;
    @!%p1 shr.s32 %r12, %r3, 2;
    cvt.u64.u32 %rd13, %r12;
    selp.b32 %r4, %r15, %r12, %p1;
    or.b32 %r15, %r12, %r9;
    xor.b32 %r22, %r15, 4294967295;
    mul.lo.u32 %r27, %r3, %r15;
    max.u32 %r17, %r22, %r4;
    cvt.u64.u32 %rd15, %r3;
    add.s32 %r27, %r12, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
