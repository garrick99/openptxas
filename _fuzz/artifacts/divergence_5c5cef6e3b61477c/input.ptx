.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r15, %r3, 63;
    mul.lo.s32 %r9, %r15, %r15;
    shr.u32 %r11, %r9, 30;
    shr.u32 %r26, %r11, 1;
    cvt.u64.u32 %rd9, %r9;
    setp.lo.u32 %p4, %r3, %r9;
    @!%p4 add.u32 %r19, %r11, 15;
    cvt.s64.s32 %rd11, %r15;
    mul.lo.u32 %r24, %r26, %r26;
    and.b32 %r26, %r3, 65535;
    mul.wide.u32 %rd15, %r3, %r15;
    cvt.u32.u64 %r26, %rd11;
    sub.s64 %rd15, %rd11, %rd11;
    add.u32 %r7, %r11, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
