.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r10, %r3, %r3;
    sub.s32 %r9, %r3, %r10;
    mul.lo.u32 %r14, %r3, %r3;
    cvt.s64.s32 %rd14, %r10;
    setp.lt.s32 %p1, %r3, 64;
    @!%p1 add.u32 %r21, %r9, 15;
    setp.lo.u32 %p1, %r9, %r21;
    @%p1 or.b32 %r20, %r14, %r14;
    or.b32 %r9, %r20, 16;
    sub.s32 %r16, %r10, 65535;
    and.b32 %r10, %r14, 16;
    setp.le.u32 %p2, %r16, 31;
    @%p2 shl.b64 %rd5, %rd14, 62;
    mad.lo.s32 %r18, %r21, %r3, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
