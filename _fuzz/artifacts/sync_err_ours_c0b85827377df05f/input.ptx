.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    cvt.s64.s32 %rd9, %r3;
    mul.wide.s32 %rd15, %r3, %r3;
    cvt.u32.u64 %r13, %rd9;
    mul.wide.s32 %rd15, %r3, %r13;
    max.u32 %r20, %r3, %r13;
    sub.u64 %rd8, %rd9, %rd15;
    shl.b32 %r27, %r3, 7;
    setp.gt.u32 %p1, %r27, %r20;
    shr.s32 %r10, %r3, 31;
    cvt.u64.u32 %rd14, %r27;
    add.s64 %rd7, %rd8, %rd15;
    sub.u32 %r19, %r13, %r27;
    add.s64 %rd15, %rd9, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
