    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r17, %r3, 2147483647;
    shr.s32 %r19, %r17, 15;
    mul.wide.u32 %rd13, %r3, %r17;
    add.u32 %r12, %r17, 31;
    shr.u64 %rd10, %rd13, 48;
    and.b64 %rd15, %rd13, %rd10;
    shr.u32 %r9, %r12, 16;
    max.s64 %rd11, %rd13, %rd15;
