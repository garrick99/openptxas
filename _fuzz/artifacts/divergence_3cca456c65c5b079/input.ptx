.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r14, %r3, %r3, %r3;
    setp.hi.u32 %p3, %r14, %r14;
    @%p3 mad.lo.s32 %r27, %r3, %r3, %r3;
    mad.lo.s32 %r12, %r27, %r3, %r27;
    and.b32 %r15, %r14, 63;
    max.s32 %r10, %r14, 15;
    mul.wide.s32 %rd6, %r27, %r14;
    max.u64 %rd14, %rd6, %rd6;
    selp.b32 %r9, %r3, %r12, %p3;
    setp.hs.u32 %p3, %r12, %r10;
    @%p3 mul.lo.u32 %r8, %r3, %r14;
    max.u32 %r25, %r12, %r15;
    setp.lo.u32 %p2, %r3, %r8;
    setp.ls.u32 %p2, %r9, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
