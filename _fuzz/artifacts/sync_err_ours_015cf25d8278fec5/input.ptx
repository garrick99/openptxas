.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    shr.u32 %r15, %r3, 30;
    shr.u32 %r12, %r15, 0;
    shr.u32 %r4, %r3, 31;
    sub.u32 %r8, %r3, %r15;
    min.u64 %rd6, %rd5, %rd5;
    shr.u64 %rd14, %rd5, 0;
    cvt.u32.u64 %r10, %rd5;
    add.u64 %rd15, %rd14, %rd14;
    xor.b64 %rd9, %rd6, %rd15;
    mul.lo.s32 %r24, %r10, 63;
    and.b64 %rd11, %rd14, %rd14;
    shr.s64 %rd10, %rd5, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
