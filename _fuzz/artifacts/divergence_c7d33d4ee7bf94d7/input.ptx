.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r18, %r3, 31;
    max.u32 %r24, %r3, 5;
    sub.s32 %r17, %r24, %r18;
    max.s32 %r7, %r3, 1;
    min.s32 %r13, %r17, %r7;
    cvt.s64.s32 %rd5, %r18;
    sub.s32 %r22, %r3, %r18;
    mul.wide.s32 %rd12, %r3, %r18;
    cvt.u32.u64 %r7, %rd5;
    shr.u32 %r25, %r7, 2;
    and.b32 %r6, %r25, 0;
    cvt.u64.u32 %rd11, %r3;
    mul.lo.u32 %r22, %r18, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
