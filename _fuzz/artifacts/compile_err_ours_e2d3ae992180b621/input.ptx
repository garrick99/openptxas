.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p2, %r0, 0;
    vote.sync.ballot.b32 %r13, %p2, -1;
    shfl.sync.up.b32 %r19, %r3, 8, 0x1f, -1;
    setp.ne.u32 %p2, %r13, %r13;
    vote.sync.ballot.b32 %r5, %p2, -1;
    max.u32 %r10, %r19, %r0;
    shfl.sync.up.b32 %r19, %r13, 8, 0x1f, -1;
    or.b32 %r7, %r0, %r5;
    setp.lt.u32 %p2, %r7, 8;
    vote.sync.ballot.b32 %r13, %p2, -1;
    and.b32 %r4, %r7, %r13;
    vote.sync.any.pred %p2, %p2, -1;
    setp.eq.u32 %p2, %r3, %r3;
    vote.sync.ballot.b32 %r9, %p2, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
