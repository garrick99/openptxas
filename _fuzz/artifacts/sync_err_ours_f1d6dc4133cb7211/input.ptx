.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r16, %r3, 8;
    cvt.u64.u32 %rd8, %r3;
    shr.u32 %r18, %r16, 7;
    shl.b32 %r9, %r16, 7;
    mad.lo.s32 %r21, %r16, %r3, %r18;
    cvt.s32.s64 %r26, %rd8;
    mad.lo.u32 %r19, %r26, %r9, %r26;
    min.u32 %r20, %r9, 4294967295;
    or.b32 %r25, %r26, %r21;
    xor.b32 %r13, %r25, 15;
    cvt.u32.u64 %r16, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
