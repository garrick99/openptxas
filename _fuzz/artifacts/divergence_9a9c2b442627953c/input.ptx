.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    and.b64 %rd12, %rd12, %rd12;
    and.b64 %rd7, %rd12, %rd12;
    shr.u32 %r25, %r3, 3;
    sub.u64 %rd10, %rd7, %rd7;
    max.s32 %r5, %r3, 2147483647;
    min.u64 %rd8, %rd7, %rd12;
    shr.u64 %rd7, %rd12, 1;
    shr.s64 %rd7, %rd12, 2;
    shr.s64 %rd10, %rd12, 2;
    shr.u32 %r27, %r25, 2;
    xor.b32 %r6, %r5, 4;
    mul.lo.s32 %r7, %r5, 4294967295;
    xor.b32 %r5, %r3, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
