.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    cvt.s32.s64 %r22, %rd6;
    shr.u32 %r21, %r22, 16;
    mul.wide.s32 %rd9, %r22, %r21;
    mad.lo.u32 %r10, %r21, %r22, %r22;
    min.s64 %rd6, %rd9, %rd6;
    cvt.s64.s32 %rd8, %r22;
    mul.lo.s32 %r8, %r3, %r21;
    or.b32 %r9, %r8, %r21;
    setp.lo.u32 %p3, %r21, 1;
    @!%p3 add.s32 %r6, %r3, 16;
    or.b32 %r16, %r6, 31;
    selp.b32 %r17, %r6, %r6, %p3;
    shr.u64 %rd9, %rd6, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
