.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd11, %r3, %r3;
    setp.eq.u32 %p2, %r3, 4294967295;
    @%p2 max.s32 %r6, %r3, %r3;
    mul.wide.u32 %rd7, %r6, %r3;
    shl.b64 %rd15, %rd7, 4;
    add.u32 %r16, %r3, %r3;
    mul.lo.s32 %r12, %r3, 4;
    or.b32 %r19, %r6, 2;
    mul.wide.u32 %rd12, %r3, %r6;
    mad.lo.s32 %r6, %r3, %r19, %r6;
    max.s32 %r4, %r3, 15;
    cvt.s32.s64 %r17, %rd12;
    and.b64 %rd15, %rd15, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
