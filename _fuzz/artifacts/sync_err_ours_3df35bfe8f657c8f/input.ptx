.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r13, %r3, 31;
    setp.ne.s32 %p4, %r3, 8;
    @!%p4 mul.lo.s32 %r6, %r13, 4294967295;
    mad.lo.u32 %r27, %r13, %r13, %r6;
    xor.b32 %r19, %r13, 4;
    cvt.u64.u32 %rd13, %r6;
    cvt.s32.s64 %r19, %rd13;
    shr.s32 %r26, %r19, 16;
    xor.b32 %r26, %r27, %r27;
    mul.wide.s32 %rd6, %r27, %r19;
    shr.u32 %r25, %r6, 30;
    shr.s64 %rd14, %rd13, 31;
    shr.s32 %r4, %r26, 0;
    mul.wide.s32 %rd9, %r13, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
