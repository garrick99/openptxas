.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    mul.wide.u32 %rd12, %r3, %r3;
    min.u32 %r6, %r3, %r3;
    shr.s64 %rd11, %rd8, 32;
    shr.u32 %r25, %r6, 30;
    max.u32 %r19, %r3, 2147483648;
    mul.lo.s32 %r7, %r6, %r25;
    xor.b32 %r9, %r7, 16;
    sub.s32 %r26, %r9, %r19;
    add.u32 %r18, %r7, %r19;
    max.u32 %r4, %r19, 3;
    min.s32 %r7, %r7, 7;
    min.s32 %r19, %r3, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
