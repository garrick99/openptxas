.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r6, %r3, 7;
    mul.wide.s32 %rd14, %r6, %r3;
    mul.lo.s32 %r20, %r6, 64;
    shr.u64 %rd13, %rd14, 62;
    cvt.u64.u32 %rd11, %r20;
    add.s32 %r18, %r20, %r3;
    sub.u32 %r12, %r6, 64;
    shl.b32 %r10, %r3, 7;
    setp.hi.u32 %p1, %r6, 1;
    @%p1 mad.lo.u32 %r6, %r10, %r20, %r6;
    shr.s32 %r7, %r10, 3;
    sub.u32 %r19, %r12, 3;
    min.u32 %r13, %r20, %r10;
    cvt.u32.u64 %r23, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
