.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r20, %r3, %r3;
    sub.s32 %r8, %r20, 64;
    setp.le.s32 %p3, %r8, 4294967295;
    setp.ge.s32 %p1, %r8, 2;
    @!%p1 mul.wide.s32 %rd12, %r8, %r3;
    cvt.u32.u64 %r10, %rd12;
    cvt.u32.u64 %r6, %rd12;
    mul.wide.u32 %rd14, %r8, %r8;
    mul.lo.s32 %r11, %r6, 256;
    and.b32 %r8, %r6, 32;
    add.u64 %rd9, %rd12, %rd14;
    min.s32 %r17, %r3, %r3;
    mul.lo.u32 %r7, %r3, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
