.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    shr.s32 %r12, %r3, 15;
    cvt.s32.s64 %r13, %rd14;
    mul.lo.u64 %rd7, %rd14, %rd14;
    mad.lo.s32 %r16, %r13, %r13, %r3;
    min.u32 %r10, %r13, 0;
    xor.b64 %rd5, %rd7, %rd14;
    cvt.s32.s64 %r26, %rd14;
    cvt.s64.s32 %rd6, %r26;
    shl.b32 %r26, %r26, 4;
    mul.lo.u32 %r12, %r16, 256;
    mul.lo.u32 %r26, %r26, 31;
    mad.lo.s32 %r15, %r3, %r10, %r13;
    add.u32 %r23, %r10, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
