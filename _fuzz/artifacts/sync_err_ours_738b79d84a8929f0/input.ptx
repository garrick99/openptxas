.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r22, %r3, 3;
    cvt.u64.u32 %rd9, %r3;
    sub.u32 %r15, %r22, 31;
    mul.wide.u32 %rd14, %r3, %r15;
    xor.b32 %r19, %r3, 64;
    max.u32 %r23, %r15, %r19;
    mad.lo.s32 %r25, %r19, %r15, %r3;
    max.u64 %rd12, %rd14, %rd9;
    cvt.s32.s64 %r23, %rd12;
    sub.s32 %r10, %r23, %r3;
    cvt.s32.s64 %r24, %rd14;
    cvt.s32.s64 %r21, %rd12;
    add.s32 %r17, %r21, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
