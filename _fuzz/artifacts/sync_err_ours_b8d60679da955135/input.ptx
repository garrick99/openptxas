.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r10, %r3, 5;
    max.u32 %r12, %r10, 2;
    cvt.u64.u32 %rd14, %r3;
    max.s64 %rd11, %rd14, %rd14;
    max.u32 %r14, %r3, 255;
    mad.lo.s32 %r4, %r10, %r3, %r14;
    cvt.u32.u64 %r11, %rd11;
    cvt.u64.u32 %rd7, %r12;
    sub.u32 %r15, %r10, %r10;
    mul.wide.u32 %rd8, %r11, %r14;
    shl.b32 %r22, %r3, 30;
    shl.b64 %rd5, %rd8, 47;
    xor.b32 %r6, %r15, %r11;
    mul.lo.s64 %rd8, %rd5, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
