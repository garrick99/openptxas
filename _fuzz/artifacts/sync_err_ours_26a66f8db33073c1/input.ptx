.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r17, %r3, 15;
    add.u32 %r15, %r3, 5;
    mul.wide.s32 %rd7, %r3, %r17;
    or.b32 %r13, %r17, %r3;
    shr.s32 %r20, %r17, 31;
    sub.s64 %rd8, %rd7, %rd7;
    or.b32 %r27, %r3, %r17;
    xor.b64 %rd8, %rd7, %rd7;
    setp.eq.s32 %p1, %r20, 15;
    cvt.s64.s32 %rd13, %r17;
    mad.lo.u32 %r24, %r15, %r20, %r27;
    and.b32 %r8, %r17, 16;
    and.b32 %r27, %r15, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
