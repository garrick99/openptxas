.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd5, %r3, %r3;
    shr.s32 %r8, %r3, 3;
    sub.s32 %r10, %r3, 31;
    sub.s32 %r15, %r3, %r8;
    mul.wide.u32 %rd8, %r15, %r3;
    cvt.u64.u32 %rd11, %r15;
    mul.lo.s32 %r17, %r8, %r15;
    max.s32 %r13, %r8, 4;
    mul.wide.s32 %rd10, %r13, %r10;
    mul.lo.u32 %r27, %r17, %r8;
    sub.s32 %r25, %r27, %r3;
    shl.b32 %r12, %r17, 4;
    sub.u64 %rd5, %rd8, %rd10;
    xor.b32 %r23, %r25, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
