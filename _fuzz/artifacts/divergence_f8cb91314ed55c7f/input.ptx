.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r7, %r3, %r3, %r3;
    xor.b32 %r10, %r7, %r3;
    mad.lo.u32 %r20, %r10, %r10, %r7;
    cvt.s64.s32 %rd10, %r20;
    min.u32 %r5, %r3, 63;
    shr.s64 %rd13, %rd10, 3;
    cvt.u64.u32 %rd5, %r3;
    mul.wide.s32 %rd6, %r5, %r3;
    setp.gt.s32 %p4, %r10, %r3;
    cvt.u32.u64 %r5, %rd10;
    max.s32 %r8, %r3, 4294967295;
    sub.s32 %r13, %r5, %r8;
    add.s32 %r13, %r3, 0;
    min.s32 %r6, %r3, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
