.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r15, %r3, %r3;
    cvt.u64.u32 %rd8, %r15;
    and.b32 %r11, %r15, %r3;
    min.u32 %r24, %r11, %r11;
    mad.lo.s32 %r20, %r11, %r15, %r11;
    max.u32 %r15, %r24, 256;
    sub.s64 %rd7, %rd8, %rd8;
    add.u32 %r12, %r20, %r24;
    xor.b32 %r16, %r11, %r11;
    max.u32 %r23, %r15, %r24;
    min.u32 %r18, %r20, %r23;
    mul.wide.s32 %rd14, %r12, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
