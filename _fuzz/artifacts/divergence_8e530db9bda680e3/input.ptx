.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r26, %r3, 31;
    max.s32 %r17, %r26, 15;
    mad.lo.u32 %r5, %r3, %r26, %r17;
    add.s32 %r7, %r17, 1;
    min.s32 %r23, %r17, 15;
    cvt.u64.u32 %rd10, %r26;
    max.s32 %r16, %r23, %r7;
    add.s64 %rd5, %rd10, %rd10;
    shl.b64 %rd10, %rd5, 7;
    shl.b64 %rd15, %rd5, 62;
    mul.lo.s32 %r17, %r7, %r16;
    max.s32 %r8, %r5, 1;
    xor.b32 %r18, %r23, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
