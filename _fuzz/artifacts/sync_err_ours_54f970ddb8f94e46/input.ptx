.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r13, %r3, 7;
    shl.b32 %r27, %r3, 4;
    mul.lo.u32 %r26, %r3, 31;
    or.b32 %r21, %r27, %r3;
    shr.s32 %r14, %r3, 0;
    cvt.s64.s32 %rd14, %r26;
    mad.lo.u32 %r22, %r13, %r14, %r27;
    sub.u32 %r14, %r26, 64;
    min.s32 %r15, %r26, %r22;
    shr.s32 %r18, %r15, 2;
    shr.u32 %r9, %r3, 2;
    add.u32 %r24, %r15, %r13;
    shr.u32 %r9, %r27, 31;
    xor.b32 %r20, %r21, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
