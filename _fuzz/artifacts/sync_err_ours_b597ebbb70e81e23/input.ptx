    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r21, %r3, %r3;
    setp.ge.u32 %p2, %r21, 2147483647;
    shr.s32 %r9, %r3, 15;
    mul.lo.u32 %r11, %r9, 32;
    selp.b32 %r5, %r11, %r3, %p2;
    setp.lt.u32 %p2, %r9, 255;
    @%p2 mul.wide.u32 %rd10, %r5, %r5;
    and.b32 %r21, %r9, 8;
    min.u32 %r11, %r21, 63;
    sub.s32 %r23, %r3, %r21;
    setp.ne.s32 %p1, %r9, 0;
    setp.ne.s32 %p2, %r23, 7;
    @!%p2 min.s32 %r7, %r9, %r21;
    setp.lo.u32 %p3, %r11, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
