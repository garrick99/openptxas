.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r16, %r3, 64;
    mad.lo.u32 %r22, %r16, %r16, %r3;
    cvt.u64.u32 %rd10, %r3;
    mul.lo.s32 %r15, %r22, 64;
    mul.lo.s64 %rd14, %rd10, %rd10;
    max.u32 %r25, %r22, %r16;
    add.s32 %r22, %r15, %r22;
    setp.lo.u32 %p4, %r22, 256;
    @%p4 add.u32 %r26, %r25, 256;
    add.s32 %r10, %r25, %r15;
    setp.le.u32 %p1, %r16, 1;
    add.s32 %r10, %r3, %r10;
    setp.ls.u32 %p1, %r26, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
