    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p1, %r3, 7;
    @%p1 cvt.u64.u32 %rd14, %r3;
    setp.hi.u32 %p3, %r3, 3;
    @%p3 sub.u32 %r5, %r3, 0;
    shl.b32 %r24, %r5, 31;
    setp.ge.s32 %p1, %r5, 4294967295;
    or.b32 %r9, %r3, %r24;
