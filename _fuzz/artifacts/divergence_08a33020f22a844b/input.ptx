.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r26, %r3, 65535;
    shr.s32 %r20, %r3, 4;
    sub.s32 %r18, %r26, 65536;
    mad.lo.u32 %r27, %r20, %r3, %r18;
    min.s32 %r26, %r18, 256;
    mul.wide.u32 %rd15, %r3, %r18;
    setp.ne.u32 %p3, %r27, 15;
    @%p3 min.u64 %rd14, %rd15, %rd15;
    min.s64 %rd15, %rd15, %rd14;
    shl.b64 %rd15, %rd15, 33;
    or.b32 %r7, %r27, 7;
    setp.lo.u32 %p3, %r18, 1;
    @%p3 max.s32 %r14, %r27, 31;
    setp.ls.u32 %p3, %r20, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
