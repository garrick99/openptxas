.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p3, %r3, 3;
    @%p3 xor.b32 %r7, %r3, %r3;
    add.s32 %r6, %r7, %r7;
    shr.u32 %r9, %r6, 2;
    mad.lo.s32 %r8, %r3, %r6, %r9;
    add.s32 %r14, %r9, %r7;
    shl.b32 %r18, %r8, 3;
    max.u32 %r9, %r9, %r9;
    min.s32 %r22, %r6, %r7;
    setp.le.s32 %p4, %r7, %r8;
    @%p4 cvt.u64.u32 %rd5, %r22;
    mad.lo.s32 %r25, %r7, %r3, %r9;
    add.s32 %r19, %r22, 8;
    max.s64 %rd7, %rd5, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
