.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    mul.lo.s32 %r16, %r3, %r3;
    shr.s32 %r7, %r3, 3;
    mul.lo.s32 %r26, %r7, %r7;
    sub.s64 %rd15, %rd10, %rd10;
    mul.wide.u32 %rd7, %r16, %r7;
    cvt.s32.s64 %r23, %rd10;
    mad.lo.u32 %r26, %r16, %r3, %r16;
    mad.lo.s32 %r18, %r26, %r16, %r3;
    min.u32 %r25, %r7, 4294967295;
    and.b32 %r13, %r3, %r18;
    sub.u32 %r20, %r3, %r7;
    mad.lo.u32 %r7, %r3, %r18, %r20;
    sub.s32 %r14, %r7, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
