.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r17, %r3, %r3;
    mul.lo.u32 %r14, %r3, %r17;
    mul.lo.s32 %r21, %r3, %r17;
    shr.s32 %r18, %r14, 16;
    mul.wide.u32 %rd5, %r3, %r18;
    or.b32 %r7, %r17, 15;
    and.b32 %r23, %r21, 4294967295;
    min.s32 %r11, %r14, 2147483647;
    mul.lo.u64 %rd12, %rd5, %rd5;
    shr.u64 %rd11, %rd12, 1;
    cvt.u32.u64 %r19, %rd12;
    add.s32 %r25, %r7, %r14;
    setp.eq.s32 %p3, %r23, %r25;
    @%p3 cvt.u32.u64 %r9, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
