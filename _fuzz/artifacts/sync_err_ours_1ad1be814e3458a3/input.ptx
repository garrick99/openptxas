.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    shr.u32 %r27, %r3, 0;
    min.s32 %r22, %r27, %r3;
    max.s32 %r17, %r3, 65536;
    min.u32 %r6, %r27, %r17;
    shr.u64 %rd11, %rd13, 15;
    cvt.s64.s32 %rd10, %r3;
    min.u64 %rd15, %rd10, %rd11;
    mul.lo.s32 %r4, %r3, 8;
    setp.lt.u32 %p3, %r22, %r6;
    @%p3 selp.b32 %r20, %r6, %r4, %p3;
    sub.s32 %r16, %r27, 65536;
    sub.s64 %rd5, %rd11, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
