.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r27, %r3, %r3;
    cvt.u64.u32 %rd12, %r3;
    mad.lo.s32 %r21, %r27, %r27, %r3;
    shl.b32 %r14, %r21, 16;
    xor.b32 %r4, %r3, %r3;
    max.s32 %r20, %r3, %r4;
    mul.wide.u32 %rd9, %r20, %r21;
    mul.lo.u32 %r18, %r21, 64;
    mul.lo.u64 %rd9, %rd12, %rd9;
    or.b32 %r25, %r21, 2147483648;
    setp.lo.u32 %p2, %r27, 8;
    @%p2 or.b32 %r23, %r20, 65536;
    setp.lt.s32 %p4, %r3, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
