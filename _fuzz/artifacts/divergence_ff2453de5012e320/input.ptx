.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    setp.le.u32 %p4, %r3, 255;
    @!%p4 shl.b32 %r27, %r3, 2;
    min.u64 %rd14, %rd10, %rd10;
    or.b32 %r6, %r3, %r3;
    setp.lo.u32 %p1, %r3, %r6;
    @!%p1 selp.b32 %r10, %r6, %r6, %p1;
    max.s32 %r6, %r27, %r3;
    mul.lo.s32 %r20, %r3, %r3;
    min.u32 %r7, %r27, %r27;
    and.b64 %rd7, %rd14, %rd14;
    setp.le.u32 %p1, %r10, 65536;
    @!%p1 max.s32 %r18, %r3, %r3;
    shl.b64 %rd11, %rd14, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
