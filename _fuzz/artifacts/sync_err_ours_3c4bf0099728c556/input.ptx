.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd7, %r3, %r3;
    mad.lo.u32 %r21, %r3, %r3, %r3;
    max.s32 %r25, %r3, %r3;
    max.s32 %r22, %r25, %r25;
    shr.u32 %r20, %r25, 4;
    max.u32 %r25, %r21, 32;
    mul.wide.s32 %rd10, %r20, %r20;
    shr.s32 %r15, %r25, 3;
    xor.b32 %r12, %r3, 4;
    sub.s32 %r22, %r21, %r20;
    xor.b32 %r13, %r21, 4;
    mad.lo.s32 %r17, %r20, %r3, %r21;
    or.b32 %r25, %r17, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
