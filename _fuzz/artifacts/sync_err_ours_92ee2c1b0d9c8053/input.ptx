.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p1, %r3, 32;
    @!%p1 xor.b32 %r12, %r3, %r3;
    cvt.s64.s32 %rd13, %r3;
    setp.lo.u32 %p4, %r3, 63;
    @!%p4 max.s32 %r21, %r3, 65535;
    sub.u32 %r12, %r12, %r3;
    shl.b64 %rd7, %rd13, 1;
    and.b32 %r23, %r3, 64;
    sub.s32 %r12, %r21, 3;
    min.s32 %r11, %r23, 8;
    max.u32 %r8, %r21, %r11;
    cvt.s64.s32 %rd5, %r21;
    min.u64 %rd8, %rd13, %rd13;
    shl.b32 %r15, %r11, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
