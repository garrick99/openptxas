.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    min.s64 %rd5, %rd12, %rd12;
    max.s32 %r22, %r3, 3;
    mul.wide.u32 %rd8, %r22, %r3;
    mul.lo.u32 %r24, %r3, %r22;
    add.s64 %rd5, %rd8, %rd12;
    cvt.u64.u32 %rd5, %r24;
    mul.wide.s32 %rd10, %r22, %r24;
    shr.s32 %r16, %r24, 3;
    cvt.s32.s64 %r18, %rd12;
    or.b32 %r14, %r18, %r16;
    and.b32 %r24, %r18, 32;
    xor.b64 %rd10, %rd10, %rd5;
    setp.ne.s32 %p1, %r22, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
