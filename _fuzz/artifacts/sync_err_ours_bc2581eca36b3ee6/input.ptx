.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r9, %r3, 0;
    add.u32 %r13, %r9, 255;
    sub.s32 %r12, %r13, 3;
    mul.lo.s32 %r18, %r9, 4294967295;
    setp.gt.s32 %p2, %r3, 65536;
    sub.u32 %r17, %r18, 2147483648;
    shr.u32 %r15, %r18, 3;
    mul.lo.u32 %r25, %r17, 256;
    shr.u32 %r6, %r25, 30;
    mad.lo.s32 %r23, %r6, %r17, %r6;
    mad.lo.s32 %r13, %r17, %r18, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
