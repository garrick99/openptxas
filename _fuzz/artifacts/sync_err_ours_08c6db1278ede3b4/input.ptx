.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r27, %r3, %r3;
    mad.lo.s32 %r21, %r3, %r3, %r27;
    min.u32 %r18, %r3, %r21;
    cvt.s64.s32 %rd9, %r18;
    mul.wide.u32 %rd10, %r18, %r21;
    xor.b32 %r24, %r18, 255;
    shr.s32 %r6, %r24, 4;
    add.s32 %r10, %r18, %r24;
    sub.u32 %r9, %r3, 8;
    mad.lo.s32 %r7, %r6, %r21, %r10;
    min.s32 %r27, %r24, %r21;
    max.s64 %rd11, %rd10, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
