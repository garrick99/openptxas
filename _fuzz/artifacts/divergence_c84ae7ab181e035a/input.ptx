.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r7, %r3, %r3, %r3;
    and.b32 %r14, %r7, %r7;
    shr.s32 %r6, %r14, 30;
    setp.ls.u32 %p3, %r14, 4;
    @%p3 max.s32 %r16, %r7, %r6;
    add.u32 %r9, %r3, %r16;
    mad.lo.s32 %r17, %r9, %r6, %r16;
    setp.lo.u32 %p3, %r6, 31;
    @%p3 sub.u32 %r27, %r7, 8;
    sub.u32 %r6, %r14, 15;
    selp.b32 %r4, %r7, %r6, %p3;
    shl.b32 %r4, %r17, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
