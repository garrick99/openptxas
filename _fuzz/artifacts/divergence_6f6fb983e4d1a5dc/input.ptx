.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r13, %r3, %r3;
    max.u32 %r23, %r3, %r13;
    add.s32 %r22, %r23, 16;
    mul.lo.s32 %r24, %r3, 4294967295;
    max.u32 %r21, %r13, %r24;
    shr.s32 %r17, %r24, 7;
    min.s32 %r4, %r17, 7;
    mad.lo.s32 %r19, %r13, %r4, %r22;
    shr.s32 %r4, %r21, 15;
    mul.lo.s32 %r26, %r24, %r22;
    xor.b32 %r17, %r19, %r24;
    mad.lo.u32 %r20, %r4, %r17, %r22;
    cvt.s64.s32 %rd11, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
