.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    mul.lo.s32 %r27, %r3, 4294967295;
    max.u32 %r12, %r3, %r27;
    add.s32 %r20, %r3, %r12;
    max.u32 %r11, %r20, %r12;
    shl.b32 %r19, %r12, 31;
    min.s32 %r16, %r12, 32;
    shr.u32 %r16, %r19, 30;
    mul.lo.s32 %r24, %r3, %r16;
    mul.lo.u32 %r11, %r20, 0;
    cvt.s32.s64 %r14, %rd9;
    mul.lo.s32 %r26, %r27, %r27;
    mul.wide.u32 %rd10, %r20, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
