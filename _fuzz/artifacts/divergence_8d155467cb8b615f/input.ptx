    ld.global.u32 %r3, [%rd2];
    shfl.sync.bfly.b32 %r6, %r3, 1, 0x1f, -1;
    setp.lt.u32 %p3, %r6, 2147483647;
    vote.sync.ballot.b32 %r10, %p3, -1;
    xor.b32 %r9, %r10, %r0;
    shfl.sync.down.b32 %r9, %r6, 2, 0x1f, -1;
    or.b32 %r5, %r6, %r3;
    xor.b32 %r19, %r0, %r6;
