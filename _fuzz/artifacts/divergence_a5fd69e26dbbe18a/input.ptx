.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r22, %r3, %r3;
    cvt.s64.s32 %rd6, %r22;
    mad.lo.u32 %r24, %r22, %r3, %r22;
    add.u32 %r7, %r3, %r24;
    cvt.s32.s64 %r25, %rd6;
    mad.lo.s32 %r27, %r22, %r22, %r3;
    shr.u64 %rd5, %rd6, 62;
    mul.lo.s64 %rd7, %rd6, %rd6;
    or.b32 %r7, %r7, 32;
    add.u32 %r6, %r27, 31;
    mul.lo.u64 %rd7, %rd5, %rd6;
    shl.b64 %rd6, %rd5, 16;
    cvt.s32.s64 %r8, %rd7;
    shr.s32 %r4, %r27, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
