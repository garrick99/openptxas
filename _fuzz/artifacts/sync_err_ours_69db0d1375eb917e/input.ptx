.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r19, %r3, 30;
    min.s32 %r11, %r3, %r19;
    xor.b32 %r19, %r11, %r11;
    cvt.s64.s32 %rd6, %r19;
    mul.wide.s32 %rd12, %r19, %r11;
    shr.s64 %rd13, %rd6, 0;
    add.s32 %r27, %r3, %r3;
    cvt.u64.u32 %rd12, %r3;
    mul.wide.u32 %rd8, %r11, %r27;
    mad.lo.s32 %r20, %r19, %r19, %r27;
    sub.u32 %r19, %r19, %r11;
    add.u64 %rd9, %rd13, %rd12;
    min.u64 %rd12, %rd12, %rd12;
    xor.b32 %r23, %r11, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
