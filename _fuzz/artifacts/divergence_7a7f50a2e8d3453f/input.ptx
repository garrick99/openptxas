.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    cvt.s32.s64 %r20, %rd13;
    and.b32 %r14, %r3, %r20;
    mul.wide.s32 %rd7, %r3, %r14;
    shr.s32 %r5, %r14, 16;
    shr.u64 %rd13, %rd7, 0;
    shr.u32 %r27, %r3, 30;
    min.u32 %r16, %r3, %r20;
    setp.le.s32 %p1, %r20, 1;
    or.b32 %r14, %r16, %r16;
    cvt.u32.u64 %r8, %rd13;
    max.u32 %r26, %r16, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
