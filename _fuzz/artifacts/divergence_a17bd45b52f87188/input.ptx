.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r14, %r3, %r3;
    add.s32 %r27, %r14, 5;
    cvt.u64.u32 %rd8, %r27;
    shr.s64 %rd13, %rd8, 0;
    setp.hi.u32 %p3, %r14, 8;
    @%p3 and.b32 %r9, %r3, 4294967295;
    max.s64 %rd6, %rd8, %rd13;
    selp.b32 %r4, %r9, %r27, %p3;
    max.u32 %r27, %r27, %r4;
    shl.b64 %rd10, %rd13, 15;
    shl.b64 %rd11, %rd6, 4;
    add.s64 %rd14, %rd10, %rd11;
    mad.lo.s32 %r23, %r9, %r27, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
