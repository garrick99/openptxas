.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    shr.s32 %r17, %r3, 16;
    xor.b32 %r11, %r3, 65535;
    add.s32 %r23, %r11, 3;
    min.u32 %r6, %r17, 64;
    min.u32 %r13, %r6, 5;
    mul.wide.u32 %rd6, %r13, %r13;
    setp.lo.u32 %p1, %r6, 0;
    add.s32 %r24, %r6, 32;
    cvt.s64.s32 %rd15, %r3;
    mul.lo.u64 %rd11, %rd15, %rd15;
    cvt.u64.u32 %rd11, %r11;
    shr.u32 %r6, %r6, 3;
    setp.lt.s32 %p2, %r24, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
