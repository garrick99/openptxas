.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    min.u32 %r18, %r3, %r3;
    cvt.u64.u32 %rd12, %r18;
    mad.lo.u32 %r26, %r3, %r3, %r18;
    min.u32 %r10, %r26, 255;
    shl.b32 %r6, %r3, 1;
    max.s32 %r21, %r10, %r26;
    max.u32 %r26, %r6, %r10;
    sub.s64 %rd13, %rd6, %rd12;
    setp.le.u32 %p3, %r3, 65535;
    setp.ls.u32 %p2, %r10, %r10;
    @!%p2 mad.lo.s32 %r20, %r26, %r18, %r21;
    cvt.u64.u32 %rd6, %r18;
    min.s64 %rd7, %rd6, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
