.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r8, %r3, %r3;
    min.u32 %r17, %r8, 2147483647;
    add.s32 %r23, %r3, %r17;
    mad.lo.u32 %r13, %r3, %r8, %r3;
    cvt.s64.s32 %rd10, %r23;
    mad.lo.s32 %r5, %r17, %r13, %r3;
    or.b32 %r14, %r5, 64;
    mul.lo.s64 %rd13, %rd10, %rd10;
    setp.ne.s32 %p3, %r3, 4294967295;
    @%p3 shr.u32 %r15, %r8, 2;
    mul.wide.s32 %rd10, %r15, %r3;
    shr.s64 %rd12, %rd13, 0;
    mad.lo.u32 %r24, %r5, %r5, %r15;
    cvt.s32.s64 %r16, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
