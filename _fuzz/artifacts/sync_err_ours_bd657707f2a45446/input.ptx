.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p2, %r3, 2147483648;
    cvt.s64.s32 %rd8, %r3;
    xor.b32 %r7, %r3, %r3;
    shl.b32 %r6, %r7, 4;
    add.u32 %r8, %r6, %r6;
    sub.u32 %r17, %r8, 4294967295;
    cvt.u32.u64 %r14, %rd8;
    setp.ne.s32 %p4, %r17, %r8;
    @%p4 sub.u64 %rd8, %rd8, %rd8;
    shr.s32 %r6, %r14, 15;
    setp.lt.u32 %p1, %r6, 65535;
    min.u32 %r27, %r17, %r14;
    selp.b32 %r23, %r7, %r7, %p4;
    cvt.u32.u64 %r9, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
