.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    cvt.u32.u64 %r13, %rd11;
    min.s32 %r24, %r3, 15;
    min.s32 %r26, %r3, 256;
    mad.lo.u32 %r16, %r13, %r3, %r26;
    shr.u32 %r26, %r26, 2;
    setp.ls.u32 %p3, %r26, %r24;
    @!%p3 shl.b32 %r5, %r24, 31;
    mul.wide.u32 %rd9, %r3, %r5;
    min.s32 %r6, %r24, 16;
    selp.b32 %r16, %r5, %r16, %p3;
    add.s64 %rd8, %rd11, %rd11;
    cvt.u64.u32 %rd9, %r3;
    shr.u64 %rd11, %rd9, 48;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
