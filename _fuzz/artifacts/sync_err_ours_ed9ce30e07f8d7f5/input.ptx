.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r24, %r3, %r3;
    xor.b32 %r20, %r24, 64;
    max.u32 %r11, %r20, 2147483647;
    min.u32 %r20, %r3, 63;
    add.s32 %r6, %r11, %r3;
    cvt.u64.u32 %rd13, %r11;
    mul.wide.u32 %rd5, %r24, %r11;
    add.u32 %r16, %r3, 4294967295;
    max.u64 %rd12, %rd5, %rd5;
    max.u64 %rd11, %rd12, %rd13;
    shr.s64 %rd6, %rd12, 0;
    setp.lo.u32 %p4, %r3, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
