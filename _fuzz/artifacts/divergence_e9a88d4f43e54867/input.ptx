.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r24, %r3, %r3;
    and.b32 %r20, %r24, %r3;
    cvt.s64.s32 %rd15, %r20;
    mul.lo.u32 %r20, %r24, 65535;
    cvt.s64.s32 %rd11, %r3;
    mul.lo.s32 %r22, %r20, %r24;
    min.s64 %rd15, %rd15, %rd11;
    shl.b64 %rd9, %rd11, 3;
    setp.ne.u32 %p1, %r22, 65536;
    or.b32 %r6, %r22, 256;
    and.b64 %rd6, %rd9, %rd15;
    sub.s32 %r17, %r6, 255;
    cvt.s32.s64 %r20, %rd15;
    selp.b32 %r20, %r20, %r6, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
