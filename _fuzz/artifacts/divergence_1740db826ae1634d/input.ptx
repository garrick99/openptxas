.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    cvt.s64.s32 %rd8, %r3;
    mul.wide.u32 %rd13, %r3, %r3;
    setp.ge.s32 %p2, %r3, 63;
    @%p2 cvt.s64.s32 %rd5, %r3;
    add.s64 %rd10, %rd13, %rd5;
    cvt.u32.u64 %r25, %rd10;
    setp.lt.u32 %p4, %r25, 5;
    @%p4 xor.b32 %r6, %r25, 5;
    shl.b32 %r14, %r25, 7;
    min.u32 %r6, %r14, %r3;
    min.u32 %r27, %r3, 0;
    max.u32 %r7, %r27, 65536;
    shr.s64 %rd11, %rd8, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
