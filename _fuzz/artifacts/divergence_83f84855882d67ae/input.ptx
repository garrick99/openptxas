.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p1, %r3, %r3;
    @%p1 add.s32 %r11, %r3, 7;
    min.u32 %r12, %r3, 16;
    cvt.s64.s32 %rd14, %r11;
    cvt.s32.s64 %r4, %rd14;
    add.s32 %r24, %r12, 3;
    cvt.u32.u64 %r8, %rd14;
    mad.lo.s32 %r11, %r24, %r24, %r3;
    max.u32 %r7, %r12, 4294967295;
    add.s32 %r13, %r7, 65536;
    add.s32 %r13, %r24, %r4;
    max.u64 %rd11, %rd14, %rd14;
    cvt.s32.s64 %r19, %rd14;
    shr.s64 %rd15, %rd11, 62;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
