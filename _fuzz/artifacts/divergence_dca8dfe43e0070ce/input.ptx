.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p4, %r3, 256;
    @!%p4 mul.wide.u32 %rd7, %r3, %r3;
    shl.b32 %r27, %r3, 7;
    shr.s64 %rd8, %rd7, 47;
    sub.s32 %r12, %r27, %r3;
    sub.u32 %r17, %r12, %r27;
    min.u32 %r17, %r12, 63;
    shr.s32 %r7, %r12, 15;
    mul.wide.u32 %rd9, %r17, %r7;
    shl.b32 %r6, %r17, 30;
    and.b32 %r21, %r17, 3;
    mad.lo.u32 %r6, %r17, %r27, %r12;
    selp.b32 %r6, %r7, %r21, %p4;
    max.s32 %r12, %r21, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
