.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r7, %r3, 2;
    cvt.s64.s32 %rd7, %r3;
    or.b32 %r8, %r3, %r7;
    mul.wide.u32 %rd6, %r3, %r8;
    cvt.u64.u32 %rd7, %r8;
    sub.s32 %r13, %r7, %r7;
    setp.gt.s32 %p3, %r3, 64;
    min.s32 %r7, %r13, %r8;
    shr.u32 %r5, %r13, 16;
    or.b32 %r20, %r13, %r5;
    shr.s32 %r24, %r3, 4;
    mad.lo.s32 %r19, %r24, %r8, %r8;
    shr.u32 %r4, %r24, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
