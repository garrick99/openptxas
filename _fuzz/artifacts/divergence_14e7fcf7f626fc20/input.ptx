.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r8, %r3, 16;
    cvt.s64.s32 %rd10, %r3;
    mul.lo.u32 %r7, %r3, %r8;
    max.s32 %r23, %r8, %r7;
    min.u32 %r19, %r7, 15;
    and.b32 %r20, %r8, 8;
    max.u32 %r9, %r23, %r19;
    shr.u32 %r26, %r7, 0;
    setp.ge.s32 %p3, %r8, 65536;
    @%p3 shr.s64 %rd6, %rd10, 3;
    cvt.u64.u32 %rd8, %r9;
    xor.b32 %r16, %r20, %r20;
    cvt.s32.s64 %r12, %rd8;
    mul.wide.u32 %rd8, %r7, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
