.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    mad.lo.s32 %r14, %r3, %r3, %r3;
    mad.lo.s32 %r25, %r14, %r14, %r14;
    and.b32 %r6, %r14, %r14;
    min.s32 %r7, %r25, %r25;
    shr.u32 %r23, %r3, 4;
    and.b32 %r19, %r14, %r3;
    mul.lo.s32 %r10, %r23, %r6;
    max.s32 %r4, %r6, %r7;
    or.b32 %r11, %r3, 8;
    setp.eq.s32 %p3, %r3, %r4;
    @!%p3 cvt.u64.u32 %rd14, %r11;
    setp.ne.s32 %p2, %r25, 63;
    @%p2 min.u32 %r14, %r25, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
