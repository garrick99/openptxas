.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r15, %r3, 2147483647;
    max.s32 %r8, %r15, 7;
    cvt.s64.s32 %rd10, %r8;
    shl.b32 %r11, %r8, 30;
    xor.b32 %r18, %r8, 1;
    shr.s64 %rd11, %rd10, 3;
    and.b32 %r17, %r15, %r18;
    max.s32 %r23, %r15, %r17;
    xor.b32 %r12, %r18, %r18;
    shr.u32 %r22, %r8, 30;
    sub.u32 %r10, %r15, %r23;
    shl.b32 %r19, %r17, 16;
    shr.s32 %r16, %r23, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
