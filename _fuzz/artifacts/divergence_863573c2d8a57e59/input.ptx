.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r8, %r3, %r3, %r3;
    max.u32 %r9, %r3, 7;
    cvt.u64.u32 %rd11, %r8;
    cvt.s64.s32 %rd13, %r8;
    mul.wide.s32 %rd13, %r9, %r8;
    shl.b64 %rd11, %rd11, 15;
    cvt.s64.s32 %rd6, %r9;
    shr.u64 %rd6, %rd11, 32;
    cvt.u32.u64 %r19, %rd13;
    max.s32 %r16, %r19, 2;
    setp.hi.u32 %p2, %r19, %r9;
    @%p2 xor.b32 %r27, %r19, %r8;
    mad.lo.u32 %r13, %r8, %r16, %r3;
    sub.s32 %r7, %r13, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
