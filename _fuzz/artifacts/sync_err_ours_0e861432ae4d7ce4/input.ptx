.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    mad.lo.u32 %r18, %r3, %r3, %r3;
    mul.lo.u64 %rd12, %rd10, %rd10;
    mad.lo.s32 %r6, %r3, %r18, %r18;
    shl.b32 %r12, %r3, 3;
    setp.ge.u32 %p1, %r12, %r12;
    @%p1 or.b32 %r24, %r18, %r12;
    cvt.s32.s64 %r12, %rd10;
    mad.lo.u32 %r12, %r24, %r12, %r24;
    mad.lo.s32 %r26, %r12, %r6, %r24;
    shr.u32 %r9, %r26, 4;
    shl.b32 %r26, %r18, 4;
    mul.lo.s32 %r23, %r18, %r24;
    min.s32 %r8, %r26, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
