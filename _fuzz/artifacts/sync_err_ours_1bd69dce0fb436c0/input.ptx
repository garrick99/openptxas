.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r15, %r3, 15;
    mul.wide.s32 %rd14, %r15, %r15;
    mul.wide.u32 %rd11, %r15, %r3;
    add.u64 %rd7, %rd11, %rd11;
    add.s32 %r11, %r15, %r3;
    sub.s32 %r26, %r11, %r11;
    or.b32 %r15, %r26, 65536;
    shl.b32 %r25, %r26, 4;
    and.b32 %r25, %r15, %r15;
    min.s32 %r23, %r26, 256;
    shr.s64 %rd10, %rd14, 0;
    shr.s32 %r26, %r25, 3;
    max.s64 %rd13, %rd14, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
