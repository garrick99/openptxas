.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r18, %r3, %r3;
    shr.u32 %r24, %r3, 1;
    add.u32 %r25, %r18, %r18;
    mul.lo.s32 %r13, %r18, 3;
    shr.s32 %r17, %r18, 2;
    mul.wide.s32 %rd6, %r13, %r24;
    setp.ge.u32 %p3, %r18, 7;
    @%p3 mad.lo.s32 %r15, %r18, %r3, %r17;
    mul.lo.u32 %r7, %r13, %r13;
    or.b32 %r23, %r15, %r17;
    max.u32 %r6, %r23, %r23;
    mul.wide.u32 %rd9, %r18, %r17;
    or.b32 %r27, %r15, %r23;
    max.u32 %r15, %r27, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
