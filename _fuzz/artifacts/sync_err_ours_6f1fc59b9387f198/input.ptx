.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r20, %r3, %r3;
    max.s32 %r16, %r20, %r20;
    cvt.u64.u32 %rd14, %r3;
    mul.wide.u32 %rd9, %r20, %r20;
    shr.s32 %r5, %r3, 2;
    add.s32 %r10, %r3, 4;
    shr.u32 %r5, %r5, 0;
    sub.u32 %r11, %r16, 3;
    cvt.u32.u64 %r11, %rd9;
    and.b32 %r8, %r20, %r3;
    mul.wide.s32 %rd15, %r3, %r3;
    cvt.s64.s32 %rd5, %r11;
    mad.lo.u32 %r22, %r3, %r10, %r16;
    setp.ge.s32 %p1, %r3, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
