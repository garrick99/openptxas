.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd7, %r3, %r3;
    add.u32 %r20, %r3, %r3;
    min.s32 %r8, %r20, 63;
    cvt.u32.u64 %r9, %rd7;
    mul.wide.s32 %rd7, %r20, %r20;
    add.s32 %r12, %r8, 65536;
    mul.wide.s32 %rd5, %r12, %r3;
    sub.s64 %rd12, %rd5, %rd7;
    mad.lo.u32 %r10, %r3, %r9, %r8;
    mul.wide.u32 %rd14, %r9, %r9;
    max.u32 %r23, %r20, 31;
    cvt.u32.u64 %r7, %rd5;
    cvt.u32.u64 %r7, %rd12;
    sub.u32 %r13, %r23, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
