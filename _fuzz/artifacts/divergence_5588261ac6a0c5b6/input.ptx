.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hi.u32 %p1, %r3, %r3;
    @%p1 shl.b32 %r13, %r3, 31;
    selp.b32 %r15, %r13, %r13, %p1;
    setp.gt.s32 %p1, %r3, %r13;
    @!%p1 sub.s32 %r5, %r3, %r15;
    mad.lo.u32 %r25, %r5, %r3, %r5;
    setp.le.u32 %p1, %r15, %r15;
    @%p1 sub.u32 %r22, %r13, %r3;
    mul.wide.s32 %rd5, %r3, %r5;
    add.s32 %r21, %r13, %r15;
    sub.u32 %r19, %r21, %r22;
    selp.b32 %r9, %r5, %r25, %p1;
    sub.s32 %r21, %r22, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
