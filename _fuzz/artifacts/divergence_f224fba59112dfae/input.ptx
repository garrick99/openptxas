.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r17, %r3, %r3;
    mul.wide.s32 %rd14, %r3, %r17;
    setp.hi.u32 %p4, %r17, 3;
    @%p4 selp.b32 %r24, %r17, %r3, %p4;
    setp.ls.u32 %p1, %r17, %r24;
    min.s32 %r24, %r3, 63;
    sub.s32 %r24, %r24, 64;
    cvt.u64.u32 %rd14, %r17;
    shr.u32 %r22, %r24, 15;
    setp.hs.u32 %p4, %r24, 3;
    @!%p4 shl.b32 %r16, %r24, 0;
    selp.b32 %r9, %r17, %r24, %p1;
    add.s32 %r16, %r22, 16;
    and.b32 %r27, %r24, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
