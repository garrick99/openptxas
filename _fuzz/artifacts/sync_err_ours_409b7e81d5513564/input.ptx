.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    cvt.u32.u64 %r22, %rd5;
    add.s32 %r26, %r3, %r22;
    add.u32 %r6, %r3, 4294967295;
    add.s32 %r26, %r26, %r6;
    add.u64 %rd12, %rd5, %rd5;
    add.u32 %r6, %r6, 2;
    or.b32 %r10, %r22, %r3;
    shr.s32 %r21, %r22, 31;
    shr.u64 %rd6, %rd5, 48;
    add.u32 %r25, %r6, 3;
    cvt.s32.s64 %r24, %rd12;
    or.b32 %r10, %r10, %r6;
    or.b64 %rd8, %rd12, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
