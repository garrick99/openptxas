.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r19, %r3, %r3, %r3;
    cvt.u64.u32 %rd7, %r3;
    cvt.u32.u64 %r21, %rd7;
    mul.lo.u32 %r14, %r3, 63;
    and.b32 %r26, %r14, 5;
    shl.b32 %r23, %r21, 31;
    shr.u64 %rd12, %rd7, 7;
    cvt.s64.s32 %rd14, %r23;
    or.b64 %rd15, %rd12, %rd12;
    cvt.s64.s32 %rd14, %r19;
    setp.lo.u32 %p3, %r26, 64;
    @%p3 shl.b64 %rd7, %rd15, 2;
    cvt.s32.s64 %r19, %rd15;
    selp.b32 %r11, %r3, %r19, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
