.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r5, %r3, 256;
    setp.le.s32 %p2, %r3, %r5;
    @%p2 add.s32 %r23, %r5, 0;
    cvt.u64.u32 %rd9, %r5;
    shr.s32 %r6, %r23, 16;
    min.s32 %r22, %r6, 5;
    min.s32 %r9, %r5, %r23;
    shl.b32 %r10, %r23, 4;
    shl.b32 %r26, %r5, 3;
    max.s32 %r11, %r26, 4;
    max.s32 %r18, %r26, %r9;
    shl.b32 %r13, %r18, 7;
    mad.lo.u32 %r21, %r3, %r22, %r23;
    setp.ge.s32 %p4, %r10, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
