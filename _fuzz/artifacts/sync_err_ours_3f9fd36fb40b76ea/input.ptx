.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r24, %r3, %r3;
    mul.lo.s32 %r11, %r3, %r3;
    and.b32 %r10, %r3, %r11;
    shl.b32 %r4, %r10, 3;
    mad.lo.u32 %r24, %r10, %r3, %r4;
    min.u32 %r22, %r11, %r10;
    xor.b32 %r8, %r24, 4;
    mul.wide.u32 %rd7, %r11, %r3;
    setp.gt.u32 %p2, %r8, 2147483648;
    setp.lo.u32 %p1, %r22, %r4;
    @!%p1 min.u32 %r7, %r24, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
