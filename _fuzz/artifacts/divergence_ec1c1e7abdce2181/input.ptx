.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    mad.lo.u32 %r14, %r3, %r3, %r3;
    and.b64 %rd9, %rd10, %rd10;
    sub.u64 %rd9, %rd9, %rd10;
    setp.ge.s32 %p4, %r14, 4;
    cvt.s32.s64 %r21, %rd10;
    or.b32 %r27, %r21, 64;
    mul.lo.s32 %r27, %r14, 65536;
    selp.b32 %r4, %r27, %r21, %p4;
    max.s32 %r6, %r4, 2;
    shl.b64 %rd5, %rd10, 3;
    add.s32 %r19, %r14, 65536;
    max.s32 %r4, %r19, %r6;
    shr.s64 %rd13, %rd9, 47;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
