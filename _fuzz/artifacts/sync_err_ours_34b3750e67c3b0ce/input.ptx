.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    mul.lo.u32 %r9, %r3, %r3;
    cvt.u64.u32 %rd11, %r3;
    mul.wide.u32 %rd13, %r9, %r3;
    cvt.s64.s32 %rd8, %r3;
    shl.b32 %r17, %r9, 1;
    cvt.u32.u64 %r21, %rd13;
    max.u32 %r14, %r3, %r17;
    mul.wide.s32 %rd6, %r14, %r9;
    xor.b32 %r15, %r21, %r17;
    shr.s64 %rd9, %rd5, 1;
    add.s32 %r4, %r9, %r9;
    add.s32 %r22, %r9, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
