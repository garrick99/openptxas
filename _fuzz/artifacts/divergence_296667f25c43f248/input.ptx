.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r25, %r3, 16;
    mul.wide.u32 %rd8, %r3, %r25;
    add.u32 %r9, %r3, %r25;
    setp.ne.s32 %p3, %r25, 4294967295;
    cvt.u64.u32 %rd8, %r25;
    setp.le.s32 %p2, %r9, %r9;
    @%p2 mad.lo.u32 %r25, %r25, %r3, %r25;
    setp.gt.u32 %p4, %r9, 7;
    @%p4 sub.u32 %r18, %r3, %r3;
    setp.eq.s32 %p4, %r9, 65535;
    @!%p4 and.b32 %r24, %r18, %r9;
    mul.lo.u32 %r13, %r25, %r3;
    mul.wide.u32 %rd8, %r18, %r18;
    sub.u32 %r8, %r13, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
