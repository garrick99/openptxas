.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r23, %r3, %r3;
    and.b32 %r15, %r23, 15;
    sub.u32 %r17, %r15, 15;
    min.s32 %r27, %r15, 15;
    sub.s32 %r22, %r17, 63;
    cvt.s64.s32 %rd6, %r3;
    setp.hs.u32 %p3, %r15, %r17;
    @%p3 min.s32 %r10, %r3, %r3;
    shr.s64 %rd5, %rd6, 48;
    shr.u64 %rd13, %rd5, 63;
    min.s32 %r12, %r27, 8;
    mul.lo.s32 %r11, %r22, %r27;
    shl.b64 %rd13, %rd5, 47;
    mul.lo.u32 %r22, %r3, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
