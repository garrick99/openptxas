.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r27, %r3, %r3, %r3;
    cvt.u64.u32 %rd8, %r3;
    shr.u64 %rd15, %rd8, 48;
    shr.s32 %r24, %r3, 15;
    max.s64 %rd5, %rd8, %rd8;
    shl.b32 %r27, %r24, 3;
    mul.lo.u32 %r18, %r3, 32;
    shl.b32 %r11, %r24, 31;
    mul.lo.s32 %r20, %r24, %r24;
    or.b32 %r9, %r18, 7;
    shr.s32 %r24, %r18, 16;
    max.u32 %r4, %r11, %r11;
    mad.lo.u32 %r6, %r4, %r4, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
