    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    min.s32 %r10, %r3, %r3;
    sub.u64 %rd11, %rd7, %rd7;
    shr.u32 %r24, %r10, 0;
    shr.s32 %r16, %r3, 15;
