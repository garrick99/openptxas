.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r23, %r3, 31;
    setp.ne.u32 %p2, %r23, 4;
    @%p2 sub.s32 %r4, %r3, %r23;
    cvt.s64.s32 %rd10, %r4;
    max.s32 %r9, %r4, 65535;
    selp.b32 %r7, %r4, %r9, %p2;
    sub.s32 %r21, %r4, %r3;
    setp.ne.u32 %p2, %r3, %r7;
    @%p2 or.b32 %r19, %r7, %r23;
    setp.ge.u32 %p2, %r4, %r3;
    @!%p2 max.s32 %r7, %r9, 63;
    setp.ne.s32 %p3, %r7, 2147483647;
    setp.le.u32 %p1, %r19, %r21;
    @%p1 xor.b32 %r19, %r7, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
