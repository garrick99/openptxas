.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r20, %r3, %r3;
    cvt.s64.s32 %rd6, %r3;
    mul.wide.s32 %rd12, %r20, %r20;
    min.u64 %rd7, %rd12, %rd12;
    add.s32 %r9, %r3, 1;
    sub.u32 %r18, %r9, 4;
    shr.u32 %r14, %r9, 16;
    mad.lo.u32 %r18, %r3, %r9, %r18;
    cvt.u64.u32 %rd6, %r20;
    mul.lo.u32 %r16, %r9, %r14;
    shr.u64 %rd6, %rd7, 1;
    min.u32 %r4, %r3, %r3;
    min.s32 %r22, %r18, %r16;
    shr.s64 %rd11, %rd7, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
