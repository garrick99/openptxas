.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r11, %r3, 63;
    min.s32 %r9, %r3, 4294967295;
    setp.le.s32 %p3, %r9, %r9;
    cvt.u64.u32 %rd8, %r3;
    max.u32 %r19, %r9, 1;
    setp.ne.s32 %p2, %r3, %r9;
    setp.hs.u32 %p3, %r11, 4294967295;
    setp.gt.s32 %p2, %r11, 0;
    @!%p2 min.s32 %r27, %r19, %r3;
    min.s32 %r20, %r9, %r11;
    and.b64 %rd7, %rd8, %rd8;
    and.b32 %r18, %r9, 15;
    xor.b32 %r17, %r19, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
