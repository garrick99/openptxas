.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r24, %r3, 16;
    add.u32 %r21, %r24, 1;
    shl.b32 %r15, %r3, 7;
    sub.u32 %r22, %r21, 256;
    mul.wide.s32 %rd10, %r3, %r21;
    shr.u64 %rd5, %rd10, 16;
    mul.lo.u32 %r10, %r3, %r15;
    or.b32 %r15, %r24, 63;
    add.s32 %r6, %r22, 32;
    add.s32 %r15, %r22, %r10;
    cvt.s64.s32 %rd13, %r15;
    cvt.u64.u32 %rd7, %r6;
    setp.le.s32 %p4, %r6, %r3;
    @%p4 selp.b32 %r14, %r24, %r3, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
