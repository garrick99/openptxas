.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r21, %r3, 31;
    cvt.u64.u32 %rd11, %r3;
    add.u64 %rd8, %rd11, %rd11;
    setp.gt.s32 %p1, %r21, 31;
    @%p1 mul.wide.u32 %rd15, %r3, %r3;
    shr.s32 %r13, %r3, 31;
    shr.s32 %r13, %r21, 2;
    setp.ls.u32 %p3, %r13, %r3;
    @%p3 xor.b32 %r25, %r3, 65536;
    cvt.u64.u32 %rd10, %r21;
    setp.gt.u32 %p4, %r25, 64;
    sub.s32 %r11, %r25, 8;
    shr.s64 %rd7, %rd8, 4;
    cvt.u64.u32 %rd7, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
