.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r10, %r3, 0;
    max.u32 %r26, %r10, 2;
    mul.lo.s32 %r22, %r26, %r10;
    sub.u32 %r27, %r3, %r26;
    mad.lo.u32 %r5, %r22, %r27, %r26;
    mul.lo.u32 %r26, %r22, %r22;
    mad.lo.s32 %r5, %r26, %r5, %r10;
    mul.lo.s32 %r15, %r10, 2147483648;
    add.u32 %r20, %r26, 2147483648;
    mul.lo.s32 %r27, %r27, 0;
    mad.lo.u32 %r19, %r15, %r3, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
