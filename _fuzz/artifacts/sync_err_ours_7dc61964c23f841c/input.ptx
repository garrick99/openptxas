.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p3, %r3, 4;
    @%p3 shr.s32 %r19, %r3, 30;
    mul.wide.u32 %rd6, %r3, %r3;
    mul.wide.u32 %rd5, %r19, %r19;
    sub.u32 %r8, %r19, %r19;
    and.b32 %r11, %r8, %r8;
    shl.b64 %rd9, %rd6, 16;
    setp.eq.s32 %p2, %r3, %r3;
    @%p2 add.s32 %r6, %r11, 16;
    add.s32 %r17, %r19, 64;
    shr.u32 %r19, %r11, 31;
    setp.lt.u32 %p4, %r19, %r17;
    @%p4 or.b32 %r10, %r3, 31;
    sub.u32 %r17, %r6, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
