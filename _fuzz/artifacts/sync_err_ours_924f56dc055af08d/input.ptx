.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p4, %r3, 8;
    @!%p4 cvt.u64.u32 %rd12, %r3;
    sub.s32 %r17, %r3, %r3;
    mad.lo.u32 %r22, %r3, %r17, %r17;
    mad.lo.s32 %r10, %r17, %r22, %r3;
    cvt.u32.u64 %r5, %rd12;
    setp.ls.u32 %p3, %r5, 4294967295;
    @%p3 selp.b32 %r13, %r3, %r22, %p4;
    shl.b32 %r12, %r13, 2;
    sub.s64 %rd8, %rd12, %rd12;
    cvt.u32.u64 %r17, %rd12;
    and.b32 %r26, %r17, 15;
    mad.lo.s32 %r9, %r17, %r26, %r10;
    min.s32 %r18, %r17, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
