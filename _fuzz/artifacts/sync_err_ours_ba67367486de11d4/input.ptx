.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r20, %r3, %r3;
    min.s32 %r26, %r20, %r3;
    sub.s32 %r17, %r3, %r26;
    sub.u32 %r19, %r20, 4;
    add.s32 %r16, %r17, %r3;
    setp.hs.u32 %p2, %r3, 64;
    @%p2 shr.s32 %r23, %r16, 2;
    or.b32 %r16, %r3, 3;
    cvt.s64.s32 %rd5, %r17;
    sub.s64 %rd8, %rd5, %rd5;
    setp.le.s32 %p4, %r20, %r3;
    sub.s32 %r27, %r16, %r3;
    add.s32 %r4, %r26, 15;
    add.u32 %r27, %r20, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
