.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r27, %r3, %r3;
    cvt.u64.u32 %rd6, %r3;
    min.u32 %r7, %r27, 31;
    shr.s64 %rd12, %rd6, 0;
    and.b32 %r19, %r7, 5;
    mul.lo.s64 %rd11, %rd12, %rd6;
    mul.wide.u32 %rd7, %r7, %r27;
    min.s32 %r17, %r19, 63;
    cvt.u32.u64 %r25, %rd12;
    max.u32 %r27, %r17, %r7;
    shr.u32 %r4, %r17, 31;
    sub.u64 %rd5, %rd11, %rd7;
    shl.b64 %rd12, %rd11, 33;
    mad.lo.s32 %r19, %r7, %r3, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
