.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    shl.b32 %r27, %r3, 4;
    and.b32 %r16, %r3, %r3;
    setp.hi.u32 %p1, %r3, %r3;
    cvt.u32.u64 %r13, %rd5;
    add.u32 %r13, %r16, %r3;
    xor.b32 %r13, %r13, %r27;
    sub.s32 %r5, %r3, %r13;
    max.u64 %rd9, %rd5, %rd5;
    cvt.u32.u64 %r27, %rd9;
    setp.gt.s32 %p4, %r3, %r5;
    setp.eq.s32 %p2, %r3, 4;
    cvt.s32.s64 %r23, %rd5;
    shl.b32 %r13, %r5, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
