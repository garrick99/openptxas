.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r16, %r3, 4294967295;
    shl.b32 %r11, %r16, 30;
    sub.s32 %r9, %r16, %r3;
    cvt.s64.s32 %rd12, %r3;
    shl.b64 %rd7, %rd12, 30;
    sub.u64 %rd12, %rd7, %rd12;
    shr.u64 %rd13, %rd7, 3;
    add.u64 %rd12, %rd7, %rd7;
    min.u64 %rd12, %rd7, %rd13;
    max.u32 %r10, %r3, %r16;
    max.s32 %r9, %r9, 7;
    add.s32 %r8, %r3, %r16;
    add.s32 %r18, %r10, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
