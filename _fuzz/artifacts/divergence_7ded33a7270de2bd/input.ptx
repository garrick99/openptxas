.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r23, %r3, 63;
    cvt.u64.u32 %rd14, %r23;
    and.b32 %r7, %r23, 65536;
    and.b64 %rd11, %rd14, %rd14;
    min.u64 %rd10, %rd14, %rd14;
    mul.lo.u32 %r18, %r7, 0;
    max.u64 %rd11, %rd10, %rd14;
    setp.hi.u32 %p3, %r18, 15;
    @%p3 mad.lo.s32 %r20, %r3, %r18, %r23;
    setp.ge.s32 %p3, %r7, %r7;
    @%p3 mul.wide.u32 %rd9, %r23, %r7;
    mul.lo.u32 %r11, %r3, %r18;
    add.u32 %r22, %r20, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
