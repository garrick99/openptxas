.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r9, %r3, %r3, %r3;
    setp.le.s32 %p3, %r9, 2;
    @!%p3 cvt.u64.u32 %rd10, %r9;
    add.u32 %r13, %r9, %r3;
    sub.s32 %r11, %r3, 255;
    mul.lo.s64 %rd11, %rd10, %rd10;
    mul.lo.u32 %r4, %r9, 7;
    add.s32 %r16, %r3, %r3;
    mul.wide.s32 %rd7, %r3, %r9;
    mul.wide.u32 %rd13, %r16, %r4;
    or.b32 %r21, %r9, 63;
    add.u32 %r27, %r11, 64;
    xor.b32 %r23, %r11, 32;
    and.b32 %r24, %r11, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
