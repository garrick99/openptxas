.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r20, %r3, 255;
    cvt.s64.s32 %rd8, %r20;
    max.s32 %r8, %r20, 65535;
    min.u32 %r16, %r3, %r8;
    shl.b32 %r10, %r16, 31;
    shr.u32 %r23, %r10, 7;
    mul.lo.u32 %r14, %r10, %r10;
    mul.lo.u32 %r5, %r16, 5;
    sub.u32 %r25, %r3, %r3;
    sub.s32 %r13, %r16, %r14;
    shr.s32 %r22, %r23, 30;
    xor.b32 %r25, %r20, %r5;
    setp.hi.u32 %p2, %r5, 4294967295;
    @%p2 cvt.s32.s64 %r24, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
