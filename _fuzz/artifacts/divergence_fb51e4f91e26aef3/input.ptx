.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r15, %r3, %r3;
    mad.lo.s32 %r8, %r3, %r3, %r15;
    cvt.u64.u32 %rd9, %r8;
    cvt.u64.u32 %rd10, %r15;
    setp.lt.s32 %p2, %r15, 256;
    @%p2 shr.u32 %r19, %r8, 4;
    cvt.s32.s64 %r9, %rd9;
    mul.lo.s32 %r19, %r19, %r3;
    min.s32 %r4, %r9, 65535;
    mad.lo.u32 %r7, %r3, %r9, %r4;
    setp.ge.s32 %p3, %r4, %r4;
    @%p3 shl.b32 %r5, %r4, 30;
    sub.u32 %r15, %r3, %r7;
    min.u32 %r24, %r8, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
