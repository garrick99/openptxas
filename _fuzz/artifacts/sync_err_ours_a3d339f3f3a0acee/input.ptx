.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    and.b64 %rd15, %rd5, %rd5;
    cvt.u64.u32 %rd14, %r3;
    shl.b32 %r26, %r3, 3;
    xor.b32 %r19, %r26, 5;
    cvt.s32.s64 %r17, %rd14;
    sub.u32 %r9, %r19, %r19;
    cvt.u64.u32 %rd6, %r17;
    sub.u32 %r7, %r26, %r26;
    shr.u32 %r20, %r9, 0;
    shr.s64 %rd14, %rd6, 1;
    shr.s32 %r21, %r9, 15;
    cvt.s32.s64 %r7, %rd15;
    add.s32 %r10, %r3, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
