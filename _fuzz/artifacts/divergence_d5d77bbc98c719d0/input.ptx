.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r14, %r3, 5;
    cvt.s64.s32 %rd15, %r14;
    add.s32 %r22, %r14, 3;
    setp.lo.u32 %p3, %r3, 7;
    @%p3 shr.s32 %r6, %r3, 15;
    shr.u64 %rd15, %rd15, 2;
    and.b32 %r25, %r6, 63;
    shr.u64 %rd8, %rd15, 4;
    mul.lo.s32 %r21, %r14, 1;
    min.s64 %rd5, %rd15, %rd15;
    and.b32 %r19, %r25, 2;
    add.s64 %rd7, %rd8, %rd15;
    mad.lo.u32 %r22, %r6, %r25, %r22;
    cvt.s64.s32 %rd11, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
