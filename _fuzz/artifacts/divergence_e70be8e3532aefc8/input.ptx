.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    sub.u32 %r9, %r3, %r3;
    shl.b64 %rd6, %rd12, 32;
    cvt.u64.u32 %rd10, %r3;
    mul.wide.u32 %rd9, %r9, %r3;
    min.s32 %r20, %r3, 7;
    shr.s64 %rd12, %rd9, 7;
    add.u64 %rd13, %rd10, %rd10;
    shr.u64 %rd5, %rd12, 0;
    xor.b32 %r10, %r3, %r9;
    or.b32 %r25, %r20, %r9;
    min.u32 %r21, %r3, %r20;
    mul.lo.s32 %r5, %r10, %r25;
    mad.lo.s32 %r12, %r10, %r20, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
