.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r27, %r3, 3;
    max.s32 %r19, %r27, %r3;
    add.s32 %r13, %r3, %r19;
    cvt.s64.s32 %rd5, %r27;
    min.s32 %r5, %r3, 65535;
    setp.lo.u32 %p1, %r3, %r3;
    add.s32 %r27, %r27, 16;
    setp.ne.s32 %p3, %r3, %r13;
    @%p3 and.b64 %rd12, %rd5, %rd5;
    max.s32 %r23, %r3, 63;
    xor.b64 %rd10, %rd12, %rd12;
    max.u64 %rd8, %rd5, %rd5;
    mul.wide.s32 %rd10, %r3, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
