.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    shl.b32 %r18, %r3, 1;
    mul.wide.s32 %rd5, %r3, %r18;
    mad.lo.u32 %r13, %r18, %r18, %r18;
    mul.wide.s32 %rd8, %r18, %r13;
    shr.u32 %r14, %r13, 15;
    mul.lo.u32 %r13, %r14, 31;
    mul.wide.u32 %rd12, %r13, %r18;
    mul.lo.u32 %r22, %r3, %r13;
    cvt.u64.u32 %rd10, %r14;
    min.u32 %r25, %r22, %r22;
    or.b32 %r9, %r14, 32;
    mul.wide.s32 %rd14, %r22, %r14;
    sub.s32 %r9, %r9, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
