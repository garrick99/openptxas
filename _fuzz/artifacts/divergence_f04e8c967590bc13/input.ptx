.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd14, %r3, %r3;
    add.u32 %r9, %r3, 4294967295;
    min.s32 %r7, %r9, %r9;
    shr.s32 %r15, %r9, 15;
    min.u32 %r23, %r7, %r7;
    sub.s32 %r6, %r15, %r3;
    add.u32 %r18, %r3, %r23;
    sub.u32 %r20, %r15, 32;
    max.s64 %rd5, %rd14, %rd14;
    cvt.s64.s32 %rd8, %r3;
    max.u32 %r16, %r20, 16;
    mul.lo.s32 %r14, %r18, %r7;
    setp.ge.u32 %p4, %r15, %r15;
    mul.lo.u64 %rd14, %rd8, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
