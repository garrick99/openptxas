.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r17, %r0, %r3;
    sub.u32 %r11, %r3, %r3;
    shfl.sync.down.b32 %r4, %r0, 4, 0x1f, -1;
    and.b32 %r6, %r11, %r3;
    sub.u32 %r17, %r3, %r17;
    shfl.sync.down.b32 %r17, %r11, 2, 0x1f, -1;
    setp.lt.u32 %p2, %r11, 31;
    vote.sync.ballot.b32 %r8, %p2, -1;
    min.u32 %r8, %r17, %r11;
    vote.sync.any.pred %p1, %p2, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
