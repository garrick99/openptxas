.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r24, %r3, %r3, %r3;
    cvt.u64.u32 %rd15, %r24;
    max.u32 %r22, %r3, 256;
    min.u32 %r24, %r22, 2147483648;
    add.s32 %r16, %r22, 16;
    cvt.u32.u64 %r27, %rd15;
    shr.s32 %r18, %r22, 30;
    and.b32 %r20, %r24, 65536;
    and.b32 %r25, %r3, 15;
    min.u32 %r8, %r20, 3;
    setp.eq.u32 %p4, %r3, %r8;
    @!%p4 cvt.u32.u64 %r14, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
