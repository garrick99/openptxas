.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd6, %r3, %r3;
    cvt.u64.u32 %rd12, %r3;
    cvt.s32.s64 %r19, %rd12;
    min.u32 %r5, %r19, %r19;
    mul.wide.u32 %rd15, %r3, %r5;
    add.u64 %rd14, %rd12, %rd12;
    max.s32 %r14, %r19, %r5;
    shr.u32 %r27, %r14, 15;
    setp.lt.u32 %p2, %r19, %r5;
    @!%p2 mul.wide.s32 %rd14, %r14, %r3;
    sub.u64 %rd8, %rd14, %rd14;
    xor.b32 %r16, %r14, %r3;
    max.u64 %rd12, %rd6, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
