    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    max.s32 %r25, %r3, %r3;
    or.b32 %r4, %r25, 2147483648;
    max.s32 %r24, %r4, %r25;
    and.b64 %rd10, %rd5, %rd5;
    mul.wide.u32 %rd11, %r3, %r4;
    mul.lo.u64 %rd5, %rd11, %rd10;
    shl.b64 %rd14, %rd10, 3;
    shl.b64 %rd9, %rd5, 62;
    mul.lo.s32 %r21, %r24, %r4;
    mul.lo.u32 %r25, %r24, 2147483648;
    and.b64 %rd8, %rd10, %rd5;
    mad.lo.u32 %r13, %r4, %r24, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
