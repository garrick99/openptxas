.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r17, %r3, %r3;
    min.u32 %r10, %r17, 2;
    max.u32 %r7, %r10, 5;
    cvt.s64.s32 %rd9, %r10;
    max.s32 %r8, %r3, 1;
    mad.lo.s32 %r5, %r10, %r10, %r8;
    or.b32 %r4, %r7, 65535;
    mad.lo.s32 %r23, %r10, %r10, %r3;
    xor.b64 %rd15, %rd9, %rd9;
    cvt.s64.s32 %rd8, %r4;
    mad.lo.u32 %r4, %r10, %r5, %r7;
    mul.wide.s32 %rd7, %r10, %r17;
    shr.u64 %rd8, %rd9, 48;
    mul.lo.s32 %r22, %r8, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
