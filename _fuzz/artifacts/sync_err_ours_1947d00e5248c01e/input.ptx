.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r10, %r3, 0;
    cvt.u64.u32 %rd14, %r3;
    xor.b32 %r14, %r3, 7;
    add.s32 %r5, %r14, %r3;
    xor.b32 %r22, %r5, %r3;
    xor.b64 %rd7, %rd14, %rd14;
    sub.u32 %r23, %r14, 32;
    setp.le.u32 %p1, %r10, %r22;
    @%p1 cvt.s32.s64 %r6, %rd7;
    mul.wide.s32 %rd11, %r3, %r6;
    shr.s32 %r18, %r22, 31;
    min.u32 %r24, %r22, %r22;
    shl.b32 %r10, %r23, 15;
    max.u32 %r16, %r14, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
