.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r23, %r3, %r3, %r3;
    mad.lo.u32 %r22, %r23, %r23, %r3;
    max.s32 %r22, %r23, 63;
    min.s32 %r15, %r22, 255;
    or.b32 %r10, %r22, 64;
    add.u32 %r14, %r10, %r22;
    max.s32 %r15, %r14, %r15;
    cvt.u64.u32 %rd12, %r10;
    or.b32 %r20, %r22, %r15;
    shl.b64 %rd13, %rd12, 30;
    shr.u32 %r27, %r15, 3;
    setp.le.u32 %p3, %r3, %r14;
    @!%p3 max.s32 %r25, %r20, %r10;
    sub.s32 %r19, %r15, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
