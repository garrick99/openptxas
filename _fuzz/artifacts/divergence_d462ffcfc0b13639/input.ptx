.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p3, %r3, %r3;
    @%p3 sub.s32 %r6, %r3, 4;
    shl.b32 %r8, %r3, 4;
    cvt.s64.s32 %rd15, %r3;
    sub.s64 %rd8, %rd15, %rd15;
    cvt.s32.s64 %r14, %rd15;
    add.u64 %rd11, %rd8, %rd15;
    mul.lo.u32 %r20, %r8, 256;
    max.u32 %r10, %r3, %r14;
    shr.u32 %r17, %r6, 1;
    min.u32 %r5, %r17, %r10;
    selp.b32 %r16, %r3, %r6, %p3;
    shl.b64 %rd11, %rd15, 63;
    shr.u32 %r14, %r17, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
