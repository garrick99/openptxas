.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r26, %r3, 16;
    shr.s32 %r17, %r3, 30;
    cvt.s64.s32 %rd6, %r26;
    shr.s64 %rd9, %rd6, 2;
    shr.s64 %rd11, %rd9, 30;
    max.s32 %r21, %r17, 64;
    max.s64 %rd10, %rd9, %rd6;
    shl.b32 %r10, %r21, 31;
    max.u64 %rd11, %rd11, %rd10;
    shr.u32 %r24, %r21, 16;
    sub.u32 %r12, %r10, %r24;
    setp.le.u32 %p3, %r26, 32;
    @!%p3 max.s32 %r15, %r10, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
