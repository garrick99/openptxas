.version 9.0
.target sm_120
.address_size 64

.visible .entry bra_test(
    .param .u64 out_ptr,
    .param .u32 n)
{
    .reg .b32   %r<4>;
    .reg .b64   %rd<4>;
    .reg .pred  %p0;

    // out[tid.x] = tid.x if tid.x < n, else unchanged
    mov.u32         %r0, %tid.x;
    ld.param.u32    %r1, [n];
    setp.ge.u32     %p0, %r0, %r1;
    @%p0 bra        DONE;

    cvt.u64.u32     %rd0, %r0;
    shl.b64         %rd0, %rd0, 2;
    ld.param.u64    %rd1, [out_ptr];
    add.u64         %rd2, %rd1, %rd0;
    st.global.u32   [%rd2], %r0;
DONE:
    ret;
}
