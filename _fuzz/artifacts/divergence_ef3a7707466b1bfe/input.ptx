.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r25, %r3, %r3;
    mad.lo.s32 %r10, %r3, %r25, %r3;
    sub.u32 %r4, %r25, 16;
    setp.le.s32 %p3, %r4, 7;
    @%p3 selp.b32 %r5, %r25, %r10, %p3;
    cvt.s64.s32 %rd13, %r25;
    max.s64 %rd6, %rd13, %rd13;
    selp.b32 %r22, %r25, %r25, %p3;
    mad.lo.s32 %r5, %r25, %r3, %r3;
    shr.s32 %r25, %r3, 30;
    min.u32 %r25, %r22, %r25;
    selp.b32 %r24, %r4, %r25, %p3;
    and.b32 %r20, %r25, %r10;
    sub.u64 %rd10, %rd6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
