.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    cvt.u32.u64 %r24, %rd11;
    setp.gt.s32 %p2, %r3, 4;
    @!%p2 xor.b32 %r5, %r24, 63;
    setp.eq.s32 %p1, %r5, 4;
    @!%p1 xor.b64 %rd5, %rd11, %rd11;
    shr.s64 %rd14, %rd5, 4;
    shr.s32 %r16, %r24, 1;
    min.u32 %r16, %r5, 4294967295;
    min.u32 %r21, %r16, %r5;
    add.u64 %rd6, %rd5, %rd5;
    sub.s32 %r7, %r3, %r21;
    sub.s32 %r7, %r3, %r3;
    max.u32 %r17, %r7, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
