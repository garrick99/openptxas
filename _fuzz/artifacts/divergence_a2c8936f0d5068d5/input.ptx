.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r20, %r3, %r3;
    setp.lo.u32 %p2, %r20, %r3;
    @%p2 or.b32 %r22, %r20, 0;
    max.u32 %r11, %r3, 31;
    setp.le.s32 %p4, %r11, 32;
    add.u32 %r11, %r3, 5;
    mul.lo.u32 %r20, %r22, %r22;
    max.s32 %r18, %r3, %r20;
    cvt.u64.u32 %rd6, %r11;
    cvt.s32.s64 %r9, %rd6;
    sub.s32 %r13, %r9, 63;
    shr.u64 %rd8, %rd6, 0;
    min.u32 %r12, %r18, 255;
    and.b32 %r16, %r13, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
