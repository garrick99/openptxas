.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r16, %r3, %r3;
    cvt.u64.u32 %rd12, %r16;
    shr.u64 %rd14, %rd12, 15;
    mul.lo.u32 %r13, %r16, %r3;
    mul.lo.u32 %r12, %r3, 32;
    shr.u32 %r18, %r16, 16;
    min.s32 %r25, %r13, %r13;
    add.s32 %r15, %r12, %r13;
    shl.b32 %r14, %r3, 16;
    xor.b32 %r16, %r13, 32;
    add.s32 %r17, %r18, %r18;
    sub.u32 %r14, %r15, %r17;
    shr.s64 %rd7, %rd14, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
