.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r5, %r3, %r3;
    add.s32 %r8, %r3, 5;
    cvt.u64.u32 %rd7, %r8;
    shr.u32 %r16, %r8, 16;
    cvt.u64.u32 %rd9, %r16;
    mul.lo.u32 %r26, %r16, 7;
    min.s64 %rd9, %rd7, %rd9;
    mul.wide.s32 %rd5, %r5, %r26;
    mul.wide.u32 %rd7, %r16, %r16;
    setp.ge.u32 %p2, %r3, 16;
    @%p2 max.u32 %r27, %r8, %r5;
    max.s32 %r6, %r27, 63;
    shr.s64 %rd7, %rd9, 15;
    cvt.u64.u32 %rd14, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
