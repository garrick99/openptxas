.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd13, %r3, %r3;
    setp.le.s32 %p3, %r3, 65536;
    @%p3 xor.b64 %rd12, %rd13, %rd13;
    cvt.s32.s64 %r15, %rd12;
    max.u32 %r20, %r3, %r15;
    shr.s32 %r21, %r15, 15;
    or.b64 %rd7, %rd13, %rd13;
    selp.b32 %r9, %r21, %r21, %p3;
    sub.s32 %r23, %r21, 8;
    mul.lo.s32 %r25, %r21, %r21;
    xor.b32 %r8, %r9, 16;
    max.s64 %rd12, %rd7, %rd13;
    selp.b32 %r27, %r23, %r20, %p3;
    mul.wide.s32 %rd12, %r25, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
