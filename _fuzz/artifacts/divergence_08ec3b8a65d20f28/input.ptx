.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p1, %r3, %r3;
    @%p1 max.s32 %r17, %r3, 256;
    max.u32 %r12, %r17, 32;
    mul.lo.s32 %r10, %r12, %r3;
    selp.b32 %r17, %r17, %r10, %p1;
    mad.lo.s32 %r14, %r3, %r3, %r3;
    sub.u32 %r5, %r12, 2;
    min.u32 %r22, %r14, 65535;
    cvt.u64.u32 %rd9, %r10;
    cvt.u32.u64 %r4, %rd9;
    shl.b64 %rd13, %rd9, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
