.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r24, %r3, %r3;
    mul.lo.u32 %r27, %r24, %r24;
    or.b32 %r10, %r27, 2147483647;
    cvt.u64.u32 %rd8, %r27;
    cvt.s32.s64 %r15, %rd8;
    mul.wide.s32 %rd11, %r15, %r3;
    add.s32 %r21, %r3, %r24;
    mul.lo.s64 %rd13, %rd11, %rd11;
    cvt.u32.u64 %r7, %rd11;
    setp.le.u32 %p1, %r10, %r3;
    @%p1 xor.b32 %r7, %r7, 15;
    min.u32 %r9, %r15, %r21;
    add.s32 %r16, %r7, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
