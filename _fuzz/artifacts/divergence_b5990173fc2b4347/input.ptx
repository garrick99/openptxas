.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r27, %r3, %r3;
    or.b32 %r21, %r3, 2147483648;
    cvt.u64.u32 %rd10, %r21;
    add.u32 %r27, %r27, 1;
    setp.eq.s32 %p2, %r21, %r21;
    @!%p2 mad.lo.s32 %r6, %r27, %r3, %r3;
    shr.s64 %rd7, %rd10, 15;
    min.s64 %rd11, %rd10, %rd10;
    shl.b64 %rd10, %rd11, 16;
    selp.b32 %r23, %r6, %r27, %p2;
    shr.s64 %rd8, %rd7, 63;
    add.s32 %r24, %r21, 2;
    add.u32 %r10, %r6, 2;
    cvt.s64.s32 %rd14, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
