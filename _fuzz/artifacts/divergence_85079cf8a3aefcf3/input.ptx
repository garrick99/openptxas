.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r20, %r3, %r3;
    mul.wide.s32 %rd5, %r20, %r20;
    add.s32 %r15, %r20, %r3;
    or.b64 %rd9, %rd5, %rd5;
    setp.hi.u32 %p1, %r20, %r20;
    @%p1 sub.s32 %r7, %r20, %r15;
    add.s32 %r21, %r15, %r3;
    mul.lo.u32 %r23, %r21, %r20;
    add.s64 %rd5, %rd9, %rd5;
    shr.u64 %rd7, %rd9, 47;
    or.b32 %r7, %r15, 15;
    cvt.u64.u32 %rd10, %r23;
    selp.b32 %r27, %r3, %r21, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
