.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r5, %r3, 2;
    setp.ne.s32 %p4, %r5, %r5;
    mul.wide.s32 %rd8, %r5, %r3;
    mul.lo.u64 %rd6, %rd8, %rd8;
    and.b32 %r20, %r3, %r3;
    min.s32 %r24, %r3, %r3;
    setp.ls.u32 %p3, %r20, 4294967295;
    cvt.u32.u64 %r27, %rd6;
    max.u32 %r4, %r3, %r5;
    sub.s32 %r11, %r5, 65535;
    min.s32 %r9, %r11, 0;
    selp.b32 %r4, %r3, %r5, %p4;
    max.s32 %r10, %r24, %r20;
    selp.b32 %r17, %r5, %r11, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
