.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p3, %r3, %r3;
    @%p3 xor.b32 %r11, %r3, %r3;
    setp.ne.s32 %p3, %r11, 255;
    setp.ls.u32 %p2, %r11, %r3;
    @%p2 max.u32 %r4, %r11, %r11;
    setp.ne.s32 %p2, %r11, 32;
    @%p2 cvt.s64.s32 %rd14, %r4;
    max.s32 %r14, %r11, 31;
    shr.u64 %rd15, %rd14, 33;
    mul.wide.s32 %rd9, %r11, %r14;
    mul.wide.s32 %rd10, %r11, %r4;
    min.u64 %rd15, %rd14, %rd9;
    sub.u32 %r17, %r14, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
