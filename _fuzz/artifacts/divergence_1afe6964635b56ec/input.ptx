.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r6, %r3, 65535;
    setp.gt.s32 %p1, %r3, %r6;
    @!%p1 shr.u32 %r18, %r3, 31;
    selp.b32 %r4, %r6, %r18, %p1;
    shr.s32 %r20, %r4, 0;
    shr.s32 %r25, %r20, 0;
    and.b32 %r19, %r3, %r20;
    mad.lo.u32 %r14, %r20, %r20, %r20;
    cvt.s64.s32 %rd9, %r20;
    xor.b32 %r8, %r20, %r18;
    min.s32 %r23, %r14, %r6;
    max.u32 %r17, %r3, %r14;
    mul.wide.s32 %rd12, %r18, %r3;
    cvt.s32.s64 %r4, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
