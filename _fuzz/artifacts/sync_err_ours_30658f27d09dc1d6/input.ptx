    mul.lo.s32 %r17, %r22, %r21;
    cvt.s32.s64 %r7, %rd12;
    mul.lo.s32 %r24, %r22, %r3;
    shl.b32 %r11, %r24, 16;
    max.s32 %r11, %r7, %r11;
    mul.lo.s32 %r5, %r11, 2147483647;
    min.s64 %rd8, %rd12, %rd14;
    mul.wide.s32 %rd8, %r5, %r24;
