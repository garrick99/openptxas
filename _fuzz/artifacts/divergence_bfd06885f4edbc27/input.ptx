.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r25, %r3, %r3;
    sub.u32 %r20, %r3, 15;
    mul.lo.u32 %r27, %r25, %r3;
    mul.wide.s32 %rd6, %r3, %r20;
    mul.wide.u32 %rd12, %r25, %r20;
    min.u32 %r5, %r20, %r27;
    mul.wide.s32 %rd13, %r3, %r20;
    mul.lo.s32 %r16, %r5, 65535;
    setp.ne.s32 %p3, %r16, %r27;
    @%p3 mul.lo.s32 %r20, %r3, %r25;
    cvt.s64.s32 %rd12, %r5;
    mul.lo.u32 %r8, %r27, 2147483647;
    add.s32 %r11, %r3, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
