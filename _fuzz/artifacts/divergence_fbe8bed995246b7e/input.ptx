.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r20, %r3, %r3;
    shr.s32 %r17, %r20, 0;
    mad.lo.s32 %r15, %r20, %r3, %r20;
    min.u32 %r6, %r3, %r17;
    max.s32 %r25, %r3, 255;
    setp.ge.s32 %p2, %r15, 1;
    @%p2 sub.u32 %r14, %r15, %r17;
    mad.lo.u32 %r4, %r15, %r25, %r6;
    sub.s32 %r23, %r20, %r6;
    selp.b32 %r9, %r17, %r17, %p2;
    cvt.u64.u32 %rd8, %r14;
    cvt.s64.s32 %rd5, %r14;
    cvt.u32.u64 %r25, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
