.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r20, %r3, 7;
    max.u32 %r17, %r20, 4294967295;
    min.u32 %r19, %r20, 64;
    min.u32 %r24, %r19, 4;
    mul.lo.u32 %r16, %r24, 4294967295;
    setp.hi.u32 %p3, %r19, %r20;
    @%p3 mad.lo.s32 %r12, %r3, %r20, %r16;
    selp.b32 %r17, %r24, %r16, %p3;
    min.u32 %r20, %r16, %r16;
    max.u32 %r13, %r16, %r24;
    mad.lo.s32 %r4, %r16, %r12, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
