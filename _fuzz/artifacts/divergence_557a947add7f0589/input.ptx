.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r20, %r3, %r3, %r3;
    and.b32 %r22, %r3, %r20;
    cvt.s64.s32 %rd12, %r22;
    setp.ls.u32 %p2, %r20, %r22;
    @%p2 sub.u32 %r15, %r20, 7;
    add.u32 %r23, %r22, 4294967295;
    shr.s64 %rd12, %rd12, 7;
    xor.b32 %r16, %r15, %r20;
    or.b64 %rd13, %rd12, %rd12;
    add.s32 %r7, %r23, 15;
    and.b32 %r10, %r3, %r15;
    mad.lo.u32 %r4, %r22, %r22, %r16;
    max.u64 %rd13, %rd13, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
