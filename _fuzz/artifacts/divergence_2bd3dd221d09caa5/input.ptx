.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    cvt.s64.s32 %rd9, %r3;
    max.u32 %r16, %r3, %r3;
    setp.lo.u32 %p4, %r16, 2;
    add.s32 %r27, %r16, 3;
    selp.b32 %r10, %r27, %r3, %p4;
    cvt.u32.u64 %r5, %rd12;
    mul.lo.u32 %r23, %r3, 65536;
    mad.lo.s32 %r17, %r10, %r23, %r10;
    mul.lo.s32 %r17, %r5, %r27;
    cvt.s32.s64 %r16, %rd12;
    sub.s32 %r9, %r10, 5;
    mul.wide.s32 %rd15, %r3, %r5;
    mul.lo.s64 %rd14, %rd12, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
