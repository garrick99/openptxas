.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r22, %r3, %r3;
    max.s32 %r13, %r22, %r22;
    shr.s32 %r6, %r3, 15;
    setp.ge.u32 %p4, %r3, 65536;
    @%p4 shr.u32 %r14, %r22, 16;
    mul.wide.u32 %rd8, %r14, %r13;
    min.s32 %r18, %r3, 2;
    shr.u32 %r11, %r13, 15;
    selp.b32 %r13, %r22, %r13, %p4;
    add.u32 %r10, %r3, %r18;
    mad.lo.s32 %r9, %r10, %r3, %r22;
    mul.wide.u32 %rd11, %r22, %r11;
    min.u64 %rd6, %rd8, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
