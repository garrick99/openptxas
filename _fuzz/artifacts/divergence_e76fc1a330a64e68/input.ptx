.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    cvt.u32.u64 %r12, %rd5;
    shl.b64 %rd14, %rd5, 0;
    shl.b32 %r6, %r3, 0;
    min.s32 %r27, %r12, 31;
    shr.s32 %r9, %r27, 1;
    shr.s32 %r19, %r12, 4;
    mad.lo.s32 %r20, %r3, %r27, %r19;
    mul.wide.s32 %rd5, %r6, %r12;
    max.s32 %r21, %r27, %r9;
    setp.ge.s32 %p4, %r3, %r9;
    @%p4 or.b32 %r23, %r3, 4294967295;
    min.s32 %r23, %r23, %r9;
    setp.ls.u32 %p1, %r12, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
