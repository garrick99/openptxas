.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r5, %r3, %r3;
    cvt.s64.s32 %rd5, %r3;
    max.s32 %r14, %r5, 16;
    mul.wide.u32 %rd8, %r14, %r14;
    setp.ne.s32 %p3, %r14, %r3;
    mul.wide.s32 %rd10, %r5, %r14;
    setp.ls.u32 %p4, %r14, 15;
    sub.s64 %rd14, %rd10, %rd5;
    min.s64 %rd14, %rd14, %rd8;
    selp.b32 %r13, %r3, %r14, %p4;
    selp.b32 %r23, %r3, %r5, %p4;
    mul.wide.u32 %rd7, %r14, %r13;
    cvt.u32.u64 %r17, %rd5;
    shr.u32 %r27, %r23, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
