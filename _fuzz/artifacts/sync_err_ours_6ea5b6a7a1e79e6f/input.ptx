.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    sub.s64 %rd8, %rd15, %rd15;
    shr.s32 %r11, %r3, 16;
    mul.wide.s32 %rd13, %r11, %r11;
    sub.u32 %r21, %r3, %r3;
    setp.lt.u32 %p3, %r3, 15;
    @!%p3 min.u32 %r27, %r11, %r21;
    add.u32 %r21, %r11, 8;
    cvt.s32.s64 %r19, %rd13;
    add.s32 %r9, %r3, %r3;
    or.b32 %r22, %r19, %r19;
    shl.b64 %rd6, %rd15, 2;
    xor.b32 %r26, %r21, %r9;
    setp.le.s32 %p1, %r3, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
