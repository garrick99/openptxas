.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    shl.b32 %r17, %r3, 15;
    mul.lo.u32 %r6, %r3, %r17;
    min.u32 %r4, %r17, %r3;
    mul.wide.u32 %rd13, %r17, %r3;
    shr.s32 %r14, %r17, 4;
    or.b32 %r19, %r14, %r17;
    cvt.u64.u32 %rd13, %r4;
    or.b32 %r6, %r17, %r4;
    min.s32 %r18, %r4, 7;
    and.b32 %r24, %r19, %r18;
    shr.u32 %r22, %r4, 3;
    sub.s32 %r21, %r19, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
