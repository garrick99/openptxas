.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r17, %r3, %r3;
    or.b32 %r12, %r3, 8;
    setp.lt.s32 %p3, %r17, %r3;
    @%p3 cvt.u64.u32 %rd8, %r17;
    min.u64 %rd10, %rd8, %rd8;
    mul.wide.u32 %rd13, %r3, %r12;
    or.b32 %r20, %r12, %r17;
    mul.wide.u32 %rd8, %r20, %r3;
    max.s32 %r26, %r17, %r17;
    shr.s64 %rd14, %rd13, 7;
    mad.lo.s32 %r14, %r17, %r3, %r20;
    min.u32 %r4, %r17, %r17;
    mad.lo.u32 %r5, %r14, %r20, %r4;
    cvt.u32.u64 %r26, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
