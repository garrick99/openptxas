.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    add.s32 %r5, %r3, %r3;
    cvt.s64.s32 %rd10, %r5;
    and.b32 %r10, %r3, %r5;
    mul.wide.u32 %rd11, %r10, %r3;
    min.u64 %rd6, %rd11, %rd11;
    or.b32 %r12, %r5, %r3;
    cvt.u64.u32 %rd5, %r3;
    mad.lo.u32 %r21, %r5, %r3, %r5;
    sub.s32 %r16, %r3, %r5;
    xor.b32 %r22, %r21, %r3;
    add.s32 %r16, %r3, %r10;
    or.b32 %r13, %r16, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
