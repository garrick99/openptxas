.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r25, %r3, 4;
    sub.u32 %r13, %r3, %r25;
    setp.gt.s32 %p4, %r25, 5;
    @%p4 shr.u32 %r6, %r25, 16;
    cvt.u64.u32 %rd5, %r6;
    add.s32 %r8, %r6, %r6;
    shr.u32 %r9, %r25, 7;
    shr.u64 %rd12, %rd5, 47;
    selp.b32 %r17, %r9, %r9, %p4;
    selp.b32 %r8, %r8, %r3, %p4;
    add.u32 %r21, %r8, 31;
    shr.s32 %r9, %r21, 16;
    cvt.s64.s32 %rd14, %r17;
    mad.lo.s32 %r5, %r9, %r9, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
