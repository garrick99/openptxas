    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    min.s32 %r19, %r3, %r3;
    shr.u32 %r22, %r3, 31;
    mad.lo.s32 %r5, %r19, %r3, %r3;
    mul.lo.s32 %r16, %r5, 4294967295;
    and.b32 %r20, %r3, %r16;
    mul.lo.s32 %r11, %r5, %r22;
    mul.wide.u32 %rd13, %r20, %r3;
    shl.b32 %r19, %r11, 30;
    cvt.u32.u64 %r7, %rd13;
    shr.s32 %r16, %r22, 30;
    cvt.u32.u64 %r23, %rd13;
    max.s32 %r13, %r20, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
