.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r14, %r3, %r3;
    cvt.u64.u32 %rd11, %r14;
    cvt.s32.s64 %r12, %rd11;
    setp.hi.u32 %p2, %r3, 31;
    sub.s32 %r11, %r14, %r12;
    setp.hi.u32 %p2, %r12, 255;
    setp.ne.s32 %p1, %r14, %r14;
    @%p1 cvt.u32.u64 %r16, %rd11;
    and.b64 %rd12, %rd11, %rd11;
    xor.b32 %r10, %r12, %r12;
    cvt.u32.u64 %r11, %rd11;
    or.b64 %rd12, %rd11, %rd11;
    selp.b32 %r20, %r14, %r11, %p2;
    cvt.u32.u64 %r22, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
