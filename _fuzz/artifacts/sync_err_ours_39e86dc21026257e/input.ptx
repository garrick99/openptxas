.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r26, %r3, %r3;
    or.b32 %r15, %r3, %r26;
    mul.lo.u32 %r13, %r15, 255;
    shr.u32 %r11, %r26, 1;
    min.u32 %r15, %r3, 3;
    cvt.s64.s32 %rd10, %r11;
    min.s64 %rd12, %rd10, %rd10;
    cvt.u64.u32 %rd14, %r13;
    shl.b32 %r5, %r3, 3;
    and.b32 %r13, %r11, %r15;
    or.b32 %r25, %r13, 3;
    mul.lo.u32 %r14, %r13, %r26;
    setp.gt.s32 %p1, %r14, 0;
    mul.lo.s32 %r26, %r13, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
