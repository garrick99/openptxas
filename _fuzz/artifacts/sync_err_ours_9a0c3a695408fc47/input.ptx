.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    min.u32 %r26, %r3, %r3;
    xor.b32 %r16, %r26, %r26;
    sub.u32 %r8, %r26, 7;
    cvt.s64.s32 %rd13, %r3;
    max.s32 %r25, %r3, 31;
    add.u32 %r8, %r8, %r26;
    setp.gt.u32 %p1, %r25, 65535;
    @%p1 mad.lo.s32 %r14, %r3, %r3, %r26;
    shr.u32 %r22, %r3, 15;
    mad.lo.s32 %r17, %r14, %r8, %r25;
    selp.b32 %r17, %r8, %r14, %p1;
    setp.ne.u32 %p4, %r26, %r8;
    @%p4 shr.u32 %r8, %r26, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
