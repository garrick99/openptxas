.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p3, %r3, 4294967295;
    @%p3 max.u32 %r7, %r3, %r3;
    sub.s32 %r13, %r3, 31;
    add.s32 %r14, %r13, 0;
    mul.wide.u32 %rd10, %r14, %r7;
    mad.lo.u32 %r17, %r14, %r7, %r3;
    max.u64 %rd8, %rd10, %rd10;
    setp.ne.u32 %p4, %r17, 2147483647;
    @%p4 mul.wide.s32 %rd9, %r3, %r14;
    mul.lo.u32 %r22, %r13, 2147483648;
    add.u32 %r17, %r22, 5;
    setp.gt.s32 %p4, %r14, 31;
    @%p4 and.b32 %r18, %r22, %r14;
    mul.lo.u64 %rd5, %rd10, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
