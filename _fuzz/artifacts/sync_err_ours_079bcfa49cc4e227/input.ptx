.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    or.b32 %r20, %r3, %r3;
    setp.gt.s32 %p2, %r20, %r20;
    add.s32 %r8, %r20, %r3;
    sub.u32 %r8, %r20, %r20;
    sub.s32 %r11, %r8, %r3;
    shl.b32 %r12, %r8, 15;
    min.s32 %r26, %r11, %r20;
    shr.u64 %rd8, %rd5, 7;
    max.u32 %r4, %r26, 256;
    mul.wide.u32 %rd10, %r11, %r20;
    shl.b32 %r26, %r8, 16;
    and.b32 %r7, %r12, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
