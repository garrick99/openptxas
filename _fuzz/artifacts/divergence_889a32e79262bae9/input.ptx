.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r16, %r3, 63;
    max.s32 %r25, %r16, %r3;
    mad.lo.s32 %r16, %r16, %r16, %r16;
    shr.s32 %r23, %r25, 15;
    shr.s32 %r14, %r23, 7;
    shr.s32 %r16, %r14, 7;
    mul.wide.u32 %rd5, %r25, %r16;
    setp.gt.u32 %p1, %r25, 4;
    @!%p1 mul.lo.u64 %rd13, %rd5, %rd5;
    mul.lo.s32 %r9, %r3, %r23;
    shr.u32 %r10, %r3, 31;
    setp.lo.u32 %p2, %r16, 31;
    @%p2 max.s32 %r24, %r3, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
