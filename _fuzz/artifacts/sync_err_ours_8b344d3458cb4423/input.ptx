.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd15, %r3, %r3;
    mul.wide.u32 %rd5, %r3, %r3;
    xor.b32 %r21, %r3, 64;
    mul.lo.u32 %r11, %r21, %r3;
    mad.lo.s32 %r27, %r21, %r3, %r21;
    shr.s64 %rd6, %rd15, 48;
    and.b32 %r10, %r3, 7;
    mul.lo.s64 %rd8, %rd15, %rd15;
    shl.b32 %r8, %r21, 2;
    cvt.u64.u32 %rd8, %r11;
    shr.u64 %rd9, %rd8, 3;
    setp.ge.u32 %p2, %r3, 4294967295;
    @!%p2 mul.lo.u64 %rd9, %rd15, %rd8;
    sub.u32 %r26, %r8, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
