.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r8, %r3, 15;
    add.s32 %r8, %r8, 255;
    or.b32 %r23, %r3, 16;
    mul.wide.u32 %rd5, %r23, %r23;
    sub.s32 %r15, %r23, 256;
    sub.s32 %r26, %r3, %r3;
    shr.u64 %rd9, %rd5, 7;
    mul.wide.u32 %rd11, %r26, %r3;
    mad.lo.u32 %r19, %r15, %r3, %r15;
    xor.b32 %r17, %r15, 256;
    max.s32 %r11, %r23, %r23;
    setp.le.s32 %p4, %r15, 7;
    @!%p4 add.u32 %r8, %r3, %r11;
    setp.ge.s32 %p1, %r3, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
