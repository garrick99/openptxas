.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r21, %r3, %r3;
    setp.lt.u32 %p1, %r21, %r21;
    @%p1 mul.lo.s32 %r17, %r21, %r3;
    sub.s32 %r13, %r21, 63;
    selp.b32 %r11, %r17, %r21, %p1;
    min.s32 %r14, %r11, 63;
    selp.b32 %r11, %r17, %r3, %p1;
    setp.lo.u32 %p2, %r13, %r17;
    @!%p2 shl.b32 %r11, %r11, 31;
    min.s32 %r16, %r11, 63;
    mad.lo.u32 %r11, %r11, %r17, %r21;
    cvt.s64.s32 %rd10, %r17;
    mul.wide.s32 %rd7, %r14, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
