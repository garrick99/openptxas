.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r14, %r3, 4;
    or.b32 %r7, %r3, 3;
    setp.lo.u32 %p4, %r3, %r14;
    shr.s32 %r21, %r3, 4;
    setp.hs.u32 %p1, %r3, 4294967295;
    @%p1 min.s32 %r21, %r7, 5;
    shr.s32 %r4, %r7, 0;
    mul.lo.u32 %r7, %r7, 4294967295;
    sub.u32 %r22, %r21, %r4;
    sub.u32 %r24, %r14, 0;
    cvt.u64.u32 %rd9, %r7;
    shr.u32 %r10, %r22, 4;
    selp.b32 %r7, %r14, %r3, %p4;
    sub.u64 %rd11, %rd9, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
