    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p4, %r3, %r3;
    shr.u32 %r9, %r3, 1;
    mul.wide.u32 %rd15, %r9, %r3;
