.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r14, %r3, %r3;
    sub.s32 %r12, %r3, %r14;
    cvt.s64.s32 %rd13, %r12;
    mad.lo.u32 %r5, %r14, %r3, %r3;
    shl.b64 %rd15, %rd13, 4;
    setp.ne.u32 %p3, %r5, %r3;
    @%p3 max.u32 %r12, %r12, %r14;
    and.b32 %r22, %r12, %r3;
    xor.b64 %rd14, %rd13, %rd13;
    mad.lo.u32 %r19, %r22, %r22, %r3;
    min.s64 %rd7, %rd15, %rd13;
    cvt.s32.s64 %r4, %rd14;
    setp.le.u32 %p4, %r14, %r19;
    @%p4 mad.lo.u32 %r11, %r14, %r22, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
