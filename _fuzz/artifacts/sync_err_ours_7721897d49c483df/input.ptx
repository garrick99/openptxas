.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r23, %r3, %r3;
    cvt.s64.s32 %rd15, %r23;
    shr.u32 %r15, %r23, 15;
    shr.u64 %rd7, %rd15, 15;
    mad.lo.s32 %r22, %r23, %r15, %r15;
    shr.u64 %rd6, %rd7, 0;
    mul.wide.s32 %rd5, %r23, %r23;
    mul.wide.s32 %rd11, %r22, %r22;
    shr.s32 %r22, %r15, 2;
    sub.s64 %rd15, %rd15, %rd11;
    mul.wide.u32 %rd11, %r15, %r23;
    shr.u32 %r25, %r15, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
