.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r14, %r3, %r3;
    min.s32 %r19, %r3, 63;
    shr.u32 %r26, %r19, 30;
    add.s32 %r16, %r19, 64;
    add.u32 %r19, %r19, %r3;
    add.u32 %r14, %r3, %r26;
    sub.u32 %r17, %r3, 65535;
    shl.b32 %r12, %r14, 31;
    cvt.u64.u32 %rd5, %r3;
    min.s32 %r6, %r26, 256;
    mul.lo.s32 %r17, %r17, 65535;
    xor.b32 %r22, %r26, 1;
    cvt.u32.u64 %r23, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
