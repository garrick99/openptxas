.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r18, %r3, %r3, %r3;
    setp.gt.u32 %p1, %r3, %r3;
    @%p1 shl.b32 %r4, %r3, 0;
    mul.wide.s32 %rd6, %r3, %r4;
    or.b32 %r18, %r4, 31;
    mad.lo.u32 %r9, %r4, %r18, %r4;
    cvt.s32.s64 %r18, %rd6;
    cvt.s32.s64 %r4, %rd6;
    setp.ne.s32 %p4, %r4, 4;
    min.u64 %rd10, %rd6, %rd6;
    and.b32 %r19, %r18, %r4;
    mul.wide.u32 %rd11, %r9, %r19;
    shr.u32 %r9, %r19, 30;
    add.s32 %r17, %r18, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
