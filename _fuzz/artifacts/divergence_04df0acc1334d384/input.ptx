.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    setp.eq.u32 %p3, %r3, 63;
    @!%p3 xor.b32 %r11, %r3, %r3;
    shr.s64 %rd13, %rd13, 16;
    setp.hs.u32 %p4, %r11, 255;
    @%p4 mul.wide.s32 %rd14, %r3, %r11;
    shr.s32 %r9, %r3, 2;
    or.b32 %r25, %r9, 2147483647;
    add.u32 %r20, %r11, 2;
    mul.lo.u32 %r14, %r25, 4294967295;
    add.u64 %rd10, %rd14, %rd13;
    shl.b32 %r22, %r14, 3;
    cvt.s32.s64 %r21, %rd14;
    mul.lo.u32 %r17, %r14, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
