.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r5, %r3, 8;
    mul.wide.u32 %rd6, %r5, %r5;
    or.b32 %r14, %r5, 16;
    cvt.s32.s64 %r27, %rd6;
    setp.eq.u32 %p4, %r3, 256;
    @%p4 sub.u32 %r8, %r27, %r3;
    mad.lo.s32 %r12, %r14, %r3, %r8;
    mul.wide.s32 %rd14, %r3, %r14;
    min.s32 %r21, %r12, 4294967295;
    setp.ls.u32 %p3, %r27, 255;
    @%p3 min.u32 %r17, %r14, %r5;
    min.s32 %r25, %r5, %r5;
    shr.u32 %r20, %r5, 15;
    mul.wide.u32 %rd12, %r25, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
