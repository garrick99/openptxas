.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    mad.lo.u32 %r16, %r3, %r3, %r3;
    mad.lo.u32 %r4, %r16, %r3, %r3;
    setp.eq.u32 %p1, %r16, 2147483647;
    @%p1 cvt.s64.s32 %rd14, %r3;
    cvt.s64.s32 %rd11, %r16;
    and.b32 %r25, %r3, 256;
    sub.s64 %rd15, %rd14, %rd11;
    sub.u32 %r11, %r4, %r16;
    shl.b32 %r15, %r16, 30;
    setp.eq.u32 %p1, %r3, 2147483648;
    @%p1 max.u32 %r17, %r4, %r11;
    mad.lo.u32 %r18, %r4, %r3, %r11;
    sub.s32 %r7, %r15, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
