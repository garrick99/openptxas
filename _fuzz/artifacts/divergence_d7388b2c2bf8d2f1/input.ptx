    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p4, %r3, %r3;
    @%p4 cvt.u64.u32 %rd11, %r3;
    selp.b32 %r15, %r3, %r3, %p4;
    max.u32 %r13, %r3, 1;
    max.u64 %rd10, %rd11, %rd11;
    sub.u32 %r8, %r13, %r3;
    or.b32 %r5, %r8, %r13;
    shl.b32 %r21, %r13, 30;
    cvt.u32.u64 %r26, %rd10;
    mad.lo.u32 %r5, %r13, %r8, %r5;
    min.s32 %r6, %r13, 65535;
    or.b32 %r27, %r3, %r6;
