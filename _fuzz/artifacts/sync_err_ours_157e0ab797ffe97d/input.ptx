.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r19, %r3, 3;
    cvt.s64.s32 %rd10, %r19;
    shr.s32 %r9, %r3, 16;
    shl.b32 %r19, %r19, 2;
    sub.u64 %rd9, %rd10, %rd10;
    shr.u64 %rd11, %rd10, 15;
    shr.u32 %r17, %r9, 31;
    add.u32 %r22, %r19, %r9;
    cvt.u32.u64 %r25, %rd9;
    setp.lt.s32 %p2, %r9, 7;
    @%p2 shr.u32 %r23, %r9, 0;
    xor.b64 %rd14, %rd10, %rd10;
    max.u64 %rd15, %rd14, %rd9;
    setp.ls.u32 %p1, %r3, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
