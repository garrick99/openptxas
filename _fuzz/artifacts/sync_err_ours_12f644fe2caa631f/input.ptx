.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r7, %r3, 0;
    max.s32 %r8, %r7, %r7;
    mul.lo.s32 %r10, %r8, 7;
    cvt.s64.s32 %rd9, %r8;
    mul.wide.u32 %rd12, %r10, %r7;
    shr.u32 %r4, %r7, 30;
    max.s64 %rd7, %rd12, %rd9;
    min.s32 %r20, %r8, %r10;
    setp.ne.s32 %p1, %r7, %r10;
    @!%p1 mad.lo.u32 %r4, %r3, %r4, %r20;
    or.b32 %r14, %r7, 65535;
    add.u32 %r4, %r20, 63;
    min.s32 %r5, %r7, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
