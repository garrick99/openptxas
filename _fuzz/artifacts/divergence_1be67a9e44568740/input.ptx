.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r9, %r3, %r3;
    sub.u32 %r20, %r3, 32;
    cvt.s64.s32 %rd15, %r9;
    shr.u32 %r14, %r3, 16;
    or.b32 %r26, %r14, 64;
    shl.b64 %rd12, %rd15, 0;
    cvt.s64.s32 %rd12, %r26;
    cvt.s64.s32 %rd10, %r20;
    shr.u32 %r20, %r20, 31;
    mul.lo.s32 %r12, %r26, %r3;
    shr.u32 %r5, %r12, 31;
    setp.le.s32 %p3, %r26, %r9;
    @!%p3 or.b32 %r11, %r3, 5;
    max.u32 %r20, %r5, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
