.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    mul.lo.u32 %r12, %r3, 7;
    setp.lt.s32 %p1, %r12, 16;
    @%p1 cvt.s64.s32 %rd13, %r3;
    shr.u64 %rd5, %rd13, 31;
    shl.b32 %r7, %r3, 4;
    min.s64 %rd5, %rd13, %rd5;
    shr.u32 %r22, %r12, 15;
    xor.b32 %r19, %r3, %r12;
    shl.b32 %r22, %r19, 1;
    cvt.u32.u64 %r12, %rd9;
    selp.b32 %r4, %r7, %r3, %p1;
    mul.wide.u32 %rd11, %r12, %r19;
    min.s64 %rd5, %rd5, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
