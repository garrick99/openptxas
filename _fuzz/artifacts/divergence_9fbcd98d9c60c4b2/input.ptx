.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r14, %r3, %r3;
    sub.s32 %r21, %r3, 63;
    setp.ne.s32 %p4, %r14, %r14;
    @!%p4 mul.lo.s32 %r4, %r14, 63;
    sub.u32 %r17, %r14, 255;
    sub.s32 %r22, %r17, %r17;
    and.b32 %r19, %r21, 4;
    setp.lt.u32 %p1, %r19, %r17;
    @%p1 shl.b32 %r16, %r3, 1;
    cvt.u64.u32 %rd9, %r16;
    mul.wide.u32 %rd6, %r3, %r22;
    mad.lo.s32 %r17, %r3, %r14, %r19;
    sub.u64 %rd13, %rd6, %rd9;
    selp.b32 %r26, %r17, %r3, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
