.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    or.b32 %r14, %r3, %r3;
    add.u32 %r17, %r3, 5;
    shr.u64 %rd15, %rd13, 33;
    max.s32 %r12, %r14, 4;
    mul.wide.u32 %rd10, %r3, %r17;
    mul.lo.s32 %r27, %r17, 0;
    setp.ge.s32 %p3, %r12, 7;
    @%p3 mad.lo.u32 %r13, %r27, %r27, %r12;
    selp.b32 %r8, %r13, %r17, %p3;
    cvt.s32.s64 %r25, %rd10;
    selp.b32 %r8, %r3, %r13, %p3;
    mad.lo.s32 %r9, %r8, %r27, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
