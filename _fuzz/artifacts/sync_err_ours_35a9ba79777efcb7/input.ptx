.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    mul.wide.u32 %rd6, %r3, %r3;
    add.s32 %r21, %r3, %r3;
    mad.lo.s32 %r19, %r3, %r21, %r3;
    and.b32 %r13, %r21, %r19;
    shr.s32 %r17, %r13, 1;
    shl.b32 %r17, %r3, 31;
    shr.s64 %rd6, %rd5, 7;
    mul.lo.s32 %r14, %r17, 65535;
    min.u32 %r17, %r14, %r17;
    xor.b32 %r16, %r19, 4294967295;
    sub.s32 %r24, %r3, 255;
    sub.s32 %r23, %r3, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
