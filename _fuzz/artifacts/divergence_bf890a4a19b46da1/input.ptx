.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r17, %r3, %r3;
    cvt.u64.u32 %rd8, %r3;
    mul.wide.s32 %rd5, %r17, %r3;
    cvt.s32.s64 %r6, %rd8;
    cvt.s32.s64 %r7, %rd5;
    setp.eq.s32 %p2, %r6, 8;
    @%p2 mad.lo.s32 %r23, %r17, %r6, %r17;
    sub.s32 %r23, %r7, %r6;
    mul.lo.s32 %r14, %r17, %r7;
    min.s32 %r19, %r14, 32;
    min.s32 %r24, %r6, %r7;
    selp.b32 %r14, %r3, %r23, %p2;
    shr.s64 %rd6, %rd5, 7;
    add.u32 %r6, %r19, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
