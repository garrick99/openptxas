.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd13, %r3, %r3;
    setp.gt.u32 %p3, %r3, 8;
    max.s64 %rd7, %rd13, %rd13;
    or.b32 %r8, %r3, 31;
    cvt.u64.u32 %rd13, %r8;
    shl.b32 %r4, %r8, 0;
    min.s32 %r26, %r8, 32;
    sub.u32 %r17, %r4, %r26;
    shr.s32 %r11, %r17, 7;
    cvt.s32.s64 %r4, %rd7;
    mul.wide.s32 %rd10, %r11, %r4;
    max.s32 %r9, %r3, 31;
    shr.u64 %rd12, %rd7, 15;
    max.s32 %r18, %r11, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
