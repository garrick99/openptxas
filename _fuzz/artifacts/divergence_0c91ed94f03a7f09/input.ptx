.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r22, %r3, 255;
    cvt.s64.s32 %rd10, %r22;
    max.u32 %r16, %r3, %r22;
    setp.ne.s32 %p2, %r22, %r16;
    sub.u32 %r13, %r22, %r16;
    setp.hs.u32 %p1, %r22, %r16;
    mul.lo.s64 %rd8, %rd10, %rd10;
    cvt.u64.u32 %rd8, %r22;
    shr.u32 %r16, %r13, 2;
    min.s32 %r14, %r22, 63;
    cvt.s32.s64 %r17, %rd10;
    setp.lt.u32 %p1, %r22, 16;
    @%p1 max.u32 %r27, %r13, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
