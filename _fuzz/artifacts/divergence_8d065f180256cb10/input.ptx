.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r8, %r3, 32;
    add.s32 %r24, %r3, 2;
    min.s32 %r27, %r24, 255;
    setp.ne.s32 %p4, %r3, 8;
    cvt.u64.u32 %rd14, %r24;
    cvt.s64.s32 %rd12, %r8;
    sub.u32 %r27, %r8, %r8;
    cvt.s64.s32 %rd13, %r27;
    add.s64 %rd13, %rd13, %rd14;
    and.b32 %r16, %r3, 15;
    mul.wide.u32 %rd11, %r8, %r3;
    add.s64 %rd11, %rd12, %rd11;
    selp.b32 %r27, %r24, %r8, %p4;
    min.s32 %r9, %r3, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
