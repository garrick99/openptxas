.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    mul.lo.s64 %rd13, %rd12, %rd12;
    add.s32 %r9, %r3, 63;
    max.u64 %rd11, %rd13, %rd12;
    add.u32 %r26, %r3, 5;
    shl.b32 %r16, %r26, 2;
    min.s64 %rd10, %rd12, %rd11;
    sub.u32 %r26, %r3, 2147483648;
    cvt.u64.u32 %rd13, %r26;
    mul.wide.s32 %rd6, %r26, %r3;
    setp.lt.s32 %p2, %r26, %r9;
    @!%p2 shl.b64 %rd13, %rd10, 4;
    shl.b32 %r10, %r16, 1;
    mul.lo.s32 %r24, %r26, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
