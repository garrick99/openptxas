.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p3, %r3, %r3;
    mad.lo.s32 %r20, %r3, %r3, %r3;
    cvt.u64.u32 %rd14, %r20;
    min.u32 %r11, %r3, 1;
    mul.wide.u32 %rd15, %r3, %r11;
    mul.lo.u32 %r10, %r20, %r11;
    setp.hi.u32 %p1, %r20, 31;
    @%p1 max.s32 %r13, %r20, 65535;
    and.b32 %r20, %r20, 16;
    setp.lt.u32 %p3, %r10, %r13;
    @%p3 cvt.s64.s32 %rd5, %r13;
    or.b64 %rd15, %rd14, %rd15;
    shl.b32 %r18, %r10, 31;
    min.s32 %r10, %r3, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
