.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r14, %r3, 5;
    mad.lo.s32 %r23, %r14, %r14, %r14;
    mul.lo.s32 %r7, %r3, %r14;
    and.b32 %r18, %r3, %r7;
    mul.wide.s32 %rd11, %r7, %r23;
    mul.wide.s32 %rd15, %r7, %r7;
    cvt.u32.u64 %r22, %rd11;
    cvt.u32.u64 %r8, %rd11;
    mul.wide.s32 %rd12, %r3, %r23;
    mul.wide.u32 %rd10, %r3, %r22;
    min.s64 %rd9, %rd10, %rd15;
    max.s32 %r4, %r8, %r8;
    xor.b32 %r26, %r18, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
