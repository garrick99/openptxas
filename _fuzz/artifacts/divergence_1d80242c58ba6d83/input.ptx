.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r6, %r3, %r3;
    mul.wide.u32 %rd12, %r3, %r3;
    shl.b32 %r21, %r6, 1;
    xor.b32 %r24, %r6, 63;
    sub.u32 %r23, %r24, 1;
    or.b32 %r4, %r21, 255;
    setp.ne.s32 %p3, %r21, 65536;
    mad.lo.u32 %r11, %r4, %r21, %r21;
    mul.wide.u32 %rd12, %r21, %r23;
    setp.hi.u32 %p1, %r23, 256;
    @%p1 sub.s32 %r10, %r21, 2;
    shr.s32 %r14, %r4, 16;
    and.b32 %r10, %r24, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
