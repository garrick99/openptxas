.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    xor.b32 %r9, %r3, 0;
    min.s32 %r18, %r3, 5;
    max.s64 %rd6, %rd8, %rd8;
    setp.eq.u32 %p4, %r18, 7;
    @%p4 shl.b32 %r8, %r3, 30;
    or.b32 %r15, %r8, %r18;
    add.s32 %r10, %r9, 65535;
    and.b32 %r8, %r9, %r8;
    max.u32 %r26, %r18, 255;
    setp.hs.u32 %p4, %r8, 64;
    @%p4 min.s32 %r4, %r8, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
