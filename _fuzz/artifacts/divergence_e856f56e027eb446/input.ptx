.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p4, %r3, %r3;
    @%p4 mul.lo.u32 %r6, %r3, %r3;
    mul.lo.u32 %r26, %r6, %r6;
    mul.lo.u32 %r13, %r26, %r6;
    setp.eq.s32 %p2, %r26, 256;
    @%p2 max.s32 %r10, %r13, %r6;
    selp.b32 %r23, %r6, %r10, %p2;
    sub.u32 %r22, %r6, %r3;
    xor.b32 %r9, %r22, 255;
    xor.b32 %r20, %r13, 0;
    setp.eq.s32 %p2, %r20, %r10;
    @!%p2 max.s32 %r15, %r26, %r10;
    setp.le.u32 %p4, %r3, 5;
    @%p4 max.u32 %r20, %r13, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
