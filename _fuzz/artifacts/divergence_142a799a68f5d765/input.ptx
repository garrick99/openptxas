.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r24, %r3, 3;
    cvt.s64.s32 %rd5, %r3;
    min.u32 %r25, %r3, %r3;
    cvt.s32.s64 %r21, %rd5;
    mul.lo.s32 %r7, %r24, %r24;
    cvt.s64.s32 %rd12, %r21;
    setp.lt.s32 %p1, %r7, %r25;
    @!%p1 and.b64 %rd15, %rd12, %rd12;
    shr.u32 %r26, %r25, 15;
    selp.b32 %r19, %r25, %r7, %p1;
    or.b32 %r25, %r21, 15;
    sub.u32 %r10, %r24, 64;
    max.s32 %r23, %r25, %r26;
    cvt.s32.s64 %r7, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
