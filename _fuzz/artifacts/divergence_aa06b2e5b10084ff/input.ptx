.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r11, %r3, 4;
    and.b32 %r27, %r3, 7;
    cvt.s64.s32 %rd6, %r27;
    min.u32 %r19, %r11, 3;
    mul.wide.s32 %rd8, %r3, %r11;
    mul.wide.u32 %rd6, %r19, %r11;
    mul.lo.s32 %r14, %r11, 255;
    sub.u32 %r12, %r27, %r27;
    mad.lo.s32 %r26, %r19, %r11, %r27;
    setp.gt.u32 %p1, %r11, 65535;
    @%p1 cvt.s32.s64 %r19, %rd6;
    mul.wide.u32 %rd13, %r19, %r27;
    selp.b32 %r26, %r26, %r19, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
