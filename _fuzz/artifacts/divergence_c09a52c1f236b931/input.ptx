.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    min.s32 %r12, %r3, 256;
    mul.lo.s32 %r17, %r12, %r3;
    add.u32 %r24, %r3, 64;
    shl.b32 %r19, %r12, 4;
    shl.b32 %r13, %r3, 1;
    xor.b32 %r24, %r12, %r12;
    setp.lt.u32 %p4, %r3, 16;
    @%p4 cvt.u32.u64 %r16, %rd5;
    xor.b32 %r13, %r3, 255;
    cvt.s64.s32 %rd8, %r3;
    shl.b32 %r9, %r17, 7;
    selp.b32 %r18, %r3, %r16, %p4;
    setp.gt.u32 %p2, %r13, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
