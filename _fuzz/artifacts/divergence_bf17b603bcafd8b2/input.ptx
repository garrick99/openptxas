    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r20, %r3, 64;
    cvt.s64.s32 %rd8, %r3;
    add.s32 %r11, %r20, %r3;
    shr.s64 %rd7, %rd8, 30;
    mul.wide.u32 %rd10, %r11, %r3;
