.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r20, %r3, %r3, %r3;
    setp.le.s32 %p3, %r3, %r3;
    setp.eq.u32 %p3, %r20, 0;
    @%p3 shl.b32 %r21, %r3, 3;
    cvt.s64.s32 %rd8, %r21;
    add.s32 %r22, %r21, %r20;
    shr.u64 %rd6, %rd8, 2;
    sub.s32 %r18, %r20, %r20;
    min.u64 %rd12, %rd8, %rd8;
    selp.b32 %r25, %r18, %r3, %p3;
    mul.wide.u32 %rd10, %r20, %r18;
    cvt.s32.s64 %r14, %rd10;
    selp.b32 %r16, %r18, %r22, %p3;
    min.s64 %rd14, %rd10, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
