    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r17, %r3, 255;
    cvt.s64.s32 %rd5, %r3;
    shr.u32 %r6, %r17, 4;
    mad.lo.u32 %r23, %r3, %r17, %r17;
    min.u32 %r21, %r3, 65535;
    setp.eq.s32 %p2, %r6, 4;
    @%p2 mad.lo.u32 %r18, %r6, %r17, %r21;
    sub.u32 %r7, %r3, 8;
    setp.lt.s32 %p4, %r6, 63;
    @!%p4 mad.lo.s32 %r26, %r6, %r7, %r21;
    selp.b32 %r15, %r18, %r3, %p2;
    mad.lo.u32 %r5, %r7, %r6, %r18;
    setp.hi.u32 %p3, %r7, 65536;
    @%p3 min.s64 %rd9, %rd5, %rd5;
