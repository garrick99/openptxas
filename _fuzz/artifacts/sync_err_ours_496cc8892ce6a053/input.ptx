.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p2, %r3, %r3;
    setp.lt.u32 %p3, %r3, %r3;
    mul.lo.u32 %r7, %r3, 2;
    xor.b32 %r7, %r3, %r7;
    mul.wide.s32 %rd6, %r3, %r3;
    shl.b32 %r14, %r3, 3;
    shr.s64 %rd14, %rd6, 1;
    shl.b32 %r15, %r7, 15;
    max.s32 %r7, %r7, %r15;
    shr.s32 %r8, %r14, 16;
    cvt.u32.u64 %r12, %rd6;
    mul.lo.s32 %r15, %r14, 1;
    shr.u32 %r19, %r14, 2;
    min.u32 %r9, %r14, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
