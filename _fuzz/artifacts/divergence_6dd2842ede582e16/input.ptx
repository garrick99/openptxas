.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r27, %r3, %r3;
    shr.u32 %r7, %r27, 3;
    sub.u32 %r12, %r3, %r7;
    sub.s32 %r11, %r12, %r27;
    min.s32 %r16, %r27, %r12;
    cvt.s64.s32 %rd11, %r27;
    min.u32 %r5, %r3, 63;
    mad.lo.u32 %r22, %r7, %r16, %r16;
    min.u32 %r12, %r27, %r22;
    mul.wide.s32 %rd12, %r16, %r12;
    setp.gt.s32 %p3, %r22, 15;
    mul.wide.s32 %rd7, %r7, %r3;
    setp.lt.u32 %p4, %r11, %r22;
    @%p4 mad.lo.u32 %r9, %r11, %r5, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
