.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r7, %r3, 3;
    xor.b32 %r17, %r3, 2147483647;
    mad.lo.s32 %r11, %r17, %r7, %r17;
    min.s32 %r16, %r3, 4;
    add.s32 %r17, %r16, %r16;
    mul.wide.s32 %rd9, %r3, %r11;
    cvt.s32.s64 %r20, %rd9;
    mul.wide.s32 %rd10, %r11, %r11;
    cvt.s32.s64 %r27, %rd10;
    sub.s32 %r16, %r17, %r20;
    mad.lo.u32 %r21, %r7, %r20, %r27;
    mul.lo.u32 %r10, %r11, 63;
    setp.lt.s32 %p1, %r16, 64;
    @%p1 cvt.u32.u64 %r18, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
