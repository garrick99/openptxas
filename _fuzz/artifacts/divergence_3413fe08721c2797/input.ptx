.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r4, %r3, 31;
    mad.lo.s32 %r13, %r3, %r4, %r4;
    add.s32 %r18, %r3, 32;
    mad.lo.s32 %r6, %r13, %r4, %r13;
    and.b32 %r13, %r3, 32;
    mul.wide.u32 %rd10, %r18, %r13;
    max.u64 %rd11, %rd10, %rd10;
    shl.b32 %r24, %r3, 16;
    shr.s64 %rd10, %rd10, 3;
    shl.b64 %rd6, %rd11, 3;
    add.u32 %r10, %r3, %r6;
    shr.s32 %r15, %r4, 15;
    and.b32 %r27, %r13, 7;
    min.u32 %r22, %r15, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
