.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    shl.b64 %rd6, %rd8, 62;
    shr.s64 %rd7, %rd6, 33;
    xor.b32 %r26, %r3, 3;
    cvt.u64.u32 %rd8, %r26;
    or.b32 %r25, %r26, %r26;
    mul.lo.s64 %rd14, %rd7, %rd7;
    max.s32 %r21, %r3, 5;
    shr.u64 %rd15, %rd14, 62;
    setp.gt.s32 %p1, %r26, 16;
    @%p1 min.u32 %r23, %r26, %r26;
    min.u32 %r24, %r25, %r3;
    mad.lo.s32 %r4, %r24, %r26, %r26;
    min.u32 %r25, %r23, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
