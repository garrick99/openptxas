.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r12, %r3, %r3, %r3;
    cvt.u64.u32 %rd5, %r3;
    and.b32 %r16, %r12, %r3;
    min.s64 %rd13, %rd5, %rd5;
    add.u32 %r15, %r12, %r3;
    mul.wide.u32 %rd5, %r12, %r16;
    add.s32 %r24, %r16, 8;
    mul.wide.u32 %rd8, %r12, %r15;
    mul.wide.u32 %rd10, %r24, %r16;
    setp.hi.u32 %p4, %r3, 32;
    or.b32 %r27, %r24, %r12;
    mul.lo.u32 %r4, %r3, %r16;
    shr.u32 %r16, %r15, 16;
    shl.b32 %r25, %r12, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
