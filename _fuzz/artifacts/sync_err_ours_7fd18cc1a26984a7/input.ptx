.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p1, %r3, 65535;
    @%p1 mul.wide.u32 %rd13, %r3, %r3;
    mul.wide.u32 %rd14, %r3, %r3;
    shl.b32 %r26, %r3, 2;
    setp.hs.u32 %p2, %r3, 5;
    @%p2 xor.b32 %r15, %r3, 65535;
    min.u32 %r23, %r15, %r26;
    shr.u32 %r11, %r3, 3;
    cvt.s32.s64 %r20, %rd13;
    min.u32 %r19, %r15, %r3;
    add.u32 %r9, %r23, %r15;
    mul.wide.s32 %rd14, %r19, %r9;
    shr.u64 %rd10, %rd13, 15;
    max.u32 %r10, %r15, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
