.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    setp.lt.u32 %p2, %r3, 65535;
    @%p2 mad.lo.s32 %r19, %r3, %r3, %r3;
    shr.u32 %r24, %r3, 7;
    shr.u32 %r24, %r24, 7;
    xor.b32 %r7, %r3, 65536;
    mad.lo.s32 %r10, %r19, %r24, %r3;
    cvt.u32.u64 %r18, %rd9;
    max.s32 %r11, %r24, 255;
    cvt.s32.s64 %r17, %rd9;
    max.u64 %rd9, %rd9, %rd9;
    xor.b32 %r27, %r17, %r11;
    mul.lo.u32 %r11, %r17, %r10;
    selp.b32 %r19, %r7, %r11, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
