.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    add.s32 %r23, %r3, %r3;
    min.s64 %rd13, %rd15, %rd15;
    shr.u32 %r14, %r3, 15;
    mad.lo.u32 %r11, %r3, %r14, %r23;
    mul.wide.s32 %rd6, %r14, %r14;
    cvt.s64.s32 %rd8, %r23;
    mul.wide.u32 %rd5, %r23, %r11;
    mul.wide.u32 %rd10, %r11, %r3;
    shr.u32 %r11, %r14, 7;
    shr.u32 %r26, %r11, 2;
    sub.s64 %rd15, %rd8, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
