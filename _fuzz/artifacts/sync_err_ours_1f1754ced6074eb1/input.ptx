.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r6, %r3, %r3;
    cvt.s64.s32 %rd8, %r3;
    setp.ge.s32 %p4, %r3, %r3;
    or.b32 %r18, %r6, 8;
    mul.lo.u32 %r16, %r6, 256;
    mul.wide.u32 %rd10, %r16, %r3;
    min.s32 %r5, %r16, %r18;
    mul.wide.u32 %rd9, %r16, %r3;
    min.u32 %r4, %r5, %r5;
    shl.b32 %r22, %r4, 15;
    shr.u32 %r13, %r6, 0;
    cvt.u64.u32 %rd13, %r18;
    mad.lo.s32 %r9, %r6, %r16, %r22;
    shr.u64 %rd12, %rd10, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
