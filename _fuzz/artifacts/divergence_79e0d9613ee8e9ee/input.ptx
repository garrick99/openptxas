.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r20, %r3, %r3;
    mul.lo.u32 %r4, %r3, %r20;
    cvt.s64.s32 %rd5, %r4;
    max.s32 %r11, %r20, %r20;
    shr.u32 %r18, %r20, 16;
    sub.u32 %r24, %r11, 32;
    or.b32 %r16, %r11, %r18;
    sub.s32 %r20, %r11, 256;
    cvt.s64.s32 %rd8, %r3;
    mul.wide.s32 %rd7, %r20, %r11;
    min.u64 %rd15, %rd7, %rd7;
    shr.s64 %rd12, %rd5, 2;
    mul.lo.s32 %r22, %r18, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
