.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r8, %r3, 64;
    shr.u32 %r10, %r8, 1;
    cvt.u64.u32 %rd6, %r10;
    max.s32 %r12, %r8, %r8;
    cvt.u32.u64 %r18, %rd6;
    min.u32 %r20, %r3, %r18;
    min.s64 %rd10, %rd6, %rd6;
    max.u32 %r11, %r20, %r18;
    add.s32 %r10, %r18, %r12;
    shr.u32 %r26, %r20, 1;
    shr.u32 %r11, %r11, 0;
    cvt.u64.u32 %rd12, %r18;
    shl.b32 %r16, %r8, 0;
    max.s32 %r25, %r18, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
