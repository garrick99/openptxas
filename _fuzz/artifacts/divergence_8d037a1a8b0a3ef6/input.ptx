.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r21, %r3, %r3;
    mul.lo.s32 %r23, %r21, %r3;
    mul.wide.s32 %rd10, %r21, %r3;
    or.b32 %r11, %r21, %r23;
    cvt.s32.s64 %r10, %rd10;
    min.u32 %r26, %r23, %r3;
    and.b32 %r22, %r26, 15;
    setp.lt.s32 %p1, %r26, %r10;
    @!%p1 shr.u64 %rd9, %rd10, 0;
    mul.wide.u32 %rd12, %r22, %r23;
    or.b32 %r15, %r23, 3;
    or.b32 %r11, %r26, 1;
    shl.b64 %rd12, %rd9, 15;
    mad.lo.s32 %r7, %r26, %r10, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
