.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r17, %r3, %r3;
    cvt.s64.s32 %rd11, %r17;
    add.s32 %r13, %r17, %r17;
    and.b32 %r15, %r17, %r3;
    setp.hi.u32 %p4, %r17, %r17;
    @%p4 cvt.s32.s64 %r13, %rd11;
    setp.eq.u32 %p3, %r15, 16;
    @!%p3 add.u64 %rd11, %rd11, %rd11;
    mul.wide.s32 %rd14, %r15, %r13;
    or.b32 %r10, %r17, %r3;
    shl.b32 %r4, %r13, 0;
    mul.lo.u32 %r21, %r10, 256;
    add.s32 %r20, %r13, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
