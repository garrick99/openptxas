    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    mad.lo.s32 %r9, %r3, %r3, %r3;
    setp.ne.s32 %p4, %r3, 4294967295;
    @!%p4 shl.b64 %rd11, %rd9, 15;
    mad.lo.u32 %r26, %r3, %r3, %r9;
    mul.lo.s32 %r7, %r26, %r3;
    cvt.s32.s64 %r20, %rd11;
    sub.u32 %r19, %r9, %r20;
