.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r25, %r3, 7;
    mad.lo.s32 %r19, %r25, %r25, %r25;
    setp.lt.s32 %p2, %r3, 4;
    mad.lo.s32 %r22, %r19, %r3, %r19;
    max.u32 %r25, %r3, %r3;
    cvt.s64.s32 %rd15, %r19;
    sub.s64 %rd8, %rd15, %rd15;
    shr.s32 %r7, %r3, 2;
    shl.b32 %r18, %r19, 16;
    add.u32 %r17, %r19, 0;
    shr.s32 %r7, %r25, 31;
    add.s32 %r23, %r22, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
