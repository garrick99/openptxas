.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    shr.s64 %rd8, %rd11, 15;
    shr.s32 %r9, %r3, 30;
    add.u32 %r19, %r9, 7;
    shl.b32 %r27, %r9, 4;
    setp.ge.u32 %p4, %r27, %r9;
    @!%p4 mad.lo.u32 %r10, %r9, %r27, %r3;
    min.s64 %rd10, %rd8, %rd11;
    min.s32 %r8, %r27, 2;
    min.s32 %r18, %r27, 5;
    xor.b32 %r5, %r3, %r19;
    sub.s64 %rd12, %rd8, %rd10;
    and.b32 %r23, %r19, %r3;
    min.s32 %r17, %r18, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
