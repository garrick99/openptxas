.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r17, %r3, %r3, %r3;
    max.u32 %r11, %r3, %r17;
    cvt.u64.u32 %rd6, %r3;
    shr.u32 %r22, %r3, 31;
    setp.eq.s32 %p4, %r22, %r3;
    @%p4 selp.b32 %r26, %r22, %r22, %p4;
    or.b32 %r15, %r22, 256;
    mul.wide.s32 %rd10, %r22, %r17;
    shr.u32 %r25, %r15, 30;
    mul.wide.s32 %rd11, %r11, %r15;
    add.u32 %r16, %r22, %r3;
    cvt.u32.u64 %r8, %rd10;
    shr.s32 %r8, %r26, 16;
    mul.lo.s32 %r15, %r26, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
