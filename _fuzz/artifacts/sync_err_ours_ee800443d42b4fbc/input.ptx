    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r26, %r3, %r3;
    mad.lo.s32 %r7, %r3, %r26, %r3;
    cvt.u64.u32 %rd13, %r26;
    min.s64 %rd9, %rd13, %rd13;
    add.s64 %rd13, %rd13, %rd9;
    shr.u32 %r18, %r26, 15;
    mad.lo.s32 %r23, %r26, %r3, %r18;
