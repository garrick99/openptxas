.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r26, %r3, 0;
    min.s32 %r10, %r26, 8;
    mul.lo.u32 %r17, %r26, %r3;
    shl.b32 %r22, %r3, 3;
    shr.s32 %r11, %r10, 7;
    mul.lo.u32 %r13, %r22, %r3;
    setp.ge.s32 %p3, %r13, %r13;
    @!%p3 cvt.u64.u32 %rd5, %r13;
    min.s32 %r27, %r10, 5;
    and.b32 %r6, %r17, %r13;
    shr.s32 %r9, %r27, 0;
    or.b32 %r18, %r11, 255;
    cvt.s32.s64 %r22, %rd5;
    mul.wide.s32 %rd5, %r26, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
