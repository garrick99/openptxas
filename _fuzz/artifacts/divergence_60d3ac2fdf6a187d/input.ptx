.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r5, %r3, 4;
    cvt.u64.u32 %rd13, %r5;
    cvt.u64.u32 %rd13, %r5;
    setp.gt.s32 %p2, %r5, 5;
    @%p2 shr.s32 %r8, %r3, 2;
    add.s32 %r25, %r8, 4294967295;
    add.u32 %r16, %r3, %r8;
    mul.wide.u32 %rd5, %r5, %r5;
    shr.u64 %rd12, %rd5, 4;
    add.u32 %r22, %r3, %r16;
    selp.b32 %r14, %r8, %r8, %p2;
    max.u32 %r5, %r5, 65536;
    shr.u32 %r23, %r8, 30;
    setp.eq.s32 %p3, %r25, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
