.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    shr.s32 %r15, %r3, 7;
    mul.lo.u32 %r8, %r3, 4294967295;
    min.s32 %r20, %r3, %r15;
    shr.u32 %r21, %r20, 0;
    cvt.s32.s64 %r9, %rd14;
    mul.lo.u32 %r16, %r8, %r20;
    mul.wide.u32 %rd11, %r9, %r20;
    min.u64 %rd5, %rd14, %rd11;
    mad.lo.s32 %r19, %r3, %r3, %r16;
    xor.b32 %r13, %r3, 7;
    setp.lt.s32 %p4, %r13, %r8;
    @%p4 shr.s32 %r13, %r13, 1;
    shr.u64 %rd13, %rd11, 48;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
