.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r15, %r3, 2;
    sub.s32 %r4, %r3, 0;
    mul.lo.s32 %r11, %r4, 2147483648;
    min.u32 %r11, %r4, %r4;
    cvt.u64.u32 %rd15, %r4;
    shr.u32 %r16, %r3, 3;
    sub.s64 %rd12, %rd15, %rd15;
    sub.u32 %r26, %r16, 8;
    shr.u32 %r14, %r16, 0;
    shr.s32 %r11, %r26, 0;
    mad.lo.s32 %r27, %r15, %r16, %r14;
    min.s64 %rd7, %rd12, %rd15;
    cvt.u32.u64 %r23, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
