.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r14, %r3, 65535;
    min.s32 %r25, %r14, 2147483648;
    xor.b32 %r6, %r3, 65536;
    or.b32 %r4, %r14, %r6;
    sub.u32 %r23, %r4, 15;
    setp.gt.u32 %p2, %r14, %r23;
    @!%p2 shr.u32 %r23, %r3, 1;
    max.u32 %r22, %r14, 256;
    mul.lo.s32 %r18, %r6, %r14;
    setp.lt.s32 %p2, %r25, %r4;
    @%p2 min.s32 %r5, %r4, %r22;
    setp.hi.u32 %p4, %r3, 8;
    setp.eq.s32 %p4, %r22, %r14;
    @%p4 mul.lo.u32 %r20, %r4, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
