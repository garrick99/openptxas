.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    shr.u32 %r12, %r3, 2;
    shr.s64 %rd6, %rd9, 0;
    mad.lo.u32 %r10, %r12, %r3, %r12;
    add.s32 %r6, %r10, 4294967295;
    or.b32 %r17, %r6, %r12;
    mul.lo.u32 %r24, %r17, 3;
    or.b32 %r16, %r12, 16;
    cvt.u32.u64 %r25, %rd6;
    add.u32 %r9, %r16, 3;
    mul.lo.s32 %r23, %r12, 255;
    and.b32 %r14, %r10, %r10;
    add.u32 %r7, %r12, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
