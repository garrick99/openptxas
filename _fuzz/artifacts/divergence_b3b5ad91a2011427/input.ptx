.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r18, %r3, 2;
    min.u32 %r10, %r3, 3;
    mad.lo.u32 %r11, %r10, %r18, %r10;
    min.u32 %r13, %r10, %r10;
    min.s32 %r6, %r13, 15;
    add.s32 %r26, %r10, 4294967295;
    max.u32 %r27, %r6, %r10;
    mad.lo.s32 %r16, %r13, %r6, %r11;
    mul.lo.s32 %r24, %r27, %r16;
    mul.lo.s32 %r4, %r11, %r18;
    sub.s32 %r15, %r26, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
