.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfe.u32 %r15, %r3, 4, 2;
    bfi.b32 %r12, %r15, %r3, 1, 32;
    popc.b32 %r10, %r12;
    bfe.u32 %r8, %r15, 31, 31;
    brev.b32 %r22, %r8;
    brev.b32 %r6, %r3;
    bfi.b32 %r13, %r10, %r12, 15, 4;
    prmt.b32 %r4, %r22, %r8, 12816;
    bfe.s32 %r23, %r8, 7, 16;
    bfe.s32 %r17, %r10, 0, 2;
    bfi.b32 %r10, %r6, %r12, 31, 4;
    bfe.u32 %r23, %r3, 0, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
