.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r14, %r3, 7;
    cvt.s64.s32 %rd7, %r14;
    or.b32 %r10, %r3, 32;
    cvt.s64.s32 %rd10, %r3;
    or.b32 %r16, %r14, %r3;
    min.s32 %r14, %r16, 63;
    mul.lo.u32 %r27, %r14, 2147483648;
    max.s32 %r16, %r16, %r3;
    shl.b32 %r22, %r27, 0;
    cvt.s32.s64 %r22, %rd10;
    cvt.u64.u32 %rd9, %r22;
    min.u32 %r20, %r27, %r14;
    mul.wide.u32 %rd14, %r3, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
