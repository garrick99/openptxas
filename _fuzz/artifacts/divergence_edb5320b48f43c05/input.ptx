.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p1, %r3, 7;
    @%p1 selp.b32 %r26, %r3, %r3, %p1;
    selp.b32 %r16, %r26, %r26, %p1;
    add.u32 %r15, %r3, %r26;
    shr.s32 %r27, %r3, 2;
    min.u32 %r23, %r15, %r26;
    sub.s32 %r21, %r16, 32;
    min.u32 %r7, %r21, 16;
    max.u32 %r16, %r27, 65535;
    mad.lo.s32 %r22, %r21, %r15, %r3;
    mul.lo.u32 %r17, %r16, %r7;
    min.u32 %r26, %r16, 64;
    mul.lo.u32 %r20, %r23, 4;
    or.b32 %r22, %r16, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
