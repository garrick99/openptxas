.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r18, %r3, %r3;
    mul.lo.u32 %r9, %r18, 63;
    or.b32 %r16, %r18, %r18;
    mul.wide.u32 %rd13, %r3, %r9;
    mad.lo.s32 %r16, %r9, %r16, %r9;
    mul.lo.u32 %r15, %r3, 65536;
    cvt.s64.s32 %rd6, %r16;
    mul.lo.s32 %r11, %r18, %r9;
    and.b32 %r23, %r15, 255;
    add.u32 %r13, %r11, %r16;
    max.s64 %rd15, %rd6, %rd13;
    shl.b64 %rd10, %rd13, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
