.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    sub.s32 %r9, %r3, 32;
    min.s32 %r5, %r3, 4294967295;
    and.b32 %r4, %r5, 4;
    setp.le.u32 %p2, %r5, 5;
    @%p2 cvt.u32.u64 %r8, %rd10;
    mul.wide.u32 %rd10, %r4, %r3;
    cvt.s32.s64 %r26, %rd10;
    mul.lo.s32 %r8, %r3, %r5;
    shr.u64 %rd14, %rd10, 3;
    add.u32 %r4, %r9, 0;
    selp.b32 %r10, %r5, %r8, %p2;
    and.b32 %r24, %r10, %r4;
    and.b32 %r25, %r10, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
