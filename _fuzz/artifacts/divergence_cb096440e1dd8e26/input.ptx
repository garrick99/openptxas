.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r17, %r3, %r3;
    max.u32 %r14, %r17, 15;
    xor.b32 %r7, %r14, %r14;
    cvt.s64.s32 %rd14, %r3;
    sub.s32 %r18, %r3, %r14;
    mul.wide.u32 %rd10, %r17, %r7;
    setp.gt.u32 %p3, %r18, 1;
    @%p3 shl.b64 %rd8, %rd10, 1;
    setp.eq.u32 %p1, %r14, 8;
    @!%p1 mul.wide.s32 %rd6, %r18, %r18;
    max.s32 %r11, %r7, 255;
    min.u32 %r6, %r17, %r11;
    sub.u32 %r17, %r3, %r6;
    setp.ls.u32 %p3, %r6, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
