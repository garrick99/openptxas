.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd9, %r3, %r3;
    mul.lo.s64 %rd5, %rd9, %rd9;
    cvt.s32.s64 %r9, %rd9;
    or.b32 %r6, %r9, %r3;
    and.b32 %r26, %r3, %r6;
    setp.lt.s32 %p1, %r6, %r9;
    @!%p1 add.s32 %r22, %r9, 31;
    setp.ge.s32 %p3, %r9, 32;
    @%p3 sub.u32 %r27, %r9, %r3;
    add.s64 %rd9, %rd9, %rd5;
    sub.s32 %r5, %r22, %r3;
    setp.ne.s32 %p4, %r3, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
