.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    setp.gt.u32 %p1, %r3, %r3;
    @%p1 max.s64 %rd14, %rd13, %rd13;
    max.u32 %r23, %r3, 256;
    cvt.s64.s32 %rd10, %r23;
    min.u32 %r14, %r3, %r23;
    mad.lo.s32 %r23, %r3, %r3, %r23;
    sub.u32 %r25, %r14, 4294967295;
    mul.wide.s32 %rd10, %r14, %r23;
    cvt.u64.u32 %rd13, %r23;
    sub.s32 %r18, %r14, %r3;
    mul.wide.s32 %rd10, %r3, %r25;
    mul.wide.s32 %rd6, %r3, %r25;
    shl.b32 %r27, %r18, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
