    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r7, %r3, %r3;
    cvt.u64.u32 %rd8, %r7;
    add.s32 %r17, %r3, 65536;
    or.b32 %r26, %r17, %r17;
