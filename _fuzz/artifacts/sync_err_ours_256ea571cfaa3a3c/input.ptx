.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r19, %r3, %r3;
    mul.lo.s32 %r6, %r19, 7;
    min.s32 %r17, %r6, %r6;
    mul.lo.s32 %r18, %r19, %r6;
    max.u32 %r4, %r6, %r18;
    sub.s32 %r26, %r18, %r17;
    cvt.s64.s32 %rd13, %r19;
    mul.wide.u32 %rd8, %r4, %r19;
    max.u32 %r12, %r6, 8;
    shr.s32 %r20, %r26, 4;
    shr.u32 %r11, %r4, 4;
    shr.u32 %r26, %r26, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
