.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    add.s32 %r22, %r3, %r3;
    setp.lt.s32 %p3, %r3, %r22;
    @%p3 cvt.s64.s32 %rd6, %r3;
    sub.u32 %r22, %r22, 65535;
    add.u32 %r23, %r3, %r3;
    min.u64 %rd9, %rd6, %rd6;
    selp.b32 %r15, %r22, %r22, %p3;
    mad.lo.u32 %r16, %r23, %r22, %r22;
    min.u32 %r4, %r15, %r3;
    setp.ne.s32 %p3, %r23, %r16;
    shl.b32 %r17, %r16, 7;
    or.b64 %rd6, %rd15, %rd15;
    setp.lt.s32 %p2, %r23, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
