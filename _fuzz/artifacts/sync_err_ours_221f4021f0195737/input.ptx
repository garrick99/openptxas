.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r7, %r3, 1;
    shr.u32 %r8, %r3, 0;
    add.u32 %r26, %r7, %r8;
    cvt.u64.u32 %rd12, %r26;
    or.b32 %r13, %r8, %r7;
    add.s32 %r21, %r7, %r7;
    add.s32 %r8, %r21, 31;
    max.s32 %r16, %r21, %r21;
    add.s32 %r15, %r16, %r13;
    xor.b32 %r8, %r13, %r15;
    mul.lo.s32 %r25, %r26, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
