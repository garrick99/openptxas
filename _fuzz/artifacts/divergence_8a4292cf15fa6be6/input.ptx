    max.u32 %r7, %r3, %r21;
    add.u32 %r17, %r3, %r7;
    max.s32 %r25, %r21, 16;
    mul.lo.s32 %r25, %r21, %r3;
    min.u32 %r20, %r3, 2147483648;
    or.b32 %r23, %r3, %r20;
    mad.lo.s32 %r23, %r3, %r25, %r3;
    shl.b32 %r8, %r3, 1;
    max.u32 %r11, %r20, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
