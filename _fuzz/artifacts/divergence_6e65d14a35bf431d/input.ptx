.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r5, %r3, 3;
    add.s32 %r13, %r5, 0;
    cvt.s64.s32 %rd7, %r5;
    setp.hs.u32 %p1, %r3, %r3;
    @%p1 selp.b32 %r25, %r5, %r13, %p1;
    setp.gt.u32 %p3, %r13, %r3;
    @%p3 or.b32 %r8, %r5, 31;
    cvt.u32.u64 %r18, %rd7;
    sub.u32 %r21, %r25, %r18;
    mad.lo.s32 %r11, %r25, %r21, %r25;
    shr.u64 %rd10, %rd7, 62;
    sub.u32 %r26, %r8, %r11;
    mad.lo.u32 %r22, %r8, %r18, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
