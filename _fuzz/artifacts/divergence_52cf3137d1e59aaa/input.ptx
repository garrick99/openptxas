.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r24, %r3, %r3;
    shl.b32 %r23, %r24, 2;
    shl.b32 %r11, %r24, 4;
    cvt.u64.u32 %rd12, %r24;
    and.b32 %r7, %r3, %r24;
    and.b32 %r19, %r24, 1;
    mad.lo.u32 %r26, %r11, %r23, %r19;
    max.s32 %r17, %r24, 65536;
    max.u32 %r16, %r26, %r17;
    mul.lo.s32 %r27, %r26, %r17;
    setp.le.u32 %p3, %r26, %r24;
    @%p3 sub.s32 %r21, %r7, %r23;
    shr.u64 %rd7, %rd12, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
