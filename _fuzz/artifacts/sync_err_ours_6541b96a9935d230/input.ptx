.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    shr.u64 %rd9, %rd7, 16;
    min.s32 %r15, %r3, 1;
    mad.lo.s32 %r8, %r15, %r3, %r15;
    add.s32 %r26, %r8, %r3;
    setp.gt.u32 %p1, %r3, %r15;
    @!%p1 selp.b32 %r11, %r3, %r26, %p1;
    or.b32 %r14, %r15, %r11;
    max.s32 %r8, %r15, %r3;
    selp.b32 %r8, %r26, %r15, %p1;
    mad.lo.u32 %r9, %r15, %r8, %r3;
    and.b32 %r26, %r14, %r26;
    cvt.s64.s32 %rd15, %r26;
    mad.lo.u32 %r15, %r11, %r11, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
