    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r15, %r3, %r3;
    setp.ge.s32 %p3, %r15, %r3;
    @%p3 cvt.s64.s32 %rd13, %r15;
    and.b32 %r15, %r3, 0;
