.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r4, %r3, 31;
    sub.s32 %r9, %r4, 5;
    min.s32 %r4, %r3, %r9;
    shl.b32 %r18, %r9, 16;
    max.s32 %r17, %r9, %r9;
    mul.lo.s32 %r19, %r17, 64;
    cvt.s64.s32 %rd8, %r9;
    max.u32 %r10, %r9, %r19;
    shr.u64 %rd9, %rd8, 3;
    cvt.s64.s32 %rd11, %r4;
    mul.lo.s32 %r20, %r17, 7;
    sub.u32 %r4, %r19, %r10;
    sub.u32 %r27, %r10, %r20;
    sub.s32 %r4, %r20, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
