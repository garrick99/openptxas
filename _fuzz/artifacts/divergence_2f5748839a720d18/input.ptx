.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r6, %r3, %r3;
    mad.lo.u32 %r8, %r3, %r3, %r6;
    cvt.s64.s32 %rd7, %r8;
    cvt.u32.u64 %r13, %rd7;
    sub.u64 %rd5, %rd7, %rd7;
    setp.ls.u32 %p4, %r6, 255;
    and.b32 %r6, %r13, 8;
    mul.lo.u64 %rd9, %rd5, %rd7;
    max.u32 %r11, %r8, %r3;
    add.u32 %r14, %r3, %r13;
    cvt.u32.u64 %r8, %rd9;
    cvt.u64.u32 %rd14, %r11;
    shl.b64 %rd5, %rd9, 47;
    shl.b32 %r25, %r14, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
