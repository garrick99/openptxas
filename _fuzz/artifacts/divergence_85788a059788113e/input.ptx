.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r14, %r3, %r3;
    shl.b32 %r20, %r3, 31;
    setp.ne.u32 %p3, %r14, 256;
    @%p3 sub.s32 %r10, %r20, %r3;
    cvt.u64.u32 %rd8, %r10;
    shr.u64 %rd13, %rd8, 33;
    sub.u32 %r11, %r3, %r3;
    cvt.u64.u32 %rd11, %r14;
    min.u32 %r26, %r20, %r10;
    max.u32 %r18, %r20, %r26;
    sub.s32 %r11, %r20, %r10;
    selp.b32 %r24, %r18, %r20, %p3;
    sub.s32 %r8, %r20, %r10;
    mad.lo.u32 %r19, %r26, %r3, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
