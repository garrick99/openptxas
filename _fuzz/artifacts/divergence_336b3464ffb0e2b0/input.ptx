    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r16, %r3, %r3;
    mad.lo.u32 %r18, %r16, %r16, %r16;
    cvt.u64.u32 %rd13, %r18;
    shr.u32 %r7, %r16, 3;
    or.b64 %rd7, %rd13, %rd13;
    cvt.u32.u64 %r14, %rd7;
    sub.s32 %r5, %r7, %r14;
    setp.lt.s32 %p3, %r5, %r14;
    mad.lo.s32 %r17, %r5, %r14, %r18;
    cvt.s64.s32 %rd14, %r3;
    shr.s64 %rd5, %rd13, 2;
    mul.lo.u32 %r17, %r5, 4294967295;
    max.s32 %r13, %r18, 2147483648;
    max.s32 %r26, %r3, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
