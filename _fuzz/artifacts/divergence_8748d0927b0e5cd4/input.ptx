.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r25, %r3, %r3;
    mad.lo.u32 %r9, %r25, %r25, %r25;
    shr.u32 %r4, %r3, 4;
    mul.lo.s32 %r18, %r3, %r3;
    setp.ge.s32 %p1, %r9, %r3;
    @%p1 max.s32 %r16, %r18, 65535;
    max.s32 %r19, %r4, %r16;
    min.s32 %r7, %r16, 32;
    cvt.u64.u32 %rd11, %r25;
    sub.u32 %r21, %r19, %r3;
    shr.u32 %r20, %r19, 1;
    shr.s64 %rd10, %rd11, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
