.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    sub.u32 %r26, %r3, 4;
    sub.u32 %r8, %r3, %r3;
    xor.b32 %r12, %r3, %r26;
    shr.s64 %rd5, %rd8, 2;
    shl.b32 %r14, %r3, 30;
    or.b32 %r17, %r26, %r3;
    setp.le.s32 %p2, %r17, %r26;
    max.s64 %rd7, %rd8, %rd8;
    mul.wide.s32 %rd10, %r12, %r17;
    mul.lo.u64 %rd14, %rd10, %rd10;
    cvt.s32.s64 %r23, %rd8;
    setp.eq.u32 %p3, %r14, 4294967295;
    @%p3 min.u32 %r18, %r17, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
