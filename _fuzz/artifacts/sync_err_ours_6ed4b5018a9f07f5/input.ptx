.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r16, %r3, 256;
    shl.b32 %r24, %r3, 3;
    max.s32 %r7, %r24, %r16;
    shl.b32 %r19, %r16, 2;
    min.s32 %r10, %r19, %r24;
    shr.s32 %r6, %r19, 1;
    max.u32 %r17, %r16, 2147483647;
    mad.lo.s32 %r21, %r24, %r7, %r10;
    add.u32 %r13, %r24, 65536;
    sub.u32 %r8, %r3, 3;
    shl.b32 %r21, %r10, 31;
    max.u32 %r19, %r8, %r24;
    and.b32 %r6, %r10, 32;
    cvt.u64.u32 %rd8, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
