.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    xor.b32 %r19, %r3, 255;
    shr.s32 %r12, %r19, 0;
    setp.le.s32 %p2, %r19, %r19;
    @%p2 max.u32 %r21, %r12, %r19;
    add.u32 %r8, %r19, %r21;
    mul.lo.u32 %r14, %r19, 15;
    mul.wide.s32 %rd10, %r8, %r21;
    min.s32 %r17, %r21, 255;
    or.b32 %r6, %r12, %r12;
    xor.b32 %r24, %r21, %r17;
    shr.u64 %rd13, %rd10, 2;
    mul.lo.u32 %r11, %r17, %r17;
    add.u32 %r24, %r21, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
