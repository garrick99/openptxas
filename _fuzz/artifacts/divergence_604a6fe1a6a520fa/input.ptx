.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    setp.ge.u32 %p3, %r3, 16;
    @%p3 add.s32 %r22, %r3, 16;
    shr.s32 %r13, %r22, 16;
    shr.u32 %r26, %r13, 7;
    sub.u32 %r18, %r3, %r22;
    or.b32 %r20, %r18, %r13;
    setp.eq.u32 %p4, %r22, 32;
    @!%p4 max.u64 %rd14, %rd14, %rd14;
    shr.u64 %rd10, %rd14, 3;
    selp.b32 %r18, %r22, %r3, %p3;
    min.s64 %rd5, %rd10, %rd10;
    mul.wide.u32 %rd10, %r20, %r20;
    add.u32 %r26, %r26, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
