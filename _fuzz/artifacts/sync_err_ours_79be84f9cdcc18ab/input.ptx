.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r13, %r3, %r3, %r3;
    max.s32 %r25, %r3, 64;
    shr.u32 %r4, %r25, 31;
    cvt.s64.s32 %rd6, %r3;
    cvt.s64.s32 %rd14, %r3;
    shr.s32 %r11, %r25, 7;
    cvt.s64.s32 %rd14, %r25;
    mad.lo.s32 %r17, %r3, %r3, %r3;
    mul.lo.u64 %rd6, %rd14, %rd14;
    max.s32 %r14, %r13, %r4;
    mul.wide.s32 %rd5, %r17, %r3;
    shr.u64 %rd15, %rd5, 48;
    setp.lt.s32 %p4, %r3, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
