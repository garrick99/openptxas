    xor.b32 %r25, %r23, %r3;
    min.s32 %r26, %r23, 65536;
    setp.ne.u32 %p3, %r22, %r25;
    @%p3 shr.s32 %r21, %r23, 15;
    or.b32 %r14, %r7, 2147483648;
    cvt.u64.u32 %rd15, %r7;
    shr.s64 %rd6, %rd15, 30;
    sub.u64 %rd13, %rd6, %rd15;
    mad.lo.s32 %r22, %r14, %r14, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
