.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r4, %r3, 30;
    cvt.u64.u32 %rd7, %r3;
    mad.lo.u32 %r25, %r4, %r4, %r3;
    xor.b64 %rd9, %rd7, %rd7;
    mad.lo.s32 %r21, %r4, %r4, %r25;
    mul.wide.s32 %rd7, %r21, %r25;
    cvt.s32.s64 %r25, %rd7;
    setp.le.s32 %p4, %r3, %r25;
    @%p4 shl.b32 %r5, %r4, 16;
    setp.lt.s32 %p3, %r25, 2;
    @%p3 min.u32 %r7, %r5, %r4;
    xor.b64 %rd15, %rd9, %rd9;
    max.s32 %r12, %r7, 1;
    mul.wide.u32 %rd10, %r3, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
