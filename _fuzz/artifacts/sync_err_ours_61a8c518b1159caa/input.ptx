.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    shr.u32 %r4, %r3, 2;
    shr.u32 %r15, %r3, 7;
    or.b32 %r22, %r15, 3;
    cvt.s64.s32 %rd5, %r3;
    mul.wide.u32 %rd7, %r22, %r22;
    sub.s64 %rd14, %rd15, %rd7;
    xor.b32 %r13, %r15, %r4;
    max.u32 %r7, %r22, 2;
    max.u32 %r26, %r4, 256;
    cvt.u32.u64 %r26, %rd14;
    shl.b64 %rd7, %rd7, 63;
    min.s64 %rd12, %rd14, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
