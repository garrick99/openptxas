.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r10, %r3, 65535;
    cvt.s64.s32 %rd11, %r3;
    setp.ne.u32 %p3, %r3, 4;
    @%p3 shr.u32 %r22, %r10, 1;
    add.u32 %r4, %r22, %r3;
    sub.s64 %rd7, %rd11, %rd11;
    min.u32 %r23, %r4, %r3;
    shr.s32 %r19, %r4, 1;
    max.u32 %r23, %r3, %r4;
    add.u32 %r5, %r4, 63;
    xor.b32 %r8, %r22, %r23;
    shr.s32 %r12, %r5, 16;
    cvt.u64.u32 %rd5, %r23;
    shr.u32 %r6, %r23, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
