.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    shr.s64 %rd10, %rd5, 48;
    mad.lo.s32 %r18, %r3, %r3, %r3;
    setp.lt.u32 %p3, %r18, 3;
    @%p3 selp.b32 %r15, %r3, %r18, %p3;
    selp.b32 %r26, %r15, %r18, %p3;
    setp.gt.s32 %p4, %r26, 256;
    @%p4 add.s64 %rd11, %rd10, %rd10;
    xor.b32 %r12, %r3, %r18;
    cvt.u32.u64 %r19, %rd11;
    shl.b64 %rd5, %rd5, 0;
    setp.ge.s32 %p2, %r18, %r15;
    @!%p2 min.s64 %rd7, %rd10, %rd5;
    sub.s64 %rd12, %rd7, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
