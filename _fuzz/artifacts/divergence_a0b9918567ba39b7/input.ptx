.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r15, %r3, 2147483648;
    mul.lo.s32 %r21, %r15, %r3;
    or.b32 %r11, %r21, 7;
    setp.le.s32 %p4, %r11, 15;
    @%p4 min.u32 %r11, %r21, 1;
    mad.lo.u32 %r26, %r11, %r21, %r3;
    setp.gt.s32 %p2, %r15, 256;
    @%p2 mul.wide.u32 %rd6, %r21, %r15;
    sub.s32 %r13, %r15, %r11;
    cvt.s64.s32 %rd11, %r11;
    selp.b32 %r16, %r13, %r11, %p2;
    min.u64 %rd6, %rd11, %rd11;
    mad.lo.u32 %r8, %r15, %r3, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
