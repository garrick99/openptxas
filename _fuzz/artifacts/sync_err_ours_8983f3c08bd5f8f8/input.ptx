.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r4, %r3, 4294967295;
    shl.b32 %r19, %r3, 15;
    cvt.s64.s32 %rd8, %r19;
    add.u32 %r4, %r19, 16;
    and.b32 %r21, %r4, 64;
    cvt.s32.s64 %r27, %rd8;
    add.s32 %r12, %r27, 65535;
    or.b32 %r25, %r4, %r3;
    max.s32 %r12, %r12, 1;
    max.s32 %r11, %r27, %r12;
    min.u32 %r6, %r11, 31;
    add.s32 %r23, %r21, %r19;
    cvt.u64.u32 %rd5, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
