.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r9, %r3, 255;
    shr.s32 %r20, %r9, 0;
    cvt.s64.s32 %rd7, %r9;
    cvt.u64.u32 %rd6, %r9;
    mul.wide.u32 %rd6, %r9, %r3;
    shr.u32 %r5, %r20, 3;
    xor.b32 %r13, %r20, 2147483647;
    mad.lo.s32 %r13, %r13, %r9, %r5;
    max.u64 %rd10, %rd6, %rd7;
    cvt.s64.s32 %rd9, %r20;
    min.s32 %r22, %r5, 32;
    cvt.u32.u64 %r4, %rd6;
    min.u32 %r17, %r9, %r4;
    setp.le.s32 %p4, %r13, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
