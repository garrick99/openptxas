.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r8, %r3, 2147483648;
    or.b32 %r20, %r3, 256;
    add.s32 %r26, %r20, %r3;
    and.b32 %r10, %r26, 64;
    setp.hs.u32 %p2, %r10, %r8;
    @%p2 sub.u32 %r15, %r26, %r10;
    cvt.u64.u32 %rd15, %r8;
    and.b32 %r16, %r3, 2;
    mul.wide.u32 %rd9, %r16, %r26;
    setp.ne.s32 %p3, %r15, 63;
    @!%p3 sub.s32 %r17, %r16, 255;
    sub.s32 %r15, %r8, 2;
    setp.hi.u32 %p4, %r20, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
