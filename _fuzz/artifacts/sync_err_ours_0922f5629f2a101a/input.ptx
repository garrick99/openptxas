.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    shl.b64 %rd8, %rd11, 3;
    and.b32 %r17, %r3, %r3;
    mad.lo.s32 %r24, %r3, %r17, %r3;
    min.s32 %r19, %r17, 7;
    max.u64 %rd13, %rd8, %rd11;
    shr.s32 %r5, %r17, 7;
    add.u32 %r5, %r5, %r19;
    add.s32 %r20, %r24, 255;
    sub.u32 %r16, %r19, 4;
    shr.s64 %rd15, %rd11, 63;
    min.s32 %r6, %r16, %r20;
    shl.b32 %r9, %r24, 2;
    cvt.u32.u64 %r4, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
