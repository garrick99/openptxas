    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r12, %r3, 64;
    cvt.u64.u32 %rd15, %r3;
    sub.s32 %r27, %r12, 63;
    cvt.s32.s64 %r18, %rd15;
    shl.b32 %r15, %r3, 3;
    or.b32 %r20, %r18, %r18;
    cvt.s32.s64 %r9, %rd15;
    shl.b32 %r19, %r27, 1;
    add.s32 %r10, %r9, %r15;
    shr.u32 %r24, %r27, 30;
    add.s32 %r27, %r18, 2147483647;
    setp.le.s32 %p4, %r15, 8;
    @%p4 add.s32 %r26, %r3, 32;
    setp.hs.u32 %p4, %r27, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
