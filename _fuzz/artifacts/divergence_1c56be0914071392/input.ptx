.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r12, %r3, 30;
    sub.u32 %r27, %r3, %r12;
    cvt.s64.s32 %rd8, %r3;
    cvt.s32.s64 %r8, %rd8;
    shr.s64 %rd6, %rd8, 16;
    cvt.s32.s64 %r20, %rd6;
    setp.ge.u32 %p2, %r8, 64;
    and.b32 %r17, %r27, 4294967295;
    sub.u64 %rd6, %rd8, %rd8;
    add.u32 %r25, %r12, %r3;
    max.s32 %r24, %r25, %r17;
    setp.ge.s32 %p3, %r20, 7;
    @%p3 shl.b32 %r11, %r17, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
