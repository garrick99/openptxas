.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r25, %r3, 16;
    sub.s32 %r16, %r25, 4;
    shr.s32 %r15, %r3, 4;
    min.u32 %r27, %r16, %r3;
    min.u32 %r26, %r3, 255;
    xor.b32 %r25, %r26, %r16;
    cvt.u64.u32 %rd10, %r16;
    setp.gt.u32 %p1, %r26, 65535;
    @!%p1 mul.wide.s32 %rd15, %r25, %r3;
    mul.lo.s32 %r23, %r26, %r25;
    cvt.u64.u32 %rd5, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
