.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p3, %r3, %r3;
    @%p3 cvt.s64.s32 %rd14, %r3;
    mad.lo.s32 %r26, %r3, %r3, %r3;
    max.u32 %r12, %r3, %r26;
    min.u64 %rd13, %rd14, %rd14;
    setp.le.s32 %p1, %r3, 4294967295;
    setp.ls.u32 %p1, %r3, 256;
    @%p1 shr.s64 %rd11, %rd13, 31;
    selp.b32 %r22, %r12, %r3, %p1;
    cvt.s32.s64 %r16, %rd13;
    cvt.s64.s32 %rd8, %r16;
    setp.ne.s32 %p2, %r3, %r22;
    and.b32 %r11, %r12, 2147483647;
    mul.lo.s64 %rd14, %rd8, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
