.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r19, %r3, 3;
    shr.u32 %r7, %r19, 2;
    mul.wide.u32 %rd7, %r7, %r3;
    setp.le.s32 %p2, %r19, %r3;
    mul.lo.s32 %r20, %r19, %r19;
    min.s64 %rd7, %rd7, %rd7;
    mul.wide.s32 %rd7, %r20, %r20;
    shr.u32 %r15, %r3, 1;
    cvt.u64.u32 %rd12, %r20;
    shr.s64 %rd15, %rd7, 7;
    shr.s64 %rd8, %rd15, 3;
    mul.lo.u32 %r19, %r19, %r19;
    cvt.u64.u32 %rd6, %r7;
    shr.u32 %r26, %r3, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
