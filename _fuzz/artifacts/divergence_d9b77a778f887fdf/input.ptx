.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r25, %r3, 65536;
    add.u32 %r27, %r3, 15;
    mad.lo.u32 %r27, %r27, %r27, %r3;
    max.u32 %r12, %r25, %r25;
    add.u32 %r16, %r27, %r25;
    cvt.u64.u32 %rd15, %r16;
    and.b64 %rd9, %rd15, %rd15;
    setp.hi.u32 %p2, %r27, %r16;
    add.s32 %r17, %r25, %r3;
    sub.s32 %r12, %r12, %r16;
    and.b64 %rd8, %rd9, %rd15;
    max.s32 %r19, %r12, 4;
    selp.b32 %r18, %r19, %r16, %p2;
    cvt.s64.s32 %rd7, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
