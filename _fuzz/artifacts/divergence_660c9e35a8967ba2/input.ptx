.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    shr.s64 %rd8, %rd5, 62;
    or.b32 %r13, %r3, %r3;
    sub.s32 %r26, %r13, %r3;
    min.u32 %r22, %r3, %r13;
    max.s32 %r19, %r22, 2;
    or.b32 %r6, %r13, 65535;
    shr.s32 %r23, %r3, 31;
    cvt.s64.s32 %rd9, %r26;
    shr.s32 %r17, %r3, 30;
    min.u64 %rd14, %rd9, %rd5;
    max.s32 %r6, %r23, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
