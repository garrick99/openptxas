.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p1, %r3, 8;
    @%p1 min.u32 %r26, %r3, %r3;
    shl.b32 %r21, %r26, 1;
    add.u32 %r10, %r26, %r21;
    setp.gt.s32 %p4, %r3, 65536;
    or.b32 %r26, %r21, 31;
    shl.b32 %r27, %r21, 3;
    mad.lo.s32 %r11, %r27, %r21, %r10;
    sub.u32 %r13, %r27, %r11;
    setp.lt.s32 %p4, %r13, 32;
    @!%p4 add.u32 %r7, %r11, 32;
    and.b32 %r22, %r7, 3;
    add.u32 %r14, %r3, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
