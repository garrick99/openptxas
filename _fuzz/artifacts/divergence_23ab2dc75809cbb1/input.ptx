.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r23, %r3, 7;
    shr.s32 %r19, %r23, 15;
    setp.gt.s32 %p4, %r19, %r3;
    setp.lt.s32 %p4, %r19, 65535;
    shr.u32 %r22, %r23, 1;
    sub.u32 %r9, %r22, 0;
    setp.ge.u32 %p2, %r23, %r9;
    cvt.s64.s32 %rd9, %r3;
    xor.b32 %r4, %r23, 2;
    and.b32 %r7, %r4, 0;
    mul.lo.s32 %r17, %r19, %r3;
    selp.b32 %r24, %r23, %r4, %p4;
    max.u32 %r20, %r4, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
