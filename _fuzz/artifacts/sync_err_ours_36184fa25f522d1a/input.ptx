.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    min.u32 %r20, %r3, 15;
    shl.b32 %r14, %r20, 31;
    setp.hs.u32 %p3, %r20, %r14;
    @!%p3 add.u32 %r23, %r20, %r20;
    min.u64 %rd5, %rd9, %rd9;
    xor.b32 %r21, %r23, %r20;
    min.u32 %r11, %r20, 256;
    cvt.s32.s64 %r19, %rd5;
    shl.b32 %r12, %r21, 30;
    and.b32 %r12, %r23, %r21;
    setp.le.s32 %p2, %r23, 15;
    @%p2 mad.lo.s32 %r14, %r11, %r3, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
