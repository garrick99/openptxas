.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r12, %r3, 4294967295;
    max.s32 %r4, %r12, 4;
    shr.u32 %r5, %r4, 30;
    cvt.u64.u32 %rd13, %r12;
    setp.lt.u32 %p4, %r4, %r5;
    max.u32 %r14, %r5, %r5;
    shl.b64 %rd8, %rd13, 2;
    sub.u32 %r19, %r14, %r5;
    or.b32 %r16, %r12, %r5;
    sub.u32 %r27, %r19, %r19;
    shl.b32 %r21, %r27, 2;
    add.u64 %rd8, %rd8, %rd8;
    min.s32 %r27, %r27, %r5;
    selp.b32 %r26, %r4, %r3, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
