.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    cvt.u64.u32 %rd11, %r3;
    sub.s32 %r18, %r3, %r3;
    mul.wide.u32 %rd8, %r18, %r3;
    shr.s32 %r9, %r18, 2;
    add.s32 %r26, %r9, %r18;
    shr.s32 %r12, %r3, 3;
    shr.s64 %rd10, %rd11, 2;
    mad.lo.u32 %r16, %r9, %r9, %r12;
    xor.b32 %r14, %r18, %r26;
    sub.u32 %r13, %r9, 16;
    max.s64 %rd8, %rd11, %rd11;
    sub.u32 %r12, %r26, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
