.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    shl.b32 %r5, %r3, 16;
    shl.b64 %rd12, %rd9, 4;
    setp.gt.s32 %p1, %r5, 2;
    setp.ne.s32 %p1, %r3, 64;
    @%p1 add.s32 %r13, %r5, %r5;
    or.b32 %r25, %r3, 64;
    shr.s32 %r10, %r13, 0;
    max.u32 %r25, %r10, %r25;
    sub.u32 %r22, %r3, 1;
    shl.b32 %r25, %r5, 4;
    and.b32 %r8, %r25, %r3;
    xor.b32 %r12, %r5, 64;
    max.u32 %r5, %r25, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
