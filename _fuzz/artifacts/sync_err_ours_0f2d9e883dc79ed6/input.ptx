.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r15, %r3, 4;
    cvt.u64.u32 %rd9, %r15;
    max.u32 %r20, %r3, 255;
    setp.lt.u32 %p4, %r20, 65536;
    @!%p4 sub.s64 %rd8, %rd9, %rd9;
    and.b32 %r20, %r3, 31;
    mad.lo.s32 %r20, %r20, %r15, %r3;
    mul.wide.u32 %rd8, %r3, %r20;
    setp.le.u32 %p2, %r15, 2147483648;
    @!%p2 xor.b32 %r12, %r15, 4;
    and.b64 %rd7, %rd8, %rd8;
    mad.lo.u32 %r5, %r12, %r20, %r3;
    shr.s64 %rd15, %rd9, 32;
    mad.lo.u32 %r21, %r5, %r5, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
