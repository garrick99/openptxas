.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r6, %r3, %r3;
    sub.u32 %r12, %r6, 8;
    mul.wide.u32 %rd8, %r12, %r6;
    min.u32 %r22, %r3, %r12;
    shl.b32 %r15, %r3, 0;
    min.s32 %r14, %r22, %r15;
    cvt.s32.s64 %r23, %rd8;
    cvt.u32.u64 %r12, %rd8;
    setp.le.u32 %p4, %r15, 31;
    setp.ls.u32 %p4, %r15, 2;
    @%p4 add.s32 %r17, %r3, 256;
    mad.lo.s32 %r24, %r14, %r23, %r15;
    mul.lo.s32 %r17, %r12, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
