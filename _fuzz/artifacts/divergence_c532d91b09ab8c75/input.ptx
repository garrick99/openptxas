.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd5, %r3, %r3;
    mad.lo.s32 %r23, %r3, %r3, %r3;
    or.b32 %r23, %r3, %r3;
    add.s32 %r10, %r23, %r23;
    cvt.s32.s64 %r11, %rd5;
    or.b32 %r25, %r10, 3;
    min.u32 %r25, %r25, %r10;
    shr.u32 %r17, %r23, 16;
    shr.s64 %rd8, %rd5, 16;
    setp.hs.u32 %p2, %r23, %r3;
    @!%p2 mul.wide.s32 %rd8, %r25, %r25;
    shl.b64 %rd11, %rd8, 31;
    add.s32 %r21, %r3, 63;
    shr.u32 %r4, %r21, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
