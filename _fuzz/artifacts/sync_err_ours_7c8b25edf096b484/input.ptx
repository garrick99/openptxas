.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r9, %r3, 2;
    mul.lo.u32 %r7, %r3, 5;
    xor.b32 %r19, %r9, %r7;
    mul.wide.u32 %rd8, %r7, %r3;
    min.s32 %r20, %r9, %r3;
    max.s32 %r21, %r20, %r19;
    setp.eq.s32 %p2, %r3, 31;
    @!%p2 min.s32 %r7, %r19, %r7;
    mul.lo.u32 %r4, %r21, 3;
    setp.ne.s32 %p2, %r3, %r4;
    setp.eq.u32 %p4, %r3, %r20;
    @!%p4 selp.b32 %r21, %r4, %r7, %p2;
    shl.b32 %r7, %r20, 2;
    setp.lt.u32 %p4, %r9, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
