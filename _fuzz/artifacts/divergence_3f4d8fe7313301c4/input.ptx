.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r9, %r3, 31;
    mul.lo.s32 %r26, %r9, %r9;
    cvt.u64.u32 %rd9, %r3;
    shl.b32 %r25, %r3, 0;
    xor.b32 %r19, %r25, 15;
    max.u32 %r14, %r25, 65535;
    mul.wide.s32 %rd13, %r25, %r25;
    shr.u32 %r6, %r3, 1;
    cvt.s32.s64 %r5, %rd13;
    add.u32 %r5, %r5, 4;
    add.s32 %r21, %r5, %r25;
    cvt.s32.s64 %r6, %rd13;
    mul.lo.s32 %r16, %r14, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
