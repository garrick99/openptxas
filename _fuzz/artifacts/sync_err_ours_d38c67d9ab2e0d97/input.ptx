.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r8, %r3, 4;
    min.s32 %r23, %r3, %r8;
    mul.wide.u32 %rd14, %r23, %r3;
    setp.ne.u32 %p1, %r3, %r23;
    @!%p1 mul.lo.s32 %r16, %r3, 15;
    sub.s32 %r8, %r8, %r16;
    selp.b32 %r4, %r3, %r23, %p1;
    setp.le.s32 %p1, %r4, %r23;
    setp.ne.u32 %p4, %r8, 2;
    @%p4 shr.s64 %rd8, %rd14, 16;
    setp.hi.u32 %p3, %r8, 65536;
    @%p3 mul.wide.s32 %rd11, %r4, %r23;
    min.u32 %r19, %r16, 4;
    shl.b32 %r11, %r16, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
