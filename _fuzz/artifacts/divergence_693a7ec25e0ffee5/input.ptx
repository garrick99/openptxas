.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r22, %r3, %r3, %r3;
    cvt.s64.s32 %rd6, %r22;
    cvt.s32.s64 %r13, %rd6;
    sub.s32 %r18, %r3, 64;
    cvt.s64.s32 %rd11, %r3;
    shr.s32 %r4, %r3, 16;
    mul.lo.s32 %r24, %r4, %r22;
    mul.lo.u32 %r22, %r24, 63;
    sub.u32 %r27, %r13, %r4;
    min.s64 %rd11, %rd6, %rd11;
    setp.ge.s32 %p3, %r24, %r3;
    @%p3 add.u32 %r10, %r22, 5;
    cvt.s32.s64 %r9, %rd11;
    xor.b64 %rd13, %rd6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
