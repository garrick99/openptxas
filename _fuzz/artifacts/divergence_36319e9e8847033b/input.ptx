.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    shr.u64 %rd14, %rd9, 30;
    add.s32 %r14, %r3, %r3;
    mul.wide.u32 %rd7, %r14, %r3;
    setp.eq.u32 %p3, %r14, %r3;
    @%p3 or.b32 %r23, %r3, %r3;
    xor.b32 %r21, %r3, %r14;
    mad.lo.u32 %r11, %r14, %r23, %r3;
    sub.u32 %r16, %r21, 1;
    shr.s32 %r23, %r11, 3;
    mad.lo.s32 %r26, %r16, %r11, %r11;
    mad.lo.u32 %r16, %r21, %r23, %r16;
    add.s32 %r11, %r11, 64;
    max.u32 %r13, %r26, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
