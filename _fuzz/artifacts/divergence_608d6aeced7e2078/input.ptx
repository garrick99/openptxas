.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    min.s32 %r21, %r3, 2;
    and.b32 %r9, %r3, 31;
    cvt.u32.u64 %r14, %rd11;
    sub.s32 %r17, %r3, %r9;
    and.b32 %r6, %r3, 5;
    mul.lo.s64 %rd11, %rd11, %rd11;
    sub.s32 %r18, %r17, %r17;
    mad.lo.u32 %r8, %r9, %r21, %r17;
    shr.s64 %rd12, %rd11, 32;
    setp.le.s32 %p2, %r6, %r21;
    @!%p2 shr.u32 %r26, %r18, 4;
    setp.eq.s32 %p2, %r8, 4294967295;
    and.b64 %rd5, %rd12, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
