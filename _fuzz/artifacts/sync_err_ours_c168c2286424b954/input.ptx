.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r20, %r3, 15;
    add.s32 %r22, %r20, 0;
    min.s32 %r17, %r20, %r22;
    mul.wide.s32 %rd13, %r17, %r22;
    min.s32 %r27, %r22, 7;
    max.u32 %r11, %r3, 32;
    add.u64 %rd10, %rd13, %rd13;
    max.u32 %r11, %r17, %r20;
    add.u32 %r10, %r20, 256;
    cvt.s32.s64 %r4, %rd13;
    shr.u32 %r5, %r27, 7;
    min.s32 %r24, %r27, %r11;
    add.u32 %r5, %r11, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
