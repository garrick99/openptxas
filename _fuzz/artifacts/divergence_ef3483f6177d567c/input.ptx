.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p1, %r3, 65535;
    @%p1 cvt.s64.s32 %rd10, %r3;
    max.s32 %r25, %r3, 5;
    mul.wide.s32 %rd14, %r3, %r25;
    add.u32 %r13, %r3, 64;
    mul.wide.u32 %rd11, %r25, %r3;
    setp.ge.s32 %p3, %r25, %r13;
    @%p3 shl.b64 %rd7, %rd14, 62;
    mul.wide.u32 %rd12, %r3, %r25;
    sub.s32 %r18, %r13, %r13;
    selp.b32 %r9, %r18, %r13, %p1;
    mul.lo.s64 %rd5, %rd10, %rd7;
    cvt.u32.u64 %r26, %rd12;
    selp.b32 %r26, %r13, %r9, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
