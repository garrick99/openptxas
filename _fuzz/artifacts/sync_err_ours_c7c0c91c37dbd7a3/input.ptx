.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r25, %r3, 5;
    add.s32 %r11, %r25, 31;
    mad.lo.u32 %r4, %r3, %r3, %r25;
    setp.ge.u32 %p3, %r3, 2147483647;
    @%p3 add.s32 %r26, %r25, 256;
    mul.wide.s32 %rd8, %r11, %r25;
    cvt.s32.s64 %r10, %rd8;
    sub.s64 %rd6, %rd8, %rd8;
    shr.u32 %r4, %r25, 4;
    mad.lo.s32 %r15, %r26, %r10, %r3;
    shr.u32 %r22, %r26, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
