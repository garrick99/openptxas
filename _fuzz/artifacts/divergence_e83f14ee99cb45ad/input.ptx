.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    mul.wide.s32 %rd5, %r3, %r3;
    setp.gt.s32 %p3, %r3, %r3;
    @%p3 max.u32 %r16, %r3, 2147483648;
    min.s32 %r21, %r3, %r16;
    setp.gt.u32 %p3, %r16, 2;
    @%p3 or.b32 %r26, %r16, %r16;
    mul.wide.u32 %rd10, %r26, %r16;
    cvt.s64.s32 %rd12, %r26;
    shr.u64 %rd14, %rd5, 62;
    mad.lo.u32 %r19, %r3, %r16, %r21;
    or.b32 %r14, %r19, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
