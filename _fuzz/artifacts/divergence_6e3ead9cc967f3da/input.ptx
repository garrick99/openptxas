.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p3, %r3, %r3;
    @%p3 sub.s32 %r15, %r3, 1;
    shr.u32 %r11, %r3, 15;
    setp.lo.u32 %p4, %r15, 256;
    shr.u32 %r5, %r15, 31;
    shr.s32 %r27, %r3, 2;
    mad.lo.s32 %r26, %r5, %r11, %r27;
    min.s32 %r25, %r27, 15;
    sub.s32 %r17, %r25, 4294967295;
    sub.u32 %r27, %r27, %r3;
    setp.lt.s32 %p2, %r27, %r11;
    @%p2 shl.b32 %r10, %r15, 7;
    add.s32 %r9, %r27, 4294967295;
    shr.u32 %r22, %r10, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
