.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd10, %r3, %r3;
    shl.b64 %rd13, %rd10, 4;
    max.u32 %r13, %r3, 16;
    shr.s32 %r6, %r13, 15;
    max.u32 %r7, %r13, %r6;
    shl.b32 %r22, %r3, 7;
    and.b64 %rd12, %rd10, %rd10;
    mul.lo.u32 %r4, %r6, 65535;
    shr.u64 %rd14, %rd12, 31;
    mul.wide.u32 %rd12, %r4, %r13;
    setp.ne.u32 %p3, %r13, 2147483647;
    @%p3 min.u32 %r10, %r13, %r22;
    selp.b32 %r12, %r6, %r10, %p3;
    setp.ne.s32 %p3, %r10, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
