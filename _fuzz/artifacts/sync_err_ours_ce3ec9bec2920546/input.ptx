.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r19, %r3, 0;
    mul.lo.u32 %r21, %r3, %r3;
    min.u32 %r25, %r21, %r3;
    setp.gt.s32 %p2, %r19, %r19;
    @%p2 mul.wide.u32 %rd9, %r21, %r25;
    or.b32 %r27, %r25, 256;
    setp.le.s32 %p3, %r21, %r3;
    add.s32 %r13, %r3, %r3;
    cvt.u32.u64 %r10, %rd9;
    xor.b32 %r22, %r10, %r27;
    add.s32 %r18, %r27, %r10;
    setp.le.s32 %p2, %r22, %r21;
    selp.b32 %r10, %r27, %r21, %p3;
    shl.b64 %rd13, %rd9, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
