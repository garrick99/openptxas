.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    setp.hi.u32 %p1, %r3, 5;
    @%p1 and.b32 %r6, %r3, 4294967295;
    shr.s64 %rd7, %rd9, 3;
    and.b32 %r12, %r3, %r6;
    sub.u64 %rd5, %rd9, %rd7;
    shr.s32 %r23, %r12, 0;
    max.s32 %r26, %r6, %r3;
    add.s32 %r19, %r26, 32;
    selp.b32 %r21, %r6, %r12, %p1;
    shl.b32 %r12, %r23, 16;
    selp.b32 %r7, %r21, %r19, %p1;
    shr.u32 %r6, %r19, 16;
    add.s32 %r9, %r6, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
