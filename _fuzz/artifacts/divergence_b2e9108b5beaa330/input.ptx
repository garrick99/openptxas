.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r25, %r3, %r3;
    mul.wide.s32 %rd14, %r25, %r25;
    setp.eq.s32 %p3, %r25, %r25;
    @!%p3 selp.b32 %r20, %r3, %r25, %p3;
    or.b32 %r23, %r25, 31;
    sub.u32 %r16, %r25, 4294967295;
    sub.s32 %r8, %r25, %r20;
    add.s32 %r5, %r8, 256;
    or.b32 %r25, %r3, 65536;
    shl.b32 %r9, %r3, 1;
    or.b64 %rd14, %rd14, %rd14;
    max.u32 %r26, %r9, %r8;
    xor.b64 %rd15, %rd14, %rd14;
    mul.wide.s32 %rd15, %r8, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
