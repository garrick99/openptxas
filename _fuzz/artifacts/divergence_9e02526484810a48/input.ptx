.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r6, %r3, %r3;
    mul.lo.s32 %r20, %r6, 32;
    setp.le.u32 %p4, %r20, %r6;
    @%p4 selp.b32 %r14, %r6, %r6, %p4;
    min.u32 %r17, %r6, %r20;
    setp.ge.u32 %p1, %r20, 5;
    @%p1 or.b32 %r6, %r20, 2147483648;
    cvt.u64.u32 %rd14, %r17;
    mad.lo.s32 %r19, %r14, %r17, %r17;
    shr.u64 %rd7, %rd14, 63;
    or.b32 %r17, %r14, 1;
    selp.b32 %r4, %r3, %r19, %p4;
    mul.wide.u32 %rd13, %r4, %r4;
    selp.b32 %r10, %r4, %r17, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
