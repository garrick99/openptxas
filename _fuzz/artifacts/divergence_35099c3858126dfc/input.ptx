    min.s32 %r20, %r18, %r11;
    setp.gt.s32 %p3, %r11, 4294967295;
    or.b32 %r27, %r11, 8;
    shl.b32 %r24, %r3, 7;
    setp.le.s32 %p3, %r15, 64;
    @%p3 mad.lo.u32 %r26, %r11, %r6, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
