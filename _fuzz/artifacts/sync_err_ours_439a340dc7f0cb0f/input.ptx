.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    mul.wide.u32 %rd12, %r3, %r3;
    cvt.u64.u32 %rd6, %r3;
    shr.u32 %r10, %r3, 1;
    setp.le.s32 %p2, %r10, %r3;
    min.u64 %rd5, %rd14, %rd12;
    setp.lt.u32 %p4, %r3, 16;
    sub.u32 %r22, %r10, 65536;
    selp.b32 %r10, %r10, %r22, %p4;
    cvt.s64.s32 %rd12, %r10;
    max.s32 %r9, %r10, %r3;
    or.b32 %r22, %r3, 4;
    add.s64 %rd7, %rd14, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
