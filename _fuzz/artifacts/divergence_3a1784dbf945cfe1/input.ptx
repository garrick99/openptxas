.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r6, %r3, 16;
    cvt.u64.u32 %rd9, %r6;
    sub.s64 %rd9, %rd9, %rd9;
    shr.u32 %r17, %r3, 16;
    shr.s64 %rd9, %rd9, 16;
    min.u32 %r5, %r17, %r6;
    min.u32 %r21, %r6, %r6;
    mul.wide.s32 %rd6, %r6, %r5;
    min.u32 %r14, %r21, 64;
    shr.u32 %r15, %r21, 3;
    shr.s64 %rd13, %rd6, 3;
    mad.lo.u32 %r20, %r5, %r6, %r17;
    setp.gt.s32 %p2, %r21, %r3;
    @%p2 mad.lo.s32 %r13, %r3, %r15, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
