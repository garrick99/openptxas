.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r10, %r3, 5;
    cvt.u64.u32 %rd13, %r3;
    setp.eq.u32 %p2, %r3, 2147483647;
    @%p2 shr.u32 %r25, %r3, 30;
    min.u64 %rd5, %rd13, %rd13;
    xor.b32 %r13, %r3, %r3;
    mad.lo.s32 %r8, %r13, %r3, %r25;
    setp.ne.s32 %p1, %r3, 255;
    shr.u32 %r4, %r8, 4;
    mul.lo.s64 %rd15, %rd5, %rd13;
    mul.lo.s32 %r16, %r4, 16;
    mad.lo.s32 %r20, %r8, %r3, %r13;
    add.u32 %r23, %r13, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
