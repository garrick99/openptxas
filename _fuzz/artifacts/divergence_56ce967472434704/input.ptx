    bfe.u32 %r8, %r14, 0, 32;
    bfe.u32 %r11, %r3, 23, 31;
    popc.b32 %r19, %r8;
    prmt.b32 %r11, %r19, %r11, 21520;
    prmt.b32 %r7, %r16, %r3, 17493;
    bfe.s32 %r8, %r23, 24, 16;
