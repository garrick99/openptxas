.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hi.u32 %p3, %r3, 4;
    @%p3 shr.u32 %r11, %r3, 31;
    sub.s32 %r22, %r3, %r11;
    cvt.s64.s32 %rd12, %r11;
    min.u32 %r20, %r3, 255;
    cvt.u64.u32 %rd11, %r22;
    shr.s32 %r12, %r11, 31;
    sub.s32 %r21, %r11, %r12;
    and.b32 %r24, %r21, 8;
    mul.wide.u32 %rd9, %r21, %r22;
    cvt.s32.s64 %r7, %rd9;
    max.s32 %r12, %r11, %r20;
    selp.b32 %r13, %r20, %r22, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
