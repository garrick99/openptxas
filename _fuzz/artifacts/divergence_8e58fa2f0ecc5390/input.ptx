.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p4, %r3, 255;
    shl.b32 %r12, %r3, 15;
    selp.b32 %r14, %r3, %r12, %p4;
    max.s32 %r5, %r14, 1;
    max.s32 %r6, %r12, 15;
    xor.b32 %r17, %r12, 65536;
    shl.b32 %r18, %r12, 2;
    add.u32 %r12, %r3, %r17;
    setp.eq.u32 %p3, %r14, 2147483647;
    @%p3 cvt.s64.s32 %rd9, %r17;
    sub.s32 %r8, %r5, 65535;
    cvt.u64.u32 %rd7, %r8;
    mad.lo.s32 %r6, %r17, %r12, %r12;
    cvt.s32.s64 %r19, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
