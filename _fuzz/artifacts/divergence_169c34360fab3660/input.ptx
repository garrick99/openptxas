.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r4, %r3, %r3;
    min.u32 %r23, %r4, %r4;
    sub.u32 %r21, %r4, %r4;
    min.u32 %r12, %r3, 0;
    add.u32 %r11, %r12, %r3;
    mad.lo.s32 %r22, %r4, %r4, %r3;
    sub.u32 %r14, %r22, %r11;
    cvt.u64.u32 %rd10, %r3;
    cvt.u64.u32 %rd7, %r23;
    mad.lo.s32 %r8, %r4, %r11, %r11;
    mul.lo.u32 %r25, %r4, 8;
    shr.s32 %r20, %r25, 3;
    cvt.s64.s32 %rd11, %r12;
    max.s32 %r22, %r8, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
