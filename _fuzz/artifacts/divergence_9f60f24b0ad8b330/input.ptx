.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    shl.b32 %r16, %r3, 15;
    max.u32 %r25, %r16, %r16;
    xor.b32 %r22, %r25, %r16;
    cvt.u32.u64 %r15, %rd14;
    setp.eq.s32 %p4, %r15, %r16;
    @%p4 or.b32 %r25, %r22, %r3;
    or.b32 %r25, %r25, %r15;
    mul.lo.u64 %rd12, %rd14, %rd14;
    sub.u32 %r10, %r22, %r16;
    selp.b32 %r6, %r22, %r22, %p4;
    cvt.u64.u32 %rd14, %r25;
    max.u64 %rd10, %rd12, %rd14;
    selp.b32 %r4, %r15, %r10, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
