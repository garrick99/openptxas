    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r13, %r3, 1;
    setp.ne.s32 %p3, %r13, 31;
    @%p3 cvt.s64.s32 %rd10, %r13;
    setp.gt.s32 %p3, %r3, 31;
    @!%p3 add.u32 %r5, %r13, %r3;
    setp.lt.s32 %p2, %r3, 15;
    @%p2 max.u32 %r17, %r3, 2147483647;
    mul.wide.u32 %rd14, %r17, %r5;
    min.s64 %rd12, %rd14, %rd10;
    min.s32 %r6, %r13, 2;
    mul.lo.s32 %r15, %r5, %r13;
