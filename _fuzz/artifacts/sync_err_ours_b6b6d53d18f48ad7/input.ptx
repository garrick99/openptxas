.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r27, %r3, 31;
    setp.ge.u32 %p4, %r3, 4294967295;
    mul.wide.s32 %rd8, %r27, %r27;
    shr.u32 %r19, %r3, 30;
    add.u64 %rd6, %rd8, %rd8;
    mul.lo.u32 %r22, %r19, %r19;
    mul.lo.s32 %r10, %r27, %r19;
    and.b32 %r26, %r19, 255;
    mad.lo.s32 %r23, %r19, %r3, %r27;
    add.u32 %r10, %r26, 2;
    mul.lo.u32 %r6, %r26, 4294967295;
    setp.le.s32 %p3, %r23, %r10;
    @%p3 min.u64 %rd11, %rd8, %rd8;
    min.s32 %r27, %r22, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
