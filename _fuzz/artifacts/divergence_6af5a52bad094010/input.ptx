.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    xor.b32 %r24, %r3, 64;
    max.s64 %rd12, %rd10, %rd10;
    cvt.u64.u32 %rd6, %r24;
    min.u32 %r6, %r24, 63;
    and.b32 %r8, %r6, 31;
    add.u32 %r4, %r3, 65535;
    setp.gt.s32 %p2, %r24, %r8;
    @%p2 shl.b64 %rd10, %rd10, 4;
    mul.wide.s32 %rd12, %r4, %r3;
    cvt.s64.s32 %rd13, %r4;
    cvt.u64.u32 %rd7, %r6;
    max.s32 %r27, %r3, 0;
    shr.s64 %rd6, %rd12, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
