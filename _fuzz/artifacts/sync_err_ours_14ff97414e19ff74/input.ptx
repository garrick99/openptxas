.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    add.s32 %r19, %r3, %r3;
    setp.lo.u32 %p1, %r19, %r19;
    @%p1 mul.lo.s32 %r8, %r19, %r19;
    setp.ge.u32 %p1, %r19, 65535;
    shr.s32 %r27, %r3, 2;
    max.u32 %r6, %r3, 63;
    setp.gt.u32 %p3, %r3, 64;
    setp.ne.s32 %p3, %r3, %r19;
    @%p3 cvt.s32.s64 %r23, %rd12;
    sub.s32 %r20, %r27, 3;
    setp.le.s32 %p4, %r23, 3;
    @%p4 and.b64 %rd12, %rd12, %rd12;
    min.s32 %r15, %r6, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
