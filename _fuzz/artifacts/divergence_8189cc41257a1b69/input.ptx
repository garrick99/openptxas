.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r23, %r3, %r3;
    cvt.s64.s32 %rd8, %r23;
    mul.wide.u32 %rd13, %r23, %r23;
    min.u32 %r6, %r3, 255;
    shr.s32 %r27, %r6, 31;
    setp.lt.u32 %p4, %r6, 2147483648;
    @!%p4 cvt.s64.s32 %rd5, %r23;
    mul.lo.u64 %rd11, %rd8, %rd8;
    add.s32 %r16, %r6, 31;
    mul.wide.u32 %rd9, %r16, %r6;
    max.s32 %r15, %r6, 15;
    selp.b32 %r6, %r27, %r15, %p4;
    and.b32 %r22, %r15, 4;
    add.u64 %rd10, %rd8, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
