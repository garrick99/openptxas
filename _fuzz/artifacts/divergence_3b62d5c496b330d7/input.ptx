.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r15, %r3, 7;
    setp.ge.s32 %p2, %r15, 0;
    @%p2 cvt.u64.u32 %rd15, %r3;
    cvt.u32.u64 %r4, %rd15;
    sub.s64 %rd8, %rd15, %rd15;
    mul.wide.u32 %rd6, %r3, %r3;
    mad.lo.u32 %r23, %r3, %r15, %r15;
    cvt.u32.u64 %r24, %rd8;
    mul.lo.s32 %r25, %r23, %r3;
    setp.hi.u32 %p2, %r15, 3;
    @%p2 mul.lo.s32 %r23, %r15, %r15;
    mad.lo.s32 %r23, %r4, %r24, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
