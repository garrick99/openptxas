.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r22, %r3, 30;
    mad.lo.u32 %r12, %r22, %r3, %r22;
    sub.u32 %r7, %r3, 31;
    mul.lo.u32 %r20, %r7, 4294967295;
    max.s32 %r19, %r12, 32;
    shr.s32 %r20, %r7, 16;
    cvt.u64.u32 %rd13, %r20;
    shr.s32 %r23, %r22, 4;
    shl.b64 %rd11, %rd13, 16;
    cvt.s64.s32 %rd14, %r20;
    mul.lo.u64 %rd9, %rd11, %rd11;
    mul.lo.u32 %r12, %r12, %r19;
    sub.u32 %r9, %r12, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
