.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p3, %r3, 65536;
    @%p3 cvt.u64.u32 %rd11, %r3;
    mad.lo.u32 %r17, %r3, %r3, %r3;
    shl.b32 %r6, %r17, 3;
    mad.lo.s32 %r7, %r3, %r17, %r6;
    min.u64 %rd12, %rd11, %rd11;
    shr.s64 %rd10, %rd12, 48;
    mul.wide.u32 %rd5, %r7, %r3;
    shr.s64 %rd13, %rd11, 32;
    sub.s64 %rd8, %rd11, %rd13;
    selp.b32 %r18, %r6, %r3, %p3;
    mul.lo.s32 %r24, %r17, 4;
    max.u32 %r19, %r24, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
