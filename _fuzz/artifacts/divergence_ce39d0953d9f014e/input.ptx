.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r17, %r3, 32;
    mul.wide.u32 %rd5, %r3, %r17;
    setp.hs.u32 %p4, %r17, 64;
    @%p4 add.u32 %r19, %r17, 15;
    add.u32 %r9, %r19, %r3;
    add.u64 %rd7, %rd5, %rd5;
    selp.b32 %r24, %r17, %r19, %p4;
    sub.u32 %r24, %r17, %r9;
    selp.b32 %r9, %r9, %r24, %p4;
    mul.wide.u32 %rd14, %r17, %r3;
    cvt.u32.u64 %r4, %rd5;
    cvt.u64.u32 %rd13, %r9;
    and.b32 %r21, %r3, %r17;
    sub.u32 %r10, %r3, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
