.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r5, %r3, %r3;
    shl.b32 %r17, %r3, 31;
    sub.u32 %r22, %r17, %r5;
    mul.wide.s32 %rd8, %r5, %r22;
    shr.s64 %rd11, %rd8, 48;
    shr.u32 %r11, %r3, 15;
    mad.lo.s32 %r14, %r3, %r17, %r22;
    mul.lo.s32 %r27, %r14, %r22;
    or.b32 %r27, %r22, %r22;
    add.u32 %r10, %r22, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
