.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p3, %r3, %r3;
    vote.sync.ballot.b32 %r9, %p3, -1;
    shfl.sync.bfly.b32 %r11, %r3, 4, 0x1f, -1;
    shfl.sync.up.b32 %r13, %r3, 1, 0x1f, -1;
    setp.ne.u32 %p2, %r13, %r3;
    vote.sync.ballot.b32 %r7, %p2, -1;
    shfl.sync.up.b32 %r14, %r7, 1, 0x1f, -1;
    min.u32 %r9, %r9, %r0;
    sub.u32 %r7, %r13, %r13;
    vote.sync.all.pred %p2, %p3, -1;
    setp.le.u32 %p3, %r14, %r14;
    vote.sync.ballot.b32 %r18, %p3, -1;
    sub.u32 %r9, %r13, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
