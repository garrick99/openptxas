.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd8, %r3, %r3;
    max.s32 %r8, %r3, 2147483648;
    mul.lo.u32 %r7, %r3, 64;
    min.u32 %r25, %r7, %r3;
    mad.lo.u32 %r19, %r7, %r8, %r3;
    max.s32 %r16, %r3, %r8;
    setp.le.u32 %p4, %r8, 65535;
    @!%p4 shr.s64 %rd9, %rd8, 15;
    min.u32 %r24, %r25, %r16;
    mul.lo.u64 %rd13, %rd8, %rd8;
    min.s32 %r21, %r24, 255;
    min.u32 %r10, %r8, %r7;
    setp.lt.s32 %p2, %r21, 32;
    @%p2 shl.b64 %rd15, %rd8, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
