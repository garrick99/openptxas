.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r6, %r3, 1;
    add.s32 %r9, %r6, 64;
    setp.gt.s32 %p4, %r6, 4;
    @!%p4 shr.u32 %r16, %r3, 0;
    or.b32 %r26, %r6, 5;
    mul.wide.u32 %rd13, %r6, %r6;
    shr.s32 %r4, %r3, 16;
    add.s64 %rd14, %rd13, %rd13;
    sub.s32 %r5, %r16, 4;
    max.s32 %r25, %r9, 16;
    mad.lo.s32 %r15, %r3, %r26, %r5;
    mad.lo.u32 %r9, %r25, %r9, %r26;
    setp.eq.s32 %p3, %r6, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
