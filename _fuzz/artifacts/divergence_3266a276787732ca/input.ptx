.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r9, %r3, %r3;
    cvt.u64.u32 %rd12, %r9;
    and.b64 %rd9, %rd12, %rd12;
    setp.hi.u32 %p4, %r3, %r9;
    @%p4 shr.s32 %r27, %r3, 15;
    selp.b32 %r12, %r3, %r9, %p4;
    sub.s32 %r6, %r27, %r9;
    shl.b32 %r11, %r12, 1;
    setp.lt.s32 %p4, %r12, 1;
    @%p4 shl.b32 %r11, %r9, 15;
    cvt.u64.u32 %rd5, %r12;
    mad.lo.u32 %r16, %r3, %r9, %r11;
    shl.b32 %r22, %r16, 15;
    min.u64 %rd11, %rd5, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
