.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r10, %r3, %r3;
    min.s32 %r24, %r10, %r3;
    shl.b32 %r21, %r3, 7;
    mul.wide.u32 %rd5, %r10, %r21;
    shl.b32 %r17, %r10, 16;
    sub.s32 %r25, %r10, %r10;
    setp.gt.u32 %p4, %r21, 65536;
    @!%p4 mul.lo.u32 %r23, %r17, %r3;
    mad.lo.u32 %r26, %r17, %r21, %r3;
    shl.b32 %r6, %r3, 1;
    max.s32 %r13, %r23, %r10;
    shr.s64 %rd12, %rd5, 2;
    mul.wide.s32 %rd15, %r21, %r25;
    setp.lt.s32 %p2, %r25, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
