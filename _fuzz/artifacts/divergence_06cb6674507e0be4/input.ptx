.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p2, %r3, 1;
    @%p2 add.u32 %r7, %r3, %r3;
    cvt.s64.s32 %rd11, %r7;
    sub.u32 %r11, %r7, 63;
    shr.s32 %r25, %r11, 1;
    setp.ne.s32 %p2, %r25, %r7;
    setp.gt.u32 %p3, %r25, %r3;
    @!%p3 max.u32 %r16, %r7, %r3;
    shr.u32 %r15, %r11, 15;
    max.u32 %r10, %r7, %r15;
    xor.b32 %r24, %r10, %r11;
    selp.b32 %r19, %r24, %r7, %p3;
    shl.b32 %r4, %r3, 15;
    mul.lo.u32 %r24, %r15, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
