.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r13, %r3, %r3;
    cvt.s64.s32 %rd6, %r13;
    setp.le.s32 %p2, %r3, %r3;
    @%p2 selp.b32 %r7, %r13, %r13, %p2;
    and.b64 %rd13, %rd6, %rd6;
    shr.u32 %r8, %r7, 7;
    min.u64 %rd9, %rd6, %rd6;
    setp.lt.u32 %p2, %r13, %r3;
    @%p2 shr.s64 %rd7, %rd6, 1;
    sub.s32 %r26, %r13, %r7;
    cvt.s64.s32 %rd10, %r26;
    setp.lt.s32 %p4, %r8, 15;
    @%p4 shr.u64 %rd12, %rd7, 2;
    max.s32 %r21, %r26, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
