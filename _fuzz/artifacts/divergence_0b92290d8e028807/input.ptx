.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r12, %r3, %r3;
    shr.s32 %r12, %r12, 2;
    mul.lo.s32 %r5, %r3, %r3;
    add.u32 %r10, %r3, %r12;
    setp.le.u32 %p3, %r10, 5;
    @!%p3 or.b32 %r9, %r12, 16;
    min.u32 %r13, %r9, 63;
    mad.lo.s32 %r8, %r13, %r5, %r12;
    mul.lo.s32 %r22, %r12, 256;
    cvt.u64.u32 %rd14, %r5;
    add.u32 %r13, %r10, %r13;
    selp.b32 %r5, %r9, %r12, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
