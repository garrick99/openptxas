.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p4, %r3, %r3;
    @!%p4 cvt.u64.u32 %rd10, %r3;
    sub.s32 %r17, %r3, 65535;
    selp.b32 %r22, %r3, %r17, %p4;
    add.u32 %r24, %r3, %r22;
    min.u32 %r23, %r24, %r17;
    max.u32 %r7, %r17, %r24;
    add.s32 %r20, %r23, %r24;
    and.b32 %r6, %r22, %r24;
    mad.lo.s32 %r9, %r24, %r3, %r7;
    mad.lo.u32 %r12, %r9, %r23, %r17;
    setp.gt.u32 %p1, %r23, 64;
    @%p1 min.u32 %r16, %r17, %r12;
    cvt.u32.u64 %r13, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
