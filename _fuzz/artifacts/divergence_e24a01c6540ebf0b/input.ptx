.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd15, %r3, %r3;
    mad.lo.s32 %r22, %r3, %r3, %r3;
    add.u32 %r6, %r22, 65535;
    mul.wide.s32 %rd14, %r22, %r6;
    min.u32 %r12, %r3, 4;
    min.u32 %r16, %r12, 1;
    shr.s32 %r17, %r6, 15;
    setp.lt.s32 %p1, %r3, %r3;
    @%p1 min.s32 %r11, %r6, %r12;
    mad.lo.s32 %r12, %r17, %r22, %r3;
    min.s32 %r14, %r12, %r6;
    sub.s32 %r25, %r14, %r6;
    xor.b32 %r11, %r17, %r16;
    shr.u32 %r16, %r16, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
