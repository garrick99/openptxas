.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r20, %r3, 32;
    xor.b32 %r9, %r3, 4294967295;
    sub.u32 %r19, %r9, 65536;
    shr.s32 %r6, %r9, 30;
    setp.gt.s32 %p3, %r6, 64;
    @%p3 cvt.s64.s32 %rd6, %r9;
    sub.s32 %r16, %r3, %r9;
    cvt.s32.s64 %r20, %rd6;
    setp.le.s32 %p3, %r3, 0;
    @%p3 min.s32 %r17, %r19, 7;
    shr.u32 %r8, %r16, 1;
    shr.u32 %r27, %r16, 4;
    mad.lo.u32 %r5, %r27, %r3, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
