    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p1, %r3, %r3;
    @%p1 cvt.s64.s32 %rd6, %r3;
    or.b64 %rd14, %rd6, %rd6;
    cvt.s64.s32 %rd10, %r3;
    shr.s32 %r17, %r3, 2;
    setp.lt.s32 %p1, %r17, 255;
    @%p1 min.u32 %r26, %r17, %r3;
    min.u32 %r23, %r3, 3;
    setp.le.u32 %p2, %r26, 2147483647;
    @%p2 cvt.u32.u64 %r24, %rd14;
    shr.u32 %r17, %r17, 31;
    selp.b32 %r7, %r23, %r17, %p2;
    max.u32 %r13, %r24, %r26;
    setp.lt.s32 %p1, %r24, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
