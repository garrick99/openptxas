.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r17, %r3, %r3, %r3;
    mad.lo.s32 %r21, %r17, %r3, %r17;
    mul.wide.u32 %rd6, %r3, %r17;
    add.s32 %r13, %r21, %r17;
    mul.wide.s32 %rd8, %r21, %r17;
    mul.lo.u32 %r14, %r3, %r3;
    shr.s32 %r7, %r13, 1;
    xor.b32 %r21, %r3, %r13;
    setp.le.s32 %p4, %r17, 64;
    shl.b64 %rd13, %rd8, 31;
    mad.lo.u32 %r27, %r17, %r17, %r14;
    add.s32 %r20, %r13, 31;
    or.b32 %r16, %r13, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
