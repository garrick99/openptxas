.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd14, %r3, %r3;
    shr.u64 %rd6, %rd14, 31;
    xor.b64 %rd15, %rd6, %rd14;
    shr.s64 %rd11, %rd6, 7;
    add.s32 %r20, %r3, %r3;
    mul.wide.s32 %rd8, %r20, %r20;
    mul.wide.s32 %rd8, %r20, %r3;
    shr.s32 %r27, %r3, 4;
    min.u32 %r25, %r27, 63;
    mul.wide.s32 %rd12, %r20, %r25;
    mul.lo.s32 %r26, %r25, %r27;
    min.u32 %r13, %r27, %r25;
    add.u32 %r17, %r27, %r26;
    mad.lo.u32 %r21, %r27, %r26, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
