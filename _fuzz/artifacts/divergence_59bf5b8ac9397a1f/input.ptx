.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r10, %r3, 2;
    mul.lo.s32 %r13, %r10, 4294967295;
    mad.lo.s32 %r26, %r13, %r3, %r10;
    shr.s32 %r17, %r3, 4;
    xor.b32 %r14, %r13, 65536;
    min.u32 %r17, %r10, 255;
    cvt.s64.s32 %rd6, %r10;
    max.s64 %rd6, %rd6, %rd6;
    min.s32 %r7, %r10, 64;
    sub.u32 %r23, %r7, %r7;
    shr.u32 %r26, %r23, 15;
    min.u32 %r24, %r7, %r3;
    mul.lo.s32 %r13, %r10, %r14;
    mul.lo.u64 %rd11, %rd6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
