.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p4, %r3, %r3;
    @%p4 mul.lo.u32 %r18, %r3, 4294967295;
    min.u32 %r4, %r18, 15;
    add.u32 %r16, %r4, %r4;
    cvt.u64.u32 %rd5, %r16;
    mul.wide.s32 %rd5, %r3, %r18;
    cvt.s32.s64 %r23, %rd5;
    min.s32 %r12, %r16, %r3;
    shr.u64 %rd6, %rd5, 16;
    shr.s64 %rd13, %rd6, 32;
    shr.u64 %rd10, %rd6, 48;
    min.s32 %r22, %r4, %r12;
    shl.b32 %r20, %r12, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
