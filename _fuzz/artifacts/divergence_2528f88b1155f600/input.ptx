.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r6, %r3, 65536;
    setp.lt.s32 %p4, %r6, 63;
    @%p4 cvt.s64.s32 %rd7, %r3;
    shl.b32 %r23, %r3, 4;
    cvt.u32.u64 %r13, %rd7;
    mad.lo.u32 %r12, %r13, %r6, %r3;
    cvt.u64.u32 %rd7, %r12;
    max.s32 %r7, %r6, 2147483647;
    setp.lt.u32 %p2, %r6, %r3;
    shr.s64 %rd12, %rd7, 15;
    min.u32 %r25, %r12, %r12;
    shr.s32 %r22, %r25, 1;
    max.u32 %r12, %r12, %r6;
    cvt.u64.u32 %rd8, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
