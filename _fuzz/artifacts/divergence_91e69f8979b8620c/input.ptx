.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    xor.b32 %r22, %r3, 64;
    setp.ls.u32 %p1, %r3, 1;
    shl.b32 %r10, %r22, 0;
    xor.b32 %r4, %r22, %r22;
    add.s32 %r5, %r10, %r4;
    shl.b64 %rd5, %rd14, 32;
    mad.lo.u32 %r17, %r10, %r3, %r5;
    xor.b32 %r15, %r5, %r10;
    shr.s32 %r16, %r5, 16;
    cvt.s32.s64 %r24, %rd14;
    max.u32 %r17, %r10, %r4;
    setp.lt.u32 %p2, %r22, %r5;
    @%p2 mad.lo.s32 %r26, %r5, %r4, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
