.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r22, %r3, %r3;
    shl.b32 %r7, %r3, 2;
    and.b32 %r21, %r3, 5;
    max.s32 %r5, %r3, %r21;
    setp.le.s32 %p4, %r22, %r22;
    @%p4 cvt.s64.s32 %rd13, %r21;
    cvt.u64.u32 %rd8, %r21;
    mul.lo.s32 %r7, %r21, 4;
    shr.u32 %r27, %r7, 1;
    setp.eq.s32 %p3, %r27, %r21;
    @%p3 and.b32 %r14, %r27, %r21;
    setp.le.u32 %p2, %r22, 64;
    @%p2 selp.b32 %r19, %r14, %r14, %p3;
    mul.wide.u32 %rd8, %r21, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
