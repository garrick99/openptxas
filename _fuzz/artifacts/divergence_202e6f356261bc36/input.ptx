.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    setp.ne.u32 %p1, %r3, %r3;
    @%p1 cvt.s64.s32 %rd5, %r3;
    min.u32 %r14, %r3, 256;
    min.u32 %r13, %r3, %r3;
    cvt.s32.s64 %r25, %rd5;
    cvt.s32.s64 %r4, %rd14;
    cvt.s64.s32 %rd15, %r13;
    mul.wide.u32 %rd7, %r13, %r25;
    selp.b32 %r12, %r13, %r25, %p1;
    shr.s32 %r13, %r25, 15;
    and.b64 %rd6, %rd5, %rd14;
    or.b32 %r14, %r13, %r4;
    setp.hi.u32 %p3, %r3, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
