.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r24, %r3, 1;
    min.u32 %r5, %r24, 65536;
    shl.b32 %r6, %r3, 4;
    cvt.u64.u32 %rd14, %r3;
    max.s64 %rd5, %rd14, %rd14;
    max.s32 %r5, %r6, %r24;
    cvt.s32.s64 %r6, %rd5;
    and.b32 %r4, %r3, 32;
    mad.lo.u32 %r6, %r6, %r3, %r3;
    and.b32 %r6, %r3, %r4;
    xor.b32 %r16, %r3, %r6;
    shl.b32 %r27, %r5, 30;
    setp.eq.u32 %p4, %r6, %r27;
    @%p4 shl.b32 %r25, %r6, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
