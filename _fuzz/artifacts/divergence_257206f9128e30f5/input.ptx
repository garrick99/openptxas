.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r7, %r3, 5;
    add.s32 %r14, %r3, %r7;
    max.u32 %r13, %r14, 256;
    setp.ge.s32 %p3, %r14, 8;
    @%p3 cvt.s64.s32 %rd5, %r14;
    shr.s32 %r16, %r14, 7;
    add.s32 %r19, %r7, 0;
    selp.b32 %r18, %r7, %r3, %p3;
    min.s32 %r24, %r13, 63;
    mul.lo.u32 %r6, %r14, %r3;
    min.u32 %r27, %r13, %r13;
    setp.gt.u32 %p3, %r19, %r3;
    @%p3 max.s32 %r23, %r7, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
