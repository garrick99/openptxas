.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd11, %r3, %r3;
    mul.lo.u32 %r14, %r3, 4294967295;
    mul.wide.u32 %rd7, %r14, %r3;
    shr.u32 %r23, %r3, 31;
    mul.wide.s32 %rd12, %r14, %r23;
    cvt.u32.u64 %r20, %rd12;
    setp.ge.s32 %p3, %r3, 4;
    @%p3 cvt.s32.s64 %r18, %rd11;
    shr.s32 %r17, %r23, 0;
    max.u32 %r19, %r23, 2;
    add.s64 %rd6, %rd7, %rd12;
    shr.u32 %r16, %r14, 4;
    mul.lo.u32 %r10, %r17, %r17;
    mad.lo.u32 %r7, %r16, %r17, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
