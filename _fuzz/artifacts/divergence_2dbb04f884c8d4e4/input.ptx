.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r8, %r3, 3;
    mul.wide.s32 %rd5, %r8, %r8;
    shl.b32 %r19, %r8, 0;
    or.b64 %rd10, %rd5, %rd5;
    cvt.u64.u32 %rd12, %r3;
    sub.u32 %r7, %r8, %r8;
    setp.lt.u32 %p1, %r7, 2;
    @%p1 sub.u64 %rd7, %rd5, %rd12;
    selp.b32 %r4, %r19, %r19, %p1;
    selp.b32 %r5, %r4, %r8, %p1;
    setp.lt.s32 %p4, %r5, 2147483648;
    @%p4 or.b32 %r17, %r7, %r19;
    shr.s64 %rd11, %rd5, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
