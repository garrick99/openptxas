.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r20, %r3, 0;
    sub.u32 %r23, %r20, %r3;
    mul.wide.u32 %rd8, %r20, %r3;
    xor.b32 %r22, %r3, %r23;
    setp.eq.s32 %p3, %r20, %r3;
    @%p3 cvt.s64.s32 %rd10, %r22;
    sub.s32 %r12, %r3, %r3;
    shr.s32 %r27, %r23, 31;
    mad.lo.s32 %r18, %r23, %r12, %r12;
    xor.b64 %rd11, %rd10, %rd10;
    max.u32 %r8, %r23, %r20;
    and.b32 %r19, %r20, 2;
    and.b32 %r14, %r19, 64;
    selp.b32 %r22, %r8, %r19, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
