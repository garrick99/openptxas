.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r9, %r3, %r3, %r3;
    cvt.s64.s32 %rd6, %r3;
    and.b32 %r19, %r9, %r3;
    shr.u32 %r11, %r3, 7;
    mad.lo.u32 %r4, %r3, %r11, %r11;
    max.s32 %r14, %r9, %r19;
    setp.eq.s32 %p4, %r9, 2147483648;
    @%p4 cvt.s32.s64 %r6, %rd6;
    sub.s32 %r25, %r4, %r6;
    shl.b64 %rd14, %rd6, 4;
    shr.s32 %r27, %r9, 31;
    mul.lo.s64 %rd10, %rd6, %rd6;
    shl.b32 %r7, %r11, 30;
    sub.s32 %r25, %r6, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
