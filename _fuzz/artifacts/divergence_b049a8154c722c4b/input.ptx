.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r9, %r3, %r3;
    shr.s32 %r19, %r3, 0;
    cvt.u64.u32 %rd11, %r3;
    mad.lo.s32 %r26, %r19, %r19, %r19;
    and.b32 %r12, %r19, %r19;
    add.s32 %r17, %r3, %r3;
    cvt.s32.s64 %r17, %rd11;
    min.s64 %rd15, %rd11, %rd11;
    add.s32 %r22, %r3, %r17;
    xor.b32 %r20, %r12, %r3;
    max.u32 %r14, %r17, 31;
    cvt.u64.u32 %rd9, %r26;
    shr.u64 %rd13, %rd11, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
