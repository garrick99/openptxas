.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    mul.lo.s32 %r19, %r3, %r3;
    sub.u32 %r4, %r3, %r19;
    mul.lo.u64 %rd13, %rd12, %rd12;
    mul.wide.s32 %rd5, %r4, %r19;
    cvt.u64.u32 %rd15, %r3;
    mul.wide.s32 %rd8, %r4, %r19;
    shr.u32 %r11, %r4, 4;
    mad.lo.u32 %r19, %r11, %r19, %r4;
    sub.u32 %r27, %r19, 16;
    max.u32 %r19, %r11, %r27;
    shr.s32 %r21, %r4, 2;
    mad.lo.u32 %r16, %r11, %r3, %r27;
    or.b64 %rd10, %rd5, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
