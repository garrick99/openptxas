.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r23, %r3, 255;
    min.u32 %r8, %r3, 3;
    min.s32 %r5, %r23, 7;
    cvt.u64.u32 %rd13, %r3;
    sub.s32 %r17, %r23, %r5;
    mad.lo.s32 %r13, %r17, %r8, %r5;
    shr.u32 %r8, %r23, 3;
    min.u32 %r19, %r17, %r8;
    min.u32 %r10, %r3, %r8;
    add.s32 %r23, %r19, %r19;
    setp.ls.u32 %p1, %r17, 16;
    @%p1 mul.wide.s32 %rd9, %r3, %r13;
    setp.ge.s32 %p3, %r13, 2;
    @%p3 shr.s32 %r10, %r8, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
