.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    cvt.s64.s32 %rd12, %r3;
    max.s64 %rd15, %rd11, %rd12;
    max.s32 %r9, %r3, 16;
    cvt.s32.s64 %r14, %rd11;
    add.s32 %r14, %r9, %r14;
    sub.u32 %r4, %r14, 4294967295;
    or.b32 %r6, %r4, 32;
    shl.b32 %r24, %r9, 3;
    cvt.u64.u32 %rd6, %r14;
    min.u32 %r4, %r3, 4294967295;
    setp.le.s32 %p3, %r6, 0;
    @%p3 selp.b32 %r19, %r14, %r14, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
