.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r22, %r3, 0;
    cvt.u64.u32 %rd11, %r22;
    mul.lo.s32 %r8, %r22, %r22;
    mul.lo.s32 %r25, %r22, 15;
    shl.b32 %r22, %r25, 2;
    min.s32 %r17, %r22, %r25;
    mul.wide.s32 %rd5, %r17, %r25;
    cvt.u64.u32 %rd12, %r17;
    min.u32 %r22, %r25, %r25;
    cvt.s64.s32 %rd11, %r17;
    add.u32 %r13, %r3, %r3;
    add.u32 %r9, %r22, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
