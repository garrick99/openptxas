.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p3, %r3, %r3;
    add.s32 %r14, %r3, %r3;
    mad.lo.s32 %r13, %r3, %r3, %r14;
    max.u32 %r5, %r3, 255;
    shl.b32 %r22, %r14, 16;
    add.s32 %r7, %r5, 5;
    setp.le.s32 %p2, %r13, %r7;
    cvt.u64.u32 %rd7, %r14;
    shr.s64 %rd11, %rd7, 0;
    min.u32 %r27, %r13, %r14;
    mul.wide.u32 %rd10, %r27, %r3;
    mad.lo.u32 %r7, %r3, %r3, %r27;
    setp.lt.s32 %p2, %r22, 1;
    @%p2 shr.s32 %r8, %r13, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
