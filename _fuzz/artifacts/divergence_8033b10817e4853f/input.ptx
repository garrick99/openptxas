.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p4, %r3, 32;
    @%p4 shr.s32 %r17, %r3, 30;
    shl.b32 %r4, %r17, 4;
    sub.u32 %r21, %r17, 31;
    mul.wide.u32 %rd11, %r3, %r3;
    setp.ge.s32 %p2, %r3, 2;
    max.u32 %r21, %r21, %r3;
    max.u32 %r14, %r4, %r17;
    sub.u32 %r18, %r14, 65535;
    mul.wide.s32 %rd13, %r21, %r18;
    max.u32 %r27, %r21, 15;
    sub.s32 %r26, %r14, 63;
    setp.le.s32 %p3, %r3, %r26;
    @!%p3 selp.b32 %r6, %r17, %r18, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
