.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r23, %r3, 65535;
    and.b32 %r4, %r23, 1;
    and.b32 %r4, %r4, 7;
    mul.wide.s32 %rd11, %r4, %r23;
    shl.b32 %r4, %r4, 31;
    add.u32 %r21, %r3, %r23;
    add.s64 %rd10, %rd11, %rd11;
    and.b64 %rd5, %rd10, %rd10;
    sub.s32 %r20, %r23, 7;
    shr.u32 %r21, %r21, 30;
    shl.b64 %rd13, %rd10, 3;
    mul.lo.u32 %r21, %r4, %r4;
    min.u32 %r27, %r20, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
