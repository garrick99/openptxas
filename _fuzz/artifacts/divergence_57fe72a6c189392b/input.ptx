.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r21, %r3, 3;
    setp.ge.s32 %p2, %r3, 0;
    @%p2 shr.u32 %r14, %r21, 31;
    cvt.u64.u32 %rd13, %r21;
    and.b32 %r24, %r21, 65535;
    cvt.u64.u32 %rd6, %r14;
    mad.lo.u32 %r21, %r21, %r14, %r24;
    xor.b32 %r25, %r21, 256;
    mul.lo.s64 %rd15, %rd6, %rd6;
    max.s32 %r8, %r25, %r25;
    cvt.u32.u64 %r26, %rd15;
    shr.u32 %r27, %r8, 3;
    xor.b32 %r10, %r21, %r14;
    mad.lo.u32 %r8, %r8, %r14, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
