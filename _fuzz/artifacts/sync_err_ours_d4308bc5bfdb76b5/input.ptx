.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p1, %r3, 255;
    @%p1 mad.lo.u32 %r8, %r3, %r3, %r3;
    sub.s32 %r17, %r8, 65536;
    and.b32 %r19, %r3, %r8;
    cvt.s64.s32 %rd10, %r17;
    max.u32 %r8, %r8, %r19;
    or.b32 %r12, %r8, 4;
    cvt.s64.s32 %rd14, %r12;
    mul.lo.s64 %rd9, %rd14, %rd10;
    shl.b64 %rd15, %rd9, 62;
    min.s32 %r13, %r19, %r8;
    mad.lo.s32 %r6, %r13, %r3, %r8;
    min.u32 %r12, %r12, %r3;
    shl.b64 %rd9, %rd9, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
