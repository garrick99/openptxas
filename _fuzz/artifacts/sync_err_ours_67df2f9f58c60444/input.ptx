.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r11, %r3, 2;
    or.b32 %r8, %r3, %r11;
    cvt.u64.u32 %rd9, %r3;
    cvt.s64.s32 %rd5, %r11;
    mad.lo.u32 %r27, %r3, %r8, %r8;
    mad.lo.s32 %r8, %r3, %r27, %r27;
    setp.le.s32 %p1, %r3, 255;
    setp.le.u32 %p1, %r11, 31;
    @%p1 cvt.s64.s32 %rd7, %r27;
    mul.lo.u64 %rd8, %rd7, %rd5;
    shr.s32 %r16, %r11, 15;
    cvt.u64.u32 %rd12, %r27;
    mad.lo.u32 %r11, %r11, %r27, %r8;
    mul.lo.s64 %rd9, %rd7, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
