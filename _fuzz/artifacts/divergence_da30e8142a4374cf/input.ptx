.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    cvt.u64.u32 %rd9, %r3;
    cvt.u64.u32 %rd8, %r3;
    and.b32 %r24, %r3, %r3;
    sub.s32 %r25, %r24, 65535;
    mad.lo.u32 %r23, %r25, %r3, %r25;
    setp.le.s32 %p1, %r23, %r25;
    @%p1 min.u32 %r19, %r3, %r3;
    mul.wide.u32 %rd6, %r24, %r19;
    min.u32 %r13, %r25, %r23;
    mul.wide.s32 %rd9, %r19, %r24;
    or.b32 %r9, %r19, %r23;
    mul.lo.s32 %r23, %r23, %r19;
    add.u64 %rd5, %rd9, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
