.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    xor.b32 %r27, %r3, 2147483647;
    or.b32 %r13, %r3, 64;
    and.b32 %r7, %r3, %r3;
    shl.b32 %r6, %r13, 7;
    shr.u32 %r12, %r13, 4;
    cvt.u64.u32 %rd6, %r13;
    mul.wide.s32 %rd11, %r13, %r3;
    max.s32 %r18, %r27, %r6;
    mad.lo.u32 %r16, %r13, %r3, %r7;
    mul.wide.u32 %rd12, %r13, %r6;
    and.b32 %r14, %r27, 63;
    mul.lo.s32 %r17, %r3, 65536;
    shl.b32 %r16, %r17, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
