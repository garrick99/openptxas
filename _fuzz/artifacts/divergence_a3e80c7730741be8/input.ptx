.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r26, %r3, %r3;
    mul.wide.u32 %rd14, %r3, %r3;
    max.s32 %r11, %r26, 1;
    cvt.s32.s64 %r22, %rd14;
    cvt.s64.s32 %rd8, %r26;
    xor.b64 %rd11, %rd14, %rd8;
    min.u32 %r7, %r11, 63;
    add.u32 %r10, %r26, 5;
    mul.lo.s64 %rd5, %rd14, %rd11;
    sub.u32 %r21, %r7, %r22;
    min.u32 %r22, %r26, 0;
    shl.b32 %r13, %r11, 30;
    add.u32 %r5, %r21, %r10;
    setp.ne.u32 %p2, %r5, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
