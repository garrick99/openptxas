.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r16, %r3, 7;
    mul.wide.u32 %rd5, %r16, %r16;
    max.u32 %r10, %r3, %r3;
    cvt.s32.s64 %r7, %rd5;
    cvt.u32.u64 %r15, %rd5;
    shr.u32 %r16, %r10, 0;
    mul.lo.u32 %r5, %r3, %r16;
    max.u32 %r10, %r15, %r3;
    and.b32 %r9, %r3, %r16;
    or.b32 %r15, %r15, 15;
    add.s32 %r14, %r9, 16;
    add.u32 %r19, %r16, 255;
    mad.lo.s32 %r16, %r3, %r9, %r3;
    setp.le.s32 %p4, %r15, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
