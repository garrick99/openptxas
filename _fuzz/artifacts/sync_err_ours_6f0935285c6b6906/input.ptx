.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r14, %r3, %r3;
    setp.le.u32 %p2, %r14, 65536;
    shr.s32 %r16, %r3, 30;
    shl.b32 %r13, %r16, 30;
    setp.lt.u32 %p2, %r16, 16;
    @!%p2 min.s32 %r13, %r16, %r16;
    max.u32 %r5, %r16, %r13;
    setp.ne.s32 %p2, %r13, 63;
    @%p2 sub.u32 %r18, %r3, %r13;
    cvt.u64.u32 %rd5, %r18;
    or.b32 %r26, %r14, 2147483647;
    mul.wide.s32 %rd6, %r3, %r14;
    and.b64 %rd5, %rd5, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
