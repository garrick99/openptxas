.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    mul.lo.s32 %r20, %r3, %r3;
    max.s64 %rd12, %rd10, %rd10;
    shl.b32 %r14, %r20, 4;
    sub.s32 %r6, %r3, 3;
    mul.lo.s32 %r4, %r3, %r6;
    mad.lo.u32 %r26, %r14, %r4, %r3;
    sub.s32 %r5, %r26, %r6;
    shr.s32 %r16, %r4, 1;
    shr.s64 %rd10, %rd10, 0;
    mad.lo.s32 %r11, %r20, %r20, %r14;
    add.s32 %r8, %r26, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
