.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r11, %r3, %r3;
    cvt.s64.s32 %rd13, %r3;
    setp.lt.s32 %p1, %r11, 256;
    setp.le.u32 %p1, %r11, 3;
    @%p1 min.s32 %r19, %r3, 4294967295;
    selp.b32 %r23, %r19, %r11, %p1;
    max.s32 %r24, %r3, %r19;
    mad.lo.u32 %r18, %r19, %r11, %r19;
    and.b64 %rd12, %rd13, %rd13;
    mul.lo.s32 %r8, %r3, %r18;
    selp.b32 %r27, %r11, %r23, %p1;
    setp.ls.u32 %p4, %r24, 2147483647;
    @%p4 cvt.u32.u64 %r16, %rd12;
    max.u64 %rd8, %rd13, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
