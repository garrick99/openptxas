.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd10, %r3, %r3;
    min.u64 %rd6, %rd10, %rd10;
    and.b32 %r15, %r3, 15;
    cvt.u64.u32 %rd6, %r3;
    shr.s32 %r4, %r15, 2;
    max.u32 %r18, %r4, %r15;
    or.b32 %r19, %r18, 4294967295;
    cvt.u64.u32 %rd14, %r19;
    cvt.s32.s64 %r22, %rd6;
    cvt.s32.s64 %r26, %rd10;
    mad.lo.s32 %r23, %r19, %r18, %r19;
    sub.s32 %r4, %r4, %r23;
    cvt.s64.s32 %rd14, %r4;
    mad.lo.u32 %r24, %r18, %r19, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
