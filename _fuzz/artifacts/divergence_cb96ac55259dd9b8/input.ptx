.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    mad.lo.u32 %r18, %r3, %r3, %r3;
    mul.lo.s32 %r19, %r3, 256;
    mul.lo.u32 %r17, %r3, 65536;
    shl.b32 %r26, %r17, 2;
    sub.u32 %r24, %r3, %r26;
    mad.lo.s32 %r14, %r3, %r24, %r26;
    max.u32 %r12, %r18, %r18;
    mul.lo.s32 %r22, %r14, 4;
    mad.lo.s32 %r20, %r22, %r17, %r17;
    sub.s32 %r8, %r14, %r14;
    setp.ge.u32 %p2, %r24, 0;
    @!%p2 max.s32 %r16, %r26, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
