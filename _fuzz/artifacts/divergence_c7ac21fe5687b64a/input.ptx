.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r23, %r3, %r3, %r3;
    cvt.s64.s32 %rd10, %r23;
    sub.u64 %rd7, %rd10, %rd10;
    max.u32 %r18, %r3, %r3;
    cvt.u64.u32 %rd13, %r23;
    mul.wide.u32 %rd8, %r18, %r18;
    setp.lt.u32 %p4, %r18, %r3;
    min.s32 %r25, %r23, 15;
    selp.b32 %r21, %r23, %r23, %p4;
    max.u32 %r20, %r23, 0;
    min.s32 %r8, %r25, %r25;
    mul.lo.s32 %r16, %r8, 4294967295;
    min.s32 %r16, %r3, 64;
    selp.b32 %r5, %r8, %r23, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
