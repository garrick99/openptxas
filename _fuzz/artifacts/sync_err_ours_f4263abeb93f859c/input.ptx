.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r4, %r3, 2;
    shr.u32 %r19, %r3, 30;
    cvt.u64.u32 %rd14, %r3;
    mad.lo.s32 %r26, %r4, %r19, %r4;
    shl.b32 %r10, %r19, 1;
    mul.wide.u32 %rd12, %r10, %r26;
    sub.s32 %r26, %r10, %r26;
    xor.b64 %rd8, %rd14, %rd14;
    mul.lo.u32 %r17, %r10, 65536;
    sub.u32 %r25, %r3, 32;
    cvt.s32.s64 %r17, %rd14;
    sub.u32 %r5, %r17, %r25;
    cvt.s32.s64 %r18, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
