.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r17, %r3, %r3;
    prmt.b32 %r20, %r17, %r3, 21520;
    clz.b32 %r21, %r17;
    brev.b32 %r7, %r20;
    clz.b32 %r15, %r3;
    bfi.b32 %r12, %r15, %r15, 0, 16;
    bfe.s32 %r19, %r15, 4, 1;
    bfi.b32 %r7, %r17, %r3, 24, 1;
    bfe.s32 %r21, %r21, 31, 1;
    min.u32 %r21, %r21, %r7;
    bfe.u32 %r14, %r17, 31, 24;
    max.u32 %r13, %r21, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
