.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r12, %r3, %r3;
    and.b32 %r6, %r3, 1;
    cvt.s64.s32 %rd15, %r3;
    min.u32 %r21, %r3, 256;
    cvt.u32.u64 %r5, %rd15;
    add.u32 %r19, %r21, 16;
    cvt.s64.s32 %rd8, %r6;
    sub.u32 %r20, %r21, %r21;
    mul.wide.u32 %rd10, %r20, %r20;
    sub.s32 %r25, %r21, %r5;
    setp.gt.u32 %p4, %r19, 4;
    mul.wide.u32 %rd15, %r19, %r3;
    xor.b32 %r27, %r21, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
