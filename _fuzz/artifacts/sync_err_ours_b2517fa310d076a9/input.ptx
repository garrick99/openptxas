.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r13, %r3, 15;
    mad.lo.s32 %r9, %r3, %r13, %r13;
    cvt.u64.u32 %rd8, %r13;
    and.b64 %rd15, %rd8, %rd8;
    add.u32 %r5, %r3, %r13;
    shr.s64 %rd7, %rd15, 62;
    xor.b32 %r4, %r3, %r13;
    setp.le.s32 %p4, %r3, 4;
    xor.b32 %r20, %r4, %r13;
    sub.s32 %r12, %r9, %r4;
    min.s64 %rd6, %rd15, %rd8;
    sub.u32 %r7, %r13, %r20;
    mad.lo.u32 %r17, %r12, %r4, %r4;
    selp.b32 %r16, %r9, %r17, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
