.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r10, %r3, %r3;
    max.s32 %r14, %r3, 255;
    max.s32 %r22, %r14, %r10;
    add.u32 %r5, %r10, 2147483648;
    or.b32 %r7, %r22, %r5;
    setp.eq.s32 %p4, %r22, %r14;
    @!%p4 sub.s32 %r21, %r7, 63;
    mul.wide.u32 %rd7, %r22, %r22;
    sub.u32 %r25, %r22, %r22;
    selp.b32 %r11, %r10, %r14, %p4;
    max.s32 %r17, %r5, %r5;
    shr.u32 %r12, %r10, 16;
    xor.b32 %r4, %r17, %r5;
    add.s32 %r11, %r22, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
