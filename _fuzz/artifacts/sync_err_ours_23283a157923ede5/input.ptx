.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd8, %r3, %r3;
    min.s32 %r20, %r3, 4;
    sub.s32 %r10, %r3, 16;
    add.u32 %r17, %r3, 256;
    setp.le.s32 %p1, %r10, %r10;
    @%p1 shl.b32 %r25, %r10, 3;
    mad.lo.u32 %r13, %r25, %r20, %r25;
    min.u64 %rd6, %rd8, %rd8;
    add.s32 %r9, %r13, %r17;
    setp.eq.s32 %p4, %r13, 256;
    @%p4 sub.s32 %r17, %r13, 2147483648;
    max.s32 %r12, %r3, 16;
    mad.lo.s32 %r8, %r3, %r9, %r20;
    mul.wide.u32 %rd9, %r12, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
