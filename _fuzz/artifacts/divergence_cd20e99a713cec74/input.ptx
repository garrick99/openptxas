.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r16, %r3, 32;
    sub.u32 %r10, %r16, 16;
    mul.lo.s32 %r26, %r10, 5;
    cvt.u64.u32 %rd15, %r3;
    sub.s32 %r11, %r16, %r10;
    mul.wide.s32 %rd11, %r26, %r26;
    setp.lo.u32 %p3, %r11, 256;
    setp.hs.u32 %p1, %r26, %r10;
    @%p1 mad.lo.u32 %r24, %r11, %r3, %r3;
    max.s32 %r20, %r10, 2147483647;
    mul.lo.u32 %r11, %r24, %r26;
    and.b32 %r26, %r16, 2;
    min.u32 %r15, %r20, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
