.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r21, %r3, 2;
    min.u32 %r5, %r21, 5;
    cvt.u64.u32 %rd9, %r21;
    shl.b64 %rd7, %rd9, 30;
    or.b32 %r25, %r3, 7;
    or.b64 %rd10, %rd9, %rd9;
    shr.s64 %rd13, %rd7, 47;
    mul.wide.u32 %rd11, %r3, %r21;
    max.s32 %r19, %r5, 65536;
    shl.b64 %rd9, %rd11, 62;
    shr.s64 %rd6, %rd13, 48;
    shl.b32 %r16, %r3, 31;
    sub.s32 %r5, %r5, 31;
    mul.wide.s32 %rd15, %r5, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
