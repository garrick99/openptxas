.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p2, %r3, %r3;
    @!%p2 cvt.s64.s32 %rd15, %r3;
    shr.u64 %rd12, %rd15, 62;
    mul.wide.s32 %rd15, %r3, %r3;
    add.s32 %r24, %r3, 7;
    selp.b32 %r5, %r3, %r3, %p2;
    mul.wide.s32 %rd14, %r24, %r24;
    add.u32 %r14, %r24, %r24;
    add.s32 %r7, %r3, %r24;
    cvt.u64.u32 %rd10, %r24;
    mul.wide.s32 %rd12, %r5, %r24;
    setp.lt.s32 %p3, %r14, %r14;
    @%p3 cvt.s64.s32 %rd6, %r14;
    cvt.u64.u32 %rd12, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
