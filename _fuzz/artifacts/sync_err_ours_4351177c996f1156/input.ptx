.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    setp.ge.s32 %p3, %r3, %r3;
    setp.lo.u32 %p2, %r3, %r3;
    @%p2 or.b32 %r27, %r3, %r3;
    cvt.s32.s64 %r7, %rd14;
    or.b32 %r19, %r7, %r7;
    min.s32 %r11, %r27, %r27;
    shr.u32 %r11, %r3, 16;
    shl.b64 %rd14, %rd14, 63;
    add.s32 %r20, %r19, %r11;
    selp.b32 %r23, %r3, %r3, %p2;
    sub.s32 %r24, %r3, 256;
    add.s32 %r13, %r24, %r23;
    setp.ge.u32 %p2, %r20, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
