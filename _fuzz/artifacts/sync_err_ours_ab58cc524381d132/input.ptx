.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    min.u32 %r19, %r3, %r3;
    add.s32 %r6, %r3, 4294967295;
    shl.b32 %r12, %r19, 2;
    mul.lo.s32 %r14, %r6, 3;
    mul.lo.u32 %r8, %r14, %r6;
    or.b32 %r13, %r8, 31;
    sub.u64 %rd14, %rd13, %rd13;
    setp.eq.u32 %p4, %r6, 2147483648;
    @%p4 sub.s32 %r6, %r14, 256;
    shl.b32 %r15, %r13, 30;
    max.s64 %rd13, %rd14, %rd13;
    shr.s32 %r24, %r13, 15;
    cvt.u32.u64 %r10, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
