.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r13, %r3, %r3;
    cvt.u64.u32 %rd13, %r3;
    mul.lo.u64 %rd8, %rd13, %rd13;
    setp.ge.s32 %p1, %r3, 65536;
    @%p1 mul.lo.s32 %r21, %r13, %r3;
    min.u32 %r23, %r21, 0;
    mul.lo.u32 %r19, %r21, %r3;
    cvt.u64.u32 %rd8, %r13;
    mul.lo.s32 %r16, %r13, 65536;
    add.u32 %r8, %r3, 1;
    selp.b32 %r12, %r3, %r23, %p1;
    max.s32 %r26, %r8, 255;
    shr.s32 %r19, %r23, 31;
    shl.b32 %r9, %r21, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
