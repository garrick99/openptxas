.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    max.s32 %r22, %r3, 0;
    cvt.u32.u64 %r9, %rd8;
    cvt.s32.s64 %r10, %rd8;
    max.s32 %r9, %r10, 65536;
    cvt.u64.u32 %rd12, %r9;
    mul.lo.s32 %r25, %r22, %r22;
    setp.lo.u32 %p2, %r10, 31;
    max.u32 %r18, %r10, %r9;
    mad.lo.s32 %r21, %r18, %r25, %r9;
    cvt.s32.s64 %r8, %rd12;
    add.u32 %r6, %r9, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
