.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r19, %r3, %r3, %r3;
    cvt.s64.s32 %rd12, %r19;
    max.s32 %r14, %r3, %r19;
    min.u32 %r20, %r14, 7;
    shr.u64 %rd12, %rd12, 0;
    min.s32 %r26, %r20, %r19;
    setp.ls.u32 %p2, %r26, 3;
    @%p2 max.s32 %r4, %r3, %r3;
    shl.b64 %rd9, %rd12, 1;
    min.u32 %r15, %r19, %r26;
    xor.b32 %r26, %r26, 5;
    or.b64 %rd5, %rd9, %rd9;
    or.b32 %r25, %r26, %r4;
    min.s32 %r13, %r25, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
