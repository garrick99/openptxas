.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r24, %r3, 16;
    add.s32 %r14, %r24, %r24;
    mad.lo.u32 %r8, %r14, %r14, %r14;
    add.s32 %r17, %r24, %r24;
    setp.eq.s32 %p3, %r17, %r24;
    @!%p3 shr.s32 %r7, %r24, 15;
    cvt.u64.u32 %rd13, %r24;
    add.s32 %r12, %r24, %r17;
    mad.lo.u32 %r22, %r8, %r8, %r3;
    cvt.s32.s64 %r5, %rd13;
    shr.s32 %r4, %r5, 30;
    setp.ne.u32 %p3, %r24, %r24;
    and.b32 %r26, %r12, 31;
    selp.b32 %r12, %r8, %r7, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
