.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r16, %r3, %r3, %r3;
    min.s32 %r17, %r3, %r16;
    mul.wide.s32 %rd15, %r17, %r3;
    cvt.u64.u32 %rd14, %r16;
    mul.wide.u32 %rd15, %r16, %r3;
    sub.s32 %r5, %r16, %r17;
    and.b64 %rd15, %rd14, %rd14;
    mul.lo.u32 %r22, %r17, %r5;
    setp.le.s32 %p2, %r5, %r22;
    @%p2 selp.b32 %r11, %r3, %r17, %p2;
    and.b32 %r19, %r5, %r16;
    add.u32 %r7, %r16, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
