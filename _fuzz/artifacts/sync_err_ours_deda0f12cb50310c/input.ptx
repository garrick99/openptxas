.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd8, %r3, %r3;
    mul.wide.u32 %rd13, %r3, %r3;
    shr.s64 %rd9, %rd8, 62;
    setp.gt.s32 %p4, %r3, 3;
    @%p4 and.b32 %r9, %r3, 63;
    add.s32 %r11, %r9, 256;
    and.b32 %r21, %r9, 63;
    selp.b32 %r5, %r9, %r3, %p4;
    xor.b32 %r23, %r21, %r21;
    shl.b32 %r6, %r9, 7;
    min.u64 %rd12, %rd9, %rd8;
    sub.u32 %r4, %r5, %r23;
    add.s64 %rd8, %rd12, %rd8;
    cvt.u64.u32 %rd11, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
