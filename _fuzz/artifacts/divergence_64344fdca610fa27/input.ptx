.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r8, %r3, %r3;
    cvt.u64.u32 %rd9, %r8;
    setp.ne.s32 %p4, %r8, 15;
    @!%p4 max.s64 %rd5, %rd9, %rd9;
    mul.wide.s32 %rd13, %r3, %r8;
    shl.b32 %r16, %r8, 31;
    setp.ne.u32 %p2, %r8, %r16;
    @!%p2 shl.b32 %r23, %r16, 2;
    max.s32 %r12, %r8, %r23;
    add.s32 %r9, %r23, %r12;
    shl.b64 %rd5, %rd9, 4;
    cvt.s64.s32 %rd10, %r12;
    shl.b64 %rd9, %rd9, 62;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
