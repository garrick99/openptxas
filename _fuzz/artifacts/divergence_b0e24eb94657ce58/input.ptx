.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r13, %r3, 2;
    max.u32 %r19, %r13, 31;
    setp.lt.u32 %p2, %r19, %r13;
    @%p2 cvt.u64.u32 %rd8, %r19;
    mul.wide.u32 %rd12, %r13, %r13;
    cvt.s32.s64 %r17, %rd12;
    cvt.u32.u64 %r12, %rd12;
    setp.lo.u32 %p2, %r3, %r13;
    @%p2 shr.s64 %rd13, %rd8, 15;
    min.u64 %rd5, %rd8, %rd8;
    shl.b32 %r18, %r17, 7;
    setp.lo.u32 %p4, %r3, 0;
    @!%p4 shr.u64 %rd10, %rd5, 16;
    max.u32 %r27, %r13, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
