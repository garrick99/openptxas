.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd8, %r3, %r3;
    mul.lo.s32 %r13, %r3, 5;
    cvt.u32.u64 %r18, %rd8;
    shr.s32 %r27, %r3, 15;
    shr.s64 %rd13, %rd8, 31;
    setp.ge.u32 %p4, %r27, 5;
    selp.b32 %r15, %r27, %r18, %p4;
    mul.lo.s32 %r7, %r27, 32;
    mad.lo.u32 %r11, %r15, %r18, %r13;
    min.u32 %r7, %r7, 7;
    add.u64 %rd5, %rd8, %rd13;
    cvt.s32.s64 %r20, %rd8;
    setp.gt.s32 %p2, %r18, 16;
    @!%p2 mad.lo.s32 %r26, %r15, %r20, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
