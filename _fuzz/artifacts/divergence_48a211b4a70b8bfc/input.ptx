.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r8, %r3, 2;
    setp.le.s32 %p1, %r3, %r8;
    shr.u32 %r25, %r3, 31;
    cvt.s64.s32 %rd7, %r25;
    mul.lo.u32 %r6, %r3, 4;
    selp.b32 %r6, %r6, %r6, %p1;
    selp.b32 %r27, %r3, %r6, %p1;
    mul.wide.u32 %rd14, %r27, %r6;
    setp.lt.u32 %p3, %r3, %r27;
    setp.gt.s32 %p3, %r27, %r8;
    sub.s32 %r26, %r27, %r3;
    xor.b64 %rd11, %rd7, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
