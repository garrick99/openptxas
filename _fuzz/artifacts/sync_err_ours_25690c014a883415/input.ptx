    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r10, %r3, %r3;
    sub.s32 %r23, %r10, 4294967295;
    add.u32 %r7, %r23, %r3;
    mul.wide.u32 %rd8, %r3, %r23;
    min.s64 %rd14, %rd8, %rd8;
    mad.lo.s32 %r14, %r10, %r23, %r7;
    shl.b64 %rd5, %rd8, 2;
    and.b32 %r27, %r10, 7;
    min.u32 %r27, %r27, %r14;
    add.s64 %rd5, %rd5, %rd8;
    cvt.s64.s32 %rd8, %r3;
    add.s64 %rd6, %rd14, %rd5;
    max.u64 %rd9, %rd5, %rd5;
