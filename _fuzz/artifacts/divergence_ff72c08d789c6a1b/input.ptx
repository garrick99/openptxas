.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r8, %r3, 0;
    setp.ge.u32 %p3, %r8, 2147483647;
    @%p3 cvt.s64.s32 %rd5, %r3;
    max.s32 %r5, %r8, 255;
    max.s32 %r9, %r3, 0;
    add.u32 %r13, %r8, %r8;
    sub.u32 %r23, %r9, 4294967295;
    add.s32 %r26, %r9, 16;
    add.u64 %rd5, %rd5, %rd5;
    shr.u32 %r24, %r13, 7;
    min.s32 %r5, %r5, %r5;
    shr.s32 %r5, %r9, 0;
    or.b64 %rd15, %rd5, %rd5;
    shl.b32 %r7, %r26, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
