.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r20, %r3, 4;
    mad.lo.u32 %r6, %r3, %r20, %r20;
    or.b32 %r5, %r6, %r20;
    cvt.s64.s32 %rd14, %r5;
    shr.s32 %r19, %r6, 1;
    sub.s64 %rd6, %rd14, %rd14;
    setp.lt.s32 %p3, %r19, %r6;
    @!%p3 cvt.s32.s64 %r12, %rd14;
    mad.lo.s32 %r25, %r5, %r20, %r6;
    sub.s64 %rd12, %rd14, %rd6;
    mul.lo.s64 %rd6, %rd14, %rd6;
    mad.lo.u32 %r13, %r20, %r25, %r3;
    max.s64 %rd12, %rd6, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
