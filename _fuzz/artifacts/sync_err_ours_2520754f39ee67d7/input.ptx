.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    shl.b32 %r17, %r3, 0;
    setp.gt.s32 %p1, %r3, 5;
    @!%p1 selp.b32 %r11, %r3, %r3, %p1;
    selp.b32 %r9, %r3, %r11, %p1;
    add.s32 %r7, %r9, 16;
    setp.ge.u32 %p4, %r3, %r11;
    @!%p4 mul.wide.s32 %rd12, %r7, %r9;
    setp.ne.u32 %p4, %r17, 8;
    @!%p4 selp.b32 %r12, %r3, %r3, %p4;
    shr.u32 %r14, %r11, 2;
    min.s64 %rd6, %rd12, %rd12;
    sub.s64 %rd8, %rd12, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
