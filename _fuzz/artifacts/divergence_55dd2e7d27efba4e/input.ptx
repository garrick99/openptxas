.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    setp.eq.s32 %p3, %r3, 8;
    setp.hi.u32 %p1, %r3, 63;
    mul.lo.u64 %rd12, %rd9, %rd9;
    mul.lo.u32 %r17, %r3, 65535;
    setp.lo.u32 %p3, %r17, 4294967295;
    selp.b32 %r21, %r17, %r3, %p1;
    setp.lt.s32 %p1, %r3, 8;
    @%p1 add.s32 %r26, %r21, %r3;
    max.u32 %r7, %r21, %r21;
    max.u32 %r4, %r26, %r3;
    or.b32 %r10, %r3, %r21;
    mul.wide.u32 %rd11, %r10, %r17;
    xor.b32 %r6, %r21, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
