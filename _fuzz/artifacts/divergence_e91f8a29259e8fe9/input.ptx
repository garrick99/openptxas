.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r19, %r3, 16;
    cvt.u64.u32 %rd6, %r19;
    setp.ls.u32 %p1, %r3, %r19;
    @!%p1 max.u32 %r17, %r19, %r19;
    shr.s64 %rd7, %rd6, 3;
    sub.s64 %rd7, %rd7, %rd6;
    mul.wide.s32 %rd8, %r3, %r17;
    cvt.s32.s64 %r23, %rd6;
    shr.u32 %r9, %r3, 30;
    or.b32 %r15, %r9, %r19;
    shl.b32 %r22, %r9, 4;
    mul.wide.u32 %rd11, %r15, %r15;
    mul.wide.s32 %rd11, %r22, %r9;
    cvt.u64.u32 %rd13, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
