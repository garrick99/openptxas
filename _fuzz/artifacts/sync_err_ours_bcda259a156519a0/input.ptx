.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    shl.b64 %rd12, %rd13, 3;
    shr.u32 %r16, %r3, 7;
    shr.u64 %rd14, %rd12, 1;
    setp.ge.s32 %p4, %r16, 65535;
    @!%p4 cvt.s32.s64 %r13, %rd12;
    and.b32 %r20, %r16, %r16;
    cvt.u32.u64 %r6, %rd13;
    mul.wide.s32 %rd11, %r3, %r6;
    mul.wide.u32 %rd7, %r3, %r3;
    mul.lo.u64 %rd11, %rd13, %rd11;
    cvt.u64.u32 %rd15, %r20;
    add.s64 %rd6, %rd7, %rd13;
    sub.s32 %r24, %r20, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
