.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r7, %r3, 4294967295;
    cvt.s64.s32 %rd9, %r3;
    sub.u32 %r27, %r7, %r3;
    and.b64 %rd11, %rd9, %rd9;
    setp.eq.s32 %p3, %r3, 4294967295;
    @!%p3 max.s32 %r12, %r27, %r3;
    sub.s64 %rd14, %rd9, %rd9;
    cvt.s32.s64 %r6, %rd11;
    shr.s64 %rd9, %rd9, 30;
    shl.b32 %r6, %r6, 16;
    xor.b32 %r18, %r3, %r27;
    xor.b32 %r5, %r12, 64;
    shl.b32 %r27, %r3, 7;
    add.u32 %r21, %r6, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
