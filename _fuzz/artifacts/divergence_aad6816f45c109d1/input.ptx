.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r22, %r3, %r3;
    mul.wide.s32 %rd13, %r3, %r22;
    mul.wide.s32 %rd9, %r22, %r22;
    cvt.u32.u64 %r26, %rd13;
    or.b32 %r4, %r3, 0;
    max.u32 %r7, %r4, %r4;
    and.b32 %r4, %r3, 64;
    min.u32 %r19, %r4, 15;
    setp.hi.u32 %p4, %r3, %r3;
    @%p4 min.u32 %r27, %r19, 256;
    mad.lo.s32 %r26, %r7, %r19, %r19;
    max.s32 %r20, %r3, %r4;
    min.u64 %rd13, %rd13, %rd13;
    mul.lo.s64 %rd7, %rd9, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
