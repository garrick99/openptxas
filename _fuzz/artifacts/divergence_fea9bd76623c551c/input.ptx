.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r9, %r3, 5;
    add.s32 %r10, %r9, 65536;
    min.s32 %r4, %r9, %r9;
    add.s32 %r19, %r4, 2147483648;
    min.u32 %r7, %r3, %r19;
    mad.lo.u32 %r17, %r9, %r4, %r9;
    add.u32 %r20, %r10, 4294967295;
    setp.gt.s32 %p4, %r20, %r19;
    or.b32 %r9, %r20, %r9;
    cvt.s64.s32 %rd14, %r20;
    mad.lo.s32 %r23, %r3, %r17, %r7;
    cvt.u64.u32 %rd15, %r9;
    min.s32 %r14, %r4, %r23;
    and.b64 %rd12, %rd14, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
