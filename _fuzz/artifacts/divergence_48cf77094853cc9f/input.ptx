.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r25, %r3, 31;
    mad.lo.s32 %r27, %r25, %r25, %r3;
    cvt.u64.u32 %rd8, %r25;
    sub.u32 %r11, %r25, 16;
    shr.u64 %rd15, %rd8, 48;
    mul.wide.s32 %rd7, %r27, %r11;
    min.u32 %r13, %r25, 32;
    min.s32 %r5, %r13, %r3;
    shl.b32 %r14, %r3, 0;
    cvt.s32.s64 %r10, %rd8;
    cvt.u64.u32 %rd10, %r14;
    shl.b64 %rd8, %rd10, 7;
    or.b32 %r7, %r13, 4294967295;
    min.s32 %r27, %r3, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
