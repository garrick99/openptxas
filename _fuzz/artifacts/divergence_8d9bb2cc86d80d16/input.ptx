.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r23, %r3, %r3;
    sub.s32 %r13, %r3, 5;
    and.b32 %r24, %r3, 2147483647;
    max.u32 %r24, %r13, %r23;
    mul.wide.s32 %rd11, %r13, %r24;
    or.b32 %r5, %r23, %r24;
    max.u64 %rd5, %rd11, %rd11;
    cvt.s32.s64 %r23, %rd11;
    mul.wide.s32 %rd14, %r5, %r24;
    sub.u64 %rd12, %rd14, %rd11;
    mad.lo.s32 %r23, %r5, %r3, %r3;
    or.b32 %r21, %r3, %r24;
    shr.u64 %rd6, %rd5, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
