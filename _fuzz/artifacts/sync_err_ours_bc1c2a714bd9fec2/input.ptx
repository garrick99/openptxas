.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r15, %r3, 3;
    shl.b32 %r10, %r15, 2;
    shr.u32 %r15, %r3, 16;
    cvt.s64.s32 %rd5, %r10;
    or.b32 %r6, %r10, %r3;
    xor.b32 %r27, %r15, %r3;
    add.u32 %r24, %r27, %r6;
    mul.wide.u32 %rd10, %r3, %r15;
    add.s32 %r13, %r10, %r6;
    cvt.u64.u32 %rd6, %r3;
    sub.s32 %r19, %r13, 256;
    cvt.s32.s64 %r23, %rd6;
    mad.lo.u32 %r21, %r19, %r24, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
