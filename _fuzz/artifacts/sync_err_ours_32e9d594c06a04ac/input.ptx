.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    add.s64 %rd7, %rd6, %rd6;
    shl.b64 %rd6, %rd6, 31;
    cvt.u32.u64 %r24, %rd6;
    setp.lt.s32 %p3, %r24, 8;
    @%p3 sub.s32 %r7, %r3, 64;
    mul.wide.s32 %rd13, %r7, %r3;
    sub.u32 %r24, %r3, 64;
    mul.lo.s64 %rd10, %rd7, %rd7;
    cvt.s64.s32 %rd15, %r7;
    or.b32 %r21, %r7, %r7;
    shr.u64 %rd15, %rd10, 33;
    shl.b32 %r7, %r7, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
