.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r10, %r3, 4;
    mul.wide.s32 %rd13, %r10, %r10;
    setp.eq.s32 %p4, %r10, 2147483648;
    cvt.u64.u32 %rd13, %r3;
    setp.gt.u32 %p4, %r3, 16;
    @%p4 shr.u32 %r16, %r10, 31;
    mad.lo.s32 %r19, %r16, %r16, %r3;
    add.s32 %r24, %r10, %r3;
    shl.b32 %r6, %r10, 31;
    shl.b32 %r13, %r16, 0;
    cvt.u32.u64 %r5, %rd13;
    setp.ls.u32 %p1, %r5, 7;
    @%p1 shl.b32 %r17, %r13, 16;
    mul.wide.s32 %rd13, %r13, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
