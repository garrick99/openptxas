.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r24, %r3, 16;
    setp.ne.u32 %p4, %r24, 32;
    @!%p4 sub.s32 %r7, %r24, %r24;
    mad.lo.u32 %r17, %r24, %r3, %r3;
    cvt.s64.s32 %rd7, %r7;
    cvt.u32.u64 %r8, %rd7;
    xor.b32 %r15, %r7, %r24;
    setp.ne.u32 %p2, %r15, 5;
    mul.lo.s32 %r12, %r17, 3;
    shl.b32 %r16, %r17, 15;
    setp.lo.u32 %p2, %r8, %r3;
    @%p2 mul.wide.u32 %rd13, %r17, %r3;
    max.s32 %r12, %r8, %r8;
    shr.s64 %rd6, %rd7, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
