.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    min.s64 %rd11, %rd9, %rd9;
    or.b32 %r27, %r3, 7;
    add.u32 %r18, %r3, %r27;
    xor.b32 %r16, %r27, 32;
    max.u32 %r17, %r18, %r3;
    min.u32 %r24, %r18, %r17;
    mul.wide.u32 %rd13, %r3, %r18;
    setp.ne.s32 %p1, %r3, %r27;
    @%p1 min.u32 %r5, %r18, 4;
    min.u32 %r24, %r24, 16;
    and.b32 %r21, %r16, %r18;
    mad.lo.s32 %r27, %r24, %r17, %r5;
    mad.lo.s32 %r7, %r24, %r27, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
