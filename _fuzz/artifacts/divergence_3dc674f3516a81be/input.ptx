.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r9, %r3, %r3;
    mad.lo.u32 %r11, %r9, %r9, %r3;
    min.u32 %r27, %r11, 5;
    max.u32 %r17, %r27, 65535;
    cvt.u64.u32 %rd14, %r3;
    setp.le.s32 %p2, %r27, 0;
    @%p2 shr.s32 %r25, %r27, 30;
    sub.s32 %r7, %r11, 8;
    xor.b32 %r8, %r9, 32;
    and.b32 %r14, %r3, 15;
    add.u32 %r8, %r17, 31;
    cvt.u32.u64 %r26, %rd14;
    shl.b32 %r8, %r11, 7;
    xor.b32 %r10, %r25, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
