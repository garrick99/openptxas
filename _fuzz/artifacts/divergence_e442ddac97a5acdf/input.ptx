    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r10, %r3, %r3;
    setp.ne.s32 %p4, %r3, %r3;
    @%p4 add.s32 %r7, %r10, %r10;
    shr.s32 %r14, %r7, 1;
