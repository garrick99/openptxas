.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p4, %r3, 2;
    @%p4 cvt.u64.u32 %rd12, %r3;
    max.s32 %r27, %r3, %r3;
    add.s32 %r13, %r27, %r3;
    selp.b32 %r8, %r13, %r27, %p4;
    max.s64 %rd13, %rd12, %rd12;
    mul.lo.s32 %r15, %r13, %r13;
    mad.lo.u32 %r12, %r27, %r13, %r15;
    cvt.s64.s32 %rd10, %r15;
    shr.s64 %rd8, %rd10, 62;
    or.b32 %r9, %r13, 4;
    setp.hs.u32 %p3, %r27, %r12;
    @%p3 mul.wide.u32 %rd14, %r15, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
