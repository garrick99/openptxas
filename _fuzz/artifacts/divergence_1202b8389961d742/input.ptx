.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd7, %r3, %r3;
    sub.u32 %r18, %r3, 2;
    max.u32 %r11, %r3, %r18;
    setp.ge.u32 %p1, %r3, 32;
    @%p1 sub.s32 %r17, %r18, 255;
    cvt.s32.s64 %r15, %rd7;
    mul.wide.u32 %rd10, %r11, %r17;
    min.s32 %r14, %r17, 255;
    selp.b32 %r17, %r17, %r3, %p1;
    sub.s32 %r11, %r17, 15;
    shr.u64 %rd10, %rd7, 47;
    mul.lo.u64 %rd14, %rd10, %rd10;
    selp.b32 %r9, %r15, %r15, %p1;
    min.s32 %r6, %r3, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
