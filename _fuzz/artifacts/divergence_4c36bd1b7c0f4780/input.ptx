.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    mul.lo.s32 %r8, %r3, 4294967295;
    cvt.s32.s64 %r25, %rd5;
    sub.u32 %r15, %r8, %r3;
    mul.wide.s32 %rd6, %r3, %r3;
    sub.u32 %r23, %r15, %r15;
    sub.s32 %r24, %r15, 3;
    or.b32 %r21, %r15, 3;
    max.u32 %r17, %r15, 0;
    mad.lo.s32 %r8, %r15, %r15, %r23;
    max.u32 %r9, %r24, %r3;
    setp.le.s32 %p1, %r9, 64;
    @!%p1 selp.b32 %r27, %r17, %r15, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
