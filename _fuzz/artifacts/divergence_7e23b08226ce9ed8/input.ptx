.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    mul.lo.s64 %rd6, %rd15, %rd15;
    sub.s32 %r19, %r3, 0;
    mad.lo.u32 %r21, %r19, %r3, %r3;
    sub.s32 %r12, %r3, %r19;
    shr.u32 %r14, %r19, 30;
    max.s32 %r9, %r12, %r21;
    max.s32 %r25, %r9, 65536;
    shl.b32 %r19, %r3, 0;
    setp.ls.u32 %p4, %r3, 4294967295;
    @%p4 sub.s32 %r18, %r21, 64;
    shr.u64 %rd15, %rd6, 63;
    shr.u32 %r27, %r9, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
