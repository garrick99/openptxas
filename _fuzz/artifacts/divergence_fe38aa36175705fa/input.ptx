.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    or.b64 %rd14, %rd10, %rd10;
    cvt.s64.s32 %rd10, %r3;
    mul.wide.u32 %rd13, %r3, %r3;
    shl.b32 %r16, %r3, 30;
    cvt.u64.u32 %rd12, %r3;
    cvt.u64.u32 %rd8, %r3;
    shr.u64 %rd6, %rd10, 7;
    mad.lo.u32 %r5, %r16, %r3, %r16;
    cvt.s32.s64 %r7, %rd8;
    shl.b64 %rd7, %rd14, 30;
    mul.lo.u32 %r22, %r5, %r5;
    setp.ls.u32 %p1, %r7, %r3;
    @!%p1 selp.b32 %r20, %r7, %r7, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
