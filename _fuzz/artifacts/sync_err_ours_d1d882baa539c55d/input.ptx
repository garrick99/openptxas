.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r13, %r3, 4;
    xor.b32 %r25, %r3, %r13;
    mul.lo.u32 %r19, %r25, 3;
    xor.b32 %r15, %r19, %r19;
    cvt.u64.u32 %rd11, %r13;
    and.b32 %r15, %r15, %r3;
    setp.hi.u32 %p4, %r19, %r25;
    @%p4 shr.u32 %r6, %r13, 2;
    add.s32 %r27, %r15, %r3;
    cvt.s32.s64 %r12, %rd11;
    selp.b32 %r8, %r3, %r3, %p4;
    mad.lo.s32 %r10, %r6, %r12, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
