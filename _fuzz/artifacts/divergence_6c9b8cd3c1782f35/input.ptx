.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r22, %r3, 16;
    and.b32 %r27, %r22, 1;
    or.b32 %r10, %r27, %r27;
    shl.b32 %r19, %r10, 0;
    add.u32 %r23, %r10, %r3;
    cvt.s64.s32 %rd11, %r10;
    cvt.u64.u32 %rd11, %r19;
    and.b32 %r22, %r22, 2;
    setp.hs.u32 %p3, %r10, %r23;
    or.b32 %r20, %r3, %r22;
    min.u32 %r15, %r20, %r10;
    setp.le.s32 %p3, %r19, %r3;
    @!%p3 min.s32 %r8, %r27, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
