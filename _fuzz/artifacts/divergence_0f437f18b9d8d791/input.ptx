.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    setp.le.s32 %p1, %r3, 8;
    @%p1 shr.s32 %r9, %r3, 4;
    sub.u32 %r19, %r9, %r3;
    mul.lo.u64 %rd13, %rd8, %rd8;
    sub.s32 %r26, %r19, 64;
    max.u64 %rd11, %rd13, %rd8;
    shr.s64 %rd15, %rd8, 16;
    cvt.u32.u64 %r27, %rd13;
    cvt.s32.s64 %r9, %rd11;
    selp.b32 %r22, %r9, %r26, %p1;
    mul.wide.s32 %rd5, %r26, %r27;
    setp.gt.u32 %p1, %r9, 32;
    setp.lt.u32 %p1, %r22, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
