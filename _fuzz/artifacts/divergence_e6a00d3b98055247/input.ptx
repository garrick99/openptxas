.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r23, %r3, 16;
    max.u32 %r26, %r3, 0;
    or.b32 %r5, %r3, %r26;
    mul.lo.u32 %r23, %r26, %r5;
    cvt.u64.u32 %rd7, %r5;
    mul.wide.u32 %rd9, %r23, %r3;
    or.b32 %r4, %r23, 65536;
    cvt.u64.u32 %rd9, %r23;
    xor.b64 %rd13, %rd9, %rd7;
    mul.lo.u32 %r21, %r3, %r5;
    mul.lo.s64 %rd5, %rd13, %rd9;
    mad.lo.s32 %r20, %r21, %r23, %r4;
    mul.lo.u32 %r19, %r5, %r5;
    sub.u32 %r6, %r26, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
