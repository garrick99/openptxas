.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r20, %r3, 255;
    sub.u32 %r5, %r3, 256;
    sub.u32 %r4, %r5, %r5;
    mad.lo.u32 %r18, %r5, %r3, %r5;
    cvt.u64.u32 %rd10, %r20;
    sub.s32 %r5, %r20, %r3;
    sub.s32 %r24, %r20, 63;
    max.s64 %rd15, %rd10, %rd10;
    setp.le.u32 %p3, %r4, 5;
    @!%p3 min.s32 %r15, %r24, 5;
    add.u32 %r27, %r3, 0;
    min.s32 %r4, %r15, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
