.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r9, %r3, 2147483648;
    mul.wide.u32 %rd14, %r3, %r9;
    max.s32 %r20, %r3, 7;
    mul.wide.s32 %rd7, %r3, %r9;
    sub.u32 %r19, %r3, %r9;
    mad.lo.u32 %r22, %r20, %r9, %r20;
    min.s64 %rd8, %rd14, %rd7;
    mul.wide.u32 %rd6, %r19, %r22;
    mul.lo.u32 %r17, %r22, %r19;
    sub.u32 %r16, %r3, %r19;
    shl.b32 %r12, %r3, 7;
    sub.u32 %r8, %r20, %r20;
    shl.b32 %r13, %r20, 1;
    sub.u32 %r7, %r13, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
