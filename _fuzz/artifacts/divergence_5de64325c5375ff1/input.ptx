.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r25, %r3, %r3;
    shr.u32 %r23, %r25, 7;
    cvt.s64.s32 %rd10, %r3;
    mad.lo.s32 %r19, %r23, %r25, %r3;
    cvt.u32.u64 %r21, %rd10;
    cvt.u32.u64 %r23, %rd10;
    mul.lo.s32 %r24, %r23, 4;
    cvt.s64.s32 %rd9, %r24;
    shr.s64 %rd8, %rd9, 7;
    add.u32 %r24, %r3, %r21;
    min.u32 %r22, %r23, %r25;
    and.b32 %r7, %r21, %r19;
    max.u32 %r19, %r22, 8;
    cvt.s64.s32 %rd12, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
