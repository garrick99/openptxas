.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r24, %r3, 4;
    min.u32 %r22, %r3, %r3;
    sub.u32 %r4, %r22, 63;
    setp.lt.s32 %p4, %r24, %r4;
    @%p4 max.u32 %r15, %r24, %r3;
    cvt.s64.s32 %rd13, %r24;
    min.u32 %r4, %r24, %r4;
    max.s32 %r27, %r3, 32;
    shr.s32 %r9, %r22, 31;
    mul.lo.u32 %r5, %r24, 63;
    mul.lo.u32 %r11, %r4, 65535;
    cvt.u32.u64 %r17, %rd13;
    add.s64 %rd15, %rd13, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
