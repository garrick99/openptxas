    mad.lo.s32 %r17, %r3, %r8, %r12;
    mad.lo.u32 %r5, %r17, %r24, %r24;
    cvt.u64.u32 %rd11, %r12;
    min.u32 %r24, %r24, 7;
    sub.u32 %r21, %r8, 2147483648;
    max.u64 %rd14, %rd11, %rd11;
    mul.lo.u64 %rd7, %rd11, %rd11;
