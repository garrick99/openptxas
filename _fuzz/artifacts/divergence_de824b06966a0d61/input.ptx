.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    add.u32 %r19, %r3, 7;
    cvt.s32.s64 %r18, %rd13;
    cvt.u32.u64 %r11, %rd13;
    min.u32 %r6, %r19, 16;
    sub.s32 %r24, %r11, %r11;
    add.s32 %r23, %r6, %r24;
    setp.le.s32 %p2, %r24, %r23;
    mul.lo.s32 %r26, %r11, %r23;
    mad.lo.u32 %r17, %r26, %r11, %r3;
    xor.b32 %r23, %r3, %r3;
    or.b32 %r18, %r11, 255;
    shr.s64 %rd6, %rd13, 47;
    shr.s32 %r20, %r26, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
