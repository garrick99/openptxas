.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r18, %r3, %r3;
    cvt.s64.s32 %rd11, %r18;
    shl.b64 %rd10, %rd11, 62;
    cvt.u64.u32 %rd9, %r3;
    mul.lo.s32 %r26, %r3, 32;
    cvt.u32.u64 %r12, %rd9;
    mul.wide.u32 %rd6, %r26, %r3;
    cvt.s64.s32 %rd10, %r18;
    sub.s32 %r18, %r18, %r26;
    add.s32 %r27, %r26, %r26;
    max.s32 %r16, %r3, 255;
    shr.u64 %rd11, %rd11, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
