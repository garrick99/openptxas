.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd7, %r3, %r3;
    max.s32 %r24, %r3, 32;
    add.u32 %r12, %r3, %r24;
    cvt.s32.s64 %r4, %rd7;
    setp.hi.u32 %p4, %r24, %r4;
    @%p4 min.s32 %r21, %r3, 255;
    mul.lo.u32 %r9, %r12, %r24;
    setp.le.s32 %p1, %r12, 0;
    mad.lo.s32 %r25, %r4, %r9, %r24;
    mad.lo.s32 %r22, %r3, %r25, %r21;
    shl.b32 %r14, %r21, 7;
    or.b32 %r26, %r25, %r14;
    shl.b32 %r19, %r24, 30;
    mul.lo.u64 %rd10, %rd7, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
