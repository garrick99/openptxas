.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p1, %r3, 16;
    max.u32 %r18, %r3, %r3;
    mul.lo.u32 %r5, %r18, %r18;
    sub.s32 %r8, %r3, %r5;
    mul.wide.u32 %rd13, %r8, %r5;
    or.b32 %r9, %r18, %r3;
    cvt.s64.s32 %rd10, %r9;
    min.u32 %r19, %r18, %r8;
    xor.b64 %rd13, %rd13, %rd13;
    shr.s64 %rd9, %rd10, 3;
    add.s32 %r6, %r3, %r19;
    setp.ne.s32 %p1, %r19, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
