.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r26, %r3, 1;
    or.b32 %r21, %r3, %r26;
    and.b32 %r14, %r21, %r21;
    max.u32 %r22, %r3, 16;
    mad.lo.s32 %r19, %r14, %r26, %r26;
    cvt.u64.u32 %rd14, %r19;
    cvt.s32.s64 %r24, %rd14;
    cvt.s64.s32 %rd6, %r24;
    max.s64 %rd11, %rd14, %rd14;
    min.s64 %rd12, %rd14, %rd14;
    shr.u64 %rd7, %rd11, 15;
    mul.wide.u32 %rd7, %r22, %r22;
    max.s32 %r6, %r21, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
