.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r6, %r3, 31;
    setp.ge.u32 %p1, %r6, %r3;
    @!%p1 shr.s32 %r23, %r3, 30;
    setp.gt.s32 %p2, %r6, 256;
    @%p2 mad.lo.u32 %r12, %r6, %r3, %r3;
    max.u32 %r17, %r6, %r3;
    cvt.u64.u32 %rd12, %r12;
    selp.b32 %r24, %r3, %r6, %p1;
    mul.lo.s32 %r27, %r6, 0;
    cvt.u32.u64 %r14, %rd12;
    sub.s32 %r5, %r6, %r24;
    shl.b32 %r8, %r14, 2;
    setp.lt.u32 %p3, %r23, %r14;
    mul.lo.s32 %r24, %r8, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
