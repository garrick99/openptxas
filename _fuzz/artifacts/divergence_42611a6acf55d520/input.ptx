.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r25, %r3, 255;
    setp.le.s32 %p3, %r25, 7;
    or.b32 %r13, %r25, %r3;
    sub.s32 %r15, %r3, 16;
    cvt.s64.s32 %rd12, %r15;
    add.s32 %r25, %r15, %r3;
    cvt.s64.s32 %rd14, %r25;
    sub.u32 %r5, %r13, %r25;
    mad.lo.u32 %r5, %r15, %r5, %r13;
    sub.u32 %r24, %r25, %r3;
    shl.b64 %rd7, %rd12, 1;
    mul.wide.s32 %rd12, %r15, %r3;
    setp.le.u32 %p3, %r15, 2147483647;
    @%p3 xor.b32 %r14, %r15, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
