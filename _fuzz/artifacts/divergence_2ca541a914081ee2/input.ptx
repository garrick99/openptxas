.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r4, %r3, 4294967295;
    min.u32 %r13, %r4, 16;
    add.s32 %r13, %r13, 0;
    cvt.s64.s32 %rd5, %r4;
    cvt.s32.s64 %r13, %rd5;
    mul.lo.u64 %rd7, %rd5, %rd5;
    sub.s32 %r6, %r3, 65536;
    cvt.s32.s64 %r8, %rd7;
    or.b32 %r12, %r13, %r6;
    shl.b32 %r23, %r13, 7;
    min.u32 %r27, %r4, 5;
    min.u64 %rd15, %rd5, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
