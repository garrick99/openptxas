.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p1, %r3, 65536;
    @!%p1 shr.u32 %r8, %r3, 3;
    max.s32 %r15, %r8, 4294967295;
    selp.b32 %r24, %r8, %r8, %p1;
    xor.b32 %r7, %r15, %r15;
    shr.u32 %r19, %r15, 0;
    selp.b32 %r12, %r7, %r24, %p1;
    selp.b32 %r4, %r3, %r12, %p1;
    selp.b32 %r23, %r24, %r3, %p1;
    mul.lo.u32 %r9, %r12, 63;
    shr.u32 %r25, %r24, 15;
    or.b32 %r20, %r15, 31;
    cvt.s64.s32 %rd12, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
