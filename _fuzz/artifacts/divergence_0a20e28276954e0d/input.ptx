.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r12, %r3, 3;
    shl.b32 %r16, %r3, 15;
    cvt.s64.s32 %rd8, %r3;
    mul.lo.s32 %r23, %r12, %r12;
    sub.u32 %r21, %r23, %r3;
    cvt.s64.s32 %rd14, %r16;
    and.b32 %r22, %r3, %r23;
    min.u32 %r7, %r23, %r3;
    mul.lo.u32 %r10, %r23, %r12;
    mul.lo.s32 %r24, %r22, %r23;
    cvt.s32.s64 %r7, %rd8;
    shr.s32 %r8, %r3, 16;
    shl.b32 %r8, %r21, 4;
    mul.wide.s32 %rd8, %r22, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
