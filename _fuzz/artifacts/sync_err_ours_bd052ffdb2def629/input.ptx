.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r18, %r3, %r3, %r3;
    shr.s32 %r27, %r3, 15;
    sub.s32 %r5, %r27, %r3;
    max.s32 %r25, %r18, 256;
    cvt.s64.s32 %rd5, %r25;
    add.u32 %r4, %r25, %r5;
    cvt.s64.s32 %rd7, %r18;
    min.u32 %r25, %r18, %r4;
    setp.gt.u32 %p2, %r25, %r27;
    @%p2 max.u32 %r27, %r18, %r25;
    selp.b32 %r4, %r4, %r25, %p2;
    cvt.s64.s32 %rd7, %r25;
    and.b64 %rd11, %rd5, %rd7;
    max.s32 %r8, %r4, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
