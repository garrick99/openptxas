.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r27, %r3, 2;
    mul.lo.s32 %r5, %r3, %r3;
    sub.s32 %r9, %r3, 7;
    cvt.u64.u32 %rd15, %r27;
    cvt.s64.s32 %rd6, %r27;
    min.u32 %r8, %r5, 1;
    add.s32 %r15, %r8, 16;
    mul.wide.s32 %rd8, %r3, %r9;
    mul.lo.s32 %r15, %r5, 3;
    or.b32 %r27, %r9, %r15;
    shr.u32 %r18, %r27, 0;
    sub.u64 %rd8, %rd6, %rd6;
    mad.lo.s32 %r12, %r3, %r8, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
