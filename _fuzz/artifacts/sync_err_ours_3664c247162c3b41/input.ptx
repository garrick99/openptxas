.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    shr.u64 %rd5, %rd9, 15;
    add.u32 %r14, %r3, %r3;
    add.s32 %r17, %r14, 8;
    sub.s64 %rd11, %rd5, %rd9;
    shr.s64 %rd5, %rd9, 62;
    add.u64 %rd5, %rd5, %rd11;
    max.u64 %rd10, %rd9, %rd5;
    shr.u32 %r24, %r3, 3;
    mul.lo.s32 %r16, %r17, 31;
    shr.u32 %r21, %r16, 3;
    shr.s64 %rd8, %rd10, 31;
    xor.b32 %r16, %r16, %r17;
    max.s32 %r26, %r17, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
