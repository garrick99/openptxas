.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    shl.b32 %r22, %r3, 15;
    mul.lo.s32 %r24, %r3, %r22;
    add.u32 %r12, %r22, 0;
    or.b32 %r5, %r3, 7;
    max.u64 %rd13, %rd10, %rd10;
    min.s32 %r16, %r5, 5;
    mul.wide.s32 %rd13, %r22, %r12;
    shl.b32 %r11, %r5, 15;
    min.u32 %r27, %r12, %r3;
    min.u32 %r18, %r11, 2147483648;
    shl.b32 %r19, %r22, 31;
    max.s32 %r15, %r18, %r3;
    sub.s32 %r9, %r18, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
