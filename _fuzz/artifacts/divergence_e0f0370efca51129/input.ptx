.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r27, %r3, 2;
    mul.lo.s32 %r16, %r27, 3;
    min.u32 %r6, %r27, %r27;
    shl.b32 %r24, %r6, 1;
    cvt.s64.s32 %rd13, %r27;
    add.u32 %r26, %r27, 64;
    mul.wide.s32 %rd14, %r16, %r27;
    max.s32 %r9, %r6, 16;
    max.s32 %r15, %r3, 31;
    mul.lo.u64 %rd9, %rd13, %rd13;
    shr.s32 %r4, %r6, 30;
    min.s32 %r27, %r27, %r15;
    max.u32 %r18, %r27, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
