.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    mul.lo.s32 %r8, %r3, 15;
    sub.s32 %r27, %r8, 256;
    add.s32 %r15, %r3, 0;
    shr.s32 %r23, %r15, 2;
    mul.lo.s32 %r18, %r8, 3;
    xor.b32 %r20, %r3, %r18;
    shl.b64 %rd14, %rd15, 62;
    setp.gt.s32 %p3, %r8, 2;
    setp.gt.u32 %p4, %r8, 32;
    selp.b32 %r12, %r3, %r20, %p4;
    mul.lo.u32 %r20, %r23, 31;
    setp.lo.u32 %p2, %r3, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
