.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r16, %r3, 3;
    cvt.s64.s32 %rd10, %r16;
    mul.lo.u32 %r20, %r16, 4294967295;
    mul.lo.s32 %r26, %r3, %r20;
    setp.ge.s32 %p4, %r26, 4;
    @%p4 cvt.s32.s64 %r17, %rd10;
    shr.s32 %r8, %r20, 3;
    setp.gt.s32 %p3, %r17, 255;
    @%p3 sub.s32 %r23, %r16, %r16;
    mul.wide.u32 %rd8, %r20, %r20;
    mul.lo.u32 %r6, %r20, %r20;
    cvt.u64.u32 %rd14, %r20;
    shr.s32 %r10, %r20, 2;
    shr.s32 %r5, %r6, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
