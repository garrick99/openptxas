    max.s32 %r12, %r3, 2147483648;
    shr.u64 %rd7, %rd14, 7;
    mad.lo.u32 %r13, %r7, %r3, %r7;
    cvt.s32.s64 %r6, %rd14;
    sub.s32 %r20, %r13, %r6;
    mul.lo.u32 %r19, %r6, %r7;
    xor.b64 %rd15, %rd7, %rd7;
