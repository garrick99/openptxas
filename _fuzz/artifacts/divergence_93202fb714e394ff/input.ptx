.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r8, %r3, 30;
    setp.lt.u32 %p4, %r8, 16;
    @!%p4 cvt.u64.u32 %rd12, %r3;
    xor.b32 %r24, %r8, %r8;
    max.s32 %r7, %r24, %r24;
    add.s32 %r26, %r24, 5;
    sub.u32 %r16, %r24, 31;
    xor.b64 %rd14, %rd12, %rd12;
    sub.s64 %rd8, %rd14, %rd14;
    max.s32 %r8, %r3, %r24;
    add.u32 %r12, %r3, 5;
    min.u32 %r17, %r16, %r3;
    sub.u64 %rd7, %rd14, %rd8;
    selp.b32 %r23, %r16, %r3, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
