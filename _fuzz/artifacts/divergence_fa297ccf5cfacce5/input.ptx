.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r20, %r3, %r3;
    shr.u32 %r17, %r3, 0;
    mul.lo.s32 %r26, %r17, 5;
    mul.wide.s32 %rd13, %r20, %r26;
    max.s32 %r19, %r26, %r3;
    setp.ls.u32 %p4, %r26, 15;
    @%p4 or.b64 %rd8, %rd13, %rd13;
    max.u32 %r26, %r17, 7;
    cvt.s64.s32 %rd10, %r19;
    setp.hi.u32 %p2, %r20, %r19;
    @!%p2 selp.b32 %r18, %r20, %r26, %p2;
    cvt.u32.u64 %r9, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
