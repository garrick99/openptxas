.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    shl.b32 %r5, %r3, 16;
    shr.s64 %rd15, %rd13, 3;
    max.u64 %rd12, %rd15, %rd13;
    mul.wide.u32 %rd8, %r3, %r3;
    setp.lt.s32 %p2, %r3, 31;
    @!%p2 max.u32 %r6, %r3, 2;
    shr.u32 %r4, %r3, 4;
    cvt.s64.s32 %rd9, %r5;
    sub.u32 %r5, %r5, %r6;
    selp.b32 %r10, %r3, %r6, %p2;
    add.u32 %r20, %r3, 8;
    and.b32 %r7, %r4, 2147483648;
    add.s32 %r5, %r4, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
