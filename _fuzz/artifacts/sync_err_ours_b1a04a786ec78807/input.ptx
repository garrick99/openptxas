.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r27, %r3, 64;
    setp.lo.u32 %p4, %r3, %r3;
    @%p4 mul.wide.s32 %rd14, %r3, %r3;
    mul.lo.s32 %r16, %r3, 1;
    shr.u64 %rd13, %rd14, 16;
    mul.wide.s32 %rd14, %r3, %r27;
    cvt.s64.s32 %rd12, %r16;
    max.u32 %r6, %r16, %r3;
    sub.s32 %r22, %r27, 5;
    shr.s32 %r21, %r16, 0;
    xor.b64 %rd6, %rd12, %rd14;
    cvt.s32.s64 %r7, %rd12;
    shr.s64 %rd11, %rd13, 2;
    max.s32 %r18, %r27, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
