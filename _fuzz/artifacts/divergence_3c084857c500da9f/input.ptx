.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    cvt.u64.u32 %rd8, %r3;
    cvt.s32.s64 %r14, %rd8;
    setp.gt.s32 %p4, %r14, %r3;
    setp.le.s32 %p3, %r3, 5;
    mul.wide.u32 %rd14, %r3, %r14;
    sub.s64 %rd9, %rd8, %rd8;
    sub.s64 %rd7, %rd11, %rd11;
    mul.lo.s32 %r4, %r14, 5;
    or.b32 %r26, %r4, 3;
    sub.s32 %r8, %r4, 32;
    mad.lo.u32 %r15, %r14, %r8, %r4;
    shr.u64 %rd14, %rd11, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
