.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd5, %r3, %r3;
    and.b32 %r18, %r3, 32;
    setp.gt.s32 %p2, %r3, %r3;
    shr.u32 %r10, %r18, 16;
    min.u32 %r14, %r3, 4294967295;
    min.u64 %rd7, %rd5, %rd5;
    xor.b64 %rd13, %rd5, %rd7;
    and.b64 %rd9, %rd7, %rd13;
    shr.s32 %r17, %r14, 4;
    sub.s32 %r25, %r10, 7;
    cvt.u32.u64 %r26, %rd13;
    selp.b32 %r6, %r14, %r18, %p2;
    min.s32 %r9, %r26, %r18;
    or.b32 %r21, %r6, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
