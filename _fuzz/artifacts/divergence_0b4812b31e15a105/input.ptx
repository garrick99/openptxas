.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    setp.ls.u32 %p4, %r3, 255;
    @%p4 selp.b32 %r5, %r3, %r3, %p4;
    mad.lo.u32 %r14, %r5, %r5, %r5;
    mul.lo.s32 %r26, %r3, 3;
    selp.b32 %r21, %r14, %r5, %p4;
    xor.b32 %r9, %r26, 3;
    mul.wide.s32 %rd8, %r14, %r14;
    mul.lo.u32 %r8, %r21, 15;
    selp.b32 %r4, %r9, %r9, %p4;
    min.u32 %r23, %r3, %r26;
    and.b32 %r8, %r3, 65535;
    min.u32 %r23, %r23, %r26;
    add.u32 %r23, %r26, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
