.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p4, %r3, 2;
    @%p4 max.u32 %r11, %r3, 31;
    cvt.s64.s32 %rd6, %r11;
    mad.lo.s32 %r17, %r3, %r11, %r3;
    or.b64 %rd9, %rd6, %rd6;
    or.b32 %r19, %r17, 256;
    setp.ne.s32 %p1, %r11, 0;
    @!%p1 mul.lo.u32 %r21, %r11, %r11;
    mul.lo.u32 %r20, %r11, 2147483648;
    mul.lo.u64 %rd12, %rd9, %rd9;
    cvt.u32.u64 %r15, %rd12;
    mul.lo.u32 %r10, %r19, 65535;
    shl.b64 %rd5, %rd9, 62;
    setp.ne.u32 %p1, %r19, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
