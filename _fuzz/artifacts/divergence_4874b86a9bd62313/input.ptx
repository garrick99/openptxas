.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r24, %r3, %r3;
    sub.u32 %r17, %r3, %r3;
    cvt.u64.u32 %rd5, %r3;
    mul.lo.s32 %r5, %r17, 2;
    mad.lo.s32 %r9, %r24, %r24, %r5;
    shr.s64 %rd14, %rd5, 0;
    sub.s32 %r22, %r17, 1;
    setp.gt.s32 %p3, %r24, 3;
    setp.ge.u32 %p3, %r22, %r24;
    @!%p3 max.u32 %r23, %r22, 0;
    min.u32 %r6, %r9, %r23;
    setp.hs.u32 %p4, %r22, 15;
    @!%p4 selp.b32 %r5, %r17, %r3, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
