.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r13, %r3, 7;
    setp.lo.u32 %p4, %r13, 63;
    @%p4 sub.u32 %r18, %r13, 3;
    shr.u32 %r19, %r13, 30;
    and.b32 %r4, %r3, %r3;
    max.u32 %r17, %r19, %r3;
    cvt.s64.s32 %rd8, %r13;
    mad.lo.s32 %r23, %r17, %r18, %r3;
    shr.u32 %r20, %r3, 1;
    selp.b32 %r5, %r4, %r18, %p4;
    cvt.u64.u32 %rd6, %r3;
    cvt.s32.s64 %r21, %rd6;
    sub.u32 %r27, %r23, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
