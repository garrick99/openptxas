.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd11, %r3, %r3;
    mul.wide.u32 %rd10, %r3, %r3;
    shr.u32 %r27, %r3, 15;
    cvt.u64.u32 %rd14, %r27;
    shl.b32 %r21, %r3, 0;
    shr.u32 %r22, %r3, 31;
    mul.wide.u32 %rd12, %r22, %r22;
    xor.b64 %rd9, %rd11, %rd11;
    mul.wide.s32 %rd7, %r22, %r22;
    cvt.u32.u64 %r10, %rd11;
    setp.le.s32 %p4, %r27, 15;
    @!%p4 mad.lo.u32 %r16, %r3, %r3, %r10;
    mad.lo.s32 %r9, %r16, %r10, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
