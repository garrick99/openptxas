.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p1, %r3, %r3;
    max.u32 %r12, %r3, %r3;
    mul.lo.s32 %r14, %r12, 16;
    shl.b32 %r7, %r14, 4;
    mad.lo.u32 %r21, %r12, %r7, %r12;
    min.s32 %r19, %r12, 65535;
    cvt.s64.s32 %rd10, %r14;
    xor.b32 %r24, %r14, 2;
    sub.u64 %rd5, %rd10, %rd10;
    add.s32 %r18, %r24, 16;
    mad.lo.s32 %r12, %r24, %r24, %r7;
    setp.lo.u32 %p3, %r19, %r12;
    @!%p3 sub.u32 %r11, %r7, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
