.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd6, %r3, %r3;
    or.b64 %rd12, %rd6, %rd6;
    cvt.u64.u32 %rd12, %r3;
    setp.ls.u32 %p2, %r3, 256;
    @%p2 sub.u32 %r23, %r3, %r3;
    mad.lo.s32 %r11, %r3, %r3, %r3;
    shl.b64 %rd10, %rd6, 48;
    sub.s32 %r14, %r3, %r23;
    sub.u32 %r21, %r3, 64;
    max.u64 %rd6, %rd10, %rd6;
    mul.wide.s32 %rd6, %r3, %r3;
    shl.b64 %rd6, %rd10, 16;
    setp.ge.s32 %p4, %r21, 2147483648;
    @!%p4 selp.b32 %r24, %r3, %r21, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
