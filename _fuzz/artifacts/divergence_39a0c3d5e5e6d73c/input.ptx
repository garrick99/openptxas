.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r10, %r3, %r3;
    setp.gt.u32 %p4, %r10, 63;
    @!%p4 cvt.s64.s32 %rd11, %r10;
    xor.b64 %rd12, %rd11, %rd11;
    min.s32 %r20, %r3, 65535;
    sub.s32 %r10, %r20, %r3;
    shr.s64 %rd6, %rd11, 31;
    and.b32 %r24, %r3, 4;
    mul.wide.s32 %rd15, %r10, %r20;
    setp.ne.s32 %p2, %r3, %r10;
    @%p2 mad.lo.u32 %r20, %r10, %r3, %r3;
    setp.ne.s32 %p2, %r10, %r10;
    setp.lt.s32 %p3, %r3, 2147483648;
    setp.hs.u32 %p4, %r10, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
