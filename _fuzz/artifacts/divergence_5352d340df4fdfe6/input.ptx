.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    cvt.s64.s32 %rd5, %r3;
    max.u64 %rd10, %rd7, %rd7;
    cvt.u32.u64 %r18, %rd10;
    shl.b32 %r16, %r3, 15;
    mad.lo.s32 %r14, %r18, %r3, %r18;
    mul.wide.u32 %rd5, %r16, %r16;
    shr.u64 %rd14, %rd7, 1;
    xor.b32 %r14, %r14, 2147483648;
    cvt.s64.s32 %rd6, %r14;
    mul.wide.s32 %rd6, %r18, %r16;
    cvt.u32.u64 %r18, %rd10;
    min.s32 %r5, %r18, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
