.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    shr.u64 %rd9, %rd12, 2;
    max.s32 %r11, %r3, 4294967295;
    max.u64 %rd12, %rd12, %rd9;
    shr.s32 %r19, %r3, 0;
    sub.s32 %r16, %r19, 2147483647;
    min.u32 %r23, %r19, %r11;
    cvt.u32.u64 %r5, %rd12;
    mul.lo.u64 %rd13, %rd9, %rd9;
    mul.wide.u32 %rd5, %r11, %r5;
    min.s32 %r16, %r5, 32;
    min.u32 %r15, %r16, 3;
    mad.lo.u32 %r17, %r15, %r11, %r11;
    and.b32 %r7, %r17, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
