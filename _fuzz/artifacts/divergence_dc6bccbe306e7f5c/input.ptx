.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r16, %r3, 64;
    setp.ge.s32 %p3, %r16, 7;
    @!%p3 min.u32 %r21, %r3, 63;
    shl.b32 %r17, %r16, 0;
    and.b32 %r16, %r16, 0;
    cvt.s64.s32 %rd6, %r16;
    sub.s32 %r20, %r17, %r21;
    shl.b32 %r23, %r16, 2;
    selp.b32 %r23, %r23, %r23, %p3;
    add.s32 %r9, %r20, 4;
    cvt.s64.s32 %rd9, %r21;
    mad.lo.u32 %r12, %r21, %r20, %r23;
    or.b32 %r10, %r16, %r21;
    add.u64 %rd8, %rd9, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
