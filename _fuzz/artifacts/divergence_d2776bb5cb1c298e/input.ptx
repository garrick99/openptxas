.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd12, %r3, %r3;
    or.b32 %r26, %r3, %r3;
    cvt.u32.u64 %r26, %rd12;
    setp.lo.u32 %p2, %r26, %r26;
    @%p2 sub.s32 %r11, %r26, %r26;
    sub.s32 %r20, %r11, %r26;
    min.u32 %r24, %r20, %r20;
    and.b32 %r26, %r11, 7;
    cvt.s32.s64 %r11, %rd12;
    mul.wide.u32 %rd5, %r11, %r3;
    sub.s32 %r18, %r26, %r11;
    cvt.s32.s64 %r8, %rd5;
    selp.b32 %r14, %r3, %r8, %p2;
    sub.s32 %r21, %r26, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
