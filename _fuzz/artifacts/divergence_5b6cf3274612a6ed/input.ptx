.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r12, %r3, 5;
    cvt.s64.s32 %rd13, %r12;
    setp.ge.s32 %p3, %r12, 255;
    sub.s32 %r4, %r12, %r12;
    max.s32 %r24, %r3, 32;
    max.u32 %r12, %r12, %r4;
    selp.b32 %r14, %r24, %r24, %p3;
    mad.lo.u32 %r19, %r14, %r14, %r12;
    min.u32 %r22, %r3, %r19;
    and.b32 %r10, %r22, %r19;
    mad.lo.s32 %r26, %r12, %r22, %r24;
    setp.gt.s32 %p1, %r24, %r19;
    @%p1 shr.u32 %r19, %r14, 2;
    add.u32 %r19, %r4, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
