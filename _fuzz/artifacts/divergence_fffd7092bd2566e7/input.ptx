.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    mul.lo.s32 %r9, %r3, %r3;
    max.s32 %r6, %r9, %r9;
    cvt.u32.u64 %r5, %rd11;
    shl.b64 %rd10, %rd11, 1;
    sub.s32 %r17, %r5, %r6;
    setp.lo.u32 %p3, %r3, 7;
    @!%p3 sub.s32 %r25, %r3, 16;
    and.b32 %r24, %r17, %r9;
    max.u64 %rd15, %rd11, %rd10;
    xor.b32 %r12, %r6, 31;
    setp.gt.s32 %p3, %r25, 2147483648;
    @%p3 shr.s32 %r7, %r24, 31;
    mul.lo.s32 %r15, %r25, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
