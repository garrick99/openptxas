.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    mul.lo.s32 %r20, %r3, %r3;
    setp.eq.u32 %p4, %r3, 7;
    @%p4 mul.lo.u32 %r27, %r20, 7;
    cvt.s64.s32 %rd6, %r20;
    min.s32 %r4, %r20, 3;
    shr.s32 %r4, %r4, 31;
    cvt.s32.s64 %r19, %rd6;
    max.u32 %r14, %r27, 5;
    add.s32 %r9, %r19, %r19;
    and.b64 %rd9, %rd8, %rd8;
    xor.b64 %rd5, %rd6, %rd8;
    selp.b32 %r4, %r9, %r9, %p4;
    mul.lo.u32 %r6, %r4, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
