.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r10, %r3, 1;
    and.b32 %r22, %r10, %r3;
    cvt.s64.s32 %rd15, %r22;
    or.b32 %r6, %r10, %r10;
    shr.u32 %r6, %r3, 7;
    max.s32 %r15, %r22, %r22;
    setp.gt.s32 %p3, %r6, %r10;
    shl.b32 %r23, %r6, 2;
    min.u32 %r14, %r23, 65536;
    shl.b32 %r5, %r22, 1;
    mul.lo.u32 %r23, %r5, 2;
    max.s32 %r18, %r15, 0;
    max.s32 %r24, %r22, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
