.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r23, %r3, %r3;
    cvt.s64.s32 %rd14, %r23;
    and.b32 %r10, %r23, %r3;
    max.s64 %rd8, %rd14, %rd14;
    setp.ls.u32 %p1, %r10, %r23;
    setp.eq.s32 %p3, %r3, 2;
    selp.b32 %r10, %r10, %r10, %p1;
    xor.b64 %rd7, %rd8, %rd8;
    selp.b32 %r7, %r3, %r10, %p3;
    mul.lo.s32 %r16, %r3, 64;
    shr.u32 %r14, %r10, 16;
    xor.b32 %r12, %r10, %r23;
    mul.wide.s32 %rd11, %r14, %r23;
    shl.b32 %r24, %r23, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
