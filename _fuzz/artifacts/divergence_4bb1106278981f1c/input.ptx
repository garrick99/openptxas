.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    min.s64 %rd6, %rd14, %rd14;
    shr.s32 %r4, %r3, 1;
    mad.lo.u32 %r10, %r3, %r4, %r3;
    add.s32 %r16, %r10, 31;
    shl.b64 %rd5, %rd6, 0;
    sub.s32 %r15, %r10, %r4;
    and.b32 %r26, %r15, %r3;
    min.u64 %rd14, %rd14, %rd6;
    mul.lo.u32 %r23, %r10, 1;
    max.s32 %r16, %r16, %r15;
    shl.b32 %r5, %r15, 16;
    add.s32 %r13, %r4, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
