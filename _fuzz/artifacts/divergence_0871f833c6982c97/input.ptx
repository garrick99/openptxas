.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r13, %r3, 65535;
    mad.lo.s32 %r26, %r13, %r13, %r3;
    shr.u32 %r17, %r3, 1;
    cvt.u64.u32 %rd8, %r17;
    setp.gt.s32 %p3, %r13, 1;
    @%p3 shr.u32 %r19, %r13, 4;
    xor.b32 %r26, %r26, 64;
    shr.s64 %rd10, %rd8, 63;
    min.s32 %r26, %r3, %r13;
    or.b32 %r7, %r17, 63;
    sub.s32 %r19, %r7, 5;
    mad.lo.s32 %r17, %r13, %r13, %r7;
    setp.ge.u32 %p1, %r3, 32;
    @%p1 min.s32 %r6, %r19, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
