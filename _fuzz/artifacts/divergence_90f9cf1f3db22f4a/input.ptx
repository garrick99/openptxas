.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r12, %r3, 3;
    max.u32 %r12, %r12, %r3;
    cvt.u64.u32 %rd5, %r12;
    mad.lo.u32 %r20, %r3, %r3, %r12;
    mul.wide.u32 %rd5, %r20, %r3;
    shr.s64 %rd15, %rd5, 62;
    shl.b32 %r12, %r12, 7;
    shr.u64 %rd10, %rd5, 7;
    sub.s32 %r11, %r12, %r12;
    max.u32 %r26, %r3, %r3;
    max.u32 %r24, %r12, 3;
    setp.ls.u32 %p1, %r12, 7;
    @%p1 selp.b32 %r24, %r11, %r20, %p1;
    mad.lo.u32 %r25, %r24, %r26, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
