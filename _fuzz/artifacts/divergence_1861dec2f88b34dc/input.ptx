.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    max.u32 %r24, %r3, 0;
    min.u32 %r10, %r3, 2147483647;
    max.s32 %r21, %r24, %r24;
    xor.b32 %r27, %r24, 0;
    setp.gt.u32 %p2, %r21, 8;
    @!%p2 sub.u64 %rd14, %rd8, %rd8;
    max.u32 %r16, %r3, %r21;
    mul.lo.u32 %r11, %r3, 5;
    setp.le.u32 %p2, %r10, 0;
    @%p2 add.s32 %r15, %r24, 15;
    mad.lo.u32 %r14, %r27, %r27, %r11;
    cvt.s32.s64 %r19, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
