.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r20, %r3, 4294967295;
    cvt.s64.s32 %rd9, %r3;
    xor.b32 %r19, %r20, 65535;
    mul.lo.u32 %r25, %r3, 8;
    min.s32 %r14, %r25, %r3;
    shr.s32 %r16, %r20, 2;
    setp.ge.s32 %p4, %r25, 16;
    setp.le.u32 %p4, %r19, 15;
    @%p4 shr.s32 %r27, %r19, 16;
    and.b32 %r23, %r27, %r3;
    min.s64 %rd11, %rd9, %rd9;
    shr.u64 %rd9, %rd11, 48;
    min.u32 %r11, %r20, 15;
    mul.wide.u32 %rd15, %r3, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
