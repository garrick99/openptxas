.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r25, %r3, %r3;
    cvt.u64.u32 %rd5, %r25;
    shr.s64 %rd7, %rd5, 1;
    sub.u64 %rd8, %rd5, %rd5;
    setp.ne.s32 %p2, %r3, 32;
    @!%p2 sub.u32 %r15, %r25, %r3;
    cvt.u64.u32 %rd14, %r15;
    min.u32 %r16, %r15, %r25;
    sub.s32 %r26, %r15, 8;
    add.s64 %rd6, %rd8, %rd8;
    min.u32 %r17, %r25, 32;
    mul.wide.s32 %rd12, %r16, %r25;
    and.b32 %r15, %r17, 3;
    min.u64 %rd15, %rd6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
