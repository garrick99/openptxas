.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r20, %r3, %r3;
    shr.u32 %r15, %r20, 1;
    shl.b32 %r16, %r20, 30;
    max.s32 %r27, %r15, %r16;
    cvt.u64.u32 %rd15, %r15;
    mul.wide.s32 %rd11, %r27, %r15;
    setp.eq.s32 %p4, %r20, %r16;
    cvt.u32.u64 %r9, %rd11;
    shr.s64 %rd13, %rd11, 48;
    add.s32 %r20, %r9, %r27;
    add.u32 %r4, %r15, %r3;
    shr.s32 %r6, %r16, 15;
    selp.b32 %r13, %r6, %r4, %p4;
    min.s32 %r8, %r3, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
