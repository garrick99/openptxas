.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    shl.b64 %rd14, %rd10, 30;
    mul.wide.s32 %rd7, %r3, %r3;
    setp.le.u32 %p4, %r3, %r3;
    min.s32 %r17, %r3, 8;
    shr.u64 %rd15, %rd10, 47;
    shr.u32 %r19, %r17, 16;
    shr.s32 %r12, %r17, 4;
    and.b64 %rd10, %rd14, %rd7;
    sub.s32 %r4, %r19, %r3;
    and.b32 %r12, %r17, %r12;
    and.b32 %r20, %r17, %r12;
    cvt.s32.s64 %r23, %rd15;
    sub.s32 %r26, %r17, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
