.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    and.b64 %rd7, %rd6, %rd6;
    mad.lo.s32 %r8, %r3, %r3, %r3;
    max.u32 %r23, %r8, 65535;
    shl.b32 %r7, %r8, 4;
    and.b64 %rd12, %rd7, %rd6;
    mad.lo.u32 %r23, %r7, %r3, %r23;
    max.u32 %r20, %r23, 4;
    cvt.u32.u64 %r5, %rd12;
    add.s32 %r18, %r20, %r7;
    sub.u32 %r21, %r7, %r23;
    shr.u64 %rd6, %rd7, 0;
    mad.lo.s32 %r24, %r8, %r18, %r5;
    mul.lo.s32 %r21, %r18, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
