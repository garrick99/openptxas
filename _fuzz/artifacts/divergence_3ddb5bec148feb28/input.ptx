.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd5, %r3, %r3;
    min.u64 %rd10, %rd5, %rd5;
    mad.lo.u32 %r22, %r3, %r3, %r3;
    and.b32 %r17, %r3, %r3;
    add.u32 %r4, %r22, %r3;
    min.s32 %r17, %r22, %r3;
    shr.u32 %r4, %r17, 1;
    shr.s32 %r9, %r22, 0;
    cvt.u64.u32 %rd13, %r9;
    cvt.s64.s32 %rd5, %r3;
    or.b32 %r26, %r3, %r3;
    mul.lo.u32 %r12, %r17, 15;
    cvt.u64.u32 %rd5, %r12;
    setp.lt.s32 %p1, %r4, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
