.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r8, %r3, %r3, %r3;
    shr.s32 %r12, %r8, 0;
    cvt.s64.s32 %rd10, %r12;
    setp.ge.s32 %p3, %r8, %r12;
    setp.ne.u32 %p1, %r12, 7;
    @%p1 min.s32 %r8, %r3, 0;
    shl.b64 %rd5, %rd10, 0;
    mul.lo.u32 %r24, %r3, %r12;
    mul.wide.u32 %rd14, %r8, %r24;
    add.s32 %r27, %r12, 1;
    setp.eq.u32 %p3, %r24, %r12;
    mul.lo.u32 %r25, %r8, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
