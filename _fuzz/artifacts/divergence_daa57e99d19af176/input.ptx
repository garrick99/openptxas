.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r18, %r3, 8;
    setp.gt.s32 %p3, %r18, %r18;
    @%p3 mul.wide.u32 %rd13, %r18, %r18;
    cvt.s64.s32 %rd12, %r3;
    cvt.u64.u32 %rd14, %r18;
    setp.lt.u32 %p3, %r3, %r18;
    @%p3 mul.wide.u32 %rd11, %r18, %r3;
    cvt.u32.u64 %r12, %rd13;
    max.u32 %r18, %r18, %r3;
    max.s32 %r18, %r18, %r18;
    or.b32 %r12, %r3, %r12;
    and.b32 %r10, %r3, %r12;
    mad.lo.s32 %r7, %r3, %r18, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
