.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r13, %r3, 0;
    cvt.s64.s32 %rd9, %r3;
    and.b32 %r17, %r3, %r13;
    min.s32 %r17, %r13, %r17;
    shl.b64 %rd9, %rd9, 15;
    shr.s32 %r22, %r17, 1;
    shr.s64 %rd10, %rd9, 4;
    shr.s32 %r27, %r17, 7;
    shl.b32 %r25, %r27, 1;
    add.s32 %r17, %r27, 65535;
    cvt.u64.u32 %rd5, %r3;
    min.u32 %r19, %r17, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
