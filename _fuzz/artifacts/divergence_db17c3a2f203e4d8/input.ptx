.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r7, %r3, 15;
    mad.lo.s32 %r10, %r3, %r7, %r7;
    cvt.u64.u32 %rd6, %r7;
    setp.ge.s32 %p1, %r3, %r10;
    @%p1 max.u32 %r18, %r10, 15;
    setp.ne.s32 %p1, %r18, 65535;
    setp.le.s32 %p4, %r3, %r18;
    @%p4 sub.s32 %r25, %r10, %r10;
    setp.lt.s32 %p3, %r7, 0;
    @%p3 mul.lo.s32 %r6, %r25, 4;
    shr.s32 %r21, %r18, 16;
    selp.b32 %r23, %r6, %r25, %p1;
    xor.b32 %r11, %r23, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
