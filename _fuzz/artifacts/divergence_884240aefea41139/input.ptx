.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r26, %r3, %r3;
    max.s32 %r18, %r3, 2;
    cvt.s64.s32 %rd11, %r3;
    max.s64 %rd6, %rd11, %rd11;
    mul.lo.u32 %r27, %r26, %r3;
    mul.wide.s32 %rd12, %r3, %r27;
    sub.u32 %r19, %r18, 4294967295;
    mad.lo.s32 %r21, %r27, %r19, %r3;
    shl.b64 %rd8, %rd12, 63;
    sub.u32 %r24, %r18, 31;
    mul.lo.u32 %r8, %r18, %r24;
    xor.b32 %r25, %r3, %r27;
    mul.wide.s32 %rd9, %r27, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
