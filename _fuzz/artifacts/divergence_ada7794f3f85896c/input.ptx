.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p2, %r3, 3;
    @!%p2 shr.u32 %r8, %r3, 15;
    mul.lo.u32 %r27, %r3, %r3;
    mul.wide.s32 %rd11, %r27, %r8;
    mul.wide.s32 %rd9, %r3, %r8;
    xor.b32 %r17, %r8, %r27;
    max.u32 %r16, %r8, %r27;
    shr.s64 %rd10, %rd9, 4;
    shl.b64 %rd10, %rd9, 7;
    mul.wide.u32 %rd15, %r16, %r16;
    shr.s32 %r6, %r8, 2;
    xor.b32 %r13, %r16, %r16;
    mul.wide.u32 %rd14, %r27, %r13;
    max.s32 %r14, %r6, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
