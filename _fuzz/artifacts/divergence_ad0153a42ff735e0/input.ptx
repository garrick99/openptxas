.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r11, %r3, 30;
    cvt.u64.u32 %rd14, %r11;
    setp.ne.u32 %p2, %r3, %r11;
    @!%p2 sub.u32 %r16, %r11, 31;
    or.b32 %r9, %r11, %r16;
    xor.b32 %r15, %r3, %r3;
    shr.u32 %r4, %r9, 16;
    mul.lo.u32 %r25, %r3, %r3;
    cvt.s64.s32 %rd12, %r4;
    sub.u32 %r11, %r3, %r11;
    xor.b32 %r16, %r9, 1;
    and.b64 %rd6, %rd14, %rd14;
    max.s64 %rd11, %rd6, %rd12;
    shl.b64 %rd15, %rd14, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
