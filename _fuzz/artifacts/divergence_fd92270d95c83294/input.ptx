.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r27, %r3, 256;
    mul.lo.u32 %r15, %r27, 65536;
    xor.b32 %r14, %r3, %r15;
    sub.u32 %r16, %r15, %r27;
    max.s32 %r5, %r27, %r15;
    min.u32 %r4, %r16, 4294967295;
    shr.s32 %r23, %r5, 30;
    mul.lo.u32 %r15, %r27, 0;
    add.u32 %r11, %r5, %r27;
    setp.ne.s32 %p1, %r11, %r23;
    @%p1 cvt.u64.u32 %rd14, %r15;
    mad.lo.s32 %r13, %r15, %r5, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
