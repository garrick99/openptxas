.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd13, %r3, %r3;
    cvt.s32.s64 %r27, %rd13;
    max.s32 %r25, %r3, 4;
    cvt.s64.s32 %rd5, %r3;
    shl.b32 %r20, %r3, 1;
    setp.gt.u32 %p3, %r25, %r25;
    min.u32 %r23, %r27, %r25;
    cvt.u64.u32 %rd12, %r20;
    add.u32 %r27, %r25, %r3;
    setp.ge.s32 %p1, %r25, %r25;
    setp.ge.s32 %p3, %r25, %r20;
    @%p3 max.u32 %r15, %r25, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
