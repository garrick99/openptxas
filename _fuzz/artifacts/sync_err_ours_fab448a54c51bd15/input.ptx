    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r8, %r3, %r3;
    sub.s32 %r10, %r3, 2147483648;
    xor.b32 %r27, %r8, %r10;
    mad.lo.u32 %r26, %r8, %r8, %r10;
    cvt.u64.u32 %rd9, %r8;
    and.b32 %r10, %r3, 7;
    min.u32 %r18, %r26, 1;
    setp.eq.u32 %p2, %r10, 65535;
    @%p2 shr.u32 %r24, %r27, 31;
