.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    shl.b64 %rd12, %rd6, 63;
    sub.u32 %r9, %r3, %r3;
    sub.u32 %r12, %r3, 5;
    sub.s64 %rd8, %rd12, %rd12;
    sub.u32 %r26, %r12, 4294967295;
    setp.ne.s32 %p3, %r9, %r3;
    @!%p3 xor.b32 %r19, %r3, 65535;
    cvt.u32.u64 %r10, %rd8;
    max.u32 %r27, %r9, 64;
    shr.s32 %r8, %r19, 4;
    mad.lo.u32 %r18, %r10, %r19, %r26;
    and.b32 %r25, %r9, %r3;
    setp.eq.u32 %p3, %r26, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
