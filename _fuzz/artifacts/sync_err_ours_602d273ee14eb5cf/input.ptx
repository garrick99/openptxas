.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r5, %r3, %r3;
    or.b32 %r19, %r3, %r3;
    cvt.s64.s32 %rd15, %r3;
    cvt.u32.u64 %r9, %rd15;
    setp.eq.s32 %p3, %r19, 31;
    @%p3 and.b32 %r7, %r19, 31;
    add.u32 %r20, %r9, 65535;
    min.s32 %r13, %r3, %r9;
    sub.u32 %r11, %r3, %r3;
    setp.gt.u32 %p2, %r5, 65535;
    @%p2 cvt.s32.s64 %r9, %rd15;
    max.s32 %r22, %r7, %r5;
    setp.ne.u32 %p4, %r19, 31;
    @!%p4 sub.u64 %rd6, %rd15, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
