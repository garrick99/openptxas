.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r20, %r3, %r3;
    cvt.u64.u32 %rd11, %r20;
    shl.b64 %rd12, %rd11, 62;
    mul.wide.u32 %rd15, %r20, %r3;
    mul.wide.s32 %rd10, %r20, %r20;
    shr.u32 %r18, %r20, 16;
    shl.b32 %r15, %r18, 16;
    mad.lo.s32 %r17, %r3, %r3, %r18;
    shr.s32 %r21, %r3, 1;
    shr.u32 %r15, %r3, 2;
    mad.lo.s32 %r20, %r17, %r21, %r20;
    setp.le.s32 %p1, %r3, %r17;
    shr.u32 %r21, %r20, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
