.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p1, %r3, 5;
    @%p1 max.u32 %r24, %r3, 8;
    mul.wide.s32 %rd6, %r24, %r24;
    shr.s32 %r25, %r3, 0;
    cvt.s32.s64 %r20, %rd6;
    sub.s32 %r27, %r20, 65536;
    cvt.s64.s32 %rd7, %r25;
    mul.lo.s32 %r5, %r3, 15;
    xor.b32 %r13, %r5, %r25;
    sub.s32 %r18, %r24, %r5;
    mul.lo.u32 %r16, %r5, 2147483648;
    cvt.u32.u64 %r22, %rd7;
    add.u32 %r26, %r16, 2;
    shl.b64 %rd8, %rd6, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
