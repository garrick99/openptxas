.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    mul.wide.u32 %rd13, %r3, %r3;
    mad.lo.s32 %r7, %r3, %r3, %r3;
    shr.s64 %rd15, %rd15, 31;
    or.b32 %r16, %r3, %r3;
    max.s32 %r8, %r16, %r7;
    add.u32 %r14, %r3, 2147483647;
    shr.s64 %rd6, %rd15, 62;
    setp.eq.s32 %p3, %r16, %r8;
    @%p3 sub.u32 %r22, %r16, 256;
    setp.gt.s32 %p1, %r8, 32;
    setp.gt.s32 %p1, %r8, %r3;
    @!%p1 cvt.u64.u32 %rd6, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
