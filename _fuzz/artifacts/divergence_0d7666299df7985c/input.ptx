.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p4, %r3, 4294967295;
    @!%p4 cvt.s64.s32 %rd11, %r3;
    or.b32 %r27, %r3, %r3;
    shl.b32 %r6, %r27, 0;
    setp.le.s32 %p1, %r3, 31;
    @%p1 shr.u64 %rd8, %rd11, 7;
    mul.wide.s32 %rd15, %r6, %r6;
    cvt.u64.u32 %rd9, %r3;
    or.b32 %r22, %r27, %r3;
    cvt.u32.u64 %r4, %rd15;
    selp.b32 %r12, %r22, %r22, %p4;
    min.u64 %rd5, %rd9, %rd8;
    cvt.u32.u64 %r24, %rd5;
    setp.eq.s32 %p4, %r27, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
