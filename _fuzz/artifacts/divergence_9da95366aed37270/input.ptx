.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    or.b32 %r25, %r3, %r3;
    min.u32 %r18, %r3, %r25;
    mad.lo.u32 %r27, %r18, %r25, %r18;
    mad.lo.u32 %r5, %r25, %r3, %r18;
    add.u32 %r14, %r27, 63;
    shr.s64 %rd9, %rd7, 16;
    mul.wide.s32 %rd9, %r27, %r25;
    add.s64 %rd10, %rd9, %rd7;
    and.b64 %rd9, %rd10, %rd7;
    mul.wide.u32 %rd14, %r14, %r14;
    mad.lo.u32 %r8, %r25, %r18, %r27;
    shr.u64 %rd5, %rd9, 47;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
