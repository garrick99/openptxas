.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    sub.u32 %r5, %r3, 2147483648;
    or.b32 %r9, %r3, %r3;
    setp.gt.u32 %p2, %r5, %r9;
    shr.s32 %r17, %r3, 4;
    min.s32 %r21, %r9, %r5;
    setp.lt.u32 %p4, %r17, 65536;
    @!%p4 shl.b32 %r15, %r17, 16;
    mul.lo.u32 %r9, %r3, 15;
    or.b32 %r22, %r15, %r21;
    setp.lt.s32 %p4, %r15, 0;
    @%p4 cvt.u64.u32 %rd7, %r9;
    selp.b32 %r15, %r21, %r17, %p2;
    sub.s32 %r14, %r17, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
