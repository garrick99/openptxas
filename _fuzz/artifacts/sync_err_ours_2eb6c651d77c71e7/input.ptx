.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r23, %r3, 2;
    xor.b32 %r19, %r23, %r3;
    shr.s32 %r24, %r3, 15;
    setp.hs.u32 %p3, %r19, %r24;
    @%p3 cvt.u64.u32 %rd11, %r3;
    shr.u32 %r19, %r24, 15;
    min.u32 %r18, %r23, %r23;
    or.b32 %r10, %r19, 1;
    setp.ge.s32 %p1, %r24, %r19;
    @%p1 shr.u32 %r21, %r19, 16;
    mad.lo.u32 %r15, %r10, %r18, %r19;
    add.s32 %r5, %r21, %r3;
    sub.u32 %r27, %r24, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
