.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    sub.u64 %rd14, %rd15, %rd15;
    setp.lt.s32 %p1, %r3, 7;
    mad.lo.u32 %r11, %r3, %r3, %r3;
    cvt.s64.s32 %rd5, %r3;
    mul.lo.s32 %r10, %r11, %r3;
    cvt.s64.s32 %rd6, %r10;
    add.u32 %r25, %r10, %r10;
    mul.wide.u32 %rd15, %r11, %r3;
    cvt.s32.s64 %r14, %rd6;
    mul.wide.s32 %rd15, %r11, %r3;
    setp.ge.s32 %p2, %r11, %r11;
    @!%p2 max.s32 %r7, %r11, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
