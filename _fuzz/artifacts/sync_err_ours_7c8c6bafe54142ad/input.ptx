.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r20, %r3, 32;
    mul.lo.s32 %r13, %r3, 3;
    mul.wide.u32 %rd10, %r3, %r20;
    shr.u32 %r15, %r3, 16;
    max.u32 %r9, %r13, 8;
    setp.hi.u32 %p1, %r3, 2;
    mad.lo.u32 %r26, %r3, %r13, %r13;
    shr.s32 %r18, %r13, 15;
    xor.b32 %r15, %r15, 65535;
    xor.b64 %rd13, %rd10, %rd10;
    max.u32 %r14, %r20, %r20;
    shl.b64 %rd11, %rd10, 31;
    shl.b64 %rd15, %rd11, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
