.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd12, %r3, %r3;
    cvt.s32.s64 %r22, %rd12;
    setp.lt.u32 %p4, %r22, %r22;
    @!%p4 add.s32 %r10, %r3, %r22;
    max.u32 %r7, %r22, %r10;
    and.b32 %r11, %r3, 63;
    setp.ne.s32 %p2, %r7, 0;
    @%p2 shr.u32 %r9, %r11, 0;
    setp.ne.s32 %p3, %r9, 64;
    @%p3 mad.lo.s32 %r18, %r9, %r7, %r11;
    shr.s64 %rd7, %rd12, 16;
    and.b32 %r27, %r18, %r7;
    mad.lo.s32 %r7, %r22, %r3, %r7;
    add.u32 %r23, %r9, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
