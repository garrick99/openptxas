.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r11, %r3, 0;
    add.u32 %r19, %r11, %r11;
    cvt.u64.u32 %rd15, %r19;
    sub.s32 %r20, %r19, 16;
    max.s32 %r16, %r11, 2;
    add.s32 %r5, %r11, %r20;
    min.s32 %r22, %r11, %r16;
    and.b32 %r20, %r16, %r3;
    mul.lo.u32 %r19, %r20, 4;
    min.s32 %r9, %r11, %r19;
    and.b32 %r25, %r5, %r9;
    shr.u32 %r7, %r20, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
