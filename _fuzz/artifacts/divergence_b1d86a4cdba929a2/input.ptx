.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    mul.lo.s32 %r25, %r3, %r3;
    shl.b32 %r11, %r25, 16;
    shr.u32 %r15, %r25, 3;
    shl.b32 %r14, %r15, 15;
    shr.s64 %rd5, %rd15, 3;
    sub.u32 %r26, %r11, 0;
    max.u32 %r8, %r11, %r15;
    shl.b32 %r5, %r15, 0;
    mul.lo.u32 %r17, %r14, %r11;
    shl.b64 %rd7, %rd5, 48;
    add.s32 %r24, %r8, 7;
    min.u32 %r24, %r11, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
