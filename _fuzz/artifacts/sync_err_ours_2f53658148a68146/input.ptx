.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    mad.lo.s32 %r18, %r3, %r3, %r3;
    mul.wide.u32 %rd12, %r3, %r3;
    shl.b64 %rd5, %rd12, 1;
    mul.lo.s32 %r9, %r3, 256;
    shr.s64 %rd10, %rd12, 7;
    add.s32 %r23, %r9, %r9;
    xor.b32 %r9, %r9, %r23;
    cvt.s32.s64 %r7, %rd10;
    setp.eq.s32 %p1, %r23, %r3;
    mul.wide.u32 %rd15, %r3, %r7;
    and.b64 %rd15, %rd5, %rd10;
    setp.eq.u32 %p1, %r9, %r23;
    @%p1 min.s32 %r5, %r23, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
