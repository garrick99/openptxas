.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r22, %r3, %r3;
    mul.wide.u32 %rd6, %r22, %r3;
    cvt.s32.s64 %r17, %rd6;
    shl.b32 %r14, %r3, 15;
    add.u64 %rd8, %rd6, %rd6;
    setp.ls.u32 %p2, %r17, 256;
    @!%p2 cvt.s32.s64 %r11, %rd6;
    min.u32 %r25, %r11, %r11;
    shr.u32 %r13, %r25, 30;
    mul.wide.s32 %rd11, %r17, %r14;
    cvt.s32.s64 %r15, %rd8;
    setp.hi.u32 %p2, %r14, %r17;
    @%p2 selp.b32 %r8, %r15, %r13, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
