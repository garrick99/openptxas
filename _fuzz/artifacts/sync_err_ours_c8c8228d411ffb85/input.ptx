.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r24, %r3, %r3;
    min.s32 %r8, %r3, 4;
    or.b32 %r14, %r3, %r24;
    setp.le.s32 %p4, %r3, 255;
    @%p4 add.s32 %r10, %r14, %r24;
    cvt.s64.s32 %rd14, %r3;
    shr.u32 %r16, %r14, 30;
    max.s32 %r17, %r24, %r24;
    setp.ge.s32 %p3, %r14, %r8;
    mad.lo.u32 %r27, %r24, %r16, %r24;
    add.u32 %r24, %r10, %r10;
    add.s32 %r12, %r3, 31;
    shl.b32 %r25, %r8, 4;
    sub.u32 %r5, %r14, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
