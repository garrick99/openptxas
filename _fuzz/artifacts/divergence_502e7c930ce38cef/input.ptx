.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p1, %r3, %r3;
    @%p1 shl.b32 %r16, %r3, 15;
    mul.lo.u32 %r19, %r3, %r16;
    mad.lo.u32 %r18, %r19, %r16, %r3;
    cvt.s64.s32 %rd13, %r18;
    sub.s64 %rd10, %rd13, %rd13;
    shl.b64 %rd7, %rd13, 62;
    shr.s32 %r13, %r3, 2;
    max.s32 %r22, %r19, 8;
    cvt.u32.u64 %r18, %rd13;
    max.s32 %r20, %r3, 0;
    shr.s32 %r4, %r13, 7;
    shr.u32 %r8, %r13, 0;
    xor.b32 %r21, %r22, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
