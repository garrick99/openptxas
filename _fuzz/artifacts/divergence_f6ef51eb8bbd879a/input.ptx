.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r14, %r3, %r3;
    cvt.u64.u32 %rd6, %r14;
    shr.s64 %rd9, %rd6, 0;
    min.s32 %r21, %r14, %r3;
    setp.le.s32 %p2, %r3, 63;
    @%p2 cvt.s32.s64 %r7, %rd6;
    selp.b32 %r5, %r14, %r21, %p2;
    mul.lo.s32 %r4, %r21, 63;
    sub.u32 %r23, %r7, 1;
    max.s64 %rd12, %rd6, %rd6;
    mad.lo.u32 %r25, %r7, %r7, %r3;
    shr.u32 %r17, %r4, 31;
    mul.lo.u32 %r16, %r7, %r21;
    shl.b64 %rd11, %rd9, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
