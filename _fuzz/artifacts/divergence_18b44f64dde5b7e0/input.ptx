.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r17, %r3, 255;
    cvt.s64.s32 %rd15, %r17;
    min.u32 %r21, %r3, 255;
    shr.s64 %rd13, %rd15, 31;
    min.s64 %rd7, %rd13, %rd13;
    min.u32 %r17, %r21, %r17;
    shl.b32 %r15, %r21, 16;
    shr.u32 %r11, %r15, 4;
    setp.lt.s32 %p4, %r3, %r21;
    @%p4 or.b32 %r26, %r11, 32;
    selp.b32 %r19, %r21, %r11, %p4;
    mul.wide.s32 %rd10, %r26, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
