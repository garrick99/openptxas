.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    sub.u32 %r6, %r3, %r3;
    xor.b64 %rd5, %rd6, %rd6;
    min.u32 %r14, %r6, %r6;
    min.s64 %rd12, %rd5, %rd5;
    add.s32 %r5, %r14, 31;
    setp.ge.s32 %p4, %r14, %r5;
    @%p4 sub.s64 %rd5, %rd6, %rd5;
    shl.b32 %r15, %r14, 0;
    mad.lo.u32 %r23, %r6, %r15, %r3;
    cvt.u64.u32 %rd13, %r23;
    shr.u64 %rd13, %rd6, 2;
    shr.s32 %r23, %r15, 16;
    max.s64 %rd12, %rd12, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
