.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    or.b64 %rd6, %rd9, %rd9;
    cvt.s32.s64 %r15, %rd9;
    shr.s64 %rd6, %rd9, 15;
    min.u32 %r10, %r15, %r3;
    cvt.s32.s64 %r8, %rd9;
    mad.lo.s32 %r27, %r3, %r10, %r10;
    xor.b32 %r15, %r15, 63;
    mad.lo.s32 %r23, %r15, %r10, %r27;
    setp.lt.u32 %p2, %r15, 32;
    @%p2 min.u32 %r21, %r8, 63;
    setp.ls.u32 %p4, %r23, 256;
    @!%p4 max.s32 %r23, %r23, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
