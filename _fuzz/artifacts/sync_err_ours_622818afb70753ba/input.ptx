.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r22, %r3, %r3;
    shr.u32 %r11, %r3, 1;
    mad.lo.u32 %r13, %r11, %r22, %r3;
    max.s32 %r6, %r3, 3;
    mad.lo.s32 %r26, %r13, %r22, %r6;
    mad.lo.u32 %r10, %r11, %r26, %r6;
    max.s32 %r7, %r13, 4294967295;
    shl.b32 %r14, %r26, 2;
    cvt.u64.u32 %rd5, %r26;
    cvt.s32.s64 %r27, %rd5;
    mul.lo.u64 %rd8, %rd5, %rd5;
    mul.lo.u64 %rd10, %rd8, %rd8;
    shr.u64 %rd12, %rd5, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
