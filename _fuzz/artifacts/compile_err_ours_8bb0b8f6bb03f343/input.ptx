.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r6, %r0, %r3;
    setp.ge.u32 %p2, %r0, 65535;
    vote.sync.ballot.b32 %r15, %p2, -1;
    setp.ne.u32 %p3, %r15, 65535;
    vote.sync.ballot.b32 %r16, %p3, -1;
    shfl.sync.down.b32 %r4, %r15, 8, 0x1f, -1;
    or.b32 %r10, %r4, %r0;
    vote.sync.all.pred %p3, %p2, -1;
    setp.le.u32 %p2, %r16, 255;
    vote.sync.ballot.b32 %r12, %p2, -1;
    xor.b32 %r15, %r6, %r6;
    sub.u32 %r15, %r15, %r3;
    and.b32 %r16, %r10, %r0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
