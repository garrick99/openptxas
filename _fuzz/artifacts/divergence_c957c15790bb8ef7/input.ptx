.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r7, %r3, %r3, %r3;
    xor.b32 %r16, %r7, 256;
    cvt.u64.u32 %rd11, %r3;
    sub.u64 %rd11, %rd11, %rd11;
    xor.b32 %r18, %r16, 2;
    sub.s32 %r23, %r16, 15;
    mul.lo.s32 %r10, %r16, %r3;
    setp.le.s32 %p3, %r10, %r18;
    @%p3 mul.lo.s64 %rd14, %rd11, %rd11;
    sub.s64 %rd11, %rd14, %rd11;
    mul.lo.u32 %r8, %r10, 2147483648;
    cvt.s32.s64 %r4, %rd14;
    mul.wide.u32 %rd11, %r10, %r7;
    add.u64 %rd5, %rd14, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
