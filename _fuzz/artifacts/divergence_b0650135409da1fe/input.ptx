.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    shr.s32 %r22, %r3, 16;
    shl.b32 %r19, %r3, 30;
    and.b32 %r27, %r22, 32;
    mad.lo.s32 %r22, %r19, %r19, %r3;
    max.u32 %r27, %r27, 64;
    or.b32 %r22, %r27, %r19;
    max.s64 %rd13, %rd13, %rd13;
    sub.s32 %r25, %r22, %r22;
    setp.lt.s32 %p4, %r3, 7;
    cvt.s64.s32 %rd15, %r3;
    or.b32 %r11, %r19, 65536;
    xor.b32 %r24, %r27, %r25;
    mul.wide.s32 %rd11, %r22, %r22;
