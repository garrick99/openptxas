.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd12, %r3, %r3;
    add.u64 %rd14, %rd12, %rd12;
    shr.s64 %rd9, %rd12, 2;
    setp.gt.s32 %p3, %r3, 63;
    @!%p3 min.u32 %r15, %r3, %r3;
    cvt.u64.u32 %rd8, %r3;
    shr.u32 %r26, %r3, 15;
    selp.b32 %r9, %r15, %r26, %p3;
    min.u32 %r20, %r15, %r9;
    sub.u32 %r6, %r3, %r15;
    or.b32 %r8, %r6, 16;
    shl.b64 %rd6, %rd12, 31;
    xor.b64 %rd11, %rd9, %rd9;
    setp.lt.u32 %p1, %r26, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
