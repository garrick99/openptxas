    max.s64 %rd12, %rd15, %rd15;
    or.b32 %r6, %r3, %r8;
    xor.b32 %r8, %r8, %r3;
    cvt.s32.s64 %r19, %rd12;
    or.b32 %r25, %r18, 2147483647;
