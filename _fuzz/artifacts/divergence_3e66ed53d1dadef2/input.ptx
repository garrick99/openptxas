.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r8, %r3, 7;
    setp.hs.u32 %p4, %r8, 1;
    @!%p4 mul.wide.s32 %rd14, %r3, %r3;
    cvt.s64.s32 %rd6, %r3;
    sub.u64 %rd8, %rd14, %rd6;
    add.u32 %r10, %r8, %r8;
    add.s32 %r14, %r3, 7;
    selp.b32 %r17, %r10, %r10, %p4;
    shr.u32 %r16, %r8, 7;
    mad.lo.s32 %r23, %r16, %r17, %r8;
    xor.b32 %r14, %r23, %r3;
    shl.b64 %rd10, %rd8, 33;
    and.b64 %rd6, %rd10, %rd6;
    min.u32 %r25, %r3, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
