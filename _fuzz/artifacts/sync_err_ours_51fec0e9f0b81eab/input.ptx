.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    mul.lo.s32 %r18, %r3, %r3;
    and.b32 %r19, %r3, 4;
    or.b32 %r9, %r3, 255;
    or.b32 %r8, %r19, %r3;
    shr.s32 %r27, %r8, 2;
    shr.s32 %r10, %r27, 7;
    mul.wide.s32 %rd10, %r18, %r27;
    mul.lo.u32 %r14, %r19, %r3;
    setp.ge.s32 %p3, %r14, %r18;
    add.s32 %r20, %r9, %r8;
    mad.lo.u32 %r25, %r3, %r9, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
