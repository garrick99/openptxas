.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd6, %r3, %r3;
    min.u32 %r13, %r3, 15;
    shr.u32 %r16, %r3, 4;
    mad.lo.u32 %r17, %r3, %r3, %r13;
    shl.b64 %rd14, %rd6, 33;
    setp.eq.u32 %p4, %r13, 5;
    @!%p4 mul.wide.u32 %rd12, %r3, %r17;
    min.s32 %r4, %r16, 0;
    add.s32 %r4, %r16, 8;
    mul.wide.s32 %rd14, %r13, %r13;
    shl.b32 %r4, %r17, 3;
    min.s32 %r18, %r4, 7;
    shr.s64 %rd14, %rd14, 31;
    setp.eq.s32 %p1, %r13, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
