.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r11, %r3, 4294967295;
    cvt.u64.u32 %rd5, %r3;
    min.s32 %r23, %r11, 16;
    max.u32 %r21, %r23, %r3;
    cvt.s32.s64 %r12, %rd5;
    cvt.s64.s32 %rd6, %r12;
    shl.b64 %rd15, %rd6, 63;
    shl.b32 %r21, %r12, 15;
    sub.s32 %r19, %r3, %r12;
    add.u32 %r20, %r11, 15;
    sub.u32 %r6, %r3, %r19;
    max.u32 %r7, %r19, %r12;
    cvt.u32.u64 %r9, %rd5;
    sub.s32 %r8, %r3, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
