.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r22, %r3, %r3, %r3;
    xor.b32 %r27, %r3, 65535;
    min.s32 %r15, %r22, 256;
    min.s32 %r7, %r22, %r3;
    mad.lo.u32 %r9, %r15, %r15, %r27;
    cvt.u64.u32 %rd13, %r7;
    shr.s64 %rd15, %rd13, 2;
    cvt.s32.s64 %r17, %rd13;
    sub.s32 %r24, %r7, 3;
    cvt.u64.u32 %rd10, %r9;
    mul.lo.s64 %rd5, %rd13, %rd13;
    sub.u32 %r19, %r9, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
