.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    cvt.s64.s32 %rd7, %r3;
    max.s32 %r22, %r3, 64;
    sub.s32 %r9, %r3, 1;
    mul.wide.u32 %rd6, %r22, %r22;
    setp.lo.u32 %p3, %r9, 63;
    @!%p3 xor.b32 %r26, %r3, %r22;
    shr.u32 %r8, %r3, 31;
    selp.b32 %r15, %r8, %r22, %p3;
    shr.s64 %rd14, %rd6, 0;
    shl.b32 %r13, %r22, 7;
    max.u32 %r14, %r22, %r9;
    or.b32 %r26, %r15, %r22;
    xor.b32 %r4, %r8, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
