.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd5, %r3, %r3;
    setp.ne.u32 %p4, %r3, %r3;
    @!%p4 mad.lo.s32 %r22, %r3, %r3, %r3;
    cvt.s32.s64 %r14, %rd5;
    cvt.s32.s64 %r13, %rd5;
    shr.u64 %rd11, %rd5, 32;
    mad.lo.u32 %r7, %r22, %r3, %r14;
    or.b32 %r20, %r14, %r7;
    mul.wide.u32 %rd11, %r7, %r7;
    shr.s64 %rd12, %rd5, 63;
    max.s32 %r19, %r14, %r22;
    shr.s64 %rd8, %rd11, 33;
    mad.lo.s32 %r14, %r20, %r20, %r13;
    min.u32 %r6, %r19, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
