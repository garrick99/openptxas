.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    shr.u32 %r21, %r3, 16;
    shr.u64 %rd9, %rd8, 63;
    cvt.s32.s64 %r17, %rd9;
    mul.lo.s32 %r27, %r3, %r3;
    shr.u32 %r6, %r27, 30;
    sub.u32 %r18, %r21, %r21;
    mul.lo.s32 %r16, %r21, 2147483647;
    shr.s64 %rd6, %rd9, 33;
    sub.u32 %r11, %r21, 64;
    mul.wide.u32 %rd11, %r21, %r11;
    min.s32 %r16, %r16, 16;
    shr.u64 %rd15, %rd9, 33;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
