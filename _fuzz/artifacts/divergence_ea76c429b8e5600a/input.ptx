.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p4, %r3, %r3;
    shr.s32 %r17, %r3, 7;
    setp.gt.u32 %p4, %r17, 7;
    @!%p4 cvt.s64.s32 %rd13, %r3;
    selp.b32 %r7, %r17, %r3, %p4;
    mul.lo.s32 %r6, %r3, 4294967295;
    max.u32 %r9, %r3, %r17;
    shr.s64 %rd5, %rd13, 48;
    shl.b64 %rd9, %rd5, 30;
    add.u32 %r4, %r17, %r17;
    max.s32 %r18, %r7, 64;
    mul.lo.s32 %r24, %r9, 5;
    min.u32 %r26, %r6, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
