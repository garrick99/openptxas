.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd5, %r3, %r3;
    or.b64 %rd8, %rd5, %rd5;
    mul.lo.u32 %r20, %r3, 64;
    cvt.u64.u32 %rd15, %r20;
    max.s32 %r5, %r3, 5;
    sub.u32 %r19, %r20, %r3;
    shl.b64 %rd7, %rd5, 16;
    add.u32 %r21, %r19, 63;
    max.s32 %r11, %r21, %r19;
    shl.b32 %r18, %r19, 7;
    cvt.s32.s64 %r11, %rd5;
    mul.wide.s32 %rd10, %r3, %r20;
    shr.u64 %rd7, %rd8, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
