.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r16, %r3, %r3;
    mul.lo.u32 %r8, %r16, %r16;
    shr.u32 %r18, %r3, 30;
    max.s32 %r19, %r8, %r18;
    or.b32 %r15, %r8, 31;
    setp.ge.s32 %p4, %r16, %r8;
    @%p4 sub.u32 %r13, %r18, %r19;
    max.s32 %r15, %r16, %r13;
    max.s32 %r23, %r8, 15;
    and.b32 %r5, %r23, 4294967295;
    cvt.s64.s32 %rd13, %r8;
    sub.u32 %r27, %r5, %r5;
    setp.hs.u32 %p4, %r8, %r15;
    @%p4 and.b32 %r23, %r23, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
