.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r7, %r3, 31;
    cvt.u64.u32 %rd10, %r7;
    setp.hi.u32 %p1, %r3, 0;
    @%p1 sub.s32 %r13, %r7, 15;
    add.u32 %r4, %r3, 1;
    mad.lo.s32 %r9, %r4, %r13, %r4;
    mul.wide.s32 %rd15, %r3, %r3;
    mul.lo.s32 %r25, %r3, 7;
    or.b32 %r12, %r25, %r9;
    add.u32 %r21, %r4, 2147483647;
    cvt.u32.u64 %r6, %rd10;
    shl.b32 %r27, %r13, 4;
    setp.hi.u32 %p1, %r7, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
