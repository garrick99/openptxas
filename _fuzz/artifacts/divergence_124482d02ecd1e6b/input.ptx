.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r19, %r3, 4;
    cvt.u64.u32 %rd8, %r3;
    cvt.s64.s32 %rd8, %r3;
    shr.s64 %rd13, %rd8, 33;
    shl.b32 %r25, %r19, 30;
    setp.lt.s32 %p3, %r3, 2147483648;
    @%p3 mul.wide.u32 %rd14, %r19, %r19;
    add.s32 %r9, %r3, 255;
    shr.s32 %r11, %r9, 31;
    shl.b64 %rd8, %rd14, 30;
    shr.u32 %r5, %r9, 4;
    cvt.u64.u32 %rd10, %r19;
    cvt.s64.s32 %rd9, %r11;
    mad.lo.s32 %r9, %r5, %r25, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
