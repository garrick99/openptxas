.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r10, %r3, %r3;
    mul.wide.s32 %rd12, %r3, %r10;
    min.u32 %r25, %r10, 5;
    setp.le.u32 %p2, %r25, %r10;
    @!%p2 add.u64 %rd13, %rd12, %rd12;
    add.s64 %rd6, %rd12, %rd13;
    add.s32 %r26, %r25, 256;
    setp.ls.u32 %p4, %r25, %r10;
    @%p4 shr.u32 %r11, %r3, 3;
    mul.wide.s32 %rd7, %r11, %r26;
    xor.b64 %rd5, %rd13, %rd12;
    cvt.u64.u32 %rd11, %r11;
    selp.b32 %r9, %r10, %r26, %p4;
    mad.lo.s32 %r9, %r10, %r9, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
