.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    shl.b32 %r14, %r3, 3;
    mul.lo.u32 %r22, %r3, 4;
    or.b32 %r13, %r3, 8;
    mul.lo.s32 %r4, %r3, %r3;
    xor.b32 %r5, %r13, 0;
    mul.wide.u32 %rd13, %r22, %r14;
    mul.wide.s32 %rd11, %r22, %r14;
    sub.s32 %r16, %r4, 2;
    mul.wide.s32 %rd14, %r3, %r14;
    cvt.u32.u64 %r10, %rd9;
    or.b32 %r18, %r13, %r22;
    mul.lo.s32 %r7, %r10, %r22;
    max.s64 %rd8, %rd9, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
