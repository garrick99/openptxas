.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r5, %r3, 7;
    mad.lo.s32 %r9, %r3, %r5, %r5;
    shr.u32 %r22, %r9, 30;
    cvt.s64.s32 %rd6, %r5;
    sub.u32 %r16, %r5, %r9;
    add.u32 %r15, %r9, %r3;
    shr.u64 %rd11, %rd6, 0;
    setp.gt.s32 %p2, %r9, %r16;
    setp.lt.s32 %p4, %r9, %r9;
    shl.b32 %r27, %r9, 7;
    sub.s32 %r18, %r3, 31;
    add.s32 %r15, %r22, 16;
    add.s32 %r17, %r9, %r18;
    min.u32 %r11, %r15, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
