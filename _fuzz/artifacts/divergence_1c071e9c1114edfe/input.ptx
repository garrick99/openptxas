.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r23, %r3, 30;
    cvt.u64.u32 %rd7, %r3;
    min.s32 %r25, %r23, 7;
    max.u32 %r4, %r3, 1;
    sub.u32 %r16, %r25, %r23;
    setp.ne.s32 %p2, %r3, 63;
    @!%p2 shr.s32 %r15, %r25, 30;
    max.s32 %r12, %r15, 2;
    or.b32 %r17, %r3, %r12;
    cvt.u64.u32 %rd8, %r16;
    xor.b64 %rd14, %rd7, %rd8;
    mad.lo.u32 %r21, %r12, %r17, %r15;
    mul.wide.s32 %rd5, %r16, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
