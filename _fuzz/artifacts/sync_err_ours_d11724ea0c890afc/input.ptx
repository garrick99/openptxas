.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p3, %r3, %r3;
    @%p3 xor.b32 %r21, %r3, %r3;
    setp.eq.s32 %p2, %r3, 255;
    or.b32 %r24, %r3, %r21;
    add.s32 %r4, %r3, %r21;
    max.s32 %r14, %r4, %r3;
    sub.s32 %r17, %r24, 3;
    xor.b32 %r8, %r3, %r21;
    shl.b32 %r22, %r21, 3;
    min.s32 %r13, %r24, 65535;
    min.s32 %r16, %r13, %r3;
    and.b32 %r19, %r14, %r13;
    cvt.u64.u32 %rd15, %r17;
    cvt.u32.u64 %r25, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
