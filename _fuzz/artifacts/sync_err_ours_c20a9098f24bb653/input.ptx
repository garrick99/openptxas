.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r21, %r3, 4;
    mul.lo.s32 %r20, %r21, 65535;
    cvt.s64.s32 %rd7, %r3;
    xor.b32 %r27, %r21, %r3;
    cvt.u32.u64 %r25, %rd7;
    mul.lo.u32 %r16, %r27, 65535;
    sub.u32 %r8, %r27, %r27;
    sub.u32 %r13, %r25, %r20;
    shl.b64 %rd12, %rd7, 7;
    mul.lo.s64 %rd13, %rd7, %rd12;
    max.u64 %rd15, %rd12, %rd7;
    setp.le.s32 %p1, %r8, 255;
    @%p1 mad.lo.u32 %r27, %r8, %r27, %r3;
    mul.lo.u64 %rd13, %rd13, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
