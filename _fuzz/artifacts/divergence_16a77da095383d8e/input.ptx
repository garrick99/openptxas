.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    cvt.u32.u64 %r27, %rd11;
    setp.lt.s32 %p4, %r27, 5;
    @!%p4 max.u32 %r21, %r3, 16;
    mul.wide.s32 %rd10, %r3, %r27;
    add.u32 %r11, %r27, 0;
    cvt.u32.u64 %r26, %rd10;
    shl.b64 %rd7, %rd10, 4;
    xor.b32 %r19, %r27, 4294967295;
    shr.s64 %rd11, %rd7, 30;
    sub.s32 %r13, %r11, %r19;
    xor.b32 %r25, %r11, %r27;
    mul.wide.u32 %rd9, %r3, %r27;
    mad.lo.u32 %r11, %r21, %r19, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
