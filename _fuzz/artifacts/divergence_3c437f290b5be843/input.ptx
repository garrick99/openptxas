.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p1, %r3, 7;
    @%p1 add.u32 %r27, %r3, 15;
    shr.s32 %r7, %r3, 15;
    min.u32 %r19, %r3, %r27;
    or.b32 %r8, %r3, %r27;
    sub.s32 %r8, %r7, %r19;
    cvt.u64.u32 %rd10, %r8;
    mul.wide.u32 %rd5, %r27, %r19;
    xor.b32 %r12, %r19, %r8;
    and.b64 %rd15, %rd10, %rd10;
    shl.b32 %r26, %r27, 3;
    cvt.u64.u32 %rd13, %r12;
    min.s32 %r4, %r8, %r19;
    mul.lo.u32 %r26, %r26, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
