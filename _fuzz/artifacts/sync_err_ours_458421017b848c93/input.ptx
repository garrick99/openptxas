    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    min.u32 %r23, %r3, %r3;
    setp.eq.u32 %p2, %r23, 2147483647;
    @%p2 shr.u32 %r15, %r3, 15;
    max.u32 %r15, %r23, %r15;
    min.s32 %r4, %r3, %r23;
    selp.b32 %r13, %r15, %r4, %p2;
    cvt.u32.u64 %r21, %rd12;
    and.b32 %r5, %r3, %r23;
    add.s32 %r16, %r13, %r21;
    cvt.u64.u32 %rd5, %r4;
    cvt.u32.u64 %r24, %rd5;
    add.u32 %r25, %r23, 4294967295;
    add.s32 %r13, %r21, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
