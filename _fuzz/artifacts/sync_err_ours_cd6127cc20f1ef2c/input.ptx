.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r24, %r3, %r3;
    mul.wide.u32 %rd14, %r3, %r3;
    mul.wide.s32 %rd15, %r24, %r24;
    setp.ne.u32 %p3, %r24, 16;
    @%p3 add.u32 %r6, %r3, 4;
    xor.b32 %r13, %r3, 32;
    or.b64 %rd14, %rd15, %rd15;
    shl.b32 %r16, %r13, 1;
    add.s64 %rd10, %rd15, %rd14;
    mul.lo.u32 %r18, %r13, 3;
    mul.lo.u32 %r21, %r24, 32;
    mad.lo.u32 %r17, %r3, %r6, %r18;
    mul.wide.s32 %rd11, %r21, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
