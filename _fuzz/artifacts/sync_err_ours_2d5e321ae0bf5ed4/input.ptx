.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r27, %r3, 65536;
    cvt.u64.u32 %rd15, %r3;
    add.s32 %r6, %r3, 2;
    mul.lo.u32 %r25, %r6, 16;
    max.u32 %r5, %r27, 3;
    cvt.s32.s64 %r7, %rd15;
    and.b32 %r25, %r5, 0;
    xor.b32 %r4, %r7, %r6;
    min.u32 %r14, %r5, 31;
    shr.u64 %rd15, %rd15, 63;
    add.u32 %r13, %r14, %r27;
    shr.s32 %r18, %r7, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
