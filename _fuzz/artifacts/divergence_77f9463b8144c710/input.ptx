.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    mul.lo.s64 %rd11, %rd12, %rd12;
    sub.s32 %r19, %r3, 255;
    add.u32 %r18, %r3, %r19;
    mad.lo.s32 %r4, %r19, %r19, %r19;
    mad.lo.s32 %r5, %r18, %r18, %r3;
    setp.lt.u32 %p3, %r5, %r5;
    @%p3 shl.b32 %r15, %r19, 7;
    max.s32 %r4, %r15, 3;
    min.u32 %r21, %r15, %r5;
    cvt.s64.s32 %rd12, %r18;
    add.u32 %r12, %r15, 16;
    add.u32 %r14, %r5, %r19;
    shl.b32 %r16, %r12, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
