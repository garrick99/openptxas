.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    setp.gt.u32 %p4, %r3, %r3;
    xor.b32 %r20, %r3, 7;
    max.u32 %r4, %r3, 63;
    mul.lo.s32 %r26, %r20, 32;
    mul.lo.s32 %r16, %r20, 2147483647;
    sub.u32 %r23, %r26, 4294967295;
    mad.lo.s32 %r10, %r26, %r23, %r3;
    cvt.u32.u64 %r10, %rd7;
    shr.s32 %r20, %r26, 31;
    add.u64 %rd11, %rd7, %rd7;
    and.b64 %rd9, %rd11, %rd11;
    selp.b32 %r12, %r4, %r4, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
