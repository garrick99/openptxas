.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    mad.lo.s32 %r9, %r3, %r3, %r3;
    max.u32 %r25, %r9, 31;
    sub.u32 %r9, %r9, 64;
    shl.b64 %rd7, %rd15, 2;
    mul.wide.s32 %rd11, %r25, %r9;
    shr.s64 %rd12, %rd15, 0;
    shr.u32 %r24, %r3, 4;
    add.s32 %r11, %r9, 65535;
    shr.s32 %r16, %r3, 2;
    or.b32 %r10, %r25, %r3;
    shl.b64 %rd14, %rd12, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
