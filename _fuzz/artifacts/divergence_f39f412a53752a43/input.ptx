.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r7, %r3, %r3;
    xor.b32 %r9, %r3, 2147483647;
    setp.le.s32 %p3, %r9, 2147483647;
    @!%p3 min.u32 %r24, %r7, 2147483648;
    cvt.s64.s32 %rd13, %r7;
    mul.wide.s32 %rd12, %r9, %r9;
    shr.s32 %r21, %r9, 7;
    shr.u32 %r16, %r9, 2;
    max.u64 %rd9, %rd12, %rd13;
    setp.hi.u32 %p1, %r3, %r7;
    @%p1 mul.lo.s32 %r24, %r21, %r3;
    min.u32 %r7, %r21, %r9;
    max.s64 %rd8, %rd9, %rd12;
    xor.b32 %r16, %r21, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
