    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r14, %r3, %r3;
    min.u32 %r15, %r14, 65536;
    xor.b32 %r12, %r14, %r3;
    min.s32 %r23, %r3, %r15;
    sub.u32 %r6, %r23, 7;
    add.u32 %r16, %r14, %r14;
    shr.s32 %r18, %r6, 2;
