.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r8, %r3, 32;
    add.s32 %r12, %r3, 7;
    shr.u32 %r16, %r12, 16;
    max.s32 %r25, %r12, %r3;
    add.s32 %r19, %r3, %r12;
    shl.b32 %r20, %r19, 3;
    shr.u32 %r21, %r25, 2;
    mul.lo.u32 %r4, %r20, 31;
    xor.b32 %r22, %r16, %r3;
    cvt.u64.u32 %rd6, %r8;
    shl.b32 %r21, %r16, 31;
    add.s64 %rd6, %rd6, %rd6;
    shl.b32 %r11, %r3, 1;
    setp.lt.u32 %p3, %r19, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
