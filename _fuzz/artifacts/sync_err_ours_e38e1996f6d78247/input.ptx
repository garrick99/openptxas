.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r22, %r3, 65535;
    and.b32 %r13, %r22, %r22;
    cvt.s64.s32 %rd11, %r3;
    max.s32 %r21, %r3, %r22;
    shr.u32 %r6, %r3, 1;
    mad.lo.s32 %r26, %r3, %r22, %r13;
    shr.s64 %rd7, %rd11, 1;
    mul.lo.u32 %r23, %r6, %r22;
    mul.lo.s32 %r14, %r6, 3;
    cvt.s32.s64 %r18, %rd11;
    shr.s64 %rd9, %rd7, 48;
    min.u32 %r11, %r6, %r18;
    cvt.u32.u64 %r14, %rd11;
    min.u64 %rd12, %rd11, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
