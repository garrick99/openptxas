.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p2, %r3, %r3;
    @%p2 cvt.u64.u32 %rd14, %r3;
    mul.lo.u32 %r8, %r3, 7;
    shr.u32 %r14, %r8, 4;
    add.u32 %r5, %r3, %r14;
    min.s64 %rd10, %rd14, %rd14;
    and.b32 %r11, %r5, %r3;
    cvt.s64.s32 %rd15, %r14;
    selp.b32 %r22, %r11, %r5, %p2;
    add.s32 %r20, %r11, 7;
    min.u32 %r10, %r8, %r22;
    cvt.u32.u64 %r19, %rd15;
    cvt.s32.s64 %r15, %rd10;
    sub.s32 %r25, %r15, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
