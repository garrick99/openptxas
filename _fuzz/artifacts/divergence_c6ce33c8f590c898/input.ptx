.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    add.s64 %rd7, %rd8, %rd8;
    add.u32 %r9, %r3, 4;
    mul.wide.s32 %rd15, %r9, %r3;
    mul.lo.s64 %rd8, %rd7, %rd15;
    max.s32 %r22, %r3, %r9;
    add.s32 %r11, %r9, %r22;
    cvt.u32.u64 %r13, %rd15;
    shr.u32 %r25, %r22, 16;
    mad.lo.s32 %r6, %r9, %r25, %r22;
    mad.lo.u32 %r21, %r6, %r9, %r9;
    add.s32 %r20, %r25, %r9;
    max.s32 %r26, %r13, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
