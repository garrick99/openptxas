.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r11, %r3, 63;
    add.u32 %r9, %r3, %r11;
    mul.wide.u32 %rd6, %r3, %r9;
    sub.u32 %r17, %r9, 31;
    cvt.s32.s64 %r12, %rd6;
    mad.lo.s32 %r6, %r11, %r9, %r11;
    xor.b32 %r26, %r17, 7;
    shr.u32 %r8, %r11, 3;
    setp.ne.s32 %p3, %r6, 255;
    @%p3 max.u32 %r13, %r6, 0;
    xor.b32 %r15, %r9, 4;
    shl.b64 %rd6, %rd6, 4;
    mul.lo.s32 %r19, %r11, %r6;
    min.u64 %rd15, %rd6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
