.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r14, %r3, %r3;
    cvt.s64.s32 %rd11, %r14;
    mul.lo.u32 %r12, %r14, 16;
    xor.b64 %rd14, %rd11, %rd11;
    shl.b32 %r22, %r12, 4;
    shl.b64 %rd9, %rd14, 30;
    min.s64 %rd8, %rd14, %rd14;
    min.u32 %r10, %r22, %r14;
    shr.s32 %r5, %r12, 31;
    mul.lo.u32 %r4, %r22, %r14;
    mul.lo.u32 %r11, %r14, %r5;
    mad.lo.s32 %r13, %r14, %r11, %r5;
    sub.u32 %r17, %r22, 63;
    shr.s64 %rd9, %rd14, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
