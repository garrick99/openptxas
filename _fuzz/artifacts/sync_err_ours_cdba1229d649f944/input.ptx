.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p2, %r3, %r3;
    @%p2 shr.u32 %r25, %r3, 31;
    cvt.s64.s32 %rd15, %r3;
    add.s64 %rd7, %rd15, %rd15;
    mul.lo.u64 %rd15, %rd15, %rd15;
    shr.u32 %r10, %r3, 30;
    add.u32 %r23, %r3, %r10;
    min.s32 %r21, %r3, 65536;
    shr.s32 %r16, %r25, 31;
    or.b32 %r7, %r21, %r25;
    cvt.u64.u32 %rd9, %r25;
    selp.b32 %r18, %r21, %r10, %p2;
    shl.b64 %rd14, %rd15, 63;
    shl.b32 %r6, %r18, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
