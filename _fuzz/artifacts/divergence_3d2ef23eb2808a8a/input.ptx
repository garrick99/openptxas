.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r15, %r3, 16;
    setp.hs.u32 %p1, %r15, %r3;
    cvt.s64.s32 %rd7, %r15;
    min.s32 %r12, %r15, %r3;
    selp.b32 %r17, %r15, %r15, %p1;
    shl.b64 %rd8, %rd7, 3;
    setp.ge.s32 %p1, %r12, %r15;
    @%p1 and.b32 %r6, %r15, %r15;
    add.s64 %rd12, %rd7, %rd8;
    setp.eq.u32 %p3, %r6, %r17;
    setp.ne.s32 %p4, %r12, 0;
    @%p4 and.b32 %r23, %r12, 2;
    setp.ne.s32 %p1, %r3, 8;
    @!%p1 shr.s64 %rd9, %rd12, 62;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
