.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r22, %r3, 8;
    xor.b32 %r12, %r3, %r22;
    add.u32 %r4, %r12, 15;
    mul.lo.s32 %r24, %r22, %r4;
    mad.lo.u32 %r27, %r24, %r24, %r24;
    setp.le.s32 %p3, %r24, %r24;
    @!%p3 shr.s32 %r19, %r12, 31;
    add.u32 %r19, %r24, %r19;
    cvt.u64.u32 %rd9, %r27;
    selp.b32 %r12, %r24, %r4, %p3;
    add.s32 %r26, %r12, 16;
    selp.b32 %r11, %r12, %r22, %p3;
    min.u32 %r12, %r11, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
