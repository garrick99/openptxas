.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    setp.eq.u32 %p4, %r3, %r3;
    cvt.s32.s64 %r21, %rd12;
    max.s32 %r5, %r21, 15;
    mul.wide.s32 %rd12, %r5, %r5;
    mul.lo.u32 %r26, %r3, %r21;
    mad.lo.s32 %r11, %r3, %r21, %r21;
    add.s32 %r4, %r21, 5;
    min.s32 %r12, %r3, %r4;
    shr.u64 %rd9, %rd12, 2;
    add.u32 %r5, %r3, 8;
    sub.u64 %rd13, %rd9, %rd12;
    mad.lo.s32 %r16, %r4, %r4, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
