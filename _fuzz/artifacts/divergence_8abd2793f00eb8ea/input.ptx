.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    add.u32 %r13, %r3, %r3;
    mul.lo.u32 %r26, %r3, %r3;
    min.u64 %rd10, %rd5, %rd5;
    mul.wide.s32 %rd8, %r3, %r26;
    mul.lo.u32 %r20, %r26, %r13;
    min.u32 %r4, %r20, %r13;
    mul.wide.u32 %rd13, %r13, %r3;
    mul.lo.u32 %r12, %r26, 32;
    setp.hs.u32 %p3, %r4, %r12;
    @!%p3 cvt.s32.s64 %r12, %rd10;
    xor.b64 %rd8, %rd10, %rd8;
    add.s64 %rd6, %rd13, %rd8;
    mad.lo.u32 %r9, %r26, %r4, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
