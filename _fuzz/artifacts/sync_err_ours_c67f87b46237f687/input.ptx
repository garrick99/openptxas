.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r11, %r3, 5;
    max.u32 %r5, %r3, %r11;
    or.b32 %r10, %r11, %r5;
    sub.s32 %r22, %r5, %r11;
    add.s32 %r24, %r3, 1;
    mul.wide.u32 %rd10, %r5, %r5;
    cvt.u64.u32 %rd14, %r3;
    shl.b32 %r23, %r24, 15;
    add.s32 %r13, %r3, 1;
    shr.s64 %rd8, %rd14, 33;
    max.u64 %rd8, %rd8, %rd8;
    add.s32 %r11, %r22, %r24;
    max.u32 %r23, %r13, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
