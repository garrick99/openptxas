.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r18, %r3, %r3;
    mad.lo.u32 %r24, %r18, %r18, %r3;
    mul.wide.s32 %rd5, %r18, %r24;
    mad.lo.s32 %r23, %r18, %r24, %r18;
    xor.b32 %r11, %r24, 8;
    min.s32 %r8, %r24, 5;
    min.u32 %r26, %r3, %r24;
    min.s32 %r17, %r18, 64;
    mul.wide.s32 %rd10, %r8, %r18;
    cvt.s64.s32 %rd5, %r23;
    min.s64 %rd5, %rd10, %rd10;
    add.s32 %r26, %r17, 4;
    sub.u32 %r27, %r8, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
