.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r24, %r3, 5;
    cvt.s64.s32 %rd5, %r24;
    sub.u32 %r9, %r24, 31;
    shl.b64 %rd14, %rd5, 33;
    sub.s32 %r5, %r9, 4;
    sub.u64 %rd13, %rd5, %rd14;
    mul.wide.s32 %rd9, %r9, %r24;
    mul.lo.u32 %r10, %r3, 63;
    shr.s32 %r16, %r10, 1;
    mul.lo.u32 %r9, %r3, 4294967295;
    mul.lo.u32 %r12, %r3, 65535;
    min.s32 %r22, %r16, %r3;
    min.u32 %r16, %r24, %r9;
    setp.lt.s32 %p2, %r12, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
