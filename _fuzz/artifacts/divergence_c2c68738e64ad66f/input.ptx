.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    shl.b32 %r13, %r3, 2;
    max.s32 %r10, %r13, %r13;
    min.s32 %r21, %r10, %r3;
    min.s32 %r8, %r3, 0;
    mul.wide.s32 %rd13, %r10, %r8;
    setp.ne.s32 %p3, %r21, 7;
    mad.lo.s32 %r7, %r13, %r3, %r13;
    cvt.s32.s64 %r7, %rd13;
    shr.u32 %r6, %r7, 7;
    max.s32 %r8, %r10, %r21;
    cvt.s32.s64 %r6, %rd13;
    mul.lo.s32 %r9, %r6, %r10;
    setp.gt.s32 %p4, %r3, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
