.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r11, %r3, %r3;
    max.u32 %r7, %r3, %r3;
    mul.lo.s32 %r5, %r7, %r7;
    max.u32 %r19, %r5, %r3;
    shl.b32 %r21, %r11, 2;
    setp.hi.u32 %p4, %r5, %r21;
    @%p4 cvt.u64.u32 %rd5, %r5;
    sub.u32 %r23, %r5, %r21;
    shr.s64 %rd7, %rd5, 4;
    shr.u32 %r9, %r19, 0;
    cvt.s32.s64 %r24, %rd5;
    selp.b32 %r7, %r3, %r5, %p4;
    selp.b32 %r14, %r5, %r23, %p4;
    selp.b32 %r18, %r24, %r5, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
