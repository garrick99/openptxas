.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r16, %r3, %r3, %r3;
    max.u32 %r21, %r3, %r3;
    cvt.s64.s32 %rd9, %r3;
    shr.s32 %r8, %r21, 3;
    min.s32 %r21, %r16, %r3;
    or.b32 %r20, %r3, 5;
    setp.ne.s32 %p1, %r8, %r8;
    mul.lo.u32 %r17, %r8, 1;
    max.s64 %rd10, %rd9, %rd9;
    max.s64 %rd9, %rd9, %rd10;
    mad.lo.u32 %r24, %r21, %r21, %r16;
    cvt.s32.s64 %r11, %rd9;
    and.b32 %r10, %r24, 0;
    mad.lo.s32 %r19, %r16, %r17, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
