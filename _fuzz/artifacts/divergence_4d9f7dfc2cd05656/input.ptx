.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p1, %r3, 65535;
    @!%p1 xor.b32 %r11, %r3, 1;
    cvt.s64.s32 %rd9, %r11;
    selp.b32 %r17, %r3, %r11, %p1;
    shr.u64 %rd7, %rd9, 15;
    mul.lo.u32 %r26, %r3, 1;
    cvt.s32.s64 %r8, %rd7;
    shr.s32 %r19, %r11, 3;
    mad.lo.u32 %r11, %r3, %r26, %r17;
    add.u32 %r5, %r3, %r26;
    cvt.u64.u32 %rd13, %r8;
    cvt.u32.u64 %r18, %rd9;
    cvt.s64.s32 %rd10, %r3;
    shr.u64 %rd11, %rd7, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
