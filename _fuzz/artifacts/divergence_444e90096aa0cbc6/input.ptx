.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd7, %r3, %r3;
    min.u32 %r16, %r3, %r3;
    add.s32 %r5, %r16, 64;
    shr.s64 %rd10, %rd7, 3;
    mul.lo.u64 %rd5, %rd10, %rd7;
    xor.b32 %r18, %r3, %r3;
    shr.u32 %r16, %r3, 1;
    mul.wide.u32 %rd15, %r16, %r5;
    max.u64 %rd10, %rd15, %rd5;
    and.b32 %r21, %r3, %r3;
    cvt.u32.u64 %r4, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
