.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    setp.lt.s32 %p2, %r3, %r3;
    mul.wide.s32 %rd10, %r3, %r3;
    mul.lo.s64 %rd6, %rd10, %rd10;
    mul.lo.u32 %r18, %r3, 32;
    max.u32 %r7, %r3, 63;
    selp.b32 %r20, %r3, %r3, %p2;
    add.u64 %rd7, %rd11, %rd10;
    mul.lo.s32 %r11, %r3, 2147483647;
    add.u32 %r11, %r11, 2;
    sub.u32 %r9, %r11, %r7;
    mul.lo.u32 %r14, %r20, %r18;
    setp.ne.u32 %p2, %r14, %r18;
    @%p2 add.u32 %r6, %r9, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
