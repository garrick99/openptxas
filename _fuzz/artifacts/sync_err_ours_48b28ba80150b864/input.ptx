.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p3, %r3, 4294967295;
    cvt.s64.s32 %rd14, %r3;
    and.b32 %r10, %r3, %r3;
    mad.lo.u32 %r8, %r3, %r10, %r3;
    min.u64 %rd5, %rd14, %rd14;
    mul.wide.u32 %rd13, %r10, %r8;
    cvt.u32.u64 %r7, %rd5;
    setp.le.s32 %p4, %r10, 15;
    cvt.s64.s32 %rd7, %r7;
    shl.b32 %r17, %r3, 4;
    min.u32 %r6, %r8, %r8;
    shl.b64 %rd6, %rd7, 4;
    mad.lo.s32 %r15, %r17, %r6, %r10;
    max.s32 %r26, %r8, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
