.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    shl.b64 %rd12, %rd13, 0;
    cvt.s32.s64 %r19, %rd12;
    min.s32 %r8, %r19, %r19;
    sub.s32 %r4, %r3, 63;
    min.u32 %r4, %r19, 3;
    max.s32 %r16, %r8, %r8;
    sub.s32 %r24, %r16, 16;
    or.b32 %r4, %r3, %r24;
    xor.b32 %r27, %r3, 32;
    add.s64 %rd12, %rd12, %rd12;
    add.u64 %rd7, %rd12, %rd13;
    mul.wide.u32 %rd12, %r16, %r4;
    setp.ge.u32 %p2, %r24, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
