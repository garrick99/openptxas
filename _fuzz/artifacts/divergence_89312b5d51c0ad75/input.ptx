.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    shr.s64 %rd15, %rd11, 47;
    add.s32 %r8, %r3, %r3;
    cvt.s32.s64 %r16, %rd11;
    and.b32 %r14, %r8, %r16;
    shr.s32 %r25, %r8, 31;
    sub.s32 %r4, %r3, 4;
    max.s32 %r18, %r16, 7;
    shl.b64 %rd6, %rd11, 16;
    xor.b32 %r16, %r8, %r3;
    mad.lo.s32 %r11, %r8, %r8, %r25;
    mul.wide.u32 %rd11, %r8, %r16;
    setp.eq.s32 %p4, %r18, %r14;
    selp.b32 %r4, %r4, %r11, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
