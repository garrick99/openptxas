.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p4, %r3, 4;
    @!%p4 add.s32 %r13, %r3, %r3;
    cvt.u64.u32 %rd10, %r3;
    shl.b32 %r5, %r3, 2;
    xor.b32 %r6, %r13, 7;
    shr.u64 %rd13, %rd10, 16;
    sub.u32 %r12, %r13, 4;
    min.u32 %r4, %r13, 15;
    cvt.u32.u64 %r13, %rd10;
    mul.wide.u32 %rd7, %r5, %r12;
    cvt.s32.s64 %r15, %rd13;
    add.u32 %r22, %r4, 31;
    shl.b64 %rd13, %rd13, 48;
    add.s32 %r17, %r13, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
