.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r27, %r3, 4;
    cvt.s64.s32 %rd15, %r27;
    shl.b32 %r16, %r27, 7;
    min.s32 %r16, %r3, %r16;
    xor.b32 %r18, %r3, 31;
    mul.wide.s32 %rd12, %r27, %r3;
    shr.u32 %r11, %r16, 4;
    sub.s32 %r18, %r16, 32;
    setp.gt.u32 %p3, %r27, %r16;
    and.b64 %rd11, %rd12, %rd15;
    selp.b32 %r23, %r27, %r27, %p3;
    shl.b32 %r26, %r16, 30;
    cvt.s32.s64 %r15, %rd11;
    min.s32 %r19, %r27, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
