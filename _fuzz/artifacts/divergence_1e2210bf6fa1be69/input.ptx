.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r20, %r3, %r3;
    setp.le.s32 %p4, %r3, %r20;
    selp.b32 %r4, %r20, %r3, %p4;
    shl.b32 %r16, %r3, 30;
    and.b32 %r4, %r4, 65535;
    setp.gt.s32 %p3, %r16, %r3;
    @%p3 selp.b32 %r24, %r16, %r4, %p4;
    selp.b32 %r26, %r24, %r20, %p3;
    selp.b32 %r25, %r20, %r24, %p3;
    mul.wide.s32 %rd10, %r26, %r25;
    add.u32 %r13, %r4, %r24;
    shl.b64 %rd12, %rd10, 2;
    shl.b32 %r16, %r26, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
