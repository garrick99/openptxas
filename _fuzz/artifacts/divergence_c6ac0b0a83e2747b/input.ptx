.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p4, %r3, 65536;
    @!%p4 selp.b32 %r18, %r3, %r3, %p4;
    cvt.s64.s32 %rd9, %r3;
    or.b32 %r9, %r3, %r3;
    min.u64 %rd13, %rd9, %rd9;
    mad.lo.u32 %r6, %r18, %r18, %r9;
    shr.s32 %r27, %r9, 0;
    shr.u64 %rd5, %rd13, 7;
    add.u32 %r5, %r18, 8;
    add.s32 %r16, %r18, %r9;
    mul.wide.u32 %rd6, %r6, %r3;
    shl.b32 %r12, %r3, 7;
    max.s32 %r21, %r6, 32;
    sub.s32 %r18, %r21, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
