.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    mul.wide.u32 %rd8, %r3, %r3;
    max.u32 %r21, %r3, %r3;
    cvt.u32.u64 %r19, %rd13;
    mul.lo.u64 %rd5, %rd13, %rd13;
    max.u64 %rd7, %rd13, %rd8;
    shr.s64 %rd6, %rd7, 4;
    add.u32 %r19, %r21, %r19;
    setp.gt.s32 %p1, %r3, 31;
    @%p1 mad.lo.u32 %r23, %r19, %r3, %r21;
    mul.lo.s64 %rd5, %rd13, %rd5;
    mul.wide.u32 %rd14, %r19, %r21;
    min.u32 %r19, %r19, 32;
    min.s32 %r27, %r23, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
