.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r25, %r3, 31;
    min.s32 %r11, %r3, %r3;
    shr.u32 %r22, %r3, 2;
    add.s32 %r25, %r3, 1;
    add.u32 %r22, %r25, 2147483648;
    max.u32 %r22, %r25, %r25;
    cvt.u64.u32 %rd10, %r3;
    mad.lo.u32 %r16, %r22, %r25, %r22;
    shl.b32 %r7, %r3, 0;
    mul.lo.s32 %r8, %r22, 4294967295;
    setp.le.s32 %p1, %r8, %r3;
    @!%p1 shr.s64 %rd8, %rd10, 62;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
