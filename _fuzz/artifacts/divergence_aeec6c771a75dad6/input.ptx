.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r12, %r3, 7;
    min.u32 %r22, %r12, %r3;
    and.b32 %r8, %r3, 65535;
    shr.u32 %r23, %r3, 3;
    shr.s32 %r26, %r23, 3;
    mul.wide.s32 %rd15, %r12, %r3;
    shl.b64 %rd7, %rd15, 4;
    setp.gt.s32 %p1, %r8, %r23;
    setp.le.u32 %p2, %r12, 8;
    @%p2 shr.s32 %r20, %r26, 15;
    add.s32 %r8, %r22, %r12;
    cvt.s64.s32 %rd10, %r3;
    shr.s32 %r6, %r12, 15;
    selp.b32 %r8, %r20, %r8, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
