.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r5, %r3, 4294967295;
    mul.wide.u32 %rd13, %r5, %r5;
    sub.s32 %r21, %r5, 32;
    cvt.u32.u64 %r18, %rd13;
    shr.s32 %r27, %r3, 0;
    setp.le.s32 %p3, %r3, %r27;
    @%p3 min.u32 %r17, %r27, %r3;
    shr.s32 %r24, %r5, 2;
    setp.eq.s32 %p3, %r18, %r24;
    setp.lt.s32 %p3, %r3, %r5;
    @!%p3 mad.lo.u32 %r13, %r3, %r5, %r21;
    add.u64 %rd7, %rd13, %rd13;
    sub.s64 %rd10, %rd13, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
