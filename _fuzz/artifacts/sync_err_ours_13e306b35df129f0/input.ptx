.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    min.u32 %r8, %r3, 255;
    cvt.s64.s32 %rd12, %r3;
    min.s32 %r21, %r3, %r3;
    shr.s64 %rd8, %rd12, 30;
    and.b32 %r19, %r21, %r3;
    shl.b64 %rd10, %rd8, 63;
    sub.u32 %r25, %r3, %r3;
    max.s32 %r7, %r3, %r25;
    shr.s64 %rd6, %rd10, 31;
    setp.lt.s32 %p1, %r19, %r21;
    @%p1 add.u32 %r10, %r19, 16;
    setp.ge.s32 %p2, %r25, 5;
    cvt.u64.u32 %rd15, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
