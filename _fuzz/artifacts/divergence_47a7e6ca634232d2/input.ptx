.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    add.u32 %r16, %r3, 3;
    add.u32 %r8, %r16, 2147483648;
    setp.ge.u32 %p1, %r8, 4;
    and.b32 %r10, %r3, 1;
    mul.wide.u32 %rd14, %r10, %r3;
    min.u32 %r20, %r3, 2;
    cvt.s32.s64 %r22, %rd6;
    cvt.u64.u32 %rd10, %r22;
    setp.hs.u32 %p4, %r16, 32;
    @%p4 selp.b32 %r5, %r16, %r10, %p1;
    sub.s32 %r6, %r8, %r20;
    sub.u32 %r20, %r6, 4;
    mul.lo.s32 %r12, %r20, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
