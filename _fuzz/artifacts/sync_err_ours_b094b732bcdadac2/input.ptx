.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    setp.ge.s32 %p3, %r3, 5;
    @%p3 max.u32 %r12, %r3, 2147483648;
    max.u32 %r21, %r3, %r12;
    or.b64 %rd15, %rd7, %rd7;
    shr.s64 %rd12, %rd7, 47;
    xor.b32 %r17, %r3, %r21;
    shr.s32 %r22, %r17, 4;
    shr.u64 %rd6, %rd7, 1;
    min.s64 %rd6, %rd6, %rd7;
    max.u32 %r21, %r3, %r22;
    cvt.u32.u64 %r11, %rd6;
    cvt.u32.u64 %r20, %rd15;
    sub.s32 %r19, %r21, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
