.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    max.s32 %r7, %r3, %r3;
    shr.u64 %rd6, %rd5, 1;
    shr.u64 %rd15, %rd5, 3;
    max.u32 %r4, %r7, %r7;
    shr.u64 %rd14, %rd5, 4;
    shr.u32 %r15, %r4, 4;
    setp.ne.s32 %p2, %r4, 0;
    @%p2 or.b32 %r20, %r7, 64;
    shr.u32 %r27, %r7, 15;
    shr.s32 %r11, %r15, 31;
    add.u32 %r22, %r7, 1;
    setp.gt.u32 %p4, %r27, 256;
    @%p4 mul.wide.s32 %rd8, %r15, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
