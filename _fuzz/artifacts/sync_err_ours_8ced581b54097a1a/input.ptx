.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r7, %r3, 8;
    cvt.s64.s32 %rd15, %r7;
    mul.wide.s32 %rd15, %r7, %r3;
    mad.lo.u32 %r9, %r7, %r7, %r3;
    setp.ge.s32 %p4, %r7, %r3;
    or.b64 %rd8, %rd15, %rd15;
    sub.s32 %r26, %r9, %r7;
    cvt.u32.u64 %r9, %rd8;
    selp.b32 %r22, %r3, %r7, %p4;
    add.s32 %r17, %r3, %r22;
    mul.lo.s64 %rd9, %rd15, %rd15;
    selp.b32 %r24, %r3, %r26, %p4;
    mul.wide.u32 %rd13, %r3, %r26;
    min.s64 %rd12, %rd9, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
