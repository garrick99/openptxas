    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r8, %r3, %r3, %r3;
    min.u32 %r18, %r8, 65535;
    mul.wide.u32 %rd13, %r18, %r3;
    add.s32 %r26, %r18, 2147483647;
    max.u64 %rd11, %rd13, %rd13;
    cvt.s64.s32 %rd6, %r26;
    and.b32 %r17, %r3, 65535;
    mul.wide.s32 %rd9, %r18, %r17;
    cvt.s64.s32 %rd5, %r17;
    setp.lt.u32 %p4, %r17, 5;
    @%p4 shl.b32 %r25, %r17, 15;
    cvt.u64.u32 %rd13, %r18;
    ld.param.u64 %rd3, [p_out];
