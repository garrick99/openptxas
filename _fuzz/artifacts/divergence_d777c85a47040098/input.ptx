.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r17, %r3, %r3;
    cvt.s64.s32 %rd11, %r17;
    cvt.s32.s64 %r16, %rd11;
    mul.wide.u32 %rd8, %r16, %r17;
    setp.eq.u32 %p3, %r17, 3;
    @%p3 selp.b32 %r19, %r17, %r16, %p3;
    min.u32 %r22, %r19, %r19;
    mul.wide.u32 %rd14, %r22, %r19;
    xor.b32 %r7, %r3, %r3;
    shl.b32 %r17, %r16, 3;
    mul.lo.u64 %rd6, %rd11, %rd8;
    mul.lo.u32 %r16, %r19, %r16;
    shr.u32 %r22, %r22, 0;
    selp.b32 %r24, %r3, %r19, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
