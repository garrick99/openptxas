.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p4, %r3, %r3;
    max.s32 %r24, %r3, %r3;
    or.b32 %r18, %r24, 16;
    sub.u32 %r20, %r3, %r24;
    and.b32 %r23, %r18, 7;
    max.u32 %r20, %r18, 16;
    mad.lo.s32 %r6, %r18, %r24, %r18;
    mul.lo.s32 %r4, %r24, %r6;
    sub.s32 %r26, %r24, 63;
    sub.s32 %r22, %r23, 4;
    sub.u32 %r15, %r20, %r6;
    cvt.s64.s32 %rd13, %r3;
    xor.b32 %r14, %r3, 7;
    min.u32 %r10, %r23, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
