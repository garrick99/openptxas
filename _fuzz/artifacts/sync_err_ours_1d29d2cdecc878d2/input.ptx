.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r16, %r3, 63;
    cvt.u64.u32 %rd7, %r3;
    max.s32 %r17, %r16, %r16;
    add.s64 %rd13, %rd7, %rd7;
    setp.eq.s32 %p4, %r16, 1;
    @%p4 mul.lo.u32 %r13, %r16, %r17;
    and.b32 %r13, %r3, 256;
    shr.s32 %r10, %r13, 0;
    xor.b32 %r25, %r16, %r3;
    min.u32 %r14, %r13, 2147483648;
    setp.lt.u32 %p4, %r17, %r3;
    @%p4 or.b32 %r11, %r17, 16;
    xor.b32 %r17, %r3, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
