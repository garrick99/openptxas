.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p2, %r3, 255;
    @!%p2 shr.s32 %r18, %r3, 16;
    xor.b32 %r18, %r3, 64;
    mad.lo.u32 %r21, %r3, %r3, %r18;
    mul.wide.s32 %rd12, %r18, %r3;
    or.b32 %r8, %r18, 65536;
    add.s32 %r24, %r18, 63;
    selp.b32 %r8, %r3, %r24, %p2;
    add.u32 %r10, %r24, %r24;
    mul.wide.s32 %rd12, %r18, %r24;
    xor.b32 %r16, %r18, 3;
    setp.eq.u32 %p1, %r10, 16;
    setp.lt.s32 %p2, %r24, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
