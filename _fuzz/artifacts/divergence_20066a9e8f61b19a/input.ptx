.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r20, %r3, 32;
    cvt.u64.u32 %rd13, %r3;
    cvt.s32.s64 %r9, %rd13;
    mul.lo.u32 %r8, %r9, %r3;
    xor.b32 %r10, %r9, %r20;
    shr.s32 %r22, %r20, 1;
    mad.lo.s32 %r21, %r3, %r20, %r22;
    add.u32 %r15, %r10, 255;
    mul.lo.s32 %r7, %r20, %r21;
    sub.s32 %r10, %r7, 5;
    min.u32 %r10, %r7, %r21;
    shr.u64 %rd7, %rd13, 3;
    sub.s32 %r24, %r10, %r20;
    min.u32 %r11, %r3, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
