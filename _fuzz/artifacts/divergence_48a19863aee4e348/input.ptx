.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    min.u32 %r13, %r3, %r3;
    xor.b32 %r18, %r3, 2;
    and.b32 %r14, %r13, %r13;
    setp.ne.s32 %p2, %r18, 2;
    @!%p2 min.s32 %r10, %r3, 65536;
    max.u64 %rd14, %rd6, %rd6;
    add.s32 %r14, %r18, 3;
    mul.wide.u32 %rd11, %r10, %r14;
    sub.u32 %r27, %r3, %r10;
    min.s32 %r9, %r10, %r3;
    selp.b32 %r23, %r13, %r18, %p2;
    setp.ls.u32 %p4, %r10, 64;
    @!%p4 xor.b32 %r5, %r18, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
