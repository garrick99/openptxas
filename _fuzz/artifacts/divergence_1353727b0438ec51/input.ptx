.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    add.u32 %r27, %r3, 2;
    min.u32 %r10, %r3, 5;
    cvt.u64.u32 %rd13, %r3;
    max.u32 %r18, %r3, %r10;
    add.u32 %r23, %r27, %r3;
    cvt.u64.u32 %rd15, %r23;
    or.b32 %r15, %r27, 1;
    sub.u32 %r16, %r10, 63;
    shr.s64 %rd6, %rd13, 48;
    min.s32 %r5, %r10, 31;
    setp.lt.s32 %p4, %r5, 3;
    @!%p4 min.u64 %rd7, %rd15, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
