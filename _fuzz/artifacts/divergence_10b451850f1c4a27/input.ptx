.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r8, %r3, %r3;
    cvt.s64.s32 %rd8, %r8;
    mul.wide.u32 %rd11, %r3, %r8;
    sub.u32 %r19, %r3, 32;
    max.s32 %r16, %r19, %r19;
    min.s32 %r21, %r16, 8;
    shl.b32 %r21, %r19, 1;
    and.b32 %r16, %r16, %r19;
    xor.b64 %rd11, %rd8, %rd8;
    and.b32 %r13, %r3, %r21;
    min.s32 %r12, %r8, 256;
    or.b32 %r25, %r3, %r12;
    add.s32 %r10, %r12, %r21;
    shr.u64 %rd13, %rd11, 47;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
