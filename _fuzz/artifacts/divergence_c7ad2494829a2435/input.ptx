.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r15, %r3, 255;
    mul.lo.s32 %r8, %r15, %r3;
    max.s32 %r15, %r8, %r8;
    mul.wide.u32 %rd13, %r8, %r8;
    max.s32 %r20, %r15, %r8;
    setp.lt.s32 %p4, %r20, 4294967295;
    sub.u32 %r14, %r20, 65536;
    sub.s64 %rd15, %rd13, %rd13;
    mul.lo.u32 %r8, %r8, 8;
    sub.s64 %rd8, %rd13, %rd15;
    or.b32 %r10, %r14, %r8;
    selp.b32 %r17, %r8, %r8, %p4;
    or.b32 %r8, %r3, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
