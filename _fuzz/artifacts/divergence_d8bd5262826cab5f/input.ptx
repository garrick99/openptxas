.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r19, %r3, %r3;
    or.b32 %r14, %r19, %r3;
    max.s32 %r25, %r14, %r3;
    max.u32 %r24, %r25, 8;
    sub.u32 %r6, %r25, %r25;
    cvt.s64.s32 %rd7, %r14;
    max.s64 %rd5, %rd7, %rd7;
    sub.s32 %r13, %r24, 16;
    add.u64 %rd14, %rd5, %rd7;
    and.b32 %r18, %r14, %r19;
    or.b64 %rd10, %rd5, %rd5;
    min.u64 %rd5, %rd14, %rd7;
    min.s32 %r10, %r3, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
