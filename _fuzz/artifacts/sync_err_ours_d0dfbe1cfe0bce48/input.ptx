.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r4, %r3, 7;
    or.b32 %r27, %r3, %r3;
    sub.s32 %r13, %r3, 4294967295;
    shr.u32 %r12, %r4, 0;
    shl.b32 %r9, %r4, 2;
    max.s32 %r25, %r13, %r9;
    cvt.u64.u32 %rd10, %r25;
    max.u32 %r26, %r13, %r13;
    shl.b32 %r18, %r9, 4;
    sub.s32 %r7, %r25, 0;
    add.s32 %r6, %r13, %r4;
    mad.lo.u32 %r26, %r4, %r26, %r9;
    min.u32 %r27, %r6, %r12;
    shl.b32 %r17, %r9, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
