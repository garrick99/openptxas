.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r4, %r3, 16;
    setp.le.s32 %p3, %r4, 32;
    @%p3 cvt.s64.s32 %rd7, %r3;
    add.u32 %r6, %r4, 256;
    cvt.s32.s64 %r11, %rd7;
    shr.u64 %rd10, %rd7, 48;
    max.s32 %r27, %r3, 31;
    shr.s32 %r13, %r4, 4;
    shl.b32 %r13, %r6, 0;
    cvt.u32.u64 %r20, %rd7;
    xor.b32 %r15, %r6, %r11;
    setp.le.u32 %p3, %r13, %r6;
    @%p3 mad.lo.u32 %r23, %r11, %r13, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
