.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r6, %r3, %r3;
    shl.b32 %r7, %r6, 4;
    mul.wide.u32 %rd13, %r6, %r7;
    cvt.u32.u64 %r21, %rd13;
    cvt.s32.s64 %r17, %rd13;
    shr.u64 %rd12, %rd13, 62;
    setp.lo.u32 %p1, %r7, %r17;
    @%p1 shr.s32 %r7, %r3, 2;
    mad.lo.u32 %r20, %r21, %r7, %r3;
    sub.u32 %r12, %r21, %r3;
    xor.b64 %rd8, %rd13, %rd13;
    setp.ge.s32 %p2, %r20, 0;
    @!%p2 max.u32 %r6, %r21, %r12;
    and.b32 %r12, %r17, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
