.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    sub.u32 %r5, %r3, 31;
    max.u32 %r8, %r3, %r5;
    add.u32 %r15, %r8, %r5;
    shl.b32 %r4, %r15, 15;
    shl.b32 %r6, %r3, 0;
    sub.u32 %r27, %r4, %r6;
    cvt.u32.u64 %r4, %rd6;
    min.u32 %r11, %r15, %r5;
    shr.s32 %r16, %r6, 4;
    mul.wide.s32 %rd12, %r8, %r11;
    max.u32 %r5, %r6, %r16;
    min.s64 %rd10, %rd6, %rd12;
    mul.lo.s32 %r4, %r5, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
