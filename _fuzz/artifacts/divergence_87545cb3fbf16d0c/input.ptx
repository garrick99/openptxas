.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p3, %r3, 32;
    @%p3 mul.wide.u32 %rd6, %r3, %r3;
    shr.u32 %r6, %r3, 0;
    cvt.s32.s64 %r10, %rd6;
    mul.lo.u64 %rd10, %rd6, %rd6;
    sub.s32 %r24, %r10, 8;
    cvt.u32.u64 %r18, %rd10;
    mad.lo.s32 %r20, %r24, %r6, %r3;
    setp.gt.s32 %p3, %r18, 2;
    xor.b32 %r19, %r10, 2;
    and.b32 %r14, %r3, 3;
    max.u32 %r24, %r24, 4;
    max.s32 %r20, %r14, 255;
    cvt.u32.u64 %r26, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
