.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    min.s32 %r16, %r3, 2147483648;
    sub.s32 %r4, %r3, %r16;
    add.s32 %r11, %r16, 4294967295;
    shl.b32 %r6, %r3, 4;
    sub.s32 %r24, %r6, 7;
    mul.wide.u32 %rd15, %r6, %r16;
    max.u32 %r24, %r16, %r6;
    setp.hs.u32 %p4, %r3, %r6;
    mul.lo.u64 %rd9, %rd6, %rd6;
    min.s32 %r21, %r11, 8;
    shr.s64 %rd14, %rd9, 3;
    sub.s32 %r16, %r6, %r6;
    xor.b32 %r27, %r6, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
