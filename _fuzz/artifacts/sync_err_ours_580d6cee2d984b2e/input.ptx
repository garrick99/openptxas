.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    shl.b32 %r9, %r3, 16;
    sub.s32 %r10, %r3, 2;
    mad.lo.u32 %r9, %r3, %r10, %r10;
    max.u32 %r14, %r10, %r10;
    add.u32 %r16, %r14, %r3;
    mad.lo.u32 %r5, %r3, %r9, %r10;
    shl.b32 %r8, %r14, 16;
    mul.wide.s32 %rd12, %r16, %r8;
    shr.s32 %r17, %r14, 0;
    or.b64 %rd10, %rd13, %rd13;
    cvt.u64.u32 %rd10, %r17;
    add.s64 %rd5, %rd12, %rd13;
    setp.lt.s32 %p1, %r8, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
