.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.down.b32 %r18, %r3, 4, 0x1f, -1;
    shfl.sync.down.b32 %r7, %r0, 16, 0x1f, -1;
    setp.le.u32 %p1, %r3, 255;
    vote.sync.ballot.b32 %r19, %p1, -1;
    sub.u32 %r13, %r0, %r3;
    add.u32 %r7, %r3, %r18;
    shfl.sync.down.b32 %r12, %r0, 4, 0x1f, -1;
    shfl.sync.bfly.b32 %r19, %r7, 8, 0x1f, -1;
    vote.sync.all.pred %p3, %p1, -1;
    setp.lt.u32 %p1, %r13, 16;
    vote.sync.ballot.b32 %r5, %p1, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
