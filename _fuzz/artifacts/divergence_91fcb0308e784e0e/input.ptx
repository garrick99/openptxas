.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r15, %r3, 255;
    max.u32 %r20, %r15, %r3;
    shr.u32 %r18, %r20, 2;
    mul.wide.u32 %rd11, %r15, %r18;
    max.u32 %r18, %r18, %r18;
    and.b64 %rd9, %rd11, %rd11;
    mul.lo.s32 %r7, %r3, 2;
    setp.gt.s32 %p3, %r20, %r7;
    min.u32 %r13, %r18, 7;
    shr.s32 %r17, %r18, 1;
    max.u32 %r17, %r15, %r18;
    min.u32 %r8, %r3, %r7;
    max.s32 %r4, %r20, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
