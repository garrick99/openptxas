.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r6, %r3, 3;
    add.u32 %r22, %r6, 31;
    shr.u32 %r9, %r6, 4;
    cvt.s64.s32 %rd15, %r9;
    shl.b32 %r27, %r22, 7;
    mad.lo.s32 %r23, %r22, %r3, %r22;
    max.u32 %r7, %r9, %r27;
    min.s32 %r23, %r23, %r6;
    mul.wide.s32 %rd15, %r6, %r3;
    shl.b32 %r10, %r6, 7;
    sub.s32 %r11, %r6, 63;
    setp.ls.u32 %p4, %r11, %r22;
    shl.b32 %r23, %r9, 31;
    shl.b32 %r22, %r22, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
