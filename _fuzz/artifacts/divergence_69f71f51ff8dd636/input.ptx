.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r10, %r3, %r3;
    cvt.s64.s32 %rd8, %r3;
    add.s32 %r20, %r3, %r3;
    sub.s32 %r14, %r20, 4;
    setp.ne.s32 %p4, %r3, 31;
    @%p4 cvt.u64.u32 %rd5, %r20;
    shl.b64 %rd5, %rd5, 16;
    add.u32 %r21, %r10, %r10;
    mul.wide.s32 %rd12, %r3, %r20;
    and.b32 %r16, %r10, 65536;
    sub.u64 %rd10, %rd5, %rd5;
    shl.b32 %r7, %r20, 0;
    max.u32 %r6, %r16, 2147483648;
    mad.lo.s32 %r27, %r6, %r14, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
