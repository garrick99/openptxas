    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r10, %r3, 4294967295;
    mul.wide.u32 %rd6, %r3, %r10;
    add.s64 %rd15, %rd6, %rd6;
    shr.s32 %r19, %r3, 31;
