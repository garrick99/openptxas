.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    shr.s32 %r12, %r3, 0;
    add.s32 %r26, %r12, 7;
    setp.lt.s32 %p1, %r12, %r3;
    @!%p1 max.u32 %r21, %r3, 255;
    setp.lo.u32 %p2, %r3, 4;
    @%p2 selp.b32 %r12, %r12, %r26, %p2;
    sub.s32 %r24, %r26, 1;
    sub.s32 %r25, %r12, %r24;
    shr.u32 %r7, %r26, 16;
    mul.lo.s64 %rd10, %rd13, %rd13;
    sub.s32 %r8, %r12, %r26;
    shr.u64 %rd13, %rd10, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
