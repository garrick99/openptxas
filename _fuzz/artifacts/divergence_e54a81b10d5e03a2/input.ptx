.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r10, %r3, 64;
    cvt.s64.s32 %rd9, %r10;
    cvt.s64.s32 %rd5, %r10;
    max.u32 %r12, %r3, %r3;
    setp.lt.u32 %p3, %r12, 63;
    @%p3 add.s32 %r20, %r12, 2147483647;
    cvt.u64.u32 %rd14, %r3;
    sub.s32 %r9, %r3, %r10;
    cvt.s32.s64 %r14, %rd9;
    mul.wide.u32 %rd9, %r10, %r12;
    xor.b32 %r8, %r3, %r10;
    selp.b32 %r14, %r10, %r20, %p3;
    shr.s32 %r11, %r20, 15;
    shr.u32 %r25, %r14, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
