.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p2, %r3, 15;
    @!%p2 cvt.u64.u32 %rd8, %r3;
    or.b32 %r25, %r3, %r3;
    max.s64 %rd11, %rd8, %rd8;
    setp.eq.u32 %p4, %r25, %r25;
    @%p4 mul.wide.s32 %rd6, %r3, %r25;
    mul.lo.s32 %r13, %r25, %r3;
    cvt.s32.s64 %r19, %rd8;
    and.b32 %r5, %r13, 4294967295;
    cvt.u32.u64 %r25, %rd11;
    cvt.u64.u32 %rd7, %r5;
    add.s32 %r12, %r3, %r3;
    cvt.u64.u32 %rd9, %r3;
    and.b32 %r15, %r5, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
