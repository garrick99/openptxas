.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    add.s32 %r15, %r3, 4;
    mul.lo.s32 %r27, %r15, %r3;
    mul.wide.u32 %rd12, %r3, %r27;
    mul.wide.s32 %rd5, %r3, %r27;
    and.b32 %r21, %r15, %r15;
    and.b32 %r9, %r3, %r21;
    mul.lo.u64 %rd14, %rd15, %rd5;
    mul.lo.u32 %r23, %r3, 3;
    shl.b64 %rd12, %rd5, 15;
    shr.u32 %r24, %r3, 31;
    sub.u32 %r25, %r27, %r9;
    xor.b32 %r25, %r23, %r21;
    cvt.s32.s64 %r19, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
