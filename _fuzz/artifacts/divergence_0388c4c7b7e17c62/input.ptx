.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p3, %r3, %r3;
    @%p3 mad.lo.s32 %r7, %r3, %r3, %r3;
    shr.s32 %r17, %r7, 30;
    max.u32 %r12, %r7, %r3;
    add.s32 %r4, %r7, %r17;
    shr.s32 %r25, %r4, 16;
    max.u32 %r16, %r3, %r4;
    shr.u32 %r5, %r7, 2;
    mul.lo.s32 %r25, %r25, %r5;
    mad.lo.u32 %r21, %r7, %r3, %r12;
    shl.b32 %r22, %r4, 1;
    shr.s32 %r13, %r12, 31;
    shr.u32 %r7, %r22, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
