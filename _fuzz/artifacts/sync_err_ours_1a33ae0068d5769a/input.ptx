.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r27, %r3, %r3, %r3;
    shr.u32 %r12, %r27, 4;
    cvt.u64.u32 %rd6, %r27;
    min.s64 %rd10, %rd6, %rd6;
    cvt.u32.u64 %r27, %rd10;
    max.u32 %r5, %r12, 2147483647;
    shl.b32 %r15, %r27, 16;
    shl.b64 %rd14, %rd6, 16;
    sub.u32 %r14, %r15, 4;
    xor.b32 %r23, %r12, %r5;
    add.u64 %rd10, %rd10, %rd14;
    mul.lo.s64 %rd15, %rd6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
