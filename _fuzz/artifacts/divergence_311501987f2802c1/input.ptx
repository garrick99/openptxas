.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r16, %r3, 4;
    setp.lt.u32 %p4, %r16, 16;
    @!%p4 cvt.s64.s32 %rd15, %r16;
    cvt.s32.s64 %r26, %rd15;
    max.u64 %rd12, %rd15, %rd15;
    setp.lt.u32 %p3, %r3, 64;
    @%p3 min.u32 %r18, %r3, %r26;
    mad.lo.u32 %r7, %r3, %r18, %r18;
    add.u32 %r14, %r18, %r7;
    min.u32 %r8, %r16, 64;
    add.u64 %rd13, %rd12, %rd12;
    sub.s32 %r24, %r7, %r18;
    shr.s64 %rd10, %rd12, 7;
    or.b32 %r6, %r16, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
