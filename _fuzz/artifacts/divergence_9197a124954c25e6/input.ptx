.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd9, %r3, %r3;
    max.s64 %rd8, %rd9, %rd9;
    mad.lo.u32 %r20, %r3, %r3, %r3;
    shr.s32 %r25, %r3, 4;
    min.s32 %r22, %r25, %r3;
    or.b32 %r5, %r25, 65536;
    setp.eq.s32 %p4, %r3, 2147483647;
    @%p4 xor.b64 %rd15, %rd8, %rd9;
    shl.b64 %rd13, %rd8, 62;
    or.b32 %r6, %r3, 65535;
    mul.lo.s32 %r6, %r22, %r20;
    setp.ls.u32 %p1, %r25, 256;
    @%p1 max.s32 %r5, %r20, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
