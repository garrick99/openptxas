.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r19, %r3, %r3, %r3;
    mul.wide.s32 %rd13, %r3, %r19;
    setp.eq.s32 %p3, %r19, %r3;
    @!%p3 and.b32 %r11, %r3, %r19;
    min.s32 %r23, %r11, 64;
    sub.s32 %r14, %r19, %r19;
    cvt.u64.u32 %rd9, %r19;
    min.u32 %r15, %r23, 255;
    sub.s32 %r9, %r19, 16;
    max.s32 %r14, %r15, %r19;
    shr.s64 %rd13, %rd13, 16;
    shr.s32 %r26, %r11, 2;
    xor.b64 %rd11, %rd9, %rd13;
    sub.u64 %rd10, %rd9, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
