.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    or.b32 %r21, %r3, %r3;
    cvt.u32.u64 %r10, %rd5;
    max.s32 %r24, %r10, %r3;
    cvt.u64.u32 %rd9, %r21;
    mul.wide.u32 %rd15, %r21, %r21;
    or.b32 %r27, %r24, %r24;
    sub.s64 %rd14, %rd5, %rd15;
    setp.ne.s32 %p4, %r21, 15;
    @!%p4 cvt.s32.s64 %r15, %rd15;
    xor.b32 %r7, %r10, %r24;
    min.s32 %r4, %r7, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
