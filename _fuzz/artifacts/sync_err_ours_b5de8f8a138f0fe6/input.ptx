.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    cvt.s64.s32 %rd8, %r3;
    shr.s32 %r18, %r3, 0;
    setp.lt.u32 %p4, %r3, %r18;
    min.u64 %rd5, %rd15, %rd8;
    mul.wide.s32 %rd10, %r3, %r18;
    and.b32 %r27, %r3, %r18;
    setp.lt.s32 %p2, %r18, 7;
    @%p2 cvt.u32.u64 %r18, %rd8;
    mul.lo.s32 %r19, %r27, 0;
    setp.hs.u32 %p1, %r3, %r18;
    @%p1 xor.b32 %r24, %r27, 31;
    max.u32 %r13, %r24, %r24;
    max.s64 %rd10, %rd10, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
