.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r19, %r3, %r3, %r3;
    setp.ge.u32 %p3, %r3, %r3;
    shl.b32 %r5, %r3, 16;
    add.u32 %r12, %r19, 31;
    sub.s32 %r21, %r5, 15;
    selp.b32 %r10, %r19, %r5, %p3;
    sub.u32 %r9, %r19, 63;
    selp.b32 %r23, %r19, %r10, %p3;
    setp.lo.u32 %p2, %r19, %r19;
    @%p2 max.u32 %r15, %r21, 65536;
    cvt.u64.u32 %rd12, %r21;
    mul.wide.u32 %rd14, %r15, %r19;
    and.b32 %r16, %r12, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
