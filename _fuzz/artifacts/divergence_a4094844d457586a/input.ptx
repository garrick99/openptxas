.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r26, %r3, 2147483648;
    mad.lo.u32 %r23, %r26, %r3, %r26;
    cvt.s64.s32 %rd11, %r23;
    add.s32 %r9, %r26, %r3;
    shr.s64 %rd14, %rd11, 33;
    shl.b32 %r25, %r9, 31;
    setp.ne.u32 %p3, %r9, 5;
    setp.gt.u32 %p4, %r23, 65536;
    @!%p4 max.s32 %r11, %r9, 8;
    mul.lo.s32 %r24, %r25, %r11;
    add.u32 %r9, %r26, %r9;
    selp.b32 %r18, %r9, %r26, %p4;
    mad.lo.u32 %r5, %r25, %r18, %r11;
    cvt.s64.s32 %rd12, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
