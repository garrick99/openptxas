.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    sub.s32 %r5, %r3, %r3;
    max.u32 %r15, %r5, %r3;
    mad.lo.s32 %r17, %r5, %r3, %r5;
    shr.s32 %r20, %r3, 0;
    and.b32 %r26, %r17, 255;
    shr.s32 %r23, %r17, 16;
    and.b32 %r5, %r23, %r3;
    setp.le.u32 %p3, %r23, 3;
    @!%p3 shl.b64 %rd14, %rd9, 7;
    setp.ne.u32 %p4, %r3, 63;
    add.s32 %r19, %r15, 31;
    cvt.s32.s64 %r12, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
