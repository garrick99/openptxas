.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r24, %r3, 2;
    or.b32 %r8, %r24, %r24;
    mul.wide.s32 %rd7, %r3, %r3;
    min.s32 %r10, %r8, 65535;
    shr.s32 %r11, %r8, 1;
    sub.u32 %r8, %r11, %r10;
    setp.le.u32 %p4, %r10, 2;
    @%p4 min.u32 %r14, %r11, 3;
    xor.b32 %r19, %r3, %r3;
    setp.ge.s32 %p3, %r19, %r14;
    @%p3 mad.lo.u32 %r17, %r10, %r24, %r24;
    cvt.u64.u32 %rd8, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
