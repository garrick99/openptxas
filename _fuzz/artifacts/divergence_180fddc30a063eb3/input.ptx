.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r24, %r3, 4294967295;
    sub.s32 %r11, %r3, 8;
    max.s32 %r24, %r11, 1;
    or.b32 %r6, %r3, %r3;
    cvt.u64.u32 %rd14, %r24;
    cvt.u64.u32 %rd10, %r6;
    mul.lo.u64 %rd7, %rd14, %rd14;
    min.u32 %r22, %r11, 8;
    xor.b32 %r17, %r6, 5;
    or.b32 %r20, %r6, %r6;
    max.u32 %r12, %r3, %r20;
    add.s32 %r13, %r17, %r12;
    add.s32 %r22, %r12, %r13;
    mul.lo.s64 %rd8, %rd14, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
