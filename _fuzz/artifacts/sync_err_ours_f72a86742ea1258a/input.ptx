.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r7, %r3, 2;
    shr.u32 %r4, %r3, 4;
    min.s32 %r8, %r7, 15;
    mul.wide.s32 %rd12, %r8, %r7;
    sub.u32 %r14, %r4, %r3;
    xor.b32 %r9, %r4, %r4;
    min.u64 %rd15, %rd12, %rd12;
    mad.lo.s32 %r19, %r3, %r4, %r9;
    cvt.u64.u32 %rd12, %r19;
    mul.wide.u32 %rd11, %r8, %r19;
    shl.b32 %r7, %r3, 2;
    mad.lo.u32 %r12, %r7, %r3, %r19;
    mul.wide.s32 %rd11, %r12, %r8;
    mul.wide.u32 %rd8, %r19, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
