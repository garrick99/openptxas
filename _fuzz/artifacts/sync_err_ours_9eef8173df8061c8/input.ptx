.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p1, %r3, 3;
    cvt.u64.u32 %rd10, %r3;
    cvt.s32.s64 %r8, %rd10;
    selp.b32 %r16, %r8, %r3, %p1;
    shr.s64 %rd13, %rd10, 15;
    cvt.u64.u32 %rd13, %r16;
    shr.u32 %r24, %r3, 16;
    add.u32 %r25, %r24, %r16;
    shl.b64 %rd6, %rd13, 4;
    add.u32 %r17, %r16, %r8;
    selp.b32 %r12, %r17, %r16, %p1;
    or.b32 %r24, %r16, 65535;
    sub.s32 %r14, %r16, %r12;
    add.s32 %r19, %r16, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
