.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    shr.s64 %rd12, %rd12, 33;
    mad.lo.s32 %r18, %r3, %r3, %r3;
    shr.u32 %r20, %r18, 30;
    shl.b32 %r19, %r18, 0;
    shr.u32 %r19, %r3, 30;
    add.u32 %r24, %r19, %r18;
    max.s32 %r20, %r20, 65535;
    setp.lt.s32 %p1, %r24, 31;
    min.s32 %r20, %r20, %r24;
    cvt.u64.u32 %rd8, %r19;
    setp.gt.s32 %p3, %r20, 16;
    or.b32 %r6, %r18, %r18;
    max.u64 %rd7, %rd8, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
