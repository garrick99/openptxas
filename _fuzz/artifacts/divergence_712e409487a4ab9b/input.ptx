.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r17, %r3, 31;
    setp.gt.u32 %p4, %r17, %r3;
    cvt.s64.s32 %rd8, %r3;
    setp.ge.s32 %p2, %r3, %r17;
    shr.u32 %r27, %r17, 7;
    mad.lo.s32 %r24, %r27, %r27, %r17;
    add.s32 %r9, %r17, %r27;
    mad.lo.u32 %r23, %r17, %r27, %r9;
    cvt.s64.s32 %rd5, %r27;
    sub.s32 %r18, %r17, %r3;
    mul.wide.s32 %rd8, %r24, %r27;
    and.b32 %r7, %r9, %r23;
    mul.wide.u32 %rd5, %r3, %r23;
    shl.b64 %rd5, %rd8, 47;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
