.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r19, %r3, 30;
    cvt.u64.u32 %rd11, %r3;
    mul.wide.s32 %rd13, %r3, %r19;
    mul.wide.u32 %rd15, %r3, %r3;
    max.u32 %r7, %r3, 255;
    cvt.s64.s32 %rd8, %r19;
    min.u64 %rd12, %rd8, %rd15;
    cvt.s32.s64 %r13, %rd12;
    shr.s32 %r16, %r3, 7;
    setp.eq.s32 %p4, %r19, 64;
    @%p4 mad.lo.s32 %r7, %r19, %r3, %r7;
    max.u32 %r9, %r16, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
