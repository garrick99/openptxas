.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r21, %r3, %r3;
    shl.b32 %r6, %r3, 30;
    setp.gt.s32 %p2, %r21, %r6;
    @%p2 cvt.u64.u32 %rd15, %r6;
    mul.lo.s32 %r23, %r3, %r6;
    shr.u64 %rd10, %rd15, 4;
    max.s64 %rd9, %rd10, %rd15;
    cvt.s32.s64 %r25, %rd15;
    min.u32 %r21, %r21, %r23;
    mul.wide.s32 %rd14, %r25, %r6;
    add.s32 %r23, %r3, %r3;
    and.b32 %r20, %r23, %r25;
    cvt.s64.s32 %rd10, %r6;
    cvt.u64.u32 %rd5, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
