.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    cvt.u64.u32 %rd7, %r3;
    cvt.s32.s64 %r10, %rd7;
    shr.u32 %r9, %r3, 31;
    add.s32 %r6, %r3, %r10;
    mad.lo.u32 %r18, %r3, %r6, %r9;
    mul.lo.s32 %r11, %r10, %r6;
    cvt.s64.s32 %rd15, %r9;
    add.s64 %rd15, %rd5, %rd15;
    add.s32 %r19, %r18, 15;
    sub.u32 %r20, %r10, %r3;
    shr.u32 %r13, %r18, 16;
    setp.eq.s32 %p2, %r18, %r18;
    @!%p2 selp.b32 %r25, %r9, %r6, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
