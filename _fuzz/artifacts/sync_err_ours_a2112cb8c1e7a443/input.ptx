.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r17, %r3, 1;
    sub.s32 %r11, %r17, 63;
    add.u32 %r6, %r3, 1;
    mul.wide.s32 %rd9, %r3, %r11;
    min.u32 %r4, %r6, 2147483647;
    shl.b64 %rd10, %rd9, 63;
    add.s32 %r13, %r4, %r11;
    setp.ls.u32 %p3, %r17, 31;
    @!%p3 mul.wide.s32 %rd14, %r11, %r11;
    xor.b32 %r14, %r4, 8;
    sub.u32 %r19, %r4, %r6;
    mul.wide.s32 %rd13, %r19, %r19;
    mad.lo.u32 %r14, %r19, %r6, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
