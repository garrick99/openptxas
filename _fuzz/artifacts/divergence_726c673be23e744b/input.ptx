.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    cvt.u32.u64 %r6, %rd6;
    cvt.s32.s64 %r8, %rd6;
    mul.wide.s32 %rd10, %r8, %r6;
    mad.lo.u32 %r15, %r8, %r8, %r6;
    min.s64 %rd10, %rd10, %rd10;
    shl.b32 %r15, %r8, 7;
    sub.s32 %r12, %r6, 4;
    mul.lo.s32 %r4, %r6, %r15;
    add.s32 %r25, %r6, %r4;
    and.b32 %r6, %r6, %r6;
    mul.lo.s32 %r23, %r15, 65536;
    max.u64 %rd5, %rd10, %rd6;
    cvt.u64.u32 %rd8, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
