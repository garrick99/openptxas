.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r17, %r3, %r3;
    sub.s32 %r21, %r3, %r3;
    min.u32 %r15, %r3, %r3;
    sub.u32 %r14, %r21, %r21;
    cvt.u64.u32 %rd12, %r14;
    mul.lo.u32 %r5, %r21, %r21;
    cvt.u32.u64 %r18, %rd12;
    shr.u32 %r10, %r18, 1;
    mul.lo.u64 %rd11, %rd12, %rd12;
    shl.b64 %rd6, %rd11, 30;
    add.s32 %r17, %r3, %r21;
    min.u32 %r13, %r15, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
