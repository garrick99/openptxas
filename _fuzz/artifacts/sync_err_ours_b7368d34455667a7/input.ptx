.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r4, %r3, 5;
    cvt.s64.s32 %rd7, %r4;
    max.u32 %r14, %r3, %r3;
    mul.wide.u32 %rd5, %r4, %r4;
    cvt.s32.s64 %r6, %rd7;
    mul.lo.s32 %r25, %r14, 8;
    max.u32 %r11, %r6, 16;
    cvt.s32.s64 %r12, %rd7;
    shr.u64 %rd11, %rd7, 15;
    add.u32 %r26, %r3, %r25;
    mad.lo.u32 %r25, %r12, %r11, %r6;
    mul.wide.u32 %rd8, %r4, %r26;
    xor.b32 %r11, %r25, %r3;
    and.b32 %r26, %r26, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
