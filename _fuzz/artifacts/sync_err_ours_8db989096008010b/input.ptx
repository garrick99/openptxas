.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r24, %r3, %r3;
    cvt.s64.s32 %rd11, %r24;
    cvt.u32.u64 %r24, %rd11;
    sub.s32 %r27, %r3, %r3;
    shl.b32 %r27, %r24, 0;
    mul.wide.u32 %rd13, %r3, %r24;
    mad.lo.s32 %r20, %r24, %r24, %r24;
    mul.lo.u32 %r24, %r20, 31;
    min.s32 %r5, %r24, %r20;
    max.s32 %r19, %r20, 5;
    setp.le.s32 %p4, %r24, 65536;
    shr.u32 %r10, %r20, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
