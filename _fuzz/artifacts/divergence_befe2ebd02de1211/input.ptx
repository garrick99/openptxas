.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r9, %r3, 32;
    shr.u32 %r18, %r9, 15;
    cvt.s64.s32 %rd7, %r3;
    mad.lo.u32 %r12, %r9, %r9, %r3;
    shr.s64 %rd11, %rd7, 33;
    shl.b64 %rd13, %rd7, 33;
    mad.lo.s32 %r7, %r9, %r9, %r3;
    sub.s32 %r10, %r18, 8;
    xor.b64 %rd14, %rd7, %rd11;
    cvt.u64.u32 %rd5, %r12;
    mul.wide.u32 %rd9, %r12, %r18;
    mul.wide.u32 %rd6, %r10, %r7;
    setp.hi.u32 %p3, %r7, %r10;
    @%p3 selp.b32 %r26, %r10, %r10, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
