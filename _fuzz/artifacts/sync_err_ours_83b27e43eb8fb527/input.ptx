.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r16, %r3, 2;
    mul.lo.u32 %r11, %r16, 2147483648;
    mul.wide.u32 %rd11, %r16, %r11;
    cvt.u32.u64 %r5, %rd11;
    cvt.u32.u64 %r19, %rd11;
    mul.wide.u32 %rd14, %r3, %r16;
    mul.wide.u32 %rd15, %r5, %r11;
    mul.wide.u32 %rd10, %r16, %r5;
    sub.u64 %rd9, %rd11, %rd10;
    mad.lo.u32 %r13, %r5, %r19, %r16;
    cvt.s64.s32 %rd11, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
