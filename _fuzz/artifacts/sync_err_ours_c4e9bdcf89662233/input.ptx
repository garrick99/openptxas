    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r13, %r3, 2147483647;
    add.u32 %r26, %r3, %r13;
    mul.wide.u32 %rd6, %r3, %r3;
    min.u32 %r13, %r26, %r13;
    shl.b64 %rd12, %rd6, 7;
    shr.s64 %rd14, %rd6, 62;
    add.u32 %r4, %r3, %r3;
