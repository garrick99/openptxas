.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p3, %r3, 32;
    @!%p3 shr.s32 %r9, %r3, 16;
    mul.wide.s32 %rd8, %r9, %r3;
    max.u32 %r13, %r3, %r9;
    and.b32 %r19, %r13, 2;
    mad.lo.s32 %r6, %r9, %r3, %r19;
    max.u32 %r21, %r6, %r9;
    mul.wide.u32 %rd13, %r6, %r13;
    selp.b32 %r16, %r6, %r19, %p3;
    or.b32 %r21, %r3, 2147483647;
    shr.s64 %rd13, %rd13, 32;
    cvt.s32.s64 %r23, %rd13;
    max.u32 %r27, %r6, %r3;
    mul.lo.s32 %r20, %r23, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
