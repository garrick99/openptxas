.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p3, %r3, 3;
    cvt.s64.s32 %rd11, %r3;
    selp.b32 %r21, %r3, %r3, %p3;
    sub.u64 %rd6, %rd11, %rd11;
    sub.s64 %rd15, %rd11, %rd11;
    cvt.u32.u64 %r9, %rd11;
    and.b32 %r27, %r21, %r3;
    add.u32 %r26, %r9, %r27;
    mul.lo.s32 %r19, %r3, 65536;
    sub.u32 %r7, %r27, %r27;
    sub.u64 %rd10, %rd6, %rd15;
    cvt.s32.s64 %r11, %rd6;
    add.u32 %r21, %r19, 3;
    cvt.u32.u64 %r20, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
