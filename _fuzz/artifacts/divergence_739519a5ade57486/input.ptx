.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r18, %r3, 2;
    mad.lo.s32 %r22, %r18, %r18, %r18;
    shr.u32 %r22, %r18, 7;
    setp.lo.u32 %p3, %r18, 8;
    @!%p3 min.u32 %r12, %r18, 2;
    or.b32 %r11, %r18, 256;
    sub.u32 %r22, %r22, 15;
    selp.b32 %r9, %r22, %r11, %p3;
    and.b32 %r12, %r12, 5;
    mul.lo.u32 %r10, %r9, 4;
    add.u32 %r16, %r18, %r10;
    cvt.u64.u32 %rd15, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
