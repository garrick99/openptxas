.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    cvt.u64.u32 %rd5, %r3;
    max.u64 %rd15, %rd14, %rd14;
    shr.s32 %r11, %r3, 16;
    mad.lo.s32 %r16, %r3, %r3, %r11;
    shr.s32 %r25, %r3, 4;
    and.b32 %r26, %r11, %r25;
    shl.b64 %rd6, %rd5, 31;
    shr.s64 %rd5, %rd14, 0;
    setp.lo.u32 %p3, %r3, %r11;
    mul.lo.u32 %r22, %r16, %r26;
    cvt.u32.u64 %r21, %rd15;
    max.s32 %r19, %r25, 2;
    selp.b32 %r13, %r22, %r3, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
