.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r25, %r3, %r3;
    setp.gt.s32 %p1, %r25, %r3;
    @!%p1 add.u32 %r21, %r25, 4;
    cvt.u64.u32 %rd9, %r25;
    shr.s64 %rd11, %rd9, 0;
    cvt.u32.u64 %r19, %rd11;
    xor.b64 %rd7, %rd9, %rd9;
    shr.u32 %r17, %r25, 1;
    mul.lo.s32 %r13, %r3, %r21;
    cvt.u64.u32 %rd8, %r25;
    add.u32 %r26, %r25, 1;
    shr.s64 %rd7, %rd11, 48;
    max.u32 %r26, %r3, %r19;
    add.s32 %r26, %r21, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
