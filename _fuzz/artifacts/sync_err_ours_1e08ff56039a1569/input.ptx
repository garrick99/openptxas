.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r12, %r3, 16;
    mul.wide.u32 %rd7, %r3, %r3;
    shl.b32 %r26, %r3, 7;
    shr.s64 %rd8, %rd7, 63;
    and.b32 %r23, %r3, %r3;
    mad.lo.u32 %r14, %r26, %r3, %r3;
    cvt.u64.u32 %rd7, %r23;
    shr.s32 %r14, %r3, 7;
    add.s32 %r16, %r14, 65535;
    cvt.s64.s32 %rd9, %r14;
    cvt.s32.s64 %r21, %rd9;
    shl.b32 %r17, %r3, 16;
    mul.wide.u32 %rd11, %r26, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
