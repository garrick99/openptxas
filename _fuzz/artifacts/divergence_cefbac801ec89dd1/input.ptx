.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r21, %r3, 3;
    shr.s32 %r24, %r3, 4;
    mul.lo.u32 %r18, %r3, %r3;
    mul.lo.s32 %r19, %r3, %r3;
    shr.s32 %r26, %r19, 0;
    mad.lo.s32 %r27, %r19, %r18, %r18;
    setp.le.u32 %p4, %r19, 32;
    @%p4 mad.lo.u32 %r4, %r18, %r3, %r27;
    mul.wide.s32 %rd8, %r21, %r4;
    sub.u32 %r11, %r18, %r19;
    max.s32 %r24, %r27, %r26;
    and.b32 %r20, %r4, 65536;
    mul.wide.s32 %rd7, %r18, %r19;
    mul.lo.s32 %r5, %r27, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
