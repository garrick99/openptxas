    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r17, %r3, %r3;
    add.s32 %r9, %r17, 7;
    mul.lo.s32 %r27, %r17, 2147483648;
    cvt.u64.u32 %rd8, %r27;
    mad.lo.u32 %r9, %r3, %r27, %r17;
    min.s32 %r20, %r27, %r17;
    shr.u32 %r10, %r3, 7;
    sub.u32 %r27, %r3, %r17;
    mul.wide.u32 %rd15, %r9, %r20;
    sub.u32 %r4, %r10, 5;
    cvt.s64.s32 %rd8, %r20;
    shl.b32 %r16, %r20, 0;
    mul.lo.s32 %r23, %r17, %r16;
    max.u32 %r11, %r17, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
