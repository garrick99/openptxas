.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r11, %r3, %r3;
    max.s32 %r14, %r11, 0;
    cvt.u64.u32 %rd11, %r3;
    max.s32 %r6, %r14, 64;
    mad.lo.s32 %r13, %r14, %r3, %r6;
    cvt.u64.u32 %rd15, %r6;
    min.s32 %r24, %r14, 4294967295;
    or.b32 %r25, %r11, %r11;
    min.u64 %rd13, %rd15, %rd11;
    max.u32 %r20, %r3, %r11;
    sub.u32 %r7, %r3, %r14;
    shl.b32 %r19, %r3, 4;
    add.s32 %r12, %r11, %r14;
    mul.wide.u32 %rd15, %r6, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
