.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r18, %r3, 4;
    cvt.u64.u32 %rd13, %r3;
    xor.b32 %r12, %r18, %r18;
    xor.b32 %r6, %r18, 63;
    sub.s32 %r12, %r18, %r12;
    setp.lt.s32 %p2, %r18, %r3;
    setp.lo.u32 %p4, %r6, 7;
    @%p4 sub.u32 %r4, %r12, 3;
    add.s64 %rd5, %rd13, %rd13;
    min.u32 %r11, %r18, 64;
    sub.s32 %r26, %r6, 31;
    mad.lo.s32 %r19, %r12, %r12, %r11;
    max.s32 %r7, %r3, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
