.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r13, %r3, 15;
    setp.lt.u32 %p4, %r3, %r13;
    @!%p4 cvt.s64.s32 %rd12, %r3;
    shl.b64 %rd13, %rd12, 7;
    mul.lo.u32 %r16, %r3, %r3;
    selp.b32 %r22, %r3, %r3, %p4;
    shr.s64 %rd8, %rd13, 0;
    cvt.u32.u64 %r15, %rd8;
    sub.s32 %r27, %r13, %r3;
    shr.u32 %r10, %r3, 3;
    max.u32 %r18, %r15, %r22;
    mul.wide.s32 %rd6, %r15, %r3;
    shr.s32 %r24, %r13, 15;
    mul.lo.s32 %r5, %r15, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
