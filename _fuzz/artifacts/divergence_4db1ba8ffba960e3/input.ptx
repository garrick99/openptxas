.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r26, %r3, 31;
    mul.lo.u32 %r19, %r26, %r3;
    xor.b32 %r25, %r26, %r26;
    mul.lo.s32 %r8, %r26, 4294967295;
    mad.lo.u32 %r11, %r25, %r25, %r8;
    cvt.s64.s32 %rd14, %r11;
    or.b32 %r11, %r11, 7;
    cvt.u64.u32 %rd13, %r8;
    min.u64 %rd11, %rd13, %rd13;
    mul.wide.s32 %rd14, %r8, %r8;
    add.s32 %r16, %r11, 32;
    mul.wide.u32 %rd12, %r16, %r25;
    min.s32 %r14, %r26, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
