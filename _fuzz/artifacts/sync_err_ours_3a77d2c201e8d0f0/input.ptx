.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    mul.lo.s32 %r17, %r3, 4;
    mul.lo.s64 %rd10, %rd15, %rd15;
    cvt.u64.u32 %rd14, %r17;
    shl.b64 %rd8, %rd14, 31;
    sub.s32 %r24, %r3, 3;
    add.u32 %r4, %r17, %r17;
    sub.u32 %r4, %r24, %r4;
    mad.lo.u32 %r4, %r24, %r24, %r24;
    add.s32 %r11, %r4, %r24;
    or.b32 %r12, %r17, 5;
    shr.u64 %rd9, %rd15, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
