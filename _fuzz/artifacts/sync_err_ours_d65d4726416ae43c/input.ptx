.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r16, %r3, %r3, %r3;
    setp.gt.u32 %p4, %r3, %r16;
    @%p4 selp.b32 %r24, %r16, %r3, %p4;
    cvt.s64.s32 %rd14, %r16;
    max.s32 %r10, %r24, 31;
    max.s32 %r23, %r3, 4294967295;
    shr.s32 %r19, %r10, 16;
    min.s64 %rd11, %rd14, %rd14;
    selp.b32 %r24, %r24, %r16, %p4;
    max.u64 %rd5, %rd11, %rd14;
    max.s32 %r8, %r23, 65536;
    mad.lo.s32 %r27, %r16, %r23, %r23;
    selp.b32 %r25, %r24, %r19, %p4;
    setp.hs.u32 %p4, %r10, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
