.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r11, %r3, %r3;
    setp.le.s32 %p2, %r11, 3;
    @!%p2 min.u32 %r10, %r3, %r11;
    setp.gt.s32 %p2, %r10, %r10;
    @!%p2 mul.lo.u32 %r25, %r3, %r10;
    setp.eq.s32 %p1, %r3, %r25;
    @!%p1 mad.lo.s32 %r21, %r3, %r11, %r3;
    cvt.u64.u32 %rd6, %r10;
    selp.b32 %r15, %r11, %r10, %p1;
    mul.lo.u64 %rd11, %rd6, %rd6;
    mad.lo.u32 %r10, %r11, %r11, %r11;
    add.s32 %r11, %r25, %r21;
    mul.wide.s32 %rd8, %r3, %r25;
    add.s32 %r21, %r25, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
