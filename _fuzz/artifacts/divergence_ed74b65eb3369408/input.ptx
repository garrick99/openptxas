.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r10, %r3, %r3, %r3;
    min.s32 %r25, %r10, 31;
    cvt.s64.s32 %rd11, %r3;
    max.u32 %r21, %r3, %r25;
    max.s32 %r14, %r10, %r3;
    add.s32 %r9, %r21, 7;
    mul.lo.u32 %r18, %r3, %r9;
    shr.u64 %rd7, %rd11, 62;
    shr.s32 %r4, %r21, 7;
    setp.lt.s32 %p4, %r14, 16;
    @%p4 shr.s64 %rd13, %rd7, 63;
    setp.lt.s32 %p1, %r9, 64;
    @!%p1 add.s32 %r7, %r25, %r18;
    shr.s32 %r9, %r21, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
