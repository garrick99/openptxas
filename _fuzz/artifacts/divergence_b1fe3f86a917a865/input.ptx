.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    cvt.s64.s32 %rd12, %r3;
    mad.lo.u32 %r18, %r3, %r3, %r3;
    shl.b64 %rd10, %rd13, 30;
    and.b64 %rd14, %rd10, %rd13;
    mul.lo.u32 %r20, %r3, %r3;
    add.s32 %r24, %r18, 256;
    shr.u64 %rd12, %rd13, 48;
    shr.u64 %rd12, %rd13, 30;
    sub.u32 %r9, %r24, %r3;
    shr.s32 %r5, %r9, 31;
    mad.lo.u32 %r14, %r9, %r3, %r5;
    max.u32 %r21, %r18, %r20;
    setp.eq.s32 %p4, %r24, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
