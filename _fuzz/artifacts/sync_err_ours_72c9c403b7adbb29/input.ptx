.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r7, %r3, 4;
    min.u32 %r11, %r3, 65535;
    mul.lo.s32 %r27, %r3, 255;
    shr.u32 %r16, %r7, 4;
    shr.s32 %r19, %r16, 16;
    cvt.s64.s32 %rd10, %r19;
    or.b32 %r13, %r7, %r11;
    cvt.s64.s32 %rd6, %r11;
    and.b32 %r10, %r19, %r11;
    max.s32 %r16, %r3, %r19;
    sub.u32 %r18, %r3, %r11;
    shr.s32 %r14, %r13, 15;
    shr.u64 %rd14, %rd10, 48;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
