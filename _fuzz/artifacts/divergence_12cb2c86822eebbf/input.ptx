.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    max.u32 %r21, %r3, 31;
    cvt.s32.s64 %r19, %rd10;
    shl.b32 %r21, %r19, 4;
    or.b32 %r12, %r21, 31;
    cvt.s32.s64 %r22, %rd10;
    sub.s32 %r11, %r19, %r22;
    sub.u32 %r17, %r11, 64;
    max.u64 %rd14, %rd10, %rd10;
    mul.lo.u32 %r16, %r11, 2;
    shl.b32 %r5, %r12, 7;
    setp.ls.u32 %p4, %r12, %r5;
    @%p4 mad.lo.s32 %r24, %r11, %r21, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
