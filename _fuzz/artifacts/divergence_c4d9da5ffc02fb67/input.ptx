.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r4, %r3, 4294967295;
    mul.lo.s32 %r16, %r4, 2147483647;
    shr.s32 %r27, %r3, 2;
    setp.lo.u32 %p1, %r27, %r4;
    mul.wide.s32 %rd6, %r27, %r3;
    and.b32 %r18, %r3, %r3;
    and.b32 %r23, %r16, 4294967295;
    shr.u32 %r11, %r27, 15;
    shl.b64 %rd11, %rd6, 15;
    shr.s32 %r9, %r4, 30;
    mul.wide.u32 %rd15, %r27, %r27;
    selp.b32 %r12, %r4, %r23, %p1;
    shr.s64 %rd12, %rd11, 48;
    setp.hs.u32 %p2, %r16, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
