.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r5, %r3, %r3;
    mul.wide.s32 %rd8, %r5, %r5;
    xor.b32 %r10, %r3, %r5;
    shr.s32 %r21, %r3, 0;
    max.u32 %r22, %r3, %r21;
    mad.lo.u32 %r25, %r3, %r10, %r3;
    shr.u64 %rd5, %rd8, 48;
    min.s64 %rd7, %rd5, %rd8;
    add.u32 %r10, %r21, 2147483647;
    add.u32 %r11, %r21, 63;
    mul.wide.s32 %rd12, %r5, %r21;
    max.u64 %rd12, %rd5, %rd7;
    mul.lo.u32 %r21, %r21, 5;
    and.b32 %r4, %r25, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
