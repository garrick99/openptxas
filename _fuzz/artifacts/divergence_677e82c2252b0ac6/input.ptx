.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r17, %r3, 30;
    setp.ne.u32 %p1, %r3, 4;
    mad.lo.s32 %r4, %r3, %r17, %r3;
    setp.eq.s32 %p4, %r17, %r4;
    @%p4 mul.wide.u32 %rd6, %r3, %r4;
    shl.b32 %r10, %r4, 3;
    mad.lo.s32 %r21, %r3, %r3, %r17;
    shr.u64 %rd10, %rd6, 62;
    shl.b32 %r26, %r3, 3;
    max.s32 %r19, %r17, %r26;
    min.s32 %r8, %r21, %r17;
    shr.s32 %r26, %r19, 7;
    cvt.s32.s64 %r10, %rd6;
    setp.le.u32 %p4, %r19, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
