.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r19, %r3, %r3, %r3;
    mad.lo.s32 %r23, %r19, %r19, %r3;
    cvt.s64.s32 %rd11, %r19;
    shr.s32 %r21, %r23, 30;
    mul.wide.u32 %rd13, %r19, %r21;
    cvt.u32.u64 %r6, %rd11;
    shr.u32 %r10, %r23, 31;
    sub.u32 %r20, %r6, %r21;
    sub.u32 %r6, %r19, %r20;
    mad.lo.u32 %r20, %r3, %r6, %r20;
    and.b64 %rd14, %rd11, %rd11;
    add.u64 %rd13, %rd14, %rd11;
    mul.lo.u32 %r7, %r21, %r10;
    min.s32 %r19, %r7, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
