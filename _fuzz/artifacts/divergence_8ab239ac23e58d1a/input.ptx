.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfi.b32 %r19, %r3, %r3, 0, 4;
    clz.b32 %r14, %r3;
    clz.b32 %r18, %r14;
    bfe.s32 %r23, %r14, 31, 8;
    bfe.s32 %r17, %r18, 24, 7;
    prmt.b32 %r9, %r18, %r18, 291;
    bfe.s32 %r7, %r3, 1, 16;
    bfe.u32 %r10, %r14, 31, 2;
    bfi.b32 %r20, %r17, %r10, 4, 7;
    bfe.s32 %r20, %r7, 24, 2;
    bfe.u32 %r10, %r20, 8, 2;
    bfe.u32 %r18, %r9, 24, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
