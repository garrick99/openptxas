.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    max.u32 %r18, %r3, 0;
    setp.hs.u32 %p2, %r3, 16;
    @%p2 sub.u32 %r6, %r18, %r3;
    and.b32 %r5, %r18, 15;
    min.u32 %r22, %r3, 0;
    shr.s64 %rd10, %rd10, 63;
    mul.lo.u64 %rd9, %rd10, %rd10;
    shl.b32 %r7, %r6, 16;
    mul.wide.u32 %rd9, %r18, %r5;
    max.s32 %r13, %r5, 5;
    max.u64 %rd8, %rd9, %rd9;
    cvt.s32.s64 %r13, %rd8;
    min.u32 %r13, %r6, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
