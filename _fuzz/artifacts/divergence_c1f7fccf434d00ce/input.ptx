    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r8, %r3, %r3;
    sub.u32 %r4, %r3, %r8;
    add.u32 %r10, %r8, 2;
    or.b32 %r5, %r8, %r3;
    shl.b32 %r22, %r3, 4;
    setp.lt.s32 %p3, %r3, %r3;
    @!%p3 cvt.s64.s32 %rd14, %r22;
    cvt.u64.u32 %rd7, %r10;
    sub.u32 %r27, %r10, 2147483648;
    mad.lo.u32 %r20, %r8, %r5, %r5;
    min.u32 %r21, %r4, 32;
    setp.gt.s32 %p1, %r21, 255;
    @%p1 sub.u32 %r12, %r27, %r20;
