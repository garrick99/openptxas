.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p3, %r3, %r3;
    @!%p3 cvt.s64.s32 %rd11, %r3;
    mul.lo.u32 %r15, %r3, 1;
    shl.b32 %r4, %r15, 16;
    selp.b32 %r7, %r15, %r4, %p3;
    mul.lo.u32 %r5, %r15, %r4;
    max.u32 %r12, %r5, 1;
    max.u32 %r14, %r4, %r15;
    or.b32 %r14, %r7, 64;
    shr.u64 %rd11, %rd11, 4;
    shr.s64 %rd8, %rd11, 1;
    shl.b64 %rd8, %rd11, 48;
    mul.lo.u64 %rd11, %rd8, %rd8;
    xor.b32 %r21, %r4, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
