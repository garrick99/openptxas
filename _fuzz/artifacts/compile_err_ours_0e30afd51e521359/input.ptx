.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r4, %r0, %r3;
    xor.b32 %r8, %r0, %r3;
    min.u32 %r12, %r3, %r4;
    setp.le.u32 %p3, %r8, %r3;
    vote.sync.ballot.b32 %r12, %p3, -1;
    add.u32 %r4, %r8, %r4;
    setp.gt.u32 %p2, %r4, 4294967295;
    vote.sync.ballot.b32 %r9, %p2, -1;
    vote.sync.all.pred %p3, %p2, -1;
    shfl.sync.bfly.b32 %r6, %r8, 4, 0x1f, -1;
    vote.sync.all.pred %p2, %p2, -1;
    max.u32 %r11, %r8, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
