.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p3, %r3, %r3;
    @%p3 xor.b32 %r16, %r3, %r3;
    shr.s32 %r5, %r16, 7;
    mad.lo.s32 %r5, %r5, %r5, %r16;
    xor.b32 %r24, %r3, %r16;
    add.u32 %r6, %r16, %r5;
    or.b32 %r8, %r3, 16;
    setp.lo.u32 %p3, %r6, %r24;
    @%p3 cvt.u64.u32 %rd13, %r5;
    and.b32 %r6, %r8, %r24;
    max.u32 %r16, %r3, %r5;
    min.u32 %r22, %r16, %r6;
    mul.wide.u32 %rd8, %r5, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
