.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r8, %r3, 16;
    shr.u32 %r26, %r8, 30;
    or.b32 %r25, %r8, %r3;
    max.s32 %r11, %r26, 15;
    setp.gt.u32 %p3, %r8, %r3;
    setp.ne.s32 %p4, %r25, %r25;
    setp.ge.s32 %p1, %r25, 0;
    @%p1 mul.lo.s32 %r4, %r26, %r3;
    min.s32 %r14, %r26, %r11;
    mul.wide.s32 %rd15, %r8, %r4;
    setp.ne.s32 %p3, %r26, 5;
    setp.le.s32 %p1, %r4, 4294967295;
    @!%p1 shr.s32 %r11, %r26, 1;
    selp.b32 %r11, %r4, %r14, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
