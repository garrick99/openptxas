.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    brev.b32 %r16, %r3;
    and.b32 %r9, %r3, 8;
    clz.b32 %r8, %r9;
    bfi.b32 %r11, %r16, %r16, 31, 31;
    brev.b32 %r4, %r9;
    clz.b32 %r7, %r8;
    clz.b32 %r14, %r8;
    bfe.s32 %r16, %r8, 15, 32;
    clz.b32 %r6, %r3;
    prmt.b32 %r18, %r8, %r16, 17476;
    clz.b32 %r18, %r9;
    bfi.b32 %r20, %r9, %r9, 0, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
