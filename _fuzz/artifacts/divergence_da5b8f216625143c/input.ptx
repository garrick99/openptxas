.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r21, %r3, 65536;
    max.s32 %r17, %r21, 31;
    setp.hs.u32 %p4, %r3, %r17;
    @%p4 xor.b32 %r11, %r21, 2;
    cvt.u64.u32 %rd13, %r17;
    shr.s64 %rd9, %rd13, 15;
    min.u32 %r22, %r21, 8;
    add.s32 %r14, %r3, %r17;
    add.u32 %r18, %r17, %r22;
    min.s32 %r6, %r21, %r21;
    add.s32 %r15, %r22, %r21;
    selp.b32 %r6, %r22, %r15, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
