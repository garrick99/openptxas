.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p1, %r3, 255;
    vote.sync.ballot.b32 %r17, %p1, -1;
    setp.gt.u32 %p1, %r17, %r0;
    vote.sync.ballot.b32 %r12, %p1, -1;
    shfl.sync.down.b32 %r14, %r17, 4, 0x1f, -1;
    vote.sync.any.pred %p3, %p1, -1;
    max.u32 %r18, %r12, %r0;
    shfl.sync.idx.b32 %r6, %r18, 15, 0x1f, -1;
    shfl.sync.up.b32 %r8, %r0, 4, 0x1f, -1;
    and.b32 %r15, %r3, %r12;
    sub.u32 %r15, %r3, %r0;
    shfl.sync.down.b32 %r18, %r18, 2, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
