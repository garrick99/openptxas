.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p4, %r3, 31;
    @!%p4 cvt.u64.u32 %rd8, %r3;
    min.s32 %r21, %r3, %r3;
    selp.b32 %r14, %r3, %r3, %p4;
    mul.lo.u64 %rd9, %rd8, %rd8;
    setp.hi.u32 %p2, %r14, 8;
    @%p2 and.b32 %r19, %r3, %r3;
    cvt.s64.s32 %rd15, %r19;
    cvt.u32.u64 %r4, %rd9;
    selp.b32 %r23, %r21, %r3, %p4;
    shr.s64 %rd5, %rd15, 62;
    cvt.s32.s64 %r14, %rd5;
    mul.lo.s32 %r22, %r21, %r14;
    cvt.u32.u64 %r19, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
