.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r5, %r3, 15;
    sub.u32 %r4, %r5, %r5;
    mul.lo.s32 %r21, %r4, %r3;
    sub.s32 %r17, %r5, %r21;
    cvt.s64.s32 %rd15, %r17;
    setp.ge.u32 %p4, %r5, 2147483647;
    @!%p4 max.u32 %r8, %r4, %r21;
    xor.b32 %r27, %r3, %r17;
    add.s32 %r21, %r3, %r27;
    mul.lo.u32 %r27, %r21, 255;
    xor.b64 %rd13, %rd15, %rd15;
    max.s32 %r18, %r8, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
