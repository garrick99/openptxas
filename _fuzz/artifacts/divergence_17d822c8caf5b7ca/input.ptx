.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r4, %r3, %r3;
    shl.b32 %r10, %r4, 2;
    max.s32 %r5, %r3, %r10;
    shr.u32 %r27, %r4, 15;
    mul.lo.s32 %r8, %r5, %r4;
    cvt.s64.s32 %rd14, %r27;
    cvt.s64.s32 %rd8, %r3;
    add.s64 %rd14, %rd8, %rd8;
    setp.eq.s32 %p3, %r5, %r10;
    @%p3 selp.b32 %r24, %r10, %r3, %p3;
    min.u32 %r24, %r4, %r24;
    mul.lo.s32 %r15, %r10, 65535;
    mul.wide.u32 %rd8, %r8, %r24;
    mad.lo.u32 %r15, %r24, %r27, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
