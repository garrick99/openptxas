.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r20, %r3, %r3;
    shl.b32 %r14, %r3, 4;
    mul.lo.u32 %r20, %r3, 255;
    mad.lo.s32 %r26, %r14, %r14, %r3;
    mul.wide.u32 %rd6, %r26, %r26;
    setp.lt.u32 %p1, %r26, 0;
    @%p1 cvt.s64.s32 %rd8, %r14;
    or.b32 %r17, %r26, %r26;
    add.u32 %r10, %r17, 3;
    mul.wide.u32 %rd14, %r20, %r3;
    max.s32 %r14, %r20, 255;
    selp.b32 %r18, %r20, %r26, %p1;
    setp.lo.u32 %p3, %r26, %r17;
    @%p3 mul.lo.u32 %r10, %r20, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
