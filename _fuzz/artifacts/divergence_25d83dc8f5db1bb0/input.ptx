.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r7, %r3, 3;
    min.u32 %r26, %r3, 65535;
    mul.lo.u32 %r14, %r26, %r7;
    min.u32 %r10, %r26, %r7;
    shl.b32 %r22, %r7, 2;
    cvt.s64.s32 %rd6, %r22;
    shr.u32 %r24, %r26, 7;
    cvt.s64.s32 %rd13, %r22;
    sub.s32 %r19, %r26, %r7;
    shl.b64 %rd10, %rd13, 16;
    min.u32 %r5, %r26, %r24;
    shl.b64 %rd7, %rd10, 32;
    add.u32 %r6, %r22, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
