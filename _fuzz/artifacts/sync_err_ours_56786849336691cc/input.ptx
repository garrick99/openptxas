.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    cvt.u32.u64 %r13, %rd8;
    min.u32 %r10, %r3, %r13;
    setp.ne.s32 %p2, %r3, %r10;
    @%p2 sub.s32 %r9, %r10, %r3;
    selp.b32 %r26, %r9, %r10, %p2;
    mad.lo.s32 %r15, %r26, %r3, %r26;
    shr.s64 %rd6, %rd8, 30;
    max.u64 %rd10, %rd6, %rd6;
    xor.b32 %r11, %r3, %r10;
    shl.b32 %r22, %r10, 3;
    shl.b32 %r23, %r15, 7;
    shr.s32 %r23, %r15, 3;
    mul.lo.u32 %r22, %r15, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
