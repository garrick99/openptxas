.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r22, %r3, 4;
    setp.le.s32 %p4, %r3, 256;
    @%p4 or.b32 %r7, %r22, %r3;
    mad.lo.u32 %r11, %r22, %r22, %r7;
    selp.b32 %r19, %r3, %r11, %p4;
    add.s32 %r10, %r11, 15;
    and.b32 %r21, %r10, %r7;
    cvt.s64.s32 %rd5, %r10;
    sub.s32 %r14, %r7, 32;
    add.s64 %rd14, %rd5, %rd5;
    cvt.s32.s64 %r17, %rd14;
    setp.ge.s32 %p1, %r17, 4;
    @%p1 or.b32 %r10, %r14, %r10;
    shl.b64 %rd5, %rd14, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
