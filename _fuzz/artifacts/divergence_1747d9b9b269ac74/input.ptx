.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r12, %r3, 63;
    shl.b32 %r19, %r3, 30;
    cvt.u64.u32 %rd12, %r19;
    mul.wide.u32 %rd15, %r12, %r3;
    max.s32 %r10, %r12, 3;
    min.u32 %r17, %r3, 2147483647;
    max.u32 %r16, %r3, %r10;
    cvt.s32.s64 %r19, %rd12;
    mul.lo.s64 %rd15, %rd15, %rd12;
    setp.le.s32 %p2, %r17, 256;
    @!%p2 max.u32 %r19, %r12, 0;
    setp.eq.s32 %p4, %r19, %r12;
    and.b32 %r27, %r10, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
