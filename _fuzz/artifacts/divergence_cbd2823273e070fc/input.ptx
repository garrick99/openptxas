.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r11, %r3, 30;
    setp.ls.u32 %p2, %r11, %r11;
    xor.b32 %r6, %r11, 64;
    cvt.s64.s32 %rd7, %r6;
    xor.b32 %r7, %r3, 255;
    add.s32 %r11, %r7, %r3;
    setp.lt.u32 %p4, %r7, 256;
    @!%p4 selp.b32 %r15, %r11, %r11, %p4;
    mul.wide.s32 %rd8, %r15, %r11;
    cvt.u64.u32 %rd12, %r6;
    selp.b32 %r20, %r15, %r15, %p4;
    add.s32 %r5, %r6, 2;
    max.u32 %r24, %r11, %r3;
    add.s32 %r8, %r15, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
