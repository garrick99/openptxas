.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p1, %r3, %r3;
    @!%p1 max.u32 %r10, %r3, 65535;
    xor.b32 %r11, %r3, 16;
    cvt.u64.u32 %rd9, %r10;
    mad.lo.u32 %r10, %r3, %r10, %r11;
    xor.b32 %r20, %r3, 31;
    setp.ge.s32 %p3, %r10, 1;
    @%p3 cvt.u64.u32 %rd14, %r11;
    mul.wide.u32 %rd8, %r3, %r20;
    shl.b64 %rd6, %rd8, 30;
    min.s32 %r14, %r20, %r11;
    cvt.s32.s64 %r8, %rd6;
    mul.lo.s32 %r15, %r10, %r3;
    mul.lo.u64 %rd9, %rd9, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
