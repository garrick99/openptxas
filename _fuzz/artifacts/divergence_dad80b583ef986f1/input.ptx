.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r16, %r3, %r3;
    max.s32 %r18, %r3, %r3;
    mad.lo.s32 %r8, %r18, %r16, %r3;
    setp.lo.u32 %p1, %r8, 7;
    @!%p1 mul.wide.s32 %rd10, %r18, %r3;
    shl.b32 %r21, %r16, 30;
    sub.s32 %r20, %r18, %r3;
    xor.b32 %r10, %r21, %r16;
    selp.b32 %r23, %r20, %r20, %p1;
    setp.eq.s32 %p2, %r16, %r21;
    @%p2 min.u32 %r19, %r18, 2147483648;
    max.u32 %r17, %r16, 256;
    shl.b32 %r5, %r19, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
