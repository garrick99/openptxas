.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    mad.lo.s32 %r21, %r3, %r3, %r3;
    setp.lt.u32 %p2, %r21, %r21;
    @%p2 mul.lo.s32 %r9, %r21, 256;
    selp.b32 %r26, %r9, %r9, %p2;
    add.u32 %r11, %r26, 5;
    shr.s32 %r11, %r26, 4;
    selp.b32 %r7, %r11, %r3, %p2;
    min.s32 %r9, %r3, %r9;
    mul.lo.s32 %r23, %r9, %r9;
    mad.lo.u32 %r11, %r26, %r21, %r11;
    shl.b64 %rd5, %rd10, 48;
    min.u32 %r16, %r7, 65535;
    add.u32 %r22, %r23, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
