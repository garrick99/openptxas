.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r6, %r3, %r3, %r3;
    cvt.s64.s32 %rd9, %r6;
    mad.lo.u32 %r25, %r3, %r3, %r6;
    max.u32 %r15, %r25, 4294967295;
    or.b32 %r22, %r25, %r6;
    min.s64 %rd10, %rd9, %rd9;
    shr.s32 %r14, %r22, 1;
    xor.b32 %r8, %r15, %r15;
    shl.b32 %r10, %r22, 2;
    cvt.s32.s64 %r13, %rd10;
    add.s32 %r16, %r6, %r3;
    max.u32 %r14, %r14, %r14;
    max.s32 %r22, %r22, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
