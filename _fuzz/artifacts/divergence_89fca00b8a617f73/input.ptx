.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p4, %r3, 255;
    add.u32 %r18, %r3, 65535;
    setp.gt.u32 %p3, %r18, %r18;
    @%p3 mul.lo.s32 %r27, %r18, 31;
    and.b32 %r6, %r18, %r3;
    max.u32 %r15, %r6, 1;
    cvt.u64.u32 %rd5, %r15;
    min.s32 %r15, %r6, %r3;
    cvt.s32.s64 %r17, %rd5;
    cvt.s32.s64 %r5, %rd5;
    cvt.u64.u32 %rd15, %r17;
    add.u32 %r9, %r27, %r5;
    shr.u32 %r24, %r9, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
