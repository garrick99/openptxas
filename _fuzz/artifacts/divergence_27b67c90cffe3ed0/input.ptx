.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r7, %r3, %r3;
    cvt.s64.s32 %rd5, %r7;
    cvt.u64.u32 %rd15, %r7;
    cvt.s32.s64 %r20, %rd15;
    shr.s64 %rd10, %rd15, 7;
    mul.wide.u32 %rd6, %r3, %r3;
    max.u32 %r24, %r3, 65536;
    mul.wide.s32 %rd7, %r3, %r20;
    setp.hs.u32 %p3, %r24, %r20;
    or.b32 %r6, %r7, 256;
    min.u32 %r9, %r6, %r24;
    max.s64 %rd10, %rd15, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
