.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p4, %r3, 64;
    @!%p4 cvt.s64.s32 %rd13, %r3;
    shr.u32 %r21, %r3, 0;
    setp.le.u32 %p1, %r21, 0;
    @%p1 min.u32 %r23, %r21, %r21;
    setp.lo.u32 %p4, %r3, 8;
    @%p4 sub.s32 %r17, %r3, 4;
    sub.s32 %r27, %r23, 4294967295;
    selp.b32 %r27, %r23, %r27, %p4;
    cvt.u32.u64 %r22, %rd13;
    mul.wide.s32 %rd12, %r17, %r27;
    min.s32 %r10, %r23, %r17;
    shl.b32 %r10, %r22, 2;
    min.s32 %r20, %r27, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
