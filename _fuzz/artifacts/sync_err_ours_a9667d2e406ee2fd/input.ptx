.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    setp.gt.u32 %p4, %r3, %r3;
    setp.eq.s32 %p3, %r3, %r3;
    @%p3 add.u64 %rd8, %rd14, %rd14;
    setp.le.s32 %p2, %r3, %r3;
    setp.ge.u32 %p1, %r3, 15;
    @%p1 add.s32 %r23, %r3, 0;
    shr.s64 %rd15, %rd8, 0;
    add.s32 %r17, %r3, 64;
    setp.ge.s32 %p1, %r3, %r3;
    min.u32 %r21, %r3, %r23;
    add.u32 %r27, %r21, %r23;
    mul.lo.u32 %r5, %r21, 31;
    mul.wide.s32 %rd13, %r3, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
