.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r12, %r3, 5;
    cvt.s64.s32 %rd11, %r3;
    max.u32 %r14, %r12, %r3;
    max.s32 %r10, %r12, %r3;
    add.s32 %r11, %r12, 64;
    cvt.u32.u64 %r26, %rd11;
    min.s32 %r11, %r10, %r10;
    shr.u64 %rd9, %rd11, 31;
    cvt.s32.s64 %r4, %rd11;
    max.u32 %r17, %r12, %r12;
    xor.b32 %r22, %r4, 2;
    setp.ne.s32 %p3, %r12, 65536;
    @%p3 mad.lo.s32 %r27, %r22, %r12, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
