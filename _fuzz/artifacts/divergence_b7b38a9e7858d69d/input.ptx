.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r13, %r3, %r3;
    setp.eq.s32 %p4, %r3, %r13;
    @%p4 xor.b32 %r20, %r3, %r3;
    shr.u32 %r8, %r13, 7;
    mul.lo.s32 %r10, %r20, 8;
    selp.b32 %r27, %r8, %r10, %p4;
    xor.b32 %r8, %r8, %r8;
    or.b32 %r6, %r27, %r10;
    selp.b32 %r24, %r3, %r6, %p4;
    max.s32 %r22, %r20, 8;
    or.b32 %r19, %r24, 65535;
    cvt.u64.u32 %rd6, %r19;
    sub.u32 %r21, %r13, %r22;
    shr.u32 %r8, %r21, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
