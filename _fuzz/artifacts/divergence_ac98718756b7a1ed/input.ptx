.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r26, %r3, %r3, %r3;
    mul.wide.s32 %rd7, %r3, %r3;
    setp.ge.u32 %p1, %r26, 2147483648;
    @%p1 shl.b32 %r22, %r26, 16;
    setp.gt.u32 %p2, %r22, 16;
    mul.lo.s32 %r26, %r22, 4294967295;
    cvt.u32.u64 %r25, %rd7;
    shr.u64 %rd5, %rd7, 32;
    max.s32 %r24, %r26, %r26;
    setp.ge.s32 %p2, %r3, %r24;
    @%p2 add.u32 %r22, %r3, %r22;
    shr.u32 %r19, %r24, 4;
    xor.b32 %r26, %r19, %r3;
    xor.b32 %r7, %r24, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
