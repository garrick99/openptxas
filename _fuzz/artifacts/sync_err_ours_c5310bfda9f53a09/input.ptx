.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r9, %r3, 4;
    shl.b32 %r6, %r3, 0;
    cvt.u64.u32 %rd9, %r3;
    mad.lo.s32 %r4, %r9, %r6, %r6;
    mul.lo.s32 %r18, %r3, 16;
    max.s32 %r24, %r4, %r9;
    cvt.u32.u64 %r21, %rd9;
    max.s64 %rd13, %rd9, %rd9;
    or.b32 %r20, %r9, 1;
    mul.lo.u64 %rd8, %rd13, %rd9;
    shl.b32 %r23, %r9, 30;
    setp.ge.u32 %p4, %r3, 4;
    add.s32 %r19, %r23, %r6;
    cvt.u32.u64 %r20, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
