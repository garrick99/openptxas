.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    max.u32 %r20, %r3, 1;
    shl.b32 %r6, %r20, 16;
    mul.lo.u32 %r11, %r6, 255;
    min.u64 %rd5, %rd5, %rd5;
    mul.lo.u32 %r22, %r11, %r20;
    setp.ne.u32 %p4, %r20, 31;
    @%p4 cvt.u32.u64 %r8, %rd5;
    mul.lo.s32 %r10, %r20, %r20;
    sub.s32 %r20, %r8, 7;
    mad.lo.s32 %r17, %r20, %r3, %r11;
    shr.s64 %rd7, %rd5, 62;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
