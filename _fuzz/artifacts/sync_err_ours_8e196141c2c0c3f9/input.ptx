.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    max.u32 %r15, %r3, 255;
    min.s32 %r11, %r3, 2147483648;
    xor.b32 %r13, %r3, %r3;
    shr.s32 %r18, %r15, 2;
    mul.lo.s32 %r18, %r3, 65535;
    setp.hs.u32 %p1, %r13, %r15;
    @%p1 and.b32 %r6, %r3, %r18;
    selp.b32 %r20, %r6, %r11, %p1;
    shr.u64 %rd5, %rd6, 1;
    shr.s64 %rd11, %rd6, 15;
    mul.wide.s32 %rd12, %r15, %r6;
    selp.b32 %r23, %r15, %r15, %p1;
    sub.s32 %r16, %r13, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
