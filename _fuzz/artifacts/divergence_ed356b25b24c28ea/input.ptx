.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r5, %r3, 32;
    mul.wide.u32 %rd7, %r3, %r5;
    mad.lo.s32 %r18, %r5, %r3, %r3;
    mad.lo.s32 %r14, %r18, %r3, %r18;
    min.u32 %r14, %r5, %r14;
    or.b32 %r21, %r14, %r14;
    max.u32 %r25, %r14, %r3;
    shl.b64 %rd8, %rd7, 7;
    shl.b32 %r20, %r5, 15;
    sub.u64 %rd11, %rd7, %rd7;
    setp.le.s32 %p1, %r25, %r21;
    @%p1 mul.lo.u32 %r13, %r20, 63;
    setp.ls.u32 %p2, %r14, %r18;
    @%p2 or.b32 %r4, %r25, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
