.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    sub.u32 %r13, %r3, 1;
    setp.lt.s32 %p4, %r3, 3;
    @!%p4 add.s32 %r17, %r3, %r3;
    cvt.s32.s64 %r6, %rd15;
    and.b32 %r12, %r17, 2;
    setp.le.s32 %p4, %r12, 5;
    @%p4 cvt.u32.u64 %r22, %rd15;
    min.u32 %r27, %r3, 5;
    shl.b64 %rd14, %rd15, 30;
    mul.lo.s32 %r18, %r17, 16;
    cvt.u32.u64 %r12, %rd15;
    add.u32 %r17, %r18, 1;
    mul.wide.s32 %rd13, %r27, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
