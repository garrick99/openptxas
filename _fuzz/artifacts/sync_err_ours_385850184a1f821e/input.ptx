.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r23, %r3, %r3;
    min.u32 %r20, %r3, %r23;
    setp.ne.u32 %p1, %r3, 63;
    @%p1 mul.wide.u32 %rd5, %r23, %r20;
    mad.lo.u32 %r24, %r23, %r3, %r20;
    max.u32 %r14, %r23, 63;
    add.u32 %r14, %r14, %r14;
    max.u32 %r21, %r3, 63;
    cvt.u64.u32 %rd9, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
