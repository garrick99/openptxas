.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    or.b32 %r7, %r3, %r3;
    max.u32 %r16, %r7, 7;
    cvt.u64.u32 %rd12, %r3;
    add.s32 %r23, %r7, 7;
    sub.s32 %r14, %r3, %r23;
    sub.s32 %r7, %r16, 16;
    setp.le.s32 %p3, %r16, 255;
    @!%p3 min.u64 %rd12, %rd6, %rd12;
    max.u32 %r24, %r16, 32;
    shr.s64 %rd10, %rd6, 3;
    max.u32 %r9, %r24, 256;
    cvt.u32.u64 %r19, %rd6;
    max.u32 %r12, %r19, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
