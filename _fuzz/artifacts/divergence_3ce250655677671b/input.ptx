.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r8, %r3, 0;
    mul.lo.s32 %r5, %r3, %r8;
    max.u32 %r4, %r5, %r3;
    mad.lo.s32 %r11, %r4, %r5, %r8;
    add.s32 %r23, %r3, %r5;
    mul.lo.s32 %r18, %r3, 0;
    sub.u32 %r13, %r8, %r5;
    mul.wide.s32 %rd14, %r4, %r13;
    mad.lo.u32 %r24, %r3, %r13, %r5;
    and.b32 %r15, %r23, %r18;
    mad.lo.u32 %r6, %r13, %r24, %r13;
    add.s32 %r24, %r4, %r8;
    shr.s64 %rd11, %rd14, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
