    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    min.s32 %r21, %r3, 5;
    or.b64 %rd12, %rd15, %rd15;
    max.s64 %rd12, %rd15, %rd12;
    add.s32 %r21, %r3, 2147483648;
    cvt.u64.u32 %rd5, %r3;
    setp.lt.s32 %p3, %r21, %r21;
    @%p3 mul.lo.s64 %rd7, %rd5, %rd15;
    cvt.u32.u64 %r9, %rd12;
    mul.lo.s32 %r19, %r3, %r21;
    cvt.u64.u32 %rd12, %r9;
    xor.b32 %r27, %r21, %r3;
    setp.gt.s32 %p2, %r3, %r19;
    @%p2 max.s32 %r8, %r9, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
