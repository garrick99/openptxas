.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p4, %r3, 1;
    @!%p4 shl.b32 %r27, %r3, 31;
    xor.b32 %r16, %r3, %r27;
    min.s32 %r26, %r3, %r16;
    xor.b32 %r25, %r3, 4294967295;
    shl.b32 %r4, %r3, 1;
    add.s32 %r21, %r26, %r3;
    shr.s32 %r11, %r25, 0;
    cvt.s64.s32 %rd7, %r3;
    setp.ne.s32 %p2, %r27, %r26;
    @!%p2 max.u32 %r12, %r26, %r25;
    mul.wide.u32 %rd6, %r4, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
