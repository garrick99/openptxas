.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd8, %r3, %r3;
    setp.ge.s32 %p4, %r3, 2147483648;
    @%p4 and.b64 %rd7, %rd8, %rd8;
    setp.gt.u32 %p2, %r3, 5;
    @%p2 xor.b32 %r21, %r3, %r3;
    and.b32 %r25, %r21, 5;
    or.b32 %r14, %r3, 31;
    shl.b32 %r16, %r21, 2;
    max.s32 %r23, %r3, %r16;
    or.b32 %r18, %r16, 2147483648;
    setp.ge.s32 %p3, %r21, 255;
    setp.lt.s32 %p3, %r25, 65536;
    @%p3 cvt.s64.s32 %rd15, %r23;
    mul.lo.u64 %rd8, %rd8, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
