.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r27, %r3, %r3;
    setp.eq.s32 %p2, %r27, %r27;
    @!%p2 mul.lo.s32 %r20, %r3, 7;
    setp.gt.s32 %p4, %r27, %r27;
    @%p4 add.s32 %r24, %r3, 2;
    min.u32 %r4, %r3, %r20;
    max.u32 %r12, %r3, %r3;
    mul.wide.u32 %rd6, %r4, %r3;
    shr.s32 %r14, %r3, 1;
    max.u32 %r9, %r20, 16;
    add.u32 %r11, %r24, %r14;
    max.s64 %rd10, %rd6, %rd6;
    sub.s64 %rd10, %rd10, %rd6;
    mad.lo.u32 %r14, %r9, %r20, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
