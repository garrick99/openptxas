.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r24, %r3, 7;
    and.b32 %r26, %r24, %r24;
    add.s32 %r10, %r26, 65535;
    cvt.u64.u32 %rd13, %r26;
    shl.b32 %r6, %r3, 15;
    shl.b64 %rd9, %rd13, 62;
    add.s64 %rd5, %rd13, %rd13;
    mul.wide.u32 %rd15, %r26, %r6;
    max.u32 %r20, %r26, %r24;
    shr.s64 %rd5, %rd13, 16;
    and.b64 %rd9, %rd9, %rd9;
    or.b32 %r23, %r20, 15;
    cvt.u32.u64 %r22, %rd15;
    add.s32 %r26, %r24, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
