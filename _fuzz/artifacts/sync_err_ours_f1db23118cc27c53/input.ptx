.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r23, %r3, %r3;
    cvt.s64.s32 %rd7, %r3;
    cvt.u32.u64 %r24, %rd7;
    mul.wide.u32 %rd10, %r24, %r3;
    cvt.s32.s64 %r21, %rd7;
    min.u32 %r7, %r21, %r23;
    cvt.s32.s64 %r22, %rd10;
    and.b32 %r14, %r24, %r7;
    mad.lo.s32 %r19, %r3, %r21, %r21;
    max.u32 %r14, %r21, %r7;
    max.s32 %r18, %r19, %r3;
    max.u32 %r11, %r22, 1;
    add.u32 %r14, %r3, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
