.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r10, %r3, 3;
    add.s32 %r16, %r3, %r10;
    add.u32 %r22, %r16, 31;
    setp.ls.u32 %p3, %r16, 7;
    @!%p3 cvt.u64.u32 %rd15, %r22;
    setp.ge.u32 %p3, %r3, 3;
    sub.s32 %r25, %r3, %r10;
    setp.ge.s32 %p3, %r3, %r25;
    @!%p3 mad.lo.u32 %r21, %r22, %r10, %r22;
    mul.wide.s32 %rd11, %r10, %r25;
    mad.lo.u32 %r23, %r16, %r21, %r16;
    selp.b32 %r27, %r16, %r10, %p3;
    add.u32 %r20, %r16, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
