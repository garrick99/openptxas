.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    and.b32 %r11, %r3, 255;
    setp.lt.u32 %p4, %r3, %r11;
    @%p4 cvt.u64.u32 %rd10, %r3;
    shr.u64 %rd9, %rd5, 3;
    or.b32 %r26, %r11, %r11;
    shr.u64 %rd12, %rd5, 3;
    min.s32 %r25, %r3, %r11;
    and.b32 %r23, %r3, 1;
    sub.u32 %r24, %r11, 0;
    mul.wide.u32 %rd12, %r11, %r23;
    mul.wide.s32 %rd6, %r23, %r25;
    selp.b32 %r12, %r25, %r26, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
