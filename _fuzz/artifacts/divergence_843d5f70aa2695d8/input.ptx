.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r27, %r3, %r3;
    setp.ne.s32 %p3, %r3, %r27;
    @!%p3 shl.b32 %r14, %r27, 4;
    cvt.u64.u32 %rd11, %r27;
    selp.b32 %r19, %r14, %r3, %p3;
    add.s64 %rd15, %rd11, %rd11;
    mad.lo.s32 %r21, %r19, %r14, %r19;
    shr.s32 %r11, %r27, 31;
    selp.b32 %r20, %r11, %r11, %p3;
    cvt.u32.u64 %r20, %rd15;
    min.u32 %r15, %r21, 5;
    add.s32 %r25, %r3, %r3;
    setp.lt.s32 %p1, %r3, %r15;
    @%p1 xor.b32 %r6, %r19, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
