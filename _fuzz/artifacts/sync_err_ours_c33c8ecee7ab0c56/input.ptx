.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r26, %r3, 30;
    setp.gt.u32 %p3, %r26, 255;
    @%p3 cvt.u64.u32 %rd15, %r3;
    mad.lo.u32 %r23, %r3, %r26, %r26;
    add.s32 %r11, %r26, 2;
    or.b32 %r21, %r26, 4294967295;
    shr.s32 %r9, %r23, 0;
    or.b32 %r17, %r11, %r11;
    add.s32 %r8, %r9, %r21;
    xor.b64 %rd11, %rd15, %rd15;
    mad.lo.u32 %r4, %r11, %r23, %r9;
    shr.u32 %r19, %r11, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
