.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    setp.lo.u32 %p2, %r3, 31;
    @%p2 cvt.s64.s32 %rd5, %r3;
    cvt.s32.s64 %r8, %rd5;
    add.u32 %r20, %r3, %r8;
    mul.wide.s32 %rd7, %r8, %r3;
    mul.wide.s32 %rd8, %r8, %r20;
    setp.ne.s32 %p3, %r20, %r3;
    @%p3 mul.wide.u32 %rd10, %r3, %r8;
    max.s32 %r13, %r8, %r3;
    sub.s32 %r21, %r20, 15;
    add.s32 %r12, %r3, 31;
    setp.lt.u32 %p2, %r8, %r8;
    cvt.s32.s64 %r18, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
