    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p2, %r3, %r3;
    cvt.u64.u32 %rd12, %r3;
    shl.b32 %r20, %r3, 0;
    or.b32 %r21, %r3, 255;
    setp.lt.u32 %p3, %r3, %r21;
    @!%p3 mul.lo.s32 %r11, %r20, %r20;
    selp.b32 %r20, %r11, %r21, %p3;
    mul.lo.u32 %r10, %r20, 5;
    add.s32 %r14, %r21, 8;
    shr.s32 %r20, %r14, 1;
    shl.b32 %r23, %r14, 16;
    mul.lo.u32 %r19, %r23, 1;
    add.u32 %r25, %r14, 2147483647;
    max.u32 %r25, %r23, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
