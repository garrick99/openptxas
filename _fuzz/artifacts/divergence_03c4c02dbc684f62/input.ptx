.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r24, %r3, 8;
    cvt.s64.s32 %rd12, %r24;
    min.s32 %r18, %r3, 4294967295;
    mad.lo.s32 %r13, %r18, %r18, %r18;
    mul.wide.u32 %rd11, %r18, %r18;
    or.b32 %r11, %r13, %r24;
    or.b64 %rd5, %rd12, %rd12;
    shr.s32 %r4, %r18, 1;
    setp.ne.s32 %p3, %r3, 0;
    xor.b32 %r13, %r11, 3;
    setp.hs.u32 %p4, %r3, %r4;
    shr.u32 %r24, %r3, 2;
    mul.wide.s32 %rd5, %r11, %r4;
    selp.b32 %r6, %r4, %r18, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
