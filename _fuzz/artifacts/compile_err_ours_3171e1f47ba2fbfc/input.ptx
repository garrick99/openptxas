.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p3, %r3, %r0;
    vote.sync.ballot.b32 %r4, %p3, -1;
    shfl.sync.idx.b32 %r8, %r4, 31, 0x1f, -1;
    setp.ne.u32 %p3, %r8, 31;
    vote.sync.ballot.b32 %r14, %p3, -1;
    shfl.sync.bfly.b32 %r10, %r4, 8, 0x1f, -1;
    add.u32 %r19, %r8, %r4;
    setp.gt.u32 %p2, %r8, 0;
    vote.sync.ballot.b32 %r11, %p2, -1;
    vote.sync.any.pred %p3, %p2, -1;
    shfl.sync.up.b32 %r14, %r19, 4, 0x1f, -1;
    xor.b32 %r8, %r10, %r3;
    sub.u32 %r19, %r0, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
