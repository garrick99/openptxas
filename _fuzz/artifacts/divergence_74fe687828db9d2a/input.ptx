.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    mul.lo.u64 %rd9, %rd13, %rd13;
    min.s64 %rd10, %rd13, %rd9;
    max.u32 %r16, %r3, %r3;
    mul.lo.s32 %r25, %r16, 1;
    mul.wide.u32 %rd13, %r3, %r25;
    sub.s32 %r9, %r25, 3;
    setp.ge.s32 %p1, %r3, %r9;
    mad.lo.u32 %r17, %r16, %r16, %r25;
    add.s32 %r25, %r16, 2147483648;
    setp.lo.u32 %p4, %r3, 1;
    xor.b32 %r5, %r25, 256;
    sub.s32 %r14, %r5, %r16;
    shl.b32 %r9, %r5, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
