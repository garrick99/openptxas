.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r20, %r3, 16;
    setp.gt.u32 %p1, %r3, 0;
    @%p1 mul.lo.s32 %r23, %r20, %r3;
    setp.lo.u32 %p1, %r20, 2;
    @!%p1 mul.wide.s32 %rd13, %r20, %r20;
    sub.s32 %r4, %r23, 65536;
    add.u32 %r24, %r3, 32;
    cvt.s32.s64 %r20, %rd13;
    setp.ge.s32 %p1, %r20, %r20;
    shr.u32 %r11, %r23, 30;
    shl.b32 %r25, %r23, 16;
    selp.b32 %r16, %r4, %r23, %p1;
    or.b32 %r26, %r11, %r16;
    cvt.s32.s64 %r27, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
