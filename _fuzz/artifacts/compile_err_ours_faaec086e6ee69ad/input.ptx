.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p3, %r3, 65535;
    vote.sync.ballot.b32 %r8, %p3, -1;
    vote.sync.all.pred %p1, %p3, -1;
    shfl.sync.idx.b32 %r19, %r0, 15, 0x1f, -1;
    max.u32 %r12, %r19, %r3;
    shfl.sync.idx.b32 %r17, %r12, 0, 0x1f, -1;
    shfl.sync.up.b32 %r14, %r0, 1, 0x1f, -1;
    vote.sync.any.pred %p2, %p3, -1;
    setp.ge.u32 %p2, %r17, %r0;
    vote.sync.ballot.b32 %r4, %p2, -1;
    shfl.sync.up.b32 %r12, %r14, 4, 0x1f, -1;
    max.u32 %r10, %r0, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
