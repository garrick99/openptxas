.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    shl.b64 %rd10, %rd6, 3;
    mad.lo.s32 %r24, %r3, %r3, %r3;
    sub.u32 %r8, %r3, 3;
    cvt.u64.u32 %rd5, %r3;
    cvt.u32.u64 %r27, %rd5;
    and.b32 %r14, %r8, %r3;
    setp.lt.u32 %p3, %r8, 4294967295;
    @!%p3 add.u32 %r13, %r24, 64;
    mul.wide.u32 %rd15, %r24, %r13;
    and.b32 %r4, %r3, %r13;
    add.u32 %r21, %r4, %r24;
    mad.lo.s32 %r23, %r14, %r4, %r27;
    add.u32 %r22, %r13, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
