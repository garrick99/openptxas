.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    and.b32 %r17, %r3, %r3;
    shl.b32 %r5, %r17, 16;
    or.b32 %r16, %r3, %r3;
    shl.b64 %rd9, %rd13, 63;
    mul.lo.s32 %r7, %r5, 32;
    mul.wide.s32 %rd14, %r17, %r7;
    add.u32 %r16, %r17, %r16;
    min.u32 %r23, %r7, 3;
    cvt.u64.u32 %rd15, %r5;
    and.b32 %r6, %r7, 7;
    cvt.s32.s64 %r22, %rd9;
    xor.b32 %r15, %r17, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
