.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r26, %r3, 65535;
    shl.b32 %r7, %r3, 31;
    sub.u32 %r17, %r26, 31;
    sub.s32 %r16, %r26, 65536;
    shl.b32 %r21, %r17, 16;
    or.b32 %r6, %r26, 32;
    mul.wide.s32 %rd5, %r26, %r6;
    max.u32 %r10, %r17, 15;
    add.u32 %r21, %r17, 255;
    sub.s32 %r19, %r26, 2147483647;
    add.s32 %r12, %r17, 65535;
    sub.u32 %r19, %r10, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
