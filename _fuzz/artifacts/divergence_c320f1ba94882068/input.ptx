.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    shl.b64 %rd6, %rd9, 47;
    and.b32 %r4, %r3, %r3;
    mul.lo.s32 %r4, %r4, 31;
    max.s32 %r21, %r3, %r3;
    shr.u32 %r11, %r21, 2;
    mul.lo.u32 %r16, %r11, 256;
    add.s64 %rd6, %rd9, %rd6;
    mul.lo.s32 %r18, %r21, %r11;
    cvt.s32.s64 %r12, %rd9;
    cvt.u64.u32 %rd15, %r18;
    setp.lt.s32 %p2, %r16, 2147483647;
    @%p2 mul.wide.s32 %rd12, %r3, %r12;
    mul.wide.u32 %rd6, %r11, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
