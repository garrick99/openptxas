.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r15, %r3, %r3;
    add.u32 %r27, %r15, %r15;
    min.u32 %r15, %r27, 16;
    cvt.u64.u32 %rd8, %r15;
    cvt.s32.s64 %r8, %rd8;
    add.u32 %r16, %r15, %r15;
    max.s32 %r22, %r15, %r16;
    cvt.u64.u32 %rd12, %r16;
    shr.s32 %r27, %r8, 31;
    setp.ne.u32 %p1, %r8, 16;
    @%p1 cvt.s64.s32 %rd15, %r22;
    cvt.u32.u64 %r27, %rd8;
    cvt.s32.s64 %r18, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
