.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p3, %r3, 4294967295;
    max.u32 %r18, %r3, 65536;
    sub.u32 %r14, %r3, %r18;
    min.s32 %r27, %r3, %r3;
    cvt.s64.s32 %rd5, %r27;
    or.b32 %r15, %r18, 255;
    min.s32 %r25, %r27, %r15;
    min.s64 %rd6, %rd5, %rd5;
    cvt.s32.s64 %r4, %rd6;
    shr.u64 %rd12, %rd5, 0;
    selp.b32 %r25, %r4, %r15, %p3;
    and.b32 %r12, %r25, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
