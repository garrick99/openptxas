.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    sub.u64 %rd11, %rd10, %rd10;
    shr.s32 %r26, %r3, 4;
    cvt.u32.u64 %r26, %rd10;
    cvt.s64.s32 %rd12, %r3;
    cvt.s64.s32 %rd5, %r3;
    shr.u32 %r5, %r3, 1;
    cvt.s32.s64 %r20, %rd5;
    add.u32 %r8, %r20, %r26;
    cvt.u64.u32 %rd7, %r20;
    shl.b32 %r19, %r26, 1;
    mul.lo.s32 %r21, %r19, 65536;
    cvt.s64.s32 %rd7, %r20;
    max.u32 %r9, %r5, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
