.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p3, %r3, 64;
    sub.s32 %r22, %r3, 63;
    and.b32 %r4, %r3, 4;
    max.u32 %r19, %r3, %r22;
    sub.s32 %r21, %r19, 255;
    mul.lo.s32 %r24, %r21, %r21;
    mad.lo.u32 %r16, %r21, %r24, %r4;
    min.s32 %r8, %r3, %r22;
    setp.ge.s32 %p1, %r21, %r24;
    @!%p1 mul.wide.s32 %rd14, %r3, %r4;
    mul.lo.s32 %r10, %r24, 65536;
    shl.b32 %r23, %r22, 15;
    setp.lo.u32 %p1, %r24, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
