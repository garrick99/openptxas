.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    mad.lo.s32 %r20, %r3, %r3, %r3;
    mad.lo.u32 %r13, %r20, %r20, %r20;
    add.s32 %r11, %r13, %r3;
    or.b32 %r24, %r13, %r3;
    cvt.s32.s64 %r8, %rd9;
    shr.s32 %r22, %r8, 4;
    add.s64 %rd12, %rd9, %rd9;
    sub.s32 %r10, %r22, 32;
    cvt.s64.s32 %rd6, %r20;
    setp.ls.u32 %p3, %r11, %r10;
    @%p3 selp.b32 %r11, %r20, %r8, %p3;
    sub.s64 %rd8, %rd9, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
