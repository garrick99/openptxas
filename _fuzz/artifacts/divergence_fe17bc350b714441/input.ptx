.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    setp.lt.u32 %p3, %r3, %r3;
    @%p3 add.u32 %r8, %r3, %r3;
    shl.b64 %rd8, %rd12, 2;
    cvt.u64.u32 %rd14, %r3;
    shr.s64 %rd15, %rd12, 3;
    add.s32 %r25, %r3, 65535;
    mul.wide.u32 %rd12, %r3, %r8;
    xor.b32 %r17, %r8, 16;
    mad.lo.u32 %r8, %r25, %r25, %r17;
    cvt.s64.s32 %rd12, %r25;
    mul.lo.s32 %r8, %r3, %r8;
    setp.hs.u32 %p1, %r17, %r8;
    @%p1 shr.s32 %r22, %r3, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
