.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    shl.b64 %rd15, %rd10, 3;
    sub.s32 %r6, %r3, %r3;
    shl.b32 %r6, %r3, 2;
    shl.b32 %r22, %r3, 31;
    min.s64 %rd5, %rd15, %rd10;
    add.s64 %rd7, %rd10, %rd15;
    or.b64 %rd6, %rd10, %rd15;
    cvt.s32.s64 %r11, %rd5;
    mad.lo.s32 %r9, %r22, %r22, %r6;
    max.u32 %r9, %r9, %r11;
    max.s32 %r21, %r11, %r22;
    setp.le.u32 %p4, %r21, 5;
    @%p4 cvt.s32.s64 %r12, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
