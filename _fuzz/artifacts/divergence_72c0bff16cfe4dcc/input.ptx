    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r24, %r3, %r3;
    and.b32 %r20, %r3, 2147483647;
    add.s32 %r27, %r3, %r24;
    mad.lo.u32 %r22, %r3, %r20, %r20;
    min.u32 %r6, %r22, 1;
    mul.lo.s32 %r15, %r27, 4;
    min.s32 %r17, %r27, 15;
