.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r7, %r3, 65536;
    sub.s32 %r19, %r7, %r7;
    setp.lt.u32 %p2, %r3, %r19;
    setp.lo.u32 %p2, %r7, %r3;
    @!%p2 max.s32 %r7, %r19, %r7;
    cvt.u64.u32 %rd11, %r7;
    and.b32 %r26, %r19, %r7;
    max.s64 %rd15, %rd11, %rd11;
    sub.u32 %r9, %r19, %r19;
    shr.u32 %r17, %r7, 3;
    mad.lo.s32 %r16, %r26, %r3, %r26;
    shr.s64 %rd6, %rd11, 33;
    shr.u32 %r23, %r19, 4;
    selp.b32 %r14, %r17, %r23, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
