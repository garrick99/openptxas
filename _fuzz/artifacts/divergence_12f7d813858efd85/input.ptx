.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r19, %r3, 7;
    mul.wide.u32 %rd9, %r3, %r3;
    sub.s32 %r9, %r3, %r19;
    mad.lo.u32 %r21, %r19, %r9, %r9;
    mad.lo.u32 %r4, %r3, %r3, %r19;
    shr.u64 %rd10, %rd9, 31;
    mul.wide.u32 %rd14, %r9, %r21;
    cvt.u32.u64 %r7, %rd10;
    xor.b32 %r4, %r4, 15;
    min.u32 %r4, %r4, %r19;
    mul.wide.u32 %rd6, %r19, %r19;
    or.b32 %r22, %r9, 31;
    mad.lo.u32 %r5, %r7, %r19, %r21;
    min.u32 %r21, %r4, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
