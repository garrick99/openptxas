.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r11, %r3, 4;
    xor.b32 %r15, %r11, 65536;
    mul.lo.u32 %r24, %r11, 4294967295;
    xor.b32 %r20, %r15, 5;
    cvt.s64.s32 %rd14, %r24;
    cvt.s32.s64 %r15, %rd14;
    shr.s64 %rd6, %rd14, 2;
    xor.b32 %r27, %r20, 65535;
    mad.lo.u32 %r10, %r15, %r24, %r3;
    mad.lo.u32 %r5, %r24, %r27, %r24;
    mul.wide.u32 %rd8, %r3, %r24;
    cvt.u64.u32 %rd5, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
