.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r9, %r3, %r3;
    cvt.s64.s32 %rd12, %r3;
    max.u32 %r14, %r3, %r9;
    add.u32 %r15, %r3, %r9;
    cvt.s32.s64 %r26, %rd12;
    sub.s32 %r21, %r9, 2;
    shl.b64 %rd11, %rd12, 2;
    cvt.u32.u64 %r24, %rd11;
    cvt.s32.s64 %r8, %rd12;
    mul.wide.s32 %rd11, %r15, %r26;
    cvt.s64.s32 %rd14, %r9;
    shr.u32 %r26, %r14, 16;
    mul.lo.u32 %r24, %r14, %r24;
    mad.lo.s32 %r11, %r21, %r8, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
