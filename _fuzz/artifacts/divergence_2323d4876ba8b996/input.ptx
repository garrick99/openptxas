.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    setp.ne.s32 %p3, %r3, 32;
    cvt.s64.s32 %rd6, %r3;
    max.u32 %r13, %r3, 4294967295;
    max.u32 %r25, %r3, %r3;
    shl.b32 %r12, %r13, 16;
    or.b32 %r9, %r12, %r3;
    max.u32 %r21, %r25, %r25;
    and.b32 %r4, %r25, %r3;
    shr.u32 %r13, %r25, 1;
    shr.u64 %rd14, %rd6, 32;
    cvt.s64.s32 %rd9, %r21;
    max.s32 %r24, %r21, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
