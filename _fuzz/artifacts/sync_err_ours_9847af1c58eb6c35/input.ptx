.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd12, %r3, %r3;
    shr.s32 %r12, %r3, 0;
    setp.ne.s32 %p2, %r3, 5;
    @%p2 mad.lo.s32 %r17, %r3, %r12, %r12;
    xor.b32 %r18, %r3, 4;
    and.b32 %r10, %r12, 64;
    max.s32 %r8, %r18, 64;
    or.b32 %r13, %r17, 1;
    sub.u32 %r11, %r13, 7;
    and.b32 %r26, %r13, %r18;
    add.s32 %r6, %r18, %r17;
    add.u32 %r7, %r8, %r11;
    mul.wide.s32 %rd8, %r13, %r3;
    min.u32 %r4, %r17, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
