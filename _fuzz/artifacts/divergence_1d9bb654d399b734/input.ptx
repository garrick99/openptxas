.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    or.b32 %r10, %r3, %r3;
    cvt.s64.s32 %rd5, %r10;
    shr.s64 %rd7, %rd5, 4;
    shr.s64 %rd11, %rd7, 15;
    mul.wide.s32 %rd11, %r10, %r10;
    shr.u32 %r9, %r10, 30;
    setp.ls.u32 %p1, %r3, %r3;
    max.u32 %r20, %r10, %r3;
    setp.le.s32 %p2, %r10, 4294967295;
    @%p2 and.b32 %r7, %r3, 255;
    add.u32 %r6, %r7, %r7;
    mul.lo.s32 %r7, %r6, 4294967295;
    mad.lo.s32 %r4, %r7, %r9, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
