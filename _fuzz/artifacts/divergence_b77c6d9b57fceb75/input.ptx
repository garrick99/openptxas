.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r16, %r3, 31;
    add.u32 %r25, %r16, 7;
    setp.le.s32 %p1, %r16, 32;
    @!%p1 shr.s32 %r20, %r25, 4;
    mad.lo.s32 %r25, %r16, %r3, %r20;
    selp.b32 %r5, %r16, %r16, %p1;
    mul.wide.u32 %rd9, %r5, %r20;
    sub.u32 %r26, %r25, 1;
    mul.wide.u32 %rd11, %r3, %r26;
    sub.s64 %rd7, %rd11, %rd9;
    setp.ls.u32 %p3, %r16, 64;
    @%p3 xor.b32 %r14, %r5, 255;
    max.s32 %r6, %r26, %r20;
    or.b32 %r26, %r25, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
