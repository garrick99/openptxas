.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.up.b32 %r4, %r3, 16, 0x1f, -1;
    and.b32 %r4, %r0, %r3;
    setp.gt.u32 %p1, %r4, 7;
    vote.sync.ballot.b32 %r12, %p1, -1;
    min.u32 %r15, %r0, %r0;
    max.u32 %r19, %r4, %r15;
    vote.sync.any.pred %p1, %p1, -1;
    setp.le.u32 %p3, %r3, %r15;
    vote.sync.ballot.b32 %r13, %p3, -1;
    min.u32 %r5, %r15, %r0;
    and.b32 %r11, %r15, %r13;
    max.u32 %r4, %r19, %r0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
