.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r19, %r3, %r3;
    add.s32 %r25, %r3, 255;
    sub.u32 %r7, %r19, %r25;
    min.s32 %r27, %r7, 65535;
    mul.lo.u32 %r6, %r3, %r3;
    setp.eq.s32 %p1, %r27, 65535;
    setp.hi.u32 %p1, %r3, 7;
    @%p1 selp.b32 %r23, %r25, %r19, %p1;
    xor.b32 %r21, %r19, %r3;
    cvt.u64.u32 %rd6, %r19;
    setp.le.s32 %p3, %r25, %r19;
    add.s32 %r20, %r25, %r19;
    mad.lo.s32 %r26, %r20, %r19, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
