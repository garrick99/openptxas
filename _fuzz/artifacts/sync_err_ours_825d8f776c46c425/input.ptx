.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r17, %r3, %r3;
    shl.b32 %r17, %r3, 30;
    setp.lt.u32 %p4, %r17, 2;
    @%p4 mul.lo.s32 %r27, %r3, 8;
    xor.b32 %r7, %r17, %r17;
    sub.u32 %r23, %r3, 5;
    min.s32 %r26, %r23, 1;
    setp.lt.s32 %p2, %r3, 32;
    @!%p2 cvt.s64.s32 %rd9, %r26;
    sub.s64 %rd7, %rd9, %rd9;
    shl.b64 %rd15, %rd9, 7;
    mul.lo.u64 %rd5, %rd15, %rd9;
    max.s32 %r17, %r3, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
