.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    shr.u64 %rd6, %rd11, 0;
    sub.s32 %r19, %r3, 16;
    xor.b32 %r23, %r3, %r19;
    mul.wide.s32 %rd9, %r23, %r23;
    min.u32 %r21, %r3, %r23;
    cvt.u32.u64 %r27, %rd9;
    shr.s32 %r26, %r19, 4;
    cvt.s64.s32 %rd6, %r19;
    mad.lo.s32 %r26, %r26, %r23, %r3;
    cvt.u64.u32 %rd13, %r3;
    sub.s32 %r18, %r21, %r19;
    cvt.u32.u64 %r18, %rd9;
    cvt.u64.u32 %rd13, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
