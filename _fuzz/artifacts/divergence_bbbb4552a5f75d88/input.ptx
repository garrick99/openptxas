.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    shl.b32 %r4, %r3, 2;
    mul.wide.u32 %rd15, %r3, %r4;
    sub.s32 %r18, %r3, 7;
    cvt.s64.s32 %rd8, %r18;
    mul.lo.u32 %r9, %r4, 2147483648;
    min.u32 %r6, %r3, 256;
    mul.lo.u32 %r25, %r4, 65535;
    min.u32 %r14, %r6, 2147483647;
    setp.lo.u32 %p3, %r9, 2;
    @%p3 max.u32 %r27, %r14, %r25;
    cvt.u64.u32 %rd8, %r3;
    mul.wide.u32 %rd12, %r14, %r14;
    shl.b64 %rd13, %rd15, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
