.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r17, %r3, 16;
    setp.ls.u32 %p4, %r3, 32;
    @%p4 mul.wide.u32 %rd13, %r17, %r3;
    min.s64 %rd5, %rd13, %rd13;
    xor.b32 %r21, %r17, %r17;
    or.b32 %r15, %r21, 0;
    mul.wide.u32 %rd14, %r15, %r17;
    selp.b32 %r11, %r21, %r3, %p4;
    cvt.s32.s64 %r11, %rd5;
    add.s32 %r19, %r17, 2;
    setp.eq.u32 %p3, %r17, 4294967295;
    cvt.u64.u32 %rd5, %r3;
    sub.s32 %r5, %r19, %r3;
    setp.ne.u32 %p3, %r19, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
