.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r21, %r3, 255;
    max.u32 %r19, %r21, 4294967295;
    mad.lo.s32 %r7, %r3, %r19, %r19;
    add.s32 %r17, %r3, 2;
    cvt.u64.u32 %rd5, %r3;
    and.b32 %r7, %r7, 2;
    mad.lo.s32 %r14, %r7, %r19, %r7;
    shr.s64 %rd10, %rd5, 3;
    shr.u32 %r25, %r7, 0;
    mad.lo.u32 %r4, %r19, %r3, %r21;
    cvt.s64.s32 %rd5, %r19;
    shr.s32 %r20, %r14, 31;
    sub.s32 %r25, %r19, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
