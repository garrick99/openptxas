.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r10, %r3, 2;
    max.u32 %r11, %r10, %r3;
    max.s32 %r7, %r11, %r10;
    sub.s32 %r8, %r10, %r10;
    or.b32 %r27, %r10, 32;
    mul.wide.s32 %rd8, %r10, %r10;
    max.s32 %r19, %r8, %r11;
    cvt.s32.s64 %r18, %rd8;
    setp.le.s32 %p2, %r8, %r3;
    @%p2 shr.u64 %rd9, %rd8, 4;
    cvt.s32.s64 %r20, %rd9;
    cvt.s32.s64 %r27, %rd8;
    selp.b32 %r19, %r18, %r7, %p2;
    mul.wide.u32 %rd13, %r11, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
