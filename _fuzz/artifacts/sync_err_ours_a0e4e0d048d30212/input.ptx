.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    sub.s64 %rd8, %rd10, %rd10;
    max.u32 %r27, %r3, 3;
    setp.eq.u32 %p3, %r3, 1;
    add.s32 %r7, %r27, %r27;
    selp.b32 %r24, %r7, %r7, %p3;
    add.s32 %r8, %r24, 1;
    min.s64 %rd11, %rd10, %rd10;
    setp.le.s32 %p4, %r27, %r8;
    @%p4 shl.b32 %r11, %r3, 15;
    mul.lo.s32 %r17, %r24, 65536;
    cvt.s64.s32 %rd6, %r8;
    shr.s64 %rd7, %rd8, 33;
    shr.u32 %r4, %r17, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
