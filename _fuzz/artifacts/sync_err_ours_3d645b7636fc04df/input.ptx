.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    min.s64 %rd10, %rd14, %rd14;
    max.s32 %r15, %r3, 4294967295;
    and.b32 %r11, %r3, %r15;
    setp.ge.u32 %p2, %r15, %r11;
    setp.gt.s32 %p4, %r11, %r15;
    or.b64 %rd11, %rd14, %rd14;
    min.s32 %r21, %r3, %r15;
    setp.ne.s32 %p2, %r15, %r3;
    @%p2 selp.b32 %r19, %r15, %r11, %p2;
    selp.b32 %r6, %r19, %r11, %p4;
    setp.lt.s32 %p2, %r11, 8;
    @!%p2 and.b32 %r6, %r11, %r6;
    mul.lo.u32 %r20, %r19, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
