.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r9, %r3, %r3;
    cvt.s64.s32 %rd5, %r9;
    cvt.u32.u64 %r16, %rd5;
    cvt.s32.s64 %r17, %rd5;
    shr.s32 %r24, %r9, 31;
    sub.u32 %r24, %r24, %r16;
    setp.lt.u32 %p2, %r17, %r9;
    min.s32 %r13, %r3, 4;
    min.s32 %r9, %r24, 4294967295;
    and.b64 %rd6, %rd5, %rd5;
    add.u64 %rd11, %rd6, %rd5;
    shr.u32 %r16, %r16, 3;
    or.b32 %r9, %r17, 4;
    mul.wide.s32 %rd5, %r3, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
