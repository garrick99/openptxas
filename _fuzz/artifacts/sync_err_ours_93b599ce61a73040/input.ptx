.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r19, %r3, 7;
    mul.wide.s32 %rd14, %r19, %r19;
    shr.s32 %r25, %r3, 15;
    setp.ge.u32 %p4, %r3, 65535;
    @%p4 and.b32 %r27, %r25, 5;
    cvt.s32.s64 %r20, %rd14;
    add.u64 %rd6, %rd14, %rd14;
    shr.u32 %r19, %r19, 0;
    sub.s32 %r25, %r25, %r3;
    selp.b32 %r26, %r25, %r20, %p4;
    max.s32 %r19, %r26, %r19;
    mul.wide.u32 %rd11, %r25, %r3;
    mul.wide.s32 %rd14, %r19, %r19;
    cvt.u64.u32 %rd12, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
