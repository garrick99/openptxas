.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r18, %r3, %r3;
    sub.s32 %r7, %r3, 64;
    cvt.s64.s32 %rd13, %r18;
    shr.u32 %r23, %r7, 31;
    min.s32 %r4, %r7, %r7;
    shr.s32 %r14, %r3, 31;
    shr.u32 %r22, %r7, 4;
    setp.ls.u32 %p4, %r4, %r3;
    @!%p4 max.u32 %r17, %r18, %r4;
    selp.b32 %r22, %r7, %r17, %p4;
    xor.b32 %r27, %r22, %r23;
    setp.le.s32 %p1, %r3, %r22;
    @!%p1 mul.wide.u32 %rd6, %r17, %r3;
    and.b32 %r24, %r14, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
