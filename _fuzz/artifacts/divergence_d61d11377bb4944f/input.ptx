.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r13, %r3, 3;
    mul.wide.u32 %rd10, %r13, %r3;
    setp.eq.s32 %p3, %r3, %r13;
    shr.s32 %r16, %r3, 7;
    setp.ge.u32 %p2, %r16, 255;
    add.u32 %r10, %r3, %r3;
    min.s32 %r24, %r13, %r3;
    shr.s64 %rd15, %rd10, 16;
    setp.le.s32 %p2, %r16, %r24;
    @!%p2 add.s32 %r7, %r13, %r10;
    cvt.u64.u32 %rd10, %r3;
    cvt.s64.s32 %rd7, %r24;
    shr.u64 %rd14, %rd10, 2;
    and.b64 %rd10, %rd15, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
