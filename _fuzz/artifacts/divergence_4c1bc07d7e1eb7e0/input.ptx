.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r20, %r3, 1;
    mul.lo.u32 %r26, %r20, 1;
    cvt.u64.u32 %rd15, %r26;
    shr.u32 %r11, %r3, 16;
    shr.u64 %rd8, %rd15, 32;
    xor.b64 %rd15, %rd8, %rd15;
    mad.lo.u32 %r25, %r11, %r11, %r3;
    cvt.s32.s64 %r13, %rd8;
    max.u32 %r24, %r20, %r26;
    max.u32 %r12, %r13, %r3;
    mul.lo.u32 %r8, %r13, 16;
    mul.lo.u32 %r11, %r11, %r11;
    setp.lt.s32 %p2, %r24, %r25;
    @%p2 xor.b32 %r18, %r20, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
