.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r21, %r3, 30;
    add.u32 %r23, %r3, %r21;
    mul.wide.s32 %rd10, %r21, %r21;
    setp.eq.u32 %p1, %r23, %r21;
    @%p1 mul.wide.u32 %rd13, %r3, %r21;
    setp.le.u32 %p2, %r3, %r23;
    @%p2 xor.b32 %r15, %r3, %r23;
    selp.b32 %r5, %r21, %r15, %p1;
    sub.s32 %r9, %r21, %r3;
    shr.u32 %r26, %r3, 30;
    shl.b64 %rd10, %rd13, 62;
    min.u32 %r6, %r23, 15;
    sub.s32 %r4, %r5, %r3;
    mul.lo.s32 %r7, %r3, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
