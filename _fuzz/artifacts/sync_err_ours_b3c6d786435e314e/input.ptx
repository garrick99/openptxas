.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r19, %r3, 4;
    add.u32 %r21, %r19, %r19;
    cvt.u64.u32 %rd5, %r19;
    max.s32 %r6, %r19, %r19;
    sub.s32 %r23, %r21, 3;
    min.u64 %rd6, %rd5, %rd5;
    mul.lo.u32 %r12, %r23, %r23;
    xor.b32 %r20, %r19, %r21;
    cvt.u64.u32 %rd12, %r20;
    xor.b32 %r27, %r6, %r12;
    shr.s32 %r27, %r23, 3;
    shr.s32 %r5, %r19, 16;
    shl.b32 %r21, %r20, 7;
    setp.gt.s32 %p2, %r3, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
