.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    mul.wide.s32 %rd6, %r3, %r3;
    setp.ge.s32 %p4, %r3, %r3;
    xor.b32 %r15, %r3, 64;
    mul.wide.u32 %rd11, %r3, %r3;
    shr.s32 %r26, %r15, 3;
    shr.s32 %r9, %r3, 30;
    shr.u32 %r8, %r15, 1;
    setp.ge.s32 %p1, %r9, %r26;
    @%p1 sub.u64 %rd13, %rd12, %rd11;
    setp.hs.u32 %p1, %r9, %r9;
    @%p1 max.s32 %r10, %r8, %r8;
    shr.s64 %rd15, %rd6, 33;
    and.b32 %r14, %r26, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
