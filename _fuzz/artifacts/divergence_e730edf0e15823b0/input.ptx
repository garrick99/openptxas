.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r26, %r3, %r3;
    setp.lo.u32 %p4, %r26, 4294967295;
    @%p4 min.s32 %r25, %r26, %r3;
    min.s32 %r16, %r26, %r3;
    cvt.u64.u32 %rd10, %r25;
    sub.u32 %r15, %r26, 7;
    mul.wide.u32 %rd14, %r15, %r26;
    sub.s32 %r12, %r15, 5;
    mul.wide.u32 %rd14, %r26, %r16;
    mul.lo.s32 %r10, %r25, %r15;
    xor.b32 %r21, %r25, %r10;
    and.b32 %r9, %r26, %r25;
    mad.lo.s32 %r6, %r15, %r10, %r3;
    xor.b32 %r7, %r12, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
