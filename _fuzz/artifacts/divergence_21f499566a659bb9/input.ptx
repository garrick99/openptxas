.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfe.u32 %r8, %r3, 0, 32;
    sub.u32 %r13, %r8, 3;
    bfi.b32 %r20, %r13, %r8, 8, 2;
    bfi.b32 %r15, %r3, %r8, 23, 32;
    bfe.s32 %r14, %r20, 31, 8;
    clz.b32 %r21, %r13;
    bfe.s32 %r21, %r8, 16, 4;
    bfi.b32 %r4, %r13, %r3, 24, 16;
    bfe.s32 %r11, %r15, 23, 31;
    bfi.b32 %r5, %r8, %r13, 16, 24;
    bfe.s32 %r5, %r15, 1, 2;
    max.u32 %r11, %r4, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
