.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r16, %r3, 65536;
    mad.lo.u32 %r18, %r16, %r3, %r3;
    and.b32 %r22, %r16, %r16;
    cvt.u64.u32 %rd6, %r3;
    sub.s32 %r26, %r16, %r3;
    shl.b32 %r10, %r16, 7;
    setp.ls.u32 %p3, %r3, 64;
    @%p3 selp.b32 %r4, %r16, %r10, %p3;
    add.s32 %r5, %r22, 65536;
    or.b32 %r27, %r18, %r16;
    sub.u64 %rd14, %rd6, %rd6;
    selp.b32 %r7, %r27, %r5, %p3;
    setp.lt.u32 %p1, %r4, %r10;
    add.s32 %r23, %r10, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
