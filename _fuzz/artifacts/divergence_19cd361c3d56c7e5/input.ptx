    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    mad.lo.u32 %r5, %r3, %r3, %r3;
    mad.lo.s32 %r12, %r5, %r5, %r3;
    shr.s32 %r4, %r3, 30;
    shr.s64 %rd6, %rd11, 33;
    or.b64 %rd13, %rd11, %rd6;
    add.s64 %rd7, %rd6, %rd11;
    add.u32 %r17, %r4, 32;
    shr.s32 %r22, %r17, 3;
    shr.s32 %r23, %r5, 15;
    setp.eq.u32 %p3, %r4, 2147483648;
    setp.gt.s32 %p1, %r12, 64;
    @!%p1 max.u32 %r26, %r12, %r17;
    max.u32 %r16, %r26, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
