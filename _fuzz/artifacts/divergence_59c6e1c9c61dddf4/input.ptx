.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r20, %r3, 7;
    cvt.u64.u32 %rd5, %r3;
    setp.hs.u32 %p3, %r3, 15;
    shr.u32 %r19, %r20, 31;
    xor.b32 %r16, %r19, %r20;
    shr.u64 %rd10, %rd5, 7;
    mul.lo.s32 %r13, %r16, %r19;
    cvt.u64.u32 %rd14, %r20;
    shr.u64 %rd15, %rd14, 3;
    xor.b64 %rd13, %rd15, %rd10;
    mul.wide.s32 %rd10, %r20, %r16;
    setp.ge.u32 %p4, %r13, %r16;
    @!%p4 or.b32 %r6, %r19, 2147483648;
    add.u32 %r25, %r6, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
