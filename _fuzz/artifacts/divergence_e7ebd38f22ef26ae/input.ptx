.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r16, %r3, 0;
    mul.lo.s32 %r25, %r3, 4;
    max.u32 %r24, %r16, 4;
    cvt.u64.u32 %rd6, %r25;
    min.u32 %r16, %r25, 8;
    shr.s64 %rd12, %rd6, 63;
    shr.s64 %rd9, %rd12, 2;
    mad.lo.s32 %r24, %r16, %r16, %r24;
    min.u32 %r22, %r3, %r3;
    mul.lo.u32 %r4, %r3, 1;
    setp.hi.u32 %p4, %r4, 0;
    @%p4 or.b32 %r4, %r25, %r24;
    mul.lo.s32 %r8, %r24, %r3;
    mul.lo.u32 %r9, %r24, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
