.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r20, %r3, %r3;
    shr.s32 %r27, %r20, 7;
    mul.lo.s32 %r9, %r20, %r27;
    mad.lo.u32 %r5, %r9, %r9, %r27;
    cvt.s64.s32 %rd6, %r20;
    sub.u32 %r22, %r3, %r9;
    mul.wide.u32 %rd15, %r9, %r27;
    mul.wide.u32 %rd12, %r22, %r3;
    shl.b32 %r6, %r5, 3;
    cvt.s32.s64 %r8, %rd15;
    mul.wide.u32 %rd14, %r9, %r6;
    max.u32 %r6, %r20, 4294967295;
    mul.lo.u32 %r7, %r6, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
