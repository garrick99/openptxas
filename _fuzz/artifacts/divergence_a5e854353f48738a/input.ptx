.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r21, %r3, %r3;
    max.u32 %r4, %r3, 256;
    sub.s32 %r22, %r21, %r21;
    mul.wide.s32 %rd14, %r22, %r3;
    or.b64 %rd14, %rd14, %rd14;
    cvt.u64.u32 %rd15, %r4;
    min.u32 %r5, %r4, %r3;
    mul.lo.u64 %rd7, %rd15, %rd15;
    mad.lo.u32 %r14, %r4, %r4, %r5;
    shl.b32 %r23, %r4, 3;
    or.b32 %r4, %r21, %r23;
    or.b64 %rd11, %rd15, %rd14;
    setp.gt.s32 %p2, %r4, %r23;
    @%p2 sub.u32 %r8, %r3, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
