.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r14, %r3, 31;
    setp.ge.s32 %p1, %r14, %r14;
    @!%p1 and.b32 %r22, %r3, 65536;
    shr.s32 %r6, %r22, 2;
    shl.b32 %r12, %r22, 0;
    mul.wide.s32 %rd12, %r14, %r12;
    shl.b32 %r18, %r14, 7;
    shr.s64 %rd15, %rd12, 2;
    shr.u64 %rd8, %rd12, 7;
    add.u32 %r13, %r6, %r14;
    max.u32 %r22, %r3, %r14;
    cvt.s32.s64 %r18, %rd15;
    sub.u32 %r24, %r3, %r12;
    selp.b32 %r14, %r24, %r18, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
