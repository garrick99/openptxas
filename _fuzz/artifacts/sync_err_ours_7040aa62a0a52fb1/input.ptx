.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    min.s64 %rd15, %rd14, %rd14;
    mad.lo.s32 %r9, %r3, %r3, %r3;
    min.s32 %r8, %r9, 7;
    shr.u64 %rd15, %rd14, 33;
    setp.ne.s32 %p3, %r3, 16;
    @!%p3 max.s32 %r6, %r3, %r9;
    add.s32 %r25, %r3, %r9;
    add.u32 %r11, %r8, %r6;
    sub.u64 %rd11, %rd14, %rd15;
    mul.wide.s32 %rd10, %r3, %r3;
    cvt.u64.u32 %rd8, %r6;
    add.s64 %rd15, %rd14, %rd8;
    setp.lt.u32 %p4, %r6, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
