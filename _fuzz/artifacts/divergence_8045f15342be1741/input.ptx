.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r19, %r3, %r3;
    mul.wide.u32 %rd13, %r19, %r3;
    sub.s64 %rd13, %rd13, %rd13;
    mul.lo.u64 %rd5, %rd13, %rd13;
    mul.wide.u32 %rd6, %r3, %r3;
    setp.eq.s32 %p1, %r19, 16;
    @%p1 add.u32 %r26, %r19, %r19;
    sub.u32 %r20, %r26, %r26;
    cvt.u64.u32 %rd6, %r19;
    shl.b32 %r10, %r26, 2;
    selp.b32 %r13, %r20, %r10, %p1;
    mad.lo.s32 %r8, %r19, %r26, %r20;
    min.u32 %r16, %r19, 32;
    cvt.s64.s32 %rd14, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
