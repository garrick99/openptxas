.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r12, %r3, %r3;
    cvt.s64.s32 %rd15, %r12;
    mul.wide.u32 %rd10, %r3, %r3;
    min.u32 %r14, %r3, 256;
    setp.ls.u32 %p1, %r12, 2;
    cvt.u32.u64 %r9, %rd15;
    shr.s32 %r4, %r12, 31;
    min.s64 %rd7, %rd15, %rd10;
    selp.b32 %r22, %r4, %r4, %p1;
    setp.ne.s32 %p2, %r9, %r22;
    sub.s32 %r25, %r4, 32;
    max.u32 %r20, %r14, %r4;
    cvt.s64.s32 %rd9, %r20;
    xor.b32 %r16, %r22, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
