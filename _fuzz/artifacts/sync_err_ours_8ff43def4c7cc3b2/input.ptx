.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r13, %r3, %r3;
    shl.b32 %r25, %r13, 16;
    cvt.s64.s32 %rd13, %r3;
    or.b32 %r11, %r13, %r13;
    add.s32 %r20, %r13, 7;
    max.s32 %r19, %r11, %r3;
    shr.s32 %r18, %r19, 16;
    shr.u32 %r11, %r19, 1;
    shr.u32 %r22, %r11, 4;
    cvt.u64.u32 %rd8, %r25;
    min.s32 %r18, %r19, %r18;
    shr.s64 %rd10, %rd13, 62;
    setp.le.s32 %p4, %r25, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
