.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r11, %r3, %r3;
    cvt.s64.s32 %rd9, %r3;
    max.u32 %r17, %r3, 8;
    sub.s32 %r23, %r3, %r11;
    mul.wide.u32 %rd11, %r23, %r3;
    max.s32 %r26, %r17, %r23;
    or.b32 %r26, %r26, %r11;
    setp.hi.u32 %p2, %r26, 5;
    @%p2 shr.u32 %r9, %r17, 0;
    min.u64 %rd8, %rd9, %rd9;
    shr.u32 %r27, %r11, 3;
    mul.wide.u32 %rd15, %r11, %r26;
    selp.b32 %r17, %r17, %r26, %p2;
    max.u64 %rd13, %rd8, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
