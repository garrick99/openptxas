.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r16, %r3, 63;
    setp.hi.u32 %p3, %r16, %r16;
    and.b32 %r14, %r16, %r3;
    shr.s32 %r22, %r3, 0;
    cvt.u64.u32 %rd14, %r3;
    shr.u32 %r22, %r16, 1;
    mad.lo.s32 %r6, %r22, %r22, %r16;
    max.s32 %r24, %r14, %r22;
    selp.b32 %r15, %r6, %r24, %p3;
    sub.s32 %r25, %r3, 31;
    add.u32 %r25, %r15, %r16;
    cvt.u64.u32 %rd5, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
