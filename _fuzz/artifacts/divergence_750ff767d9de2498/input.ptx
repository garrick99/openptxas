.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r25, %r3, %r3, %r3;
    setp.gt.u32 %p4, %r25, 255;
    @!%p4 and.b32 %r8, %r3, 4;
    mad.lo.s32 %r22, %r8, %r25, %r3;
    and.b32 %r21, %r3, 32;
    setp.lt.s32 %p2, %r3, %r22;
    @%p2 sub.s32 %r24, %r3, %r3;
    selp.b32 %r20, %r22, %r25, %p2;
    mul.lo.s32 %r17, %r22, %r24;
    setp.gt.u32 %p2, %r21, %r17;
    @%p2 selp.b32 %r17, %r3, %r22, %p4;
    mul.lo.s32 %r22, %r17, %r3;
    shr.u32 %r13, %r24, 2;
    min.u32 %r20, %r17, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
