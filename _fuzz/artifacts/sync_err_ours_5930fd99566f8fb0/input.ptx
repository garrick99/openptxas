.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    sub.s32 %r13, %r3, 4294967295;
    shr.u64 %rd14, %rd7, 16;
    shl.b32 %r21, %r13, 4;
    setp.ls.u32 %p4, %r21, %r3;
    shr.u32 %r26, %r13, 1;
    add.u64 %rd10, %rd7, %rd14;
    max.s32 %r21, %r26, %r13;
    add.u32 %r27, %r3, %r21;
    selp.b32 %r25, %r27, %r21, %p4;
    mul.lo.u32 %r22, %r27, %r26;
    mad.lo.s32 %r7, %r25, %r3, %r26;
    or.b64 %rd6, %rd7, %rd10;
    setp.lt.u32 %p3, %r7, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
