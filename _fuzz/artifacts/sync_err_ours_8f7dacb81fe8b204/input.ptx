.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p1, %r3, %r3;
    @!%p1 cvt.u64.u32 %rd13, %r3;
    cvt.s32.s64 %r19, %rd13;
    mad.lo.s32 %r14, %r19, %r3, %r19;
    add.s32 %r24, %r19, 64;
    or.b32 %r6, %r19, %r14;
    xor.b32 %r7, %r3, %r24;
    cvt.s32.s64 %r12, %rd13;
    setp.ge.s32 %p4, %r12, %r14;
    setp.ge.u32 %p1, %r19, %r24;
    @%p1 cvt.u32.u64 %r21, %rd13;
    max.u32 %r27, %r12, %r7;
    or.b32 %r4, %r19, %r27;
    min.u32 %r16, %r3, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
