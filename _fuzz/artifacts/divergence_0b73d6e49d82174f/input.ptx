.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r18, %r3, %r3, %r3;
    cvt.s64.s32 %rd7, %r3;
    mad.lo.s32 %r4, %r3, %r3, %r18;
    setp.ge.s32 %p1, %r3, %r4;
    @!%p1 min.u32 %r13, %r3, %r4;
    shr.u32 %r18, %r13, 2;
    shl.b32 %r25, %r13, 1;
    xor.b32 %r24, %r3, %r18;
    setp.gt.s32 %p2, %r3, %r24;
    @%p2 and.b32 %r25, %r25, %r18;
    selp.b32 %r27, %r4, %r24, %p1;
    cvt.s64.s32 %rd5, %r27;
    mul.wide.u32 %rd10, %r18, %r4;
    shr.s32 %r17, %r18, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
