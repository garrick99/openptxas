.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r13, %r3, 16;
    shl.b32 %r8, %r13, 7;
    cvt.u64.u32 %rd15, %r8;
    mul.lo.s64 %rd8, %rd15, %rd15;
    mul.wide.u32 %rd14, %r8, %r3;
    mad.lo.u32 %r24, %r13, %r3, %r3;
    setp.hi.u32 %p2, %r3, 65535;
    @%p2 min.u32 %r19, %r3, %r8;
    max.u32 %r18, %r24, %r3;
    mad.lo.u32 %r7, %r3, %r18, %r3;
    min.u32 %r7, %r8, 32;
    add.u32 %r24, %r3, %r7;
    mul.lo.s32 %r8, %r24, 2147483647;
    max.u32 %r5, %r3, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
