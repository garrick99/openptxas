.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    cvt.s64.s32 %rd15, %r3;
    mul.lo.s32 %r25, %r3, 2147483648;
    cvt.u64.u32 %rd15, %r25;
    or.b32 %r9, %r25, %r25;
    sub.u32 %r6, %r25, 2;
    cvt.s32.s64 %r7, %rd15;
    cvt.s64.s32 %rd8, %r25;
    shr.u64 %rd8, %rd8, 4;
    max.u32 %r23, %r3, %r9;
    shl.b64 %rd7, %rd15, 1;
    add.u32 %r4, %r9, 256;
    shl.b64 %rd11, %rd15, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
