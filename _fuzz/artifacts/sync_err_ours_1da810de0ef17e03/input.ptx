.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r8, %r3, 256;
    add.s32 %r20, %r8, %r8;
    cvt.u64.u32 %rd12, %r20;
    shl.b32 %r15, %r8, 7;
    xor.b32 %r6, %r3, %r15;
    setp.le.s32 %p1, %r3, %r20;
    or.b32 %r24, %r3, %r15;
    xor.b32 %r17, %r24, 256;
    shl.b32 %r19, %r8, 4;
    selp.b32 %r6, %r19, %r15, %p1;
    add.u32 %r9, %r20, %r3;
    shl.b32 %r8, %r19, 4;
    mul.wide.u32 %rd6, %r6, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
