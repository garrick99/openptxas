.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r9, %r3, %r3;
    mul.wide.s32 %rd10, %r9, %r9;
    shr.u64 %rd14, %rd10, 62;
    max.s32 %r17, %r9, 0;
    min.s32 %r14, %r9, 5;
    min.u32 %r6, %r9, 2147483647;
    or.b64 %rd6, %rd14, %rd10;
    setp.lo.u32 %p1, %r3, %r9;
    @%p1 add.s32 %r11, %r3, 16;
    setp.lt.s32 %p3, %r14, %r9;
    @%p3 xor.b64 %rd5, %rd10, %rd14;
    cvt.u64.u32 %rd13, %r6;
    max.u32 %r4, %r9, %r11;
    max.s32 %r9, %r3, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
