.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    mul.lo.u64 %rd6, %rd6, %rd6;
    min.s32 %r6, %r3, 16;
    xor.b32 %r19, %r6, %r6;
    max.s32 %r17, %r3, 255;
    shr.u64 %rd12, %rd6, 7;
    or.b32 %r26, %r19, 0;
    shr.u32 %r26, %r3, 31;
    or.b32 %r17, %r3, %r3;
    cvt.u32.u64 %r7, %rd12;
    and.b64 %rd14, %rd6, %rd6;
    shr.u32 %r18, %r6, 2;
    mul.wide.s32 %rd14, %r26, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
