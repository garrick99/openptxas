.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r11, %r3, 65535;
    mul.lo.s32 %r17, %r11, %r3;
    max.u32 %r27, %r3, %r17;
    mad.lo.s32 %r17, %r3, %r17, %r11;
    mul.lo.u32 %r9, %r27, %r27;
    shr.s32 %r11, %r17, 15;
    setp.lt.u32 %p1, %r9, 65536;
    @!%p1 cvt.s64.s32 %rd8, %r17;
    or.b32 %r4, %r27, %r3;
    cvt.s32.s64 %r12, %rd8;
    sub.s32 %r5, %r12, %r27;
    shr.s64 %rd10, %rd8, 30;
    max.u32 %r21, %r9, %r27;
    cvt.u64.u32 %rd9, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
