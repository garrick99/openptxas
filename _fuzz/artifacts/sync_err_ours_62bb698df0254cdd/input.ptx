.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r21, %r3, %r3;
    setp.gt.u32 %p4, %r3, %r3;
    @%p4 selp.b32 %r5, %r3, %r21, %p4;
    selp.b32 %r23, %r21, %r3, %p4;
    sub.u32 %r4, %r5, 65535;
    mul.wide.u32 %rd9, %r4, %r23;
    mad.lo.s32 %r26, %r3, %r21, %r21;
    shl.b32 %r8, %r4, 3;
    mul.lo.s32 %r26, %r23, 0;
    or.b32 %r25, %r3, %r4;
    sub.s32 %r9, %r21, %r23;
    add.s32 %r27, %r21, 32;
    and.b32 %r6, %r21, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
