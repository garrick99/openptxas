.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r7, %r3, 15;
    min.s32 %r24, %r7, %r7;
    max.u32 %r5, %r24, %r3;
    and.b32 %r16, %r3, 32;
    min.u32 %r20, %r7, %r3;
    mad.lo.s32 %r13, %r24, %r20, %r5;
    cvt.u64.u32 %rd12, %r20;
    setp.lt.u32 %p2, %r13, %r3;
    @!%p2 sub.s64 %rd13, %rd12, %rd12;
    selp.b32 %r24, %r16, %r5, %p2;
    mul.wide.s32 %rd10, %r16, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
