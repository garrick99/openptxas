.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r25, %r3, %r3;
    or.b32 %r5, %r25, 31;
    shr.u32 %r11, %r3, 4;
    mul.wide.s32 %rd5, %r3, %r11;
    max.u32 %r27, %r5, %r5;
    min.u32 %r8, %r27, 5;
    mul.lo.s64 %rd13, %rd5, %rd5;
    add.u32 %r8, %r27, %r27;
    mad.lo.s32 %r23, %r8, %r11, %r25;
    setp.ne.u32 %p2, %r5, %r27;
    @%p2 shr.u32 %r21, %r5, 4;
    mul.lo.s32 %r9, %r21, 256;
    selp.b32 %r11, %r8, %r9, %p2;
    setp.lt.s32 %p4, %r21, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
