.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd11, %r3, %r3;
    or.b32 %r15, %r3, 64;
    mul.lo.u32 %r8, %r3, 1;
    mul.lo.u32 %r9, %r8, 256;
    mad.lo.s32 %r17, %r3, %r8, %r9;
    setp.ne.s32 %p2, %r17, %r15;
    mul.wide.u32 %rd13, %r15, %r8;
    mul.wide.s32 %rd13, %r8, %r15;
    cvt.s32.s64 %r4, %rd11;
    max.s32 %r14, %r9, 0;
    and.b32 %r24, %r15, 4;
    mul.lo.s32 %r4, %r9, 256;
    or.b32 %r10, %r4, %r3;
    mad.lo.u32 %r22, %r14, %r8, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
