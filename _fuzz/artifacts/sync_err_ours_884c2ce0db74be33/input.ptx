.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p3, %r3, %r3;
    @%p3 cvt.s64.s32 %rd9, %r3;
    shl.b32 %r21, %r3, 31;
    mul.lo.u32 %r20, %r3, 65535;
    shr.s32 %r21, %r21, 30;
    shr.u32 %r11, %r20, 2;
    mul.lo.u32 %r18, %r20, %r21;
    selp.b32 %r5, %r3, %r21, %p3;
    setp.gt.s32 %p2, %r5, %r20;
    @%p2 mad.lo.s32 %r25, %r21, %r18, %r5;
    min.s32 %r19, %r21, %r11;
    mul.wide.u32 %rd13, %r20, %r25;
    cvt.u32.u64 %r4, %rd9;
    setp.hi.u32 %p4, %r18, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
