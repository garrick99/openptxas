.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p2, %r3, %r3;
    @%p2 max.u32 %r13, %r3, 31;
    add.s32 %r20, %r13, 65536;
    xor.b32 %r5, %r3, %r20;
    add.u32 %r16, %r20, %r3;
    max.s32 %r18, %r5, 4294967295;
    min.s32 %r11, %r5, 2147483647;
    cvt.s64.s32 %rd10, %r11;
    xor.b32 %r11, %r11, 3;
    sub.u32 %r17, %r11, 4;
    sub.s64 %rd13, %rd10, %rd10;
    min.u32 %r26, %r5, %r3;
    mul.wide.u32 %rd8, %r20, %r5;
    min.u32 %r15, %r17, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
