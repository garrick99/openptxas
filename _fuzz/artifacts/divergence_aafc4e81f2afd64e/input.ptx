.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.bfly.b32 %r17, %r3, 1, 0x1f, -1;
    setp.lt.u32 %p3, %r17, %r3;
    vote.sync.ballot.b32 %r5, %p3, -1;
    setp.gt.u32 %p1, %r5, 2;
    vote.sync.ballot.b32 %r12, %p1, -1;
    xor.b32 %r4, %r12, %r12;
    sub.u32 %r8, %r12, %r5;
    setp.eq.u32 %p1, %r4, %r5;
    vote.sync.ballot.b32 %r6, %p1, -1;
    setp.eq.u32 %p2, %r6, 2;
    vote.sync.ballot.b32 %r17, %p2, -1;
    setp.lt.u32 %p3, %r6, 16;
    vote.sync.ballot.b32 %r8, %p3, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
