.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p4, %r3, 65535;
    @!%p4 cvt.u64.u32 %rd6, %r3;
    mul.wide.u32 %rd7, %r3, %r3;
    cvt.u32.u64 %r7, %rd6;
    min.u32 %r9, %r7, 65536;
    mul.lo.u64 %rd11, %rd7, %rd7;
    shr.u32 %r24, %r7, 16;
    sub.u32 %r23, %r7, %r9;
    mad.lo.u32 %r7, %r3, %r3, %r24;
    selp.b32 %r12, %r9, %r3, %p4;
    cvt.s32.s64 %r6, %rd6;
    sub.s32 %r9, %r7, 255;
    cvt.u32.u64 %r18, %rd11;
    shr.s32 %r22, %r23, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
