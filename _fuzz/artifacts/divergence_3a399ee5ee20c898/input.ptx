.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r16, %r3, 4;
    xor.b32 %r13, %r3, 4;
    mul.wide.u32 %rd13, %r13, %r3;
    setp.hi.u32 %p4, %r16, 0;
    @%p4 cvt.s32.s64 %r22, %rd13;
    selp.b32 %r22, %r13, %r16, %p4;
    selp.b32 %r25, %r16, %r3, %p4;
    mad.lo.u32 %r24, %r16, %r25, %r13;
    cvt.u32.u64 %r4, %rd13;
    mul.lo.s32 %r18, %r25, 15;
    mul.wide.s32 %rd10, %r25, %r3;
    mul.lo.u32 %r26, %r16, 4294967295;
    max.u32 %r5, %r22, 0;
    setp.hs.u32 %p4, %r16, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
