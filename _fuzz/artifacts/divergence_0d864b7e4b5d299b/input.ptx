.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    shr.s64 %rd15, %rd8, 63;
    add.s32 %r5, %r3, %r3;
    cvt.u64.u32 %rd7, %r3;
    setp.ne.u32 %p3, %r5, %r5;
    @!%p3 add.u64 %rd11, %rd15, %rd8;
    max.u32 %r16, %r5, %r5;
    add.s32 %r10, %r3, 31;
    sub.u32 %r23, %r5, 4;
    mul.wide.u32 %rd6, %r16, %r23;
    setp.le.u32 %p1, %r23, 4;
    @%p1 xor.b32 %r12, %r16, 63;
    cvt.s64.s32 %rd9, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
