.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r27, %r3, 31;
    cvt.s64.s32 %rd8, %r27;
    min.s32 %r5, %r27, %r27;
    shr.s32 %r15, %r5, 1;
    add.u32 %r17, %r5, %r3;
    add.u32 %r13, %r15, %r17;
    min.u32 %r4, %r27, %r15;
    mad.lo.u32 %r10, %r17, %r13, %r17;
    mad.lo.u32 %r23, %r4, %r5, %r27;
    add.s64 %rd12, %rd8, %rd8;
    shl.b64 %rd12, %rd12, 31;
    shl.b32 %r4, %r4, 7;
    mad.lo.s32 %r5, %r15, %r23, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
