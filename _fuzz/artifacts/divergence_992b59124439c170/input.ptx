.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    min.u32 %r20, %r3, 1;
    or.b32 %r22, %r20, %r20;
    cvt.s64.s32 %rd10, %r20;
    sub.u32 %r21, %r3, %r20;
    max.s32 %r13, %r3, %r22;
    mul.lo.u32 %r20, %r3, %r22;
    shr.u64 %rd7, %rd9, 31;
    max.s64 %rd8, %rd10, %rd9;
    mad.lo.u32 %r22, %r21, %r21, %r3;
    cvt.u64.u32 %rd9, %r21;
    mul.wide.s32 %rd7, %r3, %r22;
    cvt.u64.u32 %rd12, %r3;
    xor.b32 %r27, %r13, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
