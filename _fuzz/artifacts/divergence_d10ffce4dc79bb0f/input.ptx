.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p4, %r3, %r3;
    @%p4 add.u32 %r9, %r3, %r3;
    cvt.s64.s32 %rd14, %r3;
    setp.lt.s32 %p1, %r9, 16;
    @%p1 mad.lo.u32 %r23, %r3, %r9, %r3;
    max.s32 %r22, %r3, 2147483647;
    max.s32 %r17, %r3, 4294967295;
    min.s32 %r13, %r22, 31;
    setp.hs.u32 %p1, %r9, 4;
    @%p1 mul.wide.s32 %rd7, %r17, %r13;
    cvt.u32.u64 %r19, %rd7;
    mul.wide.u32 %rd5, %r13, %r23;
    mad.lo.u32 %r5, %r3, %r23, %r17;
    sub.s32 %r17, %r19, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
