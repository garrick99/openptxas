.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r8, %r3, %r3;
    setp.eq.s32 %p1, %r3, 7;
    @%p1 shr.s32 %r17, %r8, 3;
    or.b32 %r5, %r3, 15;
    min.u32 %r23, %r8, %r8;
    shr.s32 %r5, %r23, 30;
    xor.b32 %r12, %r3, %r17;
    add.s32 %r14, %r23, %r3;
    setp.ne.s32 %p3, %r14, %r8;
    @%p3 and.b32 %r11, %r8, 8;
    mad.lo.u32 %r16, %r11, %r23, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
