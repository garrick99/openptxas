.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r14, %r3, 32;
    cvt.u64.u32 %rd15, %r14;
    setp.le.s32 %p3, %r14, %r14;
    @%p3 min.s32 %r9, %r14, 2;
    cvt.u64.u32 %rd12, %r9;
    add.s32 %r24, %r3, %r3;
    and.b64 %rd11, %rd12, %rd12;
    mul.lo.u32 %r6, %r14, 64;
    setp.gt.s32 %p1, %r6, %r6;
    cvt.u32.u64 %r7, %rd15;
    or.b32 %r26, %r14, 2;
    cvt.s32.s64 %r12, %rd11;
    cvt.u32.u64 %r19, %rd11;
    setp.ge.s32 %p2, %r19, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
