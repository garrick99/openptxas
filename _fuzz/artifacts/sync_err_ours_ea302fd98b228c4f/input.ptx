.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r5, %r3, %r3, %r3;
    mul.wide.s32 %rd5, %r5, %r5;
    mul.wide.s32 %rd9, %r5, %r5;
    and.b32 %r18, %r5, 32;
    mad.lo.s32 %r24, %r5, %r5, %r18;
    max.u32 %r15, %r5, %r5;
    setp.ne.s32 %p1, %r18, %r3;
    @!%p1 min.u32 %r4, %r24, 2;
    shl.b64 %rd13, %rd5, 30;
    add.s32 %r15, %r5, 2147483648;
    mul.wide.u32 %rd9, %r3, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
