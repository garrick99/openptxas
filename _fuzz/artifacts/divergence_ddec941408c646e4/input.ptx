.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p1, %r3, 32;
    @%p1 selp.b32 %r4, %r3, %r3, %p1;
    shr.s32 %r11, %r4, 30;
    setp.lt.s32 %p3, %r3, %r11;
    @!%p3 cvt.u64.u32 %rd6, %r4;
    cvt.u64.u32 %rd11, %r3;
    add.u32 %r4, %r11, 0;
    or.b32 %r8, %r4, %r4;
    max.s32 %r9, %r3, %r11;
    and.b32 %r25, %r3, %r8;
    shl.b32 %r26, %r4, 16;
    setp.eq.s32 %p4, %r9, 15;
    @%p4 shl.b32 %r13, %r26, 0;
    sub.s32 %r4, %r8, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
