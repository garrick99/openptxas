.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p3, %r3, 8;
    @%p3 or.b32 %r11, %r3, %r3;
    cvt.s64.s32 %rd14, %r3;
    add.u64 %rd6, %rd14, %rd14;
    cvt.s32.s64 %r13, %rd14;
    sub.u64 %rd5, %rd6, %rd14;
    min.u32 %r14, %r11, %r13;
    mad.lo.u32 %r15, %r13, %r11, %r11;
    setp.lt.s32 %p1, %r3, %r15;
    @%p1 max.s64 %rd6, %rd5, %rd5;
    cvt.s64.s32 %rd10, %r13;
    setp.ne.s32 %p4, %r14, %r13;
    mul.wide.s32 %rd15, %r13, %r13;
    shr.s32 %r23, %r13, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
