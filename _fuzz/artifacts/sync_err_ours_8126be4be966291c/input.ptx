.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r7, %r3, %r3;
    mul.lo.u32 %r19, %r7, 5;
    mul.lo.u32 %r26, %r3, 32;
    mul.wide.u32 %rd14, %r19, %r7;
    shr.s32 %r11, %r3, 3;
    and.b32 %r15, %r7, %r19;
    min.s32 %r27, %r3, %r19;
    max.s32 %r11, %r27, %r11;
    mul.wide.u32 %rd10, %r19, %r19;
    mad.lo.s32 %r24, %r3, %r19, %r11;
    xor.b32 %r18, %r26, %r15;
    mul.lo.s32 %r25, %r7, %r24;
    mul.wide.s32 %rd5, %r3, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
