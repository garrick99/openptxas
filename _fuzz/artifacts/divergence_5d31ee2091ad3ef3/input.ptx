.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r19, %r3, 2;
    shr.u32 %r12, %r19, 1;
    shr.u32 %r27, %r12, 15;
    xor.b32 %r5, %r19, %r3;
    setp.eq.s32 %p4, %r5, %r12;
    @!%p4 mul.wide.u32 %rd10, %r27, %r27;
    mad.lo.u32 %r21, %r27, %r19, %r27;
    selp.b32 %r7, %r21, %r27, %p4;
    mad.lo.u32 %r25, %r21, %r7, %r12;
    min.u32 %r26, %r5, 63;
    and.b32 %r27, %r3, %r26;
    min.u32 %r26, %r25, %r21;
    mad.lo.u32 %r16, %r3, %r25, %r21;
    selp.b32 %r16, %r25, %r26, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
