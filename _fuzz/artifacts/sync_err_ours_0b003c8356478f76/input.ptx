.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r5, %r3, %r3;
    cvt.s64.s32 %rd9, %r3;
    setp.eq.u32 %p1, %r5, 7;
    @%p1 selp.b32 %r23, %r3, %r3, %p1;
    shr.s64 %rd15, %rd9, 62;
    selp.b32 %r24, %r5, %r23, %p1;
    min.u32 %r19, %r24, 31;
    selp.b32 %r6, %r19, %r24, %p1;
    and.b64 %rd7, %rd15, %rd15;
    cvt.s64.s32 %rd6, %r6;
    add.u32 %r15, %r23, %r6;
    sub.s32 %r11, %r24, 255;
    add.s32 %r5, %r15, %r5;
    max.s32 %r27, %r23, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
