.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r22, %r3, %r3;
    mad.lo.u32 %r15, %r22, %r22, %r22;
    mul.lo.u32 %r21, %r15, %r15;
    shr.s32 %r14, %r15, 31;
    setp.gt.s32 %p2, %r14, 31;
    @%p2 mul.lo.u32 %r17, %r21, %r21;
    max.u32 %r26, %r14, %r21;
    cvt.s64.s32 %rd6, %r21;
    and.b64 %rd13, %rd6, %rd6;
    sub.s32 %r4, %r17, 4294967295;
    max.u32 %r25, %r14, %r14;
    selp.b32 %r21, %r3, %r4, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
