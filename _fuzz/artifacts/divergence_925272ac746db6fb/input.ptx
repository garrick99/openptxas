.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r6, %r3, 0;
    mul.lo.u32 %r17, %r3, %r3;
    mul.wide.s32 %rd8, %r6, %r17;
    shl.b64 %rd12, %rd8, 4;
    cvt.s64.s32 %rd11, %r6;
    sub.u32 %r25, %r6, 64;
    shr.s64 %rd15, %rd12, 33;
    xor.b32 %r6, %r3, %r17;
    sub.u32 %r10, %r6, %r25;
    shr.s64 %rd15, %rd11, 0;
    max.s32 %r27, %r3, 4;
    min.u32 %r14, %r25, 15;
    mad.lo.s32 %r5, %r17, %r14, %r10;
    cvt.u64.u32 %rd13, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
