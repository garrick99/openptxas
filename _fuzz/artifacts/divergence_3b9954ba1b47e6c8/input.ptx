.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r6, %r3, 31;
    shr.u32 %r4, %r3, 2;
    cvt.u64.u32 %rd6, %r6;
    cvt.s64.s32 %rd9, %r4;
    and.b64 %rd6, %rd9, %rd9;
    mul.wide.u32 %rd14, %r6, %r6;
    shr.u64 %rd9, %rd9, 15;
    setp.eq.s32 %p2, %r6, 64;
    setp.le.s32 %p2, %r4, 2147483647;
    @%p2 or.b32 %r15, %r6, 2147483648;
    shr.s32 %r18, %r4, 15;
    selp.b32 %r19, %r4, %r4, %p2;
    sub.u64 %rd5, %rd9, %rd9;
    mul.lo.u32 %r22, %r19, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
