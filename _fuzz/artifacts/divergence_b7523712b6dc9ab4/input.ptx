.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r10, %r3, 30;
    and.b32 %r11, %r10, 2147483647;
    mul.lo.s32 %r14, %r3, %r11;
    cvt.s64.s32 %rd14, %r14;
    and.b32 %r23, %r10, %r10;
    and.b32 %r22, %r10, %r23;
    setp.gt.s32 %p4, %r14, 65536;
    sub.s32 %r13, %r14, %r11;
    setp.lt.u32 %p2, %r3, %r14;
    mul.lo.s32 %r19, %r14, 63;
    mul.wide.s32 %rd12, %r14, %r22;
    setp.eq.s32 %p3, %r22, %r19;
    @%p3 add.s32 %r18, %r23, %r19;
    mul.lo.s64 %rd12, %rd14, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
