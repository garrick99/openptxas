.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r20, %r3, %r3;
    shr.u32 %r21, %r3, 30;
    min.s32 %r17, %r20, %r3;
    mad.lo.u32 %r9, %r20, %r3, %r21;
    max.u32 %r16, %r9, 16;
    or.b32 %r24, %r16, 65536;
    cvt.u64.u32 %rd14, %r3;
    max.u32 %r14, %r9, 1;
    cvt.u32.u64 %r18, %rd14;
    max.s64 %rd11, %rd14, %rd14;
    min.s32 %r21, %r16, %r18;
    cvt.s32.s64 %r26, %rd14;
    max.s32 %r7, %r18, %r3;
    mad.lo.s32 %r4, %r26, %r18, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
