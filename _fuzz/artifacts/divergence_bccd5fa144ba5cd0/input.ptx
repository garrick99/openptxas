    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r26, %r3, %r3;
    xor.b32 %r12, %r26, 2147483647;
    setp.le.s32 %p4, %r26, %r3;
    cvt.u64.u32 %rd8, %r26;
    cvt.u32.u64 %r21, %rd8;
    min.u32 %r10, %r21, 3;
    cvt.u32.u64 %r17, %rd8;
