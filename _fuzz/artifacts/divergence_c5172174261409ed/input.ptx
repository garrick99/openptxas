.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    add.u32 %r8, %r3, %r3;
    max.u32 %r14, %r8, 256;
    sub.u32 %r7, %r8, %r14;
    mad.lo.s32 %r13, %r14, %r14, %r7;
    cvt.u64.u32 %rd9, %r14;
    cvt.s32.s64 %r13, %rd9;
    sub.u32 %r16, %r7, %r8;
    mul.wide.s32 %rd7, %r7, %r14;
    mul.wide.u32 %rd9, %r7, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
