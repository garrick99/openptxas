.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    shl.b32 %r15, %r3, 4;
    shr.u32 %r4, %r3, 2;
    max.s32 %r7, %r3, %r3;
    mad.lo.u32 %r4, %r3, %r15, %r7;
    mad.lo.s32 %r21, %r3, %r3, %r4;
    sub.u32 %r14, %r4, %r7;
    sub.u32 %r5, %r7, %r3;
    setp.lt.u32 %p2, %r4, 4;
    @!%p2 or.b32 %r8, %r7, %r7;
    and.b64 %rd11, %rd10, %rd10;
    sub.u32 %r5, %r4, 32;
    shl.b32 %r24, %r7, 30;
    add.u32 %r7, %r24, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
