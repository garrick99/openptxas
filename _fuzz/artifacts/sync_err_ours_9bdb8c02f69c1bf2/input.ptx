.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r25, %r3, 255;
    mul.wide.s32 %rd11, %r25, %r3;
    add.u32 %r23, %r3, 32;
    shr.s64 %rd15, %rd11, 7;
    cvt.s32.s64 %r24, %rd11;
    min.s32 %r22, %r3, 8;
    cvt.u32.u64 %r18, %rd15;
    add.s64 %rd13, %rd15, %rd15;
    cvt.s64.s32 %rd8, %r25;
    sub.u32 %r9, %r18, 8;
    mad.lo.u32 %r5, %r24, %r25, %r23;
    mul.lo.u32 %r9, %r9, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
