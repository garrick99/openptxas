.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r24, %r3, 16;
    mul.lo.s32 %r16, %r3, %r24;
    add.s32 %r9, %r3, %r3;
    setp.lt.s32 %p4, %r3, %r3;
    @%p4 cvt.s64.s32 %rd9, %r3;
    mad.lo.u32 %r11, %r24, %r16, %r16;
    cvt.s64.s32 %rd5, %r11;
    setp.ne.s32 %p4, %r16, 255;
    @!%p4 sub.s32 %r20, %r11, %r11;
    shl.b64 %rd15, %rd9, 47;
    min.s64 %rd9, %rd15, %rd15;
    cvt.u64.u32 %rd12, %r16;
    max.u64 %rd11, %rd15, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
