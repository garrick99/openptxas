.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p1, %r3, 2147483648;
    @!%p1 max.u32 %r11, %r3, 16;
    and.b32 %r15, %r11, %r11;
    xor.b32 %r17, %r11, %r3;
    selp.b32 %r24, %r15, %r11, %p1;
    shl.b32 %r6, %r15, 7;
    mul.lo.u32 %r15, %r6, 16;
    cvt.u64.u32 %rd11, %r11;
    max.u32 %r25, %r17, %r6;
    selp.b32 %r14, %r15, %r24, %p1;
    setp.ne.u32 %p2, %r3, %r3;
    sub.s32 %r16, %r6, %r15;
    add.s32 %r13, %r25, %r15;
    shr.u32 %r25, %r25, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
