.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    shr.s64 %rd6, %rd11, 15;
    mad.lo.s32 %r21, %r3, %r3, %r3;
    setp.lo.u32 %p4, %r21, 255;
    @%p4 mul.wide.s32 %rd7, %r21, %r21;
    mul.lo.u64 %rd15, %rd7, %rd6;
    cvt.s32.s64 %r4, %rd11;
    min.u32 %r20, %r3, 256;
    sub.u32 %r6, %r4, %r20;
    shr.u64 %rd13, %rd7, 15;
    mul.lo.s32 %r27, %r20, 5;
    mul.wide.s32 %rd11, %r3, %r6;
    max.u32 %r14, %r6, %r4;
    add.s32 %r8, %r20, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
