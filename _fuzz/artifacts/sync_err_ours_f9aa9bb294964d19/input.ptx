.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r26, %r3, %r3, %r3;
    cvt.u64.u32 %rd11, %r3;
    cvt.u64.u32 %rd12, %r26;
    mad.lo.s32 %r5, %r26, %r26, %r3;
    and.b64 %rd12, %rd11, %rd11;
    shr.u32 %r19, %r3, 3;
    min.u64 %rd6, %rd11, %rd11;
    shl.b64 %rd8, %rd12, 63;
    shl.b64 %rd12, %rd12, 15;
    setp.ne.s32 %p4, %r3, %r26;
    @%p4 max.u32 %r16, %r5, %r19;
    setp.ls.u32 %p1, %r16, 3;
    setp.gt.u32 %p2, %r26, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
