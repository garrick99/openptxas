.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    or.b32 %r5, %r3, 2;
    min.s32 %r26, %r5, 2;
    setp.hi.u32 %p2, %r3, %r5;
    setp.eq.s32 %p4, %r3, %r26;
    @%p4 max.s64 %rd14, %rd9, %rd9;
    mul.wide.s32 %rd14, %r26, %r3;
    sub.u32 %r21, %r5, %r5;
    shl.b64 %rd9, %rd14, 3;
    shr.u64 %rd11, %rd14, 1;
    cvt.u64.u32 %rd6, %r3;
    max.s32 %r10, %r3, %r21;
    add.s64 %rd11, %rd6, %rd14;
    mul.wide.u32 %rd10, %r26, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
