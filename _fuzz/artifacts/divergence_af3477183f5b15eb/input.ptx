.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    max.u32 %r12, %r3, 15;
    xor.b64 %rd11, %rd12, %rd12;
    shr.u64 %rd10, %rd12, 15;
    mul.wide.u32 %rd6, %r12, %r12;
    min.s32 %r11, %r3, 3;
    setp.eq.s32 %p4, %r3, %r11;
    @%p4 selp.b32 %r10, %r3, %r3, %p4;
    sub.s32 %r5, %r3, %r11;
    add.u32 %r21, %r5, %r11;
    mul.lo.s32 %r12, %r3, 31;
    cvt.s64.s32 %rd10, %r11;
    cvt.u64.u32 %rd8, %r10;
    max.s32 %r19, %r3, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
