.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p1, %r3, 0;
    @%p1 selp.b32 %r8, %r3, %r3, %p1;
    cvt.s64.s32 %rd7, %r3;
    selp.b32 %r19, %r3, %r8, %p1;
    mul.lo.s32 %r16, %r8, %r19;
    mul.wide.u32 %rd8, %r8, %r19;
    sub.u32 %r18, %r16, %r16;
    mul.wide.u32 %rd8, %r19, %r18;
    add.u32 %r6, %r8, 65535;
    shr.s32 %r19, %r19, 0;
    mul.lo.u32 %r22, %r16, %r3;
    mad.lo.u32 %r14, %r6, %r18, %r19;
    shr.u64 %rd12, %rd8, 4;
    cvt.u64.u32 %rd10, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
