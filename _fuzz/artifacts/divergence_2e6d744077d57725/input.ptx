.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p3, %r3, 65535;
    @%p3 cvt.u64.u32 %rd6, %r3;
    cvt.s32.s64 %r8, %rd6;
    shr.s64 %rd6, %rd6, 63;
    min.s64 %rd14, %rd6, %rd6;
    shl.b64 %rd7, %rd6, 48;
    or.b32 %r4, %r3, %r3;
    min.u32 %r12, %r4, 5;
    mul.lo.u64 %rd14, %rd7, %rd14;
    xor.b32 %r27, %r8, %r4;
    sub.u32 %r25, %r12, %r12;
    mad.lo.u32 %r9, %r25, %r27, %r4;
    selp.b32 %r19, %r3, %r27, %p3;
    selp.b32 %r24, %r25, %r8, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
