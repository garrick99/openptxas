    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p2, %r3, 32;
    @!%p2 mul.lo.s32 %r16, %r3, 63;
    mul.wide.s32 %rd8, %r16, %r3;
    shl.b32 %r21, %r3, 4;
    shr.u64 %rd9, %rd8, 47;
    add.u64 %rd14, %rd9, %rd9;
    setp.lt.s32 %p1, %r21, 2147483648;
    @%p1 mul.lo.s32 %r6, %r21, %r21;
    cvt.s32.s64 %r25, %rd9;
    cvt.u32.u64 %r6, %rd8;
    setp.ne.s32 %p3, %r21, %r21;
    @!%p3 sub.u32 %r6, %r3, %r6;
    mul.wide.u32 %rd12, %r21, %r25;
    mul.lo.s32 %r22, %r16, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
