.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r26, %r3, 2;
    add.s32 %r21, %r3, 7;
    max.s32 %r26, %r3, 2;
    mad.lo.u32 %r13, %r26, %r26, %r26;
    mul.lo.u32 %r16, %r21, 2;
    min.u32 %r9, %r21, %r26;
    setp.ge.s32 %p4, %r16, %r9;
    mul.wide.s32 %rd10, %r26, %r26;
    setp.hi.u32 %p4, %r21, %r21;
    min.s32 %r24, %r21, 32;
    cvt.s64.s32 %rd10, %r26;
    selp.b32 %r17, %r9, %r26, %p4;
    min.u64 %rd9, %rd10, %rd10;
    cvt.s32.s64 %r23, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
