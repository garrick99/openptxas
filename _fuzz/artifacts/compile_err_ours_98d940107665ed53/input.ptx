    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r4, %r0, %r3;
    shfl.sync.bfly.b32 %r14, %r0, 16, 0x1f, -1;
    or.b32 %r6, %r4, %r4;
    setp.le.u32 %p2, %r4, 4294967295;
    vote.sync.ballot.b32 %r4, %p2, -1;
    xor.b32 %r9, %r14, %r0;
    setp.eq.u32 %p3, %r6, %r9;
    vote.sync.ballot.b32 %r15, %p3, -1;
    min.u32 %r7, %r0, %r15;
