.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    cvt.s32.s64 %r25, %rd10;
    shl.b32 %r14, %r25, 30;
    max.u32 %r23, %r3, %r14;
    or.b32 %r9, %r3, %r23;
    cvt.s64.s32 %rd8, %r3;
    shl.b64 %rd14, %rd8, 4;
    add.u64 %rd7, %rd14, %rd14;
    sub.u32 %r10, %r25, 3;
    shr.s32 %r16, %r9, 30;
    shr.s64 %rd11, %rd10, 7;
    setp.ls.u32 %p1, %r14, 256;
    @%p1 selp.b32 %r10, %r23, %r10, %p1;
    shl.b64 %rd14, %rd11, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
