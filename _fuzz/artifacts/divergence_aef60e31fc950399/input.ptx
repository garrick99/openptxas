.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    mad.lo.u32 %r9, %r3, %r3, %r3;
    min.s32 %r10, %r9, 65536;
    cvt.u32.u64 %r24, %rd12;
    mul.wide.s32 %rd12, %r9, %r3;
    max.u32 %r23, %r3, %r3;
    shr.s64 %rd6, %rd12, 2;
    xor.b32 %r5, %r23, 3;
    shr.s32 %r18, %r3, 4;
    shr.u64 %rd5, %rd12, 33;
    shl.b32 %r23, %r10, 30;
    shl.b64 %rd11, %rd6, 63;
    mul.lo.u64 %rd8, %rd6, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
