.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd9, %r3, %r3;
    and.b32 %r10, %r3, %r3;
    xor.b32 %r14, %r10, %r3;
    cvt.s32.s64 %r21, %rd9;
    min.s32 %r16, %r21, %r3;
    cvt.u32.u64 %r17, %rd9;
    sub.u32 %r5, %r10, %r21;
    shl.b64 %rd15, %rd9, 30;
    mad.lo.u32 %r6, %r10, %r5, %r5;
    xor.b32 %r4, %r14, %r5;
    shl.b32 %r15, %r21, 16;
    mul.lo.u32 %r6, %r3, 2147483648;
    shr.u32 %r11, %r21, 30;
    mul.lo.s32 %r18, %r5, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
