.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r17, %r3, %r3;
    mad.lo.s32 %r13, %r3, %r3, %r3;
    cvt.u64.u32 %rd6, %r3;
    mul.wide.s32 %rd13, %r13, %r17;
    cvt.s32.s64 %r27, %rd13;
    shr.s32 %r17, %r27, 0;
    min.s64 %rd8, %rd6, %rd6;
    max.u32 %r26, %r13, %r13;
    shl.b32 %r9, %r26, 0;
    shr.s32 %r13, %r3, 7;
    shl.b32 %r16, %r26, 16;
    shl.b64 %rd7, %rd13, 0;
    add.s64 %rd15, %rd13, %rd8;
    min.u32 %r7, %r3, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
