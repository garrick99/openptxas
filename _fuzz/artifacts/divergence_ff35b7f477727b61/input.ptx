.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r14, %r3, %r3;
    and.b32 %r15, %r3, %r14;
    setp.ne.u32 %p4, %r14, %r14;
    @%p4 min.s32 %r24, %r14, 0;
    mul.lo.s32 %r22, %r14, 256;
    setp.le.u32 %p2, %r22, %r15;
    cvt.s64.s32 %rd8, %r14;
    mul.lo.u32 %r21, %r3, %r24;
    shr.s32 %r21, %r14, 15;
    max.u32 %r21, %r14, 256;
    add.s32 %r19, %r15, 1;
    setp.lt.s32 %p4, %r22, 255;
    @!%p4 and.b32 %r17, %r3, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
