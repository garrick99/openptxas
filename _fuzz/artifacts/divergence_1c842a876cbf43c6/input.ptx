.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r26, %r3, 7;
    cvt.u64.u32 %rd7, %r26;
    cvt.u32.u64 %r4, %rd7;
    xor.b32 %r8, %r26, 5;
    add.s64 %rd11, %rd7, %rd7;
    min.s32 %r24, %r26, %r8;
    shr.s32 %r11, %r24, 30;
    sub.s32 %r8, %r8, 16;
    sub.u32 %r26, %r3, 0;
    max.s32 %r24, %r8, %r3;
    mul.wide.u32 %rd10, %r11, %r4;
    add.s64 %rd7, %rd10, %rd7;
    mul.lo.s32 %r9, %r4, %r8;
    shr.s32 %r25, %r9, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
