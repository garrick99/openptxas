.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r13, %r3, %r3, %r3;
    setp.ls.u32 %p2, %r3, %r3;
    @%p2 add.u32 %r27, %r13, %r13;
    sub.s32 %r24, %r13, %r27;
    shr.u32 %r20, %r24, 7;
    min.u32 %r26, %r27, 64;
    setp.ne.s32 %p1, %r24, %r20;
    and.b32 %r25, %r27, 65536;
    add.s32 %r9, %r26, 65535;
    setp.ge.u32 %p4, %r3, 256;
    @!%p4 shl.b32 %r19, %r13, 31;
    cvt.u64.u32 %rd7, %r24;
    sub.u32 %r23, %r13, %r9;
    max.u32 %r26, %r26, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
