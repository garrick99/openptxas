.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r20, %r3, 2147483647;
    shl.b32 %r13, %r20, 0;
    max.s32 %r10, %r3, %r13;
    mul.wide.u32 %rd15, %r13, %r10;
    mul.wide.s32 %rd8, %r3, %r13;
    add.s32 %r24, %r3, 64;
    max.u32 %r10, %r24, 3;
    shl.b32 %r22, %r24, 0;
    mul.lo.s32 %r25, %r20, %r10;
    mul.wide.s32 %rd6, %r10, %r22;
    cvt.u64.u32 %rd7, %r24;
    setp.hi.u32 %p2, %r25, 8;
    setp.eq.u32 %p3, %r13, 4294967295;
    @!%p3 or.b32 %r20, %r20, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
