.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r19, %r3, %r3;
    sub.s32 %r11, %r19, 16;
    cvt.s64.s32 %rd14, %r3;
    or.b32 %r7, %r11, %r19;
    setp.ge.u32 %p2, %r3, %r7;
    max.s64 %rd7, %rd14, %rd14;
    setp.le.u32 %p3, %r11, 64;
    @%p3 mad.lo.u32 %r5, %r7, %r11, %r7;
    cvt.s32.s64 %r26, %rd14;
    shr.s32 %r6, %r26, 4;
    cvt.s64.s32 %rd15, %r6;
    sub.s32 %r27, %r5, 1;
    max.s32 %r16, %r5, %r7;
    cvt.s32.s64 %r13, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
