.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r26, %r3, 8;
    setp.lt.u32 %p2, %r26, 5;
    @%p2 or.b32 %r4, %r26, 15;
    max.s32 %r25, %r3, 4;
    sub.u32 %r6, %r4, %r4;
    cvt.s64.s32 %rd7, %r3;
    xor.b32 %r13, %r25, %r26;
    or.b32 %r4, %r26, %r4;
    min.u32 %r5, %r26, 1;
    setp.hs.u32 %p3, %r25, %r26;
    @%p3 max.u32 %r23, %r13, 7;
    sub.s32 %r19, %r13, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
