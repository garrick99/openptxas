.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r22, %r3, %r3;
    setp.ge.u32 %p1, %r3, %r3;
    setp.ne.s32 %p3, %r3, 7;
    cvt.s64.s32 %rd12, %r3;
    min.u32 %r13, %r3, 3;
    setp.hs.u32 %p2, %r3, 64;
    @%p2 cvt.u64.u32 %rd14, %r3;
    cvt.u64.u32 %rd9, %r3;
    min.u64 %rd10, %rd12, %rd9;
    or.b32 %r7, %r22, 31;
    add.u32 %r9, %r13, %r22;
    setp.ge.s32 %p1, %r13, %r9;
    shr.u32 %r17, %r3, 30;
    shr.u32 %r20, %r7, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
