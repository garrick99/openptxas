.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r17, %r3, %r3;
    setp.ge.s32 %p4, %r17, %r17;
    @%p4 mul.lo.u32 %r11, %r3, 1;
    cvt.u64.u32 %rd14, %r11;
    shl.b64 %rd15, %rd14, 4;
    mad.lo.u32 %r26, %r11, %r3, %r3;
    shl.b32 %r27, %r26, 16;
    add.s32 %r18, %r11, %r11;
    mad.lo.u32 %r20, %r27, %r3, %r26;
    mad.lo.u32 %r19, %r26, %r18, %r26;
    sub.s64 %rd6, %rd15, %rd15;
    mul.wide.s32 %rd5, %r17, %r18;
    shr.u64 %rd7, %rd6, 4;
    mul.wide.u32 %rd9, %r17, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
