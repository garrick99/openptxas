.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r20, %r3, 31;
    cvt.s64.s32 %rd6, %r20;
    mad.lo.u32 %r23, %r20, %r20, %r20;
    max.u32 %r9, %r3, %r20;
    and.b64 %rd11, %rd6, %rd6;
    cvt.u32.u64 %r10, %rd6;
    setp.lt.s32 %p4, %r9, %r23;
    @%p4 mad.lo.s32 %r24, %r20, %r9, %r20;
    and.b32 %r18, %r10, 31;
    setp.ge.u32 %p2, %r18, %r24;
    @%p2 shr.s64 %rd12, %rd6, 7;
    shl.b64 %rd6, %rd11, 48;
    add.s32 %r20, %r24, %r18;
    cvt.s32.s64 %r24, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
