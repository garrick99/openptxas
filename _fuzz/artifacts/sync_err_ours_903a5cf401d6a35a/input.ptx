.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    add.s32 %r4, %r3, %r3;
    shl.b64 %rd14, %rd14, 1;
    max.s64 %rd7, %rd14, %rd14;
    mad.lo.u32 %r20, %r4, %r4, %r3;
    max.u32 %r12, %r20, 65536;
    sub.u32 %r19, %r12, 31;
    shl.b64 %rd5, %rd7, 62;
    add.u32 %r10, %r20, 3;
    cvt.u32.u64 %r8, %rd5;
    xor.b32 %r10, %r8, %r4;
    mul.wide.s32 %rd5, %r19, %r4;
    shr.u64 %rd7, %rd14, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
