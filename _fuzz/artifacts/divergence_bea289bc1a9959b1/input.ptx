.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r7, %r3, 8;
    shr.s32 %r6, %r7, 1;
    mul.wide.u32 %rd11, %r7, %r7;
    setp.le.u32 %p2, %r3, 256;
    @!%p2 sub.s64 %rd15, %rd11, %rd11;
    shl.b32 %r4, %r6, 7;
    mad.lo.u32 %r21, %r7, %r4, %r6;
    cvt.s32.s64 %r13, %rd15;
    mul.wide.s32 %rd7, %r6, %r3;
    selp.b32 %r26, %r13, %r3, %p2;
    cvt.u32.u64 %r6, %rd7;
    add.u32 %r18, %r3, 65535;
    mul.lo.u32 %r11, %r7, %r3;
    sub.u32 %r6, %r13, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
