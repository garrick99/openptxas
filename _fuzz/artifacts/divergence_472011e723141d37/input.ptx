.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    shr.u32 %r13, %r3, 16;
    mul.lo.u32 %r25, %r13, %r13;
    add.s32 %r11, %r3, %r25;
    sub.u64 %rd13, %rd5, %rd5;
    xor.b64 %rd8, %rd13, %rd5;
    add.s32 %r14, %r3, %r13;
    max.u64 %rd13, %rd13, %rd8;
    mul.lo.s64 %rd15, %rd13, %rd5;
    add.u32 %r17, %r13, 255;
    mad.lo.u32 %r22, %r3, %r3, %r25;
    mul.lo.u32 %r15, %r25, %r13;
    cvt.s32.s64 %r19, %rd15;
    setp.le.s32 %p2, %r25, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
