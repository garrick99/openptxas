.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r11, %r3, %r3, %r3;
    setp.eq.s32 %p2, %r11, %r11;
    @!%p2 cvt.s64.s32 %rd5, %r3;
    sub.s32 %r20, %r11, 65535;
    mul.lo.u64 %rd13, %rd5, %rd5;
    setp.ne.s32 %p1, %r3, %r11;
    @%p1 add.s32 %r7, %r3, %r3;
    shl.b64 %rd15, %rd13, 63;
    shr.u32 %r23, %r20, 3;
    or.b32 %r14, %r11, %r20;
    shr.u32 %r6, %r14, 30;
    shl.b32 %r24, %r7, 0;
    shr.u32 %r11, %r23, 2;
    mul.lo.u64 %rd15, %rd13, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
