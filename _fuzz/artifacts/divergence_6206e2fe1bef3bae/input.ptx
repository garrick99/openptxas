.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p1, %r3, 7;
    @%p1 and.b32 %r21, %r3, 0;
    mad.lo.u32 %r26, %r21, %r21, %r21;
    mul.wide.u32 %rd10, %r3, %r21;
    mad.lo.u32 %r21, %r26, %r26, %r3;
    setp.lo.u32 %p3, %r3, 0;
    @%p3 shl.b32 %r25, %r21, 1;
    sub.u32 %r27, %r26, %r3;
    add.s32 %r27, %r26, %r25;
    xor.b32 %r14, %r25, %r25;
    shl.b64 %rd13, %rd10, 33;
    mad.lo.s32 %r13, %r3, %r26, %r21;
    mul.wide.s32 %rd15, %r27, %r25;
    and.b32 %r18, %r13, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
