.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r17, %r3, %r3;
    min.u32 %r24, %r17, %r3;
    and.b32 %r18, %r17, %r17;
    shl.b32 %r19, %r17, 1;
    setp.gt.s32 %p2, %r3, %r19;
    @!%p2 cvt.u64.u32 %rd8, %r24;
    shl.b64 %rd11, %rd8, 7;
    cvt.s64.s32 %rd7, %r3;
    shr.u64 %rd10, %rd7, 15;
    setp.ne.s32 %p2, %r19, 255;
    max.u32 %r25, %r18, %r19;
    max.s32 %r19, %r17, %r18;
    sub.u64 %rd12, %rd7, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
