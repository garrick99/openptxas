.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r21, %r3, %r3;
    max.s32 %r13, %r21, %r21;
    max.u32 %r21, %r13, 8;
    mad.lo.u32 %r8, %r13, %r3, %r13;
    cvt.s64.s32 %rd8, %r21;
    shr.u64 %rd10, %rd8, 1;
    mad.lo.u32 %r10, %r13, %r13, %r3;
    shl.b64 %rd9, %rd10, 16;
    sub.s32 %r17, %r10, %r21;
    mul.lo.u32 %r17, %r21, %r17;
    max.u64 %rd12, %rd10, %rd10;
    mad.lo.u32 %r7, %r8, %r13, %r17;
    mad.lo.u32 %r26, %r7, %r3, %r17;
    mul.lo.s32 %r18, %r7, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
