.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r10, %r3, 2;
    cvt.s64.s32 %rd10, %r3;
    shr.s64 %rd6, %rd10, 1;
    mul.lo.s32 %r20, %r3, %r10;
    xor.b32 %r11, %r3, 4;
    mul.wide.u32 %rd15, %r11, %r3;
    or.b32 %r17, %r20, 2147483647;
    shr.u32 %r26, %r3, 1;
    max.u32 %r10, %r26, %r10;
    mad.lo.u32 %r21, %r20, %r10, %r11;
    mul.wide.s32 %rd6, %r17, %r21;
    shl.b32 %r7, %r10, 31;
    max.u32 %r13, %r10, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
