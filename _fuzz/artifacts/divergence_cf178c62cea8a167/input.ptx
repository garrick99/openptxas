.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r12, %r3, 16;
    cvt.u64.u32 %rd11, %r12;
    shl.b32 %r22, %r12, 7;
    mad.lo.u32 %r5, %r12, %r3, %r3;
    max.s64 %rd14, %rd11, %rd11;
    add.s32 %r6, %r12, %r5;
    setp.lt.s32 %p4, %r22, %r22;
    @%p4 and.b32 %r20, %r3, %r6;
    cvt.s64.s32 %rd14, %r22;
    cvt.u64.u32 %rd15, %r6;
    xor.b32 %r11, %r20, 1;
    min.s64 %rd13, %rd15, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
