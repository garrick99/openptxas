.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p2, %r3, 7;
    @%p2 cvt.u64.u32 %rd14, %r3;
    cvt.u32.u64 %r15, %rd14;
    min.s32 %r9, %r15, %r15;
    shl.b32 %r8, %r9, 4;
    max.u32 %r22, %r9, 4294967295;
    and.b32 %r17, %r8, 3;
    shr.u32 %r23, %r17, 30;
    shl.b32 %r22, %r17, 30;
    cvt.u64.u32 %rd5, %r22;
    mul.wide.s32 %rd10, %r22, %r3;
    mul.wide.u32 %rd14, %r15, %r3;
    and.b32 %r22, %r22, 256;
    shr.u64 %rd5, %rd10, 48;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
