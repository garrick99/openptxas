.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r5, %r3, %r3;
    setp.ge.u32 %p2, %r3, 2147483648;
    setp.lo.u32 %p1, %r3, %r5;
    setp.gt.u32 %p3, %r5, 63;
    setp.eq.u32 %p4, %r3, %r3;
    and.b32 %r7, %r5, 64;
    mad.lo.s32 %r14, %r5, %r7, %r3;
    mul.wide.u32 %rd6, %r5, %r14;
    and.b32 %r16, %r5, 256;
    sub.u32 %r13, %r3, %r16;
    selp.b32 %r8, %r5, %r5, %p4;
    cvt.u64.u32 %rd9, %r5;
    mul.lo.s64 %rd14, %rd9, %rd9;
    mul.lo.s32 %r21, %r14, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
