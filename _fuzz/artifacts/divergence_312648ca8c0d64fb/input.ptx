.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r22, %r3, %r3;
    setp.gt.s32 %p4, %r22, %r3;
    @%p4 cvt.u64.u32 %rd6, %r22;
    sub.s32 %r18, %r3, %r3;
    shl.b64 %rd15, %rd6, 7;
    min.s32 %r21, %r22, 5;
    shl.b32 %r7, %r18, 2;
    shl.b64 %rd10, %rd15, 30;
    or.b32 %r27, %r22, 31;
    selp.b32 %r18, %r27, %r22, %p4;
    mul.lo.u32 %r9, %r3, 65536;
    setp.lo.u32 %p3, %r7, %r18;
    cvt.u32.u64 %r4, %rd6;
    min.u32 %r14, %r22, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
