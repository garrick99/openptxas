.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p1, %r3, 2147483648;
    @%p1 sub.s32 %r19, %r3, %r3;
    mul.wide.s32 %rd14, %r3, %r3;
    setp.le.u32 %p4, %r19, 255;
    @!%p4 mul.wide.s32 %rd9, %r3, %r19;
    and.b32 %r5, %r3, %r3;
    add.u64 %rd9, %rd9, %rd14;
    max.s64 %rd13, %rd14, %rd9;
    max.s32 %r24, %r19, %r3;
    shr.s32 %r4, %r24, 4;
    setp.gt.s32 %p1, %r24, %r5;
    @%p1 or.b32 %r22, %r24, %r19;
    or.b32 %r9, %r4, %r3;
    mad.lo.s32 %r7, %r4, %r3, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
