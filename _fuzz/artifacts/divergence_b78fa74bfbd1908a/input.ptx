.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r10, %r3, 31;
    mul.wide.s32 %rd9, %r10, %r3;
    shr.s32 %r23, %r10, 30;
    shl.b64 %rd7, %rd9, 4;
    cvt.u32.u64 %r15, %rd7;
    setp.ge.s32 %p1, %r15, 65535;
    @%p1 mad.lo.u32 %r18, %r10, %r10, %r15;
    or.b32 %r21, %r18, %r18;
    xor.b32 %r13, %r10, %r3;
    mul.lo.s32 %r6, %r23, 5;
    mad.lo.u32 %r13, %r10, %r10, %r21;
    mul.lo.s32 %r20, %r13, 3;
    shr.s32 %r12, %r18, 1;
    sub.u32 %r20, %r20, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
