.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r5, %r3, %r3;
    shr.s32 %r21, %r3, 15;
    add.u32 %r20, %r3, %r3;
    cvt.s64.s32 %rd8, %r3;
    and.b32 %r26, %r3, 63;
    shr.s64 %rd11, %rd8, 4;
    mul.lo.u64 %rd14, %rd11, %rd11;
    shl.b32 %r12, %r26, 2;
    mul.lo.s64 %rd10, %rd14, %rd14;
    mad.lo.u32 %r4, %r20, %r26, %r3;
    min.s32 %r24, %r5, %r3;
    xor.b32 %r20, %r21, 2147483647;
    max.s32 %r8, %r12, %r20;
    mul.wide.u32 %rd5, %r20, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
