.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r26, %r3, %r3;
    cvt.u64.u32 %rd7, %r26;
    sub.u32 %r25, %r26, 256;
    shr.u32 %r9, %r25, 16;
    add.u32 %r16, %r25, %r9;
    max.u64 %rd5, %rd7, %rd7;
    mad.lo.u32 %r11, %r26, %r16, %r16;
    shr.u32 %r25, %r3, 7;
    add.u32 %r13, %r16, %r16;
    mad.lo.u32 %r15, %r3, %r25, %r3;
    mad.lo.u32 %r22, %r26, %r11, %r3;
    and.b32 %r8, %r11, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
