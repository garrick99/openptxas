.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    shr.s32 %r25, %r3, 16;
    cvt.u32.u64 %r6, %rd7;
    max.s32 %r4, %r3, 15;
    cvt.u64.u32 %rd13, %r25;
    mul.lo.s32 %r24, %r3, 15;
    cvt.s64.s32 %rd14, %r4;
    min.u32 %r8, %r24, 31;
    mad.lo.s32 %r18, %r8, %r6, %r3;
    max.u32 %r8, %r4, 15;
    min.u32 %r23, %r18, %r4;
    cvt.s32.s64 %r6, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
