    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd8, %r3, %r3;
    shr.s32 %r8, %r3, 4;
    setp.ge.s32 %p1, %r8, 2;
    @%p1 add.s32 %r11, %r3, 2147483647;
    max.s32 %r15, %r8, 31;
    add.u32 %r4, %r11, 1;
    add.s32 %r4, %r15, 256;
