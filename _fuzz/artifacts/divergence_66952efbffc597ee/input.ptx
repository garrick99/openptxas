.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p1, %r3, %r3;
    @%p1 shl.b32 %r10, %r3, 0;
    shr.u32 %r4, %r10, 7;
    cvt.s64.s32 %rd8, %r10;
    max.s32 %r22, %r10, %r10;
    mul.lo.u32 %r16, %r10, 32;
    shl.b32 %r8, %r10, 1;
    mul.lo.u64 %rd8, %rd8, %rd8;
    or.b32 %r18, %r8, 255;
    mul.lo.s32 %r18, %r18, 7;
    mul.wide.u32 %rd14, %r4, %r3;
    selp.b32 %r15, %r3, %r10, %p1;
    mul.wide.u32 %rd7, %r22, %r16;
    add.u32 %r12, %r16, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
