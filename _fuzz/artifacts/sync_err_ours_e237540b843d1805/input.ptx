.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r4, %r3, %r3;
    setp.eq.u32 %p1, %r3, %r4;
    @!%p1 mul.wide.u32 %rd14, %r3, %r4;
    mad.lo.u32 %r25, %r4, %r3, %r3;
    xor.b64 %rd15, %rd14, %rd14;
    max.u32 %r20, %r25, 32;
    xor.b32 %r15, %r20, %r4;
    mul.wide.u32 %rd8, %r15, %r15;
    max.u32 %r10, %r15, %r4;
    or.b32 %r17, %r4, 256;
    sub.u32 %r20, %r3, %r20;
    cvt.s64.s32 %rd7, %r10;
    sub.u32 %r12, %r17, 63;
    min.s64 %rd15, %rd7, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
