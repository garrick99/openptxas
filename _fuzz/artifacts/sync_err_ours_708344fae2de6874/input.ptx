.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p1, %r3, 255;
    @%p1 mad.lo.s32 %r9, %r3, %r3, %r3;
    selp.b32 %r22, %r3, %r9, %p1;
    max.s32 %r23, %r9, 256;
    cvt.s64.s32 %rd14, %r9;
    setp.gt.u32 %p1, %r9, 65536;
    max.s32 %r15, %r22, 2;
    add.u32 %r21, %r3, 5;
    add.s32 %r27, %r22, %r3;
    sub.u32 %r13, %r21, %r21;
    min.u32 %r7, %r23, 7;
    add.u32 %r26, %r9, %r27;
    mad.lo.s32 %r7, %r7, %r9, %r7;
    mul.lo.s64 %rd11, %rd14, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
