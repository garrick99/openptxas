.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r17, %r3, 3;
    mad.lo.u32 %r20, %r17, %r17, %r17;
    max.u32 %r12, %r20, 64;
    shr.s32 %r20, %r20, 31;
    shr.u32 %r23, %r17, 3;
    add.s32 %r25, %r20, 3;
    or.b32 %r14, %r20, 5;
    add.s32 %r12, %r23, 64;
    sub.u32 %r9, %r3, %r20;
    mad.lo.s32 %r12, %r23, %r9, %r9;
    setp.ls.u32 %p1, %r25, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
