.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r18, %r3, %r3;
    cvt.u64.u32 %rd13, %r18;
    shr.u32 %r23, %r3, 4;
    min.u32 %r13, %r3, %r23;
    cvt.s64.s32 %rd10, %r23;
    mad.lo.u32 %r17, %r18, %r3, %r13;
    shl.b32 %r10, %r23, 30;
    min.s64 %rd15, %rd13, %rd13;
    min.s32 %r19, %r18, %r18;
    sub.s32 %r5, %r10, 256;
    xor.b64 %rd15, %rd13, %rd15;
    mul.lo.s32 %r26, %r23, %r5;
    add.u32 %r9, %r18, 3;
    add.u32 %r25, %r17, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
