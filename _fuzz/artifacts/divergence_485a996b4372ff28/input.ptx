.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    setp.le.u32 %p2, %r3, 4294967295;
    @%p2 add.s32 %r15, %r3, 31;
    sub.s32 %r22, %r3, %r15;
    sub.u32 %r16, %r22, %r15;
    shl.b64 %rd6, %rd12, 1;
    mul.lo.s32 %r23, %r22, 5;
    setp.hs.u32 %p2, %r16, %r3;
    setp.ge.s32 %p3, %r3, %r23;
    shr.s32 %r8, %r15, 1;
    mul.wide.s32 %rd15, %r15, %r15;
    min.s32 %r14, %r8, %r16;
    xor.b32 %r7, %r16, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
