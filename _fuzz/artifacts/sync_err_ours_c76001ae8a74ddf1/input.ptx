.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r7, %r3, %r3;
    sub.u32 %r26, %r7, 65535;
    mul.wide.u32 %rd12, %r26, %r7;
    setp.hs.u32 %p2, %r3, %r3;
    @%p2 min.u32 %r9, %r26, 4294967295;
    mul.wide.u32 %rd6, %r26, %r26;
    cvt.u64.u32 %rd14, %r7;
    and.b32 %r27, %r9, %r9;
    cvt.u32.u64 %r27, %rd6;
    setp.ls.u32 %p1, %r9, %r7;
    @%p1 sub.u64 %rd5, %rd6, %rd14;
    xor.b32 %r18, %r27, 4;
    xor.b32 %r8, %r3, 1;
    add.s32 %r26, %r3, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
