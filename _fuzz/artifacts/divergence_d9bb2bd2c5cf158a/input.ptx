.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r8, %r3, 32;
    cvt.s64.s32 %rd5, %r8;
    sub.s32 %r20, %r8, %r8;
    or.b32 %r11, %r8, %r3;
    shl.b64 %rd13, %rd5, 32;
    setp.eq.s32 %p2, %r3, %r8;
    @!%p2 selp.b32 %r24, %r20, %r11, %p2;
    max.u32 %r26, %r3, 7;
    mul.wide.s32 %rd5, %r24, %r20;
    min.u32 %r26, %r20, %r3;
    or.b32 %r18, %r11, %r24;
    setp.eq.u32 %p4, %r11, 7;
    @%p4 sub.u32 %r13, %r8, %r11;
    add.u32 %r5, %r13, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
