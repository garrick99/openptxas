.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    mul.wide.u32 %rd6, %r3, %r3;
    cvt.u32.u64 %r27, %rd8;
    add.s32 %r22, %r3, 64;
    mul.lo.s32 %r9, %r27, %r3;
    cvt.s64.s32 %rd5, %r27;
    cvt.s64.s32 %rd12, %r27;
    setp.hi.u32 %p4, %r22, 256;
    @%p4 mad.lo.s32 %r10, %r27, %r22, %r9;
    cvt.s32.s64 %r22, %rd6;
    add.s32 %r6, %r22, %r9;
    shl.b32 %r21, %r6, 1;
    cvt.s32.s64 %r23, %rd12;
    or.b64 %rd8, %rd6, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
