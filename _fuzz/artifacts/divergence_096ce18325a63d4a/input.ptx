.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p3, %r3, 31;
    @!%p3 shl.b32 %r23, %r3, 0;
    cvt.s64.s32 %rd12, %r23;
    shr.s32 %r6, %r23, 15;
    cvt.s64.s32 %rd9, %r3;
    setp.ge.u32 %p3, %r23, 8;
    @%p3 min.s32 %r18, %r3, %r23;
    and.b32 %r5, %r23, %r3;
    or.b32 %r22, %r18, %r3;
    setp.lo.u32 %p4, %r6, 65536;
    sub.s64 %rd7, %rd9, %rd9;
    cvt.u32.u64 %r26, %rd7;
    sub.s32 %r24, %r22, 8;
    mul.lo.s64 %rd11, %rd12, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
