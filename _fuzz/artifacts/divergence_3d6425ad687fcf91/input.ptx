.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    cvt.u32.u64 %r10, %rd9;
    sub.u64 %rd9, %rd9, %rd9;
    cvt.s32.s64 %r23, %rd9;
    setp.ls.u32 %p4, %r10, 4;
    @%p4 min.s32 %r12, %r10, %r3;
    shl.b64 %rd12, %rd9, 31;
    xor.b32 %r14, %r12, %r12;
    mul.wide.s32 %rd5, %r12, %r14;
    shr.s64 %rd5, %rd5, 7;
    setp.le.s32 %p3, %r14, 64;
    @%p3 mul.lo.s32 %r25, %r10, %r12;
    add.s64 %rd13, %rd5, %rd9;
    cvt.u64.u32 %rd7, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
