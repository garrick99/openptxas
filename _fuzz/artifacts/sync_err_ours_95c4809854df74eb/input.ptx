.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r11, %r3, %r3;
    shl.b32 %r6, %r11, 31;
    mul.wide.u32 %rd9, %r3, %r11;
    xor.b32 %r24, %r6, %r6;
    mul.lo.u32 %r4, %r3, 8;
    min.s32 %r20, %r3, %r24;
    sub.s32 %r21, %r11, %r4;
    max.u64 %rd9, %rd9, %rd9;
    and.b32 %r14, %r4, 3;
    setp.lt.u32 %p1, %r3, 2147483647;
    @%p1 shr.s32 %r18, %r11, 3;
    xor.b32 %r4, %r11, %r18;
    shr.s32 %r25, %r11, 15;
    mul.lo.s32 %r6, %r18, %r4;
    ld.param.u64 %rd3, [p_out];
