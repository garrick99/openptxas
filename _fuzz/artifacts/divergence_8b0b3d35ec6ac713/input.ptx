.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd13, %r3, %r3;
    mad.lo.u32 %r7, %r3, %r3, %r3;
    setp.lt.s32 %p1, %r7, 15;
    @!%p1 add.s32 %r7, %r7, %r7;
    shl.b64 %rd7, %rd13, 33;
    mul.wide.s32 %rd7, %r3, %r3;
    shr.u64 %rd6, %rd13, 4;
    setp.ge.u32 %p2, %r3, %r3;
    @%p2 max.s32 %r7, %r3, 4294967295;
    min.s32 %r10, %r7, 15;
    shr.u64 %rd9, %rd7, 31;
    max.s32 %r9, %r3, 15;
    and.b32 %r26, %r7, 32;
    shr.u64 %rd12, %rd7, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
