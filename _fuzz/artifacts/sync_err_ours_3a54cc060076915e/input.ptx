.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    min.u64 %rd12, %rd14, %rd14;
    shr.u64 %rd15, %rd12, 48;
    min.u32 %r19, %r3, %r3;
    add.s32 %r17, %r19, %r19;
    mad.lo.s32 %r19, %r17, %r19, %r19;
    setp.hi.u32 %p3, %r17, %r17;
    cvt.u32.u64 %r17, %rd15;
    mad.lo.u32 %r25, %r17, %r19, %r19;
    sub.s32 %r18, %r17, %r25;
    max.u32 %r16, %r25, %r17;
    sub.u32 %r26, %r25, 255;
    mul.wide.s32 %rd12, %r16, %r19;
    cvt.s32.s64 %r26, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
