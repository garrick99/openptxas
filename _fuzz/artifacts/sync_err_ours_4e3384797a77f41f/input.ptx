.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p1, %r3, 64;
    @!%p1 shl.b32 %r15, %r3, 15;
    add.u32 %r19, %r15, %r3;
    min.u32 %r21, %r3, %r15;
    cvt.u64.u32 %rd13, %r3;
    xor.b32 %r7, %r15, %r21;
    sub.u32 %r26, %r7, %r15;
    cvt.s64.s32 %rd14, %r3;
    shl.b64 %rd5, %rd13, 1;
    setp.lt.s32 %p3, %r19, %r7;
    setp.lo.u32 %p4, %r3, 2147483648;
    mul.wide.u32 %rd7, %r15, %r3;
    selp.b32 %r11, %r3, %r7, %p3;
    sub.u64 %rd14, %rd7, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
