.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r7, %r3, 2147483648;
    add.s32 %r4, %r7, 4294967295;
    and.b32 %r16, %r7, %r3;
    mad.lo.s32 %r10, %r4, %r3, %r16;
    max.s32 %r12, %r7, 8;
    setp.ne.s32 %p1, %r10, 15;
    setp.lt.u32 %p4, %r3, %r4;
    @%p4 shr.s32 %r8, %r4, 15;
    shr.u32 %r26, %r8, 7;
    shr.u32 %r14, %r26, 7;
    setp.eq.s32 %p4, %r7, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
