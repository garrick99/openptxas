.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r11, %r3, %r3;
    cvt.s64.s32 %rd11, %r11;
    mul.wide.u32 %rd13, %r11, %r3;
    max.u64 %rd14, %rd11, %rd13;
    xor.b64 %rd9, %rd11, %rd11;
    mad.lo.s32 %r17, %r11, %r11, %r11;
    max.s32 %r7, %r3, %r3;
    mul.wide.u32 %rd7, %r3, %r7;
    shr.u32 %r18, %r7, 30;
    mad.lo.s32 %r16, %r18, %r3, %r3;
    mul.wide.u32 %rd10, %r18, %r7;
    mul.wide.s32 %rd9, %r7, %r11;
    setp.ge.u32 %p2, %r11, 65536;
    @%p2 shr.u32 %r19, %r3, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
