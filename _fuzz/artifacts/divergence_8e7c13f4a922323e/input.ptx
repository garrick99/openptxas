.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r15, %r3, 30;
    setp.gt.s32 %p1, %r15, 4;
    @!%p1 selp.b32 %r27, %r3, %r15, %p1;
    shr.u32 %r19, %r27, 3;
    max.s32 %r19, %r3, 32;
    shl.b32 %r23, %r27, 7;
    mad.lo.s32 %r27, %r23, %r3, %r3;
    selp.b32 %r27, %r15, %r15, %p1;
    selp.b32 %r9, %r19, %r19, %p1;
    max.u32 %r9, %r9, 5;
    add.u32 %r24, %r9, 4294967295;
    xor.b32 %r12, %r27, 255;
    add.u32 %r5, %r23, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
