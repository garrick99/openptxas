.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd9, %r3, %r3;
    sub.u32 %r4, %r3, 3;
    add.s32 %r19, %r3, 65535;
    setp.gt.s32 %p2, %r3, 2147483648;
    @!%p2 mul.wide.s32 %rd8, %r4, %r3;
    setp.lo.u32 %p1, %r19, %r4;
    @%p1 min.s32 %r15, %r4, 63;
    mul.lo.u32 %r4, %r19, 65536;
    add.s32 %r11, %r19, 63;
    mul.lo.s64 %rd5, %rd9, %rd8;
    shr.s32 %r11, %r19, 2;
    shr.u32 %r16, %r11, 31;
    sub.u32 %r20, %r15, 64;
    selp.b32 %r9, %r16, %r19, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
