.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r16, %r3, 65536;
    add.s32 %r15, %r16, 15;
    mad.lo.u32 %r11, %r3, %r15, %r3;
    cvt.u64.u32 %rd6, %r3;
    cvt.s64.s32 %rd13, %r15;
    min.s64 %rd14, %rd6, %rd13;
    mad.lo.s32 %r9, %r16, %r15, %r3;
    mad.lo.s32 %r5, %r15, %r16, %r11;
    cvt.u32.u64 %r9, %rd14;
    shr.u32 %r10, %r16, 16;
    min.u64 %rd9, %rd6, %rd6;
    setp.eq.s32 %p2, %r9, %r11;
    @%p2 selp.b32 %r10, %r15, %r11, %p2;
    or.b64 %rd15, %rd13, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
