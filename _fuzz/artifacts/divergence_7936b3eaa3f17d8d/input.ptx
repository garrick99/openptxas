.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    add.u32 %r7, %r3, %r3;
    mul.lo.u64 %rd10, %rd6, %rd6;
    mul.lo.s32 %r8, %r3, 63;
    or.b64 %rd7, %rd6, %rd6;
    or.b32 %r25, %r3, %r7;
    mul.lo.s32 %r9, %r3, 5;
    max.s64 %rd10, %rd6, %rd6;
    or.b32 %r17, %r8, 4;
    cvt.u32.u64 %r13, %rd6;
    shr.u32 %r12, %r9, 4;
    shl.b32 %r6, %r7, 31;
    max.s32 %r26, %r25, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
