.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r17, %r3, 2;
    shr.u32 %r27, %r17, 7;
    add.s32 %r14, %r17, %r27;
    cvt.u64.u32 %rd10, %r14;
    shr.u32 %r12, %r17, 4;
    xor.b32 %r18, %r17, 8;
    mul.lo.s32 %r4, %r18, 4;
    sub.s32 %r9, %r27, %r18;
    max.s32 %r11, %r9, %r17;
    shr.u64 %rd7, %rd10, 4;
    and.b32 %r24, %r14, 0;
    add.s32 %r22, %r4, 0;
    shr.s64 %rd14, %rd10, 3;
    add.u32 %r9, %r17, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
