.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r12, %r3, 8;
    setp.lt.s32 %p3, %r3, %r12;
    @%p3 mul.lo.s32 %r15, %r3, %r3;
    cvt.s64.s32 %rd12, %r3;
    max.u32 %r26, %r15, 32;
    cvt.s32.s64 %r20, %rd12;
    max.s32 %r10, %r20, 31;
    cvt.u32.u64 %r24, %rd12;
    mul.lo.u32 %r17, %r15, %r20;
    selp.b32 %r21, %r24, %r3, %p3;
    cvt.s64.s32 %rd12, %r17;
    mul.lo.u32 %r4, %r26, %r26;
    shl.b64 %rd14, %rd12, 1;
    sub.s32 %r8, %r4, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
