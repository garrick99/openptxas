.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r22, %r3, 16;
    cvt.s64.s32 %rd15, %r3;
    cvt.s32.s64 %r16, %rd15;
    shr.u32 %r22, %r16, 16;
    shr.s64 %rd6, %rd15, 7;
    and.b32 %r4, %r16, 5;
    cvt.s32.s64 %r25, %rd6;
    min.u32 %r20, %r3, 0;
    shr.u64 %rd5, %rd15, 31;
    mul.lo.s32 %r12, %r20, %r4;
    and.b32 %r12, %r12, 64;
    shr.u32 %r27, %r22, 0;
    setp.ge.u32 %p3, %r20, 65536;
    @%p3 sub.s32 %r5, %r25, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
