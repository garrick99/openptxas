.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p3, %r3, %r3;
    @%p3 cvt.u64.u32 %rd6, %r3;
    mul.lo.u32 %r26, %r3, 8;
    shr.u32 %r20, %r3, 1;
    shl.b32 %r10, %r20, 0;
    max.s32 %r4, %r20, %r20;
    add.s64 %rd9, %rd6, %rd6;
    shr.u32 %r25, %r4, 30;
    max.u64 %rd13, %rd6, %rd9;
    cvt.s32.s64 %r25, %rd6;
    mul.lo.s32 %r6, %r20, %r25;
    shr.s32 %r19, %r6, 31;
    selp.b32 %r25, %r19, %r25, %p3;
    add.u32 %r16, %r10, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
