.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r20, %r3, 7;
    max.s32 %r23, %r20, %r20;
    mad.lo.u32 %r12, %r23, %r20, %r23;
    cvt.u64.u32 %rd7, %r12;
    shl.b32 %r6, %r12, 30;
    shl.b32 %r5, %r3, 3;
    mul.lo.u32 %r23, %r20, 2147483647;
    mul.wide.s32 %rd11, %r6, %r20;
    shr.s64 %rd6, %rd7, 63;
    max.s64 %rd11, %rd11, %rd6;
    cvt.s32.s64 %r6, %rd7;
    or.b32 %r4, %r23, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
