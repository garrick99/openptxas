.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r24, %r3, 8;
    cvt.u64.u32 %rd8, %r3;
    mul.wide.u32 %rd8, %r3, %r3;
    mul.lo.s32 %r20, %r24, 32;
    cvt.u64.u32 %rd11, %r24;
    or.b32 %r24, %r24, %r20;
    setp.lt.s32 %p2, %r3, %r20;
    sub.s32 %r22, %r3, %r24;
    selp.b32 %r5, %r22, %r20, %p2;
    sub.u32 %r25, %r3, 63;
    max.u32 %r8, %r3, 1;
    max.u32 %r18, %r5, %r25;
    shr.u64 %rd13, %rd11, 33;
    mul.lo.u64 %rd12, %rd13, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
