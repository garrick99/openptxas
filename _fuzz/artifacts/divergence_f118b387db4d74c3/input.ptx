.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p4, %r3, %r3;
    @%p4 cvt.u64.u32 %rd7, %r3;
    setp.hs.u32 %p2, %r3, 31;
    min.s32 %r8, %r3, %r3;
    mul.lo.s32 %r6, %r3, 5;
    mul.wide.u32 %rd15, %r8, %r3;
    max.s32 %r14, %r3, %r8;
    sub.u32 %r18, %r6, 3;
    mad.lo.s32 %r18, %r18, %r3, %r6;
    shr.u64 %rd10, %rd15, 4;
    setp.le.s32 %p1, %r18, 0;
    @%p1 sub.s32 %r26, %r3, 255;
    cvt.u32.u64 %r15, %rd10;
    or.b32 %r13, %r8, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
