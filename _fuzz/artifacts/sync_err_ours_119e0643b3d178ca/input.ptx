.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r10, %r3, 16;
    sub.u32 %r15, %r10, 32;
    max.s32 %r16, %r3, %r10;
    cvt.u64.u32 %rd8, %r3;
    min.u32 %r12, %r3, %r10;
    add.u32 %r23, %r10, 256;
    xor.b32 %r27, %r3, %r15;
    mul.lo.s64 %rd7, %rd8, %rd8;
    setp.eq.u32 %p2, %r16, 2;
    @%p2 xor.b32 %r16, %r10, 255;
    setp.eq.s32 %p4, %r3, %r23;
    @%p4 mul.wide.s32 %rd9, %r23, %r12;
    setp.ge.s32 %p4, %r3, 2147483648;
    shl.b32 %r10, %r27, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
