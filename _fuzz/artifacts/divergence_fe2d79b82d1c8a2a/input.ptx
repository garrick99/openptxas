.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r4, %r3, 4294967295;
    cvt.s64.s32 %rd5, %r3;
    mad.lo.u32 %r15, %r4, %r4, %r4;
    mul.lo.u32 %r13, %r4, %r4;
    mul.wide.s32 %rd6, %r15, %r13;
    min.s32 %r23, %r13, %r13;
    shl.b64 %rd13, %rd5, 7;
    shr.s32 %r21, %r13, 15;
    mul.lo.s32 %r17, %r21, 5;
    setp.ne.u32 %p4, %r3, 32;
    @%p4 selp.b32 %r23, %r15, %r4, %p4;
    setp.hi.u32 %p1, %r17, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
