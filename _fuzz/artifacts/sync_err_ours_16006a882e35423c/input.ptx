.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r24, %r3, 2147483647;
    cvt.s64.s32 %rd8, %r24;
    and.b64 %rd11, %rd8, %rd8;
    sub.s32 %r8, %r24, 1;
    shl.b32 %r26, %r24, 0;
    shl.b64 %rd10, %rd8, 1;
    mul.lo.u32 %r16, %r8, %r8;
    mad.lo.u32 %r10, %r3, %r24, %r26;
    mul.lo.u32 %r5, %r8, %r3;
    and.b64 %rd5, %rd11, %rd10;
    mad.lo.s32 %r22, %r16, %r10, %r24;
    and.b32 %r9, %r22, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
