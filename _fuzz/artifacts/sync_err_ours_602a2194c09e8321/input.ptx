.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r9, %r3, 4294967295;
    sub.u32 %r23, %r3, %r9;
    min.s32 %r18, %r3, %r3;
    max.u32 %r18, %r9, 255;
    mad.lo.u32 %r26, %r18, %r3, %r3;
    shr.u32 %r7, %r18, 7;
    or.b32 %r12, %r23, %r26;
    mul.wide.s32 %rd14, %r18, %r23;
    min.u32 %r5, %r18, %r9;
    shl.b32 %r7, %r3, 7;
    shr.s32 %r21, %r23, 30;
    or.b32 %r7, %r5, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
