.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd15, %r3, %r3;
    shr.u64 %rd12, %rd15, 30;
    or.b32 %r14, %r3, 63;
    shl.b32 %r5, %r3, 16;
    shr.s64 %rd5, %rd12, 32;
    shl.b64 %rd9, %rd12, 3;
    add.s32 %r24, %r5, %r14;
    mad.lo.s32 %r14, %r3, %r14, %r14;
    add.u32 %r12, %r24, 5;
    cvt.s64.s32 %rd12, %r12;
    shl.b64 %rd14, %rd9, 16;
    add.s32 %r17, %r24, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
