    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    cvt.u32.u64 %r5, %rd6;
    max.s64 %rd13, %rd6, %rd6;
    xor.b32 %r24, %r3, 65535;
