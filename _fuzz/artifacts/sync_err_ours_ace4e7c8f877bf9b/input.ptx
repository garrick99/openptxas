.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r14, %r3, 4;
    min.s32 %r23, %r14, 64;
    add.s32 %r23, %r14, %r23;
    cvt.u64.u32 %rd14, %r3;
    cvt.s32.s64 %r5, %rd14;
    shr.u64 %rd5, %rd14, 1;
    mul.wide.s32 %rd13, %r23, %r23;
    or.b32 %r26, %r23, %r14;
    add.u64 %rd6, %rd14, %rd13;
    mul.wide.u32 %rd12, %r14, %r14;
    shl.b32 %r23, %r26, 16;
    min.s32 %r16, %r3, %r26;
    min.s64 %rd5, %rd13, %rd5;
    sub.u32 %r13, %r5, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
