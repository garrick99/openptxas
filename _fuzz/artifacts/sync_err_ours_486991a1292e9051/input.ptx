.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r6, %r3, 30;
    mul.lo.u32 %r15, %r3, 31;
    add.u32 %r13, %r6, 7;
    or.b32 %r18, %r13, %r13;
    add.s32 %r7, %r6, 5;
    cvt.u64.u32 %rd12, %r15;
    mul.wide.u32 %rd15, %r15, %r6;
    shr.u32 %r7, %r15, 2;
    cvt.u32.u64 %r26, %rd15;
    max.u32 %r24, %r13, %r26;
    shl.b64 %rd11, %rd12, 31;
    sub.s32 %r24, %r6, 4294967295;
    add.u64 %rd14, %rd12, %rd12;
    mul.wide.u32 %rd6, %r26, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
