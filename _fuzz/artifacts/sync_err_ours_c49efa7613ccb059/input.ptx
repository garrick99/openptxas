.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hi.u32 %p2, %r3, %r3;
    setp.eq.s32 %p1, %r3, 2;
    @!%p1 mul.wide.s32 %rd14, %r3, %r3;
    min.u32 %r10, %r3, %r3;
    min.u32 %r22, %r3, %r10;
    mul.lo.u32 %r19, %r22, %r3;
    mul.lo.s32 %r17, %r10, %r19;
    max.s32 %r10, %r22, %r22;
    setp.eq.u32 %p3, %r22, %r10;
    @%p3 max.u32 %r22, %r19, %r19;
    shr.s32 %r26, %r17, 31;
    max.s64 %rd10, %rd14, %rd14;
    or.b32 %r17, %r19, 4294967295;
    setp.lt.u32 %p4, %r3, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
