.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p1, %r3, %r3;
    @%p1 cvt.u64.u32 %rd11, %r3;
    shr.s32 %r27, %r3, 1;
    cvt.u64.u32 %rd6, %r27;
    min.s64 %rd9, %rd11, %rd6;
    max.u64 %rd12, %rd11, %rd11;
    cvt.s64.s32 %rd7, %r27;
    setp.ls.u32 %p4, %r3, 16;
    @%p4 shl.b32 %r5, %r27, 3;
    min.u32 %r8, %r27, 4294967295;
    mul.wide.u32 %rd7, %r27, %r5;
    xor.b32 %r9, %r5, 5;
    max.u64 %rd6, %rd9, %rd6;
    mad.lo.s32 %r17, %r8, %r27, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
