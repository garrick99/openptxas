    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r26, %r3, 2;
    sub.u32 %r13, %r3, %r26;
    add.s32 %r18, %r13, %r13;
    setp.lt.s32 %p1, %r26, %r3;
    @!%p1 cvt.s64.s32 %rd7, %r26;
    add.u32 %r13, %r13, 2147483648;
    mad.lo.s32 %r12, %r3, %r3, %r26;
    mad.lo.u32 %r11, %r3, %r18, %r3;
