.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r16, %r3, 63;
    mul.wide.u32 %rd5, %r3, %r16;
    shl.b32 %r15, %r16, 30;
    min.u32 %r7, %r16, %r3;
    mul.lo.s32 %r20, %r15, 255;
    setp.lt.s32 %p4, %r20, 256;
    @!%p4 and.b32 %r17, %r7, %r16;
    selp.b32 %r21, %r20, %r3, %p4;
    mad.lo.s32 %r14, %r16, %r7, %r3;
    mul.lo.u32 %r9, %r14, 2;
    sub.u32 %r12, %r16, 7;
    sub.u32 %r21, %r3, %r7;
    sub.u32 %r27, %r12, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
