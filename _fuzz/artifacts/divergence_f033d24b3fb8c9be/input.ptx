.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    add.u32 %r14, %r3, 65535;
    setp.le.s32 %p1, %r14, %r14;
    @%p1 shr.s32 %r24, %r3, 0;
    mul.lo.u32 %r18, %r3, %r24;
    shr.s64 %rd13, %rd14, 33;
    mul.wide.s32 %rd9, %r14, %r14;
    cvt.u32.u64 %r11, %rd14;
    shr.s32 %r5, %r14, 1;
    xor.b32 %r15, %r14, %r24;
    selp.b32 %r18, %r11, %r14, %p1;
    setp.hs.u32 %p1, %r18, %r24;
    @%p1 mul.wide.s32 %rd8, %r3, %r15;
    cvt.s64.s32 %rd14, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
