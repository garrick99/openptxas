.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r17, %r3, %r3, %r3;
    cvt.u64.u32 %rd6, %r17;
    shl.b64 %rd15, %rd6, 7;
    shr.s64 %rd12, %rd15, 2;
    shl.b32 %r5, %r3, 1;
    sub.u32 %r20, %r5, 3;
    shr.u32 %r14, %r20, 2;
    and.b64 %rd13, %rd6, %rd15;
    shl.b64 %rd9, %rd12, 31;
    sub.s32 %r9, %r20, 4;
    shl.b32 %r15, %r14, 4;
    or.b32 %r17, %r15, %r17;
    setp.gt.s32 %p4, %r5, 256;
    @%p4 min.u32 %r11, %r15, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
