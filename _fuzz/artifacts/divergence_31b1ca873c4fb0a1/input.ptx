.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r4, %r3, 16;
    min.u32 %r23, %r3, %r3;
    cvt.s64.s32 %rd15, %r3;
    min.u32 %r21, %r4, %r23;
    shl.b32 %r18, %r4, 1;
    mul.wide.u32 %rd15, %r4, %r23;
    mul.lo.s32 %r20, %r23, 5;
    shl.b32 %r21, %r21, 15;
    cvt.u64.u32 %rd9, %r18;
    min.s32 %r20, %r20, %r3;
    mul.wide.u32 %rd11, %r23, %r3;
    max.u32 %r5, %r18, 0;
    mul.wide.u32 %rd12, %r23, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
