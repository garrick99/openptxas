.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r12, %r3, %r3;
    and.b32 %r22, %r3, %r12;
    sub.u32 %r24, %r3, 15;
    add.u32 %r7, %r3, %r12;
    add.s32 %r26, %r12, %r7;
    cvt.u64.u32 %rd6, %r24;
    xor.b32 %r11, %r7, %r7;
    shr.u64 %rd6, %rd6, 33;
    max.u64 %rd14, %rd6, %rd6;
    max.u32 %r11, %r24, %r24;
    cvt.s32.s64 %r8, %rd6;
    setp.ge.s32 %p1, %r8, %r7;
    @%p1 shl.b32 %r23, %r12, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
