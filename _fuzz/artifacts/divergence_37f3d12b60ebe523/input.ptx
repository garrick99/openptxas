.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r17, %r3, %r3;
    setp.hi.u32 %p3, %r3, %r17;
    @%p3 mul.wide.u32 %rd5, %r17, %r17;
    setp.hs.u32 %p1, %r3, 65535;
    @!%p1 mul.lo.s32 %r14, %r17, %r3;
    mul.wide.u32 %rd12, %r14, %r17;
    sub.u32 %r4, %r3, 255;
    cvt.u32.u64 %r13, %rd5;
    xor.b32 %r26, %r13, 64;
    mul.lo.u64 %rd13, %rd12, %rd12;
    cvt.u64.u32 %rd13, %r3;
    min.u32 %r6, %r26, 32;
    selp.b32 %r24, %r26, %r3, %p3;
    min.s32 %r9, %r6, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
