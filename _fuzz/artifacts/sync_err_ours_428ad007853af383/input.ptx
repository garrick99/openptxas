.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    mul.wide.s32 %rd15, %r3, %r3;
    mad.lo.u32 %r20, %r3, %r3, %r3;
    shr.u64 %rd11, %rd15, 4;
    mul.lo.s32 %r23, %r20, 65535;
    add.u32 %r7, %r23, %r20;
    shr.s64 %rd9, %rd11, 0;
    cvt.u64.u32 %rd5, %r3;
    shr.s64 %rd6, %rd5, 15;
    cvt.s32.s64 %r23, %rd6;
    min.s32 %r17, %r7, 2147483647;
    min.s64 %rd15, %rd14, %rd11;
    shr.u64 %rd5, %rd6, 15;
    xor.b32 %r15, %r23, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
