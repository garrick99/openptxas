.version 9.0
.target sm_120
.address_size 64

.visible .entry mul_rr(
    .param .u64 out,
    .param .u32 val)
{
    .reg .b32  %r<8>;
    .reg .b64  %rd<2>;
    ld.param.u32  %r0, [val];
    // Compute two registers so mul.lo is R-R
    add.u32       %r1, %r0, 1;
    add.u32       %r2, %r0, 2;
    mul.lo.u32    %r3, %r1, %r2;
    cvt.u64.u32   %rd1, %r3;
    ld.param.u64  %rd0, [out];
    st.global.u64 [%rd0], %rd1;
    ret;
}
