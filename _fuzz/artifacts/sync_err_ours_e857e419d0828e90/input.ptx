.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    add.u64 %rd10, %rd12, %rd12;
    setp.le.s32 %p2, %r3, %r3;
    setp.ge.s32 %p4, %r3, 2;
    add.u32 %r6, %r3, 1;
    add.s32 %r27, %r6, 1;
    add.u32 %r5, %r6, %r6;
    add.u32 %r13, %r5, %r6;
    and.b32 %r16, %r13, %r3;
    or.b32 %r7, %r16, 255;
    xor.b32 %r14, %r27, 5;
    xor.b32 %r26, %r14, 7;
    max.s32 %r11, %r26, %r13;
    shr.u32 %r9, %r16, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
