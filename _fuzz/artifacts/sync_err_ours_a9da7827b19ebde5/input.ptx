.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd6, %r3, %r3;
    sub.s32 %r17, %r3, 3;
    mul.lo.u64 %rd14, %rd6, %rd6;
    max.u32 %r15, %r17, 7;
    mul.lo.u32 %r25, %r15, %r15;
    max.u32 %r19, %r15, 0;
    min.u32 %r8, %r3, %r15;
    cvt.u64.u32 %rd12, %r17;
    xor.b32 %r7, %r3, 65536;
    max.u32 %r21, %r7, 1;
    min.s64 %rd6, %rd12, %rd6;
    min.u32 %r25, %r17, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
