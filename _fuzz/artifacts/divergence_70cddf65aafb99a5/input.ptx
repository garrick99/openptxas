    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd12, %r3, %r3;
    mad.lo.s32 %r18, %r3, %r3, %r3;
    setp.ge.u32 %p2, %r3, 2147483647;
    mul.lo.s32 %r17, %r3, %r3;
    cvt.s32.s64 %r7, %rd12;
    selp.b32 %r18, %r18, %r7, %p2;
    sub.u64 %rd8, %rd12, %rd12;
    mul.lo.u64 %rd15, %rd12, %rd12;
    shl.b64 %rd6, %rd12, 4;
    and.b64 %rd13, %rd15, %rd12;
    shr.s64 %rd14, %rd6, 15;
    mul.wide.s32 %rd9, %r18, %r7;
    or.b32 %r19, %r18, %r3;
    mul.lo.u32 %r13, %r18, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
