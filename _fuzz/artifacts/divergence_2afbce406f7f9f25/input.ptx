.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r20, %r3, 7;
    setp.le.s32 %p2, %r20, 31;
    cvt.s64.s32 %rd13, %r3;
    setp.le.s32 %p4, %r3, 4294967295;
    @!%p4 shr.u32 %r16, %r20, 16;
    sub.u64 %rd15, %rd13, %rd13;
    sub.s32 %r8, %r3, %r3;
    mul.lo.s32 %r5, %r3, %r16;
    add.u64 %rd7, %rd15, %rd15;
    and.b32 %r18, %r20, %r3;
    cvt.s32.s64 %r24, %rd15;
    shr.s32 %r18, %r3, 0;
    shl.b32 %r24, %r24, 2;
    mul.lo.s32 %r11, %r5, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
