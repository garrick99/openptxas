.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r13, %r3, %r3;
    setp.gt.u32 %p3, %r3, 2147483648;
    @!%p3 shr.s32 %r5, %r13, 4;
    setp.le.s32 %p2, %r3, 1;
    setp.hi.u32 %p2, %r13, %r5;
    @%p2 cvt.u64.u32 %rd7, %r13;
    selp.b32 %r24, %r13, %r13, %p2;
    sub.u32 %r22, %r13, %r5;
    shr.s32 %r18, %r5, 16;
    cvt.s64.s32 %rd6, %r24;
    mul.lo.u64 %rd10, %rd7, %rd6;
    shl.b32 %r23, %r24, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
