.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r7, %r3, 16;
    cvt.u64.u32 %rd10, %r7;
    shl.b64 %rd12, %rd10, 16;
    setp.lt.u32 %p3, %r7, 64;
    @%p3 sub.u32 %r4, %r3, %r3;
    selp.b32 %r10, %r7, %r4, %p3;
    max.u32 %r10, %r7, %r4;
    add.u32 %r17, %r4, %r3;
    cvt.u32.u64 %r11, %rd10;
    mul.wide.s32 %rd5, %r10, %r11;
    add.u32 %r14, %r17, %r17;
    and.b64 %rd7, %rd10, %rd12;
    add.s32 %r11, %r17, 65536;
    shr.s32 %r20, %r10, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
