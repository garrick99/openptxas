.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    cvt.s64.s32 %rd5, %r3;
    shl.b32 %r11, %r3, 1;
    mul.lo.u32 %r10, %r3, 64;
    add.s32 %r11, %r10, %r10;
    and.b32 %r22, %r11, %r11;
    add.u32 %r5, %r11, %r11;
    add.s32 %r14, %r3, %r11;
    max.u32 %r5, %r5, %r3;
    cvt.u32.u64 %r26, %rd7;
    and.b64 %rd5, %rd7, %rd7;
    and.b32 %r19, %r5, %r22;
    xor.b32 %r22, %r22, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
