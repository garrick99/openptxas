.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd14, %r3, %r3;
    min.u32 %r11, %r3, %r3;
    cvt.s32.s64 %r4, %rd14;
    shr.s64 %rd8, %rd14, 63;
    setp.le.u32 %p3, %r11, 65535;
    sub.u32 %r14, %r4, %r11;
    selp.b32 %r11, %r3, %r14, %p3;
    mul.wide.u32 %rd14, %r4, %r14;
    setp.ge.s32 %p2, %r14, %r11;
    setp.lt.u32 %p1, %r4, 16;
    @%p1 or.b32 %r7, %r11, 2;
    selp.b32 %r23, %r7, %r14, %p1;
    shl.b64 %rd13, %rd8, 63;
    mul.wide.s32 %rd9, %r11, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
