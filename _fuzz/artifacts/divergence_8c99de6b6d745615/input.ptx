.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    cvt.s64.s32 %rd15, %r3;
    shr.s64 %rd14, %rd6, 7;
    setp.ge.u32 %p4, %r3, %r3;
    @%p4 shr.u64 %rd9, %rd14, 47;
    shr.s64 %rd12, %rd6, 47;
    cvt.s64.s32 %rd8, %r3;
    mul.lo.s32 %r19, %r3, %r3;
    xor.b32 %r19, %r3, %r19;
    and.b32 %r24, %r19, 16;
    cvt.u32.u64 %r19, %rd8;
    min.u32 %r11, %r24, %r19;
    cvt.s64.s32 %rd6, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
