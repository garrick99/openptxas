.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p1, %r3, 5;
    cvt.u64.u32 %rd6, %r3;
    sub.u32 %r11, %r3, 63;
    shl.b64 %rd14, %rd6, 62;
    mul.wide.u32 %rd11, %r11, %r3;
    max.u32 %r19, %r11, 16;
    mul.wide.u32 %rd8, %r19, %r3;
    cvt.u64.u32 %rd8, %r11;
    shr.u64 %rd9, %rd11, 2;
    shr.u64 %rd7, %rd9, 0;
    mad.lo.u32 %r23, %r11, %r11, %r19;
    cvt.u32.u64 %r26, %rd6;
    sub.u64 %rd13, %rd14, %rd9;
    or.b32 %r14, %r19, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
