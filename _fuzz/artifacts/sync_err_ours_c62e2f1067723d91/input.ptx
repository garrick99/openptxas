.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    shl.b32 %r11, %r3, 16;
    sub.s32 %r23, %r11, 16;
    max.u32 %r12, %r3, %r3;
    shr.s32 %r20, %r12, 3;
    setp.hs.u32 %p2, %r11, 7;
    shr.s32 %r7, %r23, 2;
    shr.u32 %r26, %r12, 2;
    cvt.s32.s64 %r27, %rd15;
    or.b32 %r27, %r27, %r27;
    selp.b32 %r16, %r7, %r20, %p2;
    shr.s32 %r8, %r23, 31;
    add.s32 %r21, %r20, %r20;
    shl.b64 %rd5, %rd15, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
