.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r4, %r3, 16;
    setp.hs.u32 %p1, %r4, %r4;
    @%p1 max.u32 %r25, %r4, 2147483647;
    selp.b32 %r22, %r4, %r3, %p1;
    sub.u32 %r18, %r4, %r4;
    setp.eq.s32 %p4, %r25, %r3;
    @%p4 add.u32 %r11, %r25, %r25;
    cvt.s64.s32 %rd7, %r3;
    shl.b32 %r16, %r3, 2;
    shr.u64 %rd9, %rd7, 16;
    xor.b32 %r9, %r11, %r11;
    selp.b32 %r25, %r16, %r18, %p1;
    and.b32 %r27, %r4, %r16;
    selp.b32 %r20, %r3, %r9, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
