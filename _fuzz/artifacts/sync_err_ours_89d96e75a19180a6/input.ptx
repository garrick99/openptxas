.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r22, %r3, 2;
    max.u32 %r17, %r3, 255;
    shl.b32 %r5, %r17, 2;
    shl.b32 %r22, %r5, 16;
    setp.eq.s32 %p1, %r3, 2;
    @%p1 and.b32 %r4, %r17, %r3;
    add.u32 %r6, %r4, %r3;
    min.s32 %r22, %r3, %r22;
    cvt.s64.s32 %rd10, %r22;
    max.u32 %r8, %r4, 4;
    or.b32 %r4, %r5, %r6;
    setp.lt.u32 %p3, %r22, %r3;
    setp.ge.s32 %p3, %r4, %r4;
    @%p3 min.u64 %rd12, %rd10, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
