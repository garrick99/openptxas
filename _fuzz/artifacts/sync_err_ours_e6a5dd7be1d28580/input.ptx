    setp.le.s32 %p3, %r24, 2147483647;
    @%p3 sub.s32 %r10, %r3, %r7;
    max.u32 %r8, %r10, %r24;
    min.s64 %rd10, %rd5, %rd11;
    sub.s32 %r19, %r19, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
