.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p1, %r3, %r3;
    @%p1 sub.s32 %r22, %r3, 31;
    and.b32 %r18, %r3, 65536;
    selp.b32 %r27, %r18, %r18, %p1;
    shl.b32 %r11, %r22, 3;
    xor.b32 %r24, %r18, 5;
    min.s32 %r7, %r22, %r22;
    mad.lo.u32 %r25, %r11, %r24, %r3;
    sub.u32 %r10, %r25, 7;
    cvt.s64.s32 %rd7, %r11;
    selp.b32 %r23, %r27, %r25, %p1;
    cvt.s32.s64 %r5, %rd7;
    xor.b32 %r26, %r25, 0;
    shr.u64 %rd12, %rd7, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
