.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r17, %r3, %r3;
    cvt.u64.u32 %rd8, %r3;
    add.s32 %r22, %r3, %r3;
    setp.ge.u32 %p1, %r3, 7;
    @%p1 selp.b32 %r27, %r22, %r3, %p1;
    min.s32 %r11, %r22, %r27;
    and.b32 %r15, %r11, %r11;
    cvt.s32.s64 %r25, %rd8;
    shr.s64 %rd10, %rd8, 33;
    xor.b32 %r26, %r17, %r3;
    mad.lo.u32 %r11, %r3, %r15, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
