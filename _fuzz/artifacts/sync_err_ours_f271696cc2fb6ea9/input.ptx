.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hi.u32 %p2, %r3, 2147483647;
    @!%p2 cvt.u64.u32 %rd9, %r3;
    min.u64 %rd12, %rd9, %rd9;
    selp.b32 %r8, %r3, %r3, %p2;
    selp.b32 %r6, %r8, %r8, %p2;
    shr.s32 %r7, %r8, 7;
    cvt.s32.s64 %r24, %rd12;
    add.u64 %rd11, %rd9, %rd12;
    mul.lo.s32 %r21, %r24, 8;
    xor.b64 %rd7, %rd12, %rd11;
    shl.b64 %rd8, %rd11, 16;
    xor.b32 %r9, %r21, %r21;
    shr.s32 %r14, %r3, 3;
    add.u32 %r4, %r6, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
