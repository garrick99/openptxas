.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    mul.lo.s32 %r9, %r3, %r3;
    cvt.s64.s32 %rd15, %r3;
    and.b32 %r6, %r9, %r9;
    max.u32 %r7, %r3, %r6;
    min.s32 %r22, %r7, %r6;
    add.u32 %r20, %r22, 0;
    mul.lo.u64 %rd10, %rd5, %rd15;
    min.u32 %r17, %r22, %r9;
    mul.lo.s32 %r6, %r20, %r9;
    shr.u64 %rd7, %rd15, 33;
    shl.b32 %r12, %r6, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
