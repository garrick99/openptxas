.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    and.b32 %r20, %r3, 64;
    shr.u64 %rd12, %rd13, 15;
    or.b32 %r18, %r20, %r3;
    shl.b32 %r15, %r3, 0;
    mad.lo.s32 %r23, %r15, %r3, %r20;
    setp.ge.s32 %p2, %r15, %r20;
    @!%p2 add.u32 %r25, %r18, 65536;
    setp.le.u32 %p3, %r25, %r23;
    @%p3 selp.b32 %r7, %r23, %r18, %p3;
    sub.u64 %rd14, %rd13, %rd12;
    or.b32 %r9, %r25, 65535;
    sub.u64 %rd14, %rd13, %rd12;
    setp.ge.u32 %p3, %r25, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
