.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r27, %r3, 7;
    shr.u32 %r14, %r27, 16;
    add.u32 %r16, %r27, 63;
    shl.b32 %r25, %r27, 2;
    min.s32 %r5, %r3, 31;
    shr.u32 %r12, %r5, 1;
    shl.b32 %r12, %r5, 31;
    cvt.u64.u32 %rd8, %r12;
    mad.lo.s32 %r6, %r5, %r3, %r3;
    add.u64 %rd15, %rd8, %rd8;
    and.b32 %r24, %r25, %r12;
    min.s32 %r23, %r3, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
