.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfe.s32 %r11, %r3, 4, 16;
    bfe.u32 %r7, %r11, 24, 16;
    prmt.b32 %r16, %r7, %r3, 65244;
    prmt.b32 %r10, %r7, %r16, 65244;
    xor.b32 %r22, %r7, 15;
    bfe.u32 %r11, %r3, 0, 16;
    bfi.b32 %r7, %r7, %r16, 1, 31;
    popc.b32 %r8, %r16;
    clz.b32 %r13, %r7;
    min.u32 %r4, %r3, %r3;
    bfe.u32 %r4, %r3, 16, 16;
    bfe.s32 %r20, %r22, 4, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
