.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r24, %r3, 4;
    cvt.s64.s32 %rd7, %r24;
    shl.b32 %r17, %r24, 7;
    sub.u32 %r25, %r3, %r3;
    mul.lo.u32 %r16, %r17, 255;
    min.s32 %r27, %r24, %r24;
    min.s32 %r9, %r24, %r16;
    min.s32 %r22, %r3, %r9;
    mul.lo.s32 %r21, %r16, 65536;
    cvt.s64.s32 %rd9, %r24;
    sub.u32 %r16, %r25, 4294967295;
    min.u32 %r15, %r21, %r9;
    mul.wide.s32 %rd11, %r9, %r21;
    setp.ne.u32 %p2, %r24, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
