.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    setp.gt.u32 %p4, %r3, %r3;
    cvt.s64.s32 %rd14, %r3;
    or.b32 %r17, %r3, 256;
    cvt.s32.s64 %r23, %rd13;
    xor.b32 %r16, %r3, 65536;
    add.s32 %r11, %r16, %r17;
    add.u64 %rd8, %rd13, %rd14;
    shl.b32 %r27, %r23, 30;
    or.b32 %r14, %r16, 2147483648;
    max.u32 %r16, %r27, %r16;
    shr.s32 %r12, %r16, 7;
    mad.lo.s32 %r4, %r14, %r14, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
