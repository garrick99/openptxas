    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r12, %r3, %r3;
    sub.u32 %r19, %r3, %r12;
    mul.wide.s32 %rd13, %r19, %r12;
    mul.lo.u64 %rd14, %rd13, %rd13;
    add.s32 %r24, %r12, 65536;
    or.b32 %r4, %r12, 64;
    shr.u64 %rd11, %rd13, 15;
    max.u32 %r27, %r3, 0;
    mul.wide.s32 %rd15, %r3, %r3;
    mad.lo.u32 %r11, %r24, %r24, %r24;
    min.s32 %r25, %r11, %r24;
    and.b32 %r12, %r3, %r25;
