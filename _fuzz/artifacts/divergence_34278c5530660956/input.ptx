.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r7, %r3, 4294967295;
    shl.b32 %r10, %r3, 31;
    mul.wide.s32 %rd15, %r7, %r7;
    mul.wide.u32 %rd8, %r7, %r7;
    or.b32 %r17, %r3, %r10;
    mad.lo.s32 %r15, %r10, %r3, %r10;
    shl.b32 %r6, %r17, 30;
    add.s32 %r25, %r15, %r7;
    mul.wide.u32 %rd14, %r3, %r17;
    setp.eq.s32 %p2, %r17, 4294967295;
    @!%p2 shr.s64 %rd12, %rd15, 1;
    setp.hs.u32 %p1, %r6, %r3;
    @%p1 shr.s32 %r5, %r7, 4;
    setp.ls.u32 %p4, %r3, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
