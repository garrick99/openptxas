.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p4, %r3, %r3;
    @%p4 shr.u32 %r11, %r3, 16;
    and.b32 %r7, %r11, %r3;
    setp.ge.s32 %p2, %r11, 2147483648;
    @!%p2 max.u32 %r26, %r7, %r11;
    setp.le.s32 %p3, %r26, %r11;
    @%p3 or.b32 %r25, %r26, %r7;
    mul.wide.s32 %rd7, %r7, %r7;
    or.b64 %rd13, %rd7, %rd7;
    shr.s64 %rd8, %rd7, 48;
    shr.s32 %r27, %r26, 16;
    cvt.u64.u32 %rd15, %r25;
    shr.u32 %r15, %r27, 30;
    xor.b32 %r4, %r25, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
