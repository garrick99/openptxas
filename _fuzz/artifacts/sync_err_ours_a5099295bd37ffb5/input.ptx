.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    mad.lo.s32 %r26, %r3, %r3, %r3;
    setp.eq.s32 %p3, %r26, 4294967295;
    @%p3 cvt.u32.u64 %r10, %rd9;
    mul.lo.s32 %r5, %r10, 255;
    shr.u64 %rd7, %rd9, 32;
    and.b32 %r26, %r10, %r26;
    min.u32 %r18, %r5, %r3;
    or.b64 %rd5, %rd7, %rd9;
    sub.u32 %r11, %r5, %r26;
    or.b32 %r12, %r3, %r18;
    mul.wide.s32 %rd8, %r12, %r26;
    shr.s64 %rd12, %rd9, 4;
    mad.lo.u32 %r10, %r10, %r10, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
