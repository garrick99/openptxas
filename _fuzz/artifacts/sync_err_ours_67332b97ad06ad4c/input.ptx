.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r27, %r3, 3;
    cvt.u64.u32 %rd6, %r3;
    and.b64 %rd13, %rd6, %rd6;
    sub.s32 %r20, %r27, 256;
    sub.u32 %r18, %r20, %r27;
    min.u32 %r7, %r18, %r3;
    min.u32 %r23, %r18, %r18;
    and.b64 %rd7, %rd13, %rd13;
    shr.u32 %r26, %r18, 7;
    min.s32 %r16, %r18, 5;
    shr.s32 %r5, %r7, 3;
    sub.u32 %r14, %r23, %r16;
    max.s32 %r9, %r23, %r7;
    add.u32 %r5, %r7, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
