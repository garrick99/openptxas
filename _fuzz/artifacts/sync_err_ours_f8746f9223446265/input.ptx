.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r7, %r3, %r3;
    xor.b32 %r22, %r7, %r3;
    add.s32 %r9, %r7, %r7;
    cvt.s64.s32 %rd8, %r3;
    shl.b64 %rd10, %rd8, 48;
    min.s64 %rd8, %rd8, %rd10;
    add.s32 %r11, %r3, 3;
    mul.wide.s32 %rd13, %r22, %r7;
    max.s64 %rd5, %rd10, %rd8;
    shr.s64 %rd9, %rd8, 30;
    shr.s32 %r26, %r7, 30;
    mad.lo.s32 %r9, %r3, %r11, %r11;
    add.s32 %r6, %r9, %r3;
    add.u32 %r7, %r11, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
