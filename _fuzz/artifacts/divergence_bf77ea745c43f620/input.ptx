.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r5, %r3, %r3;
    add.u32 %r10, %r5, %r3;
    shr.u32 %r9, %r3, 16;
    mul.lo.s32 %r27, %r9, 1;
    cvt.s64.s32 %rd7, %r27;
    shr.u64 %rd15, %rd7, 47;
    sub.u64 %rd7, %rd15, %rd7;
    mad.lo.s32 %r22, %r9, %r9, %r3;
    add.s32 %r7, %r10, 64;
    shr.u64 %rd10, %rd15, 16;
    setp.le.u32 %p2, %r9, %r27;
    @%p2 max.u32 %r17, %r9, 2;
    selp.b32 %r26, %r10, %r7, %p2;
    min.u32 %r25, %r26, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
