.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    shl.b32 %r11, %r3, 1;
    max.s64 %rd8, %rd13, %rd13;
    max.u64 %rd13, %rd8, %rd13;
    add.u32 %r5, %r11, %r3;
    shr.u32 %r5, %r3, 15;
    shr.u64 %rd7, %rd13, 16;
    cvt.u32.u64 %r22, %rd8;
    mad.lo.u32 %r25, %r11, %r3, %r22;
    xor.b32 %r6, %r22, %r5;
    shl.b64 %rd5, %rd7, 4;
    and.b64 %rd12, %rd13, %rd13;
    shl.b64 %rd13, %rd8, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
