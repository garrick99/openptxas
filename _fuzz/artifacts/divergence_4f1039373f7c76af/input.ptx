.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r21, %r3, 2147483648;
    min.s32 %r5, %r21, %r3;
    setp.le.u32 %p3, %r3, 15;
    shr.u32 %r12, %r5, 16;
    setp.le.s32 %p4, %r3, %r12;
    @!%p4 shl.b32 %r11, %r5, 3;
    mul.lo.u32 %r27, %r5, %r5;
    setp.gt.s32 %p2, %r11, 4294967295;
    cvt.u64.u32 %rd8, %r12;
    or.b32 %r23, %r27, %r3;
    sub.s32 %r27, %r27, %r23;
    or.b32 %r14, %r12, %r12;
    mul.lo.s32 %r6, %r27, 2;
    cvt.s64.s32 %rd8, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
