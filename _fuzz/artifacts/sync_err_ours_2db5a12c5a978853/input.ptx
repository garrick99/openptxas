.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r10, %r3, 31;
    cvt.s64.s32 %rd6, %r10;
    mul.lo.s32 %r8, %r3, 65535;
    and.b32 %r14, %r8, %r10;
    min.u32 %r25, %r14, %r8;
    add.s32 %r25, %r25, %r8;
    or.b32 %r18, %r25, %r25;
    mul.wide.u32 %rd10, %r10, %r18;
    min.s32 %r10, %r3, 16;
    xor.b32 %r20, %r18, %r8;
    or.b32 %r5, %r14, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
