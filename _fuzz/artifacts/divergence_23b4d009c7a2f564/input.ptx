.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r19, %r3, 30;
    mul.wide.s32 %rd15, %r3, %r19;
    cvt.s32.s64 %r13, %rd15;
    mul.wide.s32 %rd7, %r19, %r3;
    setp.lt.s32 %p3, %r3, 4;
    @!%p3 mul.lo.s32 %r5, %r19, %r13;
    mad.lo.u32 %r14, %r3, %r3, %r13;
    and.b32 %r9, %r13, 7;
    selp.b32 %r22, %r5, %r5, %p3;
    cvt.s32.s64 %r17, %rd7;
    sub.s64 %rd10, %rd15, %rd15;
    shr.u64 %rd5, %rd15, 16;
    xor.b32 %r6, %r5, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
