.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    min.s32 %r19, %r3, 65536;
    sub.s32 %r15, %r19, 1;
    cvt.u64.u32 %rd13, %r3;
    add.s32 %r11, %r19, %r19;
    setp.ls.u32 %p4, %r3, %r19;
    sub.u32 %r25, %r3, %r15;
    cvt.u32.u64 %r20, %rd15;
    shr.s32 %r25, %r3, 4;
    shr.u32 %r24, %r11, 2;
    xor.b32 %r24, %r24, %r3;
    shr.u32 %r5, %r19, 1;
    max.s32 %r19, %r25, 3;
    max.u32 %r21, %r11, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
