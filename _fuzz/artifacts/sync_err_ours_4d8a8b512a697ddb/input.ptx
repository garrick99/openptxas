.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p3, %r3, 4;
    @!%p3 mul.lo.s32 %r16, %r3, %r3;
    shl.b32 %r25, %r3, 7;
    cvt.u64.u32 %rd10, %r25;
    shr.u64 %rd13, %rd10, 33;
    shl.b32 %r14, %r3, 30;
    mul.wide.s32 %rd8, %r14, %r3;
    shr.u32 %r16, %r3, 2;
    setp.ne.u32 %p2, %r14, %r25;
    @%p2 add.s32 %r27, %r14, 16;
    sub.u32 %r15, %r14, %r14;
    mul.lo.s32 %r23, %r14, %r14;
    setp.gt.s32 %p4, %r23, %r27;
    @!%p4 cvt.u32.u64 %r16, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
