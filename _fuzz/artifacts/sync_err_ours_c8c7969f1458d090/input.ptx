.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r9, %r3, %r3;
    shl.b32 %r25, %r3, 0;
    and.b32 %r15, %r3, 65535;
    mul.wide.s32 %rd6, %r9, %r9;
    or.b32 %r21, %r3, %r3;
    cvt.s64.s32 %rd10, %r3;
    add.s64 %rd6, %rd10, %rd10;
    xor.b32 %r27, %r21, %r25;
    cvt.s64.s32 %rd15, %r15;
    cvt.u64.u32 %rd15, %r15;
    mul.wide.s32 %rd8, %r25, %r27;
    xor.b64 %rd5, %rd15, %rd15;
    mul.wide.s32 %rd8, %r3, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
