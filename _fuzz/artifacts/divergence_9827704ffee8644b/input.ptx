.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r7, %r3, %r3;
    shr.s32 %r26, %r7, 0;
    setp.ne.u32 %p3, %r3, 256;
    @%p3 add.s32 %r17, %r7, %r26;
    sub.s32 %r24, %r7, 65536;
    shr.s32 %r19, %r7, 30;
    shr.u32 %r16, %r19, 2;
    xor.b32 %r22, %r3, 4;
    cvt.s64.s32 %rd6, %r17;
    mad.lo.u32 %r17, %r17, %r24, %r24;
    shr.s32 %r25, %r17, 0;
    mul.wide.s32 %rd12, %r26, %r25;
    mul.wide.u32 %rd13, %r26, %r7;
    cvt.u64.u32 %rd7, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
