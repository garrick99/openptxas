.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r20, %r3, %r3;
    or.b32 %r10, %r3, 8;
    min.s32 %r7, %r3, 64;
    shr.s32 %r26, %r7, 7;
    add.s32 %r25, %r3, %r20;
    cvt.u64.u32 %rd8, %r25;
    setp.le.u32 %p3, %r20, %r10;
    sub.s32 %r25, %r25, %r7;
    add.s64 %rd5, %rd8, %rd8;
    min.u32 %r14, %r26, %r3;
    mad.lo.u32 %r7, %r20, %r3, %r26;
    max.u32 %r22, %r26, %r25;
    mul.lo.s64 %rd12, %rd5, %rd8;
    shr.u64 %rd9, %rd12, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
