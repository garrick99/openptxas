.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p3, %r3, %r3;
    @%p3 max.u32 %r6, %r3, 2147483647;
    mul.wide.u32 %rd13, %r6, %r6;
    max.s32 %r22, %r3, 256;
    mul.wide.s32 %rd6, %r22, %r3;
    mul.lo.s32 %r6, %r22, %r6;
    or.b32 %r21, %r6, 5;
    xor.b32 %r25, %r22, %r22;
    max.u32 %r5, %r3, %r25;
    mad.lo.s32 %r15, %r6, %r21, %r25;
    sub.s64 %rd15, %rd13, %rd6;
    setp.le.s32 %p3, %r15, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
