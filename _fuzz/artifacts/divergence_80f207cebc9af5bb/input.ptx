.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r13, %r3, 2;
    sub.s32 %r16, %r3, %r13;
    mul.lo.s32 %r24, %r13, 256;
    sub.u32 %r26, %r16, %r13;
    cvt.s64.s32 %rd14, %r26;
    and.b32 %r10, %r16, %r13;
    shl.b32 %r10, %r13, 15;
    min.u64 %rd6, %rd14, %rd14;
    add.s32 %r9, %r26, %r24;
    mul.lo.s32 %r4, %r9, %r9;
    cvt.u32.u64 %r4, %rd6;
    mul.lo.u32 %r26, %r10, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
