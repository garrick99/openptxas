.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd6, %r3, %r3;
    shr.s32 %r12, %r3, 15;
    max.u32 %r19, %r3, %r3;
    add.s32 %r8, %r19, %r19;
    shr.u32 %r21, %r19, 0;
    mad.lo.u32 %r17, %r3, %r12, %r19;
    mad.lo.u32 %r7, %r17, %r12, %r3;
    add.u64 %rd15, %rd6, %rd6;
    or.b32 %r13, %r17, 64;
    setp.ne.u32 %p4, %r19, 32;
    @!%p4 sub.u32 %r26, %r21, 31;
    add.s32 %r21, %r3, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
