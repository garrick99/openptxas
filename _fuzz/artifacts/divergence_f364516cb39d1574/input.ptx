.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    setp.ls.u32 %p3, %r3, 8;
    @!%p3 sub.u32 %r5, %r3, %r3;
    min.u32 %r8, %r3, 2;
    mul.lo.u32 %r5, %r8, %r5;
    mad.lo.u32 %r21, %r5, %r5, %r8;
    mad.lo.s32 %r10, %r21, %r5, %r3;
    max.s32 %r24, %r3, %r21;
    shr.s32 %r27, %r10, 1;
    max.s32 %r26, %r3, 256;
    sub.s32 %r11, %r27, %r8;
    mul.wide.u32 %rd10, %r10, %r26;
    selp.b32 %r22, %r10, %r8, %p3;
    mad.lo.s32 %r17, %r10, %r10, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
