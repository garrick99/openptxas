.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r11, %r3, 256;
    cvt.s64.s32 %rd9, %r3;
    cvt.u64.u32 %rd9, %r11;
    cvt.s32.s64 %r23, %rd9;
    sub.s32 %r20, %r3, 8;
    setp.le.u32 %p2, %r3, %r3;
    shl.b64 %rd10, %rd9, 4;
    shl.b64 %rd9, %rd9, 2;
    setp.ne.u32 %p2, %r23, %r23;
    @%p2 cvt.s32.s64 %r16, %rd9;
    mad.lo.s32 %r15, %r20, %r23, %r23;
    and.b32 %r17, %r3, %r23;
    shr.u32 %r24, %r20, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
