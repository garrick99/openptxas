.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r25, %r3, 4;
    cvt.u64.u32 %rd9, %r25;
    min.u32 %r16, %r3, %r3;
    setp.le.s32 %p2, %r16, %r3;
    cvt.s32.s64 %r9, %rd9;
    xor.b32 %r19, %r16, 4;
    mad.lo.u32 %r16, %r19, %r3, %r25;
    shr.u64 %rd5, %rd9, 2;
    setp.gt.u32 %p1, %r9, 63;
    @!%p1 xor.b32 %r6, %r3, %r9;
    shr.s64 %rd13, %rd9, 16;
    cvt.s64.s32 %rd11, %r25;
    mul.lo.s64 %rd8, %rd9, %rd9;
    shr.s32 %r13, %r6, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
