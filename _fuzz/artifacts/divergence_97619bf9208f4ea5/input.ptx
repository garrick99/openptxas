.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    min.u32 %r4, %r3, %r3;
    max.u32 %r4, %r3, 7;
    shr.s32 %r17, %r4, 4;
    mad.lo.s32 %r11, %r3, %r3, %r4;
    and.b64 %rd15, %rd9, %rd9;
    setp.eq.s32 %p2, %r17, %r4;
    @%p2 or.b32 %r6, %r11, %r17;
    and.b32 %r27, %r4, 7;
    min.s32 %r18, %r6, %r17;
    selp.b32 %r15, %r11, %r6, %p2;
    add.u32 %r26, %r17, %r6;
    and.b32 %r24, %r27, 7;
    min.s32 %r24, %r15, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
