.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r6, %r3, %r3;
    mul.lo.u32 %r5, %r3, 4294967295;
    min.u32 %r13, %r6, %r3;
    mul.wide.s32 %rd14, %r13, %r6;
    and.b32 %r11, %r13, 4294967295;
    max.u32 %r6, %r13, %r11;
    cvt.s64.s32 %rd6, %r6;
    add.s32 %r12, %r6, %r13;
    cvt.u32.u64 %r16, %rd6;
    add.s32 %r19, %r12, 2;
    mul.wide.s32 %rd7, %r19, %r3;
    shr.s64 %rd11, %rd6, 1;
    add.s32 %r20, %r5, 0;
    xor.b32 %r22, %r12, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
