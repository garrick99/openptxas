.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    add.s32 %r5, %r3, %r3;
    cvt.u32.u64 %r27, %rd7;
    min.s32 %r8, %r27, 63;
    min.u32 %r15, %r27, 65536;
    shl.b32 %r12, %r8, 31;
    mad.lo.s32 %r7, %r8, %r27, %r8;
    shr.s64 %rd8, %rd7, 48;
    sub.u32 %r11, %r12, %r15;
    xor.b32 %r15, %r11, %r11;
    or.b32 %r24, %r15, %r11;
    shr.s32 %r19, %r8, 7;
    shr.u32 %r6, %r3, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
