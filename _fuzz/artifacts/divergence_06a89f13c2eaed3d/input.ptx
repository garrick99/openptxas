    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    xor.b32 %r7, %r3, 2147483647;
    mad.lo.s32 %r9, %r3, %r7, %r7;
