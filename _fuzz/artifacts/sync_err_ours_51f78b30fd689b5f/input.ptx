.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r7, %r3, %r3;
    xor.b32 %r26, %r7, %r3;
    setp.ge.s32 %p2, %r7, %r26;
    @%p2 selp.b32 %r6, %r7, %r26, %p2;
    min.s32 %r18, %r26, %r26;
    cvt.u64.u32 %rd13, %r6;
    selp.b32 %r18, %r3, %r18, %p2;
    cvt.s32.s64 %r4, %rd13;
    shr.s64 %rd5, %rd13, 63;
    setp.lt.u32 %p1, %r18, %r6;
    and.b32 %r7, %r3, %r6;
    cvt.u64.u32 %rd13, %r7;
    selp.b32 %r25, %r3, %r3, %p1;
    cvt.s32.s64 %r14, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
