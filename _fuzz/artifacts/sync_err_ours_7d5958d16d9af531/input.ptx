.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p3, %r3, %r3;
    @%p3 cvt.u64.u32 %rd13, %r3;
    mul.lo.s32 %r27, %r3, %r3;
    sub.u32 %r23, %r27, 31;
    cvt.s32.s64 %r14, %rd13;
    mad.lo.u32 %r16, %r14, %r3, %r3;
    setp.ge.u32 %p2, %r14, %r27;
    @%p2 shr.s32 %r22, %r3, 0;
    max.s32 %r22, %r14, %r16;
    sub.u32 %r21, %r3, %r3;
    shr.u64 %rd13, %rd13, 47;
    shr.s32 %r11, %r3, 30;
    cvt.u64.u32 %rd11, %r22;
    shr.s32 %r26, %r11, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
