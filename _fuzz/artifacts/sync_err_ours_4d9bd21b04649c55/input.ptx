.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r20, %r3, %r3;
    cvt.u64.u32 %rd9, %r3;
    max.s32 %r20, %r20, %r20;
    max.u32 %r14, %r3, 255;
    sub.s64 %rd12, %rd9, %rd9;
    cvt.u32.u64 %r14, %rd12;
    max.s32 %r10, %r20, 0;
    min.s32 %r6, %r14, %r10;
    or.b64 %rd7, %rd12, %rd9;
    mul.lo.s32 %r23, %r14, %r14;
    max.s32 %r26, %r14, %r14;
    min.u32 %r25, %r14, %r14;
    setp.ne.s32 %p3, %r26, 7;
    @!%p3 mad.lo.s32 %r4, %r26, %r14, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
