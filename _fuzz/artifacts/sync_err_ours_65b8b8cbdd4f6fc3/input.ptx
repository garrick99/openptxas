.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r20, %r3, 4;
    cvt.u64.u32 %rd12, %r3;
    mul.lo.u32 %r19, %r20, %r3;
    mul.wide.u32 %rd6, %r19, %r3;
    sub.u32 %r7, %r19, 65536;
    shl.b32 %r8, %r19, 31;
    sub.s32 %r7, %r8, %r3;
    max.s64 %rd7, %rd12, %rd12;
    mul.wide.s32 %rd12, %r7, %r20;
    setp.ge.s32 %p2, %r3, %r19;
    @%p2 selp.b32 %r13, %r20, %r3, %p2;
    setp.ge.u32 %p2, %r3, 3;
    @%p2 mul.wide.s32 %rd14, %r7, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
