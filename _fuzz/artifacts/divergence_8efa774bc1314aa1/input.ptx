.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r23, %r3, %r3;
    max.u32 %r9, %r23, 2;
    mad.lo.u32 %r19, %r23, %r23, %r9;
    add.u32 %r27, %r19, %r3;
    mad.lo.u32 %r14, %r19, %r9, %r3;
    mul.lo.u32 %r24, %r19, %r19;
    min.s32 %r17, %r23, %r23;
    mad.lo.s32 %r23, %r24, %r3, %r17;
    xor.b32 %r24, %r24, %r9;
    xor.b32 %r26, %r27, 65536;
    min.s32 %r17, %r14, %r24;
    cvt.s64.s32 %rd11, %r14;
    mul.wide.u32 %rd7, %r26, %r14;
    and.b32 %r8, %r19, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
