.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    cvt.s32.s64 %r17, %rd5;
    or.b32 %r21, %r3, %r17;
    cvt.u32.u64 %r6, %rd5;
    shl.b32 %r16, %r21, 1;
    add.u32 %r8, %r16, 5;
    shr.u64 %rd6, %rd5, 7;
    max.u64 %rd12, %rd6, %rd6;
    cvt.s32.s64 %r17, %rd5;
    mul.lo.s32 %r13, %r21, %r21;
    and.b64 %rd7, %rd6, %rd6;
    mad.lo.s32 %r4, %r3, %r6, %r8;
    max.s32 %r18, %r13, %r21;
    shr.s32 %r27, %r16, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
