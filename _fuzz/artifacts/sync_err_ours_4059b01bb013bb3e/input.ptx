    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r21, %r3, 3;
    max.u32 %r24, %r21, %r21;
    sub.s32 %r26, %r24, %r3;
    shl.b32 %r19, %r24, 1;
    min.u32 %r6, %r21, 0;
    shl.b32 %r19, %r24, 31;
    and.b32 %r16, %r21, %r6;
    add.u32 %r4, %r26, 2147483647;
    xor.b32 %r22, %r3, %r16;
    cvt.u64.u32 %rd15, %r4;
    min.u32 %r20, %r22, 65535;
    min.u32 %r5, %r4, 3;
    xor.b32 %r16, %r3, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
