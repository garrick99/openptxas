.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r24, %r3, 0;
    mul.wide.u32 %rd15, %r24, %r3;
    shl.b32 %r13, %r24, 0;
    shl.b32 %r18, %r24, 4;
    sub.u64 %rd7, %rd15, %rd15;
    mad.lo.s32 %r9, %r13, %r13, %r24;
    max.s32 %r6, %r13, 65535;
    sub.s64 %rd10, %rd7, %rd15;
    shr.s64 %rd10, %rd7, 4;
    setp.ne.s32 %p3, %r18, 65536;
    max.s32 %r9, %r24, %r13;
    selp.b32 %r20, %r24, %r24, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
