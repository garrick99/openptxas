.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r26, %r3, 65536;
    mul.lo.u32 %r4, %r3, %r26;
    sub.u32 %r17, %r4, %r26;
    mul.wide.u32 %rd13, %r4, %r26;
    mad.lo.u32 %r4, %r4, %r17, %r3;
    shl.b64 %rd5, %rd13, 1;
    max.u32 %r26, %r3, 256;
    mad.lo.s32 %r16, %r4, %r26, %r3;
    min.u32 %r17, %r16, %r16;
    min.u32 %r20, %r17, %r17;
    mad.lo.u32 %r17, %r20, %r20, %r3;
    sub.u64 %rd15, %rd13, %rd5;
    max.u32 %r22, %r4, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
