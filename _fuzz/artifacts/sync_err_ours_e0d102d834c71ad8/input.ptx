.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r21, %r3, 0;
    min.s32 %r13, %r21, %r3;
    max.u32 %r13, %r13, 15;
    add.s32 %r6, %r21, 2;
    shr.u32 %r11, %r6, 15;
    cvt.u64.u32 %rd15, %r6;
    sub.u32 %r7, %r21, 15;
    mul.lo.s32 %r6, %r3, 15;
    max.s32 %r21, %r21, %r11;
    shr.s32 %r6, %r3, 4;
    min.u32 %r5, %r3, %r21;
    min.u32 %r14, %r11, %r7;
    mad.lo.s32 %r16, %r11, %r13, %r21;
    shr.s32 %r17, %r11, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
