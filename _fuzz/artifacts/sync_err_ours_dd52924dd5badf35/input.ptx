.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r6, %r3, 16;
    cvt.u64.u32 %rd14, %r3;
    min.s32 %r6, %r6, 4;
    cvt.s32.s64 %r21, %rd14;
    and.b32 %r7, %r6, %r6;
    shr.u64 %rd10, %rd14, 15;
    shl.b32 %r17, %r7, 7;
    mul.wide.s32 %rd15, %r17, %r3;
    setp.gt.s32 %p4, %r7, 5;
    @%p4 sub.u32 %r12, %r6, 2;
    mul.lo.s32 %r10, %r7, %r7;
    add.u32 %r9, %r21, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
