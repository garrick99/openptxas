.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    shl.b64 %rd15, %rd9, 48;
    setp.hi.u32 %p2, %r3, %r3;
    @%p2 or.b32 %r15, %r3, 256;
    max.u64 %rd7, %rd9, %rd15;
    shr.u32 %r10, %r3, 30;
    add.s32 %r26, %r3, %r3;
    and.b32 %r5, %r15, %r10;
    mad.lo.u32 %r9, %r26, %r3, %r3;
    min.s32 %r22, %r5, %r15;
    and.b32 %r14, %r22, 65536;
    shl.b32 %r9, %r10, 15;
    cvt.u32.u64 %r20, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
