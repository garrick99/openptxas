.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    shr.u32 %r5, %r3, 0;
    mul.lo.s64 %rd8, %rd6, %rd6;
    sub.u64 %rd5, %rd8, %rd6;
    cvt.u64.u32 %rd15, %r5;
    mul.wide.s32 %rd12, %r5, %r3;
    max.u32 %r24, %r5, 65536;
    xor.b64 %rd11, %rd15, %rd5;
    add.s32 %r14, %r24, %r5;
    sub.u32 %r5, %r14, %r5;
    shr.s32 %r10, %r24, 16;
    sub.s32 %r25, %r24, 256;
    shr.s32 %r14, %r5, 2;
    mul.wide.s32 %rd14, %r14, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
