.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p1, %r3, %r3;
    cvt.s64.s32 %rd5, %r3;
    mul.wide.u32 %rd6, %r3, %r3;
    shr.s32 %r6, %r3, 31;
    or.b32 %r19, %r6, %r3;
    sub.u32 %r18, %r3, %r3;
    sub.u32 %r15, %r3, 4;
    shl.b64 %rd11, %rd6, 15;
    cvt.u32.u64 %r19, %rd5;
    mad.lo.s32 %r9, %r3, %r15, %r15;
    setp.ge.s32 %p4, %r18, 8;
    @%p4 shr.u32 %r26, %r9, 0;
    cvt.u64.u32 %rd7, %r26;
    setp.eq.u32 %p2, %r9, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
