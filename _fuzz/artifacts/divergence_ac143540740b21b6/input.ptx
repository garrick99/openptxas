    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    and.b64 %rd10, %rd12, %rd12;
    sub.s32 %r11, %r3, %r3;
    and.b32 %r6, %r3, %r3;
    mul.lo.s32 %r22, %r3, %r11;
