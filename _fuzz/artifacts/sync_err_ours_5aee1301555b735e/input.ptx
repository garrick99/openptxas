.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r8, %r3, 0;
    sub.s32 %r17, %r3, 65536;
    add.u32 %r22, %r8, %r8;
    and.b32 %r7, %r17, 65535;
    shr.s32 %r17, %r22, 16;
    xor.b32 %r5, %r17, %r22;
    and.b32 %r16, %r3, %r3;
    mad.lo.s32 %r5, %r7, %r7, %r3;
    setp.eq.s32 %p2, %r5, 32;
    mul.wide.u32 %rd15, %r17, %r3;
    setp.eq.u32 %p4, %r17, 7;
    @%p4 selp.b32 %r15, %r16, %r3, %p4;
    and.b32 %r25, %r15, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
