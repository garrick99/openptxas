.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p2, %r3, 2;
    setp.lo.u32 %p4, %r3, %r3;
    @%p4 shr.u32 %r17, %r3, 3;
    mul.lo.s32 %r22, %r17, %r17;
    or.b32 %r22, %r3, %r22;
    setp.lo.u32 %p3, %r3, 4;
    @!%p3 max.u32 %r23, %r22, %r17;
    shr.u32 %r18, %r22, 30;
    sub.u32 %r7, %r23, 4294967295;
    max.u32 %r15, %r3, 2147483647;
    add.s32 %r8, %r18, 31;
    setp.gt.s32 %p2, %r8, %r22;
    cvt.s64.s32 %rd13, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
