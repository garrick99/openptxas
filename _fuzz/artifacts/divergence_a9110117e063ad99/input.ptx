.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd9, %r3, %r3;
    min.s32 %r20, %r3, 32;
    and.b64 %rd11, %rd9, %rd9;
    shl.b64 %rd13, %rd9, 3;
    max.u32 %r9, %r3, 2147483647;
    sub.u32 %r11, %r9, 63;
    max.u32 %r8, %r3, %r11;
    shr.u64 %rd6, %rd9, 32;
    cvt.u64.u32 %rd11, %r8;
    and.b32 %r5, %r9, %r11;
    shr.s32 %r5, %r5, 16;
    shr.u64 %rd12, %rd9, 0;
    mul.wide.s32 %rd6, %r11, %r11;
    shl.b64 %rd13, %rd12, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
