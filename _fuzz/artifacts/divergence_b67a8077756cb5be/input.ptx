.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r17, %r3, %r3;
    cvt.s64.s32 %rd9, %r17;
    mad.lo.u32 %r12, %r3, %r3, %r17;
    setp.ge.s32 %p1, %r17, 255;
    @%p1 max.s32 %r25, %r12, 64;
    cvt.u32.u64 %r11, %rd9;
    setp.ne.s32 %p2, %r17, 2;
    cvt.s32.s64 %r10, %rd9;
    min.u32 %r26, %r12, 7;
    sub.u32 %r11, %r26, %r12;
    mad.lo.u32 %r7, %r10, %r12, %r25;
    mul.wide.s32 %rd11, %r17, %r26;
    or.b32 %r27, %r26, %r25;
    mul.wide.s32 %rd14, %r7, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
