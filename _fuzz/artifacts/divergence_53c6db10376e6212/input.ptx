.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    shl.b32 %r6, %r3, 2;
    min.u32 %r16, %r3, 255;
    mul.lo.s32 %r5, %r6, %r6;
    shl.b32 %r21, %r3, 30;
    min.s32 %r9, %r21, %r5;
    shr.u64 %rd10, %rd13, 15;
    shr.s32 %r13, %r9, 30;
    mad.lo.u32 %r12, %r5, %r16, %r9;
    max.s32 %r5, %r5, %r21;
    shr.u32 %r24, %r13, 31;
    mul.wide.u32 %rd7, %r24, %r16;
    mul.lo.u32 %r11, %r6, 65536;
    sub.u64 %rd14, %rd7, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
