.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r18, %r3, 255;
    sub.s32 %r17, %r3, %r18;
    cvt.s64.s32 %rd6, %r3;
    shr.s32 %r26, %r17, 4;
    add.s32 %r10, %r18, %r17;
    add.s32 %r14, %r17, %r17;
    mul.wide.u32 %rd14, %r17, %r26;
    xor.b32 %r5, %r14, 2;
    setp.ge.s32 %p3, %r3, 5;
    @%p3 and.b32 %r20, %r26, 15;
    max.s32 %r24, %r5, 1;
    xor.b32 %r23, %r17, 1;
    add.s32 %r27, %r3, %r20;
    shr.u32 %r19, %r10, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
