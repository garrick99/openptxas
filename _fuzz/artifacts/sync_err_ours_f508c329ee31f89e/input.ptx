.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r11, %r3, 3;
    setp.ls.u32 %p3, %r11, %r3;
    @%p3 shl.b32 %r15, %r11, 1;
    or.b32 %r7, %r11, %r3;
    sub.u32 %r6, %r3, %r7;
    shr.u32 %r16, %r3, 16;
    selp.b32 %r26, %r7, %r6, %p3;
    add.s32 %r21, %r26, %r16;
    sub.u32 %r14, %r26, %r11;
    add.s32 %r15, %r11, %r14;
    shr.u32 %r17, %r14, 15;
    or.b32 %r20, %r17, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
