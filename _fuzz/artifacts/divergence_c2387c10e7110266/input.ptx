.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r12, %r3, 0;
    cvt.u64.u32 %rd10, %r12;
    add.s32 %r12, %r3, 4294967295;
    mad.lo.s32 %r5, %r3, %r12, %r12;
    setp.le.s32 %p4, %r12, 65536;
    @%p4 add.u32 %r12, %r3, %r5;
    selp.b32 %r11, %r5, %r3, %p4;
    shr.u32 %r20, %r11, 0;
    mul.wide.s32 %rd10, %r3, %r5;
    mul.lo.s32 %r15, %r20, %r11;
    mul.wide.u32 %rd13, %r5, %r20;
    and.b64 %rd10, %rd13, %rd13;
    or.b32 %r12, %r12, 5;
    selp.b32 %r19, %r5, %r20, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
