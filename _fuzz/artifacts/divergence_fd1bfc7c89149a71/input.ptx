.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r14, %r3, %r3;
    max.u32 %r9, %r14, 7;
    shr.s32 %r23, %r9, 15;
    mul.wide.u32 %rd11, %r9, %r23;
    shr.s64 %rd13, %rd11, 63;
    cvt.s32.s64 %r22, %rd11;
    shr.u64 %rd15, %rd11, 0;
    max.s32 %r19, %r3, %r22;
    setp.gt.s32 %p2, %r14, 2147483647;
    @%p2 min.u32 %r15, %r22, 2;
    and.b32 %r18, %r19, %r22;
    xor.b32 %r13, %r19, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
