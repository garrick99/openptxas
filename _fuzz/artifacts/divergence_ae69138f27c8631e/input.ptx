.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    mul.lo.s32 %r4, %r3, %r3;
    add.u64 %rd5, %rd12, %rd12;
    cvt.s64.s32 %rd13, %r3;
    setp.eq.s32 %p4, %r4, 0;
    @%p4 shr.u32 %r14, %r4, 31;
    setp.lt.u32 %p2, %r14, %r14;
    setp.eq.s32 %p4, %r4, %r4;
    @%p4 cvt.u64.u32 %rd9, %r14;
    and.b32 %r14, %r14, 7;
    cvt.s32.s64 %r14, %rd13;
    min.u32 %r14, %r3, %r14;
    shr.s64 %rd8, %rd13, 15;
    sub.s64 %rd14, %rd12, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
