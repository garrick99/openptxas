.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r14, %r3, 7;
    mad.lo.s32 %r26, %r3, %r14, %r14;
    mad.lo.s32 %r4, %r3, %r26, %r26;
    sub.u32 %r10, %r3, 5;
    mul.wide.u32 %rd11, %r4, %r4;
    shr.u32 %r19, %r14, 0;
    min.u64 %rd10, %rd11, %rd11;
    setp.le.s32 %p1, %r3, %r26;
    @!%p1 add.u32 %r5, %r4, 4294967295;
    sub.s64 %rd12, %rd11, %rd10;
    or.b32 %r13, %r26, %r26;
    min.s32 %r14, %r14, 4294967295;
    add.u32 %r26, %r3, %r10;
    sub.u32 %r23, %r3, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
