.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r10, %r3, %r3;
    cvt.s64.s32 %rd13, %r10;
    add.u32 %r11, %r3, %r10;
    setp.gt.u32 %p1, %r11, %r11;
    mul.wide.u32 %rd8, %r3, %r3;
    shr.s32 %r15, %r3, 7;
    mul.wide.s32 %rd13, %r11, %r15;
    sub.s32 %r27, %r11, 2;
    shr.u32 %r27, %r27, 1;
    xor.b64 %rd12, %rd8, %rd8;
    mul.wide.u32 %rd9, %r10, %r10;
    xor.b32 %r14, %r10, %r15;
    selp.b32 %r12, %r10, %r14, %p1;
    mul.wide.s32 %rd6, %r14, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
