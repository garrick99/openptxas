.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p4, %r3, 16;
    @%p4 add.u32 %r23, %r3, 64;
    selp.b32 %r22, %r23, %r3, %p4;
    shr.u32 %r12, %r3, 1;
    min.s32 %r6, %r23, 4294967295;
    max.s32 %r20, %r22, 256;
    setp.gt.u32 %p3, %r6, 0;
    @%p3 shr.s32 %r22, %r20, 31;
    mul.wide.s32 %rd9, %r22, %r20;
    cvt.s32.s64 %r6, %rd9;
    shl.b32 %r14, %r20, 31;
    selp.b32 %r15, %r14, %r6, %p4;
    mul.wide.s32 %rd7, %r15, %r20;
    sub.s32 %r21, %r23, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
