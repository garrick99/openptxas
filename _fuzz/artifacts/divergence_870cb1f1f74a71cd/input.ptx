.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r23, %r3, 8;
    cvt.u64.u32 %rd5, %r23;
    min.s32 %r16, %r23, %r23;
    cvt.s32.s64 %r9, %rd5;
    mad.lo.s32 %r11, %r16, %r23, %r23;
    min.s64 %rd8, %rd5, %rd5;
    mul.wide.u32 %rd15, %r23, %r23;
    mul.wide.s32 %rd9, %r3, %r3;
    or.b64 %rd9, %rd5, %rd15;
    and.b32 %r14, %r16, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
