.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r25, %r3, %r3;
    cvt.s64.s32 %rd9, %r3;
    mul.wide.s32 %rd10, %r3, %r25;
    xor.b32 %r5, %r25, %r3;
    shr.s32 %r20, %r5, 31;
    mul.lo.s32 %r12, %r5, 65535;
    add.u32 %r19, %r5, %r25;
    sub.s32 %r10, %r3, %r5;
    min.s32 %r17, %r10, 15;
    shr.u32 %r12, %r19, 16;
    shr.u64 %rd13, %rd10, 4;
    add.s32 %r10, %r12, %r20;
    cvt.u32.u64 %r24, %rd9;
    shr.s32 %r9, %r24, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
