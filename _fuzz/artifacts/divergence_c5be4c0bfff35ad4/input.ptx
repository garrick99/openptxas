.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r22, %r3, 1;
    max.s32 %r6, %r3, %r22;
    sub.s32 %r21, %r22, 1;
    mul.lo.u32 %r25, %r6, 5;
    sub.u32 %r11, %r21, 65535;
    min.u32 %r18, %r22, 3;
    setp.eq.u32 %p4, %r22, 2147483648;
    and.b32 %r11, %r11, 65536;
    cvt.s64.s32 %rd15, %r18;
    and.b32 %r4, %r25, %r6;
    shr.s32 %r11, %r18, 15;
    or.b32 %r7, %r21, %r4;
    mul.lo.s32 %r22, %r4, 0;
    and.b32 %r24, %r7, %r11;
