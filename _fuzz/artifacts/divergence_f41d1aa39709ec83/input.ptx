.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd9, %r3, %r3;
    add.s32 %r8, %r3, %r3;
    mul.wide.s32 %rd10, %r8, %r8;
    cvt.u32.u64 %r24, %rd9;
    max.s32 %r17, %r24, %r3;
    min.s32 %r20, %r3, %r3;
    mul.wide.s32 %rd11, %r24, %r24;
    sub.s32 %r17, %r3, %r3;
    add.s32 %r16, %r3, %r3;
    min.s32 %r16, %r24, %r20;
    max.u32 %r19, %r16, %r16;
    shl.b32 %r17, %r24, 4;
    add.u32 %r7, %r3, %r8;
    min.u32 %r15, %r20, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
