.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r9, %r3, %r3;
    or.b32 %r27, %r9, %r3;
    sub.u32 %r16, %r9, 1;
    cvt.u64.u32 %rd6, %r27;
    mad.lo.u32 %r12, %r16, %r3, %r3;
    mul.lo.u32 %r25, %r9, %r3;
    add.u32 %r26, %r25, %r9;
    cvt.u32.u64 %r14, %rd6;
    shl.b32 %r20, %r25, 4;
    sub.s32 %r13, %r27, %r27;
    mul.wide.u32 %rd12, %r20, %r16;
    mul.lo.u32 %r23, %r9, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
