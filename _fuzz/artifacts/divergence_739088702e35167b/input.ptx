.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r10, %r3, %r3;
    shl.b32 %r8, %r10, 31;
    max.s32 %r24, %r8, %r3;
    min.s32 %r26, %r8, %r24;
    min.u32 %r20, %r10, %r8;
    max.s32 %r23, %r8, %r8;
    cvt.s64.s32 %rd11, %r23;
    add.u32 %r15, %r24, 16;
    shr.u64 %rd5, %rd11, 30;
    cvt.u32.u64 %r14, %rd5;
    setp.ge.s32 %p2, %r15, %r14;
    @%p2 cvt.s32.s64 %r27, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
