.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r11, %r3, 8;
    setp.le.s32 %p4, %r3, %r11;
    @%p4 max.u32 %r27, %r11, %r11;
    sub.u32 %r10, %r11, %r27;
    sub.u32 %r23, %r3, 5;
    xor.b32 %r14, %r3, 5;
    mul.wide.u32 %rd11, %r11, %r27;
    min.u32 %r25, %r27, %r27;
    sub.s64 %rd9, %rd11, %rd11;
    sub.s32 %r7, %r14, 4;
    shl.b32 %r24, %r7, 2;
    mad.lo.s32 %r10, %r23, %r7, %r27;
    sub.s32 %r18, %r3, %r27;
    add.u64 %rd6, %rd9, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
