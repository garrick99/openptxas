.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p2, %r3, %r3;
    mad.lo.u32 %r4, %r3, %r3, %r3;
    or.b32 %r21, %r4, %r4;
    selp.b32 %r20, %r3, %r4, %p2;
    sub.s32 %r14, %r21, %r20;
    setp.eq.u32 %p1, %r14, %r14;
    @%p1 cvt.s64.s32 %rd11, %r20;
    cvt.s32.s64 %r13, %rd11;
    setp.lt.u32 %p2, %r3, 15;
    @%p2 and.b32 %r7, %r20, %r21;
    mul.wide.u32 %rd7, %r13, %r4;
    sub.s32 %r13, %r20, %r13;
    shl.b32 %r13, %r20, 3;
    mad.lo.s32 %r26, %r4, %r3, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
