.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r26, %r3, 15;
    mul.lo.u32 %r14, %r26, 4294967295;
    min.s32 %r11, %r14, 1;
    cvt.u64.u32 %rd6, %r11;
    cvt.u64.u32 %rd9, %r26;
    sub.s32 %r23, %r14, %r14;
    add.u32 %r6, %r23, %r23;
    xor.b32 %r24, %r23, %r3;
    mul.lo.s64 %rd12, %rd6, %rd6;
    or.b32 %r20, %r11, %r3;
    add.u32 %r19, %r24, 0;
    min.s32 %r22, %r14, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
