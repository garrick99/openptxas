.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    add.u32 %r27, %r3, %r3;
    shr.u64 %rd12, %rd13, 16;
    shr.s32 %r6, %r3, 2;
    xor.b32 %r5, %r3, %r27;
    shr.s32 %r24, %r3, 2;
    and.b32 %r14, %r3, %r6;
    max.s32 %r15, %r27, 2;
    min.u32 %r6, %r5, %r14;
    cvt.s32.s64 %r26, %rd13;
    sub.u32 %r20, %r15, %r26;
    setp.lo.u32 %p4, %r5, %r14;
    @%p4 shl.b32 %r12, %r15, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
