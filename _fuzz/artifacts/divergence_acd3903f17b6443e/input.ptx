.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r11, %r3, 4294967295;
    min.u32 %r11, %r3, %r11;
    mul.wide.u32 %rd13, %r11, %r11;
    mul.lo.u32 %r23, %r11, %r11;
    shr.u32 %r18, %r23, 3;
    mul.lo.u32 %r27, %r3, %r23;
    max.u32 %r27, %r3, 16;
    cvt.u32.u64 %r6, %rd13;
    mul.wide.s32 %rd12, %r18, %r6;
    mad.lo.u32 %r26, %r18, %r27, %r11;
    mul.lo.s32 %r12, %r27, 5;
    max.u32 %r10, %r11, 63;
    shr.u32 %r4, %r12, 1;
    add.s32 %r27, %r27, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
