.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r22, %r3, 16;
    xor.b32 %r19, %r3, %r22;
    mad.lo.s32 %r20, %r3, %r3, %r22;
    shr.s32 %r13, %r19, 15;
    sub.s32 %r27, %r3, 8;
    mul.lo.u32 %r21, %r13, %r19;
    cvt.s64.s32 %rd7, %r13;
    setp.eq.s32 %p1, %r22, %r19;
    @%p1 mul.wide.s32 %rd5, %r20, %r13;
    min.u32 %r22, %r27, %r27;
    or.b32 %r11, %r19, %r19;
    xor.b32 %r12, %r20, %r20;
    setp.ne.s32 %p2, %r27, 65535;
    @%p2 cvt.u32.u64 %r27, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
