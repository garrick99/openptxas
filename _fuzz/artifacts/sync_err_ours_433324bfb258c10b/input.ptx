.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    cvt.s32.s64 %r24, %rd9;
    shr.u32 %r18, %r24, 16;
    min.u32 %r22, %r3, 2;
    max.s32 %r7, %r18, 0;
    sub.s32 %r12, %r24, %r3;
    mad.lo.s32 %r26, %r12, %r18, %r22;
    shr.u32 %r7, %r18, 2;
    cvt.s32.s64 %r14, %rd9;
    min.s32 %r10, %r24, %r7;
    and.b32 %r12, %r26, %r26;
    or.b32 %r21, %r14, %r3;
    shr.u64 %rd5, %rd9, 48;
    shr.u32 %r27, %r7, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
