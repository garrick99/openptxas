.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r7, %r3, %r3;
    setp.hs.u32 %p1, %r7, %r7;
    @%p1 or.b32 %r18, %r7, 2147483647;
    cvt.s64.s32 %rd13, %r7;
    shl.b32 %r8, %r3, 1;
    and.b32 %r18, %r3, %r8;
    shl.b64 %rd13, %rd13, 4;
    mul.lo.s32 %r18, %r18, 256;
    setp.lt.s32 %p3, %r3, %r8;
    @%p3 cvt.s64.s32 %rd12, %r8;
    max.u32 %r24, %r3, 1;
    xor.b32 %r15, %r3, %r24;
    setp.le.u32 %p1, %r3, %r15;
    @%p1 min.u32 %r23, %r24, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
