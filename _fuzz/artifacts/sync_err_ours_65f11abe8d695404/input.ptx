.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    min.s32 %r6, %r3, 64;
    max.s32 %r21, %r3, 2;
    mul.wide.s32 %rd9, %r21, %r3;
    shr.u32 %r22, %r21, 15;
    or.b32 %r27, %r22, 5;
    mul.wide.s32 %rd14, %r6, %r6;
    mad.lo.u32 %r9, %r6, %r22, %r21;
    shr.s64 %rd15, %rd5, 2;
    sub.u32 %r20, %r22, %r6;
    sub.s32 %r25, %r9, %r9;
    add.u32 %r21, %r3, 65536;
    cvt.s32.s64 %r13, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
