.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    and.b32 %r24, %r3, %r3;
    min.s32 %r25, %r3, 0;
    shr.u64 %rd10, %rd14, 7;
    cvt.u32.u64 %r23, %rd14;
    mul.lo.s32 %r20, %r3, 2147483647;
    mul.wide.s32 %rd9, %r3, %r20;
    shr.s32 %r27, %r23, 30;
    shr.u64 %rd9, %rd10, 31;
    min.s32 %r19, %r27, %r20;
    or.b32 %r6, %r23, 255;
    mul.lo.s64 %rd8, %rd10, %rd10;
    sub.u32 %r9, %r19, 0;
    xor.b32 %r4, %r6, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
