.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r11, %r3, %r3;
    cvt.u64.u32 %rd6, %r3;
    max.s32 %r4, %r11, 3;
    add.s32 %r15, %r11, %r4;
    shr.s32 %r7, %r3, 31;
    mul.lo.s32 %r23, %r3, 2147483647;
    xor.b32 %r13, %r11, 7;
    shr.u32 %r9, %r4, 1;
    setp.eq.s32 %p2, %r4, %r3;
    @%p2 shl.b32 %r26, %r9, 4;
    shl.b64 %rd14, %rd6, 47;
    max.s32 %r12, %r4, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
