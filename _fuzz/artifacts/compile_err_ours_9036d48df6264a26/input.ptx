.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p2, %r0, 2;
    vote.sync.ballot.b32 %r11, %p2, -1;
    setp.le.u32 %p2, %r11, %r11;
    vote.sync.ballot.b32 %r17, %p2, -1;
    shfl.sync.idx.b32 %r17, %r0, 31, 0x1f, -1;
    vote.sync.any.pred %p3, %p2, -1;
    setp.lt.u32 %p3, %r11, 31;
    vote.sync.ballot.b32 %r9, %p3, -1;
    shfl.sync.idx.b32 %r15, %r17, 15, 0x1f, -1;
    setp.ge.u32 %p2, %r11, %r17;
    vote.sync.ballot.b32 %r10, %p2, -1;
    shfl.sync.down.b32 %r19, %r15, 1, 0x1f, -1;
    max.u32 %r8, %r19, %r15;
    shfl.sync.down.b32 %r7, %r19, 2, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
