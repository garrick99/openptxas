.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p3, %r3, %r3;
    @%p3 mul.wide.u32 %rd7, %r3, %r3;
    mul.wide.s32 %rd15, %r3, %r3;
    max.u32 %r10, %r3, 8;
    mad.lo.u32 %r24, %r3, %r10, %r10;
    max.s32 %r4, %r10, %r10;
    add.s32 %r12, %r24, %r24;
    setp.gt.s32 %p3, %r12, %r3;
    @!%p3 add.s32 %r20, %r24, %r4;
    max.s64 %rd11, %rd7, %rd7;
    cvt.s32.s64 %r26, %rd15;
    mul.lo.s32 %r23, %r10, 16;
    setp.eq.u32 %p1, %r23, 2;
    mul.wide.s32 %rd5, %r23, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
