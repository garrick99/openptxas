.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r10, %r3, 30;
    and.b32 %r21, %r10, %r3;
    setp.lt.u32 %p3, %r3, 7;
    @%p3 xor.b32 %r6, %r10, %r21;
    cvt.u64.u32 %rd15, %r3;
    selp.b32 %r22, %r21, %r21, %p3;
    setp.gt.u32 %p4, %r3, %r21;
    @%p4 shl.b32 %r23, %r6, 0;
    shr.u32 %r18, %r23, 1;
    xor.b32 %r21, %r18, 32;
    mad.lo.u32 %r22, %r18, %r22, %r18;
    cvt.s64.s32 %rd5, %r23;
    sub.s32 %r22, %r3, %r21;
    add.s32 %r16, %r23, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
