.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r20, %r3, 8;
    cvt.s64.s32 %rd14, %r3;
    shr.s32 %r19, %r3, 4;
    mul.lo.u32 %r6, %r20, 2147483647;
    add.u32 %r11, %r20, %r6;
    sub.u32 %r20, %r6, 2;
    mul.lo.s64 %rd11, %rd14, %rd14;
    max.u32 %r26, %r11, 8;
    mad.lo.u32 %r24, %r19, %r26, %r20;
    sub.s32 %r14, %r3, 3;
    setp.hi.u32 %p1, %r14, %r11;
    setp.gt.u32 %p2, %r19, 16;
    mul.wide.u32 %rd6, %r3, %r6;
    max.u32 %r24, %r20, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
