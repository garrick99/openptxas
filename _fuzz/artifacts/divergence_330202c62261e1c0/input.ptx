.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r9, %r3, 2147483647;
    sub.u32 %r24, %r9, 2;
    setp.hs.u32 %p1, %r3, 5;
    @%p1 xor.b32 %r10, %r24, %r24;
    setp.ls.u32 %p1, %r3, %r9;
    shr.u32 %r17, %r10, 4;
    cvt.s64.s32 %rd15, %r10;
    mul.lo.u32 %r14, %r10, %r24;
    shr.s64 %rd8, %rd15, 3;
    min.u64 %rd15, %rd8, %rd8;
    shl.b32 %r23, %r9, 30;
    shl.b32 %r4, %r10, 15;
    shr.u32 %r6, %r10, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
