    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r25, %r3, %r3;
    min.u32 %r26, %r25, %r3;
    cvt.s64.s32 %rd9, %r25;
    setp.gt.u32 %p1, %r25, %r26;
    sub.s32 %r17, %r26, %r26;
    setp.eq.s32 %p1, %r26, %r26;
    shr.s64 %rd8, %rd9, 0;
    mul.lo.s32 %r21, %r17, 15;
    mul.wide.s32 %rd6, %r26, %r17;
    setp.ge.s32 %p3, %r3, 256;
    @%p3 sub.s32 %r14, %r26, %r25;
    selp.b32 %r18, %r14, %r17, %p1;
    add.u32 %r14, %r25, %r14;
    sub.s32 %r24, %r3, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
