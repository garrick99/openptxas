.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r24, %r3, 1;
    mul.wide.s32 %rd11, %r3, %r24;
    mul.lo.s32 %r17, %r3, %r24;
    shr.u32 %r20, %r24, 7;
    cvt.s64.s32 %rd8, %r24;
    add.u32 %r24, %r24, %r24;
    setp.le.s32 %p2, %r20, 2147483647;
    @!%p2 cvt.u32.u64 %r21, %rd11;
    shr.u64 %rd5, %rd8, 1;
    shr.s32 %r18, %r3, 3;
    min.u64 %rd7, %rd11, %rd8;
    shr.s32 %r25, %r21, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
