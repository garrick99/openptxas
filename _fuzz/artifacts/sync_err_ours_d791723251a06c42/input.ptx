.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    add.u64 %rd14, %rd8, %rd8;
    mad.lo.s32 %r6, %r3, %r3, %r3;
    shl.b32 %r9, %r3, 31;
    mad.lo.s32 %r9, %r6, %r3, %r6;
    sub.u32 %r22, %r6, 65536;
    shl.b64 %rd13, %rd8, 48;
    setp.ne.s32 %p2, %r22, 2;
    @!%p2 mul.lo.s64 %rd5, %rd8, %rd14;
    mul.wide.s32 %rd9, %r3, %r22;
    shr.s64 %rd5, %rd8, 16;
    setp.le.s32 %p4, %r3, 256;
    shl.b64 %rd8, %rd13, 15;
    mul.wide.s32 %rd10, %r3, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
