.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r17, %r3, 64;
    cvt.u64.u32 %rd9, %r3;
    shr.s32 %r11, %r17, 31;
    cvt.u32.u64 %r8, %rd9;
    xor.b32 %r17, %r8, 63;
    mad.lo.s32 %r25, %r11, %r17, %r3;
    and.b64 %rd11, %rd9, %rd9;
    or.b32 %r9, %r3, %r8;
    mul.wide.u32 %rd12, %r11, %r11;
    min.u64 %rd11, %rd12, %rd9;
    mul.lo.s32 %r21, %r8, 3;
    max.u32 %r27, %r21, %r9;
    add.s32 %r21, %r17, %r3;
    and.b32 %r7, %r27, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
