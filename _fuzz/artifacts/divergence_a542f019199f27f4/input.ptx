.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r20, %r3, 7;
    sub.s32 %r10, %r3, 3;
    sub.s32 %r25, %r20, %r20;
    cvt.s64.s32 %rd11, %r3;
    shl.b64 %rd6, %rd11, 7;
    setp.eq.s32 %p2, %r10, 4294967295;
    @%p2 mul.wide.s32 %rd8, %r3, %r20;
    sub.s32 %r22, %r25, 1;
    add.u32 %r12, %r3, %r3;
    shr.u64 %rd11, %rd8, 48;
    mad.lo.s32 %r20, %r20, %r10, %r20;
    setp.ne.u32 %p4, %r22, 32;
    @!%p4 selp.b32 %r18, %r25, %r20, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
