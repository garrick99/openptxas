.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r25, %r3, 16;
    shr.s32 %r20, %r25, 4;
    xor.b32 %r16, %r3, 8;
    min.u32 %r22, %r3, %r3;
    setp.eq.s32 %p4, %r3, %r16;
    @%p4 cvt.s64.s32 %rd9, %r16;
    max.u32 %r18, %r16, 8;
    cvt.s64.s32 %rd5, %r20;
    mul.lo.u32 %r18, %r18, 7;
    shl.b64 %rd8, %rd9, 4;
    cvt.u64.u32 %rd6, %r16;
    max.u32 %r21, %r18, 65536;
    shr.u32 %r24, %r22, 15;
    min.s64 %rd10, %rd8, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
