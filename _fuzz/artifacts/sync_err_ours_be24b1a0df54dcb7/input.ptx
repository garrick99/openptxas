    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r27, %r3, 31;
    max.s32 %r20, %r27, %r3;
    or.b32 %r18, %r3, %r27;
    cvt.s64.s32 %rd11, %r18;
    max.s64 %rd11, %rd11, %rd11;
    setp.lt.u32 %p1, %r3, %r27;
    @%p1 min.s64 %rd8, %rd11, %rd11;
    add.s32 %r15, %r20, 0;
    max.u32 %r22, %r15, 2147483647;
    shr.u64 %rd5, %rd11, 2;
    setp.gt.s32 %p2, %r22, %r20;
    @%p2 mul.lo.s32 %r16, %r22, %r18;
    min.s32 %r16, %r20, 65536;
    or.b32 %r23, %r16, 65536;
    ld.param.u64 %rd3, [p_out];
