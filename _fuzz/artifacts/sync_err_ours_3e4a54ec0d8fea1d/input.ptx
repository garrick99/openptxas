.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd5, %r3, %r3;
    max.u32 %r21, %r3, 5;
    add.u32 %r10, %r21, %r3;
    shr.s32 %r7, %r21, 1;
    min.s32 %r20, %r3, %r3;
    shr.u32 %r10, %r10, 1;
    cvt.u32.u64 %r17, %rd5;
    and.b64 %rd5, %rd5, %rd5;
    xor.b32 %r6, %r7, %r3;
    shl.b64 %rd15, %rd5, 48;
    shr.u32 %r27, %r3, 30;
    add.u32 %r27, %r27, %r6;
    sub.u32 %r7, %r17, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
