.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    min.u32 %r26, %r3, 255;
    sub.s32 %r20, %r3, %r26;
    mad.lo.s32 %r11, %r3, %r20, %r26;
    min.u32 %r16, %r11, 65536;
    add.s32 %r6, %r16, %r16;
    cvt.s32.s64 %r7, %rd14;
    shr.s32 %r23, %r20, 30;
    max.s32 %r17, %r7, %r11;
    or.b32 %r7, %r17, %r26;
    add.u32 %r5, %r6, %r7;
    sub.u32 %r8, %r23, 256;
    cvt.u32.u64 %r25, %rd14;
    cvt.s32.s64 %r18, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
