.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r27, %r3, %r3;
    cvt.s64.s32 %rd8, %r3;
    mul.wide.u32 %rd6, %r27, %r3;
    sub.u32 %r26, %r27, 16;
    min.u32 %r22, %r3, %r26;
    max.u32 %r21, %r22, %r26;
    sub.s32 %r9, %r3, 32;
    or.b32 %r4, %r3, %r22;
    setp.ne.u32 %p4, %r3, %r4;
    cvt.u32.u64 %r22, %rd8;
    and.b32 %r17, %r22, %r4;
    add.s32 %r21, %r27, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
