.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r12, %r3, 31;
    cvt.s64.s32 %rd5, %r3;
    setp.ge.s32 %p2, %r3, %r12;
    @!%p2 and.b32 %r5, %r12, %r12;
    cvt.s64.s32 %rd12, %r3;
    sub.u32 %r4, %r12, %r12;
    add.u64 %rd10, %rd12, %rd5;
    mad.lo.s32 %r12, %r4, %r4, %r4;
    add.u32 %r26, %r12, 64;
    selp.b32 %r13, %r4, %r26, %p2;
    mul.lo.u64 %rd13, %rd10, %rd10;
    selp.b32 %r23, %r4, %r13, %p2;
    max.s32 %r18, %r3, %r3;
    cvt.s64.s32 %rd5, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
