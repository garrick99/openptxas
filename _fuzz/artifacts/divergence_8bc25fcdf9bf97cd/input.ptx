.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r7, %r3, %r3, %r3;
    sub.s32 %r16, %r3, 5;
    max.s32 %r24, %r3, %r16;
    min.u32 %r8, %r7, %r16;
    sub.s32 %r6, %r24, %r24;
    max.s32 %r15, %r3, %r8;
    min.s32 %r14, %r7, %r15;
    setp.hi.u32 %p1, %r7, 2147483648;
    mul.lo.s32 %r21, %r8, 4294967295;
    max.u32 %r11, %r16, 64;
    shl.b32 %r9, %r16, 31;
    cvt.u64.u32 %rd7, %r16;
    max.s32 %r10, %r21, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
