.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    cvt.s64.s32 %rd10, %r3;
    min.s32 %r11, %r3, %r3;
    sub.s32 %r24, %r3, %r11;
    shr.u32 %r27, %r24, 7;
    min.u32 %r18, %r27, %r27;
    cvt.s64.s32 %rd13, %r24;
    cvt.s32.s64 %r14, %rd13;
    setp.ge.s32 %p2, %r24, 2;
    or.b32 %r11, %r27, 63;
    mul.lo.u32 %r18, %r18, 7;
    cvt.u32.u64 %r10, %rd10;
    mul.lo.u32 %r25, %r3, %r18;
    max.s32 %r20, %r25, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
