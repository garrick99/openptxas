.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    shr.u64 %rd12, %rd7, 31;
    shr.s32 %r21, %r3, 15;
    min.u32 %r24, %r21, %r3;
    shr.s64 %rd15, %rd7, 4;
    cvt.u64.u32 %rd8, %r3;
    shr.u32 %r17, %r24, 1;
    shr.s32 %r18, %r17, 3;
    mul.wide.s32 %rd8, %r3, %r24;
    cvt.u32.u64 %r25, %rd15;
    mul.lo.s32 %r4, %r3, 255;
    max.u32 %r5, %r25, %r3;
    max.u32 %r18, %r24, 255;
    setp.ge.s32 %p2, %r25, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
