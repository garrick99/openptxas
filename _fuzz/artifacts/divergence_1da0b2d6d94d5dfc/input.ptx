.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p4, %r3, %r3;
    @%p4 mul.wide.u32 %rd9, %r3, %r3;
    setp.eq.s32 %p3, %r3, %r3;
    @!%p3 selp.b32 %r15, %r3, %r3, %p3;
    min.u32 %r26, %r15, %r15;
    mad.lo.s32 %r9, %r26, %r3, %r26;
    shl.b64 %rd10, %rd9, 62;
    max.s32 %r25, %r9, %r15;
    mul.wide.u32 %rd6, %r25, %r9;
    shr.s64 %rd15, %rd9, 4;
    shr.s64 %rd10, %rd6, 16;
    max.u64 %rd12, %rd15, %rd15;
    cvt.s64.s32 %rd9, %r9;
    add.u32 %r16, %r3, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
