.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r16, %r3, %r3;
    setp.eq.u32 %p2, %r16, %r3;
    @%p2 mul.wide.s32 %rd12, %r16, %r3;
    add.s32 %r4, %r16, 5;
    max.s32 %r11, %r4, %r16;
    setp.eq.u32 %p3, %r16, %r3;
    setp.ge.u32 %p3, %r11, 4;
    @%p3 and.b32 %r21, %r4, %r4;
    mul.lo.u32 %r16, %r16, %r16;
    shr.s32 %r9, %r4, 3;
    sub.s32 %r26, %r11, %r9;
    shr.u32 %r12, %r21, 15;
    mad.lo.s32 %r8, %r12, %r16, %r21;
    shr.s32 %r5, %r12, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
