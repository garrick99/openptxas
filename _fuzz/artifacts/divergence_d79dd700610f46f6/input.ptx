.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r16, %r3, %r3;
    sub.s32 %r15, %r3, 4;
    and.b32 %r5, %r15, 256;
    max.u32 %r13, %r5, %r3;
    cvt.u64.u32 %rd10, %r13;
    min.u64 %rd5, %rd10, %rd10;
    min.s32 %r25, %r3, %r13;
    xor.b32 %r27, %r15, %r15;
    sub.s32 %r10, %r15, 2147483648;
    shl.b64 %rd7, %rd10, 4;
    or.b32 %r6, %r15, 255;
    sub.s32 %r18, %r27, 8;
    mul.wide.s32 %rd8, %r13, %r27;
    cvt.u32.u64 %r11, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
