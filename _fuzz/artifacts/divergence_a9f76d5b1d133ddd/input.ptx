.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r4, %r3, 4;
    mad.lo.u32 %r4, %r4, %r3, %r3;
    cvt.u64.u32 %rd5, %r3;
    shr.u32 %r6, %r3, 0;
    max.u32 %r13, %r3, %r6;
    mad.lo.s32 %r13, %r4, %r6, %r3;
    min.u32 %r10, %r6, %r6;
    or.b64 %rd5, %rd5, %rd5;
    cvt.s64.s32 %rd14, %r10;
    mad.lo.u32 %r14, %r3, %r3, %r3;
    cvt.u64.u32 %rd6, %r10;
    setp.gt.u32 %p2, %r10, 0;
    @%p2 sub.u32 %r21, %r3, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
