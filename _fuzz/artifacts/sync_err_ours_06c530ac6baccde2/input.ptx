.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r21, %r3, 7;
    cvt.s64.s32 %rd8, %r21;
    or.b32 %r7, %r3, %r21;
    sub.s32 %r17, %r3, %r3;
    and.b32 %r22, %r17, %r21;
    shl.b32 %r4, %r22, 31;
    shr.s32 %r21, %r21, 4;
    shl.b32 %r18, %r7, 15;
    add.s32 %r26, %r7, %r3;
    mul.wide.s32 %rd6, %r3, %r3;
    mul.wide.s32 %rd7, %r18, %r7;
    setp.le.u32 %p2, %r17, 4294967295;
    mul.wide.s32 %rd6, %r22, %r26;
    shr.s32 %r14, %r7, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
