.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r24, %r3, 15;
    setp.gt.u32 %p4, %r3, 15;
    @!%p4 sub.u32 %r13, %r24, 15;
    selp.b32 %r24, %r13, %r24, %p4;
    mad.lo.s32 %r16, %r13, %r3, %r13;
    cvt.s64.s32 %rd15, %r13;
    selp.b32 %r4, %r16, %r24, %p4;
    shr.s64 %rd13, %rd15, 62;
    shr.u32 %r25, %r16, 31;
    cvt.u64.u32 %rd5, %r4;
    xor.b32 %r5, %r25, 8;
    cvt.u64.u32 %rd8, %r16;
    cvt.s64.s32 %rd13, %r5;
    max.u32 %r27, %r3, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
