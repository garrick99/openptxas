.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd13, %r3, %r3;
    shr.u32 %r4, %r3, 2;
    sub.u32 %r14, %r3, %r4;
    shl.b64 %rd5, %rd13, 62;
    setp.gt.s32 %p2, %r4, 65535;
    setp.ne.s32 %p1, %r14, %r4;
    @%p1 add.s32 %r16, %r4, %r4;
    and.b32 %r21, %r4, %r4;
    setp.le.s32 %p1, %r3, 32;
    mad.lo.s32 %r20, %r21, %r14, %r21;
    xor.b32 %r17, %r3, %r14;
    cvt.u64.u32 %rd14, %r4;
    sub.s32 %r8, %r16, 1;
    shr.u32 %r8, %r8, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
