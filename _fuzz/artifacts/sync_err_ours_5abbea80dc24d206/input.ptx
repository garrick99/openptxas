.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r11, %r3, 31;
    or.b32 %r10, %r11, 65536;
    setp.gt.s32 %p2, %r3, 4294967295;
    @!%p2 min.s32 %r21, %r11, %r10;
    xor.b32 %r19, %r10, %r21;
    min.s32 %r23, %r19, %r19;
    max.s32 %r17, %r3, 0;
    or.b32 %r27, %r23, %r17;
    shr.s32 %r16, %r27, 7;
    cvt.s64.s32 %rd5, %r17;
    selp.b32 %r26, %r23, %r11, %p2;
    cvt.s64.s32 %rd7, %r27;
    max.u64 %rd12, %rd7, %rd7;
    shr.s32 %r16, %r3, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
