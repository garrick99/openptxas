    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r9, %r3, 0;
    setp.eq.u32 %p4, %r3, 0;
    setp.le.s32 %p1, %r3, 4294967295;
    mul.wide.u32 %rd5, %r9, %r9;
    and.b32 %r21, %r3, 7;
    shr.u64 %rd5, %rd5, 7;
    cvt.s32.s64 %r24, %rd5;
    mad.lo.s32 %r22, %r21, %r21, %r9;
    max.s32 %r13, %r24, 65536;
    cvt.s64.s32 %rd7, %r13;
    shr.u64 %rd10, %rd5, 1;
    sub.s32 %r25, %r24, %r22;
    sub.u32 %r22, %r24, %r3;
