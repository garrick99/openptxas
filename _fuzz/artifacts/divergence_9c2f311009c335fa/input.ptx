.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r20, %r3, %r3, %r3;
    cvt.u64.u32 %rd14, %r20;
    setp.lt.u32 %p4, %r3, %r20;
    @%p4 max.u32 %r23, %r20, 63;
    shr.u32 %r23, %r23, 4;
    shr.u64 %rd5, %rd14, 33;
    mad.lo.s32 %r5, %r3, %r3, %r20;
    sub.u32 %r13, %r23, %r20;
    cvt.s64.s32 %rd6, %r13;
    mul.wide.s32 %rd12, %r3, %r5;
    shl.b32 %r13, %r3, 2;
    shl.b64 %rd10, %rd6, 63;
    cvt.s32.s64 %r6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
