.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r26, %r3, %r3;
    cvt.s64.s32 %rd15, %r26;
    shl.b32 %r20, %r3, 0;
    max.s32 %r17, %r3, 255;
    mul.wide.u32 %rd8, %r3, %r17;
    mul.wide.s32 %rd11, %r17, %r17;
    cvt.s64.s32 %rd9, %r3;
    mad.lo.u32 %r19, %r3, %r20, %r26;
    min.s32 %r14, %r19, %r17;
    setp.hs.u32 %p2, %r14, 3;
    @%p2 max.u32 %r24, %r14, 3;
    mul.lo.s64 %rd6, %rd8, %rd11;
    selp.b32 %r20, %r17, %r26, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
