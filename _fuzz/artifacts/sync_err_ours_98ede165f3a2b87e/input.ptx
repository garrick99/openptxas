.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r9, %r3, 7;
    or.b32 %r17, %r3, 3;
    mul.lo.u32 %r16, %r9, %r17;
    setp.lt.s32 %p4, %r9, 256;
    @%p4 mul.lo.u32 %r13, %r9, %r16;
    mad.lo.s32 %r8, %r13, %r3, %r13;
    mad.lo.u32 %r16, %r3, %r13, %r13;
    setp.gt.s32 %p2, %r8, 7;
    add.s32 %r20, %r17, %r3;
    sub.s32 %r17, %r17, %r8;
    mul.lo.s32 %r5, %r17, 65535;
    cvt.s64.s32 %rd14, %r16;
    shr.s64 %rd9, %rd14, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
