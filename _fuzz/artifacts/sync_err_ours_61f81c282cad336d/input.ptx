    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd11, %r3, %r3;
    cvt.s32.s64 %r16, %rd11;
    min.u64 %rd6, %rd11, %rd11;
    shr.u32 %r17, %r16, 30;
    xor.b32 %r4, %r16, 64;
    cvt.s32.s64 %r25, %rd11;
    mul.lo.u32 %r14, %r16, %r17;
