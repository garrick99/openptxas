.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r16, %r3, 32;
    add.s32 %r10, %r3, 3;
    mul.wide.u32 %rd14, %r3, %r16;
    setp.ne.u32 %p3, %r3, 4294967295;
    shl.b64 %rd7, %rd14, 7;
    max.u32 %r22, %r16, %r3;
    shr.u32 %r11, %r22, 15;
    shl.b64 %rd15, %rd7, 62;
    mad.lo.s32 %r4, %r16, %r10, %r11;
    max.s32 %r7, %r4, 65536;
    setp.le.u32 %p1, %r11, 65536;
    @%p1 selp.b32 %r24, %r3, %r11, %p3;
    and.b64 %rd11, %rd7, %rd7;
    sub.s32 %r10, %r7, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
