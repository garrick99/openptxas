.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r14, %r3, %r3;
    mad.lo.s32 %r4, %r14, %r3, %r14;
    min.s32 %r20, %r4, %r4;
    cvt.u64.u32 %rd15, %r3;
    cvt.u32.u64 %r8, %rd15;
    mul.wide.s32 %rd12, %r4, %r8;
    shr.u32 %r27, %r20, 1;
    shr.u64 %rd9, %rd15, 31;
    shr.s64 %rd9, %rd15, 2;
    setp.ge.s32 %p3, %r4, 65536;
    @!%p3 mul.wide.u32 %rd10, %r20, %r20;
    add.s32 %r21, %r4, %r8;
    setp.lt.u32 %p2, %r4, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
