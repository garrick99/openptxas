.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p3, %r3, 2;
    @%p3 mad.lo.s32 %r21, %r3, %r3, %r3;
    setp.eq.s32 %p1, %r21, 15;
    setp.le.s32 %p3, %r3, %r21;
    @!%p3 add.u32 %r5, %r3, %r3;
    setp.ne.u32 %p2, %r5, 2147483648;
    @%p2 mul.wide.s32 %rd10, %r3, %r3;
    shr.s32 %r24, %r5, 30;
    cvt.u64.u32 %rd15, %r21;
    selp.b32 %r9, %r21, %r24, %p3;
    sub.s64 %rd14, %rd10, %rd10;
    xor.b32 %r18, %r21, %r24;
    shr.s32 %r6, %r24, 7;
    add.s64 %rd12, %rd15, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
