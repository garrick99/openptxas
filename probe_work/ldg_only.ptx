.version 9.0
.target sm_120
.address_size 64

.visible .entry ldg_only(
    .param .u64 out_ptr,
    .param .u64 in_ptr)
{
    .reg .b64   %rd<4>;
    .reg .b32   %r<2>;
    ld.param.u64    %rd0, [in_ptr];
    ld.global.u64   %rd1, [%rd0];
    ld.param.u64    %rd2, [out_ptr];
    st.global.u64   [%rd2], %rd1;
    ret;
}
