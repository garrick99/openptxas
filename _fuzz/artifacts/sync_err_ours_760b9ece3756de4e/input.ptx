.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r24, %r3, %r3;
    cvt.u64.u32 %rd7, %r24;
    shl.b64 %rd8, %rd7, 7;
    shr.s64 %rd12, %rd8, 0;
    cvt.u64.u32 %rd7, %r24;
    xor.b32 %r26, %r24, 65536;
    cvt.u64.u32 %rd8, %r24;
    and.b32 %r27, %r26, %r3;
    cvt.s32.s64 %r17, %rd12;
    shl.b64 %rd5, %rd12, 30;
    shr.s32 %r13, %r17, 4;
    max.u32 %r7, %r3, %r27;
    sub.s32 %r20, %r17, %r24;
    add.u32 %r25, %r13, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
