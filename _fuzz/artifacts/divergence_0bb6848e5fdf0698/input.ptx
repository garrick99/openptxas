.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r22, %r3, 3;
    cvt.s64.s32 %rd13, %r22;
    cvt.s64.s32 %rd15, %r22;
    mad.lo.u32 %r4, %r22, %r22, %r3;
    shr.s64 %rd10, %rd13, 2;
    shr.s64 %rd13, %rd10, 4;
    sub.s32 %r10, %r22, %r3;
    mad.lo.u32 %r24, %r22, %r22, %r10;
    or.b32 %r4, %r4, %r10;
    sub.s64 %rd13, %rd13, %rd10;
    setp.lo.u32 %p1, %r3, 255;
    @%p1 xor.b32 %r15, %r3, %r24;
    selp.b32 %r8, %r3, %r22, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
