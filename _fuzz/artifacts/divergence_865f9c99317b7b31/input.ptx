.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r6, %r3, 65535;
    setp.gt.u32 %p1, %r3, 0;
    cvt.u64.u32 %rd5, %r3;
    cvt.s32.s64 %r17, %rd5;
    setp.hi.u32 %p1, %r17, %r6;
    @!%p1 cvt.s32.s64 %r8, %rd5;
    cvt.s64.s32 %rd12, %r17;
    min.u32 %r11, %r17, %r3;
    selp.b32 %r10, %r11, %r8, %p1;
    setp.eq.u32 %p3, %r10, 7;
    @%p3 mul.wide.u32 %rd13, %r3, %r6;
    mul.lo.s64 %rd13, %rd12, %rd5;
    max.u32 %r16, %r8, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
