.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r7, %r3, 64;
    max.u32 %r12, %r3, %r7;
    mul.lo.u32 %r7, %r7, 2147483648;
    min.u32 %r10, %r7, %r7;
    mul.lo.s32 %r9, %r3, 255;
    shl.b32 %r22, %r3, 31;
    xor.b32 %r20, %r3, 2147483648;
    cvt.s64.s32 %rd15, %r10;
    add.s32 %r14, %r10, 256;
    mul.lo.u64 %rd5, %rd15, %rd15;
    mad.lo.u32 %r10, %r7, %r7, %r3;
    setp.eq.u32 %p2, %r12, %r9;
    @%p2 sub.s32 %r21, %r9, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
