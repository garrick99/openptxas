.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r6, %r3, %r3;
    mad.lo.s32 %r21, %r3, %r3, %r6;
    add.u32 %r7, %r3, %r6;
    max.s32 %r25, %r7, 7;
    shl.b32 %r6, %r25, 31;
    shr.u32 %r6, %r7, 1;
    shr.u32 %r16, %r3, 0;
    mul.wide.u32 %rd6, %r16, %r6;
    and.b64 %rd7, %rd6, %rd6;
    mad.lo.s32 %r21, %r6, %r25, %r7;
    mul.lo.s32 %r26, %r21, %r16;
    or.b64 %rd5, %rd7, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
