.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r10, %r3, 1;
    max.u32 %r22, %r3, 3;
    mad.lo.s32 %r5, %r10, %r10, %r10;
    min.s32 %r9, %r22, 4294967295;
    cvt.s64.s32 %rd9, %r9;
    shr.u64 %rd11, %rd9, 63;
    shr.s64 %rd14, %rd9, 31;
    mul.wide.s32 %rd10, %r3, %r9;
    shl.b64 %rd8, %rd9, 48;
    shl.b64 %rd5, %rd11, 16;
    and.b32 %r6, %r9, 2147483648;
    mad.lo.s32 %r23, %r6, %r3, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
