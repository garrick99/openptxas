.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r13, %r3, 4;
    mul.wide.u32 %rd6, %r13, %r13;
    min.s32 %r4, %r13, 63;
    cvt.u64.u32 %rd15, %r3;
    cvt.s64.s32 %rd13, %r4;
    xor.b32 %r6, %r13, 7;
    setp.eq.s32 %p2, %r3, %r13;
    setp.lo.u32 %p1, %r3, 1;
    @!%p1 sub.u32 %r9, %r13, %r13;
    add.u32 %r11, %r3, 2147483648;
    add.s32 %r22, %r11, %r11;
    mul.wide.u32 %rd14, %r22, %r13;
    sub.u32 %r9, %r4, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
