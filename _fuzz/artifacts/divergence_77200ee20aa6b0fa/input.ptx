    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r22, %r3, 32;
    or.b32 %r6, %r3, %r3;
    setp.lo.u32 %p1, %r22, 2147483648;
    @%p1 shl.b32 %r17, %r6, 4;
    shl.b32 %r11, %r17, 3;
    selp.b32 %r7, %r17, %r6, %p1;
