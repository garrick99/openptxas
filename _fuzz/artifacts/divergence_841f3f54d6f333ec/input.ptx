.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd6, %r3, %r3;
    shl.b64 %rd9, %rd6, 0;
    and.b32 %r19, %r3, 255;
    shr.s32 %r21, %r3, 3;
    xor.b32 %r20, %r3, 2147483647;
    sub.u32 %r16, %r3, 32;
    mul.wide.s32 %rd9, %r19, %r20;
    mul.wide.u32 %rd6, %r21, %r20;
    shl.b64 %rd5, %rd9, 31;
    setp.ge.u32 %p2, %r19, %r16;
    @!%p2 shl.b32 %r12, %r16, 1;
    shr.s64 %rd12, %rd6, 0;
    mul.lo.u32 %r19, %r19, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
