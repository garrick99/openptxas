.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    sub.u64 %rd14, %rd7, %rd7;
    setp.gt.s32 %p1, %r3, %r3;
    @%p1 shl.b64 %rd8, %rd14, 62;
    mad.lo.u32 %r25, %r3, %r3, %r3;
    shl.b32 %r11, %r3, 15;
    mad.lo.u32 %r5, %r25, %r25, %r25;
    shr.s32 %r26, %r3, 15;
    min.u64 %rd11, %rd14, %rd14;
    mad.lo.s32 %r15, %r11, %r3, %r25;
    mul.lo.u32 %r5, %r25, 31;
    setp.eq.u32 %p3, %r15, 256;
    shr.s32 %r23, %r15, 0;
    add.s32 %r23, %r3, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
