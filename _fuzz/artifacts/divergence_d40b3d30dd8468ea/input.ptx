.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r5, %r3, %r3, %r3;
    cvt.s64.s32 %rd8, %r5;
    mad.lo.s32 %r7, %r3, %r5, %r5;
    cvt.u64.u32 %rd7, %r7;
    setp.lt.s32 %p1, %r7, 4;
    @%p1 shr.s32 %r22, %r3, 30;
    setp.ls.u32 %p2, %r22, %r5;
    @%p2 selp.b32 %r17, %r3, %r5, %p2;
    max.s32 %r20, %r7, %r5;
    mad.lo.s32 %r17, %r20, %r3, %r17;
    sub.u64 %rd12, %rd8, %rd8;
    mul.wide.s32 %rd5, %r5, %r5;
    or.b32 %r26, %r7, %r17;
    mul.wide.s32 %rd15, %r26, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
