    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    mul.lo.u64 %rd5, %rd8, %rd8;
    max.u32 %r18, %r3, 0;
    cvt.u64.u32 %rd5, %r3;
    mul.lo.s32 %r20, %r18, %r3;
    cvt.u32.u64 %r9, %rd8;
    min.s32 %r17, %r9, 2147483647;
    mul.lo.u32 %r13, %r20, 2147483648;
    shr.s64 %rd7, %rd5, 16;
    or.b32 %r24, %r20, %r17;
