.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    and.b64 %rd11, %rd13, %rd13;
    mul.wide.u32 %rd7, %r3, %r3;
    mad.lo.s32 %r6, %r3, %r3, %r3;
    min.s32 %r22, %r3, %r6;
    mad.lo.u32 %r8, %r6, %r22, %r6;
    add.u32 %r22, %r3, 8;
    setp.eq.s32 %p2, %r3, %r22;
    cvt.u32.u64 %r18, %rd13;
    add.s32 %r7, %r6, %r22;
    mad.lo.s32 %r6, %r18, %r18, %r6;
    mul.wide.u32 %rd10, %r3, %r7;
    cvt.u32.u64 %r6, %rd7;
    or.b32 %r12, %r6, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
