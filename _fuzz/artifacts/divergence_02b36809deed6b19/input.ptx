    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r13, %r3, %r3, %r3;
    sub.u32 %r24, %r13, 31;
    mul.lo.u32 %r16, %r13, 2147483647;
