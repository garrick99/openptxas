.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    sub.u32 %r21, %r3, 255;
    mul.lo.u32 %r18, %r3, %r3;
    cvt.u32.u64 %r26, %rd5;
    shr.s64 %rd5, %rd5, 33;
    max.s32 %r21, %r21, 0;
    mad.lo.u32 %r16, %r3, %r21, %r18;
    cvt.s32.s64 %r7, %rd5;
    and.b32 %r14, %r16, 7;
    setp.ge.u32 %p2, %r21, %r3;
    @%p2 add.s32 %r23, %r14, 16;
    mul.lo.s64 %rd8, %rd5, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
