.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r25, %r3, %r3;
    shl.b32 %r26, %r25, 16;
    cvt.u64.u32 %rd13, %r26;
    cvt.u32.u64 %r26, %rd13;
    and.b32 %r5, %r26, %r3;
    cvt.s64.s32 %rd14, %r5;
    add.s64 %rd6, %rd13, %rd13;
    cvt.s32.s64 %r10, %rd6;
    sub.s32 %r16, %r10, %r26;
    mul.lo.u32 %r22, %r3, %r25;
    add.s32 %r19, %r25, %r22;
    mul.wide.s32 %rd13, %r3, %r19;
    mul.wide.u32 %rd14, %r16, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
