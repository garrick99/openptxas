.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r8, %r3, 7;
    min.u32 %r19, %r8, %r3;
    setp.gt.s32 %p3, %r8, %r19;
    @!%p3 mad.lo.u32 %r23, %r19, %r19, %r19;
    mad.lo.u32 %r21, %r19, %r23, %r23;
    add.u32 %r5, %r3, %r23;
    setp.ge.s32 %p2, %r19, %r19;
    @%p2 mul.wide.s32 %rd8, %r5, %r5;
    setp.hi.u32 %p4, %r19, %r8;
    mul.wide.u32 %rd10, %r8, %r3;
    mad.lo.s32 %r25, %r19, %r19, %r21;
    shr.u32 %r24, %r23, 4;
    cvt.u32.u64 %r16, %rd8;
    shr.s64 %rd10, %rd8, 47;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
