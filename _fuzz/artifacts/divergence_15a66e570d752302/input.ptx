.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r18, %r3, %r3;
    shr.u32 %r14, %r3, 30;
    min.s32 %r11, %r3, 64;
    sub.s32 %r19, %r3, 255;
    sub.s32 %r7, %r11, 5;
    setp.ls.u32 %p4, %r11, %r11;
    @!%p4 cvt.u64.u32 %rd8, %r7;
    setp.ge.s32 %p4, %r3, %r19;
    setp.ge.u32 %p3, %r18, 1;
    @%p3 selp.b32 %r26, %r7, %r11, %p4;
    cvt.s64.s32 %rd9, %r14;
    sub.u32 %r6, %r3, %r18;
    min.s32 %r25, %r7, 31;
    mul.wide.u32 %rd7, %r19, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
