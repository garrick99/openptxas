.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r27, %r3, 0;
    min.u32 %r23, %r27, %r27;
    cvt.s64.s32 %rd10, %r23;
    shl.b32 %r23, %r3, 3;
    setp.ne.s32 %p4, %r27, 64;
    @!%p4 shr.s32 %r19, %r27, 0;
    mul.wide.u32 %rd10, %r23, %r23;
    or.b64 %rd12, %rd10, %rd10;
    cvt.s32.s64 %r11, %rd10;
    mad.lo.s32 %r16, %r3, %r11, %r23;
    xor.b64 %rd13, %rd10, %rd12;
    sub.u32 %r19, %r16, 15;
    mad.lo.u32 %r21, %r19, %r11, %r11;
    shr.s64 %rd6, %rd10, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
