.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    add.s32 %r5, %r3, 16;
    mul.wide.s32 %rd10, %r5, %r5;
    mul.lo.s32 %r23, %r3, %r3;
    sub.u32 %r20, %r5, %r23;
    cvt.s32.s64 %r21, %rd10;
    min.s32 %r22, %r23, 4294967295;
    shl.b64 %rd14, %rd10, 3;
    sub.s64 %rd5, %rd14, %rd15;
    sub.u32 %r8, %r21, %r23;
    max.s32 %r25, %r23, %r20;
    and.b32 %r7, %r22, %r21;
    and.b32 %r4, %r7, 32;
    or.b64 %rd7, %rd15, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
