    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    sub.u32 %r12, %r3, 15;
    mul.lo.s32 %r9, %r12, %r3;
    setp.eq.s32 %p3, %r3, %r3;
    @%p3 shr.s64 %rd11, %rd6, 4;
    add.s64 %rd6, %rd6, %rd6;
    shl.b64 %rd8, %rd11, 48;
    mul.wide.u32 %rd12, %r12, %r12;
    setp.ls.u32 %p2, %r12, 2147483647;
    @!%p2 mad.lo.u32 %r17, %r9, %r3, %r12;
    shr.s64 %rd13, %rd11, 32;
    selp.b32 %r6, %r3, %r3, %p2;
