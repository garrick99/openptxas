.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r21, %r3, %r3;
    cvt.u64.u32 %rd11, %r3;
    sub.s32 %r18, %r3, 4;
    xor.b32 %r15, %r18, 256;
    setp.le.u32 %p4, %r3, 2;
    @%p4 shr.u32 %r8, %r3, 31;
    max.s32 %r19, %r8, %r18;
    mul.lo.u32 %r10, %r3, %r21;
    add.s32 %r26, %r3, %r10;
    selp.b32 %r21, %r19, %r19, %p4;
    cvt.u32.u64 %r10, %rd11;
    xor.b32 %r8, %r21, 0;
    add.s64 %rd12, %rd11, %rd11;
    xor.b32 %r22, %r18, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
