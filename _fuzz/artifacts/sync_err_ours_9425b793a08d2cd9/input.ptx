    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r19, %r3, 2147483648;
    and.b32 %r10, %r19, %r19;
    setp.ls.u32 %p1, %r19, %r10;
    @%p1 mul.lo.s32 %r15, %r10, 64;
    add.u32 %r24, %r19, %r3;
    min.s32 %r24, %r15, 16;
    setp.gt.s32 %p4, %r3, 4294967295;
