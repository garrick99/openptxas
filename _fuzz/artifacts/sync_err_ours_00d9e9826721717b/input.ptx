.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    shr.u64 %rd13, %rd13, 31;
    mul.lo.u32 %r9, %r3, 64;
    mul.lo.u64 %rd9, %rd13, %rd13;
    setp.ls.u32 %p1, %r9, 15;
    @!%p1 mul.lo.u64 %rd14, %rd9, %rd13;
    setp.le.u32 %p2, %r3, 7;
    @!%p2 add.u64 %rd15, %rd14, %rd13;
    shr.u64 %rd8, %rd14, 0;
    shr.u32 %r4, %r3, 1;
    min.u32 %r6, %r9, %r9;
    shr.s64 %rd11, %rd15, 7;
    mul.wide.s32 %rd6, %r6, %r6;
    mad.lo.u32 %r19, %r3, %r3, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
