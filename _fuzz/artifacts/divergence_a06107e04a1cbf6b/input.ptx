.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    max.s32 %r5, %r3, %r3;
    sub.s64 %rd7, %rd8, %rd8;
    min.u32 %r10, %r5, %r3;
    or.b32 %r21, %r10, %r5;
    add.u32 %r13, %r5, 16;
    cvt.s32.s64 %r20, %rd8;
    shr.s64 %rd14, %rd8, 62;
    setp.eq.s32 %p2, %r5, %r21;
    @%p2 shl.b32 %r17, %r20, 31;
    mul.lo.s32 %r15, %r20, 64;
    mad.lo.u32 %r25, %r3, %r20, %r3;
    shl.b32 %r19, %r20, 2;
    cvt.s64.s32 %rd7, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
