.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r16, %r3, 1;
    add.s32 %r5, %r3, %r16;
    sub.s32 %r9, %r5, 8;
    sub.u32 %r20, %r9, 31;
    setp.gt.s32 %p1, %r20, 16;
    @%p1 max.s32 %r23, %r3, %r5;
    mul.lo.u32 %r9, %r23, %r20;
    cvt.u64.u32 %rd11, %r23;
    cvt.s64.s32 %rd13, %r23;
    shr.u32 %r4, %r16, 31;
    mad.lo.s32 %r17, %r20, %r20, %r23;
    or.b32 %r24, %r20, %r3;
    sub.u32 %r4, %r24, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
