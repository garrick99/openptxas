.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r8, %r3, 32;
    mul.lo.s32 %r25, %r3, %r8;
    setp.ge.s32 %p3, %r8, %r8;
    @!%p3 sub.u32 %r9, %r25, 255;
    max.s32 %r24, %r3, %r25;
    shl.b32 %r14, %r9, 16;
    max.u32 %r5, %r24, 255;
    setp.le.s32 %p1, %r24, %r9;
    max.u32 %r20, %r9, %r14;
    mad.lo.u32 %r23, %r25, %r8, %r3;
    mul.lo.u32 %r8, %r14, 5;
    sub.u32 %r7, %r25, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
