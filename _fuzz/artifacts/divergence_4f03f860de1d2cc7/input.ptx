.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r5, %r3, 8;
    mad.lo.s32 %r24, %r5, %r3, %r5;
    shr.s32 %r23, %r24, 4;
    add.s32 %r21, %r5, 8;
    shl.b32 %r23, %r5, 4;
    or.b32 %r8, %r21, %r5;
    cvt.u64.u32 %rd6, %r24;
    setp.gt.u32 %p1, %r3, %r23;
    and.b32 %r5, %r3, 15;
    selp.b32 %r8, %r5, %r5, %p1;
    shr.s64 %rd6, %rd6, 7;
    setp.ne.s32 %p2, %r21, 3;
    @!%p2 shr.s32 %r20, %r3, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
