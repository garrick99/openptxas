.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r24, %r3, 30;
    max.u32 %r10, %r24, %r3;
    mul.lo.s32 %r4, %r3, %r3;
    cvt.u64.u32 %rd10, %r24;
    max.u32 %r7, %r24, 7;
    sub.u32 %r12, %r24, %r10;
    min.u32 %r7, %r12, %r24;
    shl.b32 %r17, %r24, 0;
    cvt.u32.u64 %r11, %rd10;
    mul.lo.s32 %r17, %r24, 31;
    shr.u64 %rd5, %rd10, 48;
    sub.u32 %r15, %r4, %r3;
    mul.lo.u32 %r14, %r4, 4294967295;
    mul.wide.s32 %rd11, %r24, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
