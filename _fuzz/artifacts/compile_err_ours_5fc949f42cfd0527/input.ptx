.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r17, %r0, %r3;
    or.b32 %r14, %r0, %r17;
    shfl.sync.down.b32 %r12, %r3, 4, 0x1f, -1;
    setp.ge.u32 %p1, %r12, 8;
    vote.sync.ballot.b32 %r18, %p1, -1;
    shfl.sync.idx.b32 %r9, %r12, 15, 0x1f, -1;
    vote.sync.all.pred %p2, %p1, -1;
    and.b32 %r13, %r9, %r18;
    sub.u32 %r18, %r17, %r12;
    shfl.sync.idx.b32 %r15, %r14, 15, 0x1f, -1;
    shfl.sync.bfly.b32 %r4, %r14, 4, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
