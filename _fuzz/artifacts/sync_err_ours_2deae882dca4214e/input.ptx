.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r21, %r3, 4294967295;
    sub.s32 %r17, %r3, %r3;
    shr.u32 %r11, %r17, 3;
    xor.b32 %r17, %r21, 65536;
    mad.lo.s32 %r12, %r21, %r21, %r11;
    add.u32 %r22, %r17, %r21;
    setp.lo.u32 %p4, %r17, 63;
    @%p4 or.b32 %r21, %r22, 7;
    add.s32 %r23, %r12, %r17;
    and.b32 %r16, %r21, 65536;
    mul.wide.u32 %rd11, %r12, %r22;
    shr.s64 %rd13, %rd11, 4;
    and.b32 %r7, %r23, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
