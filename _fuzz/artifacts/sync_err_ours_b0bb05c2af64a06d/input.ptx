.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r14, %r3, %r3, %r3;
    mul.wide.u32 %rd6, %r3, %r3;
    max.u32 %r16, %r14, 256;
    min.u32 %r21, %r14, %r16;
    max.s32 %r25, %r14, %r3;
    mad.lo.u32 %r20, %r16, %r16, %r16;
    shr.s32 %r21, %r20, 30;
    sub.u64 %rd9, %rd6, %rd6;
    shl.b32 %r22, %r25, 0;
    max.s32 %r16, %r3, %r21;
    max.u32 %r16, %r3, %r22;
    mad.lo.u32 %r10, %r22, %r25, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
