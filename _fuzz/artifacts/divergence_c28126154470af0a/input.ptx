.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r13, %r3, 31;
    xor.b32 %r6, %r3, 2147483648;
    add.s32 %r9, %r3, %r13;
    sub.u32 %r5, %r13, %r3;
    mul.lo.s32 %r6, %r13, %r9;
    cvt.s64.s32 %rd7, %r6;
    setp.gt.s32 %p3, %r9, %r13;
    @!%p3 selp.b32 %r18, %r13, %r5, %p3;
    mul.lo.s32 %r9, %r5, %r3;
    add.s32 %r12, %r9, %r13;
    sub.u32 %r23, %r9, 2147483648;
    sub.s32 %r13, %r5, %r23;
    xor.b32 %r6, %r12, 32;
    selp.b32 %r13, %r13, %r9, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
