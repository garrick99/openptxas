.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p1, %r3, 16;
    @%p1 shr.s32 %r25, %r3, 7;
    setp.eq.u32 %p2, %r25, %r25;
    @%p2 mul.lo.s32 %r27, %r3, %r25;
    cvt.s64.s32 %rd6, %r25;
    shr.u64 %rd11, %rd6, 3;
    or.b32 %r4, %r25, 31;
    shr.s32 %r21, %r27, 30;
    shr.s64 %rd12, %rd11, 33;
    mad.lo.u32 %r8, %r4, %r27, %r27;
    mul.wide.u32 %rd15, %r25, %r4;
    min.s32 %r24, %r3, %r25;
    mul.lo.u64 %rd14, %rd15, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
