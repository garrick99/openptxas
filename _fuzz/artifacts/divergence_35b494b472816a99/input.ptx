.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r4, %r3, 64;
    cvt.s64.s32 %rd6, %r3;
    shl.b64 %rd11, %rd6, 31;
    mul.lo.u32 %r15, %r3, %r3;
    shr.s32 %r9, %r4, 16;
    max.u32 %r4, %r3, %r15;
    mul.lo.u64 %rd11, %rd11, %rd11;
    mad.lo.s32 %r13, %r15, %r9, %r3;
    min.s32 %r13, %r15, %r15;
    or.b32 %r10, %r4, %r13;
    shr.s64 %rd15, %rd11, 63;
    max.u32 %r4, %r10, 1;
    shr.u64 %rd9, %rd11, 15;
    setp.gt.s32 %p2, %r3, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
