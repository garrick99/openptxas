    min.s32 %r11, %r23, 7;
    add.s32 %r17, %r23, %r15;
    setp.ls.u32 %p3, %r10, %r10;
    @%p3 or.b32 %r9, %r3, %r3;
    mul.wide.u32 %rd9, %r10, %r3;
    shl.b64 %rd6, %rd9, 16;
    min.u32 %r15, %r11, 2147483648;
    mul.lo.u64 %rd7, %rd6, %rd6;
