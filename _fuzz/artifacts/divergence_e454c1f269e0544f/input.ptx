.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    max.s32 %r17, %r3, 63;
    and.b64 %rd7, %rd8, %rd8;
    cvt.s32.s64 %r27, %rd7;
    mul.wide.s32 %rd7, %r27, %r17;
    and.b32 %r18, %r27, %r3;
    sub.u32 %r12, %r18, %r27;
    min.s32 %r18, %r17, %r18;
    shr.s64 %rd9, %rd7, 0;
    mul.lo.s32 %r10, %r3, 4294967295;
    shl.b32 %r15, %r17, 2;
    shl.b64 %rd14, %rd8, 33;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
