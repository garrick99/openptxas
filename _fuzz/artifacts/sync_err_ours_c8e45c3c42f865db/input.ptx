.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p3, %r3, 64;
    @%p3 add.s32 %r26, %r3, 3;
    min.u32 %r4, %r3, %r26;
    selp.b32 %r22, %r26, %r26, %p3;
    shr.s32 %r6, %r3, 3;
    or.b32 %r15, %r6, %r26;
    add.s32 %r5, %r22, %r4;
    mad.lo.u32 %r8, %r15, %r3, %r3;
    sub.u32 %r12, %r22, 4294967295;
    max.s32 %r23, %r5, %r3;
    mul.wide.s32 %rd6, %r12, %r22;
    add.s32 %r8, %r8, %r26;
    selp.b32 %r15, %r15, %r22, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
