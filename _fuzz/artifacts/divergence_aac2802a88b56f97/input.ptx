.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r5, %r3, %r3, %r3;
    shr.s32 %r17, %r3, 7;
    shr.u32 %r18, %r3, 7;
    mul.lo.s32 %r26, %r18, 63;
    max.u32 %r26, %r26, %r26;
    shl.b32 %r22, %r5, 2;
    mul.lo.u32 %r8, %r3, %r22;
    mul.lo.u32 %r9, %r5, 256;
    cvt.s64.s32 %rd10, %r9;
    shr.s64 %rd13, %rd10, 63;
    add.s32 %r20, %r17, %r8;
    setp.hs.u32 %p3, %r8, %r3;
    shr.s64 %rd6, %rd10, 16;
    selp.b32 %r10, %r9, %r17, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
