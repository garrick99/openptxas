.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    setp.hi.u32 %p4, %r3, 255;
    @%p4 max.s32 %r11, %r3, %r3;
    setp.le.s32 %p1, %r11, 256;
    @!%p1 min.s32 %r26, %r3, %r11;
    cvt.u32.u64 %r21, %rd6;
    max.s64 %rd7, %rd6, %rd6;
    shr.s32 %r15, %r26, 31;
    add.u32 %r23, %r21, %r21;
    shr.u64 %rd9, %rd7, 0;
    shr.s64 %rd15, %rd7, 63;
    shr.s32 %r16, %r11, 15;
    max.u32 %r12, %r11, 3;
    selp.b32 %r9, %r15, %r12, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
