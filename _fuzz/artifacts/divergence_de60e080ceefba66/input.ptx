.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    shl.b32 %r17, %r3, 2;
    add.s32 %r11, %r17, %r17;
    setp.ne.u32 %p1, %r11, 5;
    sub.s32 %r26, %r3, 64;
    mul.lo.s32 %r8, %r11, 255;
    add.u32 %r27, %r26, 65535;
    mad.lo.u32 %r26, %r3, %r17, %r8;
    and.b32 %r4, %r27, %r27;
    cvt.s64.s32 %rd11, %r3;
    and.b32 %r16, %r17, 4;
    sub.s32 %r14, %r11, 4294967295;
    sub.s32 %r22, %r14, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
