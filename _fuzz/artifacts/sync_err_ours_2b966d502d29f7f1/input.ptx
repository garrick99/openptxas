.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r18, %r3, 0;
    cvt.u64.u32 %rd6, %r18;
    add.s32 %r17, %r18, 65535;
    setp.ls.u32 %p3, %r17, %r18;
    @%p3 mul.lo.s32 %r15, %r18, %r18;
    max.u32 %r12, %r15, %r3;
    or.b64 %rd15, %rd6, %rd6;
    shr.u64 %rd15, %rd15, 1;
    shl.b32 %r13, %r12, 31;
    mul.lo.s32 %r8, %r12, %r15;
    mad.lo.u32 %r11, %r8, %r12, %r13;
    min.u32 %r23, %r8, 15;
    min.s32 %r8, %r13, 5;
    min.s32 %r14, %r23, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
