.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r26, %r3, %r3, %r3;
    xor.b32 %r10, %r26, 256;
    mul.lo.u32 %r16, %r3, %r10;
    setp.ls.u32 %p3, %r10, 2147483648;
    add.s32 %r13, %r16, %r16;
    setp.ge.s32 %p3, %r16, %r13;
    @%p3 add.s32 %r24, %r13, %r10;
    cvt.s64.s32 %rd11, %r3;
    sub.u32 %r15, %r10, 4294967295;
    sub.s32 %r5, %r16, %r24;
    setp.ls.u32 %p1, %r26, %r15;
    @%p1 mul.wide.s32 %rd14, %r24, %r3;
    shl.b64 %rd14, %rd11, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
