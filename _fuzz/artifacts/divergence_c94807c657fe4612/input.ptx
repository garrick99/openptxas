.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd15, %r3, %r3;
    add.u64 %rd7, %rd15, %rd15;
    add.s64 %rd7, %rd15, %rd15;
    max.u32 %r5, %r3, %r3;
    mul.lo.u64 %rd10, %rd7, %rd7;
    setp.eq.u32 %p3, %r5, 0;
    @%p3 max.s32 %r7, %r5, %r5;
    mul.lo.s32 %r27, %r7, %r3;
    mul.wide.u32 %rd8, %r5, %r27;
    cvt.u32.u64 %r15, %rd15;
    add.u32 %r26, %r27, 31;
    add.u32 %r17, %r3, %r15;
    selp.b32 %r14, %r3, %r5, %p3;
    shl.b64 %rd10, %rd7, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
