.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    cvt.u32.u64 %r5, %rd11;
    add.s32 %r4, %r3, 2147483647;
    add.s32 %r16, %r5, 16;
    shr.u32 %r21, %r16, 0;
    setp.lt.s32 %p3, %r4, %r3;
    @%p3 shr.s64 %rd15, %rd11, 30;
    cvt.u64.u32 %rd12, %r5;
    cvt.s32.s64 %r19, %rd15;
    shl.b64 %rd7, %rd12, 30;
    add.u32 %r27, %r3, %r19;
    max.s32 %r22, %r27, %r3;
    min.u32 %r23, %r5, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
