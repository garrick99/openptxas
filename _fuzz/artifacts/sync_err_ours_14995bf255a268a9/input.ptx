.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    setp.lo.u32 %p4, %r3, 256;
    @%p4 shr.u64 %rd15, %rd11, 2;
    mul.wide.s32 %rd11, %r3, %r3;
    cvt.s32.s64 %r22, %rd15;
    xor.b32 %r18, %r22, 63;
    sub.s32 %r6, %r22, %r22;
    mul.wide.s32 %rd8, %r22, %r18;
    mul.wide.u32 %rd10, %r3, %r3;
    cvt.u32.u64 %r19, %rd10;
    selp.b32 %r10, %r3, %r6, %p4;
    xor.b32 %r23, %r19, 1;
    add.u64 %rd7, %rd11, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
