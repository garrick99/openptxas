.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r5, %r3, %r3;
    cvt.s64.s32 %rd7, %r3;
    mul.lo.s32 %r11, %r3, 255;
    cvt.s32.s64 %r14, %rd7;
    setp.ne.s32 %p3, %r11, %r11;
    @%p3 min.u32 %r27, %r5, 255;
    cvt.u64.u32 %rd9, %r11;
    add.u32 %r23, %r3, 2;
    mul.wide.u32 %rd15, %r14, %r11;
    max.u64 %rd15, %rd7, %rd7;
    mul.wide.u32 %rd11, %r14, %r11;
    or.b32 %r10, %r14, 2147483647;
    shr.u64 %rd11, %rd15, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
