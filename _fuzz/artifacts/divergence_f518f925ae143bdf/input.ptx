.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    add.u32 %r16, %r3, 65535;
    setp.ge.s32 %p3, %r3, %r3;
    min.u64 %rd15, %rd13, %rd13;
    add.s32 %r8, %r16, 64;
    shr.u64 %rd10, %rd15, 62;
    selp.b32 %r10, %r16, %r8, %p3;
    shr.u32 %r9, %r10, 0;
    shr.s32 %r5, %r8, 1;
    sub.u32 %r16, %r3, 7;
    sub.s32 %r23, %r10, 32;
    sub.u32 %r24, %r5, %r23;
    mul.wide.s32 %rd8, %r9, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
