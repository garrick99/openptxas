.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r7, %r3, 4294967295;
    xor.b32 %r5, %r7, %r3;
    setp.ne.u32 %p1, %r3, 15;
    @!%p1 mul.wide.u32 %rd10, %r5, %r3;
    min.s64 %rd8, %rd10, %rd10;
    selp.b32 %r22, %r3, %r3, %p1;
    shr.s32 %r5, %r3, 7;
    sub.u32 %r6, %r3, %r5;
    cvt.u32.u64 %r12, %rd10;
    mul.wide.s32 %rd8, %r3, %r12;
    min.s32 %r20, %r3, 255;
    setp.lt.u32 %p4, %r7, 3;
    @!%p4 add.u32 %r8, %r5, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
