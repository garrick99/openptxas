.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r21, %r3, %r3;
    cvt.s64.s32 %rd11, %r21;
    setp.gt.u32 %p3, %r3, %r3;
    sub.s32 %r6, %r3, 7;
    shr.s64 %rd10, %rd11, 32;
    sub.u32 %r24, %r3, %r21;
    mul.lo.s64 %rd5, %rd10, %rd11;
    shr.u32 %r16, %r6, 3;
    setp.eq.s32 %p2, %r6, %r24;
    selp.b32 %r10, %r16, %r16, %p3;
    cvt.s64.s32 %rd10, %r3;
    setp.gt.s32 %p1, %r3, 31;
    @%p1 sub.s32 %r4, %r10, %r3;
    max.u32 %r13, %r16, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
