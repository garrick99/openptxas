.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r11, %r3, 4294967295;
    min.u32 %r11, %r11, %r3;
    setp.hi.u32 %p2, %r3, %r11;
    @%p2 sub.u32 %r15, %r11, 8;
    max.s32 %r13, %r15, %r3;
    cvt.s64.s32 %rd7, %r15;
    cvt.s64.s32 %rd15, %r3;
    setp.eq.u32 %p4, %r3, %r13;
    mul.lo.u32 %r26, %r3, %r3;
    add.s64 %rd13, %rd7, %rd15;
    sub.u32 %r19, %r3, 0;
    sub.s32 %r4, %r26, %r11;
    and.b32 %r5, %r3, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
