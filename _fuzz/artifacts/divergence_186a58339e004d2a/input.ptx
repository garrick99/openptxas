.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p2, %r3, %r3;
    @%p2 shr.s32 %r22, %r3, 30;
    shl.b32 %r5, %r22, 4;
    mul.wide.u32 %rd7, %r22, %r3;
    selp.b32 %r12, %r5, %r3, %p2;
    mul.wide.s32 %rd15, %r22, %r22;
    xor.b32 %r24, %r12, %r12;
    mul.wide.s32 %rd12, %r3, %r24;
    setp.le.s32 %p1, %r22, 5;
    @!%p1 min.u32 %r10, %r24, %r22;
    cvt.u32.u64 %r23, %rd7;
    cvt.s64.s32 %rd5, %r10;
    selp.b32 %r13, %r24, %r10, %p2;
    shr.s32 %r13, %r23, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
