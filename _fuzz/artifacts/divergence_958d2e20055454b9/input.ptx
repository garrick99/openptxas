.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r24, %r3, %r3;
    cvt.u64.u32 %rd12, %r3;
    shl.b32 %r10, %r24, 15;
    sub.s32 %r26, %r10, 4294967295;
    xor.b32 %r10, %r3, %r24;
    mad.lo.u32 %r8, %r10, %r10, %r24;
    xor.b32 %r17, %r26, 0;
    add.u32 %r17, %r24, 5;
    mul.lo.u32 %r23, %r3, 64;
    mul.lo.u32 %r10, %r10, 256;
    setp.gt.s32 %p1, %r26, 16;
    @%p1 mad.lo.u32 %r7, %r3, %r10, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
