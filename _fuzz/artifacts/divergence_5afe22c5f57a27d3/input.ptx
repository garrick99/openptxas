.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r18, %r3, 3;
    setp.lo.u32 %p4, %r18, 63;
    @%p4 cvt.u64.u32 %rd9, %r18;
    or.b32 %r19, %r3, %r18;
    xor.b64 %rd14, %rd9, %rd9;
    min.s32 %r18, %r19, %r18;
    cvt.s32.s64 %r19, %rd9;
    setp.eq.s32 %p2, %r3, %r18;
    @%p2 xor.b32 %r18, %r19, 4294967295;
    max.u32 %r27, %r18, 65536;
    mad.lo.u32 %r15, %r27, %r3, %r19;
    min.s32 %r16, %r18, 255;
    sub.s32 %r23, %r3, %r3;
    mad.lo.s32 %r27, %r27, %r16, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
