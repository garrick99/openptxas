.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfi.b32 %r6, %r3, %r3, 4, 7;
    bfe.s32 %r15, %r3, 16, 31;
    min.u32 %r7, %r3, 4294967295;
    and.b32 %r22, %r7, %r7;
    bfe.s32 %r23, %r6, 16, 32;
    brev.b32 %r16, %r23;
    bfi.b32 %r11, %r22, %r16, 31, 4;
    clz.b32 %r12, %r3;
    bfe.s32 %r20, %r15, 31, 32;
    bfe.s32 %r10, %r11, 7, 32;
    bfi.b32 %r22, %r22, %r15, 23, 7;
    bfe.s32 %r16, %r11, 16, 24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
