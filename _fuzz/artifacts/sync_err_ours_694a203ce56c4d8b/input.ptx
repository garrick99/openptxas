.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd7, %r3, %r3;
    setp.lt.u32 %p1, %r3, %r3;
    @%p1 min.s64 %rd10, %rd7, %rd7;
    sub.u32 %r16, %r3, %r3;
    cvt.s32.s64 %r8, %rd7;
    and.b32 %r22, %r8, 4294967295;
    mul.wide.s32 %rd11, %r8, %r8;
    shr.u32 %r16, %r8, 31;
    mad.lo.u32 %r27, %r8, %r16, %r3;
    cvt.s64.s32 %rd10, %r3;
    mad.lo.s32 %r14, %r8, %r3, %r27;
    mad.lo.s32 %r4, %r16, %r27, %r14;
    xor.b32 %r15, %r16, %r3;
    shr.s64 %rd11, %rd11, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
