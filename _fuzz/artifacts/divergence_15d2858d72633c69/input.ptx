.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p4, %r3, 7;
    @%p4 mul.lo.u32 %r7, %r3, %r3;
    shl.b32 %r13, %r7, 0;
    shr.s32 %r20, %r7, 16;
    mul.wide.u32 %rd8, %r3, %r20;
    shr.s64 %rd6, %rd8, 3;
    selp.b32 %r27, %r20, %r20, %p4;
    add.u32 %r26, %r20, %r3;
    sub.s64 %rd5, %rd8, %rd8;
    mul.lo.s32 %r17, %r3, 63;
    xor.b32 %r21, %r27, 64;
    mul.wide.s32 %rd12, %r26, %r3;
    shr.s32 %r16, %r7, 0;
    and.b64 %rd10, %rd6, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
