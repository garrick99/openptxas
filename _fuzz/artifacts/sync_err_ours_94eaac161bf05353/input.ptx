.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    xor.b64 %rd5, %rd7, %rd7;
    shr.s32 %r12, %r3, 16;
    min.s64 %rd11, %rd7, %rd5;
    shr.u64 %rd13, %rd5, 48;
    sub.u32 %r24, %r12, %r3;
    shl.b32 %r7, %r12, 3;
    shl.b32 %r24, %r3, 0;
    mad.lo.u32 %r9, %r24, %r24, %r24;
    add.u32 %r8, %r9, %r24;
    shr.u64 %rd8, %rd5, 31;
    shr.s64 %rd11, %rd7, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
