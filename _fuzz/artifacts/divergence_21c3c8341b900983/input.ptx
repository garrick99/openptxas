.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r14, %r3, %r3;
    xor.b32 %r24, %r3, %r3;
    cvt.s64.s32 %rd14, %r3;
    min.u32 %r8, %r3, %r24;
    max.u64 %rd12, %rd14, %rd14;
    cvt.u32.u64 %r23, %rd14;
    add.u32 %r25, %r23, 0;
    mad.lo.u32 %r19, %r25, %r8, %r14;
    mad.lo.u32 %r9, %r25, %r25, %r25;
    mad.lo.u32 %r4, %r9, %r23, %r8;
    and.b32 %r17, %r19, %r19;
    max.u32 %r23, %r14, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
