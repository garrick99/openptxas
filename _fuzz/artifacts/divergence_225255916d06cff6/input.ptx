.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r5, %r3, 2;
    shr.u32 %r17, %r3, 1;
    setp.hi.u32 %p2, %r17, 3;
    @%p2 cvt.u64.u32 %rd14, %r17;
    min.u32 %r16, %r17, %r17;
    shr.u32 %r10, %r17, 1;
    max.s32 %r21, %r3, 63;
    add.s32 %r10, %r10, %r16;
    shr.s64 %rd5, %rd14, 62;
    add.s32 %r23, %r10, %r5;
    cvt.s64.s32 %rd7, %r5;
    cvt.u32.u64 %r11, %rd14;
    shl.b64 %rd15, %rd14, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
