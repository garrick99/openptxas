.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r4, %r3, %r3;
    cvt.u64.u32 %rd14, %r3;
    setp.ls.u32 %p2, %r4, %r4;
    setp.le.s32 %p3, %r3, 8;
    @%p3 add.s64 %rd15, %rd14, %rd14;
    setp.ne.u32 %p4, %r3, 2147483647;
    @!%p4 min.s32 %r9, %r4, 8;
    add.s64 %rd5, %rd14, %rd15;
    setp.ge.s32 %p2, %r3, %r3;
    setp.hs.u32 %p4, %r9, 63;
    @%p4 max.u32 %r18, %r9, %r9;
    mul.wide.s32 %rd11, %r9, %r9;
    shr.s32 %r17, %r4, 7;
    min.s32 %r16, %r3, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
