.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    shr.u32 %r10, %r3, 0;
    sub.s32 %r6, %r10, 3;
    max.s32 %r11, %r6, %r10;
    xor.b32 %r24, %r6, %r11;
    mul.lo.s32 %r5, %r3, 15;
    min.u64 %rd11, %rd12, %rd12;
    mul.lo.s32 %r15, %r11, 32;
    cvt.u64.u32 %rd12, %r5;
    shl.b32 %r18, %r5, 0;
    max.u32 %r9, %r6, 4294967295;
    shr.u32 %r4, %r9, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
