.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r21, %r3, 2;
    setp.ne.s32 %p2, %r21, 7;
    @%p2 shl.b32 %r11, %r3, 15;
    and.b32 %r11, %r21, %r21;
    mul.wide.u32 %rd13, %r11, %r11;
    selp.b32 %r4, %r21, %r11, %p2;
    and.b32 %r17, %r4, 3;
    or.b32 %r21, %r3, %r3;
    max.u32 %r25, %r11, %r17;
    mul.wide.u32 %rd9, %r11, %r17;
    mul.wide.u32 %rd10, %r3, %r21;
    mad.lo.u32 %r14, %r4, %r11, %r25;
    sub.s32 %r10, %r11, %r11;
    sub.s32 %r15, %r14, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
