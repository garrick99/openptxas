.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r26, %r3, %r3;
    min.u32 %r15, %r26, %r3;
    setp.gt.u32 %p2, %r26, 15;
    setp.lt.u32 %p1, %r15, %r3;
    @!%p1 cvt.s64.s32 %rd6, %r15;
    shr.s32 %r25, %r3, 0;
    mul.wide.u32 %rd14, %r15, %r26;
    setp.ge.u32 %p2, %r26, 0;
    @!%p2 cvt.u32.u64 %r4, %rd14;
    setp.hi.u32 %p4, %r15, 256;
    shl.b64 %rd10, %rd14, 0;
    mul.lo.u32 %r24, %r15, 4;
    max.s32 %r20, %r25, 2147483647;
    or.b32 %r16, %r4, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
