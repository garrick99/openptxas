.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r6, %r3, 31;
    max.u32 %r24, %r6, %r6;
    max.s32 %r25, %r3, 31;
    setp.gt.u32 %p1, %r24, %r25;
    @%p1 add.u32 %r8, %r25, %r3;
    cvt.u64.u32 %rd5, %r25;
    sub.s32 %r10, %r25, %r3;
    xor.b32 %r24, %r3, %r10;
    shr.u32 %r18, %r6, 15;
    shl.b64 %rd12, %rd5, 32;
    and.b32 %r27, %r18, 4294967295;
    mul.lo.u32 %r10, %r8, %r27;
    sub.u32 %r11, %r25, %r27;
    cvt.u32.u64 %r4, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
