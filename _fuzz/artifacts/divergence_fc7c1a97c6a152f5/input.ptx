.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    setp.lo.u32 %p2, %r3, %r3;
    @!%p2 min.s32 %r6, %r3, %r3;
    mad.lo.u32 %r19, %r6, %r3, %r3;
    shr.u64 %rd12, %rd11, 15;
    shr.u64 %rd8, %rd11, 62;
    mul.lo.s32 %r13, %r6, %r6;
    shr.u32 %r23, %r13, 15;
    mul.lo.s64 %rd14, %rd8, %rd8;
    shl.b64 %rd10, %rd12, 4;
    add.s32 %r7, %r13, 32;
    max.s64 %rd14, %rd14, %rd10;
    mul.lo.u32 %r13, %r6, %r6;
    add.s32 %r19, %r19, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
