.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r7, %r3, 63;
    cvt.s64.s32 %rd14, %r7;
    mul.lo.u32 %r11, %r3, 65535;
    setp.eq.s32 %p3, %r7, 8;
    @!%p3 mul.lo.u32 %r12, %r11, 65536;
    xor.b64 %rd6, %rd14, %rd14;
    shl.b32 %r23, %r12, 0;
    sub.u32 %r16, %r3, 1;
    min.u64 %rd9, %rd6, %rd14;
    add.s32 %r16, %r12, %r23;
    mad.lo.u32 %r18, %r7, %r23, %r16;
    min.s32 %r5, %r11, %r7;
    max.u32 %r5, %r18, 5;
    min.u64 %rd15, %rd9, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
