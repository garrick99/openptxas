.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.down.b32 %r14, %r3, 1, 0x1f, -1;
    add.u32 %r18, %r0, %r3;
    or.b32 %r5, %r14, %r18;
    add.u32 %r13, %r14, %r0;
    min.u32 %r17, %r5, %r18;
    xor.b32 %r6, %r18, %r5;
    max.u32 %r15, %r18, %r14;
    shfl.sync.up.b32 %r6, %r13, 1, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
