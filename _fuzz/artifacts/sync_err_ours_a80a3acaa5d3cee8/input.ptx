    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r8, %r3, 32;
    max.u32 %r9, %r3, 4294967295;
    sub.s32 %r20, %r3, %r3;
    setp.hi.u32 %p1, %r3, %r9;
