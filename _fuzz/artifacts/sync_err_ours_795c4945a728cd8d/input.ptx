.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd15, %r3, %r3;
    setp.eq.s32 %p2, %r3, %r3;
    shr.s32 %r20, %r3, 30;
    mad.lo.u32 %r4, %r20, %r3, %r3;
    add.u32 %r13, %r20, %r20;
    shr.s32 %r11, %r3, 2;
    add.u32 %r18, %r3, %r11;
    shl.b32 %r22, %r11, 31;
    setp.ne.u32 %p2, %r22, %r22;
    @%p2 mul.wide.u32 %rd6, %r20, %r13;
    min.s64 %rd8, %rd6, %rd6;
    mad.lo.s32 %r18, %r22, %r4, %r11;
    shr.u32 %r22, %r20, 3;
    shr.u32 %r9, %r4, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
