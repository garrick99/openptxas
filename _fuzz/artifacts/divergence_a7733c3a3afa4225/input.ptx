.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r7, %r3, %r3;
    mul.lo.s32 %r15, %r7, %r7;
    setp.gt.s32 %p2, %r15, %r3;
    @%p2 or.b32 %r11, %r3, %r7;
    or.b32 %r15, %r15, %r7;
    sub.s32 %r17, %r11, 255;
    cvt.u64.u32 %rd5, %r15;
    mul.wide.s32 %rd13, %r7, %r7;
    add.s32 %r26, %r7, %r11;
    cvt.u32.u64 %r16, %rd5;
    mad.lo.u32 %r10, %r26, %r17, %r11;
    mul.wide.u32 %rd9, %r26, %r10;
    min.s64 %rd7, %rd9, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
