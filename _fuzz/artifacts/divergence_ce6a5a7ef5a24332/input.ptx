.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r20, %r3, %r3, %r3;
    setp.lo.u32 %p4, %r20, 65536;
    @!%p4 mul.lo.s32 %r19, %r20, 0;
    mad.lo.u32 %r25, %r3, %r3, %r20;
    xor.b32 %r21, %r25, %r20;
    min.u32 %r21, %r20, %r21;
    mul.lo.s32 %r9, %r20, 7;
    mad.lo.u32 %r17, %r3, %r25, %r3;
    mad.lo.s32 %r23, %r17, %r19, %r21;
    setp.eq.s32 %p3, %r20, %r25;
    @!%p3 sub.u32 %r5, %r9, %r9;
    add.s32 %r17, %r17, %r19;
    add.s32 %r17, %r21, %r3;
    selp.b32 %r21, %r20, %r3, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
