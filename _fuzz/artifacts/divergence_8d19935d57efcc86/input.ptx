    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r20, %r3, 2147483647;
    setp.gt.u32 %p4, %r20, 16;
    @%p4 min.u32 %r7, %r20, 2147483647;
    mul.lo.u32 %r5, %r20, 2147483647;
    cvt.u64.u32 %rd15, %r20;
