.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hi.u32 %p1, %r3, 64;
    @!%p1 shr.s32 %r11, %r3, 4;
    add.u32 %r21, %r11, %r11;
    sub.u32 %r24, %r21, %r21;
    mul.wide.u32 %rd6, %r24, %r21;
    mad.lo.u32 %r6, %r3, %r24, %r24;
    sub.u32 %r4, %r11, %r3;
    shr.s32 %r16, %r21, 4;
    xor.b32 %r6, %r24, %r4;
    mul.wide.u32 %rd7, %r3, %r24;
    mul.lo.u32 %r8, %r6, 31;
    selp.b32 %r19, %r6, %r3, %p1;
    setp.hi.u32 %p2, %r24, 65536;
    mul.lo.u32 %r9, %r4, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
