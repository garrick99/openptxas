.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r17, %r3, 0;
    shl.b32 %r25, %r3, 15;
    mul.lo.u32 %r15, %r3, 7;
    mul.wide.u32 %rd13, %r3, %r15;
    or.b32 %r23, %r15, %r25;
    setp.eq.s32 %p2, %r17, 63;
    @%p2 cvt.u32.u64 %r22, %rd13;
    min.u32 %r15, %r3, %r23;
    xor.b32 %r11, %r15, %r22;
    and.b32 %r20, %r15, %r11;
    sub.s32 %r9, %r25, 4;
    shr.u32 %r25, %r23, 3;
    and.b32 %r13, %r11, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
