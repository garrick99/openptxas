.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p3, %r3, %r3;
    @!%p3 mul.wide.s32 %rd6, %r3, %r3;
    xor.b32 %r17, %r3, 2147483647;
    cvt.s64.s32 %rd13, %r17;
    shr.s64 %rd14, %rd6, 16;
    mad.lo.u32 %r5, %r3, %r17, %r3;
    mul.wide.u32 %rd12, %r3, %r5;
    and.b32 %r10, %r17, 16;
    shr.u32 %r26, %r17, 1;
    shr.u32 %r27, %r17, 2;
    setp.le.u32 %p4, %r3, 32;
    @%p4 shr.u32 %r11, %r27, 7;
    mad.lo.u32 %r23, %r11, %r26, %r5;
    sub.u32 %r19, %r27, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
