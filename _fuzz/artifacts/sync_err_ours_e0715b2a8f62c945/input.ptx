.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r13, %r3, 4;
    cvt.u64.u32 %rd12, %r13;
    shr.u32 %r20, %r13, 16;
    shr.u32 %r4, %r13, 1;
    or.b32 %r7, %r13, %r4;
    xor.b32 %r12, %r7, 256;
    mul.wide.u32 %rd7, %r4, %r3;
    mad.lo.s32 %r5, %r12, %r3, %r12;
    setp.ls.u32 %p2, %r13, 4294967295;
    mul.wide.s32 %rd12, %r20, %r3;
    setp.le.s32 %p3, %r20, %r5;
    @!%p3 cvt.u32.u64 %r11, %rd7;
    sub.u32 %r20, %r5, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
