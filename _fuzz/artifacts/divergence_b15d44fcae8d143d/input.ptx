.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r11, %r3, 65535;
    add.u32 %r9, %r3, %r11;
    add.s32 %r27, %r11, 2;
    sub.u32 %r9, %r3, %r9;
    sub.u32 %r5, %r11, 15;
    min.s32 %r25, %r9, %r9;
    shr.u32 %r19, %r5, 2;
    setp.ge.s32 %p4, %r3, 32;
    @%p4 mul.wide.u32 %rd11, %r3, %r3;
    mul.lo.s64 %rd13, %rd11, %rd11;
    min.s32 %r10, %r27, 65535;
    cvt.u32.u64 %r4, %rd11;
    shr.u64 %rd13, %rd11, 33;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
