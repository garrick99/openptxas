    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r7, %r3, %r3, %r3;
    shl.b32 %r14, %r3, 0;
    and.b32 %r25, %r14, 65535;
    mul.wide.u32 %rd5, %r7, %r14;
    min.u32 %r7, %r3, %r3;
    cvt.u64.u32 %rd5, %r3;
    mul.wide.s32 %rd5, %r14, %r3;
    setp.ne.s32 %p2, %r14, 2147483647;
    @%p2 max.s64 %rd6, %rd5, %rd5;
    mad.lo.s32 %r18, %r25, %r3, %r7;
    max.u32 %r23, %r7, %r7;
    shr.s32 %r11, %r23, 16;
