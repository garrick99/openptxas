.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r23, %r3, %r3;
    and.b32 %r10, %r23, 2147483647;
    add.u32 %r11, %r3, 31;
    setp.eq.s32 %p3, %r11, %r23;
    max.u32 %r8, %r23, %r10;
    sub.s32 %r27, %r10, %r23;
    max.u32 %r24, %r11, %r23;
    add.s32 %r9, %r3, %r24;
    mul.lo.s32 %r12, %r3, %r27;
    setp.eq.u32 %p2, %r8, %r10;
    @!%p2 mad.lo.s32 %r21, %r9, %r8, %r24;
    mul.wide.s32 %rd5, %r11, %r10;
    mul.lo.u64 %rd13, %rd5, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
