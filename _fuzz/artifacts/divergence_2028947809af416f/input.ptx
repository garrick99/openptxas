.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r13, %r3, 64;
    setp.gt.s32 %p1, %r13, 3;
    add.u32 %r12, %r13, 32;
    sub.s32 %r18, %r3, %r3;
    min.u32 %r22, %r18, %r3;
    and.b32 %r21, %r3, %r12;
    shr.u32 %r7, %r13, 1;
    mul.wide.u32 %rd10, %r12, %r22;
    shr.u32 %r16, %r7, 2;
    mul.wide.u32 %rd7, %r18, %r22;
    max.u32 %r21, %r12, %r13;
    add.s32 %r26, %r18, 8;
    setp.ge.s32 %p3, %r22, %r22;
    @%p3 min.u32 %r26, %r16, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
