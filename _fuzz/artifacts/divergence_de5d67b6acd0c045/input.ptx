.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r23, %r3, %r3;
    mad.lo.u32 %r21, %r23, %r23, %r23;
    mad.lo.u32 %r10, %r3, %r23, %r3;
    mad.lo.u32 %r15, %r23, %r3, %r10;
    or.b32 %r4, %r23, %r21;
    or.b32 %r18, %r21, %r23;
    cvt.s64.s32 %rd6, %r3;
    cvt.s32.s64 %r24, %rd6;
    mul.wide.u32 %rd5, %r4, %r10;
    sub.s32 %r24, %r23, %r24;
    xor.b32 %r16, %r15, %r18;
    mad.lo.u32 %r13, %r16, %r18, %r3;
    setp.lt.u32 %p4, %r21, %r10;
    @%p4 sub.u32 %r14, %r16, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
