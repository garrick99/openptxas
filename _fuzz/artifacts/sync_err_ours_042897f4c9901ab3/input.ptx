.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p3, %r3, %r3;
    @!%p3 max.s32 %r23, %r3, %r3;
    sub.u32 %r5, %r3, 32;
    min.u32 %r4, %r23, %r5;
    add.s32 %r26, %r5, %r5;
    cvt.u64.u32 %rd15, %r3;
    shr.u32 %r17, %r3, 4;
    and.b32 %r5, %r23, %r5;
    selp.b32 %r22, %r5, %r17, %p3;
    sub.u64 %rd14, %rd15, %rd15;
    add.s32 %r9, %r26, %r23;
    min.u32 %r4, %r26, %r3;
    and.b32 %r17, %r22, 65536;
    sub.u32 %r17, %r22, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
