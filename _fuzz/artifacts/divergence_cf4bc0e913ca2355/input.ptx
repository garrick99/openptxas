.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r13, %r3, 0;
    add.u32 %r12, %r13, %r13;
    mul.wide.u32 %rd13, %r3, %r13;
    min.u32 %r27, %r13, 2;
    add.s32 %r8, %r13, %r12;
    mul.wide.s32 %rd15, %r12, %r27;
    shl.b32 %r25, %r13, 7;
    min.s32 %r16, %r8, %r3;
    and.b32 %r9, %r13, %r13;
    mul.lo.s32 %r18, %r3, 16;
    cvt.s64.s32 %rd13, %r16;
    setp.eq.s32 %p1, %r18, %r9;
    max.s32 %r15, %r13, %r27;
    max.s32 %r11, %r13, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
