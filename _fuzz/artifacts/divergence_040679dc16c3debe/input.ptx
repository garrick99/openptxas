.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    mul.lo.s32 %r8, %r3, %r3;
    min.s32 %r13, %r8, %r3;
    mad.lo.s32 %r10, %r8, %r8, %r13;
    mul.lo.u32 %r4, %r13, %r10;
    min.u32 %r4, %r4, %r4;
    min.u32 %r6, %r10, 2147483648;
    setp.hi.u32 %p1, %r6, %r8;
    @%p1 min.u32 %r5, %r3, %r13;
    cvt.s64.s32 %rd9, %r10;
    mul.lo.s32 %r6, %r8, %r10;
    cvt.u64.u32 %rd11, %r8;
    setp.gt.u32 %p4, %r13, 5;
    setp.le.u32 %p4, %r10, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
