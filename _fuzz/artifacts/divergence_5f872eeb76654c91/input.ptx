    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    sub.s32 %r5, %r3, 63;
    cvt.s64.s32 %rd15, %r5;
    cvt.u32.u64 %r22, %rd6;
    sub.u32 %r24, %r22, 63;
    max.u64 %rd6, %rd6, %rd15;
    add.s32 %r18, %r22, %r5;
    shr.u32 %r8, %r18, 7;
    sub.u32 %r19, %r5, %r24;
    mad.lo.u32 %r7, %r19, %r22, %r18;
    add.s32 %r23, %r5, 2147483648;
    cvt.u32.u64 %r14, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
