.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r15, %r3, 16;
    setp.eq.s32 %p4, %r15, %r3;
    @%p4 min.u32 %r16, %r3, 3;
    cvt.u64.u32 %rd6, %r15;
    shr.s32 %r6, %r15, 31;
    min.s32 %r7, %r6, %r16;
    mul.lo.u32 %r9, %r16, %r16;
    mul.lo.s32 %r16, %r9, %r7;
    add.u64 %rd11, %rd6, %rd6;
    add.s32 %r5, %r16, 64;
    sub.u32 %r26, %r5, %r3;
    setp.ge.s32 %p4, %r3, %r26;
    @%p4 cvt.s64.s32 %rd7, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
