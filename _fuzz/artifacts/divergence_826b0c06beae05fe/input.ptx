.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    mad.lo.u32 %r4, %r3, %r3, %r3;
    shr.s64 %rd12, %rd8, 7;
    setp.lt.u32 %p3, %r4, 16;
    @!%p3 xor.b32 %r22, %r4, 31;
    mul.wide.u32 %rd12, %r22, %r3;
    cvt.s64.s32 %rd12, %r22;
    cvt.s64.s32 %rd13, %r22;
    mad.lo.u32 %r26, %r22, %r22, %r22;
    max.s32 %r18, %r3, 8;
    setp.eq.s32 %p4, %r3, 255;
    @%p4 sub.u32 %r9, %r18, 256;
    shr.s64 %rd11, %rd8, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
