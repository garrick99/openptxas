.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p1, %r3, %r3;
    @!%p1 cvt.s64.s32 %rd5, %r3;
    cvt.s64.s32 %rd15, %r3;
    setp.hi.u32 %p3, %r3, %r3;
    cvt.u64.u32 %rd5, %r3;
    add.s32 %r10, %r3, 255;
    shr.s64 %rd8, %rd15, 0;
    shr.s32 %r21, %r3, 4;
    setp.ne.s32 %p3, %r10, %r21;
    @!%p3 shr.u32 %r27, %r3, 16;
    sub.u32 %r6, %r3, 1;
    mul.lo.u32 %r11, %r6, 65535;
    shr.s64 %rd8, %rd15, 48;
    add.s32 %r9, %r27, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
