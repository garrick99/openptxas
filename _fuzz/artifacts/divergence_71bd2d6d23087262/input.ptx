.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p1, %r3, 4294967295;
    @!%p1 add.u32 %r5, %r3, 65536;
    cvt.u64.u32 %rd11, %r3;
    cvt.s64.s32 %rd9, %r5;
    selp.b32 %r16, %r3, %r5, %p1;
    mul.wide.s32 %rd15, %r5, %r5;
    add.u32 %r15, %r3, 65535;
    shl.b32 %r16, %r15, 4;
    setp.lt.s32 %p1, %r3, %r3;
    @%p1 min.s32 %r24, %r5, 4;
    cvt.s64.s32 %rd13, %r24;
    mul.wide.s32 %rd8, %r3, %r24;
    mad.lo.s32 %r26, %r5, %r15, %r15;
    mul.wide.u32 %rd14, %r24, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
