.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p1, %r3, 4;
    @%p1 mad.lo.u32 %r8, %r3, %r3, %r3;
    cvt.s64.s32 %rd9, %r3;
    mul.lo.s32 %r20, %r3, 65535;
    shr.s64 %rd7, %rd9, 32;
    setp.lt.u32 %p1, %r3, %r20;
    @%p1 shr.s32 %r22, %r8, 30;
    setp.ge.s32 %p2, %r22, 4;
    @!%p2 or.b32 %r17, %r22, %r3;
    max.s64 %rd8, %rd9, %rd9;
    shr.s32 %r19, %r20, 15;
    mad.lo.u32 %r23, %r17, %r17, %r20;
    mad.lo.s32 %r16, %r19, %r22, %r22;
    mul.wide.s32 %rd8, %r3, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
