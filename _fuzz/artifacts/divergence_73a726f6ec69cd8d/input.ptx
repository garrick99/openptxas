.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd6, %r3, %r3;
    max.s32 %r11, %r3, 2;
    setp.eq.s32 %p2, %r11, %r11;
    setp.le.u32 %p2, %r3, 65536;
    @%p2 sub.u64 %rd10, %rd6, %rd6;
    selp.b32 %r25, %r11, %r3, %p2;
    setp.ls.u32 %p4, %r3, %r3;
    @!%p4 add.s32 %r9, %r3, %r25;
    shr.s64 %rd14, %rd10, 33;
    cvt.u32.u64 %r16, %rd6;
    cvt.u64.u32 %rd10, %r9;
    shr.u32 %r15, %r9, 15;
    or.b32 %r25, %r9, %r15;
    add.s32 %r9, %r16, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
