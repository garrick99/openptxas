.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r7, %r3, %r3, %r3;
    mul.lo.u32 %r26, %r3, 2147483647;
    setp.ne.s32 %p4, %r3, %r26;
    or.b32 %r23, %r3, 65535;
    xor.b32 %r8, %r3, 15;
    mul.lo.u32 %r22, %r3, %r7;
    add.u32 %r21, %r26, %r22;
    xor.b32 %r8, %r7, 4294967295;
    add.u32 %r9, %r21, 256;
    xor.b32 %r21, %r22, 4294967295;
    sub.s32 %r14, %r22, %r23;
    mul.wide.u32 %rd11, %r8, %r7;
    cvt.s32.s64 %r16, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
