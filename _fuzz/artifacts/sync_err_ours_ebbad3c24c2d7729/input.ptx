.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r5, %r3, 32;
    shr.s32 %r20, %r3, 15;
    add.s32 %r27, %r20, 2;
    shr.u32 %r18, %r5, 0;
    add.u32 %r4, %r5, %r5;
    shr.s32 %r13, %r3, 2;
    shr.u32 %r21, %r18, 7;
    cvt.u64.u32 %rd11, %r21;
    max.s64 %rd12, %rd11, %rd11;
    setp.eq.s32 %p2, %r27, 0;
    @!%p2 xor.b32 %r6, %r13, 4;
    mad.lo.s32 %r13, %r5, %r18, %r3;
    shl.b64 %rd12, %rd11, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
