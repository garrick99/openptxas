.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r11, %r3, %r3;
    add.u32 %r27, %r11, %r11;
    cvt.u64.u32 %rd15, %r3;
    shr.u64 %rd14, %rd15, 15;
    max.u32 %r18, %r3, %r27;
    add.s32 %r21, %r3, %r18;
    mul.wide.u32 %rd6, %r21, %r11;
    setp.eq.s32 %p4, %r3, 2;
    max.u32 %r4, %r27, %r21;
    mad.lo.s32 %r20, %r4, %r18, %r3;
    shl.b64 %rd7, %rd6, 0;
    setp.ge.s32 %p3, %r27, 3;
    @%p3 min.s32 %r15, %r27, 31;
    mad.lo.s32 %r10, %r20, %r4, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
