.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r5, %r3, %r3;
    cvt.u64.u32 %rd6, %r5;
    cvt.u64.u32 %rd10, %r3;
    and.b32 %r18, %r5, 256;
    shr.s64 %rd7, %rd6, 3;
    add.s32 %r27, %r18, %r5;
    mul.wide.u32 %rd7, %r3, %r5;
    max.u32 %r17, %r5, 3;
    shr.u64 %rd14, %rd6, 30;
    max.s32 %r27, %r3, %r18;
    add.s32 %r14, %r5, %r18;
    setp.gt.u32 %p2, %r18, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
