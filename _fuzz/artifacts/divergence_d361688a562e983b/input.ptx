.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd15, %r3, %r3;
    shr.s32 %r14, %r3, 15;
    xor.b64 %rd10, %rd15, %rd15;
    shr.s64 %rd12, %rd10, 7;
    shr.u32 %r15, %r14, 30;
    or.b32 %r13, %r3, %r14;
    setp.le.u32 %p3, %r3, 16;
    @%p3 and.b32 %r19, %r14, %r14;
    cvt.u32.u64 %r18, %rd12;
    sub.u32 %r11, %r3, 0;
    selp.b32 %r20, %r14, %r18, %p3;
    max.u32 %r10, %r14, %r13;
    max.u32 %r18, %r10, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
