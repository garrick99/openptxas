.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r8, %r3, 31;
    cvt.u64.u32 %rd11, %r3;
    setp.eq.s32 %p1, %r8, %r3;
    @%p1 add.s32 %r14, %r8, %r8;
    xor.b32 %r12, %r3, 4;
    max.s32 %r19, %r3, %r14;
    shr.u32 %r5, %r14, 30;
    min.s32 %r4, %r14, 31;
    shl.b32 %r13, %r4, 3;
    min.s32 %r22, %r12, %r19;
    and.b32 %r18, %r19, %r19;
    selp.b32 %r24, %r22, %r8, %p1;
    shr.s32 %r19, %r22, 16;
    mad.lo.s32 %r11, %r3, %r12, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
