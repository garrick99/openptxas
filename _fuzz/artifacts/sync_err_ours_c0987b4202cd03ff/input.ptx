.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r20, %r3, %r3;
    cvt.s64.s32 %rd7, %r3;
    max.s32 %r11, %r3, 2147483648;
    add.s32 %r9, %r3, %r3;
    shr.u32 %r7, %r9, 31;
    shr.u32 %r20, %r3, 15;
    cvt.s64.s32 %rd11, %r7;
    xor.b32 %r15, %r3, 256;
    max.s32 %r13, %r20, %r11;
    sub.u32 %r13, %r11, 256;
    min.s32 %r7, %r13, %r11;
    setp.le.s32 %p1, %r20, 2147483648;
    mul.wide.s32 %rd6, %r3, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
