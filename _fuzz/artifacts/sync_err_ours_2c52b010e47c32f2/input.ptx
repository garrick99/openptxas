.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    sub.u64 %rd10, %rd11, %rd11;
    cvt.s32.s64 %r24, %rd11;
    min.s64 %rd9, %rd11, %rd10;
    min.u32 %r12, %r3, %r24;
    min.s64 %rd13, %rd9, %rd11;
    or.b32 %r17, %r12, 3;
    sub.u32 %r22, %r3, 1;
    shr.u32 %r6, %r17, 4;
    mul.lo.s32 %r5, %r17, 255;
    mul.lo.u64 %rd7, %rd9, %rd9;
    mul.lo.s32 %r8, %r3, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
