.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r4, %r3, %r3;
    cvt.s64.s32 %rd9, %r3;
    min.s32 %r12, %r4, %r4;
    setp.hs.u32 %p1, %r12, %r12;
    @!%p1 mul.lo.s32 %r27, %r12, %r4;
    xor.b32 %r18, %r3, %r12;
    add.u32 %r12, %r4, %r3;
    shr.u32 %r10, %r27, 7;
    mul.lo.s32 %r10, %r4, 255;
    min.u32 %r4, %r18, %r12;
    mul.wide.s32 %rd7, %r27, %r27;
    cvt.u32.u64 %r26, %rd7;
    selp.b32 %r4, %r27, %r3, %p1;
    mad.lo.u32 %r16, %r26, %r27, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
