.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p2, %r0, 0;
    vote.sync.ballot.b32 %r6, %p2, -1;
    sub.u32 %r16, %r3, %r6;
    max.u32 %r5, %r0, %r16;
    shfl.sync.idx.b32 %r15, %r5, 7, 0x1f, -1;
    shfl.sync.up.b32 %r8, %r6, 8, 0x1f, -1;
    and.b32 %r8, %r5, %r0;
    vote.sync.any.pred %p1, %p2, -1;
    shfl.sync.down.b32 %r15, %r8, 2, 0x1f, -1;
    and.b32 %r9, %r8, %r16;
    shfl.sync.up.b32 %r6, %r3, 8, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
