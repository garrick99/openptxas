.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r18, %r3, 31;
    xor.b32 %r6, %r18, 32;
    max.s32 %r9, %r3, 2147483647;
    mad.lo.s32 %r11, %r3, %r6, %r3;
    sub.u32 %r21, %r9, 0;
    add.u32 %r25, %r18, 31;
    xor.b32 %r8, %r11, 3;
    max.s32 %r19, %r8, %r21;
    cvt.u64.u32 %rd9, %r11;
    mul.wide.s32 %rd6, %r21, %r9;
    setp.lt.u32 %p4, %r11, 15;
    @!%p4 mul.lo.u32 %r22, %r6, %r6;
    or.b32 %r19, %r11, %r22;
    add.u32 %r18, %r19, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
