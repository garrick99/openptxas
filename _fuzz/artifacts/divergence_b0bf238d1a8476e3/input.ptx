.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r17, %r3, 255;
    mul.wide.u32 %rd8, %r17, %r17;
    add.s32 %r16, %r3, 7;
    mad.lo.u32 %r13, %r17, %r16, %r17;
    shl.b32 %r14, %r17, 30;
    mul.wide.s32 %rd11, %r17, %r17;
    setp.ge.u32 %p3, %r3, %r17;
    @!%p3 mad.lo.u32 %r21, %r3, %r16, %r17;
    cvt.s64.s32 %rd9, %r14;
    mul.lo.u32 %r11, %r16, 63;
    mul.wide.u32 %rd5, %r11, %r17;
    mad.lo.u32 %r17, %r13, %r16, %r11;
    shr.u64 %rd12, %rd8, 33;
    mad.lo.s32 %r6, %r16, %r21, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
