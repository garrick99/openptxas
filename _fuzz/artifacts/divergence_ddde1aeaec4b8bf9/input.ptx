.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p4, %r3, 65535;
    @%p4 mul.lo.s32 %r23, %r3, %r3;
    add.u32 %r25, %r3, %r3;
    or.b32 %r8, %r3, %r23;
    cvt.s64.s32 %rd11, %r25;
    max.u32 %r4, %r3, 4294967295;
    add.s32 %r14, %r4, 2;
    shl.b32 %r5, %r3, 15;
    cvt.s32.s64 %r21, %rd11;
    and.b32 %r8, %r23, 65536;
    mul.lo.s32 %r17, %r8, %r4;
    shr.u64 %rd11, %rd11, 2;
    cvt.s64.s32 %rd15, %r21;
    sub.u32 %r24, %r8, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
