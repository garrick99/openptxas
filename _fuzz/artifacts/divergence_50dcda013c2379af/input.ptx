.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r26, %r3, 2;
    add.s32 %r21, %r3, 5;
    cvt.u64.u32 %rd7, %r21;
    mul.lo.u32 %r5, %r3, %r21;
    xor.b64 %rd15, %rd7, %rd7;
    sub.s64 %rd14, %rd15, %rd7;
    shr.s32 %r26, %r21, 3;
    cvt.s32.s64 %r25, %rd7;
    max.s32 %r4, %r26, 4294967295;
    mul.wide.s32 %rd15, %r25, %r3;
    setp.gt.u32 %p4, %r5, %r5;
    @%p4 sub.u32 %r13, %r5, %r4;
    shl.b32 %r23, %r13, 31;
    mad.lo.u32 %r12, %r21, %r26, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
