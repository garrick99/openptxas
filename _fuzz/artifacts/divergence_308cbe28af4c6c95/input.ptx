.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r10, %r3, %r3, %r3;
    sub.u32 %r14, %r10, %r3;
    cvt.u64.u32 %rd13, %r14;
    shr.s32 %r16, %r14, 16;
    and.b32 %r19, %r3, %r14;
    xor.b64 %rd11, %rd13, %rd13;
    add.s64 %rd8, %rd13, %rd13;
    mad.lo.u32 %r20, %r14, %r19, %r3;
    add.u32 %r24, %r20, %r10;
    mul.wide.u32 %rd12, %r14, %r10;
    setp.hi.u32 %p2, %r24, %r14;
    @%p2 max.u32 %r25, %r19, %r10;
    setp.ne.u32 %p2, %r25, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
