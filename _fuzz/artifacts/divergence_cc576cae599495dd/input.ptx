.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r21, %r3, %r3;
    sub.u32 %r9, %r3, %r3;
    min.s32 %r27, %r21, 1;
    setp.le.u32 %p4, %r9, 64;
    @!%p4 cvt.u64.u32 %rd12, %r21;
    sub.s64 %rd11, %rd12, %rd12;
    xor.b32 %r4, %r9, 15;
    shr.u64 %rd13, %rd12, 30;
    sub.s32 %r23, %r9, 2147483648;
    mul.wide.s32 %rd7, %r21, %r27;
    cvt.s32.s64 %r12, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
