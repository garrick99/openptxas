    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r20, %r3, 2147483648;
    cvt.s64.s32 %rd7, %r3;
    and.b32 %r8, %r20, %r20;
