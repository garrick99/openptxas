    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r6, %r3, %r3;
    max.s32 %r8, %r3, %r3;
    min.u32 %r18, %r3, 8;
    mul.lo.u32 %r22, %r18, 1;
    mul.lo.u32 %r19, %r3, 2147483647;
    mad.lo.s32 %r12, %r6, %r22, %r6;
    cvt.u64.u32 %rd12, %r8;
    max.s32 %r22, %r3, 4294967295;
    mul.lo.s32 %r25, %r19, %r19;
    shr.u64 %rd12, %rd12, 1;
    max.s32 %r5, %r25, %r22;
    max.s64 %rd6, %rd12, %rd12;
    max.u32 %r16, %r19, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
