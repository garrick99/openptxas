.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r6, %r3, %r3, %r3;
    shl.b32 %r4, %r3, 4;
    mul.wide.s32 %rd7, %r4, %r4;
    cvt.s64.s32 %rd9, %r6;
    sub.s32 %r22, %r4, %r3;
    max.s32 %r17, %r22, %r3;
    shl.b64 %rd8, %rd9, 62;
    mul.wide.s32 %rd5, %r4, %r6;
    setp.eq.u32 %p4, %r22, 2147483648;
    max.s32 %r27, %r17, %r3;
    cvt.u64.u32 %rd12, %r17;
    xor.b32 %r24, %r6, %r4;
    cvt.u32.u64 %r21, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
