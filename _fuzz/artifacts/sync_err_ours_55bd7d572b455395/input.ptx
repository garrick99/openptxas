.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    xor.b32 %r21, %r3, 255;
    cvt.s32.s64 %r24, %rd6;
    cvt.u32.u64 %r21, %rd6;
    xor.b32 %r17, %r24, %r3;
    cvt.u64.u32 %rd5, %r21;
    shr.s32 %r5, %r24, 2;
    cvt.u32.u64 %r13, %rd6;
    mul.wide.u32 %rd5, %r21, %r13;
    xor.b32 %r8, %r5, 63;
    sub.u32 %r15, %r8, %r17;
    shl.b64 %rd10, %rd5, 15;
    mad.lo.u32 %r22, %r13, %r3, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
