.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    sub.s64 %rd15, %rd13, %rd13;
    sub.s64 %rd10, %rd15, %rd15;
    shr.s32 %r18, %r3, 1;
    and.b32 %r15, %r3, %r18;
    sub.s64 %rd9, %rd10, %rd15;
    max.s32 %r26, %r18, %r3;
    min.s32 %r6, %r15, %r26;
    shr.s32 %r16, %r18, 4;
    setp.hs.u32 %p2, %r3, %r15;
    setp.gt.s32 %p1, %r15, %r18;
    @%p1 mad.lo.s32 %r4, %r16, %r26, %r18;
    mul.wide.u32 %rd13, %r26, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
