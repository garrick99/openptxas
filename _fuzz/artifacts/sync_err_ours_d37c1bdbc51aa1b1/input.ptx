.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd10, %r3, %r3;
    sub.u32 %r20, %r3, 65535;
    add.s32 %r5, %r3, 15;
    max.s32 %r18, %r3, %r20;
    add.u32 %r7, %r5, %r20;
    cvt.s64.s32 %rd11, %r18;
    and.b32 %r23, %r3, 256;
    add.s32 %r19, %r18, %r7;
    sub.s32 %r20, %r5, %r18;
    sub.u32 %r21, %r5, 64;
    add.s32 %r20, %r23, %r5;
    mad.lo.s32 %r13, %r7, %r20, %r18;
    or.b32 %r20, %r7, 2147483647;
    setp.ge.u32 %p3, %r19, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
