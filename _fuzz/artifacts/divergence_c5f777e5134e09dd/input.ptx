.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    setp.le.s32 %p3, %r3, %r3;
    and.b32 %r18, %r3, %r3;
    setp.lt.u32 %p2, %r3, %r3;
    @%p2 shl.b64 %rd7, %rd6, 1;
    cvt.u32.u64 %r5, %rd6;
    max.s32 %r19, %r3, 8;
    mul.wide.u32 %rd7, %r3, %r3;
    min.u32 %r20, %r5, %r18;
    selp.b32 %r9, %r19, %r3, %p3;
    and.b32 %r18, %r20, %r9;
    sub.s64 %rd14, %rd7, %rd7;
    mad.lo.u32 %r19, %r20, %r20, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
