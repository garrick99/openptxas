.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r21, %r3, %r3;
    setp.lt.u32 %p1, %r21, 3;
    @!%p1 or.b32 %r24, %r21, %r21;
    setp.ge.s32 %p2, %r24, 3;
    @!%p2 mul.wide.u32 %rd10, %r21, %r3;
    sub.u32 %r21, %r3, %r24;
    sub.s32 %r11, %r24, %r3;
    or.b64 %rd12, %rd10, %rd10;
    min.u32 %r22, %r24, %r21;
    min.s32 %r22, %r3, 2147483648;
    min.s32 %r12, %r24, 32;
    sub.u32 %r21, %r11, 65536;
    setp.ls.u32 %p2, %r21, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
