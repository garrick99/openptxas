.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    mul.lo.u32 %r10, %r3, %r3;
    xor.b32 %r19, %r10, %r3;
    shr.s64 %rd8, %rd14, 62;
    mul.lo.s32 %r4, %r10, %r10;
    max.s64 %rd5, %rd14, %rd8;
    mul.lo.s32 %r13, %r4, 2;
    min.s64 %rd10, %rd5, %rd5;
    add.s32 %r22, %r10, %r19;
    sub.u32 %r14, %r3, 256;
    mad.lo.s32 %r5, %r3, %r3, %r10;
    min.s32 %r25, %r5, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
