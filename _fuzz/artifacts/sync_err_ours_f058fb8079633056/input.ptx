.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r23, %r3, 30;
    shl.b32 %r6, %r3, 1;
    shr.s32 %r13, %r3, 30;
    mul.lo.u32 %r8, %r6, %r13;
    cvt.u64.u32 %rd13, %r3;
    sub.u32 %r13, %r3, 2;
    mul.lo.s32 %r14, %r3, 63;
    setp.gt.u32 %p2, %r3, %r23;
    @%p2 mul.lo.s32 %r7, %r14, %r8;
    cvt.s32.s64 %r22, %rd13;
    add.s32 %r16, %r6, %r13;
    sub.u32 %r27, %r13, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
