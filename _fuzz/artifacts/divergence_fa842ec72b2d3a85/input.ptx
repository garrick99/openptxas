.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r21, %r3, 256;
    max.s32 %r14, %r3, 5;
    sub.s32 %r6, %r3, %r14;
    cvt.u64.u32 %rd10, %r21;
    cvt.u32.u64 %r23, %rd10;
    mul.lo.s32 %r14, %r23, 255;
    or.b64 %rd7, %rd10, %rd10;
    mul.lo.s64 %rd12, %rd7, %rd10;
    xor.b32 %r21, %r23, %r6;
    mul.wide.s32 %rd14, %r21, %r21;
    sub.u32 %r7, %r21, %r3;
    max.u32 %r24, %r21, %r7;
    shr.s32 %r24, %r21, 1;
    cvt.u64.u32 %rd13, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
