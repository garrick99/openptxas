.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    setp.gt.u32 %p1, %r3, %r3;
    @!%p1 mad.lo.u32 %r11, %r3, %r3, %r3;
    add.u32 %r14, %r11, %r11;
    shr.u32 %r7, %r14, 1;
    mul.wide.s32 %rd13, %r14, %r7;
    sub.u64 %rd10, %rd10, %rd10;
    shl.b64 %rd10, %rd10, 4;
    cvt.s32.s64 %r22, %rd13;
    shl.b64 %rd7, %rd13, 2;
    mul.lo.s32 %r9, %r11, %r7;
    setp.lo.u32 %p2, %r11, %r11;
    @%p2 mad.lo.s32 %r8, %r9, %r22, %r9;
    cvt.s64.s32 %rd13, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
