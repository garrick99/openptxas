.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p1, %r3, 256;
    @%p1 or.b32 %r6, %r3, 64;
    max.u32 %r9, %r3, %r6;
    mul.lo.s32 %r24, %r3, %r6;
    selp.b32 %r7, %r24, %r6, %p1;
    setp.ne.s32 %p1, %r6, 15;
    cvt.s64.s32 %rd10, %r9;
    or.b32 %r18, %r6, %r6;
    setp.gt.s32 %p3, %r3, 4;
    add.s32 %r6, %r9, %r18;
    mul.lo.u32 %r24, %r24, %r9;
    shr.u64 %rd6, %rd10, 4;
    sub.s32 %r19, %r24, %r18;
    min.s64 %rd7, %rd10, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
