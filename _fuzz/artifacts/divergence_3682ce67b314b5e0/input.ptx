    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    shr.u64 %rd15, %rd5, 2;
    sub.s32 %r18, %r3, 4;
    mul.lo.u64 %rd5, %rd15, %rd15;
