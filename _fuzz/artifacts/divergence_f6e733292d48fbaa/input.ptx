.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r16, %r3, %r3, %r3;
    max.s32 %r14, %r16, 8;
    mad.lo.s32 %r23, %r16, %r16, %r14;
    cvt.s64.s32 %rd13, %r3;
    max.u32 %r27, %r14, %r3;
    shr.u32 %r5, %r27, 30;
    shr.u32 %r27, %r27, 16;
    setp.ge.u32 %p2, %r5, 31;
    setp.lt.u32 %p3, %r27, 15;
    @!%p3 sub.u32 %r19, %r16, 64;
    setp.ge.u32 %p3, %r3, %r5;
    @!%p3 cvt.s32.s64 %r12, %rd13;
    shl.b32 %r24, %r27, 1;
    add.u64 %rd14, %rd13, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
