.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r20, %r3, 30;
    setp.hs.u32 %p2, %r3, 2;
    @!%p2 cvt.u64.u32 %rd12, %r20;
    add.u32 %r6, %r20, %r3;
    add.u32 %r25, %r6, %r20;
    cvt.u64.u32 %rd8, %r3;
    xor.b32 %r21, %r3, %r6;
    setp.lt.u32 %p3, %r6, 31;
    @%p3 max.s64 %rd8, %rd12, %rd8;
    or.b32 %r16, %r21, 4;
    mul.lo.s64 %rd11, %rd12, %rd8;
    cvt.u64.u32 %rd6, %r21;
    add.s32 %r4, %r6, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
