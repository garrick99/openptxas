# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Compiled CUDA binaries (generated artifacts)
*.cubin
*.fatbin

# Debug / temp files
*.debug
*.pkl
*.bin

# PTX scratch files at repo root (generated during debugging/testing).
# /*.ptx covers all future scratch files without touching examples/ or probe_work/.
/*.ptx

# Misc scratch
*.bat

# RE scratch directory (contents ignored, directory itself kept so
# tracked exception files below are reachable)
probe_work/*
!probe_work/fg40_adversarial_harness.py
!probe_work/fg42_evidence_harness.py

# Local machine-specific junction (points to ptxas repro files)
ptxas_bug/

# WB-0 workbench artifacts (per-run JSON outputs)
results/

# Logs / temp
*.log
*.out
logs/
tmp/

# Editors / IDEs
.vscode/
.idea/
*.suo

# Secrets / local env
.env
.env.local
*.pem
*.key

# OS junk
.DS_Store
Thumbs.db
