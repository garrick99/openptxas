.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r17, %r3, 15;
    add.u32 %r24, %r17, %r17;
    sub.s32 %r17, %r24, %r3;
    sub.u32 %r14, %r24, %r3;
    setp.gt.u32 %p4, %r24, %r24;
    @%p4 selp.b32 %r9, %r24, %r14, %p4;
    shr.u32 %r19, %r14, 7;
    or.b32 %r24, %r9, %r17;
    selp.b32 %r8, %r19, %r3, %p4;
    mad.lo.u32 %r13, %r14, %r9, %r17;
    mul.wide.u32 %rd11, %r3, %r14;
    mul.wide.u32 %rd15, %r3, %r8;
    setp.le.u32 %p3, %r9, %r9;
    @%p3 mad.lo.s32 %r6, %r13, %r3, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
