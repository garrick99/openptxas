.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r23, %r3, 255;
    shr.u32 %r14, %r23, 0;
    mul.lo.s32 %r26, %r23, %r3;
    mad.lo.s32 %r7, %r23, %r26, %r3;
    cvt.u64.u32 %rd6, %r14;
    and.b32 %r5, %r26, %r7;
    cvt.u32.u64 %r10, %rd6;
    max.s32 %r25, %r5, 65536;
    shl.b32 %r26, %r10, 31;
    xor.b32 %r8, %r7, %r3;
    cvt.u32.u64 %r6, %rd6;
    shl.b32 %r11, %r14, 2;
    cvt.u32.u64 %r23, %rd6;
    xor.b32 %r10, %r8, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
