.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p2, %r3, %r3;
    @%p2 add.s32 %r27, %r3, %r3;
    cvt.s64.s32 %rd7, %r27;
    mad.lo.u32 %r16, %r27, %r3, %r3;
    or.b32 %r26, %r27, 1;
    sub.s32 %r7, %r27, 65536;
    setp.ne.s32 %p3, %r26, 256;
    shl.b64 %rd13, %rd7, 16;
    mad.lo.u32 %r14, %r7, %r3, %r27;
    mul.lo.u32 %r12, %r27, %r26;
    shr.s64 %rd11, %rd7, 32;
    setp.ne.u32 %p2, %r7, %r7;
    @%p2 shr.u32 %r25, %r7, 2;
    sub.u32 %r18, %r25, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
