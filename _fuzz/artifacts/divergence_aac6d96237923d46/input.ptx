.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r13, %r3, 15;
    min.u32 %r11, %r13, %r3;
    max.s32 %r10, %r13, %r11;
    cvt.u64.u32 %rd8, %r3;
    xor.b32 %r10, %r13, 32;
    setp.ne.u32 %p1, %r10, %r11;
    @!%p1 max.u32 %r17, %r11, 2147483647;
    sub.s64 %rd6, %rd8, %rd8;
    or.b32 %r8, %r11, %r17;
    setp.lt.u32 %p1, %r11, %r17;
    @!%p1 cvt.s32.s64 %r4, %rd6;
    max.u64 %rd5, %rd8, %rd6;
    shr.s64 %rd11, %rd6, 3;
    mul.lo.s32 %r4, %r8, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
