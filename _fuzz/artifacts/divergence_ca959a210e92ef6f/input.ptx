.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    shr.s64 %rd12, %rd6, 48;
    max.u32 %r10, %r3, 2147483648;
    shl.b32 %r27, %r3, 2;
    min.s32 %r19, %r3, %r27;
    add.u64 %rd6, %rd12, %rd12;
    cvt.u64.u32 %rd13, %r19;
    shl.b64 %rd15, %rd13, 2;
    setp.gt.s32 %p2, %r19, %r27;
    add.s32 %r23, %r27, 65535;
    shl.b32 %r11, %r3, 16;
    min.s32 %r14, %r27, %r3;
    setp.hs.u32 %p4, %r3, 255;
    xor.b64 %rd5, %rd12, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
