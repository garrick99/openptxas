.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r18, %r3, 3;
    mul.lo.s32 %r8, %r3, 64;
    max.u32 %r20, %r18, 256;
    cvt.u64.u32 %rd8, %r20;
    shl.b32 %r6, %r18, 31;
    mad.lo.s32 %r10, %r8, %r18, %r8;
    cvt.u32.u64 %r21, %rd8;
    shr.s32 %r6, %r10, 7;
    cvt.s64.s32 %rd11, %r10;
    mul.wide.u32 %rd15, %r3, %r3;
    mul.wide.s32 %rd9, %r20, %r18;
    min.u32 %r17, %r8, %r10;
    mul.lo.u32 %r11, %r8, %r17;
    shr.u64 %rd15, %rd11, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
