.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r24, %r3, %r3;
    setp.ge.s32 %p4, %r3, 15;
    @%p4 cvt.s64.s32 %rd14, %r24;
    and.b32 %r16, %r3, %r24;
    selp.b32 %r4, %r24, %r3, %p4;
    cvt.s64.s32 %rd8, %r16;
    min.s64 %rd13, %rd8, %rd8;
    setp.ge.s32 %p1, %r16, 16;
    @!%p1 sub.u64 %rd10, %rd14, %rd8;
    cvt.s64.s32 %rd8, %r4;
    shr.s32 %r18, %r16, 7;
    mul.lo.u64 %rd15, %rd13, %rd13;
    shl.b64 %rd10, %rd14, 63;
    min.u32 %r22, %r3, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
