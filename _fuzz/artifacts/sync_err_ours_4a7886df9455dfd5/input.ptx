.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r13, %r3, 16;
    and.b32 %r19, %r13, %r3;
    shr.s32 %r16, %r19, 16;
    cvt.u64.u32 %rd8, %r13;
    min.u32 %r4, %r13, 256;
    shr.u64 %rd13, %rd8, 4;
    min.u32 %r15, %r3, 1;
    add.s32 %r24, %r16, 255;
    min.u32 %r13, %r24, 255;
    and.b32 %r4, %r19, %r15;
    setp.ne.u32 %p3, %r3, 4294967295;
    @%p3 sub.s32 %r15, %r16, %r4;
    sub.u32 %r6, %r19, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
