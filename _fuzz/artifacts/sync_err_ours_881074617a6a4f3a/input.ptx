.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd6, %r3, %r3;
    or.b32 %r6, %r3, 3;
    setp.gt.u32 %p4, %r6, %r3;
    @%p4 cvt.u64.u32 %rd11, %r6;
    min.u32 %r12, %r3, %r6;
    mul.lo.s32 %r15, %r3, 0;
    mul.lo.s32 %r25, %r12, %r3;
    mad.lo.u32 %r13, %r15, %r25, %r15;
    cvt.u32.u64 %r6, %rd11;
    and.b32 %r9, %r25, %r25;
    setp.ge.s32 %p3, %r9, %r25;
    @%p3 selp.b32 %r25, %r13, %r13, %p4;
    or.b32 %r6, %r9, 64;
    min.s64 %rd8, %rd6, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
