.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    add.u64 %rd7, %rd5, %rd5;
    xor.b32 %r14, %r3, %r3;
    xor.b32 %r24, %r3, %r14;
    or.b64 %rd5, %rd7, %rd7;
    min.u32 %r7, %r14, %r24;
    xor.b32 %r8, %r3, %r24;
    or.b32 %r8, %r7, %r8;
    mul.wide.s32 %rd14, %r8, %r14;
    add.s32 %r24, %r24, %r14;
    max.u32 %r27, %r24, %r14;
    cvt.s32.s64 %r23, %rd14;
    sub.s32 %r25, %r7, %r27;
    mul.wide.u32 %rd8, %r25, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
