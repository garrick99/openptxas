.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    cvt.u64.u32 %rd7, %r3;
    mul.lo.u32 %r23, %r3, %r3;
    add.s64 %rd9, %rd7, %rd7;
    cvt.s32.s64 %r8, %rd7;
    sub.u32 %r10, %r8, 4;
    mad.lo.u32 %r26, %r3, %r10, %r23;
    cvt.u64.u32 %rd15, %r8;
    xor.b32 %r9, %r3, %r26;
    or.b64 %rd11, %rd8, %rd8;
    min.u32 %r20, %r8, 64;
    setp.gt.s32 %p2, %r3, 65535;
    @%p2 xor.b32 %r14, %r3, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
