.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r26, %r3, %r3;
    shl.b32 %r25, %r26, 4;
    max.u32 %r17, %r3, %r26;
    and.b32 %r11, %r25, 65535;
    cvt.u64.u32 %rd15, %r17;
    mad.lo.s32 %r26, %r11, %r3, %r25;
    min.u32 %r20, %r26, 8;
    setp.ls.u32 %p4, %r26, 63;
    mul.wide.s32 %rd13, %r26, %r17;
    setp.ne.s32 %p4, %r3, 5;
    and.b32 %r6, %r26, 1;
    selp.b32 %r6, %r25, %r6, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
