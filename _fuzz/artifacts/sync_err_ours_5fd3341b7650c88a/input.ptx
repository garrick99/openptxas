.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    cvt.s32.s64 %r11, %rd5;
    shl.b64 %rd13, %rd5, 16;
    shl.b64 %rd12, %rd13, 32;
    mul.lo.u32 %r15, %r3, %r11;
    xor.b32 %r14, %r11, 63;
    add.u32 %r23, %r11, %r14;
    max.u32 %r13, %r11, %r3;
    setp.eq.u32 %p2, %r3, %r23;
    @!%p2 shr.s32 %r22, %r23, 31;
    shr.s64 %rd7, %rd12, 33;
    xor.b32 %r10, %r3, %r15;
    setp.ls.u32 %p1, %r3, %r14;
    @%p1 shl.b32 %r26, %r15, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
