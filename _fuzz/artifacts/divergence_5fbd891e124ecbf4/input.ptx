.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd5, %r3, %r3;
    shr.s64 %rd15, %rd5, 31;
    setp.ge.s32 %p2, %r3, 5;
    @%p2 shl.b32 %r11, %r3, 3;
    or.b32 %r24, %r11, %r11;
    sub.s32 %r5, %r24, %r24;
    shr.u32 %r8, %r24, 30;
    cvt.s32.s64 %r26, %rd5;
    mul.wide.u32 %rd7, %r24, %r3;
    mul.wide.u32 %rd10, %r26, %r24;
    setp.gt.s32 %p3, %r24, %r26;
    @%p3 mul.lo.u32 %r26, %r24, %r11;
    max.s32 %r6, %r24, %r8;
    mul.lo.s32 %r19, %r8, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
