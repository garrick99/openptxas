.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    mul.lo.u32 %r9, %r3, 4294967295;
    max.u64 %rd15, %rd9, %rd9;
    sub.u32 %r16, %r3, 2147483648;
    shl.b64 %rd12, %rd9, 4;
    cvt.s64.s32 %rd11, %r16;
    and.b32 %r22, %r9, %r9;
    cvt.s32.s64 %r12, %rd12;
    mul.wide.s32 %rd14, %r3, %r12;
    max.s32 %r6, %r12, 1;
    mul.lo.s32 %r21, %r9, %r9;
    sub.s32 %r17, %r22, %r12;
    mul.lo.s32 %r14, %r6, 65535;
    add.s32 %r24, %r9, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
