.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r7, %r3, 4;
    cvt.s64.s32 %rd8, %r3;
    mul.lo.u32 %r15, %r7, 7;
    cvt.u32.u64 %r21, %rd8;
    max.s32 %r25, %r21, %r21;
    cvt.u64.u32 %rd6, %r21;
    max.s32 %r22, %r25, 31;
    and.b32 %r20, %r21, %r3;
    shr.s64 %rd7, %rd6, 16;
    setp.lt.s32 %p2, %r22, %r22;
    @%p2 or.b32 %r27, %r22, %r15;
    shr.s64 %rd13, %rd7, 32;
    cvt.s64.s32 %rd5, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
