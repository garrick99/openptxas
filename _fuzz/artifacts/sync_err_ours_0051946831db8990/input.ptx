.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd8, %r3, %r3;
    cvt.u64.u32 %rd15, %r3;
    max.s64 %rd6, %rd8, %rd8;
    cvt.u32.u64 %r9, %rd6;
    mul.wide.s32 %rd13, %r3, %r9;
    add.u32 %r21, %r3, %r9;
    cvt.s64.s32 %rd9, %r3;
    cvt.s32.s64 %r11, %rd6;
    max.u32 %r5, %r3, %r11;
    setp.ge.s32 %p4, %r11, %r11;
    @%p4 add.u64 %rd10, %rd13, %rd13;
    sub.u32 %r23, %r21, %r21;
    add.s32 %r20, %r9, 4;
    sub.s32 %r26, %r9, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
