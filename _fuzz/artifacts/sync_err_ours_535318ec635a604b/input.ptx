.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r8, %r3, %r3;
    max.u32 %r16, %r3, %r3;
    shl.b32 %r21, %r8, 4;
    add.u32 %r9, %r8, 8;
    shr.u32 %r6, %r21, 4;
    setp.lt.u32 %p3, %r3, %r8;
    @%p3 shl.b32 %r22, %r6, 7;
    shr.s32 %r19, %r9, 30;
    selp.b32 %r12, %r19, %r6, %p3;
    mul.wide.s32 %rd10, %r12, %r9;
    sub.s32 %r5, %r22, %r12;
    setp.eq.u32 %p4, %r5, 3;
    @!%p4 add.s32 %r23, %r16, 3;
    add.u32 %r10, %r16, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
