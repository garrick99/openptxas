.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r4, %r3, 4;
    cvt.u64.u32 %rd6, %r4;
    mul.wide.s32 %rd8, %r4, %r4;
    cvt.u64.u32 %rd7, %r4;
    xor.b32 %r27, %r4, 65536;
    or.b32 %r4, %r27, %r27;
    shl.b32 %r26, %r27, 31;
    setp.ge.u32 %p1, %r3, 4294967295;
    @!%p1 add.s64 %rd8, %rd7, %rd8;
    sub.s32 %r10, %r26, 31;
    sub.s32 %r20, %r10, 15;
    setp.le.s32 %p2, %r26, 8;
    setp.ge.u32 %p1, %r26, 256;
    @%p1 and.b32 %r14, %r10, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
