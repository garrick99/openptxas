.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p3, %r3, %r3;
    sub.s32 %r17, %r3, 32;
    mul.wide.u32 %rd12, %r3, %r17;
    or.b32 %r24, %r17, %r17;
    selp.b32 %r21, %r3, %r17, %p3;
    sub.s32 %r15, %r3, 256;
    shl.b32 %r17, %r17, 1;
    cvt.u64.u32 %rd5, %r24;
    shr.u64 %rd10, %rd5, 30;
    cvt.u32.u64 %r4, %rd12;
    sub.s64 %rd10, %rd5, %rd5;
    shl.b64 %rd9, %rd12, 48;
    mul.lo.s32 %r22, %r21, 8;
    sub.s32 %r13, %r22, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
