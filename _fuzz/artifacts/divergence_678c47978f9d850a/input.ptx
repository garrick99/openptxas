.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    max.s32 %r4, %r3, 65535;
    mul.lo.s32 %r8, %r4, 2147483647;
    add.u32 %r20, %r4, 4;
    mad.lo.u32 %r18, %r3, %r3, %r3;
    sub.s32 %r27, %r20, 2147483648;
    or.b32 %r16, %r8, 4;
    mul.wide.u32 %rd5, %r3, %r4;
    mul.wide.u32 %rd5, %r3, %r8;
    or.b64 %rd13, %rd8, %rd5;
    mul.wide.s32 %rd12, %r3, %r20;
    sub.s64 %rd5, %rd13, %rd12;
    xor.b32 %r27, %r16, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
