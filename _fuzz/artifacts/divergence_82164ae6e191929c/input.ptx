.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r7, %r3, %r3;
    mul.wide.u32 %rd11, %r3, %r3;
    mul.wide.s32 %rd5, %r3, %r7;
    mul.lo.s64 %rd12, %rd5, %rd5;
    max.s32 %r14, %r7, %r3;
    shr.s64 %rd15, %rd12, 48;
    add.s32 %r4, %r14, 65535;
    min.u64 %rd6, %rd5, %rd5;
    sub.u64 %rd11, %rd12, %rd6;
    sub.u32 %r13, %r7, 1;
    xor.b32 %r15, %r7, 63;
    min.s64 %rd12, %rd6, %rd5;
    min.u32 %r25, %r15, %r7;
    mad.lo.s32 %r14, %r13, %r3, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
