.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    shl.b32 %r23, %r3, 15;
    shr.s32 %r16, %r3, 30;
    sub.s64 %rd8, %rd7, %rd7;
    sub.u64 %rd6, %rd8, %rd8;
    shl.b32 %r21, %r23, 1;
    setp.eq.u32 %p2, %r21, 0;
    @!%p2 shr.u32 %r9, %r21, 16;
    mad.lo.s32 %r6, %r16, %r9, %r9;
    min.s32 %r16, %r16, 15;
    or.b32 %r26, %r9, %r9;
    cvt.u32.u64 %r26, %rd6;
    sub.s32 %r12, %r16, 256;
    max.u32 %r27, %r21, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
