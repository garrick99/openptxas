.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r16, %r3, %r3;
    min.u32 %r17, %r16, 64;
    mul.wide.u32 %rd7, %r17, %r17;
    shr.s64 %rd10, %rd7, 62;
    setp.eq.s32 %p3, %r16, 1;
    setp.le.s32 %p4, %r16, 3;
    @%p4 sub.s64 %rd10, %rd10, %rd7;
    max.u32 %r25, %r16, 1;
    shr.s64 %rd8, %rd7, 62;
    shr.u32 %r16, %r16, 2;
    and.b32 %r16, %r17, %r16;
    xor.b32 %r21, %r16, %r3;
    sub.s32 %r10, %r17, %r17;
    mul.lo.u32 %r24, %r17, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
