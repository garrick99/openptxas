.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hi.u32 %p1, %r3, 63;
    cvt.s64.s32 %rd12, %r3;
    setp.gt.s32 %p4, %r3, %r3;
    max.s32 %r19, %r3, 2;
    cvt.u64.u32 %rd11, %r3;
    selp.b32 %r4, %r3, %r19, %p4;
    or.b32 %r24, %r19, 2;
    and.b32 %r15, %r19, 7;
    mul.lo.u32 %r25, %r4, %r3;
    setp.eq.u32 %p4, %r19, 65536;
    @%p4 cvt.u32.u64 %r17, %rd11;
    setp.ne.u32 %p1, %r15, %r24;
    @%p1 cvt.s32.s64 %r4, %rd12;
    mul.wide.u32 %rd14, %r25, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
