.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r23, %r3, %r3;
    mad.lo.u32 %r19, %r23, %r23, %r23;
    setp.eq.s32 %p3, %r19, 2147483648;
    cvt.u64.u32 %rd10, %r23;
    cvt.s64.s32 %rd6, %r23;
    mul.lo.u32 %r26, %r23, %r3;
    setp.gt.u32 %p1, %r26, 32;
    @%p1 max.s32 %r25, %r19, %r19;
    shr.u64 %rd13, %rd6, 2;
    shr.s64 %rd7, %rd13, 1;
    shr.s32 %r5, %r26, 30;
    max.u32 %r6, %r3, 32;
    setp.eq.s32 %p2, %r3, %r26;
    @!%p2 sub.u32 %r16, %r26, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
