.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r11, %r3, %r3;
    setp.gt.s32 %p2, %r3, %r3;
    @%p2 sub.s32 %r18, %r11, %r11;
    and.b32 %r21, %r3, %r18;
    cvt.s64.s32 %rd14, %r11;
    xor.b32 %r17, %r11, %r3;
    max.s64 %rd7, %rd14, %rd14;
    mad.lo.u32 %r26, %r21, %r3, %r17;
    shr.u32 %r5, %r17, 31;
    mad.lo.s32 %r18, %r21, %r26, %r17;
    selp.b32 %r24, %r26, %r3, %p2;
    xor.b32 %r26, %r3, %r5;
    shr.u64 %rd10, %rd14, 0;
    min.u32 %r20, %r18, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
