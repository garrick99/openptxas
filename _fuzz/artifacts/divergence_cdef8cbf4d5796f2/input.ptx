.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p1, %r3, %r3;
    @%p1 min.s32 %r11, %r3, %r3;
    cvt.u64.u32 %rd11, %r11;
    cvt.u32.u64 %r17, %rd11;
    min.u32 %r15, %r11, 4294967295;
    shr.s64 %rd8, %rd11, 3;
    xor.b32 %r23, %r15, 4294967295;
    shl.b32 %r25, %r11, 15;
    selp.b32 %r10, %r25, %r17, %p1;
    xor.b32 %r19, %r11, %r17;
    min.s32 %r25, %r11, 2147483648;
    mul.wide.u32 %rd11, %r23, %r15;
    shr.u32 %r19, %r23, 3;
    shr.s32 %r26, %r10, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
