.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd14, %r3, %r3;
    max.s32 %r13, %r3, %r3;
    mad.lo.s32 %r6, %r3, %r3, %r3;
    and.b32 %r10, %r13, 64;
    shr.s32 %r15, %r6, 2;
    setp.ge.s32 %p2, %r6, 32;
    @!%p2 mul.lo.u32 %r20, %r6, 4;
    shr.u32 %r24, %r15, 3;
    shl.b32 %r7, %r20, 2;
    mad.lo.s32 %r27, %r15, %r10, %r20;
    shr.s32 %r8, %r6, 0;
    add.s64 %rd8, %rd14, %rd14;
    cvt.s32.s64 %r27, %rd8;
    shl.b32 %r10, %r7, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
