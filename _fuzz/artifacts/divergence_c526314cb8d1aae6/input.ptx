.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r17, %r3, %r3;
    sub.u32 %r4, %r3, %r17;
    add.u32 %r20, %r4, 2;
    cvt.u64.u32 %rd12, %r4;
    setp.gt.u32 %p4, %r17, 5;
    @%p4 min.u32 %r4, %r17, 3;
    setp.ls.u32 %p4, %r20, %r17;
    @!%p4 max.s32 %r23, %r17, 8;
    selp.b32 %r21, %r3, %r20, %p4;
    shr.u32 %r19, %r3, 4;
    cvt.s64.s32 %rd5, %r23;
    cvt.u32.u64 %r10, %rd5;
    min.s32 %r6, %r19, %r4;
    selp.b32 %r27, %r3, %r10, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
