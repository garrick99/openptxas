.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r4, %r3, 7;
    shr.u32 %r9, %r3, 16;
    cvt.s64.s32 %rd5, %r4;
    mul.wide.u32 %rd10, %r9, %r9;
    and.b32 %r15, %r3, %r4;
    sub.u32 %r4, %r9, 64;
    shr.s32 %r22, %r9, 15;
    setp.lo.u32 %p1, %r3, %r3;
    @!%p1 shr.u32 %r8, %r4, 16;
    mul.wide.s32 %rd10, %r15, %r22;
    selp.b32 %r9, %r4, %r22, %p1;
    sub.s64 %rd6, %rd5, %rd5;
    add.u32 %r17, %r4, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
