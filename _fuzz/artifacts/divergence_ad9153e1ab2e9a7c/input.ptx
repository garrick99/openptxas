.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hi.u32 %p2, %r3, %r3;
    @%p2 cvt.u64.u32 %rd11, %r3;
    mul.lo.u32 %r12, %r3, 63;
    mad.lo.u32 %r21, %r3, %r12, %r3;
    cvt.s64.s32 %rd15, %r21;
    mul.wide.s32 %rd15, %r21, %r21;
    min.s64 %rd7, %rd11, %rd11;
    mad.lo.s32 %r4, %r12, %r21, %r21;
    or.b32 %r19, %r12, %r3;
    shr.u32 %r4, %r3, 7;
    setp.ge.s32 %p4, %r19, %r21;
    @!%p4 mul.lo.s32 %r7, %r21, %r4;
    max.s32 %r16, %r7, %r3;
    shr.u64 %rd11, %rd11, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
