.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd10, %r3, %r3;
    shr.s64 %rd13, %rd10, 7;
    min.s32 %r18, %r3, %r3;
    shr.s32 %r6, %r3, 1;
    min.u32 %r21, %r3, 1;
    setp.hs.u32 %p2, %r21, %r6;
    @%p2 mul.wide.s32 %rd11, %r21, %r21;
    setp.lo.u32 %p3, %r21, 32;
    @%p3 and.b32 %r15, %r3, 255;
    add.u32 %r13, %r15, 2147483647;
    min.s64 %rd14, %rd13, %rd13;
    add.s32 %r26, %r15, %r3;
    mul.lo.s32 %r9, %r26, 31;
    and.b32 %r10, %r3, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
