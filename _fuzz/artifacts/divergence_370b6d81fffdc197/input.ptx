.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r5, %r3, %r3;
    setp.eq.u32 %p1, %r3, 0;
    @%p1 add.s32 %r26, %r3, 31;
    selp.b32 %r20, %r3, %r26, %p1;
    cvt.u64.u32 %rd13, %r5;
    cvt.u32.u64 %r24, %rd13;
    sub.s32 %r16, %r26, 3;
    min.u32 %r20, %r16, 8;
    min.s32 %r9, %r26, 7;
    setp.le.u32 %p3, %r24, 7;
    @%p3 and.b32 %r6, %r16, %r16;
    sub.s32 %r23, %r3, 0;
    setp.gt.s32 %p1, %r24, 256;
    @%p1 add.u32 %r25, %r26, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
