.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.idx.b32 %r10, %r0, 7, 0x1f, -1;
    shfl.sync.up.b32 %r15, %r0, 4, 0x1f, -1;
    max.u32 %r12, %r0, %r10;
    and.b32 %r4, %r12, %r0;
    shfl.sync.down.b32 %r7, %r3, 8, 0x1f, -1;
    sub.u32 %r16, %r7, %r3;
    and.b32 %r9, %r3, %r7;
    setp.ge.u32 %p3, %r15, %r7;
    vote.sync.ballot.b32 %r7, %p3, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
