.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    setp.gt.s32 %p4, %r3, 1;
    mul.lo.u32 %r15, %r3, %r3;
    shl.b64 %rd5, %rd6, 2;
    cvt.s32.s64 %r10, %rd5;
    shl.b32 %r11, %r10, 16;
    mul.wide.u32 %rd8, %r3, %r3;
    cvt.s64.s32 %rd7, %r3;
    sub.s32 %r24, %r15, %r11;
    mad.lo.s32 %r22, %r24, %r15, %r11;
    shr.s64 %rd7, %rd5, 62;
    mul.wide.s32 %rd8, %r15, %r15;
    add.u32 %r21, %r22, %r24;
    min.s32 %r26, %r3, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
