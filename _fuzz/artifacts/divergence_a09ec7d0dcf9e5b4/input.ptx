.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r15, %r3, %r3;
    shr.u32 %r23, %r3, 16;
    setp.lo.u32 %p4, %r23, %r3;
    @%p4 add.s32 %r27, %r23, 63;
    and.b32 %r16, %r27, 1;
    setp.lt.u32 %p2, %r16, %r15;
    @%p2 shl.b32 %r9, %r16, 2;
    cvt.u64.u32 %rd15, %r16;
    max.u32 %r7, %r16, %r23;
    cvt.u64.u32 %rd11, %r15;
    max.u32 %r13, %r16, 255;
    mul.lo.s32 %r13, %r9, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
