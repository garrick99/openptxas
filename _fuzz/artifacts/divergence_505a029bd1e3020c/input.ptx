.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r8, %r3, %r3;
    mul.lo.u32 %r5, %r8, 256;
    add.u32 %r27, %r3, 65536;
    mad.lo.u32 %r9, %r8, %r3, %r5;
    shl.b32 %r23, %r5, 31;
    cvt.s64.s32 %rd8, %r3;
    add.s32 %r26, %r27, 8;
    mad.lo.s32 %r26, %r8, %r5, %r9;
    add.s32 %r18, %r3, 2147483648;
    sub.s32 %r26, %r27, 63;
    max.s32 %r12, %r23, 4294967295;
    min.u32 %r4, %r9, %r8;
    mad.lo.u32 %r17, %r23, %r18, %r12;
    mul.wide.u32 %rd15, %r26, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
