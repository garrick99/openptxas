.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    mul.lo.s32 %r24, %r3, 4294967295;
    add.s32 %r9, %r3, %r24;
    cvt.s64.s32 %rd9, %r3;
    min.u32 %r13, %r9, %r3;
    max.u32 %r27, %r13, %r3;
    mul.lo.s32 %r26, %r3, %r13;
    cvt.s32.s64 %r24, %rd9;
    shr.s64 %rd8, %rd11, 48;
    min.s32 %r4, %r3, 64;
    mad.lo.u32 %r26, %r27, %r27, %r3;
    mad.lo.u32 %r10, %r4, %r24, %r9;
    shr.s32 %r16, %r27, 7;
    shl.b32 %r10, %r27, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
