.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    add.u32 %r20, %r3, 255;
    mul.wide.s32 %rd6, %r20, %r3;
    mul.lo.s32 %r26, %r3, 5;
    add.u32 %r7, %r3, %r3;
    shr.s32 %r24, %r26, 30;
    shr.s32 %r18, %r3, 15;
    sub.u32 %r26, %r18, %r3;
    add.s32 %r5, %r3, %r3;
    mul.lo.s32 %r19, %r3, %r20;
    cvt.s32.s64 %r22, %rd9;
    mad.lo.u32 %r20, %r24, %r26, %r5;
    shr.u32 %r24, %r18, 30;
    max.u32 %r6, %r7, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
