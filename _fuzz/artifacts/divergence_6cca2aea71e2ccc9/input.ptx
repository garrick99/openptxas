.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p3, %r3, %r3;
    shr.u32 %r16, %r3, 30;
    add.s32 %r18, %r16, %r16;
    mul.lo.s32 %r23, %r3, %r18;
    shr.s32 %r13, %r16, 31;
    min.u32 %r19, %r18, %r16;
    cvt.u64.u32 %rd11, %r18;
    selp.b32 %r14, %r16, %r3, %p3;
    shr.s32 %r17, %r13, 0;
    selp.b32 %r26, %r3, %r19, %p3;
    mul.lo.s32 %r25, %r14, %r26;
    mad.lo.u32 %r9, %r25, %r18, %r25;
    setp.eq.u32 %p2, %r14, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
