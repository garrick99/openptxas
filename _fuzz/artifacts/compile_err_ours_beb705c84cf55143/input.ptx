.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.down.b32 %r6, %r3, 4, 0x1f, -1;
    setp.gt.u32 %p3, %r6, 1;
    vote.sync.ballot.b32 %r6, %p3, -1;
    vote.sync.all.pred %p2, %p3, -1;
    add.u32 %r8, %r6, %r3;
    add.u32 %r4, %r8, %r3;
    setp.ne.u32 %p2, %r8, %r8;
    vote.sync.ballot.b32 %r8, %p2, -1;
    vote.sync.any.pred %p1, %p3, -1;
    sub.u32 %r15, %r4, %r8;
    shfl.sync.idx.b32 %r17, %r4, 15, 0x1f, -1;
    setp.eq.u32 %p2, %r3, 3;
    vote.sync.ballot.b32 %r12, %p2, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
