.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r24, %r3, 65535;
    setp.gt.s32 %p1, %r3, %r3;
    @%p1 selp.b32 %r11, %r24, %r3, %p1;
    or.b32 %r24, %r24, 5;
    sub.u32 %r20, %r3, 255;
    or.b32 %r13, %r11, %r3;
    cvt.s64.s32 %rd9, %r3;
    min.s32 %r21, %r11, %r24;
    xor.b32 %r21, %r11, 15;
    setp.eq.s32 %p2, %r20, 4294967295;
    mad.lo.s32 %r8, %r13, %r11, %r13;
    cvt.s64.s32 %rd8, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
