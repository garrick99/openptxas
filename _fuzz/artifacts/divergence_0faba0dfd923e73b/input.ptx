.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r16, %r3, %r3;
    and.b32 %r12, %r3, 8;
    add.s32 %r8, %r3, %r3;
    shr.u32 %r20, %r12, 1;
    min.u32 %r13, %r16, %r16;
    mul.wide.u32 %rd9, %r16, %r12;
    or.b32 %r18, %r3, %r16;
    cvt.u64.u32 %rd15, %r8;
    min.s64 %rd11, %rd15, %rd9;
    mad.lo.s32 %r23, %r8, %r20, %r12;
    shr.u64 %rd6, %rd9, 62;
    max.s32 %r10, %r18, 65535;
    setp.gt.u32 %p1, %r8, %r13;
    @!%p1 max.s32 %r11, %r10, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
