    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r8, %r3, %r3;
    sub.u32 %r13, %r8, 4294967295;
    mul.wide.u32 %rd7, %r3, %r3;
