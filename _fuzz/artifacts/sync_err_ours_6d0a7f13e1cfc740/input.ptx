.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r13, %r3, %r3;
    mul.lo.u32 %r13, %r3, 15;
    mul.wide.s32 %rd7, %r13, %r13;
    mul.lo.u32 %r9, %r13, 8;
    mul.lo.u32 %r16, %r3, 256;
    cvt.s32.s64 %r22, %rd7;
    shr.u64 %rd11, %rd7, 0;
    or.b32 %r5, %r16, 4294967295;
    mul.wide.s32 %rd11, %r13, %r13;
    mul.lo.u32 %r7, %r13, %r9;
    setp.le.s32 %p2, %r16, %r9;
    @!%p2 min.u32 %r27, %r16, 31;
    add.u32 %r23, %r3, %r13;
    mul.wide.s32 %rd5, %r13, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
