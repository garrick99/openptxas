.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p3, %r3, 63;
    @!%p3 shr.s32 %r13, %r3, 31;
    cvt.u64.u32 %rd8, %r13;
    and.b32 %r10, %r3, 0;
    cvt.u32.u64 %r11, %rd8;
    setp.le.u32 %p4, %r10, %r3;
    @%p4 and.b32 %r19, %r3, %r13;
    sub.u32 %r15, %r3, 255;
    shr.s64 %rd13, %rd8, 33;
    shl.b64 %rd10, %rd8, 15;
    max.s64 %rd10, %rd8, %rd13;
    cvt.s32.s64 %r13, %rd10;
    or.b32 %r15, %r19, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
