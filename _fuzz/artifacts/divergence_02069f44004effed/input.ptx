.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r6, %r3, 4;
    setp.lt.s32 %p3, %r6, %r3;
    @%p3 sub.s32 %r19, %r3, %r6;
    and.b32 %r11, %r3, 256;
    add.u32 %r27, %r19, %r11;
    shr.u32 %r13, %r27, 3;
    mad.lo.u32 %r9, %r3, %r6, %r13;
    and.b32 %r25, %r11, %r13;
    mul.lo.u32 %r22, %r6, %r13;
    mad.lo.u32 %r17, %r9, %r22, %r25;
    cvt.u64.u32 %rd15, %r9;
    cvt.s64.s32 %rd12, %r11;
    or.b32 %r20, %r13, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
