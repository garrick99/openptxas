.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    add.u32 %r6, %r3, %r3;
    add.s32 %r18, %r3, 15;
    mad.lo.s32 %r8, %r3, %r18, %r3;
    mul.wide.s32 %rd5, %r6, %r3;
    setp.eq.u32 %p1, %r3, %r6;
    @%p1 mul.lo.s32 %r18, %r6, 2147483647;
    xor.b32 %r6, %r18, %r6;
    shr.s64 %rd5, %rd5, 30;
    selp.b32 %r21, %r18, %r8, %p1;
    cvt.u64.u32 %rd14, %r3;
    mul.lo.u32 %r23, %r18, 15;
    shl.b32 %r5, %r18, 3;
    mad.lo.s32 %r23, %r23, %r18, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
