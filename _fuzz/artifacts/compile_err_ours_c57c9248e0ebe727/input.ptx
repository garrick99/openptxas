.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r13, %r0, %r3;
    and.b32 %r13, %r3, %r13;
    and.b32 %r16, %r0, %r0;
    shfl.sync.down.b32 %r6, %r3, 16, 0x1f, -1;
    setp.ge.u32 %p2, %r13, %r16;
    vote.sync.ballot.b32 %r9, %p2, -1;
    vote.sync.any.pred %p2, %p2, -1;
    or.b32 %r14, %r13, %r13;
    max.u32 %r6, %r6, %r14;
    setp.ge.u32 %p3, %r13, 2;
    vote.sync.ballot.b32 %r5, %p3, -1;
    vote.sync.any.pred %p1, %p3, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
