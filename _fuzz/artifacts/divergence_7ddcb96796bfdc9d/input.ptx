.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    cvt.u32.u64 %r17, %rd10;
    shr.s32 %r13, %r17, 3;
    sub.s32 %r18, %r13, %r13;
    sub.u32 %r7, %r13, 64;
    setp.hi.u32 %p3, %r18, 7;
    @%p3 mul.lo.s32 %r19, %r13, %r7;
    shl.b32 %r20, %r3, 2;
    mad.lo.s32 %r12, %r18, %r3, %r13;
    cvt.s64.s32 %rd6, %r18;
    shr.s32 %r21, %r19, 30;
    mad.lo.s32 %r12, %r17, %r20, %r19;
    mul.wide.u32 %rd8, %r21, %r13;
    cvt.u64.u32 %rd5, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
