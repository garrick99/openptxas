.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r7, %r3, 4294967295;
    setp.ne.s32 %p2, %r7, %r3;
    @%p2 or.b32 %r19, %r3, 64;
    cvt.s64.s32 %rd6, %r3;
    xor.b32 %r8, %r19, %r3;
    shl.b32 %r19, %r7, 0;
    setp.gt.u32 %p4, %r7, %r8;
    @%p4 or.b64 %rd12, %rd6, %rd6;
    selp.b32 %r25, %r19, %r8, %p2;
    selp.b32 %r21, %r8, %r7, %p2;
    mul.wide.u32 %rd5, %r3, %r21;
    mad.lo.u32 %r9, %r8, %r21, %r21;
    mul.lo.s32 %r7, %r8, %r21;
    shl.b32 %r27, %r25, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
