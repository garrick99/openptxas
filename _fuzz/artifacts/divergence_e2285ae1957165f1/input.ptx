.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    setp.le.s32 %p2, %r3, 64;
    shr.u64 %rd6, %rd12, 3;
    sub.s64 %rd15, %rd6, %rd12;
    setp.le.s32 %p3, %r3, 31;
    @!%p3 add.u32 %r23, %r3, 4;
    sub.u32 %r8, %r23, 0;
    cvt.s32.s64 %r5, %rd6;
    mul.wide.u32 %rd11, %r5, %r8;
    mul.wide.s32 %rd14, %r23, %r23;
    and.b32 %r15, %r23, %r23;
    max.s32 %r15, %r15, %r5;
    setp.eq.s32 %p1, %r8, 32;
    @%p1 shr.s64 %rd14, %rd15, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
