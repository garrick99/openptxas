.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    setp.lt.s32 %p4, %r3, 256;
    @%p4 max.s32 %r24, %r3, %r3;
    cvt.s32.s64 %r17, %rd11;
    shl.b32 %r26, %r24, 1;
    mul.wide.s32 %rd10, %r24, %r26;
    selp.b32 %r21, %r24, %r3, %p4;
    cvt.u32.u64 %r7, %rd11;
    cvt.s64.s32 %rd9, %r17;
    setp.lt.s32 %p4, %r7, %r26;
    @%p4 sub.s32 %r13, %r17, %r17;
    min.s64 %rd11, %rd10, %rd9;
    shr.s64 %rd11, %rd11, 3;
    shr.s64 %rd5, %rd9, 33;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
