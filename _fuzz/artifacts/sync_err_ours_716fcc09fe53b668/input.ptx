.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    mul.lo.s32 %r13, %r3, 4;
    cvt.u32.u64 %r25, %rd10;
    sub.u32 %r21, %r3, %r13;
    mad.lo.s32 %r19, %r25, %r25, %r13;
    shr.u32 %r20, %r21, 4;
    add.u32 %r21, %r25, %r19;
    and.b32 %r15, %r3, 255;
    shr.s64 %rd6, %rd10, 15;
    or.b64 %rd6, %rd10, %rd10;
    shl.b64 %rd6, %rd10, 7;
    shr.s64 %rd11, %rd10, 16;
    add.s32 %r14, %r13, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
