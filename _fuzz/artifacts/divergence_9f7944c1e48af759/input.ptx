.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd13, %r3, %r3;
    setp.gt.u32 %p3, %r3, %r3;
    @%p3 shr.u64 %rd11, %rd13, 2;
    mad.lo.u32 %r5, %r3, %r3, %r3;
    mad.lo.u32 %r15, %r3, %r5, %r5;
    cvt.u64.u32 %rd8, %r5;
    mul.wide.s32 %rd10, %r5, %r3;
    cvt.u32.u64 %r7, %rd11;
    mul.wide.s32 %rd10, %r15, %r5;
    max.u32 %r5, %r5, 256;
    min.u32 %r27, %r15, %r7;
    xor.b32 %r14, %r3, %r7;
    mul.lo.s32 %r21, %r5, %r3;
    setp.ne.s32 %p1, %r27, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
