.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    or.b32 %r9, %r3, 15;
    mul.wide.u32 %rd7, %r3, %r9;
    setp.hi.u32 %p4, %r3, %r3;
    @!%p4 mul.lo.s64 %rd12, %rd5, %rd7;
    min.u32 %r8, %r9, %r9;
    shr.u32 %r19, %r3, 7;
    cvt.s64.s32 %rd10, %r9;
    setp.gt.s32 %p4, %r3, 64;
    @%p4 max.s32 %r10, %r8, 256;
    max.s32 %r26, %r10, 1;
    and.b32 %r20, %r9, %r10;
    and.b32 %r21, %r26, 63;
    sub.u32 %r11, %r10, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
