.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r19, %r3, 4294967295;
    cvt.u64.u32 %rd6, %r19;
    min.u64 %rd11, %rd6, %rd6;
    setp.lt.s32 %p3, %r3, %r3;
    @%p3 mul.wide.s32 %rd6, %r19, %r3;
    shr.u32 %r11, %r3, 2;
    max.s32 %r21, %r3, %r3;
    selp.b32 %r27, %r3, %r11, %p3;
    shr.u64 %rd14, %rd6, 63;
    sub.s32 %r23, %r19, %r21;
    selp.b32 %r4, %r19, %r3, %p3;
    setp.lt.s32 %p3, %r27, %r23;
    min.u64 %rd11, %rd6, %rd6;
    sub.s32 %r15, %r3, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
