.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r24, %r3, %r3;
    shl.b32 %r25, %r24, 2;
    mul.wide.s32 %rd9, %r25, %r25;
    max.u32 %r8, %r24, 1;
    setp.le.s32 %p4, %r25, 7;
    and.b32 %r9, %r24, %r25;
    min.s64 %rd5, %rd9, %rd9;
    shr.s32 %r9, %r8, 30;
    mul.lo.u32 %r11, %r24, 65536;
    setp.eq.u32 %p4, %r3, %r25;
    cvt.s32.s64 %r26, %rd5;
    mul.lo.u32 %r6, %r11, 8;
    setp.gt.u32 %p3, %r3, 4;
    @%p3 mul.lo.s32 %r18, %r11, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
