.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r15, %r3, 31;
    sub.u32 %r9, %r3, %r3;
    setp.ls.u32 %p3, %r15, 32;
    setp.le.s32 %p2, %r3, %r15;
    @!%p2 max.s32 %r21, %r3, 31;
    shl.b32 %r17, %r9, 7;
    mad.lo.s32 %r18, %r17, %r9, %r9;
    selp.b32 %r22, %r15, %r3, %p2;
    selp.b32 %r26, %r9, %r3, %p3;
    or.b32 %r20, %r17, %r26;
    cvt.u64.u32 %rd12, %r21;
    xor.b32 %r20, %r20, %r18;
    cvt.u32.u64 %r19, %rd12;
    setp.hs.u32 %p1, %r3, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
