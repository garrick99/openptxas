.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r20, %r3, %r3, %r3;
    max.u32 %r16, %r20, 255;
    setp.lt.s32 %p2, %r20, 64;
    @!%p2 cvt.u64.u32 %rd8, %r3;
    mul.lo.s32 %r13, %r3, %r20;
    setp.lt.u32 %p3, %r13, %r20;
    @%p3 and.b32 %r14, %r13, %r16;
    add.u32 %r23, %r14, %r14;
    cvt.s32.s64 %r25, %rd8;
    sub.s64 %rd9, %rd8, %rd8;
    mul.lo.u32 %r13, %r13, 2;
    xor.b32 %r8, %r14, %r13;
    add.u32 %r21, %r8, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
