.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r18, %r3, 16;
    mul.wide.s32 %rd11, %r18, %r18;
    add.u64 %rd8, %rd11, %rd11;
    shl.b64 %rd9, %rd11, 0;
    mul.lo.u64 %rd11, %rd11, %rd9;
    shr.u64 %rd9, %rd11, 48;
    shr.s32 %r11, %r18, 3;
    max.s32 %r6, %r18, %r11;
    sub.s32 %r15, %r18, 255;
    mul.lo.u32 %r14, %r18, 8;
    add.s32 %r20, %r11, %r15;
    or.b32 %r7, %r11, %r11;
    max.u64 %rd9, %rd11, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
