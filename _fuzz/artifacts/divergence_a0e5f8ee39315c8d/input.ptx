.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    mul.wide.u32 %rd8, %r3, %r3;
    add.u32 %r6, %r3, %r3;
    add.s64 %rd9, %rd8, %rd5;
    xor.b32 %r6, %r3, %r6;
    or.b64 %rd5, %rd5, %rd5;
    add.s32 %r18, %r3, %r3;
    or.b32 %r21, %r18, 16;
    and.b32 %r16, %r18, 65535;
    cvt.u32.u64 %r20, %rd5;
    setp.le.s32 %p3, %r18, %r16;
    @%p3 mul.lo.u32 %r19, %r6, %r18;
    setp.le.u32 %p2, %r21, 7;
    max.s64 %rd7, %rd9, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
