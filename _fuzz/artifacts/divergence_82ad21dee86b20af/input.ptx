.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r16, %r3, 2147483648;
    mul.wide.u32 %rd5, %r16, %r3;
    max.u32 %r18, %r3, %r3;
    mul.wide.u32 %rd8, %r3, %r16;
    xor.b32 %r12, %r16, 0;
    setp.ls.u32 %p4, %r18, %r16;
    @!%p4 mad.lo.u32 %r6, %r12, %r16, %r3;
    mul.wide.u32 %rd13, %r18, %r16;
    sub.s32 %r24, %r18, 1;
    shr.u64 %rd14, %rd13, 48;
    mad.lo.u32 %r9, %r12, %r3, %r3;
    cvt.s32.s64 %r19, %rd13;
    setp.le.u32 %p1, %r12, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
