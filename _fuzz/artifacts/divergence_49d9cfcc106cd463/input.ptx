.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r25, %r3, %r3;
    cvt.u64.u32 %rd13, %r3;
    mul.wide.s32 %rd14, %r25, %r3;
    mul.lo.s32 %r15, %r3, %r25;
    setp.ls.u32 %p4, %r25, %r15;
    @%p4 mul.wide.s32 %rd14, %r3, %r25;
    and.b32 %r6, %r25, 63;
    shr.u32 %r6, %r6, 1;
    shl.b32 %r19, %r6, 7;
    mul.lo.s32 %r24, %r25, %r25;
    setp.eq.s32 %p3, %r6, %r19;
    @!%p3 shr.u32 %r4, %r19, 0;
    cvt.s64.s32 %rd13, %r24;
    max.u32 %r10, %r24, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
