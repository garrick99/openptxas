.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    setp.gt.s32 %p2, %r3, 16;
    @%p2 mul.wide.s32 %rd13, %r3, %r3;
    cvt.u32.u64 %r18, %rd13;
    selp.b32 %r11, %r18, %r3, %p2;
    add.s32 %r25, %r3, 256;
    shr.u64 %rd12, %rd5, 30;
    and.b32 %r4, %r25, 5;
    mul.lo.s32 %r11, %r25, %r25;
    mul.wide.s32 %rd6, %r11, %r18;
    selp.b32 %r14, %r18, %r18, %p2;
    shr.s64 %rd15, %rd13, 2;
    mad.lo.u32 %r8, %r4, %r4, %r14;
    shr.s32 %r21, %r8, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
