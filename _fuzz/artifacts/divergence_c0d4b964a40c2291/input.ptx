.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r7, %r3, 7;
    cvt.u64.u32 %rd10, %r7;
    shr.u64 %rd8, %rd10, 4;
    max.u32 %r23, %r3, %r7;
    cvt.s32.s64 %r20, %rd8;
    sub.u64 %rd5, %rd10, %rd10;
    shr.u32 %r22, %r20, 7;
    mul.wide.s32 %rd11, %r3, %r22;
    min.s32 %r8, %r22, 255;
    setp.eq.u32 %p2, %r7, 65535;
    @%p2 max.u32 %r17, %r20, 63;
    min.u32 %r16, %r17, %r8;
    setp.ls.u32 %p2, %r22, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
