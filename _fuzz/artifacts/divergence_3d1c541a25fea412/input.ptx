.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd14, %r3, %r3;
    sub.s32 %r23, %r3, %r3;
    mul.wide.u32 %rd6, %r3, %r23;
    add.s32 %r21, %r23, %r3;
    add.s64 %rd9, %rd14, %rd14;
    min.u32 %r9, %r21, %r23;
    setp.le.s32 %p2, %r9, 1;
    @%p2 shr.s64 %rd14, %rd14, 0;
    mul.lo.u32 %r6, %r9, 64;
    add.s32 %r11, %r3, 2;
    setp.hs.u32 %p1, %r11, %r3;
    @!%p1 mul.wide.u32 %rd11, %r23, %r11;
    add.u32 %r11, %r23, 65535;
    mul.wide.u32 %rd10, %r11, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
