.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd5, %r3, %r3;
    shr.s64 %rd14, %rd5, 32;
    mul.wide.s32 %rd6, %r3, %r3;
    shl.b32 %r8, %r3, 4;
    add.s32 %r25, %r8, 1;
    shl.b32 %r25, %r8, 3;
    sub.s32 %r19, %r3, %r3;
    and.b32 %r11, %r3, %r19;
    shl.b64 %rd10, %rd5, 62;
    shr.u32 %r8, %r11, 2;
    sub.u32 %r5, %r19, 2;
    add.s32 %r5, %r3, %r11;
    setp.lt.s32 %p3, %r5, 4;
    cvt.s64.s32 %rd6, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
