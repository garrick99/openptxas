    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r27, %r3, 15;
    cvt.u64.u32 %rd8, %r27;
    cvt.u32.u64 %r13, %rd8;
    and.b32 %r8, %r27, %r27;
