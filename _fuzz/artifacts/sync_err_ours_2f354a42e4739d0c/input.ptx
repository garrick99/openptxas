.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r27, %r3, %r3;
    cvt.u64.u32 %rd11, %r3;
    or.b32 %r17, %r3, %r3;
    max.u32 %r10, %r17, 8;
    mul.wide.s32 %rd15, %r27, %r3;
    add.s32 %r9, %r27, %r3;
    xor.b32 %r22, %r17, %r17;
    mul.lo.u32 %r15, %r3, %r9;
    shr.s32 %r18, %r27, 1;
    shr.s32 %r4, %r9, 15;
    cvt.s64.s32 %rd9, %r15;
    setp.ge.u32 %p3, %r27, %r4;
    shr.u32 %r8, %r27, 1;
    setp.eq.s32 %p3, %r9, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
