.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    mul.lo.s32 %r6, %r3, %r3;
    min.u32 %r27, %r3, 1;
    mul.lo.s32 %r22, %r3, 63;
    min.s32 %r8, %r6, %r6;
    cvt.s32.s64 %r20, %rd14;
    sub.s32 %r26, %r22, 15;
    shl.b32 %r6, %r8, 4;
    shr.s64 %rd10, %rd14, 4;
    mad.lo.s32 %r17, %r22, %r8, %r26;
    or.b32 %r25, %r27, 31;
    or.b32 %r13, %r26, 7;
    mul.wide.s32 %rd8, %r6, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
