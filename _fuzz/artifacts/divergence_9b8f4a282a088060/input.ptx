.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r24, %r3, %r3;
    cvt.u64.u32 %rd13, %r3;
    cvt.u64.u32 %rd6, %r3;
    min.u32 %r14, %r24, %r24;
    sub.s64 %rd6, %rd6, %rd6;
    setp.eq.s32 %p1, %r3, %r24;
    @%p1 add.u32 %r24, %r3, %r14;
    mul.lo.u32 %r23, %r14, 32;
    max.s32 %r8, %r23, 2;
    and.b32 %r16, %r8, %r3;
    min.u32 %r9, %r3, 256;
    selp.b32 %r27, %r24, %r16, %p1;
    mul.lo.s32 %r20, %r14, 8;
    add.u32 %r4, %r16, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
