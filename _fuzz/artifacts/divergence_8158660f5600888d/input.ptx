.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd14, %r3, %r3;
    or.b32 %r19, %r3, %r3;
    min.s32 %r6, %r19, 15;
    mul.lo.s32 %r27, %r6, %r19;
    mul.wide.u32 %rd11, %r19, %r6;
    setp.lo.u32 %p4, %r27, 65536;
    @!%p4 shr.s32 %r8, %r27, 30;
    setp.ne.u32 %p2, %r3, %r27;
    add.u32 %r24, %r19, %r8;
    mul.wide.s32 %rd5, %r3, %r24;
    shr.s64 %rd10, %rd14, 0;
    sub.s32 %r16, %r3, %r24;
    selp.b32 %r11, %r3, %r3, %p4;
    mul.lo.s32 %r23, %r6, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
