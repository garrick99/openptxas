.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd6, %r3, %r3;
    mad.lo.s32 %r4, %r3, %r3, %r3;
    min.u32 %r6, %r3, %r3;
    setp.ge.s32 %p4, %r3, %r4;
    @!%p4 shr.s64 %rd15, %rd6, 0;
    mul.lo.s32 %r22, %r6, 256;
    mul.wide.u32 %rd8, %r4, %r3;
    shl.b32 %r20, %r3, 30;
    sub.s64 %rd15, %rd15, %rd8;
    min.u32 %r18, %r6, 63;
    mad.lo.s32 %r9, %r18, %r6, %r18;
    cvt.s32.s64 %r17, %rd8;
    setp.ne.u32 %p3, %r9, %r6;
    @!%p3 selp.b32 %r26, %r3, %r22, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
