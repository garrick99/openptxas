.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r5, %r3, %r3;
    shfl.sync.up.b32 %r6, %r3, 2, 0x1f, -1;
    setp.eq.u32 %p3, %r6, %r0;
    vote.sync.ballot.b32 %r18, %p3, -1;
    setp.gt.u32 %p1, %r0, 3;
    vote.sync.ballot.b32 %r12, %p1, -1;
    min.u32 %r8, %r5, %r3;
    setp.ne.u32 %p1, %r12, 16;
    vote.sync.ballot.b32 %r14, %p1, -1;
    shfl.sync.bfly.b32 %r6, %r8, 4, 0x1f, -1;
    shfl.sync.up.b32 %r4, %r0, 1, 0x1f, -1;
    vote.sync.all.pred %p1, %p1, -1;
    setp.eq.u32 %p1, %r8, %r5;
    vote.sync.ballot.b32 %r16, %p1, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
