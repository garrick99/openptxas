.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    shr.s64 %rd13, %rd15, 2;
    cvt.s32.s64 %r11, %rd15;
    setp.eq.s32 %p3, %r11, 15;
    @%p3 sub.u32 %r9, %r3, 4294967295;
    sub.s32 %r20, %r3, %r9;
    mad.lo.s32 %r11, %r11, %r3, %r3;
    mul.lo.u32 %r12, %r20, %r11;
    add.u32 %r22, %r20, %r11;
    mad.lo.s32 %r15, %r11, %r9, %r9;
    shr.s32 %r25, %r12, 15;
    mul.wide.s32 %rd5, %r9, %r22;
    shl.b32 %r11, %r12, 4;
    mad.lo.u32 %r17, %r9, %r3, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
