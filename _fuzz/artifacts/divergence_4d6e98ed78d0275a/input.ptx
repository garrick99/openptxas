.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p2, %r3, %r3;
    @!%p2 xor.b32 %r11, %r3, %r3;
    selp.b32 %r5, %r11, %r3, %p2;
    min.s32 %r8, %r3, %r3;
    shl.b32 %r25, %r5, 2;
    selp.b32 %r20, %r11, %r5, %p2;
    max.u32 %r23, %r20, 31;
    setp.eq.u32 %p2, %r11, %r20;
    mul.wide.u32 %rd9, %r23, %r11;
    add.u32 %r12, %r25, %r5;
    mul.wide.u32 %rd5, %r8, %r3;
    setp.lt.s32 %p1, %r8, %r23;
    cvt.u64.u32 %rd9, %r25;
    add.s32 %r4, %r5, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
