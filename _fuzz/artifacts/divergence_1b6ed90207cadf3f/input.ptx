.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r23, %r3, 16;
    mul.wide.s32 %rd6, %r23, %r3;
    setp.le.s32 %p1, %r23, %r3;
    @%p1 mul.wide.u32 %rd9, %r3, %r23;
    shr.u64 %rd13, %rd9, 1;
    shl.b64 %rd10, %rd6, 4;
    max.s32 %r10, %r3, 8;
    xor.b32 %r9, %r23, 31;
    cvt.s64.s32 %rd6, %r3;
    add.u64 %rd13, %rd9, %rd10;
    max.s32 %r7, %r3, 2147483648;
    shr.s64 %rd6, %rd10, 48;
    xor.b32 %r24, %r9, 2147483648;
    cvt.s64.s32 %rd7, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
