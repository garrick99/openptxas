.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r18, %r3, 15;
    and.b32 %r20, %r18, %r3;
    cvt.s64.s32 %rd5, %r3;
    shr.u64 %rd9, %rd5, 0;
    max.s32 %r10, %r3, 63;
    mul.lo.s32 %r13, %r20, 63;
    sub.u32 %r6, %r18, 1;
    setp.eq.s32 %p1, %r6, 4;
    @%p1 add.u32 %r22, %r10, 255;
    sub.u32 %r24, %r6, 16;
    mad.lo.s32 %r18, %r20, %r10, %r24;
    max.u32 %r23, %r3, 16;
    xor.b32 %r24, %r22, %r13;
    mul.wide.s32 %rd7, %r3, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
