.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r11, %r3, 15;
    and.b32 %r26, %r11, %r11;
    sub.s32 %r27, %r26, 256;
    mul.lo.s32 %r11, %r3, 256;
    and.b32 %r24, %r3, %r3;
    shr.s32 %r13, %r27, 4;
    sub.u32 %r15, %r24, 256;
    cvt.u64.u32 %rd14, %r24;
    cvt.u32.u64 %r23, %rd14;
    setp.ls.u32 %p2, %r26, 63;
    @!%p2 min.u32 %r21, %r23, %r27;
    cvt.s32.s64 %r8, %rd14;
    cvt.s64.s32 %rd6, %r23;
    and.b32 %r21, %r21, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
