.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r4, %r3, %r3, %r3;
    sub.u32 %r15, %r3, %r4;
    mad.lo.s32 %r20, %r15, %r3, %r15;
    setp.ne.s32 %p2, %r4, 5;
    mul.lo.u32 %r25, %r20, 4294967295;
    mad.lo.u32 %r25, %r3, %r25, %r25;
    add.u32 %r12, %r4, %r3;
    min.u32 %r14, %r3, 0;
    mad.lo.s32 %r9, %r15, %r15, %r25;
    mad.lo.u32 %r27, %r9, %r4, %r3;
    selp.b32 %r13, %r3, %r4, %p2;
    mad.lo.u32 %r23, %r15, %r3, %r9;
    shl.b32 %r22, %r27, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
