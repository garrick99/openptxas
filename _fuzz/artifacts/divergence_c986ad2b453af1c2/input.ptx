.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd9, %r3, %r3;
    setp.hi.u32 %p3, %r3, %r3;
    @%p3 mad.lo.s32 %r19, %r3, %r3, %r3;
    sub.s32 %r6, %r3, 64;
    setp.ge.u32 %p1, %r19, 16;
    @%p1 mul.wide.u32 %rd14, %r3, %r19;
    mul.wide.s32 %rd14, %r19, %r3;
    cvt.s64.s32 %rd13, %r19;
    min.u32 %r24, %r19, 2;
    setp.eq.s32 %p1, %r19, %r3;
    @%p1 add.u32 %r6, %r24, 32;
    shl.b32 %r26, %r3, 15;
    max.u64 %rd8, %rd13, %rd9;
    sub.u32 %r15, %r3, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
