.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r12, %r3, %r3;
    max.u32 %r8, %r12, 15;
    xor.b32 %r23, %r3, %r12;
    setp.lo.u32 %p1, %r12, %r23;
    setp.hs.u32 %p4, %r23, %r3;
    @!%p4 max.u32 %r12, %r3, %r3;
    mad.lo.u32 %r9, %r12, %r23, %r23;
    max.s32 %r13, %r9, 4;
    shr.u32 %r9, %r8, 30;
    mad.lo.u32 %r19, %r12, %r23, %r13;
    mad.lo.s32 %r9, %r9, %r8, %r9;
    sub.s32 %r20, %r19, %r13;
    min.u32 %r14, %r19, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
