.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r23, %r3, %r3;
    mad.lo.s32 %r23, %r23, %r3, %r23;
    add.u32 %r21, %r23, %r3;
    shr.s32 %r8, %r23, 2;
    setp.ge.s32 %p3, %r8, %r23;
    @!%p3 mul.wide.u32 %rd11, %r8, %r8;
    setp.ge.s32 %p3, %r23, 255;
    selp.b32 %r11, %r3, %r23, %p3;
    shr.s64 %rd8, %rd11, 33;
    and.b32 %r6, %r23, 15;
    cvt.s32.s64 %r24, %rd8;
    sub.u32 %r14, %r24, %r11;
    cvt.u64.u32 %rd13, %r3;
    cvt.s64.s32 %rd9, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
