.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hi.u32 %p4, %r3, 1;
    cvt.u64.u32 %rd12, %r3;
    sub.u32 %r9, %r3, %r3;
    mad.lo.u32 %r26, %r3, %r3, %r3;
    shr.s32 %r24, %r26, 30;
    cvt.u32.u64 %r21, %rd12;
    mul.wide.s32 %rd10, %r9, %r3;
    xor.b32 %r26, %r3, %r21;
    setp.eq.u32 %p2, %r26, %r3;
    setp.ge.s32 %p4, %r24, %r3;
    setp.ne.s32 %p1, %r3, %r9;
    setp.eq.s32 %p3, %r24, %r24;
    @%p3 add.s64 %rd13, %rd12, %rd12;
    shl.b32 %r13, %r24, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
