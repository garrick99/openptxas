.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    mad.lo.u32 %r27, %r3, %r3, %r3;
    shr.s64 %rd8, %rd14, 4;
    xor.b32 %r5, %r27, 2;
    or.b32 %r9, %r3, 4;
    mul.lo.u32 %r5, %r9, %r9;
    cvt.u64.u32 %rd15, %r3;
    min.u32 %r27, %r5, %r3;
    shl.b64 %rd8, %rd8, 32;
    min.s32 %r12, %r5, 63;
    mul.wide.s32 %rd7, %r12, %r3;
    shl.b32 %r6, %r12, 0;
    max.u32 %r6, %r5, %r27;
    shl.b32 %r6, %r12, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
