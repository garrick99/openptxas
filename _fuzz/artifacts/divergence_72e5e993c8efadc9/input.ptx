.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p4, %r3, %r3;
    @%p4 mad.lo.s32 %r4, %r3, %r3, %r3;
    min.u32 %r13, %r4, 2;
    min.s32 %r11, %r13, 7;
    mul.lo.u32 %r27, %r3, 65536;
    mad.lo.s32 %r23, %r11, %r27, %r27;
    shl.b32 %r12, %r11, 4;
    xor.b32 %r20, %r12, %r13;
    selp.b32 %r8, %r20, %r3, %p4;
    add.u32 %r18, %r4, 15;
    shr.s32 %r26, %r8, 3;
    mad.lo.s32 %r11, %r26, %r27, %r11;
    setp.ge.u32 %p4, %r12, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
