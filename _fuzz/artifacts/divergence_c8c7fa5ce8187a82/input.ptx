.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd7, %r3, %r3;
    min.s32 %r23, %r3, 8;
    shr.u32 %r6, %r3, 3;
    setp.lt.s32 %p4, %r3, %r6;
    cvt.s64.s32 %rd12, %r6;
    setp.hi.u32 %p1, %r3, %r6;
    @%p1 add.u32 %r7, %r3, %r6;
    cvt.s32.s64 %r18, %rd12;
    shl.b64 %rd12, %rd7, 62;
    mul.wide.s32 %rd7, %r18, %r6;
    min.s32 %r26, %r18, %r7;
    min.u32 %r24, %r6, 65535;
    mad.lo.u32 %r24, %r7, %r7, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
