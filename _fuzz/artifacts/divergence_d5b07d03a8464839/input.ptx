.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r18, %r3, %r3;
    mul.lo.s32 %r4, %r3, 7;
    max.s32 %r13, %r3, %r4;
    add.s32 %r24, %r13, %r3;
    setp.le.s32 %p1, %r24, %r13;
    mul.wide.s32 %rd7, %r4, %r18;
    selp.b32 %r10, %r24, %r3, %p1;
    shl.b32 %r19, %r4, 2;
    min.u32 %r11, %r18, 65535;
    xor.b32 %r25, %r18, 7;
    cvt.s32.s64 %r13, %rd7;
    setp.le.s32 %p4, %r10, %r24;
    @%p4 or.b32 %r25, %r24, %r10;
    mul.lo.u32 %r10, %r4, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
