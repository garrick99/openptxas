.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r17, %r3, %r3, %r3;
    shr.u32 %r24, %r3, 30;
    mul.lo.u32 %r12, %r24, 5;
    mul.wide.s32 %rd13, %r17, %r24;
    add.s32 %r11, %r17, %r12;
    mul.lo.s32 %r10, %r17, 0;
    shr.s32 %r17, %r10, 2;
    sub.s64 %rd12, %rd13, %rd13;
    add.u64 %rd8, %rd13, %rd13;
    mul.wide.u32 %rd14, %r3, %r12;
    setp.ne.u32 %p4, %r10, 1;
    setp.hi.u32 %p2, %r17, %r24;
    setp.le.u32 %p4, %r12, 63;
    shr.u64 %rd5, %rd13, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
