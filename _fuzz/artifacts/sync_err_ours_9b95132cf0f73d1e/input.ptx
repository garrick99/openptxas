.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r26, %r3, 31;
    and.b32 %r12, %r3, 2147483647;
    setp.hs.u32 %p3, %r3, 8;
    shr.u32 %r8, %r3, 30;
    cvt.u64.u32 %rd10, %r26;
    cvt.s64.s32 %rd11, %r8;
    max.s64 %rd8, %rd10, %rd11;
    sub.s32 %r21, %r3, 63;
    xor.b32 %r11, %r3, 4;
    xor.b32 %r18, %r8, 2147483647;
    and.b32 %r11, %r8, %r3;
    sub.s32 %r14, %r12, %r11;
    mul.wide.u32 %rd12, %r8, %r26;
    max.s32 %r10, %r11, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
