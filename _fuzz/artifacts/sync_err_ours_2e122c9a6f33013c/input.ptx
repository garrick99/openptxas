.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r8, %r3, %r3;
    min.s32 %r16, %r3, %r8;
    mul.wide.s32 %rd13, %r8, %r8;
    cvt.u64.u32 %rd13, %r16;
    setp.eq.u32 %p1, %r8, %r16;
    or.b32 %r22, %r16, %r16;
    add.u32 %r17, %r16, %r8;
    mul.lo.s32 %r17, %r22, %r22;
    max.u64 %rd12, %rd13, %rd13;
    selp.b32 %r24, %r17, %r17, %p1;
    mul.lo.u64 %rd6, %rd13, %rd13;
    max.s32 %r19, %r22, 256;
    min.s32 %r24, %r17, 255;
    max.s64 %rd8, %rd12, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
