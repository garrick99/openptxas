    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    add.u64 %rd13, %rd9, %rd9;
    and.b32 %r5, %r3, 1;
    or.b32 %r22, %r3, 65535;
    cvt.s32.s64 %r20, %rd13;
    max.s32 %r9, %r22, 65536;
    cvt.s64.s32 %rd12, %r22;
    mul.wide.s32 %rd9, %r5, %r9;
    xor.b32 %r18, %r3, 2147483647;
    mad.lo.s32 %r14, %r9, %r5, %r9;
    mul.lo.u32 %r23, %r22, %r9;
    add.u32 %r25, %r9, %r5;
    xor.b32 %r22, %r3, 4;
