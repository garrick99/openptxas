.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p1, %r3, 8;
    @%p1 sub.u32 %r17, %r3, 31;
    max.s32 %r14, %r3, %r17;
    xor.b32 %r6, %r17, %r14;
    cvt.u64.u32 %rd12, %r17;
    mad.lo.s32 %r16, %r3, %r17, %r17;
    min.s32 %r5, %r14, %r17;
    or.b32 %r20, %r17, 4;
    selp.b32 %r4, %r6, %r16, %p1;
    setp.gt.u32 %p4, %r3, 16;
    max.u64 %rd13, %rd12, %rd12;
    and.b64 %rd9, %rd12, %rd13;
    mad.lo.u32 %r12, %r3, %r16, %r16;
    shl.b64 %rd6, %rd9, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
