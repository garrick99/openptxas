.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r17, %r3, 4;
    cvt.u64.u32 %rd10, %r17;
    shr.s32 %r18, %r3, 31;
    shr.s64 %rd6, %rd10, 63;
    min.s32 %r26, %r3, %r3;
    add.s32 %r5, %r26, %r3;
    and.b64 %rd7, %rd6, %rd10;
    min.s32 %r11, %r17, %r17;
    cvt.s32.s64 %r7, %rd6;
    setp.ge.s32 %p1, %r26, %r18;
    setp.eq.u32 %p4, %r3, %r11;
    @!%p4 add.u32 %r16, %r7, 16;
    mul.wide.u32 %rd5, %r7, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
