.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd15, %r3, %r3;
    max.u32 %r15, %r3, 8;
    max.s32 %r7, %r3, %r3;
    shr.s64 %rd10, %rd15, 31;
    sub.u32 %r14, %r7, 1;
    and.b32 %r26, %r15, %r7;
    mul.wide.u32 %rd7, %r7, %r7;
    sub.u32 %r12, %r15, 64;
    mad.lo.s32 %r9, %r15, %r7, %r12;
    xor.b32 %r21, %r26, %r12;
    shl.b32 %r9, %r21, 31;
    sub.u32 %r8, %r9, 256;
    shr.s32 %r22, %r12, 2;
    min.u32 %r8, %r8, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
