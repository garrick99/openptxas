.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r20, %r3, %r3;
    xor.b32 %r11, %r3, %r3;
    sub.s32 %r15, %r11, 255;
    min.s32 %r24, %r3, 0;
    sub.s32 %r20, %r15, 256;
    shr.s32 %r26, %r3, 31;
    setp.ge.s32 %p4, %r15, 7;
    @%p4 max.u32 %r9, %r24, 7;
    and.b32 %r21, %r9, %r11;
    cvt.u64.u32 %rd10, %r9;
    max.u32 %r22, %r9, 65535;
    mul.wide.u32 %rd14, %r20, %r21;
    max.u32 %r25, %r24, 4;
    mad.lo.u32 %r16, %r24, %r9, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
