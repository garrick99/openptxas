.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd9, %r3, %r3;
    mul.wide.u32 %rd8, %r3, %r3;
    cvt.s64.s32 %rd10, %r3;
    shl.b64 %rd7, %rd8, 4;
    mul.wide.s32 %rd14, %r3, %r3;
    mul.wide.s32 %rd5, %r3, %r3;
    mul.lo.s32 %r7, %r3, 8;
    shr.s32 %r17, %r3, 0;
    mad.lo.u32 %r8, %r7, %r7, %r7;
    mad.lo.s32 %r20, %r17, %r3, %r8;
    max.u32 %r5, %r8, %r20;
    max.u64 %rd13, %rd8, %rd7;
    add.s32 %r16, %r17, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
