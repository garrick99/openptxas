.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p4, %r3, %r3;
    @!%p4 add.u32 %r16, %r3, 1;
    shr.s32 %r18, %r16, 0;
    setp.eq.s32 %p3, %r16, %r18;
    setp.gt.s32 %p3, %r3, %r16;
    @%p3 cvt.s64.s32 %rd6, %r18;
    cvt.u32.u64 %r25, %rd6;
    or.b32 %r10, %r18, %r16;
    selp.b32 %r13, %r3, %r25, %p3;
    setp.ge.u32 %p2, %r18, 0;
    @%p2 max.s32 %r27, %r25, 8;
    xor.b32 %r12, %r16, 0;
    and.b32 %r18, %r3, %r25;
    shl.b32 %r22, %r13, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
