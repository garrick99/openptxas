    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hi.u32 %p1, %r3, 65535;
    @%p1 shr.s32 %r20, %r3, 2;
    min.s32 %r19, %r20, %r20;
    cvt.u64.u32 %rd13, %r20;
    max.s32 %r12, %r3, %r19;
    shr.s32 %r25, %r3, 3;
    shl.b32 %r20, %r3, 1;
    min.s32 %r8, %r25, %r12;
    min.s32 %r15, %r19, 2;
    selp.b32 %r15, %r15, %r20, %p1;
    min.s32 %r26, %r3, 2147483648;
    xor.b32 %r7, %r15, 16;
    max.u32 %r13, %r12, %r19;
    add.s32 %r12, %r8, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
