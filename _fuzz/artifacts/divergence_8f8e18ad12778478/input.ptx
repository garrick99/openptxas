.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r11, %r3, 256;
    mul.wide.u32 %rd10, %r3, %r3;
    or.b32 %r24, %r3, 32;
    add.u32 %r5, %r24, 16;
    shl.b64 %rd15, %rd10, 31;
    or.b32 %r20, %r3, %r5;
    sub.s32 %r6, %r20, %r11;
    mul.wide.u32 %rd9, %r3, %r3;
    add.s32 %r15, %r5, %r6;
    sub.u32 %r25, %r15, 64;
    mad.lo.s32 %r16, %r20, %r15, %r24;
    mul.wide.u32 %rd13, %r24, %r16;
    max.s32 %r4, %r15, 32;
    mul.wide.u32 %rd8, %r6, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
