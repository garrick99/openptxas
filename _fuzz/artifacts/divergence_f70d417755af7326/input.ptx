.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r6, %r3, %r3, %r3;
    shr.u32 %r20, %r6, 4;
    cvt.s64.s32 %rd7, %r6;
    add.u64 %rd11, %rd7, %rd7;
    max.u32 %r21, %r6, %r3;
    cvt.u32.u64 %r13, %rd11;
    mul.lo.u32 %r7, %r20, 2147483647;
    mul.lo.s32 %r27, %r3, %r7;
    sub.u32 %r22, %r13, 4294967295;
    shr.u64 %rd11, %rd11, 0;
    min.u32 %r11, %r21, 4;
    min.s32 %r4, %r27, 2;
    max.s64 %rd13, %rd11, %rd7;
    shl.b32 %r4, %r4, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
