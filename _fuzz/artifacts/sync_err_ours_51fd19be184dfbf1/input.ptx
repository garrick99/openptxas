.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r5, %r3, 7;
    setp.ge.s32 %p1, %r3, 64;
    setp.lt.s32 %p4, %r3, 0;
    @%p4 cvt.s64.s32 %rd9, %r5;
    mul.wide.s32 %rd5, %r5, %r5;
    shr.s32 %r18, %r5, 16;
    min.u32 %r5, %r3, 3;
    or.b32 %r13, %r18, 256;
    add.s32 %r23, %r18, %r3;
    shl.b32 %r15, %r18, 1;
    sub.u32 %r8, %r15, %r18;
    shr.u32 %r27, %r15, 31;
    mul.wide.s32 %rd11, %r8, %r3;
    sub.u64 %rd8, %rd5, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
