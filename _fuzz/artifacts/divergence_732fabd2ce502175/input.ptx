.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r14, %r3, %r3;
    mul.wide.u32 %rd6, %r14, %r14;
    shr.u64 %rd13, %rd6, 62;
    or.b32 %r16, %r3, %r3;
    cvt.u32.u64 %r15, %rd13;
    and.b32 %r4, %r3, %r3;
    shl.b32 %r22, %r14, 1;
    min.u32 %r27, %r16, %r4;
    sub.u64 %rd5, %rd13, %rd13;
    shr.u64 %rd8, %rd5, 31;
    cvt.u32.u64 %r23, %rd13;
    shr.s32 %r25, %r4, 3;
    cvt.s32.s64 %r27, %rd8;
    cvt.u32.u64 %r20, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
