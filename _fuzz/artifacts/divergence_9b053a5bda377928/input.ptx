.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p3, %r3, 32;
    @!%p3 mad.lo.u32 %r13, %r3, %r3, %r3;
    setp.eq.s32 %p4, %r13, 8;
    @%p4 cvt.u64.u32 %rd7, %r13;
    add.u32 %r26, %r13, %r3;
    min.s32 %r23, %r3, 256;
    mul.lo.s32 %r22, %r23, 255;
    mul.lo.s32 %r7, %r26, %r22;
    setp.le.u32 %p4, %r13, 7;
    @%p4 cvt.u64.u32 %rd15, %r22;
    mul.wide.u32 %rd10, %r22, %r7;
    and.b64 %rd10, %rd15, %rd10;
    shl.b32 %r7, %r26, 0;
    mul.wide.u32 %rd15, %r13, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
