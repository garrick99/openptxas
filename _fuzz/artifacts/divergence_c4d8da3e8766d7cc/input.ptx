.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r15, %r3, 3;
    setp.le.s32 %p3, %r15, %r3;
    @!%p3 max.s32 %r19, %r3, %r3;
    shl.b32 %r17, %r3, 31;
    max.u32 %r26, %r17, %r15;
    setp.lt.u32 %p3, %r3, %r26;
    @!%p3 max.s32 %r7, %r26, %r26;
    min.s32 %r14, %r17, %r17;
    cvt.s64.s32 %rd9, %r15;
    selp.b32 %r16, %r19, %r26, %p3;
    and.b32 %r10, %r15, 2;
    sub.u32 %r26, %r10, 15;
    max.s32 %r17, %r16, %r19;
    mad.lo.s32 %r6, %r3, %r7, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
