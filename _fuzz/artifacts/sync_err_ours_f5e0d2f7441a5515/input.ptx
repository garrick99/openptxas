.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    mul.lo.u32 %r21, %r3, %r3;
    max.s32 %r12, %r3, %r21;
    shr.u64 %rd9, %rd6, 15;
    setp.eq.s32 %p3, %r3, %r21;
    setp.eq.u32 %p1, %r21, %r12;
    selp.b32 %r20, %r3, %r21, %p1;
    sub.s64 %rd15, %rd9, %rd6;
    mul.lo.s32 %r7, %r20, %r21;
    sub.s32 %r8, %r3, 256;
    shl.b64 %rd12, %rd6, 33;
    or.b64 %rd6, %rd15, %rd6;
    setp.gt.s32 %p1, %r12, 2;
    @%p1 max.u32 %r10, %r21, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
