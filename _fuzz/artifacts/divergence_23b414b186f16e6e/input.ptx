.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r11, %r3, %r3;
    cvt.u64.u32 %rd7, %r3;
    mad.lo.u32 %r14, %r3, %r11, %r3;
    cvt.s32.s64 %r4, %rd7;
    sub.s32 %r18, %r14, %r11;
    cvt.s64.s32 %rd9, %r14;
    shr.s64 %rd10, %rd9, 2;
    mul.lo.s32 %r4, %r4, %r3;
    min.u32 %r26, %r3, 31;
    mul.lo.s32 %r17, %r18, 16;
    setp.le.u32 %p3, %r18, 15;
    cvt.s64.s32 %rd5, %r17;
    selp.b32 %r6, %r26, %r11, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
