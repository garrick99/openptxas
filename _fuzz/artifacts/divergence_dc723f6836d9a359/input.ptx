.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfe.u32 %r9, %r3, 23, 16;
    prmt.b32 %r20, %r9, %r9, 0;
    bfe.s32 %r6, %r20, 0, 32;
    bfi.b32 %r21, %r6, %r20, 4, 4;
    bfe.u32 %r18, %r6, 4, 8;
    and.b32 %r17, %r21, %r21;
    popc.b32 %r23, %r9;
    bfe.u32 %r10, %r20, 0, 16;
    bfi.b32 %r19, %r10, %r3, 24, 16;
    popc.b32 %r21, %r10;
    popc.b32 %r19, %r23;
    clz.b32 %r7, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
