.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p1, %r3, 65535;
    @!%p1 mul.lo.s32 %r17, %r3, %r3;
    shl.b32 %r22, %r17, 15;
    max.u32 %r25, %r17, %r22;
    shr.u32 %r7, %r25, 2;
    max.u32 %r4, %r17, %r17;
    mul.wide.s32 %rd9, %r25, %r17;
    shr.s32 %r18, %r7, 3;
    mad.lo.u32 %r22, %r25, %r7, %r3;
    min.s32 %r10, %r4, 4;
    mul.wide.s32 %rd9, %r7, %r17;
    selp.b32 %r22, %r18, %r25, %p1;
    max.s32 %r21, %r3, %r25;
    shr.u64 %rd7, %rd9, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
