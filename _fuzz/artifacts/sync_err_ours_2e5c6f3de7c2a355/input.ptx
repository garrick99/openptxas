.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    cvt.s64.s32 %rd11, %r3;
    shr.s32 %r8, %r3, 30;
    mul.lo.s64 %rd8, %rd7, %rd11;
    add.s32 %r25, %r3, %r8;
    add.u32 %r7, %r8, 8;
    shl.b32 %r9, %r8, 15;
    shl.b32 %r24, %r3, 15;
    mul.lo.s32 %r7, %r7, 64;
    mul.lo.u32 %r14, %r7, %r3;
    setp.eq.u32 %p1, %r8, %r9;
    @%p1 and.b32 %r9, %r8, 2147483648;
    mad.lo.u32 %r22, %r9, %r25, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
