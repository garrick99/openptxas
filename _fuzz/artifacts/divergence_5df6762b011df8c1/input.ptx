.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    mul.lo.s32 %r27, %r3, %r3;
    sub.s32 %r16, %r27, 65535;
    or.b32 %r15, %r27, 31;
    cvt.s32.s64 %r13, %rd8;
    max.u32 %r16, %r16, %r13;
    cvt.s64.s32 %rd5, %r16;
    max.u64 %rd8, %rd5, %rd8;
    min.u32 %r25, %r27, %r15;
    and.b32 %r25, %r15, %r25;
    min.u32 %r22, %r15, 65535;
    cvt.s32.s64 %r16, %rd5;
    mul.lo.s32 %r8, %r27, %r25;
    cvt.s64.s32 %rd6, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
