.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd7, %r3, %r3;
    cvt.u64.u32 %rd10, %r3;
    add.u32 %r14, %r3, 7;
    xor.b64 %rd15, %rd10, %rd7;
    setp.gt.u32 %p4, %r14, 15;
    @%p4 sub.s32 %r14, %r14, %r3;
    or.b64 %rd14, %rd10, %rd15;
    add.s32 %r25, %r14, 2147483648;
    add.u64 %rd15, %rd14, %rd14;
    or.b32 %r12, %r3, 65536;
    cvt.u32.u64 %r11, %rd15;
    sub.u32 %r7, %r12, %r11;
    min.u32 %r19, %r3, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
