.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r23, %r3, 0;
    shr.u32 %r11, %r3, 7;
    setp.ge.s32 %p2, %r23, 65536;
    @%p2 shl.b32 %r13, %r3, 1;
    mad.lo.s32 %r10, %r13, %r11, %r23;
    cvt.s64.s32 %rd8, %r10;
    mul.lo.u32 %r6, %r23, 7;
    min.s32 %r25, %r10, %r23;
    sub.u32 %r24, %r13, %r6;
    shl.b64 %rd9, %rd8, 16;
    mul.lo.s32 %r25, %r24, %r25;
    mul.wide.s32 %rd10, %r11, %r13;
    sub.s32 %r10, %r25, 3;
    cvt.s64.s32 %rd10, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
