.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r27, %r3, 31;
    xor.b32 %r6, %r27, 65535;
    mul.wide.u32 %rd6, %r6, %r6;
    mad.lo.u32 %r4, %r3, %r6, %r3;
    add.u32 %r15, %r6, %r4;
    setp.eq.u32 %p4, %r15, 7;
    @%p4 mul.lo.u64 %rd9, %rd6, %rd6;
    sub.u64 %rd14, %rd9, %rd6;
    cvt.s64.s32 %rd9, %r4;
    mul.wide.u32 %rd5, %r15, %r15;
    max.u32 %r18, %r6, %r6;
    setp.lo.u32 %p2, %r18, %r27;
    @%p2 shr.s32 %r25, %r4, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
