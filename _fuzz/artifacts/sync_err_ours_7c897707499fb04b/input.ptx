.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r17, %r3, %r3;
    cvt.u64.u32 %rd12, %r17;
    min.u32 %r24, %r3, %r17;
    add.s64 %rd14, %rd12, %rd12;
    max.u32 %r25, %r3, %r3;
    add.s32 %r5, %r24, %r17;
    add.s64 %rd15, %rd14, %rd14;
    cvt.s32.s64 %r16, %rd12;
    or.b32 %r25, %r3, %r17;
    cvt.s32.s64 %r13, %rd15;
    xor.b64 %rd11, %rd12, %rd15;
    mul.wide.u32 %rd5, %r25, %r25;
    setp.hi.u32 %p2, %r17, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
