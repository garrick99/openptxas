.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r21, %r3, %r3;
    sub.s32 %r5, %r21, %r3;
    min.s32 %r17, %r5, 31;
    sub.s32 %r18, %r21, 64;
    xor.b32 %r14, %r21, %r18;
    add.s32 %r11, %r5, 0;
    shl.b32 %r13, %r21, 3;
    sub.u32 %r21, %r11, %r11;
    mul.lo.u32 %r22, %r21, 8;
    cvt.s64.s32 %rd12, %r3;
    add.u32 %r10, %r18, 15;
    mul.lo.u32 %r22, %r18, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
