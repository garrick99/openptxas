.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd5, %r3, %r3;
    setp.ge.s32 %p2, %r3, 65535;
    @!%p2 max.u32 %r7, %r3, 2147483648;
    or.b32 %r13, %r7, %r7;
    cvt.s32.s64 %r19, %rd5;
    shr.u64 %rd8, %rd5, 3;
    xor.b32 %r18, %r7, 64;
    sub.u32 %r19, %r3, %r13;
    cvt.s32.s64 %r19, %rd5;
    min.s32 %r5, %r18, 4294967295;
    setp.lt.s32 %p1, %r5, 31;
    @%p1 shr.u64 %rd14, %rd8, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
