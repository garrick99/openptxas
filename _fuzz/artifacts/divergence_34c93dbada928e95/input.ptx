.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    sub.u32 %r27, %r3, %r3;
    setp.hi.u32 %p2, %r27, 4;
    setp.lo.u32 %p1, %r3, %r3;
    @%p1 or.b32 %r6, %r3, 255;
    and.b32 %r17, %r3, %r6;
    max.s64 %rd12, %rd13, %rd13;
    xor.b32 %r13, %r17, 32;
    mul.wide.s32 %rd10, %r17, %r27;
    cvt.u32.u64 %r20, %rd13;
    selp.b32 %r15, %r27, %r13, %p1;
    xor.b32 %r21, %r6, 1;
    cvt.s64.s32 %rd8, %r15;
    max.s32 %r17, %r15, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
