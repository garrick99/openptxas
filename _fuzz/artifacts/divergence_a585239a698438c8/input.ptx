.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r18, %r3, 2;
    mul.wide.s32 %rd11, %r18, %r18;
    and.b32 %r27, %r3, %r18;
    setp.lo.u32 %p4, %r3, 32;
    @!%p4 add.u32 %r6, %r3, %r3;
    max.s32 %r13, %r6, 1;
    shr.s32 %r12, %r13, 31;
    shr.s64 %rd11, %rd11, 3;
    add.s32 %r22, %r12, %r18;
    mul.wide.u32 %rd12, %r12, %r27;
    shl.b32 %r16, %r3, 15;
    cvt.s64.s32 %rd6, %r22;
    min.u64 %rd12, %rd12, %rd11;
    mul.lo.s32 %r24, %r13, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
