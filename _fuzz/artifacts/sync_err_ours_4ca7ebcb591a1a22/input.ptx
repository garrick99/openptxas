.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    max.u32 %r18, %r3, 2;
    min.u32 %r22, %r18, %r3;
    cvt.s64.s32 %rd6, %r18;
    mad.lo.s32 %r10, %r3, %r22, %r3;
    shr.u32 %r19, %r18, 1;
    min.s64 %rd8, %rd7, %rd6;
    or.b32 %r24, %r22, %r10;
    shr.u64 %rd11, %rd7, 4;
    shl.b64 %rd9, %rd8, 0;
    max.s32 %r25, %r24, %r22;
    shr.s32 %r26, %r3, 15;
    max.u32 %r22, %r22, 16;
    mad.lo.u32 %r12, %r19, %r18, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
