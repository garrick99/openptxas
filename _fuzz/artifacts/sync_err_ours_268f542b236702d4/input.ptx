.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r13, %r3, %r3;
    cvt.u64.u32 %rd13, %r13;
    mul.lo.u32 %r7, %r13, 255;
    shr.s64 %rd8, %rd13, 15;
    and.b32 %r16, %r13, %r3;
    setp.ne.u32 %p3, %r13, 2147483648;
    @!%p3 shr.u32 %r13, %r16, 15;
    or.b32 %r25, %r16, %r3;
    shl.b32 %r26, %r25, 16;
    max.u32 %r21, %r13, 63;
    min.s32 %r17, %r26, 1;
    setp.ge.s32 %p1, %r7, %r21;
    @%p1 min.u32 %r20, %r17, %r26;
    shr.u32 %r16, %r21, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
