.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    add.s32 %r10, %r3, 16;
    setp.ls.u32 %p1, %r3, %r10;
    @%p1 cvt.u64.u32 %rd5, %r10;
    shr.u64 %rd7, %rd5, 32;
    setp.hi.u32 %p2, %r10, %r10;
    @%p2 min.u32 %r20, %r10, %r3;
    setp.ge.u32 %p1, %r3, %r10;
    shr.s64 %rd15, %rd7, 4;
    cvt.u32.u64 %r10, %rd7;
    sub.s32 %r12, %r3, 31;
    add.s32 %r11, %r3, 31;
    min.u32 %r13, %r3, 16;
    xor.b32 %r4, %r20, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
