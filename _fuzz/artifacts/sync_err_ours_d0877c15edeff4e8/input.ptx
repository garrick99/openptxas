.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    shl.b64 %rd11, %rd15, 16;
    xor.b64 %rd15, %rd11, %rd11;
    sub.u32 %r14, %r3, %r3;
    min.u32 %r8, %r3, %r3;
    sub.s64 %rd6, %rd15, %rd11;
    mul.lo.s32 %r20, %r14, %r3;
    setp.lt.s32 %p1, %r20, 2147483648;
    @!%p1 add.s32 %r24, %r8, %r14;
    mul.lo.s32 %r25, %r3, 255;
    shl.b64 %rd7, %rd11, 31;
    or.b32 %r14, %r3, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
