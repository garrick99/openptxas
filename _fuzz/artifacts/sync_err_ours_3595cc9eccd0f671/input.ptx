.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r23, %r3, 1;
    mul.wide.u32 %rd14, %r23, %r3;
    mul.wide.s32 %rd5, %r23, %r3;
    and.b64 %rd12, %rd14, %rd14;
    min.u32 %r21, %r3, %r23;
    add.u32 %r13, %r23, %r21;
    setp.lt.s32 %p2, %r21, 2;
    @!%p2 or.b32 %r14, %r21, 15;
    shr.u32 %r17, %r14, 7;
    selp.b32 %r7, %r17, %r23, %p2;
    shl.b32 %r27, %r7, 2;
    min.s32 %r24, %r7, %r14;
    mul.wide.u32 %rd7, %r21, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
