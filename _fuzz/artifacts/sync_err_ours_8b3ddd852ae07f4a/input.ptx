.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r17, %r3, 7;
    shr.s32 %r11, %r17, 7;
    or.b32 %r25, %r11, %r17;
    mul.lo.s32 %r7, %r25, 255;
    xor.b32 %r20, %r25, %r17;
    cvt.s64.s32 %rd9, %r20;
    setp.eq.s32 %p1, %r7, %r25;
    setp.lo.u32 %p1, %r20, 64;
    @%p1 and.b32 %r21, %r11, %r25;
    cvt.u32.u64 %r13, %rd9;
    shl.b64 %rd13, %rd9, 0;
    mul.lo.s32 %r20, %r13, 15;
    add.s32 %r7, %r11, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
