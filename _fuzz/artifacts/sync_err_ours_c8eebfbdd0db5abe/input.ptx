.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    add.s32 %r6, %r3, %r3;
    setp.eq.u32 %p4, %r3, %r3;
    @!%p4 selp.b32 %r27, %r6, %r6, %p4;
    or.b32 %r17, %r6, %r3;
    mul.lo.s32 %r27, %r17, %r6;
    setp.lt.s32 %p1, %r27, %r6;
    @!%p1 shl.b32 %r12, %r17, 7;
    max.s32 %r24, %r27, 4294967295;
    selp.b32 %r21, %r24, %r17, %p4;
    max.s32 %r11, %r24, %r6;
    cvt.u32.u64 %r21, %rd11;
    mul.wide.u32 %rd13, %r24, %r11;
    sub.s64 %rd8, %rd11, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
