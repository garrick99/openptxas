.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r24, %r3, %r3;
    max.u32 %r16, %r3, 2147483648;
    mad.lo.s32 %r26, %r16, %r3, %r16;
    cvt.u64.u32 %rd6, %r24;
    xor.b32 %r21, %r26, %r16;
    shl.b32 %r24, %r26, 31;
    cvt.u32.u64 %r24, %rd6;
    cvt.s64.s32 %rd10, %r3;
    cvt.u64.u32 %rd11, %r26;
    setp.lt.s32 %p4, %r26, %r24;
    @!%p4 add.u32 %r13, %r21, 3;
    max.u32 %r10, %r13, 0;
    selp.b32 %r15, %r13, %r10, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
