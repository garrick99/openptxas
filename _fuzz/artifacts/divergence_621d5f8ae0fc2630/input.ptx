.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r15, %r3, 15;
    mul.lo.s32 %r26, %r15, %r15;
    cvt.u64.u32 %rd13, %r26;
    mul.lo.u64 %rd5, %rd13, %rd13;
    shl.b32 %r24, %r15, 30;
    cvt.u32.u64 %r8, %rd13;
    xor.b32 %r17, %r26, 16;
    setp.le.u32 %p3, %r24, 31;
    @%p3 min.u32 %r25, %r26, %r26;
    cvt.s32.s64 %r9, %rd5;
    mul.lo.u32 %r27, %r9, 4294967295;
    shl.b64 %rd5, %rd13, 0;
    setp.ge.s32 %p2, %r15, %r27;
    @!%p2 selp.b32 %r14, %r17, %r26, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
