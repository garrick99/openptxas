.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd8, %r3, %r3;
    shl.b32 %r12, %r3, 7;
    setp.lt.s32 %p2, %r12, %r3;
    setp.eq.u32 %p3, %r12, %r3;
    @%p3 shr.s32 %r13, %r3, 15;
    add.s32 %r4, %r3, 0;
    shl.b64 %rd13, %rd8, 0;
    selp.b32 %r23, %r3, %r3, %p3;
    shr.u32 %r15, %r4, 0;
    cvt.u32.u64 %r4, %rd8;
    xor.b32 %r22, %r4, %r3;
    selp.b32 %r20, %r13, %r4, %p3;
    cvt.u32.u64 %r26, %rd13;
    cvt.s32.s64 %r24, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
