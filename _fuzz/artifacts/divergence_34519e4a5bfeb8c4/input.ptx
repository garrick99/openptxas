.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r26, %r3, 3;
    add.u32 %r20, %r3, 3;
    cvt.u64.u32 %rd8, %r20;
    max.u64 %rd6, %rd8, %rd8;
    shr.s32 %r17, %r26, 30;
    shr.s32 %r23, %r26, 4;
    mul.lo.u32 %r22, %r26, %r26;
    shl.b32 %r21, %r26, 2;
    min.s32 %r26, %r17, 4;
    sub.u32 %r5, %r23, 256;
    mad.lo.s32 %r21, %r3, %r5, %r5;
    setp.ls.u32 %p1, %r20, 32;
    @!%p1 sub.s32 %r19, %r23, %r17;
    max.s64 %rd12, %rd6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
