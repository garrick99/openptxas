.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    min.u32 %r11, %r3, %r3;
    shr.u32 %r26, %r11, 30;
    add.s32 %r23, %r3, %r26;
    add.s32 %r25, %r23, %r11;
    add.s32 %r17, %r3, %r23;
    mul.wide.u32 %rd14, %r23, %r17;
    add.s32 %r20, %r26, 5;
    add.s32 %r24, %r11, %r25;
    shl.b64 %rd14, %rd12, 0;
    shr.u32 %r9, %r25, 7;
    cvt.s32.s64 %r14, %rd14;
    sub.u32 %r25, %r9, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
