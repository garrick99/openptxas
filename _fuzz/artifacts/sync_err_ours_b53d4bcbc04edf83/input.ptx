.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    setp.lt.s32 %p4, %r3, 64;
    @!%p4 mul.wide.s32 %rd13, %r3, %r3;
    add.s32 %r25, %r3, %r3;
    shr.s64 %rd13, %rd15, 31;
    sub.u32 %r14, %r3, %r3;
    min.s32 %r15, %r3, %r3;
    cvt.s32.s64 %r6, %rd13;
    shr.u64 %rd13, %rd15, 47;
    shr.u32 %r21, %r25, 7;
    setp.eq.s32 %p4, %r25, 0;
    shl.b32 %r23, %r14, 7;
    setp.ne.s32 %p4, %r21, %r14;
    @%p4 selp.b32 %r11, %r21, %r15, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
