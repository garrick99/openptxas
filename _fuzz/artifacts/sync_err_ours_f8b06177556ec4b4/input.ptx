.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd14, %r3, %r3;
    shl.b64 %rd11, %rd14, 31;
    sub.u64 %rd12, %rd14, %rd14;
    cvt.u32.u64 %r19, %rd12;
    shr.s64 %rd9, %rd12, 33;
    mul.wide.u32 %rd8, %r19, %r3;
    max.s32 %r22, %r19, %r19;
    setp.gt.s32 %p3, %r3, 7;
    @!%p3 add.u32 %r23, %r3, %r22;
    mul.lo.u32 %r25, %r3, 65536;
    shl.b64 %rd15, %rd11, 32;
    sub.u32 %r12, %r19, %r22;
    cvt.u32.u64 %r10, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
