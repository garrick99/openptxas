.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    sub.u64 %rd13, %rd9, %rd9;
    sub.s32 %r26, %r3, %r3;
    shl.b64 %rd13, %rd9, 7;
    min.s64 %rd14, %rd9, %rd13;
    max.s32 %r18, %r3, 7;
    mad.lo.u32 %r18, %r3, %r3, %r3;
    xor.b32 %r23, %r26, 32;
    sub.s64 %rd9, %rd14, %rd9;
    min.s32 %r5, %r3, %r23;
    shr.s64 %rd11, %rd14, 47;
    setp.ne.s32 %p3, %r3, %r5;
    @%p3 selp.b32 %r4, %r3, %r26, %p3;
    mad.lo.s32 %r4, %r4, %r3, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
