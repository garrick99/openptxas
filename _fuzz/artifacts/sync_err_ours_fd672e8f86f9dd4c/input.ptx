.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    setp.ge.u32 %p4, %r3, %r3;
    or.b32 %r8, %r3, %r3;
    shl.b32 %r18, %r3, 4;
    mul.wide.u32 %rd6, %r18, %r18;
    cvt.u32.u64 %r27, %rd6;
    shr.s32 %r6, %r18, 30;
    add.s32 %r9, %r18, %r3;
    cvt.s32.s64 %r13, %rd10;
    sub.s32 %r22, %r27, 63;
    shr.u32 %r20, %r27, 4;
    setp.ne.s32 %p4, %r27, 32;
    @!%p4 selp.b32 %r7, %r6, %r20, %p4;
    shr.u32 %r18, %r27, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
