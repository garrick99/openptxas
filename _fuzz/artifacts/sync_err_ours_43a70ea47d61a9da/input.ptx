.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r16, %r3, 63;
    cvt.s64.s32 %rd8, %r3;
    cvt.u64.u32 %rd15, %r3;
    mul.wide.u32 %rd6, %r3, %r3;
    and.b32 %r24, %r16, 2;
    add.u64 %rd13, %rd8, %rd8;
    setp.ne.s32 %p4, %r24, 64;
    setp.ls.u32 %p4, %r16, 63;
    @%p4 max.u32 %r7, %r24, %r24;
    shl.b32 %r18, %r16, 7;
    shr.u32 %r15, %r3, 3;
    sub.u64 %rd8, %rd8, %rd15;
    setp.eq.s32 %p1, %r3, %r3;
    @%p1 mul.wide.s32 %rd10, %r7, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
