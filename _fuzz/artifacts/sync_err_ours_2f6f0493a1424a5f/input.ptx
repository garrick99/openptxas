.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd10, %r3, %r3;
    max.u32 %r23, %r3, %r3;
    add.u32 %r21, %r23, %r23;
    shr.u32 %r13, %r23, 15;
    add.u32 %r4, %r13, 7;
    and.b32 %r9, %r23, 2;
    mul.lo.s64 %rd11, %rd10, %rd10;
    setp.ge.s32 %p1, %r9, 64;
    @%p1 mul.lo.u32 %r21, %r3, 3;
    shr.s64 %rd6, %rd11, 2;
    max.s32 %r26, %r4, %r21;
    min.s64 %rd7, %rd11, %rd11;
    cvt.u32.u64 %r22, %rd11;
    setp.ne.s32 %p2, %r4, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
