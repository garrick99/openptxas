.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r11, %r3, 1;
    add.u32 %r12, %r11, %r3;
    cvt.s64.s32 %rd15, %r12;
    sub.s64 %rd7, %rd15, %rd15;
    cvt.u32.u64 %r8, %rd15;
    sub.s64 %rd10, %rd7, %rd7;
    setp.lt.u32 %p4, %r8, 256;
    @!%p4 selp.b32 %r21, %r8, %r3, %p4;
    shl.b64 %rd6, %rd7, 0;
    min.u32 %r25, %r3, %r3;
    sub.s32 %r9, %r25, 4294967295;
    mul.lo.s32 %r19, %r21, 8;
    max.s32 %r6, %r11, %r8;
    min.u32 %r8, %r19, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
