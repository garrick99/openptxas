.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r8, %r3, %r3, %r3;
    add.s32 %r25, %r8, 15;
    mul.lo.u32 %r27, %r8, %r25;
    sub.s32 %r26, %r8, %r25;
    mul.lo.u32 %r19, %r25, 32;
    mul.wide.s32 %rd12, %r3, %r27;
    sub.s32 %r23, %r26, %r26;
    shl.b64 %rd15, %rd12, 47;
    xor.b64 %rd9, %rd12, %rd15;
    max.u32 %r14, %r8, 7;
    shl.b32 %r13, %r27, 4;
    shr.u32 %r9, %r8, 30;
    mul.lo.s64 %rd11, %rd15, %rd15;
    mul.lo.s32 %r26, %r9, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
