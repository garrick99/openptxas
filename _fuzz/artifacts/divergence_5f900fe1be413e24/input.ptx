.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    mul.lo.s32 %r20, %r3, 65535;
    sub.s32 %r22, %r20, 256;
    min.s32 %r18, %r3, 256;
    add.s64 %rd14, %rd8, %rd8;
    xor.b32 %r23, %r22, %r20;
    setp.ls.u32 %p4, %r23, 255;
    @%p4 shl.b64 %rd5, %rd14, 32;
    or.b32 %r8, %r3, 2;
    max.u64 %rd7, %rd8, %rd8;
    selp.b32 %r25, %r23, %r18, %p4;
    add.u32 %r12, %r18, 0;
    cvt.u32.u64 %r17, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
