.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r18, %r3, 4;
    max.u32 %r9, %r3, 16;
    add.u32 %r5, %r9, %r3;
    cvt.s64.s32 %rd10, %r5;
    shl.b32 %r21, %r9, 2;
    mul.lo.u32 %r10, %r3, 65536;
    xor.b32 %r25, %r10, %r18;
    shl.b32 %r14, %r25, 2;
    mad.lo.s32 %r9, %r3, %r14, %r25;
    cvt.u64.u32 %rd10, %r9;
    mad.lo.u32 %r7, %r9, %r9, %r14;
    or.b64 %rd9, %rd10, %rd10;
    max.s32 %r15, %r7, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
