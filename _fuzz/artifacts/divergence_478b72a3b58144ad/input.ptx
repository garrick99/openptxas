.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r18, %r3, %r3;
    setp.lt.s32 %p3, %r18, %r18;
    @%p3 sub.u32 %r26, %r3, 31;
    setp.eq.s32 %p3, %r3, %r3;
    add.s32 %r4, %r18, %r26;
    shr.s32 %r12, %r26, 0;
    shl.b32 %r5, %r12, 2;
    sub.u32 %r16, %r12, %r3;
    min.u32 %r10, %r26, 2;
    mul.lo.s32 %r19, %r5, 16;
    sub.s32 %r14, %r26, %r26;
    or.b32 %r16, %r12, %r4;
    mad.lo.u32 %r11, %r4, %r14, %r26;
    xor.b32 %r15, %r19, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
