.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd5, %r3, %r3;
    max.u32 %r21, %r3, 0;
    cvt.u64.u32 %rd7, %r21;
    cvt.u32.u64 %r16, %rd5;
    mul.lo.u32 %r19, %r21, 32;
    mul.lo.s32 %r26, %r16, %r3;
    setp.ne.s32 %p2, %r3, %r26;
    @%p2 mul.wide.u32 %rd13, %r26, %r21;
    cvt.s64.s32 %rd13, %r26;
    min.s32 %r10, %r3, 0;
    shr.s32 %r16, %r21, 7;
    mad.lo.s32 %r8, %r10, %r21, %r3;
    min.u64 %rd13, %rd7, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
