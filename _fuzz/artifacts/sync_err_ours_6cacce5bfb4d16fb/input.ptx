.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    max.u32 %r14, %r3, %r3;
    cvt.s64.s32 %rd11, %r14;
    mul.lo.u32 %r9, %r3, 7;
    sub.s32 %r4, %r9, 0;
    shr.u64 %rd13, %rd15, 62;
    setp.le.u32 %p3, %r4, %r14;
    @%p3 max.u32 %r16, %r9, %r4;
    selp.b32 %r27, %r9, %r9, %p3;
    shr.s64 %rd13, %rd13, 30;
    mad.lo.u32 %r22, %r14, %r3, %r9;
    shr.u32 %r25, %r9, 1;
    min.u32 %r11, %r16, 255;
    shr.u64 %rd8, %rd11, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
