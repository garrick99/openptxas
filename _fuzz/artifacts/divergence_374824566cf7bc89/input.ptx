.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p4, %r3, 2;
    @%p4 cvt.s64.s32 %rd7, %r3;
    add.u32 %r11, %r3, %r3;
    min.u32 %r4, %r11, 2147483648;
    cvt.s32.s64 %r8, %rd7;
    max.u32 %r26, %r11, 7;
    and.b64 %rd5, %rd7, %rd7;
    xor.b32 %r11, %r3, 32;
    shr.u32 %r5, %r3, 16;
    mul.lo.u64 %rd7, %rd5, %rd7;
    cvt.s64.s32 %rd8, %r8;
    shl.b64 %rd14, %rd5, 15;
    shr.s32 %r7, %r8, 7;
    max.u32 %r13, %r7, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
