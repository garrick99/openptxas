.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r20, %r3, %r3, %r3;
    add.u32 %r15, %r3, 31;
    add.u32 %r17, %r15, %r15;
    cvt.u64.u32 %rd10, %r17;
    shr.s32 %r24, %r17, 4;
    shr.u32 %r18, %r24, 4;
    min.u32 %r4, %r18, 2;
    setp.ge.u32 %p3, %r24, %r3;
    @%p3 sub.u32 %r14, %r18, %r24;
    sub.u32 %r12, %r17, 63;
    cvt.u32.u64 %r4, %rd10;
    or.b32 %r21, %r24, 1;
    max.s32 %r8, %r15, %r17;
    mul.wide.s32 %rd6, %r15, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
