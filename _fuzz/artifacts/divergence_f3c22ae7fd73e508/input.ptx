.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r6, %r3, %r3, %r3;
    sub.s32 %r14, %r3, %r3;
    and.b32 %r13, %r6, %r3;
    mad.lo.u32 %r8, %r13, %r13, %r13;
    shr.s32 %r20, %r8, 30;
    and.b32 %r12, %r13, %r3;
    or.b32 %r19, %r20, %r14;
    cvt.u64.u32 %rd11, %r12;
    and.b32 %r6, %r20, %r14;
    sub.s32 %r17, %r8, 256;
    add.u64 %rd13, %rd11, %rd11;
    setp.lt.u32 %p3, %r20, 15;
    @%p3 mad.lo.u32 %r11, %r3, %r12, %r13;
    shr.u64 %rd10, %rd13, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
