.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r22, %r3, 65536;
    max.s32 %r8, %r22, 31;
    cvt.u64.u32 %rd15, %r8;
    sub.s64 %rd13, %rd15, %rd15;
    min.u32 %r9, %r8, 7;
    mad.lo.u32 %r20, %r8, %r22, %r8;
    shr.s64 %rd7, %rd15, 7;
    cvt.u64.u32 %rd10, %r8;
    cvt.s32.s64 %r4, %rd13;
    shl.b64 %rd8, %rd15, 2;
    shl.b32 %r20, %r8, 4;
    min.s32 %r20, %r4, 2147483647;
    setp.ge.u32 %p2, %r8, 5;
    @!%p2 selp.b32 %r17, %r8, %r8, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
