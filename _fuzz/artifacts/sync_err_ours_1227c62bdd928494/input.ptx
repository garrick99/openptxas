.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    sub.s32 %r4, %r3, 255;
    cvt.u32.u64 %r24, %rd5;
    mul.lo.u32 %r10, %r24, %r4;
    setp.ne.u32 %p2, %r4, 64;
    @%p2 cvt.u64.u32 %rd9, %r3;
    setp.eq.u32 %p3, %r10, 7;
    @%p3 xor.b32 %r9, %r24, %r3;
    shl.b32 %r19, %r9, 2;
    add.s32 %r21, %r19, 4;
    max.s32 %r12, %r3, %r19;
    shl.b64 %rd8, %rd5, 63;
    add.s32 %r9, %r10, %r19;
    mul.lo.s32 %r12, %r21, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
