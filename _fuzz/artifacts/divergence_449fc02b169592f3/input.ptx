.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r16, %r3, 0;
    max.u32 %r26, %r3, 255;
    min.s32 %r16, %r3, 65535;
    setp.hs.u32 %p2, %r16, 65536;
    @!%p2 add.u32 %r4, %r26, %r26;
    cvt.s64.s32 %rd5, %r26;
    shr.s64 %rd13, %rd5, 31;
    cvt.s64.s32 %rd10, %r3;
    mul.wide.u32 %rd11, %r4, %r16;
    selp.b32 %r4, %r3, %r26, %p2;
    xor.b32 %r20, %r16, %r3;
    min.u32 %r17, %r16, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
