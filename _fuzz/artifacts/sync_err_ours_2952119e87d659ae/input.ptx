.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r8, %r3, %r3;
    min.s32 %r8, %r3, 255;
    mul.wide.u32 %rd8, %r3, %r3;
    add.u32 %r15, %r3, 4294967295;
    and.b32 %r9, %r15, %r3;
    mad.lo.u32 %r27, %r3, %r8, %r3;
    or.b64 %rd7, %rd8, %rd8;
    or.b32 %r14, %r27, %r9;
    shr.u32 %r12, %r8, 16;
    shr.u64 %rd11, %rd8, 31;
    cvt.u32.u64 %r19, %rd7;
    and.b64 %rd8, %rd11, %rd7;
    add.u32 %r5, %r15, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
