.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    xor.b32 %r18, %r3, 4;
    mul.wide.u32 %rd8, %r18, %r3;
    mul.lo.s64 %rd14, %rd7, %rd8;
    min.u64 %rd8, %rd14, %rd8;
    cvt.s64.s32 %rd11, %r18;
    mad.lo.u32 %r25, %r18, %r3, %r3;
    sub.s32 %r9, %r25, %r3;
    max.s32 %r26, %r25, %r9;
    cvt.u32.u64 %r13, %rd8;
    sub.s32 %r9, %r13, %r18;
    add.s32 %r16, %r13, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
