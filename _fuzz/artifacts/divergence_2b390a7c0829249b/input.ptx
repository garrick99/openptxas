.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    shr.u64 %rd13, %rd5, 15;
    xor.b64 %rd13, %rd13, %rd13;
    min.s32 %r10, %r3, 31;
    and.b32 %r25, %r3, 65535;
    and.b32 %r25, %r10, %r3;
    add.s64 %rd10, %rd5, %rd13;
    cvt.s32.s64 %r27, %rd13;
    shl.b32 %r15, %r27, 30;
    max.s32 %r19, %r25, %r25;
    cvt.s64.s32 %rd14, %r27;
    xor.b32 %r21, %r10, %r15;
    shr.u32 %r26, %r25, 7;
    max.u64 %rd12, %rd5, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
