.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r6, %r3, %r3;
    shr.s32 %r20, %r3, 7;
    shr.u32 %r15, %r3, 0;
    mad.lo.u32 %r7, %r20, %r20, %r15;
    cvt.u64.u32 %rd11, %r15;
    mul.wide.s32 %rd12, %r20, %r7;
    max.u32 %r27, %r3, %r7;
    setp.le.u32 %p4, %r27, 256;
    @%p4 min.s32 %r11, %r20, 5;
    mul.lo.u64 %rd15, %rd12, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
