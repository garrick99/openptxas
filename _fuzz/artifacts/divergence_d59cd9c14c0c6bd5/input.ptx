.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r18, %r3, 32;
    add.s32 %r8, %r18, %r3;
    cvt.u64.u32 %rd13, %r3;
    and.b32 %r11, %r3, 256;
    shr.u32 %r17, %r11, 16;
    setp.le.s32 %p3, %r17, %r8;
    add.u32 %r22, %r18, 256;
    xor.b32 %r23, %r3, 255;
    or.b32 %r15, %r11, %r3;
    mul.wide.s32 %rd6, %r18, %r15;
    sub.u32 %r18, %r11, 0;
    setp.gt.s32 %p3, %r22, 7;
    @%p3 and.b32 %r19, %r22, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
