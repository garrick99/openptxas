.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r10, %r3, %r3;
    mul.lo.s32 %r10, %r3, %r10;
    max.s32 %r22, %r3, 2147483647;
    mul.wide.u32 %rd15, %r22, %r22;
    mul.lo.s32 %r25, %r10, 7;
    setp.le.u32 %p4, %r25, 5;
    setp.le.u32 %p4, %r3, %r10;
    @%p4 sub.s32 %r5, %r3, %r22;
    mul.lo.s32 %r23, %r3, %r25;
    xor.b32 %r12, %r10, %r3;
    cvt.u32.u64 %r19, %rd15;
    cvt.s32.s64 %r15, %rd15;
    max.s32 %r7, %r3, 31;
    shl.b64 %rd6, %rd15, 48;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
