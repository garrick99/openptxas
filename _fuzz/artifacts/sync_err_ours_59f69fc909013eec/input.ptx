.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r4, %r3, 255;
    setp.ne.s32 %p4, %r3, 256;
    setp.gt.s32 %p1, %r4, 256;
    @%p1 add.s32 %r22, %r4, 32;
    shl.b32 %r6, %r22, 30;
    add.s32 %r26, %r22, 4294967295;
    max.s32 %r4, %r22, 2;
    cvt.s64.s32 %rd9, %r3;
    add.u32 %r6, %r6, %r26;
    cvt.s64.s32 %rd14, %r22;
    setp.eq.s32 %p2, %r6, 2147483647;
    mad.lo.s32 %r27, %r22, %r3, %r6;
    shr.u32 %r24, %r4, 0;
    and.b32 %r9, %r22, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
