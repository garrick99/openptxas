.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd7, %r3, %r3;
    min.s32 %r25, %r3, %r3;
    mad.lo.u32 %r15, %r3, %r3, %r3;
    max.s32 %r18, %r15, 31;
    sub.u32 %r16, %r3, %r3;
    shr.u64 %rd11, %rd7, 31;
    setp.hi.u32 %p4, %r16, 65535;
    @%p4 mul.lo.u32 %r25, %r25, %r15;
    mad.lo.u32 %r23, %r3, %r18, %r25;
    shr.s64 %rd6, %rd11, 30;
    mul.wide.u32 %rd14, %r3, %r18;
    mad.lo.u32 %r7, %r16, %r18, %r23;
    add.s32 %r19, %r7, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
