.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r7, %r3, 1;
    xor.b32 %r20, %r3, %r7;
    or.b32 %r20, %r3, %r20;
    mad.lo.u32 %r17, %r20, %r3, %r7;
    cvt.u64.u32 %rd13, %r20;
    cvt.u64.u32 %rd10, %r20;
    setp.ge.u32 %p3, %r3, 256;
    sub.u64 %rd7, %rd10, %rd13;
    mul.wide.s32 %rd12, %r17, %r17;
    sub.s32 %r23, %r17, 2;
    shr.u32 %r13, %r7, 4;
    min.s32 %r14, %r13, 7;
    mul.wide.u32 %rd15, %r3, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
