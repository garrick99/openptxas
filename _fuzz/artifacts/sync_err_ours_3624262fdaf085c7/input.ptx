.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r9, %r3, 255;
    xor.b32 %r20, %r9, %r9;
    add.s32 %r27, %r9, 2147483648;
    cvt.s64.s32 %rd6, %r3;
    mul.lo.s32 %r17, %r3, %r27;
    shl.b32 %r26, %r3, 7;
    max.s32 %r12, %r3, %r26;
    add.s64 %rd5, %rd6, %rd6;
    mad.lo.s32 %r9, %r20, %r9, %r9;
    cvt.u32.u64 %r4, %rd6;
    setp.le.s32 %p4, %r4, %r3;
    shl.b64 %rd10, %rd6, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
