.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r23, %r3, 2147483648;
    setp.eq.s32 %p2, %r3, 15;
    @%p2 selp.b32 %r26, %r23, %r23, %p2;
    shr.u32 %r25, %r26, 3;
    max.s32 %r27, %r25, 31;
    setp.lt.s32 %p3, %r23, %r26;
    @%p3 cvt.u64.u32 %rd8, %r3;
    shr.u64 %rd8, %rd8, 32;
    or.b32 %r18, %r27, %r27;
    and.b32 %r20, %r23, %r27;
    min.u32 %r7, %r27, %r23;
    shr.u32 %r4, %r7, 16;
    add.u32 %r10, %r18, %r20;
    mad.lo.u32 %r7, %r27, %r26, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
