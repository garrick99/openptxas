.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r9, %r3, 31;
    cvt.u64.u32 %rd9, %r9;
    and.b64 %rd12, %rd9, %rd9;
    cvt.u32.u64 %r25, %rd9;
    and.b32 %r13, %r3, %r25;
    mad.lo.s32 %r25, %r3, %r3, %r25;
    min.u32 %r13, %r3, %r25;
    cvt.u32.u64 %r12, %rd9;
    mul.lo.u32 %r6, %r25, 31;
    min.u32 %r9, %r13, 5;
    cvt.s32.s64 %r21, %rd9;
    min.u32 %r22, %r9, %r25;
    max.s32 %r5, %r21, 8;
    min.s64 %rd15, %rd12, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
