.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p1, %r3, %r0;
    vote.sync.ballot.b32 %r19, %p1, -1;
    setp.ne.u32 %p1, %r3, %r0;
    vote.sync.ballot.b32 %r15, %p1, -1;
    shfl.sync.up.b32 %r12, %r0, 2, 0x1f, -1;
    setp.eq.u32 %p2, %r19, 1;
    vote.sync.ballot.b32 %r16, %p2, -1;
    or.b32 %r6, %r12, %r16;
    vote.sync.all.pred %p1, %p1, -1;
    add.u32 %r10, %r19, %r16;
    sub.u32 %r7, %r3, %r19;
    setp.le.u32 %p3, %r0, 4294967295;
    vote.sync.ballot.b32 %r9, %p3, -1;
    setp.eq.u32 %p2, %r16, 2;
    vote.sync.ballot.b32 %r16, %p2, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
