.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r22, %r3, %r3, %r3;
    cvt.u64.u32 %rd13, %r3;
    setp.ne.u32 %p1, %r3, %r3;
    max.s32 %r9, %r3, %r3;
    selp.b32 %r20, %r3, %r3, %p1;
    and.b32 %r14, %r20, %r9;
    add.s32 %r23, %r3, %r22;
    mul.lo.s32 %r12, %r22, %r23;
    add.s32 %r4, %r14, %r22;
    shr.s32 %r26, %r3, 15;
    xor.b32 %r26, %r9, 7;
    mul.wide.u32 %rd11, %r22, %r14;
    sub.u32 %r11, %r4, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
