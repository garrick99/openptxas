.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    cvt.u64.u32 %rd13, %r3;
    setp.ls.u32 %p1, %r3, 2147483647;
    @!%p1 mul.lo.u32 %r16, %r3, %r3;
    add.s32 %r11, %r3, %r3;
    sub.s64 %rd8, %rd13, %rd13;
    mul.wide.u32 %rd6, %r3, %r3;
    or.b32 %r23, %r16, %r11;
    mul.lo.u32 %r19, %r11, %r23;
    min.u64 %rd11, %rd13, %rd8;
    xor.b32 %r4, %r3, 4294967295;
    or.b32 %r9, %r16, %r16;
    mul.lo.u32 %r11, %r16, 16;
    add.u64 %rd15, %rd6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
