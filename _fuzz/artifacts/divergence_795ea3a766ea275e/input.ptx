.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r24, %r3, %r3;
    setp.ne.s32 %p2, %r3, 5;
    @!%p2 shl.b32 %r7, %r24, 0;
    setp.lt.u32 %p3, %r7, %r3;
    @!%p3 xor.b32 %r14, %r24, %r24;
    cvt.u64.u32 %rd13, %r24;
    mul.wide.s32 %rd8, %r14, %r7;
    selp.b32 %r17, %r24, %r14, %p2;
    xor.b64 %rd7, %rd13, %rd13;
    or.b32 %r13, %r14, 2;
    min.u32 %r14, %r13, 32;
    shl.b32 %r21, %r3, 16;
    and.b32 %r19, %r7, 1;
    mad.lo.s32 %r24, %r24, %r13, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
