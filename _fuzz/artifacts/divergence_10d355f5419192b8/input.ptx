.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p2, %r3, 16;
    setp.le.s32 %p3, %r3, %r3;
    @!%p3 add.u32 %r27, %r3, %r3;
    setp.le.u32 %p2, %r27, 32;
    @%p2 and.b32 %r14, %r3, 65535;
    selp.b32 %r8, %r14, %r3, %p3;
    cvt.s64.s32 %rd12, %r27;
    selp.b32 %r12, %r14, %r14, %p2;
    mul.lo.u32 %r26, %r14, 64;
    selp.b32 %r19, %r27, %r26, %p3;
    mul.lo.s32 %r27, %r27, %r19;
    mad.lo.u32 %r4, %r14, %r26, %r26;
    min.s64 %rd11, %rd12, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
