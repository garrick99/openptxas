.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    sub.u32 %r16, %r3, 63;
    mul.wide.u32 %rd15, %r3, %r16;
    mul.lo.s32 %r27, %r3, %r3;
    mul.lo.s32 %r14, %r16, %r16;
    max.s32 %r21, %r16, %r16;
    shr.u64 %rd14, %rd6, 4;
    cvt.u64.u32 %rd9, %r14;
    or.b32 %r7, %r27, %r21;
    max.s32 %r20, %r3, %r3;
    mad.lo.s32 %r22, %r7, %r14, %r16;
    shl.b32 %r7, %r7, 4;
    add.u32 %r13, %r27, 0;
    or.b32 %r16, %r20, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
