.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r12, %r3, %r3;
    max.u32 %r10, %r12, 8;
    cvt.s64.s32 %rd8, %r12;
    xor.b32 %r7, %r12, 2;
    cvt.u64.u32 %rd15, %r12;
    cvt.s64.s32 %rd5, %r12;
    or.b32 %r14, %r12, 8;
    min.u32 %r25, %r14, %r12;
    cvt.u32.u64 %r8, %rd8;
    and.b32 %r4, %r3, 65536;
    shr.u64 %rd10, %rd5, 47;
    mad.lo.u32 %r21, %r3, %r14, %r4;
    setp.ne.s32 %p4, %r8, %r12;
    @%p4 mul.lo.s32 %r5, %r14, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
