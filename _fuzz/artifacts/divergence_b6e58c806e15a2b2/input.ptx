.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r4, %r3, 256;
    cvt.s64.s32 %rd10, %r3;
    shl.b32 %r6, %r4, 7;
    max.s32 %r25, %r6, 64;
    cvt.s64.s32 %rd10, %r3;
    setp.le.s32 %p4, %r25, 255;
    and.b32 %r16, %r4, 7;
    setp.ls.u32 %p4, %r16, 15;
    and.b64 %rd9, %rd10, %rd10;
    add.s32 %r12, %r4, %r4;
    sub.u32 %r6, %r12, %r16;
    shl.b32 %r11, %r16, 1;
    selp.b32 %r27, %r12, %r4, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
