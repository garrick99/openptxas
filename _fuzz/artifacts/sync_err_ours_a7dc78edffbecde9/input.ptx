.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r11, %r3, 15;
    cvt.u64.u32 %rd11, %r11;
    sub.s32 %r10, %r3, 255;
    setp.lt.s32 %p3, %r3, %r3;
    @%p3 add.s32 %r19, %r11, 16;
    sub.u32 %r9, %r11, 2147483648;
    setp.gt.s32 %p3, %r11, 64;
    setp.ne.u32 %p1, %r9, %r10;
    cvt.s64.s32 %rd11, %r10;
    min.s32 %r25, %r9, 65536;
    add.s32 %r24, %r10, %r10;
    mul.wide.u32 %rd7, %r19, %r9;
    cvt.s32.s64 %r12, %rd7;
    cvt.s32.s64 %r21, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
