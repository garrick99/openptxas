.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    min.s32 %r11, %r3, 8;
    or.b64 %rd15, %rd12, %rd12;
    setp.le.u32 %p3, %r3, 65535;
    @%p3 max.s32 %r17, %r3, 3;
    setp.le.u32 %p1, %r17, 2147483648;
    @%p1 max.s32 %r23, %r11, 3;
    selp.b32 %r27, %r17, %r23, %p3;
    max.s32 %r19, %r27, 2147483647;
    shl.b64 %rd11, %rd12, 4;
    cvt.s32.s64 %r17, %rd11;
    cvt.u32.u64 %r12, %rd15;
    cvt.u64.u32 %rd11, %r27;
    and.b32 %r25, %r23, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
