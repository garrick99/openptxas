.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r23, %r3, 1;
    cvt.s64.s32 %rd12, %r3;
    mul.wide.u32 %rd10, %r23, %r23;
    cvt.u64.u32 %rd12, %r3;
    setp.eq.s32 %p2, %r3, 15;
    @%p2 min.u32 %r16, %r3, %r3;
    mad.lo.s32 %r20, %r23, %r23, %r3;
    cvt.u32.u64 %r24, %rd10;
    selp.b32 %r24, %r23, %r23, %p2;
    shr.s32 %r20, %r23, 2;
    mul.lo.s32 %r26, %r16, 64;
    mad.lo.u32 %r6, %r24, %r26, %r26;
    add.u64 %rd7, %rd12, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
