.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r25, %r3, 7;
    shr.u32 %r25, %r25, 1;
    mul.wide.u32 %rd11, %r3, %r3;
    max.u32 %r26, %r3, 16;
    mul.lo.u32 %r24, %r25, %r26;
    setp.gt.s32 %p2, %r25, %r26;
    @!%p2 add.s32 %r6, %r25, 64;
    mul.wide.s32 %rd12, %r25, %r6;
    max.s32 %r12, %r6, 7;
    selp.b32 %r8, %r6, %r26, %p2;
    shr.u32 %r18, %r24, 4;
    sub.s32 %r19, %r26, 3;
    sub.u64 %rd7, %rd12, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
