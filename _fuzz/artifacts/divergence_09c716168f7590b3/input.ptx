.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r6, %r3, %r3, %r3;
    min.u32 %r22, %r3, 7;
    shl.b32 %r23, %r3, 30;
    setp.gt.s32 %p2, %r22, 3;
    @%p2 cvt.u64.u32 %rd7, %r22;
    sub.u32 %r24, %r23, %r22;
    selp.b32 %r17, %r24, %r23, %p2;
    min.s32 %r20, %r3, %r24;
    mad.lo.s32 %r19, %r23, %r23, %r6;
    add.s32 %r23, %r20, 4;
    setp.eq.s32 %p4, %r17, 0;
    setp.eq.s32 %p3, %r22, %r20;
    @%p3 and.b32 %r18, %r22, %r20;
    cvt.u32.u64 %r15, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
