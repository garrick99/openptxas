.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    sub.s32 %r13, %r3, %r3;
    mul.lo.u32 %r26, %r13, %r3;
    max.u64 %rd8, %rd9, %rd9;
    cvt.s64.s32 %rd8, %r13;
    setp.ge.s32 %p4, %r13, 2;
    max.s32 %r23, %r13, %r3;
    mul.wide.s32 %rd12, %r13, %r26;
    selp.b32 %r20, %r3, %r3, %p4;
    sub.u32 %r26, %r20, %r13;
    mul.lo.u32 %r7, %r3, %r23;
    selp.b32 %r7, %r23, %r7, %p4;
    add.s64 %rd15, %rd8, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
