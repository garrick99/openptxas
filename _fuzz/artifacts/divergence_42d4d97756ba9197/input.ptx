.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p1, %r3, %r3;
    mad.lo.s32 %r25, %r3, %r3, %r3;
    cvt.u64.u32 %rd9, %r3;
    sub.s64 %rd10, %rd9, %rd9;
    sub.s32 %r16, %r25, %r25;
    setp.le.s32 %p2, %r3, 5;
    min.s32 %r10, %r16, %r25;
    cvt.s64.s32 %rd15, %r25;
    min.s32 %r14, %r25, %r3;
    or.b32 %r26, %r3, %r14;
    setp.gt.s32 %p2, %r25, 7;
    @%p2 sub.u32 %r17, %r25, 255;
    selp.b32 %r16, %r26, %r10, %p1;
    setp.gt.s32 %p1, %r17, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
