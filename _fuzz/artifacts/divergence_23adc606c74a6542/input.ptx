    bfe.s32 %r7, %r11, 7, 4;
    bfi.b32 %r22, %r8, %r3, 31, 2;
    bfi.b32 %r5, %r7, %r8, 0, 7;
    bfe.s32 %r15, %r5, 4, 31;
    max.u32 %r23, %r9, %r9;
