.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    shr.u32 %r25, %r3, 7;
    min.u32 %r15, %r25, 65535;
    shl.b64 %rd6, %rd10, 62;
    cvt.s32.s64 %r20, %rd6;
    min.u32 %r24, %r15, 255;
    mul.lo.u64 %rd13, %rd6, %rd10;
    mul.lo.s32 %r16, %r20, 8;
    setp.ls.u32 %p2, %r20, %r3;
    setp.gt.u32 %p4, %r20, %r15;
    @%p4 and.b64 %rd12, %rd10, %rd10;
    and.b64 %rd12, %rd6, %rd6;
    max.u32 %r13, %r3, 4294967295;
    shl.b64 %rd7, %rd10, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
