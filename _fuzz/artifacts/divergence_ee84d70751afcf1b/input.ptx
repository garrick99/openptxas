.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p2, %r3, 5;
    @%p2 or.b32 %r7, %r3, 65535;
    mul.wide.s32 %rd11, %r7, %r3;
    shl.b32 %r23, %r7, 15;
    add.s32 %r25, %r23, %r7;
    mul.wide.u32 %rd12, %r7, %r25;
    or.b32 %r5, %r25, %r25;
    max.u32 %r18, %r3, %r5;
    add.u32 %r8, %r3, %r25;
    mad.lo.u32 %r16, %r18, %r7, %r23;
    xor.b64 %rd6, %rd11, %rd11;
    shr.u32 %r6, %r25, 0;
    mad.lo.u32 %r19, %r23, %r3, %r8;
    shr.u32 %r27, %r7, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
