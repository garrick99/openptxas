.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    max.s32 %r27, %r3, 2147483647;
    min.u32 %r5, %r3, 2147483647;
    cvt.s32.s64 %r4, %rd11;
    or.b64 %rd5, %rd11, %rd11;
    sub.s32 %r7, %r4, 15;
    or.b32 %r21, %r7, 63;
    mul.wide.u32 %rd14, %r21, %r27;
    mul.wide.s32 %rd14, %r5, %r4;
    cvt.s64.s32 %rd10, %r3;
    cvt.s32.s64 %r26, %rd10;
    shr.s32 %r22, %r3, 7;
    cvt.s32.s64 %r24, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
