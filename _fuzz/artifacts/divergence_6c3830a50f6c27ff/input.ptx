.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    mul.lo.s32 %r11, %r3, %r3;
    cvt.s64.s32 %rd15, %r11;
    sub.s32 %r9, %r3, 7;
    sub.u32 %r9, %r11, 7;
    min.u32 %r18, %r11, 4;
    mul.lo.s32 %r25, %r18, 5;
    max.s64 %rd6, %rd15, %rd15;
    add.s32 %r9, %r18, 3;
    sub.s32 %r4, %r3, 0;
    mul.wide.s32 %rd6, %r11, %r18;
    cvt.s32.s64 %r23, %rd6;
    min.u32 %r21, %r11, %r25;
    and.b32 %r14, %r18, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
