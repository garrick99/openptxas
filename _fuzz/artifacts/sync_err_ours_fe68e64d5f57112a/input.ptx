.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r25, %r3, %r3, %r3;
    min.u32 %r8, %r3, %r3;
    cvt.u64.u32 %rd6, %r3;
    cvt.s64.s32 %rd6, %r3;
    xor.b32 %r7, %r3, %r25;
    mad.lo.u32 %r23, %r8, %r8, %r3;
    shl.b64 %rd12, %rd6, 48;
    add.s32 %r8, %r8, 0;
    min.u32 %r6, %r8, %r7;
    shr.u32 %r23, %r23, 4;
    shr.u64 %rd11, %rd12, 30;
    min.u64 %rd10, %rd6, %rd6;
    or.b32 %r4, %r25, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
