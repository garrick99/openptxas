.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r25, %r3, %r3, %r3;
    mul.wide.u32 %rd14, %r3, %r3;
    sub.u64 %rd8, %rd14, %rd14;
    shr.s32 %r24, %r25, 15;
    sub.u32 %r9, %r24, 5;
    shl.b32 %r15, %r3, 15;
    xor.b32 %r5, %r24, 4294967295;
    shr.u32 %r27, %r24, 2;
    or.b32 %r10, %r3, %r24;
    shr.u32 %r14, %r24, 15;
    mad.lo.u32 %r12, %r10, %r5, %r10;
    add.s32 %r17, %r14, %r14;
    shr.s32 %r21, %r15, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
