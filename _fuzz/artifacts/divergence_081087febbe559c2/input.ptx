.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r25, %r3, 8;
    add.u32 %r4, %r25, 4;
    setp.hi.u32 %p1, %r25, 255;
    @%p1 shl.b32 %r11, %r4, 1;
    setp.lo.u32 %p4, %r4, 8;
    @%p4 sub.u32 %r6, %r3, 5;
    mul.wide.u32 %rd9, %r4, %r4;
    xor.b32 %r22, %r4, %r25;
    mul.lo.s32 %r27, %r6, %r25;
    mul.wide.s32 %rd7, %r3, %r4;
    setp.ls.u32 %p1, %r4, %r25;
    @!%p1 shr.s64 %rd10, %rd9, 16;
    sub.u64 %rd8, %rd10, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
