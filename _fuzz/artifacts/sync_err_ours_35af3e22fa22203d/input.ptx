.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r22, %r3, 31;
    max.u32 %r21, %r22, 64;
    mul.lo.s32 %r14, %r3, 255;
    mul.lo.s32 %r11, %r3, %r21;
    cvt.s64.s32 %rd6, %r11;
    mul.wide.u32 %rd10, %r21, %r21;
    sub.s32 %r10, %r3, %r3;
    add.u32 %r20, %r22, 32;
    max.u64 %rd6, %rd6, %rd6;
    sub.s32 %r19, %r3, %r14;
    sub.s64 %rd13, %rd6, %rd10;
    cvt.u64.u32 %rd15, %r3;
    shl.b64 %rd14, %rd15, 47;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
