.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    max.s32 %r12, %r3, 2;
    cvt.s32.s64 %r10, %rd13;
    mul.wide.s32 %rd9, %r10, %r3;
    sub.s32 %r24, %r3, %r12;
    setp.lt.s32 %p2, %r24, 31;
    @%p2 add.u32 %r8, %r12, %r10;
    mul.lo.s32 %r15, %r24, %r3;
    shl.b64 %rd14, %rd9, 63;
    cvt.u64.u32 %rd14, %r3;
    shr.u64 %rd9, %rd13, 2;
    setp.ne.u32 %p4, %r12, 2147483648;
    @!%p4 cvt.u32.u64 %r6, %rd13;
    xor.b32 %r24, %r8, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
