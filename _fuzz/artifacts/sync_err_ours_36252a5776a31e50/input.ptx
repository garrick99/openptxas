.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r26, %r3, 256;
    shl.b32 %r24, %r3, 31;
    shl.b32 %r4, %r24, 1;
    cvt.s64.s32 %rd11, %r24;
    shr.u32 %r14, %r26, 3;
    mul.wide.u32 %rd14, %r26, %r24;
    mad.lo.s32 %r24, %r4, %r4, %r26;
    shl.b64 %rd6, %rd11, 15;
    shr.s32 %r26, %r14, 4;
    and.b32 %r8, %r4, 1;
    shr.u32 %r26, %r4, 7;
    shr.u32 %r8, %r3, 30;
    add.s32 %r18, %r14, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
