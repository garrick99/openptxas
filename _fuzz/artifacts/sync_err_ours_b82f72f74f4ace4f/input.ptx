.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    cvt.s32.s64 %r27, %rd15;
    and.b32 %r22, %r3, %r3;
    shr.u32 %r23, %r3, 31;
    shr.u32 %r26, %r23, 1;
    max.s32 %r11, %r26, 64;
    xor.b64 %rd13, %rd15, %rd15;
    shr.s32 %r21, %r11, 4;
    cvt.u32.u64 %r26, %rd13;
    max.u32 %r7, %r11, 4294967295;
    cvt.s64.s32 %rd15, %r7;
    mul.lo.s32 %r11, %r11, 63;
    sub.s32 %r27, %r7, %r11;
    shl.b64 %rd13, %rd15, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
