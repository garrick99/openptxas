.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r25, %r3, %r3;
    add.s32 %r6, %r3, %r3;
    cvt.u64.u32 %rd8, %r25;
    or.b64 %rd13, %rd8, %rd8;
    cvt.s32.s64 %r13, %rd8;
    or.b32 %r6, %r25, 16;
    cvt.s32.s64 %r27, %rd8;
    mul.lo.u32 %r9, %r3, 4;
    cvt.u64.u32 %rd9, %r9;
    setp.eq.s32 %p4, %r13, 16;
    @%p4 shr.s32 %r20, %r9, 0;
    and.b32 %r5, %r25, 0;
    mul.lo.u32 %r19, %r27, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
