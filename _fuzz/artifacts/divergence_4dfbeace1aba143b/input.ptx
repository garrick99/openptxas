.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r22, %r3, 16;
    min.s32 %r13, %r3, 7;
    cvt.s64.s32 %rd6, %r3;
    min.u32 %r20, %r13, %r3;
    sub.u32 %r25, %r22, 3;
    mul.wide.u32 %rd14, %r22, %r25;
    shr.s64 %rd14, %rd6, 4;
    min.u32 %r13, %r3, %r13;
    cvt.s32.s64 %r14, %rd6;
    and.b32 %r27, %r25, 8;
    cvt.s32.s64 %r17, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
