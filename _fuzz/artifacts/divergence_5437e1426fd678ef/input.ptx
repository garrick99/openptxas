.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r13, %r3, %r3;
    or.b32 %r26, %r13, 8;
    setp.lt.s32 %p1, %r13, %r26;
    @%p1 mad.lo.u32 %r15, %r3, %r26, %r13;
    xor.b32 %r18, %r3, %r3;
    cvt.s64.s32 %rd9, %r18;
    xor.b64 %rd12, %rd9, %rd9;
    max.u32 %r11, %r13, 16;
    min.u32 %r21, %r15, %r3;
    cvt.s32.s64 %r15, %rd12;
    selp.b32 %r5, %r21, %r13, %p1;
    mul.lo.s64 %rd14, %rd9, %rd12;
    selp.b32 %r22, %r13, %r18, %p1;
    add.u32 %r24, %r21, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
