.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r17, %r3, 3;
    shr.s32 %r16, %r17, 2;
    max.s32 %r19, %r16, %r3;
    mad.lo.s32 %r21, %r16, %r16, %r16;
    max.u32 %r10, %r16, 31;
    sub.s32 %r14, %r21, 31;
    mul.wide.u32 %rd8, %r17, %r21;
    max.s64 %rd11, %rd8, %rd8;
    setp.hi.u32 %p4, %r21, %r21;
    @%p4 mul.wide.u32 %rd8, %r14, %r16;
    mul.wide.s32 %rd8, %r14, %r3;
    cvt.u64.u32 %rd9, %r17;
    max.s32 %r9, %r14, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
