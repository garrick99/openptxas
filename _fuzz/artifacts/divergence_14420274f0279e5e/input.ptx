.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r21, %r3, 255;
    cvt.u64.u32 %rd7, %r21;
    add.s64 %rd9, %rd7, %rd7;
    shr.s32 %r26, %r21, 7;
    min.s64 %rd15, %rd9, %rd9;
    setp.hi.u32 %p4, %r21, 15;
    setp.ne.u32 %p2, %r21, 5;
    @!%p2 max.s32 %r25, %r21, %r21;
    min.u32 %r23, %r25, %r26;
    shl.b64 %rd13, %rd9, 48;
    selp.b32 %r18, %r23, %r21, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
