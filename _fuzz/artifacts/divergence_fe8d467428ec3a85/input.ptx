.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p1, %r3, 2147483647;
    cvt.u64.u32 %rd11, %r3;
    xor.b32 %r21, %r3, %r3;
    and.b32 %r10, %r3, 16;
    mul.wide.u32 %rd13, %r10, %r10;
    shr.u32 %r9, %r10, 15;
    shr.u64 %rd7, %rd13, 16;
    setp.ge.s32 %p4, %r10, 31;
    @!%p4 xor.b32 %r6, %r9, %r3;
    cvt.u64.u32 %rd14, %r21;
    add.s32 %r15, %r10, 7;
    mul.wide.s32 %rd13, %r3, %r9;
    max.s64 %rd8, %rd7, %rd14;
    add.u32 %r13, %r6, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
