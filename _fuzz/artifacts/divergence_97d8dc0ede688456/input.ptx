.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r26, %r3, 5;
    cvt.u64.u32 %rd10, %r26;
    mul.wide.u32 %rd8, %r3, %r26;
    setp.gt.s32 %p2, %r26, 64;
    @%p2 cvt.s32.s64 %r25, %rd10;
    shl.b32 %r11, %r25, 1;
    shr.u32 %r10, %r26, 4;
    mad.lo.s32 %r17, %r11, %r11, %r26;
    xor.b32 %r18, %r3, 32;
    min.u64 %rd7, %rd10, %rd10;
    or.b32 %r21, %r17, 65536;
    xor.b32 %r21, %r11, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
