.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r20, %r3, 0;
    mul.wide.u32 %rd8, %r3, %r20;
    shr.s64 %rd11, %rd8, 30;
    min.u32 %r16, %r3, %r3;
    mul.lo.s32 %r17, %r20, 16;
    shl.b64 %rd12, %rd11, 16;
    shr.s32 %r23, %r3, 1;
    min.u32 %r22, %r3, 31;
    mad.lo.u32 %r8, %r22, %r16, %r16;
    mad.lo.s32 %r17, %r22, %r16, %r3;
    max.u32 %r6, %r16, 7;
    mul.wide.s32 %rd5, %r20, %r6;
    mul.lo.s32 %r24, %r8, %r8;
    xor.b32 %r16, %r20, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
