.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    add.u32 %r6, %r3, 7;
    setp.gt.s32 %p3, %r6, 31;
    @%p3 shr.u32 %r21, %r6, 0;
    shl.b32 %r22, %r21, 16;
    or.b64 %rd13, %rd15, %rd15;
    mul.lo.u32 %r25, %r21, %r21;
    cvt.s64.s32 %rd10, %r22;
    mad.lo.u32 %r6, %r21, %r6, %r25;
    cvt.u32.u64 %r15, %rd13;
    sub.s32 %r17, %r25, %r22;
    add.u64 %rd14, %rd10, %rd10;
    sub.s32 %r15, %r6, %r17;
    sub.s32 %r4, %r25, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
