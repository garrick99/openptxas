    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p4, %r3, 63;
    @!%p4 sub.u32 %r5, %r3, %r3;
    setp.eq.s32 %p2, %r5, %r5;
    @!%p2 max.u32 %r25, %r3, %r3;
