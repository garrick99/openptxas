.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd9, %r3, %r3;
    shr.s32 %r27, %r3, 30;
    shr.u32 %r27, %r27, 30;
    and.b32 %r13, %r27, %r27;
    sub.u32 %r10, %r13, 65536;
    xor.b32 %r9, %r10, 32;
    cvt.s32.s64 %r12, %rd9;
    setp.ge.u32 %p3, %r3, %r10;
    shr.u32 %r11, %r13, 2;
    cvt.u64.u32 %rd14, %r9;
    shl.b32 %r25, %r10, 30;
    mad.lo.s32 %r18, %r27, %r12, %r3;
    max.s32 %r23, %r25, %r13;
    max.u32 %r8, %r11, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
