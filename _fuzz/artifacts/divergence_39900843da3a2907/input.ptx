.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p3, %r3, %r3;
    @!%p3 cvt.u64.u32 %rd10, %r3;
    cvt.u32.u64 %r5, %rd10;
    sub.u32 %r21, %r3, %r5;
    max.s32 %r23, %r3, %r3;
    shl.b32 %r9, %r5, 0;
    shr.u64 %rd14, %rd10, 4;
    setp.ge.s32 %p4, %r21, 65535;
    setp.ge.s32 %p3, %r3, %r3;
    @!%p3 selp.b32 %r17, %r9, %r21, %p3;
    and.b32 %r25, %r23, %r3;
    shr.u32 %r11, %r9, 30;
    cvt.s64.s32 %rd6, %r5;
    mul.wide.s32 %rd13, %r25, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
