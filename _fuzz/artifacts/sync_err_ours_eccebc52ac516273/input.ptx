.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd5, %r3, %r3;
    add.u32 %r19, %r3, %r3;
    mul.lo.s32 %r27, %r19, %r19;
    shr.s64 %rd6, %rd5, 7;
    xor.b32 %r20, %r27, %r3;
    cvt.s64.s32 %rd13, %r3;
    sub.s32 %r10, %r3, 0;
    min.s64 %rd12, %rd6, %rd13;
    cvt.u32.u64 %r19, %rd13;
    setp.ls.u32 %p3, %r3, 63;
    setp.le.s32 %p1, %r10, 16;
    mad.lo.u32 %r25, %r27, %r10, %r10;
    cvt.s64.s32 %rd15, %r10;
    add.s32 %r27, %r25, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
