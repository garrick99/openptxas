.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    add.s32 %r6, %r3, 31;
    cvt.u64.u32 %rd8, %r6;
    cvt.u32.u64 %r27, %rd15;
    sub.s32 %r22, %r3, 2147483647;
    add.u64 %rd10, %rd15, %rd8;
    min.u32 %r15, %r27, 7;
    mul.lo.s32 %r13, %r3, %r22;
    setp.lt.s32 %p4, %r3, 3;
    @%p4 xor.b32 %r25, %r27, 31;
    max.u32 %r6, %r25, %r15;
    or.b32 %r12, %r15, %r13;
    setp.le.s32 %p2, %r6, %r3;
    @%p2 sub.u32 %r9, %r15, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
