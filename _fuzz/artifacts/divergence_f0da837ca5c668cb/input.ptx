    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r21, %r3, 5;
    cvt.u64.u32 %rd8, %r3;
    max.u32 %r19, %r21, 15;
    cvt.s32.s64 %r18, %rd8;
    max.u32 %r23, %r21, 2147483648;
    max.u32 %r21, %r21, 63;
    min.s32 %r27, %r21, 8;
