.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    cvt.s32.s64 %r15, %rd11;
    shr.s32 %r16, %r3, 1;
    mul.wide.u32 %rd5, %r3, %r15;
    mul.wide.s32 %rd8, %r16, %r3;
    add.s32 %r27, %r3, %r15;
    mad.lo.u32 %r25, %r16, %r15, %r16;
    xor.b32 %r14, %r25, %r27;
    shr.s32 %r25, %r16, 2;
    sub.s32 %r10, %r14, 3;
    shr.s32 %r9, %r27, 4;
    min.s32 %r8, %r25, 7;
    add.s32 %r22, %r3, %r15;
    shl.b64 %rd8, %rd11, 33;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
