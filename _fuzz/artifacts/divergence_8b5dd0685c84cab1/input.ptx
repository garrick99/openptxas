.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r26, %r3, %r3, %r3;
    mul.wide.s32 %rd11, %r3, %r3;
    xor.b32 %r14, %r3, %r3;
    cvt.u32.u64 %r24, %rd11;
    mul.lo.s32 %r17, %r3, 8;
    setp.eq.s32 %p1, %r24, %r17;
    @%p1 mad.lo.s32 %r13, %r3, %r24, %r3;
    xor.b32 %r16, %r26, %r3;
    selp.b32 %r4, %r13, %r16, %p1;
    mul.wide.s32 %rd5, %r16, %r26;
    sub.u32 %r12, %r16, %r26;
    setp.ls.u32 %p3, %r26, 64;
    @%p3 or.b32 %r5, %r16, %r13;
    setp.le.u32 %p2, %r13, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
