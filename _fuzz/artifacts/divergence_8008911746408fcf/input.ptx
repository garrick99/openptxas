.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r24, %r3, 31;
    shl.b32 %r6, %r3, 15;
    or.b32 %r10, %r6, 63;
    mad.lo.u32 %r13, %r24, %r3, %r10;
    cvt.s64.s32 %rd15, %r13;
    setp.lt.u32 %p2, %r10, %r13;
    @!%p2 cvt.s32.s64 %r20, %rd15;
    cvt.s32.s64 %r24, %rd15;
    mul.lo.s64 %rd8, %rd15, %rd15;
    mad.lo.u32 %r10, %r6, %r3, %r10;
    add.u32 %r11, %r3, 255;
    min.s32 %r18, %r10, %r11;
    add.u32 %r22, %r13, %r11;
    selp.b32 %r9, %r18, %r22, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
