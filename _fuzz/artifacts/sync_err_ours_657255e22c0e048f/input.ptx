.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r16, %r3, %r3;
    cvt.s64.s32 %rd5, %r3;
    mul.lo.s32 %r15, %r3, 256;
    mul.wide.s32 %rd6, %r3, %r16;
    shr.s64 %rd14, %rd6, 4;
    shr.s64 %rd12, %rd5, 63;
    mul.lo.u32 %r23, %r15, %r3;
    max.s64 %rd5, %rd6, %rd6;
    cvt.s32.s64 %r6, %rd6;
    mul.wide.s32 %rd11, %r23, %r16;
    shr.u32 %r27, %r16, 1;
    shr.s32 %r10, %r23, 15;
    mul.wide.s32 %rd7, %r15, %r6;
    add.s32 %r26, %r3, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
