.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r21, %r3, %r3;
    mad.lo.u32 %r27, %r3, %r3, %r3;
    cvt.s64.s32 %rd5, %r27;
    or.b64 %rd7, %rd5, %rd5;
    and.b32 %r4, %r21, 64;
    mul.wide.s32 %rd10, %r3, %r3;
    shr.u64 %rd7, %rd7, 63;
    setp.gt.s32 %p2, %r4, 64;
    and.b64 %rd10, %rd10, %rd5;
    min.s32 %r18, %r3, 32;
    cvt.s32.s64 %r14, %rd10;
    or.b64 %rd11, %rd5, %rd10;
    setp.hi.u32 %p1, %r18, 2;
    @!%p1 mul.lo.u64 %rd14, %rd10, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
