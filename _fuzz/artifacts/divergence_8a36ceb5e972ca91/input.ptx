.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r10, %r3, %r3;
    mul.wide.s32 %rd15, %r10, %r3;
    setp.ls.u32 %p1, %r10, %r3;
    @%p1 shl.b32 %r17, %r10, 16;
    sub.s64 %rd14, %rd15, %rd15;
    cvt.u64.u32 %rd10, %r10;
    min.s32 %r15, %r17, 5;
    mul.lo.u64 %rd11, %rd10, %rd14;
    add.s32 %r20, %r17, %r10;
    or.b32 %r12, %r17, 0;
    add.s32 %r13, %r12, %r17;
    and.b64 %rd7, %rd10, %rd14;
    setp.gt.s32 %p4, %r12, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
