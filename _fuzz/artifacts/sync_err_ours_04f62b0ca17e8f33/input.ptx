.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r26, %r3, %r3;
    min.u32 %r24, %r26, 256;
    cvt.s64.s32 %rd14, %r26;
    shr.s32 %r17, %r3, 31;
    sub.u32 %r23, %r17, 5;
    cvt.u32.u64 %r6, %rd14;
    shl.b32 %r19, %r23, 30;
    max.u32 %r5, %r19, %r26;
    mul.lo.s32 %r9, %r6, %r24;
    xor.b32 %r20, %r24, 65535;
    shl.b32 %r22, %r20, 1;
    or.b64 %rd11, %rd14, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
