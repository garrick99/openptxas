.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    add.u32 %r19, %r3, %r3;
    mul.lo.u32 %r24, %r3, 65535;
    mul.wide.u32 %rd10, %r3, %r3;
    setp.ge.s32 %p3, %r24, %r19;
    @%p3 add.s32 %r23, %r19, 15;
    xor.b32 %r14, %r3, 255;
    add.s32 %r15, %r23, 255;
    min.s32 %r22, %r15, %r3;
    add.s32 %r22, %r19, %r3;
    mul.wide.u32 %rd13, %r14, %r22;
    sub.u32 %r25, %r15, %r22;
    mad.lo.u32 %r22, %r23, %r24, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
