.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r17, %r3, %r3;
    setp.lt.s32 %p3, %r3, 31;
    @%p3 shl.b32 %r18, %r3, 2;
    mul.lo.u32 %r13, %r3, %r18;
    add.u32 %r5, %r17, %r3;
    max.u32 %r8, %r13, %r5;
    add.s32 %r12, %r8, 2;
    add.u32 %r5, %r13, 16;
    cvt.u64.u32 %rd13, %r12;
    add.u64 %rd12, %rd13, %rd13;
    max.s64 %rd11, %rd13, %rd12;
    add.u32 %r4, %r13, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
