.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    mul.lo.s32 %r7, %r3, 256;
    mul.lo.s32 %r26, %r3, %r7;
    min.u64 %rd10, %rd9, %rd9;
    shr.s32 %r6, %r26, 31;
    and.b64 %rd11, %rd9, %rd10;
    shl.b64 %rd8, %rd11, 2;
    mul.lo.u32 %r9, %r26, 2;
    add.u32 %r13, %r3, 4294967295;
    add.u32 %r24, %r3, 15;
    min.u32 %r18, %r7, %r6;
    add.s32 %r13, %r24, %r6;
    sub.u32 %r16, %r18, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
