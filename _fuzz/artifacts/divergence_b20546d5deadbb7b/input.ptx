.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    mul.lo.s32 %r8, %r3, 16;
    cvt.s32.s64 %r15, %rd14;
    min.u32 %r26, %r8, 255;
    mul.wide.u32 %rd14, %r3, %r15;
    setp.hs.u32 %p1, %r15, 65535;
    mul.lo.u32 %r5, %r26, %r8;
    sub.s32 %r6, %r5, %r3;
    setp.eq.s32 %p2, %r8, %r3;
    @%p2 shr.s32 %r22, %r5, 3;
    mul.wide.u32 %rd10, %r8, %r3;
    add.u32 %r6, %r5, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
