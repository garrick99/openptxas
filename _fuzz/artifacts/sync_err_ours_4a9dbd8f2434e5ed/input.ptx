.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    sub.u32 %r4, %r3, %r3;
    cvt.s32.s64 %r21, %rd8;
    cvt.u32.u64 %r9, %rd8;
    cvt.u32.u64 %r27, %rd8;
    cvt.u32.u64 %r7, %rd8;
    or.b64 %rd14, %rd8, %rd8;
    shr.s32 %r10, %r27, 30;
    add.u32 %r20, %r9, %r10;
    xor.b32 %r7, %r3, %r3;
    shl.b64 %rd15, %rd14, 7;
    shr.u32 %r15, %r21, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
