.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r16, %r3, %r3, %r3;
    and.b32 %r14, %r3, %r3;
    cvt.u64.u32 %rd15, %r3;
    or.b64 %rd15, %rd15, %rd15;
    mul.lo.s64 %rd7, %rd15, %rd15;
    and.b32 %r24, %r16, %r14;
    and.b32 %r14, %r14, 2;
    mul.wide.u32 %rd11, %r14, %r3;
    mad.lo.u32 %r11, %r14, %r3, %r24;
    shr.u64 %rd14, %rd11, 16;
    shr.u32 %r9, %r14, 7;
    cvt.s64.s32 %rd15, %r24;
    mad.lo.u32 %r11, %r14, %r16, %r3;
    max.u32 %r19, %r9, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
