.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r27, %r3, 4294967295;
    shl.b32 %r12, %r3, 4;
    add.s32 %r10, %r12, 16;
    min.u32 %r6, %r27, %r12;
    mul.lo.s32 %r12, %r27, %r12;
    shr.s32 %r11, %r12, 4;
    xor.b32 %r22, %r27, 5;
    max.u32 %r16, %r12, %r3;
    shl.b32 %r27, %r22, 0;
    cvt.u64.u32 %rd11, %r27;
    mad.lo.u32 %r24, %r3, %r10, %r3;
    min.u32 %r24, %r11, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
