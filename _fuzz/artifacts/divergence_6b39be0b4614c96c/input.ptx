.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r23, %r3, %r3;
    cvt.s64.s32 %rd10, %r23;
    shr.u64 %rd12, %rd10, 32;
    shr.s32 %r27, %r23, 15;
    and.b32 %r16, %r27, 255;
    sub.u32 %r12, %r27, %r16;
    setp.ne.s32 %p2, %r23, %r23;
    @%p2 min.s32 %r23, %r27, %r27;
    max.s32 %r16, %r16, 7;
    add.s32 %r13, %r3, %r12;
    setp.ge.s32 %p1, %r3, 31;
    @%p1 mul.wide.s32 %rd12, %r23, %r27;
    cvt.s64.s32 %rd9, %r13;
    max.u32 %r10, %r16, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
