.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r26, %r3, 16;
    add.u32 %r18, %r26, 65535;
    shl.b32 %r24, %r3, 2;
    cvt.u64.u32 %rd13, %r3;
    mul.wide.s32 %rd14, %r18, %r24;
    setp.gt.s32 %p1, %r24, 65536;
    setp.hi.u32 %p3, %r24, %r26;
    setp.le.s32 %p1, %r26, %r3;
    xor.b64 %rd6, %rd13, %rd13;
    mul.lo.s32 %r15, %r26, 3;
    shr.s32 %r18, %r18, 7;
    sub.s32 %r26, %r24, 0;
    mad.lo.u32 %r8, %r3, %r15, %r26;
    sub.s64 %rd12, %rd6, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
