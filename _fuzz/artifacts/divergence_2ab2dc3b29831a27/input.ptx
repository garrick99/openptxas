.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    add.u32 %r13, %r3, 16;
    setp.gt.s32 %p1, %r3, 255;
    @%p1 mad.lo.u32 %r15, %r13, %r13, %r3;
    max.s32 %r27, %r3, %r15;
    mul.lo.u32 %r18, %r13, %r3;
    max.u32 %r11, %r15, %r15;
    mad.lo.s32 %r26, %r27, %r11, %r11;
    mad.lo.s32 %r16, %r13, %r18, %r3;
    max.s32 %r7, %r13, 65535;
    setp.gt.u32 %p1, %r26, 4;
    @!%p1 mul.lo.u64 %rd6, %rd8, %rd8;
    add.s32 %r22, %r11, 64;
    mul.lo.u64 %rd14, %rd8, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
