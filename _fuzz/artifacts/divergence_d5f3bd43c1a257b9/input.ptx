.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r27, %r3, 2147483648;
    and.b32 %r10, %r27, 65536;
    mul.lo.u32 %r20, %r27, %r10;
    mad.lo.s32 %r19, %r3, %r20, %r10;
    mul.lo.s32 %r11, %r20, 8;
    or.b32 %r25, %r27, 16;
    mad.lo.s32 %r22, %r20, %r19, %r25;
    shr.u32 %r13, %r25, 2;
    cvt.u64.u32 %rd5, %r13;
    min.u32 %r24, %r25, 63;
    mul.wide.u32 %rd6, %r25, %r22;
    mad.lo.u32 %r22, %r3, %r11, %r25;
    add.s32 %r7, %r20, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
