.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd5, %r3, %r3;
    shr.u64 %rd11, %rd5, 1;
    min.u32 %r17, %r3, 31;
    mul.wide.u32 %rd12, %r17, %r17;
    and.b32 %r14, %r3, %r3;
    and.b64 %rd6, %rd12, %rd5;
    mul.lo.u32 %r6, %r3, 4;
    cvt.u64.u32 %rd14, %r14;
    mad.lo.u32 %r18, %r14, %r17, %r6;
    add.u32 %r4, %r18, %r18;
    cvt.u64.u32 %rd8, %r17;
    shr.s64 %rd13, %rd14, 3;
    setp.le.u32 %p3, %r3, 65536;
    mad.lo.u32 %r18, %r18, %r18, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
