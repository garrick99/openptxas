.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    setp.le.s32 %p2, %r3, 5;
    @%p2 mul.lo.u32 %r11, %r3, %r3;
    shr.s32 %r12, %r11, 31;
    shr.u32 %r24, %r11, 0;
    add.s32 %r15, %r3, %r24;
    or.b64 %rd10, %rd10, %rd10;
    and.b32 %r13, %r12, %r24;
    add.u32 %r17, %r12, 16;
    setp.ls.u32 %p4, %r15, 16;
    sub.s32 %r21, %r11, 4;
    sub.u32 %r9, %r21, 2;
    mul.wide.u32 %rd10, %r11, %r24;
    mad.lo.u32 %r18, %r21, %r17, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
