.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r7, %r3, %r3;
    mul.lo.u32 %r7, %r7, 65536;
    and.b32 %r10, %r7, 2147483647;
    min.u32 %r20, %r10, 7;
    mul.lo.s32 %r6, %r20, %r3;
    setp.lo.u32 %p4, %r10, 7;
    @%p4 sub.u32 %r4, %r6, 256;
    mul.wide.u32 %rd7, %r7, %r3;
    selp.b32 %r7, %r20, %r10, %p4;
    mul.lo.s64 %rd13, %rd7, %rd7;
    mad.lo.s32 %r17, %r3, %r3, %r20;
    xor.b32 %r25, %r3, %r3;
    max.s32 %r15, %r25, %r4;
    shr.s64 %rd11, %rd7, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
