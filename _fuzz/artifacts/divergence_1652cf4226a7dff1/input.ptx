.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r21, %r3, %r3;
    cvt.u64.u32 %rd11, %r21;
    mul.lo.u32 %r21, %r21, %r21;
    min.s32 %r25, %r3, %r21;
    shr.u32 %r5, %r3, 1;
    shr.u32 %r15, %r25, 1;
    and.b32 %r21, %r25, %r15;
    shr.s32 %r27, %r3, 7;
    mul.wide.s32 %rd9, %r25, %r3;
    shl.b32 %r14, %r21, 31;
    add.u32 %r17, %r15, 256;
    shr.s32 %r6, %r14, 3;
    mad.lo.s32 %r22, %r21, %r21, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
