.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    cvt.s32.s64 %r22, %rd8;
    setp.eq.u32 %p3, %r3, %r3;
    sub.s64 %rd6, %rd8, %rd8;
    shr.s32 %r21, %r22, 7;
    shr.u32 %r6, %r21, 15;
    shr.s64 %rd7, %rd6, 33;
    cvt.u64.u32 %rd15, %r6;
    add.s64 %rd10, %rd7, %rd8;
    max.u32 %r21, %r21, 4;
    selp.b32 %r21, %r6, %r21, %p3;
    mul.lo.u32 %r6, %r6, 256;
    max.u32 %r27, %r6, %r3;
    cvt.s32.s64 %r21, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
