.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r20, %r3, %r3, %r3;
    setp.ls.u32 %p2, %r3, %r20;
    @%p2 sub.s32 %r7, %r3, 65536;
    sub.u32 %r23, %r7, %r3;
    sub.s32 %r22, %r3, %r7;
    sub.s32 %r23, %r22, %r20;
    or.b32 %r15, %r7, 3;
    mul.wide.u32 %rd8, %r22, %r7;
    add.s64 %rd8, %rd8, %rd8;
    setp.ge.s32 %p1, %r22, %r20;
    @%p1 max.u32 %r14, %r15, 8;
    shr.u32 %r5, %r15, 16;
    mul.wide.u32 %rd13, %r3, %r7;
    or.b32 %r9, %r7, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
