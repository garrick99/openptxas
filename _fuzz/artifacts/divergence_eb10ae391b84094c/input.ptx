.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r23, %r3, %r3;
    max.u32 %r13, %r23, 65536;
    mad.lo.u32 %r24, %r3, %r3, %r23;
    add.u32 %r24, %r3, %r23;
    cvt.s64.s32 %rd15, %r23;
    cvt.u32.u64 %r9, %rd15;
    add.s32 %r6, %r13, 1;
    or.b32 %r16, %r13, 255;
    min.s32 %r10, %r9, %r24;
    mul.lo.u32 %r20, %r16, %r23;
    shr.u64 %rd13, %rd15, 7;
    shr.u32 %r17, %r23, 4;
    and.b32 %r7, %r13, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
