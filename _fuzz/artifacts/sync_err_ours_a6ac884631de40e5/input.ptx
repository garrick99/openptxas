.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r8, %r3, %r3;
    cvt.s64.s32 %rd13, %r8;
    mul.lo.u32 %r19, %r8, %r3;
    shl.b64 %rd15, %rd13, 48;
    mad.lo.s32 %r8, %r3, %r19, %r19;
    min.s64 %rd7, %rd15, %rd15;
    shr.s32 %r22, %r19, 16;
    shl.b32 %r16, %r3, 16;
    and.b32 %r12, %r8, %r8;
    sub.u32 %r20, %r19, %r3;
    shl.b32 %r22, %r19, 30;
    max.s32 %r4, %r3, 16;
    mul.lo.u32 %r24, %r3, %r4;
    or.b32 %r20, %r4, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
