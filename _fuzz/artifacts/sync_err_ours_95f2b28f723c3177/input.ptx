.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r13, %r3, %r3;
    sub.s32 %r12, %r13, 4294967295;
    cvt.s64.s32 %rd14, %r13;
    sub.s32 %r20, %r12, 4294967295;
    mad.lo.u32 %r17, %r13, %r12, %r13;
    setp.le.s32 %p1, %r20, 65536;
    shr.u32 %r4, %r13, 3;
    sub.s32 %r23, %r3, %r3;
    shr.u32 %r20, %r23, 30;
    min.s32 %r27, %r4, %r23;
    min.u32 %r26, %r17, %r4;
    max.u32 %r6, %r17, 31;
    shr.u32 %r15, %r27, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
