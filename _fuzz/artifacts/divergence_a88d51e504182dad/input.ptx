.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r16, %r3, 31;
    min.s32 %r4, %r16, 31;
    mad.lo.s32 %r26, %r4, %r3, %r3;
    xor.b32 %r21, %r26, %r16;
    shr.s32 %r19, %r21, 0;
    cvt.s64.s32 %rd10, %r4;
    shr.u32 %r5, %r26, 3;
    sub.s32 %r10, %r3, 4294967295;
    setp.lt.u32 %p2, %r21, %r21;
    @%p2 mul.wide.s32 %rd5, %r3, %r4;
    selp.b32 %r20, %r26, %r3, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
