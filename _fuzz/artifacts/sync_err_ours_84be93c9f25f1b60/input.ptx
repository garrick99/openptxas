.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd13, %r3, %r3;
    add.u32 %r22, %r3, 65536;
    shr.s32 %r24, %r22, 0;
    shr.u64 %rd10, %rd13, 0;
    max.s32 %r21, %r24, 63;
    add.s32 %r11, %r3, %r22;
    shr.s32 %r26, %r11, 1;
    mul.lo.s32 %r23, %r21, %r24;
    setp.gt.s32 %p3, %r24, %r3;
    max.u32 %r7, %r26, %r24;
    sub.u32 %r20, %r7, %r23;
    max.u32 %r15, %r22, %r11;
    and.b32 %r6, %r24, %r22;
    min.u64 %rd15, %rd10, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
