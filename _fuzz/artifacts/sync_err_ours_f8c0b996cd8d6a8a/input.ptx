.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r12, %r3, %r3;
    add.s32 %r14, %r3, 0;
    max.s32 %r5, %r14, 5;
    cvt.u64.u32 %rd15, %r12;
    max.u32 %r13, %r3, %r12;
    shl.b32 %r12, %r5, 1;
    or.b32 %r16, %r5, 255;
    mul.wide.s32 %rd11, %r16, %r13;
    shr.s32 %r10, %r3, 16;
    mad.lo.u32 %r6, %r5, %r14, %r12;
    shr.u64 %rd15, %rd11, 0;
    and.b32 %r7, %r13, %r5;
    sub.s32 %r8, %r12, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
