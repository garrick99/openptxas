    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r15, %r3, 255;
    sub.s32 %r17, %r3, 1;
    mul.lo.s32 %r20, %r17, %r3;
    max.u32 %r10, %r17, 2147483648;
    cvt.s64.s32 %rd15, %r10;
    mul.wide.s32 %rd10, %r15, %r10;
    setp.hs.u32 %p3, %r17, %r17;
    @%p3 mul.wide.s32 %rd11, %r3, %r20;
    sub.u32 %r9, %r15, %r20;
    max.u32 %r6, %r20, 1;
    shl.b32 %r26, %r9, 7;
    min.u64 %rd12, %rd15, %rd11;
    sub.u32 %r21, %r26, 256;
