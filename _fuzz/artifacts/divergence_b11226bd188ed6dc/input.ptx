.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r12, %r3, 16;
    mul.lo.s32 %r18, %r12, %r3;
    max.u32 %r18, %r12, 4294967295;
    setp.ge.s32 %p3, %r3, %r18;
    @!%p3 max.s32 %r8, %r18, %r18;
    add.s32 %r18, %r8, %r3;
    cvt.u64.u32 %rd13, %r8;
    cvt.u32.u64 %r23, %rd13;
    shl.b32 %r19, %r18, 31;
    cvt.u32.u64 %r9, %rd13;
    xor.b32 %r20, %r23, %r19;
    add.u32 %r12, %r9, 3;
    shr.u64 %rd8, %rd13, 32;
    setp.gt.u32 %p2, %r18, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
