.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r24, %r3, 31;
    shr.u32 %r23, %r3, 4;
    mul.wide.s32 %rd12, %r3, %r24;
    mul.wide.s32 %rd9, %r23, %r3;
    shl.b64 %rd15, %rd12, 7;
    max.u64 %rd10, %rd12, %rd12;
    setp.le.s32 %p1, %r24, 2147483647;
    @!%p1 shl.b32 %r25, %r3, 31;
    mad.lo.u32 %r9, %r23, %r23, %r25;
    cvt.u64.u32 %rd15, %r9;
    mul.wide.s32 %rd15, %r9, %r24;
    max.s64 %rd10, %rd10, %rd9;
    shr.s32 %r20, %r9, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
