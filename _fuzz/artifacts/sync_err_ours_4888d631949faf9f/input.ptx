.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r5, %r3, 4;
    cvt.s64.s32 %rd14, %r5;
    and.b32 %r10, %r5, %r3;
    add.u32 %r26, %r3, %r3;
    min.u32 %r23, %r26, %r10;
    shl.b32 %r21, %r5, 31;
    sub.u32 %r15, %r5, 5;
    sub.u32 %r4, %r5, %r3;
    shl.b32 %r5, %r3, 1;
    xor.b32 %r27, %r10, 0;
    shl.b32 %r21, %r21, 16;
    mad.lo.u32 %r27, %r23, %r27, %r3;
    sub.u32 %r27, %r26, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
