.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r6, %r3, 30;
    or.b32 %r17, %r6, %r6;
    cvt.u64.u32 %rd9, %r6;
    and.b32 %r24, %r17, 0;
    shr.u32 %r25, %r24, 4;
    cvt.u32.u64 %r26, %rd9;
    mul.lo.s64 %rd12, %rd9, %rd9;
    max.u32 %r12, %r26, %r17;
    max.u64 %rd12, %rd12, %rd12;
    add.u32 %r14, %r3, 7;
    setp.eq.u32 %p4, %r3, %r17;
    @!%p4 cvt.u32.u64 %r15, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
