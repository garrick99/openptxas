.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r20, %r3, 4;
    sub.u32 %r16, %r20, 0;
    mad.lo.u32 %r16, %r3, %r16, %r20;
    shr.u32 %r8, %r20, 1;
    max.s32 %r23, %r20, %r3;
    mul.lo.s32 %r7, %r20, 2147483647;
    cvt.s64.s32 %rd15, %r8;
    and.b32 %r16, %r20, %r8;
    min.s64 %rd10, %rd15, %rd15;
    min.u32 %r7, %r16, %r3;
    mul.wide.s32 %rd13, %r16, %r8;
    mad.lo.u32 %r15, %r20, %r23, %r7;
    shl.b32 %r13, %r15, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
