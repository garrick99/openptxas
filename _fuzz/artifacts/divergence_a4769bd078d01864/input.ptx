.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    sub.s32 %r27, %r3, 2147483647;
    cvt.u64.u32 %rd8, %r27;
    cvt.u32.u64 %r27, %rd8;
    add.u32 %r25, %r3, 256;
    and.b32 %r13, %r25, 4;
    shl.b64 %rd13, %rd8, 7;
    mul.wide.u32 %rd12, %r27, %r27;
    max.u32 %r16, %r27, 256;
    max.s32 %r18, %r25, %r3;
    setp.gt.s32 %p2, %r25, 16;
    setp.lt.u32 %p3, %r3, 15;
    @%p3 sub.u32 %r21, %r3, %r16;
    setp.le.s32 %p3, %r25, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
