.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r23, %r3, 4;
    shl.b32 %r5, %r23, 0;
    add.u32 %r27, %r3, %r5;
    cvt.u64.u32 %rd7, %r5;
    add.u32 %r4, %r3, %r5;
    shr.u32 %r5, %r3, 3;
    sub.s64 %rd12, %rd7, %rd7;
    shl.b32 %r11, %r5, 16;
    min.s32 %r7, %r11, %r4;
    mul.wide.u32 %rd11, %r11, %r7;
    setp.ne.u32 %p3, %r4, 31;
    @%p3 shr.u64 %rd6, %rd12, 7;
    shr.s32 %r26, %r11, 4;
    add.s32 %r14, %r7, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
