.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r5, %r3, 3;
    cvt.s64.s32 %rd13, %r5;
    shr.s32 %r14, %r5, 31;
    mad.lo.u32 %r19, %r5, %r14, %r14;
    mul.lo.s32 %r27, %r3, %r5;
    sub.u32 %r9, %r14, %r3;
    mul.lo.u32 %r25, %r9, %r3;
    mul.lo.s32 %r20, %r5, %r19;
    shr.u64 %rd6, %rd13, 63;
    sub.s64 %rd15, %rd13, %rd6;
    shr.u32 %r12, %r25, 4;
    setp.le.u32 %p2, %r9, 256;
    @!%p2 mad.lo.u32 %r8, %r25, %r3, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
