.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r26, %r3, %r3, %r3;
    mul.lo.u32 %r7, %r26, %r3;
    add.s32 %r9, %r7, %r26;
    mul.lo.s32 %r13, %r26, %r9;
    cvt.u64.u32 %rd5, %r7;
    cvt.u64.u32 %rd9, %r13;
    cvt.u32.u64 %r27, %rd9;
    cvt.u32.u64 %r24, %rd5;
    add.u32 %r9, %r26, 4294967295;
    max.u32 %r25, %r24, 63;
    and.b32 %r12, %r9, %r3;
    shr.s32 %r7, %r13, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
