.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r8, %r3, %r3;
    max.u32 %r19, %r8, 5;
    setp.ge.u32 %p2, %r19, 31;
    @%p2 shl.b32 %r24, %r3, 4;
    shl.b32 %r16, %r3, 31;
    setp.ge.s32 %p3, %r8, %r3;
    @!%p3 mad.lo.s32 %r20, %r3, %r24, %r3;
    cvt.s64.s32 %rd12, %r20;
    mul.wide.u32 %rd13, %r20, %r3;
    shr.u32 %r11, %r20, 31;
    max.u32 %r13, %r19, %r19;
    and.b32 %r14, %r20, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
