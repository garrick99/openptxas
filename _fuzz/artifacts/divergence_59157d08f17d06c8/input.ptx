.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd13, %r3, %r3;
    mul.wide.s32 %rd7, %r3, %r3;
    max.u32 %r26, %r3, %r3;
    shl.b64 %rd15, %rd13, 48;
    add.u32 %r25, %r3, 1;
    setp.ge.s32 %p1, %r26, %r3;
    @!%p1 mul.lo.s32 %r7, %r25, %r26;
    setp.lt.u32 %p2, %r7, %r7;
    @!%p2 add.u32 %r10, %r26, %r7;
    mul.lo.u32 %r16, %r25, %r7;
    cvt.s64.s32 %rd10, %r26;
    shl.b64 %rd6, %rd15, 63;
    add.s32 %r21, %r16, %r7;
    mul.wide.s32 %rd14, %r3, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
