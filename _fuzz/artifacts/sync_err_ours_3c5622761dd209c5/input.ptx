.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    cvt.s32.s64 %r22, %rd6;
    max.s32 %r11, %r3, %r3;
    cvt.s32.s64 %r24, %rd6;
    max.s32 %r18, %r24, %r24;
    cvt.s64.s32 %rd13, %r11;
    cvt.u32.u64 %r6, %rd13;
    setp.ne.u32 %p1, %r18, %r18;
    @!%p1 shr.u32 %r23, %r24, 3;
    max.u32 %r7, %r23, %r22;
    and.b64 %rd6, %rd6, %rd6;
    mul.wide.u32 %rd13, %r24, %r23;
    sub.u32 %r14, %r7, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
