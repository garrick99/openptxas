.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p2, %r3, %r3;
    @%p2 cvt.s64.s32 %rd12, %r3;
    cvt.u32.u64 %r10, %rd12;
    shr.s32 %r10, %r10, 4;
    sub.u32 %r12, %r10, 65536;
    shr.u32 %r19, %r10, 2;
    selp.b32 %r8, %r12, %r19, %p2;
    mad.lo.s32 %r16, %r19, %r10, %r19;
    cvt.s64.s32 %rd5, %r10;
    mul.wide.u32 %rd7, %r12, %r19;
    min.u32 %r13, %r12, %r12;
    mad.lo.s32 %r24, %r8, %r8, %r3;
    shr.u32 %r6, %r10, 1;
    xor.b32 %r19, %r24, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
