.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r16, %r3, 1;
    add.s32 %r10, %r3, 4;
    max.u32 %r6, %r16, %r10;
    setp.eq.u32 %p2, %r16, %r10;
    @!%p2 or.b32 %r17, %r3, 8;
    add.s32 %r8, %r3, 1;
    cvt.u64.u32 %rd9, %r10;
    cvt.s64.s32 %rd8, %r8;
    shr.u32 %r7, %r16, 7;
    min.u32 %r26, %r6, 31;
    and.b64 %rd14, %rd9, %rd8;
    setp.ge.s32 %p2, %r6, %r10;
    @!%p2 mad.lo.s32 %r20, %r7, %r16, %r10;
    mul.lo.s64 %rd15, %rd14, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
