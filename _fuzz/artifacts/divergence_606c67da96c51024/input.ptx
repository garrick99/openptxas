.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    setp.le.s32 %p3, %r3, 63;
    @!%p3 mul.wide.u32 %rd8, %r3, %r3;
    and.b64 %rd11, %rd8, %rd5;
    mul.lo.u64 %rd11, %rd5, %rd8;
    setp.ge.s32 %p2, %r3, 15;
    @%p2 or.b32 %r26, %r3, %r3;
    mul.lo.u32 %r21, %r3, %r26;
    min.u32 %r4, %r21, 4;
    shr.u64 %rd14, %rd8, 3;
    setp.gt.s32 %p1, %r3, %r21;
    @%p1 shl.b32 %r27, %r21, 7;
    setp.le.s32 %p1, %r3, 2;
    min.s32 %r19, %r21, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
