.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd9, %r3, %r3;
    shr.u32 %r17, %r3, 4;
    mul.lo.u32 %r18, %r3, %r3;
    add.u32 %r24, %r18, %r3;
    setp.lo.u32 %p4, %r17, 255;
    @%p4 and.b32 %r20, %r18, %r24;
    cvt.s64.s32 %rd11, %r20;
    selp.b32 %r5, %r18, %r3, %p4;
    shr.s32 %r14, %r17, 2;
    cvt.s64.s32 %rd15, %r24;
    shr.s32 %r24, %r5, 4;
    mad.lo.u32 %r4, %r3, %r24, %r18;
    setp.gt.s32 %p2, %r18, %r3;
    @!%p2 mad.lo.s32 %r16, %r14, %r14, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
