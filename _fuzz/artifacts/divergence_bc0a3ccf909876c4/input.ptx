.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r21, %r3, %r3;
    min.s32 %r14, %r3, 16;
    mul.wide.s32 %rd10, %r3, %r21;
    mad.lo.u32 %r16, %r3, %r21, %r14;
    shr.s64 %rd11, %rd10, 30;
    xor.b32 %r27, %r3, 31;
    sub.s32 %r4, %r14, 4;
    shl.b32 %r20, %r14, 16;
    max.s32 %r12, %r4, 255;
    cvt.u64.u32 %rd14, %r4;
    max.u32 %r22, %r16, %r4;
    and.b64 %rd5, %rd14, %rd14;
    max.u32 %r6, %r3, %r3;
    shr.s32 %r10, %r22, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
