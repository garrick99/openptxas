.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r5, %r3, %r3, %r3;
    cvt.s64.s32 %rd11, %r3;
    mul.wide.s32 %rd13, %r5, %r3;
    cvt.s64.s32 %rd15, %r5;
    mul.lo.u64 %rd12, %rd11, %rd13;
    min.s32 %r7, %r3, 16;
    setp.lt.u32 %p2, %r5, %r3;
    @%p2 shr.u64 %rd11, %rd15, 15;
    mul.lo.s32 %r26, %r3, %r3;
    shr.s32 %r11, %r5, 31;
    setp.hi.u32 %p3, %r3, 65535;
    @%p3 cvt.u32.u64 %r27, %rd13;
    setp.le.u32 %p3, %r5, %r26;
    selp.b32 %r24, %r3, %r27, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
