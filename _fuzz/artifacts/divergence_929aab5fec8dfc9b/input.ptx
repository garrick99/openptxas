    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r11, %r3, 1;
    mul.lo.u32 %r22, %r11, %r3;
    mul.lo.s32 %r11, %r22, 2147483647;
    shr.s32 %r22, %r11, 1;
    mad.lo.u32 %r17, %r3, %r3, %r22;
    add.u32 %r26, %r17, 16;
    cvt.s64.s32 %rd8, %r11;
    mul.lo.u32 %r21, %r26, %r11;
    setp.ne.s32 %p4, %r22, %r26;
    setp.lt.u32 %p3, %r21, 2147483647;
    @%p3 sub.s32 %r25, %r22, %r17;
    and.b32 %r24, %r22, 32;
    selp.b32 %r13, %r24, %r25, %p3;
