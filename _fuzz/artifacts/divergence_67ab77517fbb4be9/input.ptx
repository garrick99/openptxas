.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    sub.s64 %rd8, %rd8, %rd8;
    add.u32 %r6, %r3, 2;
    max.s32 %r11, %r6, 7;
    or.b32 %r22, %r6, %r11;
    setp.ls.u32 %p3, %r11, %r3;
    @!%p3 min.u32 %r16, %r11, %r6;
    or.b32 %r9, %r6, %r3;
    or.b32 %r11, %r9, %r16;
    and.b32 %r25, %r16, %r16;
    min.s32 %r13, %r16, 32;
    shr.u64 %rd6, %rd8, 47;
    cvt.s32.s64 %r22, %rd6;
    setp.eq.s32 %p4, %r11, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
