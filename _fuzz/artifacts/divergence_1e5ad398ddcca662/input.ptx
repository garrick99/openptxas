.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r23, %r3, 7;
    cvt.s64.s32 %rd6, %r3;
    mul.wide.u32 %rd15, %r3, %r23;
    cvt.s64.s32 %rd12, %r3;
    setp.ge.u32 %p3, %r23, 16;
    @!%p3 sub.s32 %r19, %r3, %r23;
    shl.b64 %rd15, %rd15, 0;
    cvt.s32.s64 %r8, %rd6;
    add.s32 %r6, %r3, %r23;
    cvt.u32.u64 %r18, %rd15;
    max.u32 %r7, %r19, 65535;
    xor.b32 %r20, %r19, %r6;
    setp.lo.u32 %p2, %r19, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
