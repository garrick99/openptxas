.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r24, %r3, %r3;
    setp.le.u32 %p4, %r3, %r24;
    @%p4 add.s32 %r4, %r24, 65536;
    selp.b32 %r26, %r3, %r3, %p4;
    and.b32 %r12, %r26, %r4;
    mad.lo.u32 %r17, %r26, %r12, %r24;
    shl.b32 %r11, %r26, 2;
    mul.lo.u32 %r17, %r24, %r24;
    selp.b32 %r24, %r3, %r4, %p4;
    mul.lo.u32 %r15, %r11, %r24;
    cvt.s64.s32 %rd14, %r17;
    and.b64 %rd5, %rd14, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
