.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r10, %r3, 65535;
    xor.b32 %r14, %r3, %r10;
    setp.eq.u32 %p1, %r3, 65535;
    @%p1 or.b32 %r17, %r10, 0;
    shr.s32 %r19, %r17, 30;
    min.u32 %r6, %r14, %r3;
    cvt.s64.s32 %rd6, %r6;
    max.u32 %r4, %r17, %r14;
    sub.s32 %r6, %r17, %r17;
    max.s32 %r16, %r19, %r14;
    mad.lo.u32 %r22, %r16, %r4, %r17;
    mul.lo.s32 %r12, %r14, %r22;
    min.s32 %r9, %r19, 256;
    shr.s64 %rd11, %rd6, 62;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
