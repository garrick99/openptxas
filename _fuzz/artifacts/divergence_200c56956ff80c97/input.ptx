.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p2, %r3, 16;
    @%p2 min.u32 %r10, %r3, %r3;
    shr.u32 %r15, %r10, 7;
    cvt.s64.s32 %rd14, %r15;
    mul.wide.s32 %rd13, %r10, %r3;
    shr.s32 %r10, %r10, 31;
    shr.s64 %rd7, %rd14, 3;
    min.s32 %r13, %r15, %r15;
    add.u64 %rd5, %rd7, %rd14;
    setp.gt.s32 %p4, %r3, %r3;
    min.u64 %rd11, %rd14, %rd7;
    mul.lo.u32 %r11, %r15, %r3;
    shl.b32 %r19, %r15, 30;
    setp.hs.u32 %p2, %r10, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
