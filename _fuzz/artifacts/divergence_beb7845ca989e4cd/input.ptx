.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r26, %r3, %r3;
    sub.u32 %r7, %r26, 0;
    cvt.u64.u32 %rd12, %r26;
    sub.u32 %r17, %r3, %r7;
    min.u32 %r18, %r26, %r7;
    setp.lt.u32 %p3, %r17, 31;
    @!%p3 xor.b32 %r24, %r17, 4;
    add.u32 %r5, %r17, 256;
    max.u32 %r18, %r24, 255;
    mad.lo.s32 %r8, %r7, %r24, %r18;
    mul.lo.s32 %r13, %r5, %r3;
    setp.lo.u32 %p1, %r24, %r3;
    mul.wide.u32 %rd5, %r8, %r18;
    shr.u32 %r4, %r24, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
