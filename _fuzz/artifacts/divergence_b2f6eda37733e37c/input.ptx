.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r7, %r3, 4;
    add.s32 %r4, %r7, %r3;
    cvt.u64.u32 %rd10, %r3;
    shr.s32 %r23, %r4, 15;
    add.s32 %r13, %r7, %r7;
    min.u32 %r10, %r4, 2147483647;
    shr.s32 %r24, %r13, 31;
    shl.b64 %rd14, %rd10, 3;
    and.b32 %r23, %r7, 16;
    mad.lo.s32 %r8, %r4, %r7, %r7;
    shr.s32 %r26, %r10, 3;
    add.s32 %r11, %r4, %r26;
    shr.s64 %rd7, %rd10, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
