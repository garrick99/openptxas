.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd8, %r3, %r3;
    mad.lo.s32 %r25, %r3, %r3, %r3;
    setp.lt.s32 %p4, %r3, 4;
    @%p4 shr.u32 %r17, %r25, 4;
    add.s32 %r24, %r3, %r17;
    selp.b32 %r18, %r25, %r3, %p4;
    sub.s32 %r17, %r17, %r25;
    shl.b64 %rd12, %rd8, 31;
    sub.u64 %rd5, %rd12, %rd12;
    max.s32 %r9, %r18, 4294967295;
    cvt.s64.s32 %rd15, %r18;
    add.s64 %rd7, %rd8, %rd15;
    min.u32 %r9, %r9, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
