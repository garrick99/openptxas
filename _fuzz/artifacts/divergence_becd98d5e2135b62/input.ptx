.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r17, %r3, 3;
    max.u32 %r25, %r3, %r3;
    min.u32 %r4, %r3, 65535;
    and.b32 %r21, %r25, %r17;
    add.u32 %r4, %r21, %r3;
    cvt.u64.u32 %rd5, %r21;
    mul.lo.s32 %r23, %r17, 4;
    shr.s32 %r19, %r4, 30;
    and.b32 %r20, %r25, %r4;
    xor.b32 %r8, %r3, %r4;
    min.s32 %r4, %r21, 15;
    max.u32 %r14, %r25, %r20;
    min.s32 %r22, %r4, %r21;
    setp.eq.s32 %p4, %r21, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
