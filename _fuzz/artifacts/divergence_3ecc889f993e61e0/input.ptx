.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p3, %r3, 32;
    @%p3 shr.s32 %r25, %r3, 4;
    selp.b32 %r21, %r25, %r25, %p3;
    shr.s32 %r12, %r3, 16;
    shr.u32 %r18, %r3, 3;
    max.s32 %r27, %r25, 3;
    and.b32 %r24, %r12, %r12;
    max.s32 %r13, %r24, 31;
    cvt.s64.s32 %rd7, %r3;
    mul.wide.s32 %rd6, %r13, %r18;
    or.b32 %r21, %r18, 1;
    shr.u32 %r12, %r24, 31;
    max.s32 %r13, %r24, %r3;
    mad.lo.u32 %r22, %r18, %r13, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
