.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    shl.b64 %rd10, %rd14, 15;
    setp.hi.u32 %p2, %r3, %r3;
    @!%p2 mad.lo.u32 %r21, %r3, %r3, %r3;
    cvt.s64.s32 %rd7, %r3;
    mul.wide.s32 %rd11, %r21, %r3;
    max.u32 %r16, %r21, %r21;
    cvt.s64.s32 %rd13, %r3;
    selp.b32 %r9, %r21, %r21, %p2;
    mul.lo.s32 %r12, %r9, 0;
    add.s32 %r11, %r16, 32;
    setp.gt.u32 %p1, %r16, 2;
    @%p1 and.b32 %r10, %r21, 0;
    add.s32 %r4, %r10, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
