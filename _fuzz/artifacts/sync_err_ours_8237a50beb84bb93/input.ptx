.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    add.u32 %r25, %r3, %r3;
    sub.s32 %r5, %r3, 2;
    shl.b32 %r11, %r3, 7;
    cvt.u32.u64 %r21, %rd13;
    mul.lo.s32 %r5, %r25, 3;
    xor.b32 %r10, %r3, %r25;
    shr.s32 %r16, %r25, 30;
    max.u64 %rd11, %rd13, %rd13;
    min.s32 %r15, %r10, 16;
    xor.b32 %r23, %r10, %r11;
    shr.s32 %r7, %r21, 2;
    shr.u64 %rd14, %rd11, 15;
    max.s32 %r14, %r15, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
