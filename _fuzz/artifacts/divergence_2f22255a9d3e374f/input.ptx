.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r25, %r3, 8;
    cvt.u64.u32 %rd7, %r3;
    max.u32 %r21, %r3, %r25;
    cvt.u64.u32 %rd12, %r25;
    mul.lo.s32 %r5, %r21, 64;
    cvt.s64.s32 %rd13, %r21;
    shr.u32 %r5, %r3, 2;
    mul.lo.u64 %rd11, %rd7, %rd7;
    sub.s32 %r4, %r3, 32;
    setp.eq.u32 %p4, %r25, 65536;
    cvt.u64.u32 %rd8, %r5;
    shr.s64 %rd12, %rd7, 7;
    setp.eq.s32 %p3, %r5, 64;
    @%p3 shr.u64 %rd5, %rd8, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
