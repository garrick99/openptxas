.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r4, %r3, 65536;
    mul.lo.s32 %r6, %r3, 65536;
    add.u32 %r9, %r4, 65536;
    min.u32 %r6, %r3, %r6;
    mad.lo.s32 %r20, %r9, %r9, %r4;
    cvt.s64.s32 %rd5, %r20;
    mul.lo.u32 %r23, %r4, %r20;
    cvt.s32.s64 %r18, %rd5;
    cvt.u32.u64 %r11, %rd5;
    setp.eq.s32 %p4, %r18, 0;
    min.s64 %rd7, %rd5, %rd5;
    shr.u32 %r21, %r4, 1;
    mad.lo.s32 %r6, %r4, %r9, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
