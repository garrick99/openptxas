.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r23, %r3, 1;
    mul.wide.u32 %rd8, %r23, %r23;
    sub.s64 %rd5, %rd8, %rd8;
    shl.b64 %rd14, %rd5, 33;
    sub.s32 %r20, %r23, %r3;
    shr.u32 %r20, %r23, 31;
    max.u32 %r9, %r23, %r3;
    shr.s64 %rd14, %rd5, 3;
    or.b32 %r11, %r23, %r9;
    shl.b32 %r5, %r23, 3;
    shl.b32 %r5, %r3, 4;
    mul.lo.s32 %r6, %r11, 63;
    sub.u32 %r23, %r20, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
