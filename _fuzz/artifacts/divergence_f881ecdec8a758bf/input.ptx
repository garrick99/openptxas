.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r16, %r3, %r3;
    cvt.s64.s32 %rd15, %r3;
    cvt.u32.u64 %r18, %rd15;
    shl.b32 %r20, %r18, 7;
    mul.wide.u32 %rd14, %r16, %r20;
    mad.lo.u32 %r15, %r16, %r20, %r18;
    add.s64 %rd10, %rd15, %rd14;
    sub.s32 %r23, %r16, %r18;
    mul.wide.s32 %rd6, %r20, %r18;
    mul.wide.u32 %rd15, %r20, %r20;
    cvt.s32.s64 %r27, %rd6;
    setp.ne.s32 %p1, %r3, %r3;
    @!%p1 cvt.s64.s32 %rd15, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
