.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r6, %r3, 2;
    setp.ne.s32 %p3, %r6, %r3;
    setp.ls.u32 %p2, %r3, 65535;
    @!%p2 mul.lo.u32 %r5, %r3, %r3;
    or.b32 %r27, %r6, %r3;
    selp.b32 %r11, %r6, %r5, %p2;
    max.u32 %r20, %r5, %r3;
    cvt.s64.s32 %rd11, %r27;
    mul.lo.u32 %r20, %r6, 8;
    cvt.s32.s64 %r9, %rd11;
    mul.wide.s32 %rd13, %r9, %r27;
    min.s32 %r5, %r20, 256;
    selp.b32 %r26, %r3, %r5, %p2;
    selp.b32 %r5, %r20, %r9, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
