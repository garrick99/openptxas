.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    sub.s32 %r19, %r3, %r3;
    setp.lt.s32 %p3, %r3, 65535;
    @%p3 sub.s64 %rd15, %rd12, %rd12;
    max.s32 %r17, %r3, 16;
    cvt.u32.u64 %r17, %rd15;
    xor.b32 %r4, %r17, 65536;
    sub.u32 %r6, %r17, %r19;
    shl.b32 %r21, %r4, 2;
    shr.s64 %rd13, %rd12, 47;
    mul.wide.s32 %rd6, %r3, %r3;
    add.u64 %rd9, %rd13, %rd12;
    setp.gt.s32 %p1, %r19, %r17;
    @!%p1 shr.s64 %rd8, %rd15, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
