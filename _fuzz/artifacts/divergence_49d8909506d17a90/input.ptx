.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hi.u32 %p4, %r3, 1;
    mul.lo.u32 %r13, %r3, 65536;
    cvt.u64.u32 %rd9, %r13;
    setp.ge.s32 %p1, %r13, %r13;
    mul.lo.s32 %r5, %r13, 65536;
    cvt.u32.u64 %r26, %rd9;
    max.u64 %rd15, %rd9, %rd9;
    shl.b32 %r6, %r3, 30;
    max.s32 %r25, %r26, %r3;
    min.s64 %rd8, %rd15, %rd15;
    or.b32 %r22, %r26, %r6;
    cvt.s32.s64 %r23, %rd15;
    cvt.u64.u32 %rd6, %r3;
    shl.b32 %r26, %r25, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
