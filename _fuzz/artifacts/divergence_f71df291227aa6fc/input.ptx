.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    max.s32 %r23, %r3, %r3;
    and.b32 %r8, %r3, 2;
    sub.s32 %r13, %r8, %r8;
    shr.s64 %rd13, %rd7, 0;
    setp.lo.u32 %p3, %r3, %r23;
    @%p3 add.u32 %r22, %r3, 2;
    shr.s64 %rd6, %rd13, 3;
    add.u32 %r27, %r3, %r13;
    selp.b32 %r20, %r23, %r22, %p3;
    mul.lo.u32 %r5, %r22, %r8;
    shl.b64 %rd11, %rd7, 4;
    mad.lo.s32 %r21, %r22, %r20, %r5;
    setp.lt.u32 %p3, %r27, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
