.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r15, %r3, %r3, %r3;
    mul.wide.u32 %rd11, %r15, %r3;
    mul.lo.s32 %r7, %r15, 0;
    sub.u32 %r25, %r15, 1;
    cvt.u32.u64 %r6, %rd11;
    xor.b32 %r22, %r3, 65536;
    sub.s64 %rd7, %rd11, %rd11;
    shl.b32 %r21, %r7, 7;
    add.s32 %r26, %r7, %r7;
    or.b32 %r15, %r21, %r22;
    mad.lo.u32 %r17, %r6, %r25, %r25;
    add.u32 %r24, %r7, %r7;
    min.s32 %r23, %r7, 255;
    setp.ge.u32 %p2, %r7, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
