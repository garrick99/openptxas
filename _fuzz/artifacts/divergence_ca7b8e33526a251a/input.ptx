.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p1, %r3, %r3;
    @%p1 add.s32 %r6, %r3, %r3;
    setp.lt.u32 %p4, %r3, %r3;
    @!%p4 selp.b32 %r10, %r6, %r6, %p4;
    max.u32 %r22, %r10, 65535;
    shl.b32 %r23, %r22, 3;
    add.u32 %r25, %r22, 4;
    mul.wide.s32 %rd15, %r10, %r22;
    mul.wide.u32 %rd14, %r3, %r23;
    min.u64 %rd15, %rd15, %rd15;
    min.u32 %r23, %r22, %r6;
    cvt.u64.u32 %rd14, %r25;
    sub.u64 %rd12, %rd14, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
