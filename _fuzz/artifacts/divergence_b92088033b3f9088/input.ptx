.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd15, %r3, %r3;
    cvt.u64.u32 %rd7, %r3;
    setp.hi.u32 %p3, %r3, %r3;
    cvt.s32.s64 %r17, %rd15;
    min.s32 %r10, %r3, %r17;
    selp.b32 %r14, %r17, %r10, %p3;
    shr.s32 %r13, %r17, 1;
    sub.s64 %rd7, %rd15, %rd7;
    setp.lo.u32 %p2, %r3, %r17;
    add.u32 %r20, %r10, 65536;
    mad.lo.s32 %r22, %r13, %r10, %r10;
    setp.gt.u32 %p2, %r10, 63;
    shl.b32 %r22, %r20, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
