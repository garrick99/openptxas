.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p2, %r3, %r3;
    @!%p2 mad.lo.u32 %r17, %r3, %r3, %r3;
    cvt.u64.u32 %rd13, %r17;
    mul.wide.s32 %rd11, %r17, %r3;
    selp.b32 %r7, %r17, %r3, %p2;
    and.b64 %rd10, %rd13, %rd11;
    shl.b64 %rd11, %rd13, 15;
    add.u32 %r23, %r7, 65536;
    shr.u64 %rd7, %rd13, 33;
    shr.u32 %r14, %r7, 3;
    min.u32 %r4, %r14, %r23;
    add.u32 %r11, %r3, %r14;
    sub.s32 %r15, %r11, 0;
    max.u32 %r23, %r7, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
