.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r11, %r3, 15;
    cvt.u64.u32 %rd12, %r3;
    mad.lo.s32 %r12, %r3, %r11, %r3;
    shl.b32 %r18, %r11, 1;
    max.u32 %r6, %r3, 32;
    shr.s32 %r10, %r12, 16;
    sub.s64 %rd15, %rd12, %rd12;
    max.s32 %r14, %r12, 8;
    shr.s32 %r20, %r10, 4;
    setp.eq.s32 %p2, %r18, %r12;
    add.u32 %r10, %r18, %r3;
    max.u32 %r11, %r3, 16;
    min.s32 %r26, %r11, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
