.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r14, %r3, 31;
    mad.lo.u32 %r20, %r3, %r3, %r3;
    mad.lo.u32 %r13, %r3, %r3, %r3;
    cvt.s64.s32 %rd7, %r13;
    add.s32 %r6, %r3, %r20;
    xor.b32 %r8, %r14, 7;
    cvt.s64.s32 %rd10, %r20;
    setp.lt.u32 %p4, %r3, 4;
    @!%p4 max.s32 %r4, %r6, %r13;
    cvt.u64.u32 %rd8, %r8;
    or.b32 %r21, %r4, 0;
    or.b32 %r22, %r4, %r13;
    setp.le.s32 %p4, %r4, %r21;
    @%p4 cvt.u64.u32 %rd14, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
