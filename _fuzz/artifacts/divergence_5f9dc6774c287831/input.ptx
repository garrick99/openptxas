    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p3, %r0, 2;
    vote.sync.ballot.b32 %r4, %p3, -1;
    setp.ne.u32 %p2, %r0, %r4;
    vote.sync.ballot.b32 %r7, %p2, -1;
    and.b32 %r19, %r7, %r3;
    shfl.sync.bfly.b32 %r8, %r3, 1, 0x1f, -1;
    setp.le.u32 %p3, %r0, 4294967295;
    vote.sync.ballot.b32 %r6, %p3, -1;
    shfl.sync.bfly.b32 %r10, %r8, 2, 0x1f, -1;
    setp.gt.u32 %p3, %r8, %r19;
