.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    sub.u64 %rd11, %rd15, %rd15;
    max.s32 %r7, %r3, %r3;
    sub.s32 %r18, %r7, 1;
    max.u32 %r21, %r7, %r7;
    cvt.u32.u64 %r12, %rd11;
    mul.wide.s32 %rd6, %r12, %r12;
    max.s32 %r20, %r3, 15;
    sub.u32 %r24, %r18, %r3;
    min.s64 %rd11, %rd11, %rd11;
    sub.s32 %r14, %r7, 65535;
    setp.ne.u32 %p4, %r14, %r14;
    @!%p4 cvt.s32.s64 %r24, %rd15;
    shr.s64 %rd8, %rd11, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
