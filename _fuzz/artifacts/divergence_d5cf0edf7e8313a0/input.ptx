.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r22, %r3, %r3;
    cvt.s64.s32 %rd9, %r22;
    cvt.u64.u32 %rd15, %r3;
    add.u32 %r16, %r22, %r3;
    or.b32 %r9, %r3, 1;
    shr.s64 %rd12, %rd9, 1;
    sub.s32 %r12, %r3, 4;
    mul.wide.u32 %rd10, %r9, %r9;
    min.s32 %r11, %r12, 65535;
    mul.wide.u32 %rd14, %r22, %r3;
    shl.b32 %r4, %r16, 7;
    setp.lt.s32 %p4, %r16, %r9;
    @!%p4 add.u32 %r15, %r3, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
