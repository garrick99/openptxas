.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd8, %r3, %r3;
    setp.ge.s32 %p3, %r3, %r3;
    @!%p3 mad.lo.u32 %r6, %r3, %r3, %r3;
    cvt.u32.u64 %r27, %rd8;
    mad.lo.s32 %r16, %r6, %r27, %r27;
    and.b32 %r11, %r3, %r3;
    add.s32 %r20, %r6, %r11;
    sub.u32 %r16, %r20, %r27;
    sub.u32 %r18, %r20, 7;
    add.s32 %r13, %r20, %r3;
    cvt.s64.s32 %rd6, %r13;
    or.b32 %r25, %r3, %r27;
    setp.lo.u32 %p1, %r3, 64;
    @%p1 shr.s32 %r15, %r6, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
