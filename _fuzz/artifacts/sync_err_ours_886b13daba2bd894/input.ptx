.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r4, %r3, %r3;
    mul.wide.u32 %rd13, %r3, %r3;
    cvt.s32.s64 %r13, %rd13;
    mul.wide.u32 %rd14, %r4, %r3;
    shl.b32 %r8, %r4, 16;
    max.s32 %r7, %r4, 32;
    max.u32 %r6, %r7, %r8;
    or.b64 %rd9, %rd13, %rd13;
    min.s32 %r10, %r13, 4294967295;
    min.u32 %r11, %r6, 256;
    sub.s32 %r14, %r4, %r10;
    setp.hi.u32 %p4, %r7, %r7;
    selp.b32 %r26, %r8, %r10, %p4;
    mul.lo.s32 %r14, %r3, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
