.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r21, %r3, 1;
    setp.ge.s32 %p3, %r3, %r3;
    @%p3 max.u32 %r8, %r3, %r21;
    shr.u32 %r13, %r21, 30;
    max.s32 %r11, %r3, 255;
    sub.u32 %r21, %r21, 64;
    cvt.u64.u32 %rd8, %r8;
    cvt.u64.u32 %rd13, %r8;
    and.b32 %r12, %r11, 2147483647;
    shr.s32 %r5, %r21, 30;
    sub.s32 %r19, %r12, %r3;
    min.u32 %r4, %r8, 31;
    add.s32 %r18, %r13, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
