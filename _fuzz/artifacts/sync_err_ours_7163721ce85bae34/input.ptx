.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r21, %r3, %r3;
    add.u32 %r22, %r3, %r3;
    mul.wide.u32 %rd10, %r3, %r22;
    or.b32 %r6, %r21, 0;
    setp.ge.u32 %p3, %r3, 1;
    @%p3 mad.lo.s32 %r20, %r22, %r21, %r6;
    add.s32 %r19, %r20, %r21;
    shr.s64 %rd11, %rd10, 3;
    shr.u64 %rd8, %rd11, 15;
    shl.b32 %r19, %r19, 30;
    shr.s32 %r17, %r19, 0;
    cvt.u32.u64 %r22, %rd8;
    mul.lo.u64 %rd13, %rd10, %rd11;
    mul.lo.u64 %rd12, %rd11, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
