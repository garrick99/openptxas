.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r14, %r3, 31;
    cvt.u64.u32 %rd10, %r14;
    mul.wide.s32 %rd6, %r14, %r3;
    and.b32 %r7, %r14, 4294967295;
    min.s32 %r6, %r14, %r7;
    mad.lo.s32 %r7, %r14, %r14, %r7;
    setp.gt.u32 %p2, %r7, 65536;
    @%p2 mul.lo.u32 %r22, %r6, 0;
    cvt.u64.u32 %rd14, %r3;
    mul.wide.s32 %rd14, %r6, %r6;
    sub.u32 %r18, %r22, 3;
    mul.lo.u32 %r20, %r22, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
