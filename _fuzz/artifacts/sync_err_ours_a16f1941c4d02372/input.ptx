.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r27, %r3, 2;
    min.s32 %r7, %r3, %r27;
    cvt.s64.s32 %rd9, %r27;
    cvt.s64.s32 %rd8, %r7;
    shr.s32 %r16, %r27, 1;
    max.u32 %r25, %r27, %r27;
    shl.b32 %r25, %r3, 3;
    cvt.u32.u64 %r10, %rd8;
    shr.s32 %r23, %r7, 16;
    shl.b32 %r5, %r27, 0;
    shl.b32 %r6, %r3, 4;
    setp.gt.s32 %p4, %r7, %r23;
    mul.lo.u32 %r8, %r25, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
