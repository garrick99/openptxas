.version 9.0
.target sm_120
.address_size 64

.visible .entry copy32(
    .param .u64 out_ptr,
    .param .u64 in_ptr)
{
    .reg .b32   %r<2>;
    .reg .b64   %rd<6>;

    // out[tid.x] = in[tid.x] (32-bit elements, no branching)
    mov.u32         %r0, %tid.x;
    cvt.u64.u32     %rd0, %r0;
    shl.b64         %rd0, %rd0, 2;

    ld.param.u64    %rd1, [in_ptr];
    add.u64         %rd2, %rd1, %rd0;
    ld.global.u32   %r1, [%rd2];

    ld.param.u64    %rd3, [out_ptr];
    add.u64         %rd4, %rd3, %rd0;
    st.global.u32   [%rd4], %r1;
    ret;
}
