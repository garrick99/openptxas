.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p3, %r3, 63;
    @%p3 and.b32 %r27, %r3, 7;
    selp.b32 %r17, %r3, %r3, %p3;
    min.s32 %r5, %r27, %r27;
    selp.b32 %r13, %r27, %r17, %p3;
    setp.eq.s32 %p1, %r13, 255;
    @!%p1 sub.s32 %r9, %r13, %r27;
    or.b32 %r26, %r27, %r3;
    cvt.s64.s32 %rd13, %r3;
    shr.u32 %r10, %r17, 31;
    selp.b32 %r9, %r9, %r27, %p3;
    cvt.s64.s32 %rd14, %r10;
    mad.lo.u32 %r4, %r13, %r3, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
