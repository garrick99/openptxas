.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r9, %r3, 16;
    mul.wide.u32 %rd6, %r3, %r3;
    sub.s64 %rd14, %rd6, %rd6;
    setp.eq.s32 %p3, %r9, %r9;
    @!%p3 and.b32 %r5, %r3, 5;
    max.s64 %rd15, %rd14, %rd14;
    setp.eq.s32 %p1, %r5, 16;
    @%p1 selp.b32 %r19, %r3, %r5, %p1;
    sub.u32 %r26, %r9, %r9;
    mad.lo.u32 %r23, %r3, %r9, %r9;
    mul.lo.u64 %rd11, %rd14, %rd6;
    or.b32 %r10, %r19, 3;
    shr.s32 %r27, %r19, 31;
    shr.s32 %r12, %r19, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
