.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r9, %r3, 3;
    cvt.s64.s32 %rd7, %r9;
    mul.wide.s32 %rd8, %r9, %r9;
    setp.le.s32 %p4, %r9, %r9;
    @%p4 cvt.u64.u32 %rd7, %r9;
    add.s64 %rd13, %rd7, %rd7;
    setp.hi.u32 %p1, %r3, 2147483648;
    @!%p1 max.s64 %rd15, %rd7, %rd8;
    add.s32 %r18, %r9, %r9;
    mul.wide.u32 %rd12, %r3, %r3;
    max.s32 %r27, %r3, %r3;
    mad.lo.u32 %r4, %r3, %r9, %r3;
    mad.lo.u32 %r16, %r18, %r18, %r18;
    max.s64 %rd7, %rd12, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
