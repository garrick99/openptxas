.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r18, %r3, %r3;
    setp.lo.u32 %p2, %r18, 15;
    @%p2 min.s32 %r7, %r3, 31;
    min.u32 %r4, %r18, %r18;
    cvt.u64.u32 %rd5, %r3;
    xor.b32 %r24, %r18, %r3;
    mad.lo.u32 %r10, %r4, %r3, %r3;
    max.u32 %r12, %r24, %r7;
    or.b32 %r13, %r4, %r7;
    mad.lo.s32 %r6, %r12, %r10, %r13;
    or.b32 %r20, %r24, %r13;
    mad.lo.u32 %r25, %r20, %r18, %r10;
    mul.lo.u32 %r16, %r7, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
