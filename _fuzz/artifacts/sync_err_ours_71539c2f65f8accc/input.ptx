.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    min.u32 %r16, %r3, %r3;
    add.u32 %r21, %r16, 5;
    shr.s32 %r22, %r21, 4;
    add.s32 %r26, %r22, 0;
    add.u32 %r26, %r21, %r16;
    cvt.s32.s64 %r8, %rd9;
    add.u32 %r8, %r22, 65535;
    or.b32 %r25, %r21, %r3;
    shr.u32 %r13, %r8, 15;
    cvt.s32.s64 %r7, %rd9;
    shl.b32 %r11, %r21, 4;
    shr.u64 %rd14, %rd9, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
