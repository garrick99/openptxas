.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    min.s32 %r7, %r3, %r3;
    shr.u32 %r25, %r7, 31;
    add.u32 %r23, %r3, %r7;
    and.b64 %rd9, %rd13, %rd13;
    max.s32 %r9, %r7, %r7;
    setp.lt.s32 %p1, %r7, %r3;
    @!%p1 mul.lo.s32 %r11, %r9, 8;
    shr.s32 %r13, %r7, 2;
    mul.lo.s32 %r13, %r7, %r25;
    max.u32 %r18, %r9, %r13;
    sub.u64 %rd10, %rd9, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
