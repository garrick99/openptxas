.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd9, %r3, %r3;
    cvt.u32.u64 %r26, %rd9;
    cvt.s64.s32 %rd9, %r26;
    setp.lt.u32 %p1, %r3, %r3;
    @%p1 xor.b32 %r17, %r26, 63;
    shr.u32 %r21, %r17, 0;
    setp.eq.s32 %p3, %r26, %r17;
    @%p3 max.u64 %rd10, %rd9, %rd9;
    mul.lo.u64 %rd11, %rd9, %rd10;
    mul.lo.s32 %r25, %r26, %r21;
    cvt.u32.u64 %r27, %rd11;
    selp.b32 %r18, %r17, %r27, %p1;
    add.s32 %r16, %r27, %r3;
    shl.b64 %rd6, %rd11, 62;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
