.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r21, %r3, 2;
    min.s32 %r13, %r21, 1;
    setp.lt.u32 %p2, %r13, %r13;
    shr.u32 %r19, %r3, 0;
    setp.ne.s32 %p2, %r13, %r13;
    cvt.u64.u32 %rd13, %r13;
    add.s32 %r24, %r19, %r21;
    sub.u64 %rd14, %rd13, %rd13;
    setp.hi.u32 %p1, %r24, %r21;
    cvt.u32.u64 %r9, %rd13;
    min.u32 %r17, %r3, %r24;
    setp.lt.s32 %p4, %r9, %r24;
    @%p4 cvt.u32.u64 %r15, %rd13;
    add.s32 %r23, %r9, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
