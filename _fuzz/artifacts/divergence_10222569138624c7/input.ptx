.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r18, %r3, %r3, %r3;
    cvt.s64.s32 %rd14, %r18;
    mad.lo.u32 %r23, %r18, %r18, %r18;
    setp.lt.u32 %p2, %r18, %r3;
    @%p2 add.s32 %r17, %r3, %r23;
    max.u64 %rd10, %rd14, %rd14;
    mad.lo.u32 %r12, %r17, %r3, %r3;
    sub.s32 %r27, %r12, %r12;
    add.s64 %rd12, %rd14, %rd10;
    shr.s32 %r24, %r18, 30;
    sub.u32 %r25, %r24, %r3;
    add.s32 %r13, %r27, %r12;
    max.u32 %r12, %r27, 31;
    max.u32 %r16, %r13, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
