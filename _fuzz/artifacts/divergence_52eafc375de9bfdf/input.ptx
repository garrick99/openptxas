.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd15, %r3, %r3;
    mul.lo.s32 %r12, %r3, %r3;
    mad.lo.s32 %r24, %r12, %r3, %r3;
    sub.u32 %r18, %r24, %r12;
    cvt.s64.s32 %rd6, %r3;
    min.u32 %r4, %r24, 3;
    mad.lo.s32 %r8, %r18, %r24, %r18;
    setp.ne.u32 %p3, %r8, 64;
    @!%p3 shl.b32 %r24, %r18, 15;
    setp.ls.u32 %p3, %r12, 16;
    @!%p3 mad.lo.s32 %r15, %r4, %r3, %r24;
    shr.u32 %r17, %r15, 31;
    min.u64 %rd10, %rd15, %rd15;
    add.s32 %r14, %r4, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
