.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd10, %r3, %r3;
    max.s64 %rd5, %rd10, %rd10;
    or.b32 %r9, %r3, %r3;
    add.s32 %r15, %r9, %r3;
    cvt.s32.s64 %r16, %rd5;
    setp.eq.u32 %p1, %r3, 32;
    setp.ne.u32 %p4, %r15, %r16;
    shr.s64 %rd7, %rd10, 33;
    and.b64 %rd12, %rd5, %rd10;
    mul.lo.s32 %r11, %r15, 8;
    or.b32 %r24, %r11, 32;
    or.b64 %rd11, %rd10, %rd5;
    xor.b64 %rd11, %rd5, %rd12;
    add.u32 %r23, %r15, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
