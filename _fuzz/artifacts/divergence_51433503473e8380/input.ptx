.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r13, %r3, %r3, %r3;
    mul.lo.u32 %r19, %r13, %r13;
    max.u32 %r23, %r19, %r19;
    setp.gt.s32 %p1, %r3, 8;
    mad.lo.s32 %r13, %r3, %r13, %r19;
    mul.wide.u32 %rd8, %r3, %r23;
    or.b32 %r19, %r23, %r13;
    shl.b32 %r15, %r3, 15;
    max.s32 %r16, %r15, 65535;
    mad.lo.u32 %r24, %r16, %r3, %r13;
    sub.s32 %r25, %r24, 65536;
    mad.lo.u32 %r21, %r24, %r19, %r19;
    max.s32 %r6, %r3, %r16;
    mul.lo.u64 %rd7, %rd8, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
