    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r14, %r3, 15;
    setp.ge.u32 %p4, %r3, 2147483647;
    @%p4 mul.lo.s32 %r14, %r14, %r3;
    sub.s32 %r6, %r3, %r14;
    xor.b32 %r17, %r6, 65535;
    mul.wide.s32 %rd5, %r6, %r14;
    add.s32 %r20, %r3, %r6;
    sub.s32 %r9, %r3, 65536;
    mad.lo.s32 %r6, %r17, %r6, %r3;
