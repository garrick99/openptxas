.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r22, %r3, %r3;
    mad.lo.s32 %r23, %r22, %r22, %r22;
    add.u32 %r27, %r22, %r22;
    setp.lt.s32 %p4, %r22, %r22;
    @%p4 or.b32 %r25, %r22, %r3;
    mul.lo.s32 %r27, %r22, 65535;
    cvt.u64.u32 %rd8, %r27;
    add.u32 %r27, %r22, 5;
    add.u32 %r17, %r23, 31;
    selp.b32 %r24, %r25, %r23, %p4;
    cvt.s64.s32 %rd14, %r3;
    and.b32 %r22, %r25, %r22;
    shl.b64 %rd14, %rd8, 33;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
