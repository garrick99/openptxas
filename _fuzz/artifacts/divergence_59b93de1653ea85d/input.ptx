    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r4, %r3, %r3;
    mul.lo.u32 %r5, %r3, %r3;
    cvt.s64.s32 %rd8, %r5;
    mul.lo.s64 %rd15, %rd8, %rd8;
    mul.lo.u32 %r5, %r5, 2147483648;
    cvt.u64.u32 %rd6, %r5;
    add.s32 %r19, %r4, 5;
    cvt.u32.u64 %r13, %rd8;
    xor.b32 %r21, %r5, %r3;
    xor.b32 %r18, %r19, %r3;
    setp.eq.s32 %p1, %r18, 4294967295;
    mul.lo.s64 %rd12, %rd6, %rd6;
