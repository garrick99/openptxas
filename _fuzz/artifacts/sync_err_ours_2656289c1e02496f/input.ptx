.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r6, %r3, %r3, %r3;
    cvt.u64.u32 %rd8, %r6;
    sub.u32 %r21, %r3, %r6;
    shr.s64 %rd15, %rd8, 48;
    sub.s32 %r22, %r21, 4;
    mul.wide.s32 %rd14, %r22, %r6;
    max.u32 %r4, %r6, %r6;
    shl.b32 %r20, %r4, 1;
    cvt.u32.u64 %r15, %rd8;
    mul.lo.s32 %r5, %r4, 16;
    mul.lo.s32 %r15, %r21, 64;
    shr.u32 %r14, %r3, 1;
    setp.ge.s32 %p4, %r15, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
