.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r25, %r3, 256;
    setp.le.s32 %p3, %r3, 2147483647;
    @!%p3 cvt.s64.s32 %rd6, %r3;
    selp.b32 %r25, %r25, %r3, %p3;
    add.u32 %r7, %r3, 4;
    shl.b32 %r10, %r3, 4;
    shr.s32 %r16, %r10, 31;
    sub.u32 %r16, %r25, %r10;
    shr.s32 %r9, %r10, 1;
    shr.s64 %rd13, %rd6, 16;
    shr.s64 %rd13, %rd6, 48;
    and.b32 %r8, %r7, %r10;
    cvt.s32.s64 %r26, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
