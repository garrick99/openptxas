.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r19, %r3, 255;
    mul.lo.s32 %r20, %r3, %r19;
    sub.s32 %r18, %r20, 1;
    max.s32 %r19, %r18, 255;
    cvt.u64.u32 %rd7, %r20;
    shr.s64 %rd15, %rd7, 16;
    cvt.s32.s64 %r9, %rd15;
    max.s32 %r14, %r9, %r9;
    mul.lo.s32 %r9, %r18, 4;
    or.b32 %r17, %r18, %r9;
    xor.b32 %r14, %r18, %r14;
    add.s32 %r17, %r20, %r3;
    min.u32 %r13, %r9, 65536;
    mul.wide.s32 %rd12, %r3, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
