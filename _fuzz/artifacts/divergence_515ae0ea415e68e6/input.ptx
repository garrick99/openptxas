.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r13, %r3, 31;
    cvt.s64.s32 %rd7, %r13;
    sub.s32 %r22, %r13, 32;
    mul.wide.s32 %rd5, %r22, %r13;
    min.u32 %r9, %r13, %r13;
    mul.wide.s32 %rd14, %r9, %r22;
    sub.u32 %r25, %r22, %r9;
    setp.lt.s32 %p1, %r3, 255;
    @%p1 cvt.s32.s64 %r23, %rd7;
    mul.wide.s32 %rd11, %r22, %r3;
    mad.lo.u32 %r15, %r25, %r9, %r25;
    shr.s32 %r17, %r9, 7;
    shr.s64 %rd14, %rd5, 2;
    mad.lo.u32 %r22, %r17, %r23, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
