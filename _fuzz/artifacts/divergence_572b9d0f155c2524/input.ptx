.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r16, %r3, %r3;
    cvt.s64.s32 %rd14, %r3;
    cvt.s32.s64 %r19, %rd14;
    xor.b32 %r15, %r3, 4294967295;
    setp.gt.s32 %p4, %r3, %r15;
    @%p4 mul.wide.s32 %rd6, %r3, %r15;
    mul.lo.s32 %r17, %r16, %r16;
    min.u32 %r12, %r16, %r19;
    add.s32 %r9, %r15, %r15;
    sub.u32 %r21, %r9, %r3;
    and.b64 %rd5, %rd6, %rd6;
    selp.b32 %r26, %r17, %r19, %p4;
    setp.eq.u32 %p3, %r26, %r19;
    @%p3 and.b32 %r23, %r9, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
