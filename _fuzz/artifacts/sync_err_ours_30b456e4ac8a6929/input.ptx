.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r24, %r3, 31;
    mul.lo.s32 %r22, %r24, %r3;
    cvt.u64.u32 %rd14, %r22;
    mul.lo.s32 %r22, %r24, %r22;
    shl.b64 %rd5, %rd14, 3;
    xor.b32 %r18, %r3, %r24;
    mul.wide.u32 %rd8, %r24, %r22;
    cvt.s64.s32 %rd14, %r24;
    cvt.s32.s64 %r25, %rd14;
    xor.b64 %rd7, %rd8, %rd14;
    shr.s32 %r17, %r3, 2;
    min.s64 %rd11, %rd8, %rd5;
    shr.s32 %r27, %r3, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
