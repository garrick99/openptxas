.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r15, %r3, 7;
    shr.u32 %r6, %r15, 31;
    cvt.u64.u32 %rd7, %r15;
    max.s32 %r15, %r3, 2;
    mul.lo.s32 %r19, %r15, %r6;
    shl.b64 %rd11, %rd7, 62;
    and.b32 %r14, %r3, %r3;
    shl.b32 %r20, %r15, 2;
    or.b32 %r27, %r20, 1;
    and.b64 %rd10, %rd11, %rd7;
    setp.lt.s32 %p1, %r6, 63;
    mul.wide.s32 %rd10, %r3, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
