.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r27, %r3, %r3, %r3;
    add.u32 %r20, %r3, %r3;
    add.u32 %r9, %r3, %r27;
    mul.wide.u32 %rd11, %r27, %r9;
    shr.u64 %rd11, %rd11, 0;
    min.u32 %r4, %r9, %r3;
    mad.lo.u32 %r24, %r27, %r20, %r27;
    min.s32 %r10, %r20, 0;
    mul.lo.s32 %r19, %r3, %r27;
    and.b32 %r6, %r9, %r20;
    mad.lo.u32 %r12, %r9, %r10, %r19;
    add.s32 %r17, %r12, 2;
    sub.u32 %r25, %r17, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
