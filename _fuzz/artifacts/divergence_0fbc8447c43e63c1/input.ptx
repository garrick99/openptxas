.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    and.b64 %rd10, %rd15, %rd15;
    max.s32 %r27, %r3, %r3;
    min.u32 %r23, %r3, 63;
    mad.lo.s32 %r15, %r3, %r23, %r23;
    mul.wide.u32 %rd6, %r27, %r23;
    shl.b64 %rd14, %rd15, 48;
    cvt.s32.s64 %r16, %rd14;
    shl.b32 %r12, %r15, 31;
    mul.wide.s32 %rd15, %r23, %r27;
    cvt.s64.s32 %rd8, %r27;
    shr.s32 %r7, %r12, 0;
    mul.lo.s32 %r18, %r3, %r16;
    cvt.s64.s32 %rd11, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
