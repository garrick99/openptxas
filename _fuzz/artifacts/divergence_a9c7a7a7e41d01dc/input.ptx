.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r6, %r3, 1;
    shl.b32 %r21, %r6, 7;
    or.b32 %r19, %r21, 2147483647;
    min.s32 %r16, %r3, %r19;
    min.u32 %r13, %r16, %r3;
    max.u32 %r26, %r6, %r6;
    sub.s32 %r21, %r6, 1;
    cvt.s64.s32 %rd8, %r21;
    shl.b64 %rd12, %rd8, 15;
    shl.b32 %r19, %r19, 15;
    or.b32 %r17, %r21, 2;
    shr.u32 %r20, %r3, 2;
    mad.lo.s32 %r19, %r20, %r19, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
