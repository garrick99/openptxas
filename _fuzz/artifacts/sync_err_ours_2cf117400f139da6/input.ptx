.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r20, %r3, 0;
    cvt.s64.s32 %rd5, %r20;
    mul.wide.u32 %rd8, %r20, %r20;
    add.s32 %r12, %r3, %r20;
    min.u32 %r14, %r12, 4;
    cvt.s32.s64 %r22, %rd5;
    shr.u32 %r14, %r3, 3;
    mad.lo.s32 %r14, %r20, %r14, %r22;
    max.u32 %r13, %r20, 32;
    mad.lo.s32 %r17, %r22, %r13, %r13;
    max.s32 %r23, %r14, %r20;
    mul.lo.s32 %r8, %r23, %r22;
    mul.lo.s64 %rd15, %rd8, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
