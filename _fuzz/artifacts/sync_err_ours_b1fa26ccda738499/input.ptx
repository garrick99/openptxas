.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    add.s64 %rd13, %rd8, %rd8;
    shr.s32 %r26, %r3, 1;
    min.u32 %r20, %r3, 256;
    mul.wide.u32 %rd14, %r20, %r3;
    max.u32 %r24, %r20, %r26;
    cvt.u64.u32 %rd7, %r20;
    max.u32 %r15, %r26, %r26;
    shr.u32 %r20, %r26, 15;
    shl.b32 %r25, %r24, 3;
    and.b32 %r13, %r25, 1;
    max.s32 %r10, %r24, %r20;
    mul.wide.s32 %rd7, %r15, %r15;
    mul.lo.s32 %r4, %r15, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
