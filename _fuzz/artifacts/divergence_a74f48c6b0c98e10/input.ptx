.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    mul.lo.u32 %r5, %r3, 2;
    setp.ge.u32 %p2, %r5, 15;
    @%p2 mul.wide.u32 %rd6, %r3, %r5;
    xor.b32 %r16, %r3, %r5;
    cvt.s32.s64 %r25, %rd6;
    xor.b32 %r24, %r25, 63;
    xor.b32 %r25, %r16, 7;
    shr.s32 %r11, %r24, 7;
    shl.b64 %rd11, %rd6, 30;
    setp.ge.s32 %p2, %r16, %r3;
    @%p2 mad.lo.u32 %r13, %r24, %r5, %r25;
    and.b32 %r16, %r11, 0;
    add.s32 %r5, %r24, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
