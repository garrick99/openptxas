.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p4, %r3, %r3;
    cvt.s64.s32 %rd11, %r3;
    mul.lo.u32 %r27, %r3, 32;
    min.u32 %r11, %r27, 64;
    mul.lo.u32 %r21, %r11, 255;
    setp.gt.s32 %p4, %r11, 7;
    @%p4 mul.lo.s64 %rd10, %rd11, %rd11;
    mad.lo.u32 %r14, %r27, %r21, %r21;
    mad.lo.u32 %r22, %r11, %r11, %r21;
    and.b32 %r24, %r14, %r3;
    setp.lt.s32 %p3, %r22, %r3;
    @!%p3 selp.b32 %r14, %r14, %r27, %p3;
    shl.b64 %rd10, %rd10, 0;
    add.s32 %r8, %r3, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
