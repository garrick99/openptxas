.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    or.b32 %r25, %r3, 4;
    sub.u32 %r21, %r25, 1;
    mul.lo.s32 %r15, %r3, 7;
    mul.lo.u32 %r19, %r25, 4294967295;
    max.s32 %r6, %r25, %r3;
    min.u32 %r27, %r19, 3;
    shr.u32 %r17, %r15, 16;
    mul.lo.s64 %rd8, %rd8, %rd8;
    add.s32 %r18, %r15, %r6;
    mul.lo.u32 %r24, %r6, %r3;
    cvt.s64.s32 %rd6, %r18;
    max.s32 %r5, %r21, 65536;
    shr.s64 %rd11, %rd6, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
