.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd11, %r3, %r3;
    shr.u64 %rd13, %rd11, 48;
    mad.lo.s32 %r17, %r3, %r3, %r3;
    and.b32 %r6, %r17, %r17;
    cvt.s64.s32 %rd14, %r6;
    mad.lo.u32 %r25, %r17, %r6, %r3;
    sub.s32 %r16, %r3, 2;
    mad.lo.u32 %r14, %r25, %r6, %r3;
    setp.gt.u32 %p3, %r16, %r17;
    @!%p3 shr.s32 %r20, %r3, 4;
    cvt.u64.u32 %rd10, %r16;
    setp.ge.s32 %p3, %r3, 63;
    @!%p3 mul.lo.u32 %r19, %r17, 255;
    mul.wide.u32 %rd10, %r20, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
