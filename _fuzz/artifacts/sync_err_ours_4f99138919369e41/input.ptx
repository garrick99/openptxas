.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r9, %r3, %r3;
    setp.hi.u32 %p1, %r3, 16;
    min.s32 %r23, %r9, %r3;
    cvt.s64.s32 %rd7, %r3;
    cvt.u64.u32 %rd5, %r3;
    cvt.u64.u32 %rd7, %r3;
    sub.u32 %r23, %r9, 1;
    mul.wide.s32 %rd9, %r9, %r23;
    mul.wide.s32 %rd10, %r23, %r9;
    max.s32 %r7, %r3, 2;
    xor.b32 %r22, %r3, %r9;
    add.u64 %rd14, %rd10, %rd5;
    max.s32 %r27, %r7, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
