.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    setp.ge.s32 %p2, %r3, 7;
    @%p2 add.u32 %r17, %r3, %r3;
    min.s32 %r13, %r3, %r17;
    mul.wide.s32 %rd13, %r3, %r13;
    mad.lo.s32 %r27, %r3, %r17, %r13;
    selp.b32 %r4, %r13, %r27, %p2;
    shr.s32 %r15, %r17, 2;
    mul.wide.u32 %rd15, %r4, %r3;
    shr.u32 %r22, %r13, 3;
    shr.s32 %r26, %r22, 2;
    cvt.u32.u64 %r4, %rd15;
    add.s32 %r7, %r13, %r15;
    cvt.u64.u32 %rd9, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
