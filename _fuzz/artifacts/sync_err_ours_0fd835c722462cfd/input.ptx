.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r9, %r3, %r3;
    cvt.s64.s32 %rd7, %r3;
    and.b32 %r19, %r3, %r3;
    xor.b32 %r16, %r19, %r9;
    max.s32 %r23, %r19, %r16;
    and.b32 %r9, %r9, %r23;
    shr.u64 %rd8, %rd7, 48;
    max.u32 %r4, %r9, 63;
    and.b32 %r17, %r4, 64;
    and.b32 %r23, %r4, %r19;
    setp.lo.u32 %p4, %r4, %r16;
    shr.u32 %r20, %r17, 15;
    min.s32 %r8, %r19, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
