.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    cvt.u64.u32 %rd9, %r3;
    add.u64 %rd12, %rd9, %rd9;
    cvt.u32.u64 %r9, %rd9;
    shl.b32 %r17, %r9, 3;
    shr.s64 %rd8, %rd12, 63;
    sub.s64 %rd12, %rd12, %rd12;
    mul.wide.u32 %rd6, %r17, %r9;
    sub.u32 %r17, %r9, %r17;
    setp.gt.u32 %p3, %r17, 0;
    @!%p3 or.b32 %r20, %r17, %r9;
    and.b32 %r25, %r20, %r20;
    setp.lt.u32 %p4, %r25, %r20;
    @%p4 mad.lo.s32 %r5, %r20, %r25, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
