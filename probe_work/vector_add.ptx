.version 9.0
.target sm_120
.address_size 64

.visible .entry vector_add(
    .param .u64 out_ptr,
    .param .u64 a_ptr,
    .param .u64 b_ptr,
    .param .u32 n)
{
    .reg .b32       %r<8>;
    .reg .b64       %rd<8>;
    .reg .pred      %p0;

    // idx = blockIdx.x * blockDim.x + threadIdx.x
    mov.u32         %r0, %tid.x;
    mov.u32         %r1, %ctaid.x;
    mov.u32         %r2, %ntid.x;
    mad.lo.s32      %r3, %r1, %r2, %r0;

    // bounds check: if (idx >= n) return
    ld.param.u32    %r4, [n];
    setp.ge.u32     %p0, %r3, %r4;
    @%p0 bra        DONE;

    // offset = idx * 4 (32-bit elements)
    cvt.u64.u32     %rd0, %r3;
    shl.b64         %rd0, %rd0, 2;

    // load a[idx]
    ld.param.u64    %rd1, [a_ptr];
    add.u64         %rd2, %rd1, %rd0;
    ld.global.u32   %r5, [%rd2];

    // load b[idx]
    ld.param.u64    %rd3, [b_ptr];
    add.u64         %rd4, %rd3, %rd0;
    ld.global.u32   %r6, [%rd4];

    // c[idx] = a[idx] + b[idx]
    add.s32         %r7, %r5, %r6;

    // store to out[idx]
    ld.param.u64    %rd5, [out_ptr];
    add.u64         %rd6, %rd5, %rd0;
    st.global.u32   [%rd6], %r7;

DONE:
    ret;
}
