.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p2, %r3, 0;
    add.u32 %r8, %r3, %r3;
    setp.ne.u32 %p3, %r8, 2147483647;
    sub.u32 %r13, %r8, %r8;
    min.s32 %r8, %r3, %r8;
    setp.ge.s32 %p3, %r3, 4294967295;
    @!%p3 min.u32 %r25, %r13, %r13;
    shr.s32 %r20, %r8, 7;
    setp.ne.s32 %p4, %r13, 65536;
    @%p4 min.u32 %r23, %r13, 3;
    cvt.s64.s32 %rd14, %r8;
    xor.b32 %r22, %r8, 4;
    shr.s32 %r17, %r25, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
