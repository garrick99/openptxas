.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r9, %r3, 2;
    or.b32 %r26, %r3, %r3;
    mad.lo.s32 %r17, %r3, %r9, %r26;
    shl.b32 %r12, %r3, 30;
    add.s32 %r21, %r17, %r17;
    sub.s32 %r10, %r12, 256;
    mul.lo.s32 %r5, %r3, %r9;
    add.u32 %r11, %r21, %r5;
    mul.lo.u32 %r17, %r11, %r12;
    min.s32 %r23, %r21, %r11;
    mul.lo.s32 %r17, %r3, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
