.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r26, %r3, 16;
    add.s32 %r5, %r3, 2147483648;
    xor.b32 %r9, %r26, %r5;
    xor.b32 %r13, %r9, 3;
    shl.b32 %r23, %r9, 2;
    and.b32 %r25, %r9, 32;
    shl.b32 %r27, %r13, 3;
    add.s32 %r25, %r25, %r26;
    shl.b32 %r27, %r26, 0;
    min.s32 %r7, %r26, %r23;
    sub.u32 %r20, %r3, 1;
    xor.b32 %r9, %r9, %r20;
    shl.b32 %r13, %r23, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
