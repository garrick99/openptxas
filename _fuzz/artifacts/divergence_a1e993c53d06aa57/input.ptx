.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r22, %r3, 2;
    mul.wide.s32 %rd9, %r3, %r22;
    max.u32 %r9, %r3, %r22;
    mul.lo.s32 %r21, %r22, 31;
    mul.wide.u32 %rd8, %r3, %r21;
    setp.lt.s32 %p1, %r9, %r22;
    @!%p1 mul.lo.u32 %r7, %r22, %r21;
    cvt.s64.s32 %rd11, %r3;
    setp.le.s32 %p3, %r21, 255;
    @!%p3 add.u32 %r8, %r3, 8;
    mad.lo.s32 %r13, %r22, %r21, %r8;
    sub.s64 %rd8, %rd9, %rd11;
    setp.hi.u32 %p4, %r7, 4;
    @%p4 cvt.u32.u64 %r14, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
