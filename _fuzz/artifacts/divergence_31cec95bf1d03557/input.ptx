.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    shr.u32 %r9, %r3, 16;
    mul.wide.u32 %rd11, %r3, %r9;
    sub.s64 %rd10, %rd11, %rd11;
    min.s32 %r14, %r9, %r9;
    cvt.s64.s32 %rd6, %r14;
    cvt.s64.s32 %rd7, %r3;
    max.u32 %r19, %r3, %r3;
    min.u32 %r23, %r9, %r3;
    min.u32 %r21, %r19, %r19;
    min.u32 %r24, %r14, 256;
    or.b32 %r25, %r23, %r21;
    setp.le.u32 %p4, %r9, %r14;
    @!%p4 add.u32 %r8, %r14, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
