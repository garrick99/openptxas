.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r6, %r3, %r3;
    min.u32 %r9, %r3, %r3;
    setp.lt.u32 %p2, %r9, %r3;
    @%p2 and.b32 %r24, %r9, 31;
    add.s32 %r13, %r3, 7;
    sub.s32 %r21, %r24, %r3;
    shr.u32 %r19, %r21, 3;
    shr.u32 %r7, %r13, 31;
    add.u32 %r5, %r13, 64;
    cvt.u64.u32 %rd13, %r13;
    shr.s32 %r15, %r21, 0;
    cvt.u32.u64 %r24, %rd13;
    min.s64 %rd8, %rd13, %rd13;
    mad.lo.s32 %r20, %r5, %r3, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
