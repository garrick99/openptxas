.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r11, %r3, %r3;
    setp.eq.s32 %p2, %r11, 64;
    cvt.s64.s32 %rd8, %r3;
    shr.s64 %rd10, %rd8, 3;
    mul.lo.s64 %rd7, %rd8, %rd10;
    xor.b64 %rd9, %rd10, %rd7;
    shr.s64 %rd10, %rd7, 63;
    max.s64 %rd9, %rd10, %rd7;
    min.s32 %r5, %r3, %r11;
    cvt.s64.s32 %rd15, %r3;
    min.s64 %rd10, %rd9, %rd15;
    selp.b32 %r21, %r3, %r5, %p2;
    max.u32 %r17, %r11, 65536;
    mul.lo.s32 %r7, %r3, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
