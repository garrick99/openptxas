.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd8, %r3, %r3;
    max.s64 %rd7, %rd8, %rd8;
    cvt.u32.u64 %r8, %rd8;
    max.s32 %r5, %r8, %r3;
    mul.wide.u32 %rd5, %r3, %r8;
    mul.lo.s32 %r24, %r5, %r5;
    mul.lo.s32 %r15, %r8, %r8;
    mul.wide.u32 %rd8, %r5, %r3;
    and.b32 %r15, %r8, %r24;
    max.s32 %r18, %r5, %r15;
    shl.b32 %r23, %r5, 2;
    mad.lo.s32 %r17, %r23, %r18, %r5;
    and.b64 %rd8, %rd7, %rd7;
    shl.b32 %r25, %r23, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
