.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p4, %r3, %r3;
    @%p4 max.s32 %r5, %r3, 2147483647;
    or.b32 %r21, %r5, 256;
    sub.s32 %r23, %r5, 64;
    max.u32 %r5, %r5, %r3;
    max.u32 %r23, %r23, %r5;
    add.u32 %r21, %r23, %r5;
    min.u32 %r21, %r23, %r5;
    cvt.u64.u32 %rd11, %r23;
    cvt.u64.u32 %rd6, %r5;
    setp.eq.u32 %p3, %r5, %r5;
    setp.gt.s32 %p4, %r5, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
