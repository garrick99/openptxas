.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p4, %r3, %r3;
    @%p4 cvt.s64.s32 %rd10, %r3;
    setp.gt.s32 %p4, %r3, %r3;
    add.u32 %r6, %r3, %r3;
    cvt.u32.u64 %r21, %rd10;
    setp.ne.u32 %p1, %r6, 15;
    mad.lo.u32 %r5, %r3, %r21, %r6;
    cvt.s64.s32 %rd14, %r3;
    and.b32 %r6, %r6, 31;
    mul.lo.s32 %r26, %r5, 5;
    cvt.u32.u64 %r23, %rd14;
    selp.b32 %r8, %r5, %r3, %p4;
    selp.b32 %r25, %r26, %r5, %p4;
    sub.s32 %r4, %r5, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
