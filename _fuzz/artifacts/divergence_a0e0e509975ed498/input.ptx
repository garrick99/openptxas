    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r14, %r3, 3;
    cvt.u64.u32 %rd8, %r14;
    cvt.u32.u64 %r24, %rd8;
    min.u32 %r8, %r24, 65536;
    mul.wide.u32 %rd12, %r8, %r14;
    shr.s64 %rd8, %rd8, 47;
    xor.b32 %r17, %r3, %r3;
