.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    max.u32 %r21, %r3, 2;
    setp.gt.u32 %p2, %r3, %r3;
    @%p2 mul.lo.s64 %rd10, %rd14, %rd14;
    max.s32 %r10, %r3, 65536;
    cvt.u32.u64 %r7, %rd10;
    sub.s32 %r14, %r10, %r21;
    cvt.s64.s32 %rd14, %r21;
    min.u32 %r23, %r10, %r7;
    sub.s32 %r24, %r21, %r10;
    mad.lo.s32 %r16, %r10, %r21, %r7;
    sub.s32 %r7, %r7, %r10;
    mul.lo.s64 %rd7, %rd14, %rd10;
    min.s64 %rd7, %rd14, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
