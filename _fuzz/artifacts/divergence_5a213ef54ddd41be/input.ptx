.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r5, %r3, %r3;
    mul.lo.s32 %r22, %r3, %r5;
    add.s32 %r27, %r5, 256;
    setp.lt.u32 %p2, %r3, 4;
    @%p2 min.u32 %r12, %r5, 16;
    max.u32 %r24, %r22, 65535;
    shr.s32 %r8, %r24, 15;
    or.b32 %r22, %r22, %r27;
    mad.lo.s32 %r22, %r24, %r12, %r27;
    min.u32 %r15, %r12, %r12;
    add.u32 %r4, %r15, 5;
    min.s32 %r27, %r22, %r24;
    and.b32 %r11, %r4, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
