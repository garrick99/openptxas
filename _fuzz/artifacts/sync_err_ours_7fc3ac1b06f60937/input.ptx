.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r20, %r3, 0;
    sub.u32 %r15, %r20, %r20;
    cvt.u64.u32 %rd12, %r3;
    sub.s64 %rd15, %rd12, %rd12;
    add.u32 %r16, %r20, %r20;
    shr.u64 %rd11, %rd12, 15;
    max.s32 %r24, %r16, 8;
    min.s64 %rd5, %rd11, %rd15;
    add.u32 %r13, %r15, %r3;
    shl.b32 %r11, %r20, 31;
    mul.wide.u32 %rd15, %r16, %r13;
    mad.lo.s32 %r21, %r20, %r20, %r20;
    mad.lo.u32 %r25, %r21, %r11, %r11;
    add.s32 %r6, %r13, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
