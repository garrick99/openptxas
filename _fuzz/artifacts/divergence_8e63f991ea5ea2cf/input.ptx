.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p1, %r3, 256;
    @%p1 shr.u32 %r25, %r3, 0;
    setp.ge.s32 %p3, %r3, 2147483648;
    add.s32 %r27, %r3, 255;
    cvt.s64.s32 %rd7, %r25;
    cvt.s64.s32 %rd7, %r25;
    sub.s32 %r4, %r27, 256;
    xor.b32 %r20, %r25, %r25;
    mul.lo.s64 %rd8, %rd7, %rd7;
    add.s32 %r8, %r3, 5;
    mul.lo.u32 %r19, %r25, %r20;
    setp.gt.u32 %p1, %r19, 5;
    @%p1 min.u32 %r7, %r8, %r19;
    and.b64 %rd10, %rd7, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
