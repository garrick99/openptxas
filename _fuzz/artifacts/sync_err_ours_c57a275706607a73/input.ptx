    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r4, %r3, 4;
    max.s32 %r19, %r3, 2147483647;
    xor.b32 %r17, %r3, %r4;
    setp.ne.u32 %p3, %r17, 16;
    @%p3 shr.s32 %r5, %r4, 31;
    cvt.s64.s32 %rd13, %r4;
    min.s64 %rd6, %rd13, %rd13;
    setp.hi.u32 %p1, %r3, 31;
    shr.s32 %r7, %r5, 15;
    selp.b32 %r10, %r19, %r19, %p3;
    min.u32 %r24, %r4, %r10;
    add.u32 %r19, %r3, %r19;
    shr.s32 %r19, %r10, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
