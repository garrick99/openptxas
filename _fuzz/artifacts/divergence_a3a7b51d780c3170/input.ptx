.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p1, %r3, 65536;
    @%p1 cvt.u64.u32 %rd11, %r3;
    shr.s64 %rd9, %rd11, 62;
    shr.s32 %r19, %r3, 30;
    shr.s32 %r6, %r19, 2;
    selp.b32 %r7, %r6, %r6, %p1;
    or.b64 %rd11, %rd11, %rd9;
    shl.b32 %r7, %r7, 1;
    and.b32 %r6, %r19, 3;
    cvt.u32.u64 %r4, %rd9;
    add.s64 %rd7, %rd9, %rd9;
    mad.lo.s32 %r27, %r4, %r19, %r4;
    max.u32 %r12, %r27, %r7;
    add.u64 %rd5, %rd9, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
