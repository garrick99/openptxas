    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r17, %r3, %r3;
    mul.wide.s32 %rd9, %r17, %r17;
    sub.s64 %rd5, %rd9, %rd9;
    min.u32 %r10, %r17, %r3;
    setp.hi.u32 %p3, %r10, 4294967295;
    @!%p3 mul.wide.u32 %rd11, %r10, %r3;
    shr.u32 %r22, %r3, 15;
    xor.b32 %r17, %r3, 2147483647;
    mul.lo.s32 %r10, %r22, %r3;
    max.s32 %r6, %r10, 256;
    add.u32 %r4, %r3, 0;
    setp.ne.s32 %p1, %r17, %r3;
    cvt.u32.u64 %r13, %rd9;
