.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r19, %r3, %r3;
    add.s32 %r19, %r3, 7;
    cvt.u64.u32 %rd11, %r3;
    sub.u64 %rd9, %rd11, %rd11;
    shr.s64 %rd14, %rd9, 63;
    shr.s64 %rd6, %rd14, 30;
    sub.u32 %r5, %r19, 32;
    cvt.s32.s64 %r14, %rd11;
    min.s32 %r13, %r14, 1;
    mad.lo.u32 %r19, %r14, %r13, %r14;
    cvt.s32.s64 %r4, %rd9;
    max.u32 %r7, %r3, 64;
    cvt.s32.s64 %r10, %rd9;
    sub.u32 %r6, %r19, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
