.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd11, %r3, %r3;
    max.u32 %r5, %r3, %r3;
    xor.b64 %rd6, %rd11, %rd11;
    min.s32 %r26, %r5, %r3;
    mul.lo.u32 %r27, %r3, %r5;
    min.u64 %rd9, %rd11, %rd11;
    shr.s32 %r15, %r3, 31;
    sub.u64 %rd13, %rd9, %rd11;
    setp.le.s32 %p4, %r27, %r3;
    @%p4 shr.u32 %r6, %r15, 1;
    mul.lo.u32 %r18, %r3, %r5;
    sub.u32 %r8, %r26, 64;
    shl.b32 %r10, %r8, 15;
    sub.u32 %r15, %r6, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
