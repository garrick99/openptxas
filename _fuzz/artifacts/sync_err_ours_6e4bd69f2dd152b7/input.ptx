.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    setp.gt.u32 %p3, %r3, %r3;
    @!%p3 mul.lo.s64 %rd15, %rd9, %rd9;
    max.u32 %r25, %r3, 2;
    mul.wide.u32 %rd11, %r25, %r25;
    mad.lo.u32 %r19, %r25, %r25, %r3;
    add.u64 %rd13, %rd11, %rd11;
    mul.lo.s64 %rd5, %rd9, %rd15;
    cvt.u64.u32 %rd9, %r19;
    max.s32 %r13, %r3, %r3;
    cvt.s32.s64 %r7, %rd11;
    setp.hs.u32 %p4, %r19, 255;
    sub.u64 %rd11, %rd15, %rd5;
    cvt.s32.s64 %r17, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
