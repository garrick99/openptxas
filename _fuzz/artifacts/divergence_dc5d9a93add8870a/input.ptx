    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r8, %r3, 31;
    mul.wide.u32 %rd6, %r8, %r3;
    max.u64 %rd5, %rd6, %rd6;
    sub.u64 %rd15, %rd5, %rd6;
    mul.lo.s32 %r10, %r8, %r3;
    mul.lo.s32 %r23, %r8, %r3;
    max.s32 %r10, %r8, %r3;
    cvt.u32.u64 %r5, %rd6;
    shl.b32 %r20, %r23, 7;
    or.b32 %r18, %r20, %r23;
    mul.lo.s32 %r10, %r20, 2147483647;
    shl.b32 %r11, %r3, 1;
    shr.s32 %r22, %r18, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
