.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd6, %r3, %r3;
    max.u32 %r15, %r3, %r3;
    min.s32 %r4, %r15, %r3;
    max.s32 %r15, %r3, 4294967295;
    mad.lo.s32 %r13, %r4, %r3, %r4;
    mul.lo.s32 %r4, %r15, 64;
    mad.lo.s32 %r20, %r13, %r3, %r4;
    max.s32 %r16, %r4, %r20;
    shr.u64 %rd13, %rd6, 2;
    cvt.s32.s64 %r16, %rd6;
    max.s32 %r9, %r4, %r13;
    shl.b64 %rd15, %rd6, 30;
    xor.b32 %r17, %r16, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
