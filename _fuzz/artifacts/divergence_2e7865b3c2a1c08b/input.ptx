.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd7, %r3, %r3;
    max.s32 %r7, %r3, %r3;
    min.u32 %r23, %r7, %r3;
    shr.s32 %r4, %r7, 0;
    and.b32 %r19, %r3, %r23;
    add.u32 %r11, %r23, 7;
    min.u32 %r25, %r4, %r23;
    mul.lo.u64 %rd14, %rd7, %rd7;
    add.s32 %r9, %r23, 64;
    cvt.u64.u32 %rd14, %r19;
    mul.lo.u32 %r26, %r7, %r4;
    min.s32 %r4, %r7, 8;
    shl.b32 %r5, %r26, 31;
    xor.b32 %r14, %r4, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
