.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r17, %r0, %r3;
    or.b32 %r16, %r0, %r3;
    shfl.sync.idx.b32 %r7, %r16, 7, 0x1f, -1;
    max.u32 %r6, %r7, %r17;
    or.b32 %r8, %r0, %r6;
    shfl.sync.up.b32 %r17, %r3, 4, 0x1f, -1;
    setp.ne.u32 %p2, %r3, %r6;
    vote.sync.ballot.b32 %r11, %p2, -1;
    or.b32 %r10, %r16, %r7;
    shfl.sync.up.b32 %r6, %r6, 8, 0x1f, -1;
    setp.le.u32 %p2, %r8, %r6;
    vote.sync.ballot.b32 %r15, %p2, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
