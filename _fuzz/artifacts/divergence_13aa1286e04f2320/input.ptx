.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    setp.gt.s32 %p3, %r3, 32;
    mul.lo.s32 %r23, %r3, 255;
    setp.le.u32 %p2, %r23, %r3;
    @%p2 max.s32 %r4, %r23, 16;
    shl.b32 %r14, %r4, 7;
    add.u32 %r23, %r3, %r23;
    mad.lo.u32 %r24, %r23, %r23, %r23;
    shl.b64 %rd7, %rd10, 7;
    or.b32 %r17, %r14, %r24;
    or.b64 %rd7, %rd10, %rd7;
    mul.wide.u32 %rd6, %r14, %r17;
    selp.b32 %r10, %r17, %r4, %p3;
    mul.wide.u32 %rd13, %r23, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
