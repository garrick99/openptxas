.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd5, %r3, %r3;
    mul.lo.u32 %r19, %r3, 65536;
    cvt.s64.s32 %rd11, %r19;
    min.u32 %r24, %r19, %r3;
    setp.lt.s32 %p4, %r3, %r24;
    setp.lt.u32 %p3, %r3, 1;
    @%p3 shr.u32 %r21, %r19, 15;
    cvt.s32.s64 %r17, %rd11;
    max.u32 %r18, %r21, %r17;
    mad.lo.s32 %r19, %r24, %r19, %r24;
    setp.ne.s32 %p1, %r24, 4;
    @%p1 cvt.s64.s32 %rd7, %r24;
    xor.b64 %rd7, %rd7, %rd7;
    min.s32 %r8, %r24, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
