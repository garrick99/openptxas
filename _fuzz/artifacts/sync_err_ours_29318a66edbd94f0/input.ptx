.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r16, %r3, 4294967295;
    min.s32 %r7, %r3, %r3;
    add.s32 %r17, %r7, 15;
    cvt.s64.s32 %rd10, %r7;
    xor.b32 %r20, %r16, %r16;
    shr.u32 %r11, %r7, 3;
    sub.s32 %r20, %r7, 256;
    setp.le.s32 %p4, %r16, %r11;
    @!%p4 add.u32 %r15, %r7, %r11;
    sub.u32 %r17, %r3, %r7;
    sub.u32 %r4, %r3, %r16;
    min.u32 %r24, %r17, 16;
    or.b32 %r23, %r20, %r7;
    cvt.s32.s64 %r19, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
