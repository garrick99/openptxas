.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r10, %r3, %r3;
    setp.gt.u32 %p3, %r10, 7;
    cvt.s64.s32 %rd6, %r10;
    mad.lo.u32 %r21, %r10, %r3, %r10;
    mul.lo.u32 %r5, %r21, %r10;
    setp.lt.u32 %p2, %r21, %r3;
    shr.u32 %r6, %r21, 3;
    mul.lo.s32 %r10, %r21, %r3;
    max.s32 %r22, %r6, 5;
    and.b32 %r19, %r22, %r5;
    selp.b32 %r22, %r22, %r6, %p3;
    cvt.u64.u32 %rd9, %r19;
    mad.lo.s32 %r27, %r22, %r19, %r3;
    shl.b64 %rd8, %rd6, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
