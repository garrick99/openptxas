.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r7, %r3, %r3;
    or.b32 %r25, %r3, 8;
    mul.lo.s32 %r10, %r25, 15;
    shl.b32 %r10, %r3, 4;
    setp.ne.s32 %p4, %r10, 0;
    setp.lo.u32 %p3, %r25, 0;
    @%p3 max.u32 %r19, %r3, 8;
    mad.lo.s32 %r21, %r19, %r19, %r19;
    mul.lo.u32 %r25, %r10, 3;
    mul.wide.u32 %rd8, %r19, %r3;
    max.s32 %r13, %r10, 65535;
    sub.s32 %r18, %r21, %r10;
    shr.u64 %rd8, %rd8, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
