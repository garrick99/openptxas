.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    shr.u32 %r15, %r3, 15;
    add.s32 %r23, %r15, %r3;
    mad.lo.u32 %r11, %r23, %r15, %r3;
    and.b32 %r15, %r11, %r15;
    min.u32 %r22, %r11, %r3;
    mul.lo.u64 %rd8, %rd6, %rd6;
    cvt.s32.s64 %r9, %rd6;
    shl.b64 %rd8, %rd6, 0;
    add.s32 %r22, %r22, %r15;
    setp.ls.u32 %p2, %r11, 4;
    @%p2 add.u32 %r13, %r9, 7;
    mul.lo.s32 %r5, %r9, 2;
    mul.wide.s32 %rd8, %r3, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
