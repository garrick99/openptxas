.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    add.s32 %r21, %r3, %r3;
    setp.lo.u32 %p4, %r21, %r21;
    shr.u32 %r4, %r3, 7;
    shr.u32 %r17, %r4, 1;
    add.s32 %r18, %r4, %r3;
    mad.lo.u32 %r10, %r4, %r17, %r21;
    mul.lo.s64 %rd15, %rd11, %rd11;
    mul.lo.s64 %rd15, %rd11, %rd15;
    max.u32 %r9, %r18, 4294967295;
    shl.b32 %r12, %r21, 16;
    add.u32 %r12, %r21, 16;
    and.b32 %r24, %r4, 16;
    selp.b32 %r8, %r12, %r9, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
