.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p2, %r3, 5;
    @!%p2 cvt.s64.s32 %rd5, %r3;
    add.u32 %r9, %r3, 3;
    sub.s32 %r17, %r9, %r3;
    shl.b64 %rd6, %rd5, 15;
    xor.b32 %r13, %r17, 2147483647;
    add.u64 %rd9, %rd6, %rd6;
    shl.b32 %r6, %r13, 0;
    mul.lo.u32 %r24, %r6, 255;
    selp.b32 %r5, %r24, %r17, %p2;
    selp.b32 %r4, %r24, %r6, %p2;
    or.b32 %r16, %r13, %r24;
    setp.gt.s32 %p2, %r6, 16;
    @!%p2 mul.lo.u32 %r8, %r6, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
