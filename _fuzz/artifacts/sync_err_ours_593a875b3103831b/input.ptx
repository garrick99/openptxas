.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r17, %r3, 31;
    min.u32 %r18, %r17, %r17;
    add.s32 %r13, %r18, %r18;
    max.s32 %r12, %r3, %r18;
    cvt.u64.u32 %rd6, %r18;
    shl.b64 %rd10, %rd6, 1;
    and.b64 %rd8, %rd10, %rd6;
    max.u64 %rd10, %rd6, %rd6;
    sub.u32 %r24, %r13, %r12;
    xor.b32 %r25, %r24, %r17;
    max.u32 %r12, %r3, 64;
    max.s32 %r24, %r13, %r13;
    max.u32 %r19, %r17, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
