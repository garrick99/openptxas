    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r19, %r3, 64;
    cvt.s64.s32 %rd11, %r3;
    add.s32 %r24, %r19, %r19;
    setp.hi.u32 %p4, %r19, 65536;
    setp.ne.u32 %p2, %r19, %r3;
    @%p2 min.s32 %r25, %r19, 16;
    max.s32 %r12, %r3, %r3;
    mul.lo.s32 %r26, %r3, 64;
    and.b32 %r27, %r24, %r26;
    mad.lo.u32 %r5, %r24, %r19, %r25;
    sub.s32 %r12, %r12, %r26;
    mul.lo.u32 %r6, %r12, %r26;
    setp.lt.s32 %p2, %r25, %r24;
    @%p2 max.u32 %r22, %r6, 32;
