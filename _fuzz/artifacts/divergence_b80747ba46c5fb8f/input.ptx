.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p2, %r3, 256;
    @%p2 max.s32 %r21, %r3, %r3;
    shr.u32 %r27, %r21, 3;
    add.s32 %r13, %r27, 5;
    setp.lt.s32 %p3, %r21, %r27;
    @%p3 selp.b32 %r8, %r3, %r21, %p2;
    shr.u32 %r25, %r3, 7;
    cvt.s64.s32 %rd12, %r27;
    min.s64 %rd6, %rd12, %rd12;
    min.u32 %r11, %r21, 16;
    shr.u32 %r4, %r13, 15;
    setp.eq.s32 %p4, %r13, 8;
    @%p4 add.s64 %rd15, %rd6, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
