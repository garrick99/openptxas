.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    setp.lt.u32 %p4, %r3, 63;
    sub.u32 %r23, %r3, %r3;
    mul.wide.u32 %rd8, %r23, %r23;
    max.s32 %r17, %r3, %r23;
    min.u32 %r20, %r17, %r23;
    cvt.s64.s32 %rd12, %r20;
    add.u32 %r7, %r17, %r3;
    shl.b64 %rd14, %rd12, 7;
    sub.s32 %r16, %r23, %r20;
    cvt.s32.s64 %r19, %rd8;
    cvt.s32.s64 %r5, %rd8;
    mul.wide.u32 %rd11, %r20, %r17;
    shl.b32 %r11, %r7, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
