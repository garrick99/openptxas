.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r11, %r0, %r0;
    add.u32 %r9, %r0, %r11;
    xor.b32 %r17, %r9, %r9;
    sub.u32 %r17, %r3, %r9;
    shfl.sync.down.b32 %r13, %r17, 4, 0x1f, -1;
    shfl.sync.up.b32 %r4, %r0, 8, 0x1f, -1;
    shfl.sync.down.b32 %r8, %r13, 4, 0x1f, -1;
    setp.le.u32 %p1, %r11, 8;
    vote.sync.ballot.b32 %r13, %p1, -1;
    sub.u32 %r6, %r9, %r8;
    shfl.sync.up.b32 %r17, %r13, 1, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
