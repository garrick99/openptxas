.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    mul.lo.s32 %r13, %r3, 4294967295;
    cvt.s64.s32 %rd12, %r3;
    cvt.u32.u64 %r12, %rd14;
    shr.s32 %r27, %r13, 1;
    sub.u32 %r17, %r27, 1;
    min.u64 %rd15, %rd14, %rd14;
    max.s32 %r20, %r12, 256;
    cvt.s32.s64 %r12, %rd14;
    or.b64 %rd15, %rd15, %rd12;
    mul.wide.u32 %rd12, %r12, %r12;
    cvt.u64.u32 %rd12, %r13;
    sub.u32 %r20, %r17, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
