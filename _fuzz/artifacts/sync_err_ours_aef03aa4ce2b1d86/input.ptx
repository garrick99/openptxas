.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r26, %r3, 15;
    mul.wide.s32 %rd5, %r26, %r26;
    sub.u32 %r19, %r26, 65535;
    and.b32 %r8, %r3, 32;
    sub.u32 %r14, %r19, %r3;
    sub.u32 %r7, %r8, %r3;
    mad.lo.u32 %r17, %r19, %r3, %r8;
    mad.lo.u32 %r26, %r19, %r17, %r17;
    mul.wide.s32 %rd12, %r26, %r17;
    max.u32 %r16, %r3, %r17;
    mul.wide.s32 %rd10, %r8, %r7;
    or.b32 %r24, %r8, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
