.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd9, %r3, %r3;
    mul.wide.s32 %rd6, %r3, %r3;
    shl.b64 %rd7, %rd9, 3;
    shr.s64 %rd13, %rd7, 32;
    and.b32 %r25, %r3, 31;
    mad.lo.u32 %r16, %r3, %r3, %r3;
    shr.u32 %r11, %r3, 31;
    setp.eq.u32 %p3, %r25, %r25;
    @%p3 xor.b32 %r13, %r25, 255;
    cvt.s64.s32 %rd12, %r3;
    mul.wide.u32 %rd5, %r11, %r25;
    shr.s32 %r23, %r13, 31;
    selp.b32 %r16, %r11, %r23, %p3;
    min.s64 %rd6, %rd12, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
