    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r22, %r3, 1;
    add.u32 %r9, %r3, %r3;
    setp.hs.u32 %p2, %r9, 2147483647;
    @%p2 cvt.s64.s32 %rd10, %r3;
    mad.lo.u32 %r13, %r9, %r9, %r9;
