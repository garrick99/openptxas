.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd7, %r3, %r3;
    setp.hi.u32 %p3, %r3, 32;
    @!%p3 shl.b32 %r17, %r3, 30;
    max.u32 %r22, %r3, %r17;
    setp.lt.s32 %p4, %r3, %r17;
    mul.wide.s32 %rd13, %r22, %r17;
    shr.s64 %rd11, %rd13, 30;
    sub.s32 %r16, %r17, 2147483647;
    setp.ls.u32 %p3, %r22, 4294967295;
    @%p3 min.s64 %rd11, %rd13, %rd7;
    max.u32 %r15, %r22, %r16;
    cvt.u64.u32 %rd14, %r15;
    add.u32 %r7, %r22, 3;
    min.u64 %rd7, %rd14, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
