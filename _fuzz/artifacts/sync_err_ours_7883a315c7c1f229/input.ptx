.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    shr.u32 %r9, %r3, 2;
    shl.b64 %rd14, %rd13, 15;
    min.s32 %r14, %r9, 8;
    mul.lo.u32 %r10, %r3, 4294967295;
    mul.lo.s32 %r17, %r3, 2147483648;
    sub.s32 %r25, %r9, 32;
    mul.wide.u32 %rd11, %r3, %r9;
    setp.le.s32 %p4, %r9, %r25;
    @%p4 add.u32 %r18, %r25, 255;
    mul.wide.u32 %rd6, %r9, %r14;
    shr.s32 %r11, %r3, 4;
    selp.b32 %r27, %r10, %r17, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
