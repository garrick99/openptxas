.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    add.s32 %r13, %r3, %r3;
    shr.u32 %r25, %r3, 16;
    setp.eq.s32 %p3, %r13, 15;
    shr.u32 %r15, %r25, 3;
    cvt.u32.u64 %r8, %rd14;
    selp.b32 %r27, %r8, %r8, %p3;
    add.u32 %r6, %r15, %r27;
    mul.wide.u32 %rd5, %r25, %r27;
    shl.b32 %r7, %r13, 2;
    cvt.s32.s64 %r27, %rd14;
    shl.b32 %r24, %r7, 3;
    mad.lo.u32 %r26, %r6, %r15, %r24;
    and.b32 %r22, %r24, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
