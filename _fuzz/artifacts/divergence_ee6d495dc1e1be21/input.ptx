.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p2, %r3, %r0;
    vote.sync.ballot.b32 %r11, %p2, -1;
    setp.ne.u32 %p1, %r3, 255;
    vote.sync.ballot.b32 %r17, %p1, -1;
    shfl.sync.up.b32 %r5, %r17, 16, 0x1f, -1;
    min.u32 %r11, %r0, %r0;
    xor.b32 %r13, %r17, %r5;
    setp.ne.u32 %p1, %r13, %r13;
    vote.sync.ballot.b32 %r17, %p1, -1;
    min.u32 %r11, %r11, %r13;
    setp.ge.u32 %p1, %r11, 8;
    vote.sync.ballot.b32 %r8, %p1, -1;
    setp.ne.u32 %p2, %r17, %r17;
    vote.sync.ballot.b32 %r18, %p2, -1;
    min.u32 %r18, %r17, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
