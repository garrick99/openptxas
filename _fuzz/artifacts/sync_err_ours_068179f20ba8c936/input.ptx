.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    shr.s32 %r25, %r3, 0;
    max.s32 %r26, %r25, %r25;
    or.b32 %r13, %r25, 65535;
    add.u64 %rd9, %rd10, %rd10;
    sub.s32 %r21, %r13, %r25;
    xor.b32 %r19, %r3, 31;
    sub.s32 %r23, %r21, %r26;
    shr.s32 %r13, %r23, 4;
    shr.u32 %r4, %r21, 1;
    sub.s64 %rd13, %rd9, %rd9;
    and.b32 %r20, %r26, 256;
    add.s32 %r11, %r21, 63;
    mul.wide.u32 %rd8, %r4, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
