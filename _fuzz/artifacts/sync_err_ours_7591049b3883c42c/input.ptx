.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r15, %r3, 65536;
    mad.lo.u32 %r26, %r3, %r3, %r15;
    add.u32 %r8, %r26, 5;
    mad.lo.s32 %r17, %r8, %r15, %r26;
    min.s32 %r11, %r26, %r17;
    shl.b32 %r24, %r3, 16;
    max.u32 %r11, %r3, %r3;
    shr.u32 %r9, %r8, 15;
    mul.lo.s32 %r26, %r8, 32;
    cvt.s64.s32 %rd11, %r11;
    sub.s32 %r27, %r26, 1;
    mul.wide.u32 %rd11, %r8, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
