.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p4, %r3, %r3;
    @!%p4 or.b32 %r20, %r3, 4294967295;
    shr.u32 %r7, %r3, 4;
    setp.eq.s32 %p4, %r7, %r7;
    @%p4 add.s32 %r15, %r20, 2147483648;
    shl.b32 %r9, %r20, 31;
    mad.lo.u32 %r25, %r3, %r15, %r9;
    cvt.u64.u32 %rd14, %r7;
    shl.b32 %r19, %r7, 16;
    setp.eq.s32 %p4, %r15, %r19;
    @%p4 max.u32 %r11, %r3, %r25;
    mul.wide.u32 %rd7, %r11, %r7;
    shr.u64 %rd7, %rd7, 1;
    sub.u32 %r17, %r25, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
