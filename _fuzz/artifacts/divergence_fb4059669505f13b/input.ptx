.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd5, %r3, %r3;
    mul.wide.u32 %rd9, %r3, %r3;
    and.b64 %rd14, %rd5, %rd9;
    sub.u32 %r13, %r3, %r3;
    sub.s32 %r17, %r13, 32;
    max.s32 %r12, %r17, 65536;
    shr.u64 %rd11, %rd9, 30;
    add.u32 %r8, %r13, %r3;
    mad.lo.u32 %r14, %r13, %r17, %r3;
    setp.le.s32 %p3, %r12, 31;
    @%p3 max.s32 %r25, %r17, %r13;
    sub.s32 %r8, %r3, %r8;
    and.b32 %r15, %r14, %r12;
    shl.b32 %r27, %r25, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
