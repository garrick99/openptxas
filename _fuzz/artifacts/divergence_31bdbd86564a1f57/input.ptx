.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r18, %r3, %r3;
    cvt.u64.u32 %rd10, %r18;
    cvt.s32.s64 %r16, %rd10;
    shl.b32 %r20, %r16, 1;
    sub.u64 %rd15, %rd10, %rd10;
    cvt.s64.s32 %rd5, %r3;
    setp.ge.u32 %p2, %r16, 32;
    @!%p2 selp.b32 %r11, %r18, %r3, %p2;
    shl.b64 %rd7, %rd15, 48;
    mul.lo.u32 %r20, %r11, 1;
    shr.s32 %r21, %r20, 31;
    max.s64 %rd13, %rd15, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
