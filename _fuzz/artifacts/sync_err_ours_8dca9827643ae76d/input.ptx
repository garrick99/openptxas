.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r14, %r3, 1;
    min.u32 %r19, %r3, %r14;
    min.s32 %r8, %r19, %r14;
    add.u32 %r25, %r3, 4;
    add.s32 %r12, %r14, 4294967295;
    xor.b32 %r20, %r12, 2147483648;
    shl.b32 %r22, %r12, 15;
    min.s32 %r19, %r22, %r25;
    mad.lo.s32 %r6, %r8, %r20, %r25;
    shr.u32 %r23, %r3, 2;
    shr.u32 %r25, %r20, 4;
    max.s32 %r7, %r19, %r23;
    mad.lo.u32 %r26, %r8, %r8, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
