.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r6, %r3, %r3;
    setp.ls.u32 %p2, %r6, 65536;
    min.u32 %r19, %r3, %r3;
    sub.u32 %r24, %r3, 64;
    and.b32 %r27, %r19, %r24;
    or.b32 %r14, %r24, 65535;
    shr.s32 %r16, %r14, 3;
    selp.b32 %r11, %r3, %r27, %p2;
    setp.ge.s32 %p3, %r24, %r14;
    @%p3 and.b32 %r22, %r6, 2;
    setp.ne.s32 %p3, %r19, %r3;
    @%p3 mul.wide.s32 %rd8, %r22, %r24;
    mul.lo.s32 %r6, %r22, 4;
    shl.b32 %r15, %r27, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
