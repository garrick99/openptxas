.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    add.u32 %r19, %r3, %r3;
    cvt.s32.s64 %r20, %rd15;
    shr.s32 %r8, %r20, 2;
    setp.le.s32 %p2, %r3, 31;
    @%p2 mad.lo.s32 %r15, %r8, %r19, %r20;
    add.s32 %r20, %r20, %r15;
    min.s32 %r14, %r15, 31;
    max.u32 %r26, %r8, %r19;
    sub.s32 %r4, %r8, 32;
    or.b32 %r21, %r15, %r3;
    shl.b64 %rd9, %rd15, 1;
    mul.lo.u32 %r8, %r14, 65536;
    min.s32 %r22, %r15, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
