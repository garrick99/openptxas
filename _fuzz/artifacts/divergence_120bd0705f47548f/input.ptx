.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r23, %r3, %r3, %r3;
    shr.u32 %r19, %r3, 16;
    setp.ge.u32 %p2, %r23, 15;
    min.s32 %r9, %r3, %r3;
    selp.b32 %r17, %r23, %r23, %p2;
    selp.b32 %r9, %r9, %r19, %p2;
    cvt.u64.u32 %rd15, %r23;
    mul.lo.s32 %r17, %r9, 65535;
    setp.hs.u32 %p4, %r9, 7;
    @!%p4 selp.b32 %r9, %r23, %r9, %p4;
    sub.u32 %r19, %r17, %r17;
    shl.b32 %r24, %r17, 30;
    add.s32 %r8, %r3, 4294967295;
    sub.u32 %r12, %r9, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
