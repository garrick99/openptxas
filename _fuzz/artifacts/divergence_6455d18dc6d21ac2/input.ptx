.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    cvt.s64.s32 %rd12, %r3;
    shr.u64 %rd7, %rd12, 15;
    max.s32 %r10, %r3, 15;
    max.s32 %r4, %r3, %r3;
    shr.s32 %r18, %r3, 31;
    cvt.s64.s32 %rd9, %r10;
    xor.b32 %r19, %r18, 2;
    mul.wide.u32 %rd11, %r19, %r19;
    setp.gt.u32 %p2, %r18, %r19;
    @!%p2 max.s32 %r27, %r18, %r10;
    sub.s32 %r8, %r3, %r3;
    mul.lo.u32 %r17, %r19, %r10;
    or.b32 %r25, %r27, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
