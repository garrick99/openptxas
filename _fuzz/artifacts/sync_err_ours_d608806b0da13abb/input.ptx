.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r27, %r3, 2;
    max.s32 %r9, %r3, %r3;
    shr.u32 %r23, %r9, 4;
    sub.s32 %r19, %r27, %r9;
    cvt.s64.s32 %rd9, %r27;
    shl.b64 %rd15, %rd9, 63;
    max.u64 %rd5, %rd15, %rd15;
    mad.lo.u32 %r18, %r9, %r3, %r3;
    cvt.u32.u64 %r18, %rd15;
    min.s32 %r14, %r19, %r9;
    cvt.u64.u32 %rd12, %r27;
    or.b32 %r15, %r18, 1;
    mul.wide.u32 %rd13, %r23, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
