.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    sub.s32 %r22, %r3, %r3;
    setp.lt.u32 %p3, %r3, %r22;
    @%p3 mul.wide.u32 %rd12, %r22, %r3;
    mul.wide.s32 %rd7, %r22, %r3;
    selp.b32 %r6, %r22, %r3, %p3;
    mul.wide.s32 %rd7, %r22, %r22;
    mul.lo.u32 %r11, %r3, 4;
    shr.u32 %r26, %r3, 31;
    mul.lo.u32 %r7, %r22, %r11;
    shr.u32 %r11, %r7, 15;
    or.b32 %r20, %r26, %r26;
    shr.u64 %rd9, %rd7, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
