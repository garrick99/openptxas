.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    mul.wide.s32 %rd9, %r3, %r3;
    sub.s32 %r5, %r3, 31;
    mul.wide.s32 %rd14, %r5, %r5;
    and.b32 %r6, %r3, 1;
    sub.s32 %r16, %r3, 5;
    mad.lo.s32 %r24, %r16, %r16, %r5;
    and.b32 %r13, %r6, 16;
    min.s64 %rd8, %rd9, %rd14;
    or.b32 %r8, %r3, %r16;
    max.s32 %r16, %r16, 31;
    or.b32 %r20, %r13, %r3;
    mad.lo.u32 %r25, %r8, %r5, %r20;
    min.u32 %r20, %r25, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
