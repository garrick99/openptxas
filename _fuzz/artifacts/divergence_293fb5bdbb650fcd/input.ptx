.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p2, %r3, 5;
    cvt.u64.u32 %rd13, %r3;
    xor.b64 %rd7, %rd13, %rd13;
    mul.lo.s32 %r23, %r3, 255;
    min.u32 %r21, %r3, 8;
    mul.lo.u32 %r8, %r3, 16;
    shr.s64 %rd5, %rd7, 16;
    max.s32 %r12, %r21, 2147483648;
    max.u32 %r4, %r3, 65536;
    selp.b32 %r5, %r21, %r23, %p2;
    mul.wide.s32 %rd13, %r3, %r3;
    setp.hi.u32 %p1, %r3, %r12;
    @%p1 min.u32 %r17, %r5, %r4;
    and.b64 %rd8, %rd7, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
