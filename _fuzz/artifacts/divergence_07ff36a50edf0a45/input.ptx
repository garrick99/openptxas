.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p2, %r3, 256;
    @%p2 mad.lo.u32 %r22, %r3, %r3, %r3;
    xor.b32 %r19, %r3, %r22;
    and.b32 %r16, %r3, 7;
    cvt.s64.s32 %rd8, %r19;
    shr.s32 %r21, %r3, 3;
    mul.lo.u32 %r19, %r16, %r16;
    sub.s32 %r10, %r19, %r21;
    max.u32 %r7, %r16, %r22;
    mul.lo.u64 %rd5, %rd8, %rd8;
    max.s32 %r22, %r3, %r7;
    mul.lo.u32 %r10, %r7, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
