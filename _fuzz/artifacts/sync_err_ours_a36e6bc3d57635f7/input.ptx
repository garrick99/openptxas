.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r16, %r3, 2;
    shr.u32 %r18, %r3, 2;
    mul.lo.s32 %r25, %r16, %r16;
    setp.eq.u32 %p1, %r18, 8;
    @%p1 mul.wide.u32 %rd14, %r25, %r16;
    shl.b64 %rd12, %rd14, 16;
    sub.u32 %r26, %r3, 255;
    sub.u32 %r20, %r18, %r3;
    shr.s32 %r6, %r26, 1;
    shr.s32 %r17, %r18, 16;
    and.b32 %r27, %r25, %r6;
    add.s32 %r16, %r6, %r3;
    setp.eq.s32 %p1, %r25, 31;
    shr.s64 %rd7, %rd14, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
