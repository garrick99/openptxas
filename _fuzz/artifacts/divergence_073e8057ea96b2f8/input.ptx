.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p3, %r3, %r3;
    setp.gt.u32 %p3, %r3, 1;
    @%p3 add.s32 %r14, %r3, %r3;
    or.b32 %r5, %r3, %r3;
    cvt.u64.u32 %rd10, %r14;
    sub.u32 %r13, %r3, 255;
    mul.wide.s32 %rd12, %r3, %r5;
    setp.hs.u32 %p4, %r14, 3;
    @%p4 mad.lo.u32 %r10, %r3, %r13, %r3;
    mad.lo.u32 %r26, %r5, %r3, %r14;
    cvt.s32.s64 %r18, %rd12;
    mad.lo.u32 %r20, %r3, %r5, %r3;
    mad.lo.s32 %r22, %r10, %r14, %r18;
    shr.s64 %rd13, %rd12, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
