.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r17, %r3, 1;
    mul.lo.u32 %r4, %r3, %r17;
    mul.lo.s32 %r8, %r3, 1;
    and.b32 %r23, %r4, 64;
    add.u32 %r6, %r17, %r17;
    setp.lt.s32 %p2, %r23, %r17;
    @!%p2 or.b32 %r15, %r23, %r8;
    cvt.s64.s32 %rd12, %r17;
    sub.u32 %r27, %r8, %r6;
    and.b32 %r6, %r15, %r27;
    shr.u32 %r9, %r4, 7;
    shr.u32 %r14, %r8, 30;
    setp.eq.u32 %p3, %r6, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
