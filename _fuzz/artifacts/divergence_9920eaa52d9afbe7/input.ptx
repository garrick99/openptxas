.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r27, %r3, %r3;
    max.u32 %r17, %r3, 16;
    max.s32 %r6, %r27, %r27;
    max.u32 %r6, %r27, %r27;
    shl.b32 %r18, %r3, 15;
    setp.ge.u32 %p3, %r17, 255;
    setp.lo.u32 %p2, %r18, %r17;
    @%p2 shl.b32 %r7, %r17, 2;
    sub.s32 %r8, %r27, %r3;
    sub.s32 %r9, %r7, %r3;
    add.u32 %r27, %r6, 4294967295;
    add.s32 %r6, %r7, %r18;
    mul.lo.s32 %r23, %r17, 1;
    setp.le.s32 %p4, %r6, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
