.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p4, %r3, %r3;
    @%p4 selp.b32 %r16, %r3, %r3, %p4;
    min.s32 %r21, %r16, %r3;
    mad.lo.s32 %r7, %r21, %r3, %r3;
    mul.wide.s32 %rd8, %r7, %r7;
    sub.s32 %r23, %r21, 5;
    and.b32 %r5, %r21, %r23;
    cvt.u32.u64 %r26, %rd8;
    shl.b64 %rd15, %rd8, 4;
    shr.u64 %rd14, %rd15, 48;
    shr.u64 %rd6, %rd8, 4;
    min.s64 %rd7, %rd15, %rd14;
    mul.lo.s32 %r19, %r16, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
