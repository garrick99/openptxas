.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p4, %r3, %r3;
    @!%p4 and.b32 %r17, %r3, 65535;
    setp.ne.s32 %p1, %r3, %r17;
    setp.le.u32 %p4, %r3, %r17;
    @!%p4 sub.s32 %r20, %r17, %r17;
    sub.u32 %r4, %r17, 5;
    shl.b32 %r17, %r20, 3;
    mad.lo.u32 %r11, %r3, %r17, %r20;
    max.s32 %r23, %r20, 7;
    max.s32 %r25, %r23, 15;
    mad.lo.u32 %r18, %r20, %r4, %r20;
    mad.lo.s32 %r5, %r11, %r4, %r17;
    mul.wide.u32 %rd8, %r25, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
