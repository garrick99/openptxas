.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r20, %r3, %r3;
    cvt.u64.u32 %rd7, %r20;
    sub.u32 %r6, %r3, 63;
    min.u32 %r11, %r20, %r3;
    mul.wide.s32 %rd8, %r11, %r11;
    min.s64 %rd14, %rd8, %rd8;
    cvt.s32.s64 %r12, %rd8;
    setp.lt.s32 %p4, %r3, %r6;
    selp.b32 %r23, %r11, %r11, %p4;
    cvt.s32.s64 %r8, %rd8;
    max.u64 %rd12, %rd8, %rd14;
    setp.eq.s32 %p2, %r20, %r12;
    @%p2 mad.lo.u32 %r5, %r23, %r6, %r11;
    max.u32 %r10, %r23, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
