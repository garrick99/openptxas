.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r8, %r3, %r3;
    setp.gt.s32 %p4, %r8, 65536;
    @%p4 shr.s32 %r8, %r3, 2;
    setp.hs.u32 %p4, %r3, 4294967295;
    cvt.s64.s32 %rd11, %r8;
    min.u32 %r19, %r3, 256;
    shl.b32 %r21, %r19, 15;
    min.u32 %r20, %r3, 65536;
    setp.ne.u32 %p1, %r3, %r3;
    max.s32 %r4, %r19, 3;
    add.u32 %r11, %r20, 0;
    cvt.s64.s32 %rd7, %r11;
    min.s32 %r19, %r4, %r19;
    and.b64 %rd10, %rd7, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
