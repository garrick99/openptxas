    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    shr.s64 %rd9, %rd9, 3;
    shr.s32 %r27, %r3, 16;
    or.b32 %r19, %r3, 2147483647;
    add.s32 %r13, %r3, 256;
    or.b64 %rd5, %rd9, %rd9;
    or.b32 %r13, %r13, %r3;
    add.u32 %r17, %r19, 0;
    add.s32 %r20, %r17, %r19;
    mad.lo.u32 %r12, %r13, %r20, %r27;
    cvt.s64.s32 %rd12, %r27;
    or.b32 %r27, %r12, 32;
    setp.hi.u32 %p3, %r13, 4294967295;
    @%p3 max.u32 %r5, %r3, 3;
