.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p4, %r3, 8;
    add.s32 %r24, %r3, %r3;
    cvt.s64.s32 %rd15, %r3;
    shr.s64 %rd11, %rd15, 4;
    sub.s32 %r24, %r24, 256;
    max.s32 %r18, %r24, %r3;
    cvt.s64.s32 %rd6, %r18;
    min.s32 %r8, %r18, 2147483647;
    shl.b32 %r19, %r8, 4;
    or.b32 %r23, %r24, %r24;
    shr.s32 %r27, %r3, 7;
    sub.s32 %r6, %r8, 1;
    mul.lo.u32 %r5, %r23, %r3;
    shl.b32 %r23, %r5, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
