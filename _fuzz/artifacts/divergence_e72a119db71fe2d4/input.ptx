.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r5, %r3, 32;
    cvt.s64.s32 %rd5, %r5;
    mul.lo.s32 %r9, %r5, 255;
    cvt.s64.s32 %rd14, %r9;
    shr.s64 %rd10, %rd5, 0;
    shr.u32 %r5, %r3, 31;
    min.u32 %r24, %r9, %r5;
    mul.wide.s32 %rd5, %r3, %r9;
    shr.u32 %r12, %r9, 4;
    xor.b64 %rd11, %rd10, %rd14;
    or.b32 %r13, %r12, %r24;
    mul.wide.u32 %rd15, %r3, %r5;
    setp.hs.u32 %p2, %r3, %r9;
    @!%p2 mul.wide.u32 %rd13, %r13, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
