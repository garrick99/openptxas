.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r4, %r3, %r3;
    mul.wide.s32 %rd10, %r3, %r3;
    shr.s64 %rd7, %rd10, 2;
    shl.b32 %r20, %r4, 1;
    and.b32 %r12, %r3, 255;
    cvt.u32.u64 %r9, %rd7;
    max.s32 %r4, %r12, %r12;
    xor.b32 %r7, %r20, %r12;
    or.b32 %r17, %r20, %r12;
    mul.lo.s32 %r4, %r4, %r4;
    mul.lo.u64 %rd8, %rd10, %rd10;
    max.u64 %rd11, %rd8, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
