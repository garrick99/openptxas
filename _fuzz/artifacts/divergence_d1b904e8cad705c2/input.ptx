.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    setp.ne.s32 %p2, %r3, 1;
    @!%p2 shr.s64 %rd11, %rd6, 16;
    add.u32 %r23, %r3, %r3;
    or.b32 %r26, %r3, 1;
    shr.u64 %rd13, %rd6, 3;
    min.s32 %r26, %r23, 31;
    xor.b32 %r23, %r3, 2;
    cvt.s32.s64 %r16, %rd6;
    and.b32 %r11, %r16, 16;
    or.b32 %r26, %r26, 15;
    min.s32 %r4, %r16, %r11;
    shl.b32 %r23, %r3, 7;
    min.s32 %r26, %r16, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
