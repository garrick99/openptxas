.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    add.u64 %rd9, %rd10, %rd10;
    add.u64 %rd11, %rd10, %rd9;
    shr.s64 %rd14, %rd10, 33;
    shl.b64 %rd5, %rd10, 32;
    add.s32 %r10, %r3, 256;
    and.b32 %r7, %r10, %r3;
    setp.le.s32 %p2, %r7, %r7;
    add.u64 %rd10, %rd9, %rd9;
    or.b32 %r11, %r3, 63;
    min.s32 %r18, %r10, 7;
    sub.u32 %r16, %r7, %r3;
    xor.b32 %r21, %r3, 7;
    max.s32 %r25, %r21, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
