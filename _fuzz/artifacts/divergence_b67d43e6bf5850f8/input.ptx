.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r6, %r3, 2147483648;
    setp.ne.s32 %p2, %r3, %r6;
    cvt.u64.u32 %rd11, %r3;
    mad.lo.s32 %r14, %r6, %r3, %r6;
    setp.ne.s32 %p1, %r6, 7;
    @!%p1 add.s64 %rd10, %rd11, %rd11;
    cvt.s64.s32 %rd14, %r6;
    shr.u64 %rd11, %rd10, 1;
    cvt.u32.u64 %r5, %rd10;
    or.b32 %r18, %r5, 0;
    shr.u64 %rd12, %rd10, 32;
    max.u32 %r21, %r6, 65535;
    xor.b32 %r10, %r6, 4;
    add.s32 %r22, %r18, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
