.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r4, %r3, %r3;
    cvt.u64.u32 %rd8, %r4;
    min.s32 %r7, %r4, 64;
    shr.s32 %r22, %r7, 4;
    min.u32 %r6, %r3, %r4;
    setp.gt.u32 %p4, %r3, 32;
    @%p4 cvt.u64.u32 %rd9, %r6;
    cvt.s64.s32 %rd10, %r4;
    xor.b32 %r26, %r7, 15;
    mul.wide.u32 %rd10, %r22, %r3;
    cvt.u64.u32 %rd15, %r26;
    max.u32 %r23, %r22, %r26;
    cvt.u64.u32 %rd15, %r7;
    selp.b32 %r16, %r4, %r23, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
