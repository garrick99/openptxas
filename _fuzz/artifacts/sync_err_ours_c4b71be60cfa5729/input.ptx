.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r25, %r3, 16;
    setp.lt.s32 %p2, %r3, %r25;
    min.u32 %r17, %r3, 4;
    mul.wide.s32 %rd12, %r3, %r25;
    shr.u64 %rd12, %rd12, 32;
    selp.b32 %r15, %r25, %r17, %p2;
    mul.lo.s32 %r24, %r15, %r15;
    setp.eq.u32 %p2, %r17, 3;
    @%p2 max.u32 %r13, %r3, %r17;
    mul.wide.u32 %rd6, %r17, %r13;
    selp.b32 %r5, %r15, %r25, %p2;
    shr.u32 %r26, %r13, 15;
    min.s64 %rd9, %rd12, %rd6;
    shr.s32 %r9, %r17, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
