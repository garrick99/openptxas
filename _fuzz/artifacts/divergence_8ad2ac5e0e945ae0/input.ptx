.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r24, %r3, 31;
    min.u32 %r13, %r3, %r3;
    shl.b32 %r11, %r24, 7;
    sub.s32 %r10, %r13, %r3;
    sub.s32 %r18, %r24, 1;
    setp.ge.u32 %p4, %r18, 255;
    @!%p4 cvt.u64.u32 %rd15, %r24;
    max.u32 %r7, %r18, %r10;
    mul.lo.s64 %rd11, %rd15, %rd15;
    max.u64 %rd11, %rd15, %rd15;
    xor.b64 %rd9, %rd11, %rd15;
    setp.lt.s32 %p2, %r3, %r18;
    @!%p2 xor.b32 %r17, %r18, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
