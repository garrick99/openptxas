.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.up.b32 %r14, %r0, 16, 0x1f, -1;
    add.u32 %r17, %r14, %r0;
    add.u32 %r14, %r14, %r0;
    xor.b32 %r10, %r17, %r14;
    max.u32 %r11, %r17, %r14;
    shfl.sync.up.b32 %r12, %r17, 16, 0x1f, -1;
    shfl.sync.up.b32 %r19, %r14, 2, 0x1f, -1;
    and.b32 %r13, %r17, %r3;
    min.u32 %r8, %r10, %r19;
    setp.lt.u32 %p1, %r3, %r19;
    vote.sync.ballot.b32 %r15, %p1, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
