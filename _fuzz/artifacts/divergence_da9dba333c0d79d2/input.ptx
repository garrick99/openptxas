.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    cvt.u64.u32 %rd11, %r3;
    max.u64 %rd5, %rd11, %rd11;
    shr.u32 %r14, %r3, 30;
    cvt.s32.s64 %r9, %rd12;
    mul.wide.s32 %rd15, %r3, %r3;
    shl.b32 %r10, %r9, 15;
    max.u32 %r19, %r9, 31;
    sub.s64 %rd9, %rd15, %rd12;
    shr.s32 %r21, %r19, 31;
    cvt.s64.s32 %rd7, %r9;
    max.s32 %r25, %r9, %r3;
    max.s32 %r12, %r25, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
