.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd15, %r3, %r3;
    shr.s32 %r19, %r3, 3;
    setp.le.s32 %p2, %r3, 31;
    setp.hi.u32 %p1, %r19, %r19;
    @%p1 or.b32 %r14, %r19, 255;
    sub.u32 %r23, %r19, %r3;
    max.u64 %rd10, %rd15, %rd15;
    or.b32 %r9, %r3, %r3;
    cvt.s32.s64 %r10, %rd10;
    or.b32 %r12, %r3, %r3;
    shr.s64 %rd12, %rd15, 7;
    shl.b64 %rd5, %rd15, 15;
    shr.s32 %r5, %r9, 7;
    cvt.s64.s32 %rd14, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
