.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    cvt.u32.u64 %r21, %rd7;
    shr.s64 %rd10, %rd7, 3;
    add.u64 %rd15, %rd10, %rd10;
    cvt.u64.u32 %rd9, %r21;
    and.b32 %r13, %r21, %r3;
    setp.gt.s32 %p3, %r3, 32;
    @%p3 selp.b32 %r17, %r3, %r3, %p3;
    max.s32 %r21, %r21, 63;
    mul.lo.u32 %r19, %r21, 7;
    shr.u64 %rd12, %rd15, 15;
    mul.wide.u32 %rd6, %r13, %r19;
    max.s32 %r26, %r17, 7;
    cvt.s32.s64 %r19, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
