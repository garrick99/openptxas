.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    shr.u32 %r4, %r3, 1;
    shr.s32 %r11, %r4, 15;
    max.u32 %r5, %r11, %r3;
    cvt.s64.s32 %rd5, %r5;
    cvt.u32.u64 %r11, %rd11;
    setp.hs.u32 %p2, %r5, 0;
    add.s32 %r22, %r4, %r4;
    shl.b32 %r27, %r4, 0;
    sub.u64 %rd12, %rd5, %rd5;
    mul.wide.s32 %rd11, %r11, %r4;
    mul.wide.s32 %rd13, %r27, %r5;
    mul.lo.u32 %r24, %r3, %r11;
    min.u32 %r10, %r27, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
