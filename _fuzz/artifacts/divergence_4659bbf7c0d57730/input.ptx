.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r5, %r3, 8;
    shl.b32 %r17, %r3, 1;
    add.u32 %r24, %r5, 5;
    xor.b32 %r22, %r3, %r3;
    min.u32 %r25, %r3, 5;
    add.s32 %r19, %r22, %r3;
    setp.ne.u32 %p3, %r22, 2147483648;
    @!%p3 max.u32 %r11, %r25, %r19;
    sub.s32 %r24, %r17, %r17;
    setp.ls.u32 %p3, %r24, %r5;
    or.b32 %r15, %r22, %r17;
    add.s32 %r27, %r11, 32;
    min.s32 %r23, %r27, 8;
    shr.s32 %r10, %r23, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
