.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd5, %r3, %r3;
    setp.gt.s32 %p4, %r3, %r3;
    setp.ge.s32 %p2, %r3, 256;
    @%p2 or.b32 %r7, %r3, %r3;
    max.s32 %r4, %r7, 256;
    cvt.u32.u64 %r7, %rd5;
    and.b32 %r12, %r4, %r3;
    setp.eq.s32 %p3, %r12, %r3;
    and.b32 %r6, %r7, %r12;
    mul.wide.s32 %rd6, %r3, %r6;
    shl.b64 %rd10, %rd6, 3;
    mul.wide.s32 %rd6, %r4, %r7;
    cvt.s64.s32 %rd8, %r7;
    mul.wide.u32 %rd15, %r7, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
