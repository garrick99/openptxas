.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r6, %r0, %r0;
    shfl.sync.up.b32 %r10, %r3, 2, 0x1f, -1;
    setp.ge.u32 %p3, %r6, %r10;
    vote.sync.ballot.b32 %r14, %p3, -1;
    add.u32 %r4, %r14, %r3;
    setp.lt.u32 %p3, %r6, %r0;
    vote.sync.ballot.b32 %r11, %p3, -1;
    add.u32 %r8, %r14, %r14;
    xor.b32 %r13, %r0, %r6;
    shfl.sync.idx.b32 %r14, %r3, 0, 0x1f, -1;
    setp.lt.u32 %p2, %r4, 65535;
    vote.sync.ballot.b32 %r15, %p2, -1;
    max.u32 %r19, %r4, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
