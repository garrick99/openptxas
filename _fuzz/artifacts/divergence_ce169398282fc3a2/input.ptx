.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r26, %r3, 4;
    add.s32 %r9, %r26, 2;
    mul.wide.u32 %rd5, %r9, %r26;
    mul.lo.s64 %rd11, %rd5, %rd5;
    setp.gt.s32 %p2, %r9, %r26;
    @%p2 min.u32 %r6, %r9, %r3;
    mad.lo.s32 %r22, %r26, %r26, %r3;
    mul.lo.u64 %rd8, %rd11, %rd11;
    mad.lo.u32 %r18, %r9, %r9, %r3;
    mad.lo.u32 %r16, %r26, %r18, %r9;
    shl.b32 %r21, %r16, 16;
    mul.lo.s32 %r5, %r22, %r9;
    or.b32 %r26, %r5, %r22;
    shl.b64 %rd6, %rd5, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
