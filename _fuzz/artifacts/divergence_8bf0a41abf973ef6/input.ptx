.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p4, %r3, %r3;
    @%p4 add.s32 %r16, %r3, %r3;
    mad.lo.u32 %r24, %r16, %r3, %r16;
    min.s32 %r9, %r24, 65535;
    setp.eq.u32 %p2, %r3, %r9;
    @%p2 mul.wide.u32 %rd14, %r16, %r16;
    mul.lo.u32 %r13, %r24, 4;
    cvt.s32.s64 %r22, %rd14;
    selp.b32 %r4, %r9, %r16, %p4;
    and.b32 %r8, %r9, %r24;
    shl.b32 %r20, %r16, 4;
    max.s32 %r27, %r8, 64;
    shr.u32 %r12, %r27, 2;
    min.s32 %r17, %r24, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
