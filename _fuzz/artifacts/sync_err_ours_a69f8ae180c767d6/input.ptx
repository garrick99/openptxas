.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    shr.u32 %r22, %r3, 2;
    min.s32 %r13, %r3, %r22;
    max.u32 %r16, %r3, %r3;
    cvt.s64.s32 %rd9, %r13;
    max.u32 %r19, %r22, %r22;
    cvt.u64.u32 %rd6, %r19;
    mul.lo.s64 %rd7, %rd10, %rd6;
    max.s32 %r11, %r19, %r16;
    sub.u32 %r22, %r13, %r11;
    sub.u64 %rd13, %rd10, %rd9;
    setp.lt.s32 %p1, %r16, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
