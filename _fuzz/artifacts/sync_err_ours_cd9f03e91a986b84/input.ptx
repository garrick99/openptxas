.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r20, %r3, %r3;
    shl.b32 %r21, %r3, 30;
    add.u32 %r20, %r21, %r20;
    mul.lo.u32 %r11, %r20, %r3;
    mul.wide.s32 %rd10, %r20, %r3;
    xor.b32 %r10, %r20, %r11;
    sub.s32 %r8, %r21, %r10;
    shl.b32 %r21, %r20, 7;
    cvt.s64.s32 %rd14, %r20;
    mad.lo.u32 %r7, %r3, %r21, %r20;
    and.b32 %r9, %r21, %r20;
    mul.wide.s32 %rd11, %r21, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
