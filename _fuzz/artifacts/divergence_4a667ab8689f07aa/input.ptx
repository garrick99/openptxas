.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r6, %r3, %r3, %r3;
    add.s32 %r11, %r6, %r6;
    cvt.u64.u32 %rd6, %r6;
    or.b32 %r25, %r11, %r11;
    xor.b32 %r7, %r6, 31;
    max.s32 %r19, %r3, %r3;
    and.b32 %r13, %r25, 255;
    shl.b32 %r15, %r3, 30;
    add.u32 %r24, %r6, 0;
    add.s64 %rd6, %rd6, %rd6;
    cvt.u32.u64 %r25, %rd6;
    shl.b64 %rd11, %rd6, 31;
    add.u32 %r15, %r7, 15;
    mul.wide.u32 %rd10, %r24, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
