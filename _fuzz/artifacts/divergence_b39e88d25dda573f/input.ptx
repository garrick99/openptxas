.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    cvt.u32.u64 %r7, %rd9;
    mul.lo.s32 %r9, %r7, 1;
    cvt.u64.u32 %rd5, %r9;
    max.u32 %r18, %r9, 63;
    mul.lo.u32 %r14, %r9, 64;
    add.u32 %r12, %r7, %r7;
    mad.lo.u32 %r12, %r12, %r14, %r12;
    max.s32 %r6, %r14, %r18;
    mad.lo.u32 %r13, %r6, %r7, %r18;
    add.u32 %r12, %r7, 32;
    xor.b32 %r26, %r14, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
