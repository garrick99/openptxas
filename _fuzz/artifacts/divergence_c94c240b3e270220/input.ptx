.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p1, %r3, 4294967295;
    @!%p1 min.s32 %r16, %r3, %r3;
    mul.lo.s32 %r4, %r3, %r3;
    selp.b32 %r24, %r16, %r3, %p1;
    mul.wide.s32 %rd15, %r4, %r16;
    or.b32 %r8, %r3, 2;
    mul.wide.s32 %rd7, %r8, %r3;
    mad.lo.u32 %r27, %r8, %r24, %r3;
    shl.b32 %r13, %r27, 0;
    sub.u32 %r8, %r24, 2;
    setp.hi.u32 %p1, %r27, 65535;
    @%p1 max.s32 %r17, %r24, %r24;
    xor.b32 %r26, %r8, %r4;
    min.u32 %r15, %r16, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
