.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r18, %r3, %r3;
    shl.b32 %r9, %r18, 30;
    cvt.s64.s32 %rd10, %r3;
    or.b32 %r9, %r9, 255;
    mad.lo.u32 %r25, %r3, %r3, %r9;
    shl.b32 %r10, %r25, 4;
    setp.hs.u32 %p2, %r18, %r9;
    @%p2 min.s32 %r7, %r18, %r10;
    cvt.s64.s32 %rd6, %r25;
    setp.le.u32 %p4, %r3, 32;
    @%p4 mad.lo.s32 %r6, %r7, %r18, %r9;
    mul.wide.s32 %rd6, %r10, %r7;
    mul.lo.s32 %r18, %r7, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
