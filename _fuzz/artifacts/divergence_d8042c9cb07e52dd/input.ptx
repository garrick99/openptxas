.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r27, %r3, %r3;
    mad.lo.s32 %r13, %r3, %r27, %r3;
    cvt.u64.u32 %rd7, %r27;
    or.b32 %r23, %r13, %r13;
    cvt.u64.u32 %rd10, %r27;
    xor.b32 %r10, %r13, %r27;
    cvt.u32.u64 %r26, %rd10;
    setp.ls.u32 %p4, %r3, %r26;
    @!%p4 shl.b32 %r27, %r10, 4;
    xor.b32 %r21, %r27, 16;
    max.s32 %r6, %r26, %r3;
    mul.lo.s32 %r24, %r27, %r26;
    cvt.u32.u64 %r12, %rd10;
    mad.lo.u32 %r14, %r13, %r24, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
