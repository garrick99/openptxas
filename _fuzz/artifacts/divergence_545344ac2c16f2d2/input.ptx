.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hi.u32 %p2, %r3, %r3;
    @%p2 max.u32 %r23, %r3, %r3;
    cvt.s64.s32 %rd5, %r23;
    min.s32 %r16, %r23, 7;
    mul.lo.s64 %rd8, %rd5, %rd5;
    add.s64 %rd7, %rd5, %rd8;
    selp.b32 %r7, %r16, %r23, %p2;
    mul.lo.s64 %rd12, %rd7, %rd5;
    mul.lo.u32 %r24, %r7, 256;
    min.u32 %r26, %r16, %r23;
    add.s32 %r26, %r3, %r23;
    mad.lo.s32 %r12, %r3, %r16, %r16;
    setp.lt.u32 %p4, %r3, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
