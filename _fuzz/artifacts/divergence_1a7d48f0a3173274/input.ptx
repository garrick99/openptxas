.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    cvt.u64.u32 %rd15, %r3;
    setp.lt.s32 %p1, %r3, 2147483647;
    setp.eq.s32 %p3, %r3, %r3;
    @!%p3 cvt.s64.s32 %rd7, %r3;
    selp.b32 %r9, %r3, %r3, %p1;
    mul.lo.u32 %r21, %r9, %r9;
    add.u32 %r21, %r3, %r21;
    min.u32 %r14, %r9, %r21;
    mul.wide.s32 %rd8, %r9, %r3;
    xor.b32 %r6, %r9, 32;
    setp.le.s32 %p3, %r9, 1;
    setp.gt.s32 %p2, %r14, 15;
    @%p2 sub.s32 %r4, %r21, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
