.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    max.s64 %rd10, %rd9, %rd9;
    add.u32 %r19, %r3, 3;
    cvt.u64.u32 %rd11, %r19;
    setp.gt.s32 %p2, %r3, 7;
    @%p2 max.u32 %r15, %r3, 65535;
    min.u32 %r4, %r15, 255;
    min.s32 %r18, %r19, %r4;
    max.u64 %rd14, %rd10, %rd11;
    mad.lo.s32 %r24, %r15, %r15, %r4;
    add.u32 %r18, %r15, 65536;
    xor.b32 %r15, %r15, 2;
    setp.ne.s32 %p1, %r24, 8;
    @%p1 min.s32 %r15, %r24, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
