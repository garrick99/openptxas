.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r24, %r3, %r3;
    cvt.s64.s32 %rd11, %r24;
    setp.ne.s32 %p1, %r24, %r3;
    @!%p1 mad.lo.u32 %r14, %r24, %r24, %r24;
    max.u32 %r23, %r14, 255;
    min.s32 %r23, %r14, %r24;
    max.s64 %rd7, %rd11, %rd11;
    xor.b64 %rd8, %rd7, %rd7;
    max.u32 %r27, %r24, 15;
    mul.lo.s64 %rd13, %rd8, %rd7;
    sub.s32 %r23, %r3, %r23;
    min.u32 %r20, %r23, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
