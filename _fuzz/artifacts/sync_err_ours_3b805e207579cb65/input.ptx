.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r8, %r3, %r3;
    setp.ne.u32 %p1, %r8, %r3;
    @%p1 min.u32 %r4, %r3, %r3;
    selp.b32 %r21, %r8, %r3, %p1;
    add.s32 %r15, %r8, %r4;
    and.b32 %r25, %r21, %r21;
    shl.b32 %r19, %r21, 0;
    sub.s32 %r25, %r8, 65535;
    selp.b32 %r22, %r21, %r15, %p1;
    cvt.u64.u32 %rd6, %r25;
    sub.s32 %r18, %r21, 3;
    shr.u32 %r25, %r18, 30;
    xor.b32 %r7, %r15, 8;
    setp.ge.s32 %p2, %r19, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
