.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r20, %r3, %r3;
    setp.hs.u32 %p4, %r3, 15;
    @!%p4 min.u32 %r7, %r20, %r20;
    sub.s32 %r6, %r20, %r20;
    add.s32 %r24, %r7, %r6;
    mad.lo.s32 %r10, %r7, %r20, %r3;
    cvt.u64.u32 %rd10, %r20;
    shr.s32 %r20, %r3, 7;
    mul.lo.s32 %r13, %r7, %r3;
    mul.lo.u64 %rd11, %rd10, %rd10;
    or.b32 %r16, %r24, %r3;
    xor.b32 %r13, %r6, 32;
    setp.ne.u32 %p3, %r20, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
