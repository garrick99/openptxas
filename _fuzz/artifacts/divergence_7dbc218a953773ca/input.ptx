.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r25, %r3, 1;
    sub.s32 %r24, %r3, %r3;
    shr.u32 %r22, %r25, 15;
    or.b32 %r18, %r25, 2;
    mad.lo.s32 %r24, %r3, %r3, %r22;
    shr.s32 %r27, %r24, 2;
    mul.lo.u32 %r21, %r18, %r22;
    sub.s32 %r16, %r27, 256;
    mul.lo.s32 %r10, %r3, 65535;
    or.b32 %r17, %r21, 64;
    setp.le.s32 %p4, %r17, %r18;
    @%p4 cvt.s64.s32 %rd10, %r22;
    selp.b32 %r11, %r22, %r25, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
