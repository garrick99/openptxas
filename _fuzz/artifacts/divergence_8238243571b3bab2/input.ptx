.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r14, %r3, 64;
    add.u32 %r24, %r14, %r14;
    mad.lo.u32 %r24, %r24, %r24, %r14;
    cvt.s64.s32 %rd9, %r24;
    xor.b32 %r22, %r24, %r14;
    min.s32 %r8, %r24, 7;
    setp.le.s32 %p1, %r24, %r24;
    @!%p1 sub.s32 %r13, %r24, %r24;
    mad.lo.u32 %r22, %r8, %r14, %r22;
    mul.lo.u32 %r14, %r24, 8;
    max.s32 %r23, %r13, %r3;
    max.s32 %r19, %r14, %r23;
    or.b32 %r13, %r13, 32;
    mul.wide.u32 %rd13, %r8, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
