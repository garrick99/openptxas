.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r20, %r3, 15;
    cvt.s64.s32 %rd10, %r3;
    cvt.s32.s64 %r26, %rd10;
    mad.lo.u32 %r9, %r20, %r3, %r20;
    setp.hi.u32 %p2, %r26, 15;
    @!%p2 mul.lo.s32 %r19, %r20, %r9;
    sub.s32 %r26, %r3, %r9;
    or.b32 %r23, %r20, 5;
    max.s32 %r7, %r9, %r26;
    cvt.s32.s64 %r9, %rd10;
    setp.lo.u32 %p2, %r20, 65536;
    @%p2 max.s32 %r10, %r26, 16;
    mul.wide.u32 %rd12, %r26, %r10;
    setp.lt.s32 %p3, %r9, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
