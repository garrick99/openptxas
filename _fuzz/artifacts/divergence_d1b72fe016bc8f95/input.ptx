.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r10, %r3, 15;
    max.u32 %r11, %r3, 7;
    min.s32 %r25, %r11, 5;
    cvt.s64.s32 %rd15, %r11;
    sub.s32 %r22, %r11, %r25;
    setp.ge.u32 %p2, %r22, 4294967295;
    @!%p2 mul.wide.s32 %rd6, %r3, %r10;
    cvt.u64.u32 %rd15, %r25;
    shl.b32 %r9, %r22, 7;
    mul.lo.s64 %rd13, %rd6, %rd15;
    sub.u32 %r4, %r25, 64;
    mad.lo.u32 %r17, %r4, %r3, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
