.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r19, %r3, %r3;
    mul.lo.s32 %r21, %r3, %r19;
    sub.u32 %r25, %r21, %r19;
    and.b32 %r26, %r25, %r25;
    setp.ge.s32 %p2, %r26, 8;
    @%p2 selp.b32 %r10, %r26, %r21, %p2;
    mul.wide.s32 %rd11, %r19, %r3;
    shl.b32 %r14, %r10, 4;
    sub.s32 %r16, %r21, %r19;
    setp.ne.s32 %p2, %r19, %r19;
    @!%p2 add.s32 %r18, %r25, 31;
    cvt.s64.s32 %rd8, %r3;
    shl.b64 %rd10, %rd8, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
