.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r9, %r3, 3;
    shr.u32 %r16, %r3, 15;
    mad.lo.s32 %r9, %r9, %r16, %r9;
    mad.lo.u32 %r4, %r9, %r16, %r3;
    min.u32 %r25, %r9, 31;
    add.u32 %r25, %r4, %r3;
    and.b32 %r25, %r16, 65536;
    min.s32 %r17, %r16, %r9;
    mad.lo.s32 %r19, %r16, %r3, %r3;
    cvt.s64.s32 %rd12, %r25;
    sub.s32 %r9, %r9, %r17;
    setp.le.s32 %p3, %r17, %r25;
    @!%p3 mul.lo.u32 %r13, %r19, %r9;
    sub.u64 %rd15, %rd12, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
