.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd12, %r3, %r3;
    mad.lo.s32 %r12, %r3, %r3, %r3;
    setp.eq.u32 %p1, %r3, 255;
    add.u64 %rd5, %rd12, %rd12;
    sub.s32 %r19, %r12, 64;
    mad.lo.s32 %r12, %r19, %r12, %r19;
    max.s32 %r27, %r3, 256;
    mul.wide.s32 %rd8, %r27, %r12;
    add.u32 %r7, %r19, %r19;
    setp.le.s32 %p3, %r3, %r19;
    @%p3 add.u32 %r4, %r12, %r19;
    selp.b32 %r5, %r27, %r27, %p1;
    shl.b32 %r8, %r4, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
