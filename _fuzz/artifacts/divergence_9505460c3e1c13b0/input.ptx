    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r18, %r3, %r3;
    cvt.u64.u32 %rd5, %r18;
    max.u32 %r22, %r3, 2147483648;
    xor.b32 %r19, %r18, %r22;
    xor.b32 %r12, %r22, %r22;
    min.u32 %r27, %r18, %r12;
    sub.s32 %r27, %r3, 16;
    setp.le.u32 %p2, %r3, %r27;
    @%p2 selp.b32 %r17, %r27, %r18, %p2;
    mad.lo.s32 %r7, %r17, %r17, %r12;
    mul.lo.s32 %r20, %r18, %r12;
    max.u32 %r10, %r19, 32;
    selp.b32 %r5, %r7, %r7, %p2;
    mul.wide.s32 %rd8, %r12, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
