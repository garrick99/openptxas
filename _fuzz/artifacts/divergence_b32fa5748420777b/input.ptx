.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r23, %r3, 2;
    sub.s32 %r8, %r23, %r3;
    min.u32 %r11, %r8, 31;
    sub.u32 %r12, %r3, %r23;
    cvt.s64.s32 %rd13, %r12;
    shr.u32 %r27, %r23, 3;
    shl.b64 %rd10, %rd13, 33;
    setp.lt.u32 %p1, %r8, %r23;
    @%p1 cvt.u32.u64 %r9, %rd13;
    selp.b32 %r4, %r11, %r12, %p1;
    add.u64 %rd11, %rd13, %rd10;
    mul.lo.u32 %r23, %r12, %r12;
    mul.lo.u32 %r27, %r27, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
