.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r8, %r3, %r3;
    setp.lo.u32 %p4, %r3, 255;
    cvt.s64.s32 %rd11, %r3;
    sub.s32 %r10, %r8, %r3;
    shr.u64 %rd8, %rd11, 15;
    sub.s32 %r21, %r8, 2;
    cvt.u64.u32 %rd11, %r10;
    sub.u64 %rd14, %rd11, %rd11;
    sub.u32 %r9, %r10, %r21;
    max.u32 %r17, %r3, %r21;
    min.s32 %r12, %r8, %r10;
    add.u64 %rd15, %rd8, %rd14;
    selp.b32 %r23, %r10, %r21, %p4;
    mul.wide.u32 %rd5, %r12, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
