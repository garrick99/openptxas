.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r7, %r3, %r3;
    setp.gt.u32 %p3, %r3, 255;
    @!%p3 cvt.u64.u32 %rd6, %r3;
    add.s32 %r9, %r3, 64;
    add.s32 %r22, %r7, %r3;
    mul.wide.s32 %rd6, %r22, %r7;
    shr.s64 %rd14, %rd6, 4;
    mul.lo.s32 %r13, %r7, %r22;
    mul.wide.u32 %rd8, %r3, %r22;
    add.s32 %r8, %r9, 3;
    or.b32 %r16, %r8, 1;
    setp.eq.s32 %p2, %r16, %r8;
    @%p2 shr.u32 %r17, %r22, 15;
    setp.lt.u32 %p1, %r8, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
