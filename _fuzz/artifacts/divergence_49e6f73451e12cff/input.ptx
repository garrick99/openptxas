    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r7, %r3, %r3;
    setp.ge.s32 %p4, %r3, %r7;
    cvt.s64.s32 %rd5, %r7;
    mad.lo.u32 %r7, %r7, %r7, %r3;
    mul.lo.u32 %r9, %r3, 65536;
    mad.lo.u32 %r26, %r7, %r9, %r3;
    mul.lo.u32 %r27, %r9, 2147483648;
