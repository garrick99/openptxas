.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r27, %r3, %r3;
    setp.gt.u32 %p4, %r27, %r3;
    @%p4 and.b32 %r4, %r27, 15;
    mul.lo.u32 %r6, %r4, %r4;
    and.b32 %r9, %r4, %r6;
    shl.b32 %r17, %r9, 2;
    or.b32 %r27, %r9, %r9;
    and.b32 %r22, %r27, %r3;
    max.u32 %r4, %r6, %r9;
    setp.ne.s32 %p3, %r9, %r3;
    shl.b32 %r15, %r6, 16;
    sub.u32 %r5, %r3, %r22;
    cvt.u64.u32 %rd8, %r17;
    add.s32 %r16, %r9, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
