.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r12, %r3, 0;
    xor.b32 %r20, %r3, %r3;
    cvt.s64.s32 %rd5, %r3;
    shr.s64 %rd12, %rd5, 2;
    setp.gt.u32 %p2, %r20, %r12;
    @%p2 mad.lo.s32 %r9, %r3, %r12, %r12;
    mul.wide.s32 %rd9, %r12, %r3;
    mul.lo.s32 %r13, %r12, %r12;
    setp.lo.u32 %p3, %r20, %r13;
    and.b32 %r6, %r13, %r20;
    selp.b32 %r26, %r13, %r9, %p2;
    mad.lo.u32 %r18, %r26, %r12, %r12;
    shr.u32 %r5, %r6, 30;
    selp.b32 %r5, %r26, %r13, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
