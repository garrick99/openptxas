.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r24, %r3, 7;
    sub.u32 %r12, %r24, 1;
    mul.wide.s32 %rd11, %r3, %r12;
    max.s64 %rd14, %rd11, %rd11;
    shl.b32 %r9, %r3, 7;
    max.u32 %r21, %r24, %r12;
    add.s32 %r12, %r9, %r21;
    and.b32 %r11, %r12, 63;
    xor.b32 %r23, %r12, %r12;
    min.u32 %r23, %r3, %r9;
    mad.lo.s32 %r17, %r23, %r9, %r24;
    min.s32 %r12, %r23, %r3;
    min.s32 %r20, %r9, 3;
    setp.hi.u32 %p1, %r11, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
