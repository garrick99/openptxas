.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r14, %r3, 30;
    cvt.s64.s32 %rd5, %r3;
    shl.b32 %r14, %r14, 2;
    max.u32 %r7, %r14, %r14;
    mul.wide.s32 %rd10, %r7, %r14;
    cvt.u64.u32 %rd9, %r14;
    shr.s64 %rd7, %rd9, 1;
    mad.lo.u32 %r14, %r3, %r14, %r7;
    mul.wide.u32 %rd11, %r7, %r7;
    mad.lo.s32 %r11, %r3, %r14, %r7;
    setp.le.s32 %p4, %r14, %r14;
    or.b32 %r13, %r3, 63;
    selp.b32 %r13, %r7, %r3, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
