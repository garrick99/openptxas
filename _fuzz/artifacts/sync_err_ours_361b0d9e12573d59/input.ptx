.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r10, %r3, 1;
    add.u32 %r24, %r10, 4294967295;
    mul.lo.s32 %r27, %r24, %r24;
    mul.wide.u32 %rd15, %r3, %r27;
    or.b32 %r17, %r3, %r3;
    setp.lt.s32 %p2, %r10, 4294967295;
    setp.gt.s32 %p4, %r27, %r3;
    add.s32 %r16, %r17, %r17;
    or.b64 %rd15, %rd15, %rd15;
    shr.u32 %r22, %r24, 30;
    shr.u32 %r6, %r24, 3;
    add.s32 %r25, %r22, 1;
    sub.u32 %r6, %r27, 4;
    max.s32 %r9, %r3, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
