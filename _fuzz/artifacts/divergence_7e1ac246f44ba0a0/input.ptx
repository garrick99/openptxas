.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p4, %r3, %r3;
    mul.lo.u32 %r20, %r3, %r3;
    min.u32 %r16, %r20, %r20;
    max.s32 %r4, %r20, %r16;
    sub.u32 %r25, %r3, %r4;
    and.b32 %r24, %r16, %r20;
    cvt.u64.u32 %rd6, %r4;
    shr.s64 %rd7, %rd6, 3;
    add.u32 %r22, %r20, 15;
    min.s32 %r20, %r16, %r22;
    mul.lo.u32 %r25, %r4, 65536;
    setp.le.s32 %p1, %r25, %r22;
    setp.gt.s32 %p3, %r24, %r20;
    @%p3 shr.u64 %rd6, %rd6, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
