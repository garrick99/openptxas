.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    shl.b32 %r22, %r3, 1;
    shr.u32 %r25, %r3, 16;
    max.u32 %r7, %r25, %r3;
    add.s32 %r13, %r7, 3;
    and.b32 %r11, %r3, %r3;
    max.u64 %rd9, %rd8, %rd8;
    shr.u64 %rd11, %rd9, 15;
    setp.le.s32 %p3, %r22, %r7;
    shr.u32 %r22, %r11, 7;
    cvt.s32.s64 %r22, %rd9;
    cvt.u32.u64 %r16, %rd8;
    mad.lo.s32 %r16, %r3, %r7, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
