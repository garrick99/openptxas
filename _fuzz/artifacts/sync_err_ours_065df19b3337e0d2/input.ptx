    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p3, %r3, 2147483648;
    @%p3 selp.b32 %r15, %r3, %r3, %p3;
    and.b32 %r21, %r3, %r15;
