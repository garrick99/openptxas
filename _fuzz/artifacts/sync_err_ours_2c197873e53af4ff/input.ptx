.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    shl.b64 %rd8, %rd12, 33;
    mul.lo.u32 %r5, %r3, %r3;
    sub.s32 %r9, %r5, %r3;
    shl.b64 %rd12, %rd12, 0;
    min.s64 %rd8, %rd12, %rd12;
    cvt.s32.s64 %r13, %rd8;
    shl.b32 %r14, %r9, 7;
    mul.lo.s32 %r27, %r3, 255;
    or.b32 %r27, %r3, %r5;
    xor.b32 %r21, %r14, %r13;
    cvt.u32.u64 %r12, %rd12;
    sub.u32 %r4, %r13, %r13;
    max.s32 %r8, %r3, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
