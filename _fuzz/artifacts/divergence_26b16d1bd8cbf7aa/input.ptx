.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    max.u32 %r19, %r3, %r3;
    and.b32 %r19, %r3, 2147483647;
    xor.b32 %r5, %r3, %r19;
    setp.ge.s32 %p1, %r3, %r19;
    @!%p1 shl.b32 %r26, %r5, 31;
    selp.b32 %r5, %r19, %r3, %p1;
    add.s32 %r9, %r3, 2;
    shr.u64 %rd13, %rd7, 62;
    shr.u32 %r11, %r9, 2;
    or.b32 %r7, %r19, %r26;
    mul.wide.s32 %rd5, %r3, %r26;
    setp.gt.s32 %p2, %r19, 0;
    @%p2 xor.b32 %r7, %r3, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
