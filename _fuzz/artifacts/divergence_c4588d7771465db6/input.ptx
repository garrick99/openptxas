.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r11, %r3, 63;
    sub.u32 %r17, %r3, 31;
    cvt.s64.s32 %rd15, %r17;
    and.b64 %rd5, %rd15, %rd15;
    cvt.u64.u32 %rd14, %r11;
    sub.u32 %r6, %r17, 4294967295;
    or.b32 %r25, %r17, 32;
    or.b32 %r24, %r11, %r17;
    min.u32 %r9, %r24, 32;
    max.s32 %r6, %r6, 4;
    mad.lo.u32 %r26, %r9, %r3, %r17;
    cvt.u32.u64 %r22, %rd15;
    xor.b32 %r25, %r24, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
