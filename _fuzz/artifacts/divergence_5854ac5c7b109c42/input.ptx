.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p3, %r3, %r3;
    min.u32 %r24, %r3, 1;
    add.s32 %r14, %r24, %r3;
    shr.u32 %r20, %r14, 2;
    shr.u32 %r25, %r3, 15;
    min.s32 %r4, %r14, 16;
    max.s32 %r8, %r25, %r20;
    mul.lo.s32 %r25, %r24, %r20;
    min.s32 %r8, %r4, %r14;
    selp.b32 %r5, %r8, %r20, %p3;
    selp.b32 %r19, %r3, %r3, %p3;
    selp.b32 %r11, %r24, %r14, %p3;
    min.s32 %r24, %r14, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
