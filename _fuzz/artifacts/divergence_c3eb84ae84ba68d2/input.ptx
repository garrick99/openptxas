.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r26, %r3, 4294967295;
    max.s32 %r6, %r26, 64;
    max.u32 %r13, %r6, 8;
    shr.u32 %r15, %r26, 15;
    sub.u32 %r4, %r15, %r13;
    add.u32 %r15, %r3, %r15;
    cvt.u64.u32 %rd5, %r6;
    shr.s64 %rd8, %rd5, 32;
    mul.wide.s32 %rd12, %r15, %r6;
    mad.lo.s32 %r19, %r4, %r13, %r3;
    mad.lo.s32 %r22, %r19, %r4, %r4;
    cvt.s64.s32 %rd11, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
