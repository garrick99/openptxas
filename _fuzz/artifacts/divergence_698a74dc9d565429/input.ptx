.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r16, %r3, 64;
    cvt.s64.s32 %rd7, %r16;
    shr.u64 %rd9, %rd7, 31;
    and.b64 %rd12, %rd9, %rd7;
    shr.s64 %rd11, %rd12, 15;
    mad.lo.u32 %r12, %r16, %r16, %r3;
    max.u32 %r16, %r12, %r16;
    cvt.s32.s64 %r13, %rd9;
    shr.u32 %r11, %r13, 16;
    sub.s32 %r11, %r16, 4;
    sub.u32 %r20, %r16, 3;
    setp.hi.u32 %p1, %r20, %r3;
    @%p1 xor.b32 %r11, %r13, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
