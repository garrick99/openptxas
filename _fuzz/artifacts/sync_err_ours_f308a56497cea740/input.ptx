.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r21, %r3, 16;
    shr.s32 %r17, %r3, 1;
    setp.ge.s32 %p3, %r17, 65535;
    @%p3 add.s32 %r23, %r17, %r21;
    max.s32 %r14, %r17, %r23;
    shr.s32 %r5, %r23, 0;
    cvt.s64.s32 %rd13, %r23;
    mul.wide.s32 %rd6, %r17, %r14;
    shr.s64 %rd9, %rd13, 0;
    min.s32 %r8, %r23, %r14;
    cvt.u32.u64 %r10, %rd6;
    and.b32 %r18, %r17, 256;
    add.s32 %r8, %r17, %r5;
    shr.s32 %r14, %r3, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
