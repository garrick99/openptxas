.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.bfly.b32 %r5, %r3, 16, 0x1f, -1;
    shfl.sync.bfly.b32 %r9, %r5, 8, 0x1f, -1;
    max.u32 %r4, %r9, %r3;
    max.u32 %r13, %r3, %r9;
    and.b32 %r13, %r13, %r5;
    shfl.sync.down.b32 %r18, %r4, 8, 0x1f, -1;
    setp.eq.u32 %p2, %r13, 255;
    vote.sync.ballot.b32 %r17, %p2, -1;
    max.u32 %r17, %r3, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
