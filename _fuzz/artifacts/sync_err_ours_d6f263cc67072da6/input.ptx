.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    shr.s64 %rd10, %rd14, 32;
    sub.s32 %r12, %r3, 2147483647;
    add.s32 %r5, %r12, 63;
    shr.u32 %r24, %r3, 0;
    setp.ge.s32 %p4, %r5, 63;
    mad.lo.s32 %r22, %r5, %r5, %r12;
    min.s64 %rd13, %rd14, %rd10;
    mul.wide.s32 %rd8, %r12, %r5;
    min.u32 %r20, %r22, %r3;
    setp.le.s32 %p4, %r3, %r3;
    @!%p4 mul.wide.u32 %rd7, %r20, %r12;
    sub.u32 %r12, %r22, 8;
    min.s32 %r4, %r24, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
