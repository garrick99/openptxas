.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r13, %r3, 5;
    min.s32 %r25, %r13, %r13;
    cvt.s64.s32 %rd10, %r25;
    or.b64 %rd10, %rd10, %rd10;
    max.u64 %rd6, %rd10, %rd10;
    mad.lo.s32 %r23, %r13, %r13, %r25;
    or.b32 %r4, %r25, %r13;
    sub.s32 %r17, %r3, %r3;
    mad.lo.s32 %r26, %r4, %r25, %r3;
    mul.lo.s32 %r20, %r3, 256;
    sub.u32 %r11, %r3, %r26;
    shr.s32 %r16, %r3, 7;
    mul.wide.s32 %rd9, %r25, %r25;
    min.u32 %r21, %r26, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
