.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    shr.s64 %rd13, %rd15, 16;
    mad.lo.u32 %r14, %r3, %r3, %r3;
    cvt.u32.u64 %r7, %rd13;
    cvt.u32.u64 %r5, %rd13;
    mad.lo.s32 %r11, %r7, %r3, %r14;
    mul.lo.u32 %r11, %r11, %r3;
    max.u32 %r16, %r7, 2147483648;
    mul.lo.u32 %r19, %r16, %r5;
    sub.u32 %r5, %r14, %r16;
    setp.ne.s32 %p1, %r3, 5;
    add.s64 %rd7, %rd13, %rd15;
    setp.ne.s32 %p4, %r3, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
