.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    mul.wide.s32 %rd10, %r3, %r3;
    mad.lo.s32 %r20, %r3, %r3, %r3;
    shr.u32 %r23, %r20, 2;
    sub.s32 %r22, %r3, 4;
    shr.s32 %r25, %r20, 15;
    shr.u64 %rd11, %rd10, 33;
    cvt.s32.s64 %r11, %rd12;
    or.b32 %r27, %r22, %r25;
    mad.lo.s32 %r24, %r3, %r20, %r25;
    min.u64 %rd12, %rd12, %rd10;
    mul.wide.u32 %rd6, %r27, %r20;
    or.b64 %rd5, %rd12, %rd12;
    add.u32 %r23, %r24, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
