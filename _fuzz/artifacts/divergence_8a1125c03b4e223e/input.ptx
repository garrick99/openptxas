.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p3, %r3, 2147483648;
    @%p3 mad.lo.u32 %r11, %r3, %r3, %r3;
    cvt.u64.u32 %rd10, %r3;
    shl.b64 %rd15, %rd10, 4;
    shr.u32 %r7, %r11, 3;
    xor.b32 %r4, %r3, 7;
    xor.b32 %r4, %r7, 63;
    add.u32 %r5, %r4, %r4;
    cvt.s32.s64 %r17, %rd10;
    shr.s64 %rd12, %rd10, 62;
    sub.s32 %r22, %r4, %r11;
    and.b32 %r22, %r4, %r4;
    max.s32 %r24, %r4, %r3;
    min.s32 %r8, %r11, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
