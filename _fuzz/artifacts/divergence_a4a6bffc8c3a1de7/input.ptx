.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p1, %r3, 256;
    @!%p1 or.b32 %r25, %r3, %r3;
    max.u32 %r21, %r25, %r3;
    setp.lt.s32 %p3, %r25, %r21;
    @%p3 sub.u32 %r12, %r21, %r21;
    cvt.u64.u32 %rd11, %r3;
    shr.u64 %rd15, %rd11, 47;
    sub.s32 %r17, %r21, %r3;
    max.s64 %rd15, %rd15, %rd11;
    and.b32 %r26, %r12, 2147483647;
    xor.b32 %r15, %r21, 15;
    mad.lo.s32 %r11, %r26, %r12, %r15;
    sub.s64 %rd9, %rd11, %rd15;
    max.s32 %r17, %r26, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
