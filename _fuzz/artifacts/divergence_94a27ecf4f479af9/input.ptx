.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    sub.u32 %r15, %r3, 65535;
    setp.lt.s32 %p1, %r3, %r15;
    @%p1 shl.b32 %r23, %r3, 30;
    setp.le.s32 %p4, %r23, 15;
    @%p4 max.s32 %r22, %r15, %r23;
    max.u32 %r13, %r15, %r22;
    add.u32 %r8, %r22, 65536;
    shr.s32 %r10, %r8, 16;
    selp.b32 %r27, %r13, %r13, %p4;
    max.u32 %r13, %r15, 255;
    max.s32 %r9, %r8, %r13;
    mad.lo.s32 %r5, %r15, %r27, %r15;
    shl.b64 %rd14, %rd14, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
