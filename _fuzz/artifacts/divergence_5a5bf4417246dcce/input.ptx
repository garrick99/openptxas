.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r21, %r3, 7;
    shr.s32 %r17, %r3, 1;
    cvt.u64.u32 %rd9, %r3;
    shl.b64 %rd15, %rd9, 3;
    sub.u32 %r20, %r17, %r17;
    setp.hs.u32 %p4, %r20, 8;
    @%p4 sub.u32 %r27, %r17, 5;
    or.b32 %r26, %r20, %r17;
    cvt.s32.s64 %r26, %rd15;
    mul.lo.u32 %r4, %r20, 255;
    sub.s32 %r24, %r26, %r27;
    cvt.s32.s64 %r19, %rd9;
    mul.wide.s32 %rd5, %r17, %r27;
    sub.u32 %r6, %r19, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
