.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r26, %r3, %r3;
    cvt.s64.s32 %rd8, %r3;
    or.b32 %r22, %r26, 2;
    sub.u32 %r16, %r26, 5;
    min.s32 %r24, %r22, %r3;
    setp.eq.s32 %p3, %r16, 3;
    @%p3 sub.s32 %r25, %r24, %r22;
    sub.s32 %r6, %r16, 1;
    mul.wide.s32 %rd5, %r25, %r16;
    setp.eq.u32 %p3, %r6, 2147483647;
    @%p3 min.s32 %r15, %r26, 3;
    mad.lo.u32 %r23, %r3, %r25, %r3;
    selp.b32 %r14, %r16, %r15, %p3;
    and.b32 %r4, %r23, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
