    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    max.s32 %r9, %r3, 2;
    sub.s32 %r4, %r9, 2147483648;
    mad.lo.s32 %r27, %r3, %r9, %r9;
    max.u32 %r7, %r9, %r4;
    cvt.u32.u64 %r10, %rd14;
    and.b32 %r15, %r10, 65535;
    and.b32 %r5, %r4, 4;
    sub.u32 %r12, %r9, %r15;
    mad.lo.u32 %r23, %r27, %r4, %r5;
    mul.lo.u32 %r18, %r27, %r4;
    mul.lo.s32 %r18, %r12, %r9;
