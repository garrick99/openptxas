.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd7, %r3, %r3;
    mul.lo.s32 %r6, %r3, 2147483647;
    min.u32 %r11, %r3, %r3;
    xor.b32 %r6, %r6, 4;
    min.u32 %r26, %r6, %r3;
    sub.s32 %r12, %r6, 7;
    mul.lo.u64 %rd5, %rd7, %rd7;
    add.u32 %r25, %r3, %r6;
    mul.lo.u32 %r4, %r12, %r11;
    shr.s64 %rd8, %rd7, 32;
    shl.b64 %rd9, %rd8, 2;
    setp.hi.u32 %p4, %r26, %r3;
    max.u32 %r6, %r12, 64;
    mul.lo.u64 %rd8, %rd7, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
