.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    shl.b64 %rd12, %rd14, 7;
    shr.s64 %rd13, %rd14, 7;
    mul.lo.s32 %r23, %r3, %r3;
    mad.lo.s32 %r11, %r23, %r3, %r3;
    cvt.u32.u64 %r26, %rd13;
    sub.u32 %r18, %r3, %r26;
    setp.ge.s32 %p3, %r23, 3;
    @!%p3 shr.u64 %rd9, %rd14, 3;
    add.s32 %r6, %r11, 4294967295;
    sub.s32 %r22, %r6, 5;
    shr.s64 %rd7, %rd14, 16;
    add.s64 %rd8, %rd12, %rd14;
    selp.b32 %r26, %r22, %r18, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
