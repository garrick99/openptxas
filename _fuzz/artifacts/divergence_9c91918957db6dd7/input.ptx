.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p2, %r3, %r3;
    setp.le.s32 %p1, %r3, 1;
    @!%p1 add.u32 %r23, %r3, %r3;
    min.u32 %r27, %r23, %r3;
    selp.b32 %r22, %r3, %r23, %p1;
    mul.lo.s32 %r15, %r22, %r3;
    cvt.s64.s32 %rd10, %r23;
    setp.gt.s32 %p3, %r15, 65536;
    @%p3 mul.lo.s32 %r21, %r3, %r27;
    xor.b32 %r27, %r27, 31;
    max.u32 %r24, %r21, %r3;
    sub.u32 %r26, %r22, %r24;
    mad.lo.s32 %r22, %r27, %r26, %r24;
    min.u32 %r21, %r27, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
