    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    shr.u32 %r24, %r3, 1;
    sub.s64 %rd10, %rd9, %rd9;
    mul.lo.u64 %rd10, %rd10, %rd10;
