.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    shl.b32 %r9, %r3, 1;
    cvt.s64.s32 %rd10, %r3;
    mul.lo.u32 %r27, %r3, 32;
    and.b64 %rd8, %rd10, %rd10;
    max.u32 %r26, %r27, %r27;
    cvt.u32.u64 %r16, %rd10;
    min.u64 %rd11, %rd8, %rd8;
    or.b32 %r11, %r3, %r9;
    max.s32 %r10, %r9, 1;
    add.u32 %r21, %r3, %r11;
    setp.ne.s32 %p4, %r27, %r26;
    @%p4 mul.lo.s32 %r6, %r21, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
