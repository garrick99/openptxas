.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r7, %r3, 4294967295;
    shr.u32 %r7, %r3, 1;
    mul.wide.u32 %rd10, %r7, %r3;
    max.u32 %r19, %r7, 8;
    shr.u64 %rd8, %rd10, 16;
    cvt.u32.u64 %r16, %rd8;
    add.s32 %r8, %r19, %r7;
    mul.wide.s32 %rd12, %r3, %r8;
    shl.b64 %rd11, %rd10, 63;
    max.u32 %r9, %r7, %r3;
    mul.wide.s32 %rd6, %r19, %r7;
    add.s64 %rd15, %rd8, %rd10;
    mul.wide.u32 %rd10, %r9, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
