.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r16, %r3, %r3;
    min.u32 %r7, %r16, %r16;
    max.s32 %r24, %r16, %r16;
    sub.u32 %r22, %r7, %r3;
    cvt.s64.s32 %rd9, %r22;
    add.u32 %r15, %r7, %r22;
    sub.u32 %r17, %r22, %r16;
    sub.u32 %r6, %r7, 0;
    max.u32 %r12, %r24, %r24;
    mul.lo.u64 %rd5, %rd9, %rd9;
    shr.u32 %r27, %r15, 15;
    mad.lo.u32 %r14, %r17, %r24, %r17;
    shr.u32 %r12, %r14, 3;
    shr.u32 %r11, %r17, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
