.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r8, %r3, %r3;
    setp.gt.u32 %p4, %r3, 15;
    @!%p4 cvt.s64.s32 %rd12, %r8;
    setp.gt.u32 %p1, %r3, %r3;
    @%p1 max.s32 %r27, %r3, %r3;
    setp.ge.s32 %p4, %r27, 65536;
    @%p4 min.u32 %r13, %r27, 3;
    mul.wide.s32 %rd7, %r13, %r13;
    selp.b32 %r26, %r13, %r13, %p4;
    xor.b32 %r12, %r3, %r8;
    cvt.s32.s64 %r17, %rd12;
    shr.s64 %rd7, %rd12, 32;
    cvt.u32.u64 %r4, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
