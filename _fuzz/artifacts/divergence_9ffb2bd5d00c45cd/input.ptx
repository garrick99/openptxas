.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r15, %r3, %r0;
    shfl.sync.idx.b32 %r11, %r0, 0, 0x1f, -1;
    setp.le.u32 %p3, %r11, 15;
    vote.sync.ballot.b32 %r13, %p3, -1;
    max.u32 %r7, %r13, %r3;
    shfl.sync.bfly.b32 %r7, %r11, 4, 0x1f, -1;
    shfl.sync.down.b32 %r11, %r13, 2, 0x1f, -1;
    add.u32 %r17, %r3, %r13;
    min.u32 %r12, %r13, %r11;
    or.b32 %r18, %r12, %r3;
    setp.ne.u32 %p3, %r15, 7;
    vote.sync.ballot.b32 %r10, %p3, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
