.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    add.u32 %r21, %r3, 65536;
    min.u32 %r6, %r3, 2147483648;
    max.u32 %r18, %r6, %r21;
    setp.ls.u32 %p2, %r3, 5;
    @!%p2 shr.s32 %r23, %r3, 31;
    max.s32 %r22, %r18, %r23;
    add.s32 %r25, %r22, 8;
    xor.b32 %r11, %r21, %r22;
    cvt.u64.u32 %rd13, %r6;
    add.u32 %r22, %r18, %r3;
    cvt.s32.s64 %r8, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
