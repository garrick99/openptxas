.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p1, %r3, 2147483648;
    setp.hi.u32 %p1, %r3, %r3;
    @%p1 add.s32 %r17, %r3, %r3;
    sub.s32 %r4, %r17, %r17;
    and.b32 %r19, %r17, %r3;
    cvt.s64.s32 %rd8, %r19;
    selp.b32 %r7, %r19, %r19, %p1;
    shr.s64 %rd12, %rd8, 32;
    add.s32 %r22, %r4, %r7;
    cvt.u32.u64 %r25, %rd8;
    shr.s64 %rd5, %rd12, 7;
    mul.wide.s32 %rd7, %r25, %r3;
    sub.s32 %r8, %r22, 5;
    shl.b32 %r5, %r17, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
