.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r6, %r3, 2;
    setp.lo.u32 %p1, %r3, 8;
    mul.lo.s32 %r8, %r3, 1;
    shr.s32 %r8, %r8, 2;
    mul.wide.u32 %rd9, %r6, %r3;
    mad.lo.s32 %r17, %r3, %r8, %r3;
    selp.b32 %r10, %r3, %r17, %p1;
    mul.wide.u32 %rd9, %r6, %r17;
    max.u32 %r16, %r17, 7;
    mul.wide.u32 %rd11, %r16, %r6;
    mad.lo.s32 %r20, %r8, %r3, %r6;
    max.s32 %r25, %r10, %r6;
    or.b32 %r20, %r25, %r20;
    add.u32 %r9, %r20, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
