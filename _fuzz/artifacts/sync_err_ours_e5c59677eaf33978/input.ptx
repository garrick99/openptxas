    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r7, %r3, %r3;
    shr.u32 %r27, %r3, 16;
    add.s32 %r10, %r3, 3;
    xor.b32 %r27, %r7, %r10;
    mul.lo.s32 %r16, %r27, %r10;
    cvt.s64.s32 %rd9, %r7;
    max.s32 %r22, %r3, %r7;
    or.b32 %r6, %r10, %r3;
    shr.u32 %r10, %r7, 30;
    add.s32 %r17, %r7, %r22;
    shr.s64 %rd11, %rd9, 2;
    max.u32 %r4, %r17, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
