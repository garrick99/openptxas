.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r5, %r3, %r3;
    sub.u32 %r5, %r5, %r3;
    add.s32 %r19, %r3, %r3;
    min.s32 %r6, %r3, 4294967295;
    mul.wide.s32 %rd11, %r6, %r5;
    max.s32 %r8, %r19, %r6;
    mad.lo.s32 %r27, %r5, %r5, %r19;
    shr.u32 %r16, %r5, 15;
    setp.ne.s32 %p4, %r19, 31;
    sub.s32 %r10, %r16, 0;
    mad.lo.s32 %r25, %r19, %r27, %r6;
    add.u32 %r7, %r19, %r16;
    sub.u32 %r19, %r8, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
