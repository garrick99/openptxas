.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r8, %r3, 1;
    cvt.s64.s32 %rd14, %r3;
    mul.wide.s32 %rd9, %r3, %r8;
    sub.s32 %r17, %r3, %r8;
    shr.u32 %r11, %r8, 16;
    cvt.u32.u64 %r5, %rd14;
    or.b32 %r26, %r8, %r5;
    shr.u32 %r7, %r11, 0;
    cvt.u64.u32 %rd13, %r5;
    cvt.u32.u64 %r24, %rd14;
    mul.wide.s32 %rd15, %r17, %r24;
    sub.u32 %r21, %r17, 32;
    setp.ls.u32 %p1, %r17, 5;
    @%p1 and.b32 %r8, %r8, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
