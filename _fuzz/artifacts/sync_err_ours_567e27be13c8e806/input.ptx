.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r8, %r3, %r3, %r3;
    mul.wide.s32 %rd5, %r3, %r3;
    add.s32 %r13, %r3, %r3;
    max.s32 %r17, %r3, %r8;
    max.u32 %r21, %r3, %r3;
    or.b32 %r17, %r3, 32;
    cvt.u32.u64 %r7, %rd5;
    mad.lo.u32 %r22, %r13, %r8, %r7;
    shr.u64 %rd10, %rd5, 2;
    setp.ne.s32 %p3, %r8, %r21;
    @%p3 shl.b32 %r15, %r17, 2;
    cvt.u32.u64 %r26, %rd10;
    shr.u32 %r16, %r17, 16;
    mul.lo.s32 %r23, %r15, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
