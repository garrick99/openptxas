.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd5, %r3, %r3;
    mul.wide.s32 %rd8, %r3, %r3;
    add.s64 %rd12, %rd5, %rd5;
    setp.le.s32 %p2, %r3, 32;
    @!%p2 shr.s32 %r17, %r3, 2;
    max.s32 %r25, %r17, 8;
    add.u32 %r25, %r3, %r17;
    min.s32 %r11, %r3, %r3;
    shl.b64 %rd10, %rd12, 62;
    selp.b32 %r12, %r17, %r11, %p2;
    setp.le.u32 %p3, %r3, 65536;
    @%p3 and.b32 %r13, %r17, 255;
    setp.gt.s32 %p3, %r11, %r3;
    @%p3 selp.b32 %r26, %r11, %r17, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
