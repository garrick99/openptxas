.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    shr.s32 %r19, %r3, 30;
    shl.b64 %rd8, %rd9, 30;
    max.u32 %r11, %r3, 8;
    shl.b64 %rd9, %rd9, 63;
    setp.eq.s32 %p2, %r3, 4;
    add.u32 %r4, %r11, %r19;
    mul.lo.u32 %r25, %r3, 63;
    xor.b32 %r27, %r3, 256;
    mad.lo.u32 %r21, %r27, %r27, %r27;
    shl.b64 %rd5, %rd8, 48;
    add.u32 %r16, %r27, %r4;
    mul.lo.s64 %rd11, %rd5, %rd8;
    add.s64 %rd5, %rd9, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
