.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r23, %r3, %r3, %r3;
    cvt.s64.s32 %rd7, %r23;
    max.u32 %r13, %r23, %r3;
    add.s32 %r7, %r13, %r3;
    mad.lo.u32 %r16, %r3, %r7, %r13;
    setp.ne.s32 %p2, %r16, 64;
    add.s32 %r5, %r16, %r13;
    mad.lo.u32 %r20, %r16, %r3, %r7;
    shr.s64 %rd11, %rd7, 32;
    min.u32 %r24, %r7, 255;
    sub.s32 %r9, %r23, 255;
    setp.ne.u32 %p1, %r13, %r7;
    @!%p1 cvt.s64.s32 %rd14, %r7;
    setp.eq.s32 %p1, %r24, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
