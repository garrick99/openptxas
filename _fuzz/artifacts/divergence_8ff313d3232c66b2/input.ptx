.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    shr.s32 %r11, %r3, 31;
    cvt.s32.s64 %r9, %rd11;
    add.s32 %r17, %r11, 256;
    shl.b32 %r23, %r9, 7;
    cvt.s32.s64 %r8, %rd11;
    cvt.s64.s32 %rd11, %r23;
    mul.wide.u32 %rd7, %r11, %r23;
    shr.s64 %rd12, %rd7, 15;
    min.s32 %r25, %r11, %r9;
    setp.lo.u32 %p4, %r25, 2147483647;
    @!%p4 cvt.u64.u32 %rd13, %r3;
    cvt.u32.u64 %r14, %rd7;
    or.b32 %r17, %r3, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
