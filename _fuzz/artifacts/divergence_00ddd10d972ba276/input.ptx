.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r18, %r3, 8;
    setp.ls.u32 %p4, %r18, 2;
    @%p4 min.s32 %r11, %r18, 16;
    xor.b32 %r19, %r3, %r18;
    mad.lo.s32 %r25, %r11, %r11, %r11;
    or.b32 %r12, %r11, 65536;
    sub.s32 %r9, %r11, 2147483647;
    mul.lo.s32 %r12, %r19, %r11;
    mul.lo.u32 %r14, %r3, 7;
    add.s32 %r26, %r18, %r3;
    max.u32 %r22, %r3, %r11;
    xor.b32 %r24, %r12, %r11;
    or.b32 %r23, %r24, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
