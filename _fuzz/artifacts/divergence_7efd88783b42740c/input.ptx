.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r8, %r3, %r3;
    min.u32 %r21, %r8, 65536;
    xor.b32 %r27, %r8, %r21;
    setp.eq.s32 %p4, %r21, 31;
    @%p4 mul.wide.u32 %rd7, %r21, %r27;
    cvt.s32.s64 %r21, %rd7;
    cvt.s64.s32 %rd8, %r3;
    mad.lo.s32 %r8, %r3, %r27, %r21;
    mul.lo.u32 %r26, %r3, 5;
    mul.wide.u32 %rd15, %r3, %r21;
    shr.s32 %r13, %r21, 0;
    setp.ge.s32 %p1, %r13, %r26;
    @!%p1 mul.wide.s32 %rd14, %r8, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
