.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r14, %r3, %r3;
    shl.b32 %r12, %r14, 16;
    cvt.u64.u32 %rd7, %r14;
    mad.lo.s32 %r20, %r14, %r12, %r12;
    cvt.s32.s64 %r19, %rd7;
    add.s64 %rd12, %rd7, %rd7;
    and.b32 %r5, %r14, %r19;
    and.b32 %r21, %r14, %r14;
    add.u32 %r27, %r3, %r20;
    add.s64 %rd9, %rd12, %rd7;
    max.s32 %r26, %r27, 4294967295;
    mul.lo.u32 %r22, %r20, %r14;
    setp.lt.s32 %p1, %r22, %r3;
    @%p1 max.u32 %r13, %r22, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
