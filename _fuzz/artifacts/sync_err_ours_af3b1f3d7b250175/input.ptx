.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r27, %r3, %r3;
    sub.u32 %r7, %r27, %r27;
    mad.lo.s32 %r19, %r3, %r27, %r3;
    mad.lo.s32 %r17, %r27, %r27, %r19;
    cvt.u64.u32 %rd10, %r27;
    mad.lo.s32 %r10, %r3, %r7, %r7;
    mad.lo.s32 %r20, %r3, %r27, %r19;
    shl.b64 %rd11, %rd10, 16;
    mad.lo.u32 %r26, %r3, %r7, %r19;
    sub.u32 %r14, %r7, %r7;
    cvt.s64.s32 %rd7, %r19;
    mul.lo.u32 %r14, %r17, 255;
    cvt.u32.u64 %r8, %rd7;
    mul.lo.s32 %r18, %r8, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
