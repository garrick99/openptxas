.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    shl.b64 %rd14, %rd11, 30;
    min.s64 %rd6, %rd14, %rd14;
    sub.u32 %r13, %r3, %r3;
    cvt.u64.u32 %rd14, %r13;
    shr.u64 %rd8, %rd14, 16;
    shr.u64 %rd14, %rd6, 15;
    shr.u32 %r12, %r3, 30;
    add.u32 %r5, %r13, %r12;
    cvt.u32.u64 %r11, %rd14;
    max.u32 %r9, %r13, 65535;
    min.u64 %rd6, %rd11, %rd8;
    min.u32 %r11, %r5, 255;
    min.s32 %r15, %r11, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
