.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p2, %r3, 32;
    @%p2 add.s32 %r22, %r3, 2;
    shr.s32 %r10, %r22, 1;
    add.s32 %r19, %r22, 65536;
    or.b32 %r15, %r19, 0;
    setp.gt.s32 %p2, %r22, 4294967295;
    @!%p2 add.u32 %r7, %r19, 8;
    cvt.u64.u32 %rd5, %r15;
    setp.gt.s32 %p3, %r15, %r10;
    @%p3 sub.u32 %r20, %r15, %r3;
    max.s32 %r21, %r20, 256;
    min.s32 %r12, %r22, %r7;
    shr.u32 %r21, %r7, 1;
    mad.lo.u32 %r14, %r20, %r3, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
