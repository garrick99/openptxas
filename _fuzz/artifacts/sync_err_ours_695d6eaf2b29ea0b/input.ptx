.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r19, %r3, %r3;
    max.u32 %r19, %r3, %r3;
    mul.lo.s32 %r13, %r3, 8;
    setp.le.s32 %p4, %r13, 1;
    @!%p4 or.b32 %r20, %r19, 65536;
    mul.wide.u32 %rd10, %r3, %r19;
    setp.gt.s32 %p2, %r13, %r20;
    @!%p2 add.u32 %r23, %r3, %r20;
    shl.b32 %r25, %r3, 7;
    mad.lo.u32 %r15, %r19, %r20, %r3;
    shl.b32 %r23, %r19, 31;
    shr.u32 %r22, %r19, 0;
    setp.lt.u32 %p4, %r25, %r19;
    @%p4 shr.s32 %r21, %r22, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
