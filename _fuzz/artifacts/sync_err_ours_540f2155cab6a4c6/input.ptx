.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    cvt.s64.s32 %rd13, %r3;
    max.s32 %r7, %r3, %r3;
    shl.b64 %rd6, %rd13, 3;
    sub.u32 %r24, %r3, %r7;
    setp.hi.u32 %p1, %r3, 5;
    xor.b64 %rd14, %rd11, %rd11;
    sub.u32 %r12, %r24, 32;
    add.u32 %r27, %r24, %r7;
    cvt.s32.s64 %r24, %rd6;
    max.u32 %r18, %r7, 7;
    or.b64 %rd10, %rd6, %rd6;
    add.s64 %rd7, %rd11, %rd10;
    min.s32 %r7, %r24, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
