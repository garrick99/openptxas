.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r10, %r3, %r3;
    cvt.s64.s32 %rd15, %r10;
    max.u32 %r16, %r10, %r10;
    max.s32 %r25, %r3, 7;
    max.u32 %r5, %r3, 256;
    shr.s64 %rd10, %rd15, 1;
    mul.lo.s32 %r27, %r10, %r10;
    setp.lt.s32 %p3, %r25, 16;
    @%p3 selp.b32 %r24, %r16, %r10, %p3;
    mad.lo.s32 %r10, %r25, %r16, %r3;
    mul.lo.u64 %rd9, %rd10, %rd15;
    setp.eq.u32 %p3, %r27, %r3;
    setp.eq.s32 %p1, %r27, %r25;
    and.b32 %r24, %r27, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
