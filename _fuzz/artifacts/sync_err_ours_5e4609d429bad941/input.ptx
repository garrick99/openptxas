.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r13, %r3, 1;
    cvt.u64.u32 %rd9, %r3;
    sub.s32 %r22, %r13, %r13;
    mad.lo.s32 %r5, %r13, %r3, %r22;
    cvt.u32.u64 %r23, %rd9;
    mul.wide.s32 %rd9, %r22, %r5;
    mul.wide.u32 %rd7, %r23, %r3;
    max.u32 %r26, %r5, 16;
    or.b32 %r20, %r23, 63;
    shr.s32 %r27, %r22, 3;
    setp.le.s32 %p2, %r26, 4294967295;
    @%p2 selp.b32 %r14, %r5, %r5, %p2;
    cvt.u32.u64 %r26, %rd7;
    add.s32 %r12, %r14, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
