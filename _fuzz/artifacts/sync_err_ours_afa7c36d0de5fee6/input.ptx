.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r27, %r3, %r3;
    shr.u32 %r7, %r27, 4;
    mul.lo.s32 %r13, %r27, %r3;
    sub.s32 %r20, %r13, 2;
    cvt.u64.u32 %rd5, %r7;
    mad.lo.s32 %r14, %r7, %r7, %r20;
    shr.s64 %rd14, %rd5, 47;
    mul.lo.u32 %r23, %r20, %r7;
    min.u64 %rd11, %rd14, %rd5;
    mad.lo.s32 %r14, %r14, %r7, %r23;
    min.u32 %r25, %r20, %r13;
    mul.lo.u32 %r15, %r3, %r7;
    mul.wide.s32 %rd7, %r27, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
