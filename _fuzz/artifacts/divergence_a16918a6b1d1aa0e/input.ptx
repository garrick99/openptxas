.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r7, %r3, %r3;
    max.s32 %r21, %r7, %r3;
    mul.lo.s32 %r7, %r21, %r7;
    mad.lo.u32 %r20, %r3, %r21, %r3;
    setp.lt.s32 %p3, %r21, %r20;
    @%p3 mul.wide.s32 %rd8, %r7, %r7;
    shr.s32 %r9, %r21, 31;
    cvt.u64.u32 %rd11, %r20;
    mad.lo.u32 %r17, %r20, %r20, %r20;
    add.s64 %rd5, %rd11, %rd11;
    or.b32 %r6, %r20, %r21;
    max.s32 %r11, %r6, 5;
    mul.lo.u64 %rd6, %rd11, %rd11;
    selp.b32 %r10, %r7, %r11, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
