.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r14, %r3, 0;
    shl.b32 %r27, %r3, 4;
    mul.lo.u32 %r23, %r27, 1;
    setp.le.s32 %p2, %r3, 4294967295;
    setp.lt.s32 %p1, %r23, 16;
    @%p1 or.b32 %r27, %r27, %r27;
    min.s32 %r13, %r27, %r27;
    cvt.u64.u32 %rd8, %r3;
    min.s32 %r18, %r14, %r23;
    setp.gt.s32 %p1, %r18, 4;
    @%p1 min.u32 %r15, %r13, %r18;
    mad.lo.s32 %r6, %r15, %r18, %r14;
    shr.u32 %r11, %r14, 30;
    and.b32 %r12, %r14, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
