.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r15, %r3, 8;
    setp.ge.s32 %p4, %r15, %r15;
    @!%p4 cvt.s64.s32 %rd7, %r15;
    mad.lo.s32 %r27, %r3, %r15, %r3;
    shr.s64 %rd5, %rd7, 15;
    add.s32 %r11, %r27, 65536;
    shr.s64 %rd5, %rd5, 4;
    shr.s64 %rd11, %rd7, 63;
    selp.b32 %r10, %r27, %r27, %p4;
    setp.le.u32 %p3, %r10, %r27;
    @%p3 mul.lo.s32 %r21, %r15, %r10;
    cvt.s32.s64 %r21, %rd5;
    max.s32 %r16, %r21, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
