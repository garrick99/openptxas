.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r5, %r3, %r3;
    setp.ne.s32 %p2, %r5, %r5;
    @%p2 mad.lo.s32 %r16, %r5, %r3, %r3;
    sub.u32 %r25, %r5, 65536;
    xor.b32 %r19, %r3, 4;
    setp.ge.u32 %p2, %r19, %r3;
    @!%p2 min.s32 %r17, %r16, %r25;
    shl.b32 %r5, %r25, 1;
    selp.b32 %r6, %r16, %r5, %p2;
    and.b32 %r24, %r19, %r3;
    cvt.s64.s32 %rd13, %r6;
    cvt.s32.s64 %r20, %rd13;
    mul.wide.s32 %rd8, %r16, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
