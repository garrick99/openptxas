.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r15, %r3, 31;
    min.u32 %r11, %r15, 65536;
    add.u32 %r11, %r11, 32;
    sub.u32 %r9, %r11, %r15;
    setp.lo.u32 %p2, %r3, 1;
    @!%p2 mul.lo.u32 %r11, %r9, 4;
    cvt.u64.u32 %rd5, %r11;
    mad.lo.s32 %r21, %r9, %r11, %r15;
    cvt.u64.u32 %rd6, %r9;
    sub.u32 %r6, %r9, %r21;
    add.s32 %r22, %r21, %r15;
    add.u64 %rd12, %rd5, %rd6;
    min.u32 %r24, %r15, %r15;
    cvt.u32.u64 %r15, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
