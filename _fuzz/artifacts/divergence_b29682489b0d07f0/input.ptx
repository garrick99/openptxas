.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    add.u32 %r16, %r3, 7;
    and.b32 %r11, %r16, %r3;
    mad.lo.s32 %r6, %r3, %r16, %r16;
    max.u64 %rd6, %rd5, %rd5;
    or.b32 %r16, %r11, %r11;
    and.b32 %r5, %r11, %r16;
    cvt.u32.u64 %r12, %rd5;
    mad.lo.s32 %r10, %r3, %r5, %r3;
    cvt.u32.u64 %r23, %rd5;
    sub.s32 %r18, %r23, %r10;
    setp.lt.u32 %p3, %r11, 255;
    @%p3 mad.lo.u32 %r24, %r5, %r16, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
