.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r21, %r3, %r3;
    shl.b32 %r4, %r3, 0;
    add.s32 %r25, %r4, 256;
    shl.b32 %r16, %r3, 16;
    or.b32 %r18, %r4, %r3;
    mad.lo.u32 %r20, %r4, %r18, %r16;
    setp.lo.u32 %p4, %r18, 1;
    max.u32 %r6, %r18, %r20;
    add.u32 %r17, %r20, 31;
    shr.u32 %r4, %r6, 4;
    mul.wide.s32 %rd15, %r3, %r21;
    setp.gt.s32 %p1, %r17, 65536;
    mad.lo.u32 %r21, %r4, %r6, %r16;
    xor.b32 %r24, %r25, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
