.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r4, %r3, %r3, %r3;
    min.s32 %r23, %r3, %r3;
    sub.s32 %r8, %r23, %r4;
    mad.lo.s32 %r9, %r3, %r3, %r4;
    shl.b32 %r8, %r8, 15;
    max.s32 %r9, %r8, %r23;
    min.s32 %r6, %r9, %r23;
    min.s32 %r5, %r4, 64;
    cvt.s64.s32 %rd8, %r5;
    cvt.s64.s32 %rd5, %r6;
    mul.lo.u32 %r6, %r5, %r8;
    add.s32 %r13, %r6, 3;
    and.b32 %r10, %r4, %r6;
    min.s32 %r7, %r3, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
