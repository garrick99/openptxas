.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r13, %r3, 16;
    cvt.u64.u32 %rd7, %r13;
    mul.lo.s32 %r15, %r13, 65536;
    min.u32 %r18, %r15, 32;
    shr.u32 %r17, %r18, 0;
    shr.u32 %r16, %r17, 0;
    mul.lo.s32 %r23, %r17, 3;
    and.b32 %r21, %r15, 65535;
    min.u32 %r23, %r21, %r21;
    cvt.s32.s64 %r9, %rd7;
    cvt.s64.s32 %rd6, %r17;
    xor.b32 %r16, %r18, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
