.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r9, %r3, 3;
    setp.gt.s32 %p3, %r9, %r3;
    @%p3 max.s32 %r13, %r9, %r9;
    cvt.u64.u32 %rd6, %r13;
    add.s64 %rd11, %rd6, %rd6;
    mad.lo.s32 %r6, %r9, %r3, %r13;
    mad.lo.s32 %r16, %r3, %r13, %r9;
    mul.lo.s32 %r20, %r3, 2;
    add.s32 %r11, %r20, 16;
    setp.hs.u32 %p4, %r11, 1;
    @%p4 cvt.u32.u64 %r4, %rd11;
    selp.b32 %r21, %r4, %r6, %p4;
    and.b32 %r15, %r16, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
