.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p2, %r3, 63;
    @%p2 sub.s32 %r20, %r3, %r3;
    mul.wide.s32 %rd6, %r3, %r3;
    shr.u32 %r15, %r20, 7;
    mul.lo.s32 %r15, %r20, 255;
    mad.lo.u32 %r15, %r15, %r3, %r3;
    min.u32 %r11, %r15, 5;
    setp.ne.u32 %p2, %r11, %r15;
    mad.lo.s32 %r17, %r15, %r15, %r20;
    mul.lo.u32 %r25, %r17, 5;
    mad.lo.u32 %r19, %r11, %r20, %r17;
    cvt.s32.s64 %r7, %rd6;
    setp.ls.u32 %p2, %r15, 7;
    max.u32 %r21, %r15, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
