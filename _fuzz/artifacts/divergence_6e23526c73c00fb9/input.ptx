    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    max.s32 %r19, %r3, %r3;
    mul.lo.s32 %r9, %r3, 2147483648;
    cvt.s32.s64 %r21, %rd15;
    add.s32 %r24, %r9, %r19;
    cvt.s32.s64 %r18, %rd15;
    shl.b32 %r5, %r24, 31;
    sub.u32 %r23, %r5, %r24;
    or.b32 %r5, %r24, 16;
    mul.wide.u32 %rd7, %r18, %r18;
    cvt.s64.s32 %rd8, %r21;
    xor.b32 %r15, %r9, %r19;
    add.s32 %r13, %r23, 65535;
    shr.u64 %rd13, %rd8, 33;
