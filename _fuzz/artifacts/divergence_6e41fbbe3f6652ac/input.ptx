.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r6, %r3, 255;
    mad.lo.u32 %r14, %r3, %r6, %r6;
    shr.u32 %r10, %r14, 3;
    max.u32 %r26, %r6, %r10;
    cvt.s64.s32 %rd13, %r3;
    setp.le.s32 %p2, %r26, %r3;
    @%p2 min.u32 %r12, %r3, 32;
    min.u32 %r15, %r10, %r3;
    cvt.u32.u64 %r16, %rd13;
    selp.b32 %r4, %r14, %r6, %p2;
    selp.b32 %r5, %r15, %r14, %p2;
    shr.u64 %rd10, %rd13, 0;
    sub.s32 %r21, %r3, %r16;
    sub.u32 %r8, %r26, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
