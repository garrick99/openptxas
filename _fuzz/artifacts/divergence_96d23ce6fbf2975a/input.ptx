.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r9, %r3, 0;
    mul.wide.u32 %rd8, %r9, %r9;
    shl.b64 %rd11, %rd8, 4;
    sub.u32 %r11, %r3, 31;
    cvt.s64.s32 %rd10, %r3;
    mul.wide.s32 %rd12, %r11, %r9;
    setp.ne.u32 %p3, %r11, %r3;
    @!%p3 or.b64 %rd15, %rd12, %rd11;
    shr.u32 %r19, %r3, 3;
    cvt.s64.s32 %rd9, %r19;
    mul.lo.u32 %r23, %r9, 15;
    cvt.u32.u64 %r7, %rd12;
    min.s32 %r19, %r9, %r7;
    selp.b32 %r23, %r23, %r7, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
