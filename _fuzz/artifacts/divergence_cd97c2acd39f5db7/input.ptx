.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r12, %r0, %r0;
    min.u32 %r10, %r12, %r0;
    sub.u32 %r11, %r10, %r12;
    or.b32 %r9, %r12, %r12;
    or.b32 %r10, %r3, %r9;
    setp.eq.u32 %p2, %r11, 15;
    vote.sync.ballot.b32 %r14, %p2, -1;
    add.u32 %r11, %r3, %r12;
    min.u32 %r6, %r10, %r9;
    setp.lt.u32 %p2, %r9, 65535;
    vote.sync.ballot.b32 %r15, %p2, -1;
    setp.ne.u32 %p3, %r3, %r0;
    vote.sync.ballot.b32 %r9, %p3, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
