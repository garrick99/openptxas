.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r20, %r3, 0;
    cvt.s64.s32 %rd10, %r3;
    setp.le.u32 %p1, %r3, 1;
    add.s32 %r18, %r3, 7;
    cvt.u64.u32 %rd6, %r18;
    max.u32 %r14, %r18, %r20;
    xor.b32 %r6, %r18, %r3;
    selp.b32 %r8, %r6, %r20, %p1;
    shl.b64 %rd11, %rd10, 47;
    setp.ge.s32 %p3, %r6, %r6;
    sub.u32 %r20, %r6, 65535;
    max.s64 %rd5, %rd11, %rd6;
    and.b32 %r18, %r3, %r8;
    sub.u32 %r5, %r8, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
