.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r17, %r3, 30;
    mad.lo.u32 %r26, %r17, %r3, %r17;
    xor.b32 %r9, %r17, 65536;
    min.u32 %r14, %r17, 8;
    shr.u32 %r6, %r3, 1;
    max.s32 %r26, %r9, %r9;
    mul.lo.s32 %r20, %r14, 8;
    or.b32 %r8, %r14, %r14;
    setp.ge.u32 %p1, %r20, %r6;
    @!%p1 min.u32 %r20, %r17, %r20;
    cvt.s64.s32 %rd7, %r9;
    shr.s64 %rd7, %rd7, 2;
    max.u32 %r21, %r3, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
