.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r7, %r3, 4;
    mad.lo.s32 %r18, %r3, %r3, %r7;
    mul.lo.u32 %r4, %r7, %r3;
    cvt.u64.u32 %rd14, %r3;
    mul.lo.s32 %r17, %r3, 32;
    cvt.s32.s64 %r19, %rd14;
    and.b32 %r20, %r19, 256;
    mul.lo.s32 %r5, %r20, 4;
    mul.lo.u32 %r4, %r4, %r3;
    sub.u32 %r16, %r3, 5;
    shl.b32 %r24, %r3, 2;
    sub.s32 %r22, %r19, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
