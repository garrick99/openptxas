.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r23, %r3, 5;
    min.u32 %r24, %r3, 64;
    cvt.u64.u32 %rd10, %r23;
    cvt.s32.s64 %r10, %rd10;
    xor.b32 %r22, %r23, %r10;
    cvt.s32.s64 %r8, %rd10;
    shl.b32 %r10, %r23, 15;
    add.u32 %r27, %r23, %r10;
    max.s32 %r20, %r8, 8;
    sub.s64 %rd15, %rd10, %rd10;
    shr.s64 %rd8, %rd10, 48;
    setp.hi.u32 %p1, %r3, 5;
    @%p1 sub.u32 %r20, %r23, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
