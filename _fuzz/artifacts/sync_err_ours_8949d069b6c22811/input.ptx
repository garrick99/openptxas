.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd11, %r3, %r3;
    setp.eq.u32 %p1, %r3, 32;
    @%p1 min.u64 %rd10, %rd11, %rd11;
    cvt.s32.s64 %r15, %rd10;
    mul.wide.u32 %rd7, %r3, %r15;
    xor.b32 %r6, %r3, 2;
    shl.b64 %rd9, %rd7, 30;
    or.b32 %r27, %r15, %r15;
    mul.lo.s32 %r27, %r6, %r6;
    setp.ge.u32 %p4, %r3, 16;
    setp.lt.s32 %p2, %r3, 2;
    shl.b32 %r8, %r3, 1;
    sub.u64 %rd5, %rd11, %rd9;
    min.u32 %r18, %r15, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
