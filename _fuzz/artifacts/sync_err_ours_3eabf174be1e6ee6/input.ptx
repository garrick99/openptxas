.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd8, %r3, %r3;
    add.u32 %r17, %r3, 2147483647;
    mad.lo.s32 %r17, %r3, %r17, %r17;
    shr.s32 %r26, %r17, 31;
    shr.u64 %rd6, %rd8, 30;
    shr.u32 %r18, %r17, 16;
    cvt.s32.s64 %r17, %rd6;
    shl.b64 %rd6, %rd8, 16;
    and.b64 %rd12, %rd6, %rd8;
    max.s32 %r7, %r17, 31;
    shl.b32 %r24, %r18, 30;
    sub.s64 %rd8, %rd8, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
