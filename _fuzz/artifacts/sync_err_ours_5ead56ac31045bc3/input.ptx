.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    max.s32 %r19, %r3, %r3;
    xor.b32 %r11, %r19, %r19;
    shr.u32 %r6, %r19, 30;
    add.u32 %r16, %r11, %r3;
    cvt.s32.s64 %r14, %rd9;
    min.u32 %r17, %r16, %r6;
    sub.s64 %rd5, %rd9, %rd9;
    add.s32 %r22, %r11, %r16;
    max.s32 %r13, %r16, 31;
    add.u32 %r26, %r3, %r13;
    min.u32 %r15, %r11, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
