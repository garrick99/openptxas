.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    mul.wide.s32 %rd15, %r3, %r3;
    min.s32 %r22, %r3, %r3;
    and.b32 %r27, %r22, 16;
    max.s32 %r17, %r27, %r22;
    mul.lo.s32 %r8, %r17, %r17;
    min.s32 %r20, %r8, 256;
    shr.u32 %r27, %r8, 16;
    max.u32 %r9, %r3, %r3;
    shr.u64 %rd13, %rd15, 47;
    cvt.s32.s64 %r21, %rd13;
    cvt.s32.s64 %r10, %rd15;
    setp.eq.u32 %p1, %r3, 4294967295;
    @%p1 mul.lo.s32 %r26, %r3, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
