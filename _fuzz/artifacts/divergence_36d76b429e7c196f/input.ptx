.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r25, %r3, 2;
    min.s32 %r23, %r25, 65535;
    cvt.u64.u32 %rd9, %r3;
    xor.b32 %r7, %r23, 64;
    mul.lo.u32 %r6, %r25, %r7;
    sub.s64 %rd6, %rd9, %rd9;
    max.s64 %rd14, %rd6, %rd9;
    min.s64 %rd10, %rd9, %rd6;
    cvt.u32.u64 %r26, %rd14;
    mad.lo.u32 %r7, %r25, %r7, %r7;
    mul.lo.u64 %rd7, %rd10, %rd10;
    mul.lo.u32 %r25, %r23, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
