.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd5, %r3, %r3;
    cvt.s32.s64 %r21, %rd5;
    sub.u32 %r8, %r21, %r21;
    cvt.s32.s64 %r20, %rd5;
    mul.lo.u32 %r26, %r20, %r3;
    max.u32 %r4, %r20, %r20;
    mad.lo.s32 %r24, %r4, %r3, %r20;
    mul.lo.s32 %r9, %r20, 15;
    max.s32 %r17, %r24, %r4;
    shr.s64 %rd13, %rd5, 62;
    min.s64 %rd11, %rd13, %rd5;
    min.u32 %r11, %r24, %r3;
    shl.b64 %rd9, %rd13, 31;
    sub.u32 %r10, %r8, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
