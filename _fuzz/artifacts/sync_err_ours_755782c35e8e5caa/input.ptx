.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r20, %r3, %r3;
    shr.u32 %r9, %r3, 3;
    cvt.s64.s32 %rd8, %r3;
    setp.le.s32 %p3, %r20, 63;
    setp.le.s32 %p1, %r9, %r3;
    min.s32 %r5, %r20, %r9;
    shr.s32 %r24, %r20, 31;
    mul.lo.s32 %r5, %r3, %r9;
    min.s32 %r4, %r5, 256;
    add.s32 %r23, %r20, %r24;
    max.s32 %r21, %r23, %r3;
    mul.wide.u32 %rd8, %r3, %r5;
    xor.b32 %r4, %r9, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
