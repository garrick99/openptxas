.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p3, %r3, 3;
    @%p3 and.b32 %r22, %r3, %r3;
    setp.le.s32 %p2, %r3, 4294967295;
    @%p2 selp.b32 %r16, %r3, %r3, %p3;
    shl.b32 %r23, %r22, 16;
    or.b32 %r19, %r3, 65535;
    cvt.s64.s32 %rd5, %r23;
    shr.u32 %r19, %r19, 31;
    mul.wide.u32 %rd5, %r3, %r19;
    min.s64 %rd7, %rd5, %rd5;
    cvt.s64.s32 %rd5, %r23;
    shl.b64 %rd9, %rd7, 16;
    and.b64 %rd5, %rd9, %rd9;
    shr.u32 %r20, %r16, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
