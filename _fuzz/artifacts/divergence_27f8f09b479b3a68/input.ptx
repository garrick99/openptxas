.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    cvt.s32.s64 %r7, %rd15;
    mul.wide.s32 %rd11, %r3, %r7;
    shr.s32 %r15, %r7, 31;
    cvt.s32.s64 %r9, %rd15;
    mul.wide.s32 %rd9, %r9, %r15;
    cvt.s64.s32 %rd13, %r15;
    sub.s32 %r14, %r3, %r15;
    max.u32 %r21, %r7, %r3;
    shl.b32 %r10, %r15, 16;
    cvt.u64.u32 %rd5, %r21;
    shr.s32 %r26, %r10, 4;
    mul.lo.s32 %r27, %r21, 65536;
    setp.ls.u32 %p3, %r3, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
