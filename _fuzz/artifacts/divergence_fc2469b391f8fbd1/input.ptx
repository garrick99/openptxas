.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd13, %r3, %r3;
    max.u32 %r26, %r3, %r3;
    mul.wide.s32 %rd15, %r3, %r26;
    min.s32 %r8, %r26, 15;
    shr.s64 %rd14, %rd13, 31;
    setp.lt.s32 %p3, %r8, %r8;
    setp.lo.u32 %p4, %r8, 5;
    @%p4 cvt.s32.s64 %r20, %rd15;
    sub.u32 %r19, %r26, %r8;
    setp.gt.s32 %p2, %r26, 7;
    @%p2 shr.u32 %r13, %r19, 16;
    shl.b64 %rd11, %rd13, 47;
    selp.b32 %r18, %r19, %r3, %p4;
    setp.ls.u32 %p3, %r8, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
