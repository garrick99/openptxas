.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r25, %r3, 3;
    and.b32 %r19, %r3, %r3;
    cvt.u64.u32 %rd12, %r19;
    min.s32 %r5, %r25, %r25;
    add.s32 %r23, %r19, 65536;
    xor.b64 %rd12, %rd12, %rd12;
    shr.u64 %rd10, %rd12, 31;
    mul.lo.s32 %r7, %r25, 4294967295;
    setp.ls.u32 %p4, %r19, 256;
    @%p4 mul.lo.u32 %r13, %r23, 256;
    min.s32 %r23, %r23, 2147483647;
    shr.u32 %r25, %r5, 2;
    shl.b32 %r7, %r7, 4;
    mad.lo.s32 %r25, %r23, %r13, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
