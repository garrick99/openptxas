.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p4, %r3, 4294967295;
    @!%p4 cvt.u64.u32 %rd13, %r3;
    min.s32 %r21, %r3, %r3;
    cvt.u32.u64 %r11, %rd13;
    shr.u64 %rd11, %rd13, 15;
    mul.wide.s32 %rd10, %r11, %r21;
    setp.ge.u32 %p2, %r21, %r21;
    @%p2 mul.lo.u32 %r22, %r11, %r3;
    selp.b32 %r25, %r11, %r11, %p4;
    max.u32 %r14, %r11, %r11;
    setp.gt.s32 %p4, %r3, 4;
    @%p4 sub.s32 %r9, %r11, 5;
    mul.wide.u32 %rd5, %r3, %r25;
    min.s32 %r19, %r3, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
