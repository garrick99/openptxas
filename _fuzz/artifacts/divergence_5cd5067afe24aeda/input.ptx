.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r8, %r3, %r3;
    mul.lo.s32 %r8, %r3, %r3;
    mul.lo.u32 %r10, %r3, 2147483647;
    mul.lo.s32 %r27, %r3, %r10;
    cvt.s64.s32 %rd6, %r10;
    add.u32 %r11, %r3, %r27;
    shr.u64 %rd10, %rd6, 2;
    xor.b32 %r26, %r8, %r8;
    sub.s32 %r12, %r10, %r26;
    xor.b32 %r18, %r3, %r8;
    cvt.u64.u32 %rd12, %r27;
    add.s64 %rd6, %rd12, %rd6;
    max.s32 %r15, %r11, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
