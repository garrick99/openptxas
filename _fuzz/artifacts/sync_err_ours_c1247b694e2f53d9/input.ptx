.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r4, %r3, 16;
    min.u32 %r25, %r4, 1;
    add.s32 %r15, %r3, 4294967295;
    cvt.s64.s32 %rd13, %r15;
    min.u64 %rd9, %rd13, %rd13;
    cvt.s64.s32 %rd15, %r3;
    sub.u32 %r12, %r3, %r3;
    shr.s32 %r18, %r3, 16;
    setp.gt.u32 %p2, %r4, %r12;
    @%p2 shr.s32 %r11, %r12, 7;
    max.s32 %r24, %r25, 63;
    setp.le.u32 %p4, %r11, 64;
    @%p4 shr.u64 %rd5, %rd9, 3;
    selp.b32 %r6, %r4, %r3, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
