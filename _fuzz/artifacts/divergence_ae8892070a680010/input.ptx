.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r11, %r3, 7;
    setp.lo.u32 %p4, %r11, %r11;
    @!%p4 or.b32 %r5, %r3, %r3;
    cvt.s64.s32 %rd10, %r3;
    mad.lo.u32 %r11, %r5, %r3, %r5;
    sub.u32 %r8, %r3, %r5;
    mul.wide.s32 %rd8, %r5, %r8;
    add.u32 %r18, %r5, %r3;
    selp.b32 %r27, %r8, %r11, %p4;
    or.b32 %r17, %r11, %r27;
    min.s32 %r8, %r11, 2;
    cvt.u64.u32 %rd14, %r8;
    xor.b64 %rd7, %rd8, %rd10;
    setp.le.s32 %p2, %r27, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
