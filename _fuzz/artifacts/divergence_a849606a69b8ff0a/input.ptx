.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r15, %r3, 0;
    and.b32 %r13, %r15, %r15;
    setp.ge.s32 %p4, %r3, 1;
    @%p4 xor.b32 %r8, %r3, %r15;
    mul.wide.s32 %rd11, %r8, %r8;
    cvt.u32.u64 %r7, %rd11;
    min.s32 %r8, %r3, 65536;
    add.u32 %r17, %r7, %r15;
    shl.b64 %rd12, %rd11, 30;
    setp.ge.s32 %p2, %r17, 64;
    @%p2 mul.wide.s32 %rd8, %r8, %r7;
    or.b64 %rd5, %rd8, %rd12;
    add.s32 %r5, %r7, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
