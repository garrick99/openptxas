.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r7, %r3, %r3;
    add.u32 %r5, %r7, %r7;
    max.s32 %r23, %r7, 1;
    max.u32 %r23, %r23, %r5;
    min.s32 %r21, %r3, %r7;
    mul.lo.s32 %r24, %r23, %r23;
    setp.lt.u32 %p2, %r5, %r23;
    @%p2 mad.lo.u32 %r25, %r24, %r24, %r21;
    min.s32 %r11, %r7, %r21;
    max.u32 %r15, %r11, %r11;
    selp.b32 %r26, %r3, %r7, %p2;
    mul.wide.s32 %rd9, %r15, %r5;
    selp.b32 %r27, %r24, %r25, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
