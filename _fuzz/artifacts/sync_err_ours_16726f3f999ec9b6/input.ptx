.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    setp.hi.u32 %p2, %r3, %r3;
    @!%p2 mul.lo.s32 %r15, %r3, 64;
    sub.s64 %rd5, %rd10, %rd10;
    min.u32 %r5, %r3, 31;
    mul.lo.s32 %r18, %r5, 65536;
    shl.b64 %rd14, %rd10, 30;
    setp.gt.s32 %p3, %r5, 31;
    shr.u32 %r22, %r15, 15;
    sub.s32 %r6, %r3, 0;
    selp.b32 %r24, %r6, %r6, %p2;
    add.s32 %r23, %r22, %r3;
    shl.b32 %r12, %r23, 2;
    cvt.s64.s32 %rd14, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
