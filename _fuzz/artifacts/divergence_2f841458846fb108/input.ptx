.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r24, %r3, 16;
    cvt.u64.u32 %rd7, %r24;
    cvt.s32.s64 %r12, %rd7;
    min.u32 %r8, %r24, 7;
    xor.b32 %r18, %r24, 256;
    shr.u32 %r11, %r3, 3;
    shr.s64 %rd7, %rd7, 4;
    max.u64 %rd10, %rd7, %rd7;
    setp.eq.u32 %p4, %r24, %r8;
    @%p4 max.u32 %r26, %r12, %r11;
    shl.b32 %r17, %r11, 3;
    setp.gt.s32 %p3, %r3, 4294967295;
    @!%p3 selp.b32 %r10, %r24, %r24, %p3;
    cvt.u64.u32 %rd13, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
