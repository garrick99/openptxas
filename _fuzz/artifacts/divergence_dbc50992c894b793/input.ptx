.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p3, %r3, 2;
    @%p3 sub.s32 %r22, %r3, 63;
    cvt.s64.s32 %rd8, %r3;
    shr.s64 %rd9, %rd8, 63;
    shl.b32 %r22, %r22, 4;
    or.b32 %r10, %r22, 0;
    add.u64 %rd8, %rd9, %rd9;
    add.u32 %r24, %r22, %r3;
    cvt.u32.u64 %r26, %rd9;
    cvt.s32.s64 %r7, %rd9;
    xor.b32 %r22, %r22, %r3;
    mul.lo.s32 %r15, %r10, 31;
    or.b32 %r14, %r7, 5;
    or.b32 %r25, %r15, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
