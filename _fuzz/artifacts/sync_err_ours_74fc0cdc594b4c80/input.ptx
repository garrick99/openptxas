.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r19, %r3, 0;
    min.u32 %r12, %r19, %r19;
    cvt.s64.s32 %rd8, %r3;
    setp.gt.s32 %p4, %r3, 3;
    @%p4 or.b32 %r7, %r12, 32;
    add.s64 %rd10, %rd8, %rd8;
    setp.eq.s32 %p4, %r7, %r19;
    setp.gt.s32 %p3, %r7, 15;
    shr.s32 %r14, %r3, 0;
    shl.b32 %r7, %r19, 15;
    shr.u32 %r6, %r7, 16;
    sub.s32 %r19, %r7, %r12;
    xor.b32 %r18, %r19, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
