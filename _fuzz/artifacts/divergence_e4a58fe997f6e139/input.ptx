    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r21, %r3, %r3, %r3;
    cvt.s64.s32 %rd6, %r3;
    min.u32 %r20, %r21, 1;
    setp.lo.u32 %p3, %r3, %r3;
    sub.u32 %r27, %r3, %r20;
    cvt.u32.u64 %r14, %rd6;
    min.u32 %r19, %r20, 4294967295;
    max.s64 %rd10, %rd6, %rd6;
    mul.lo.s32 %r14, %r21, %r21;
    mad.lo.s32 %r23, %r20, %r14, %r14;
    mul.lo.s32 %r20, %r21, 15;
    shl.b32 %r7, %r21, 1;
    selp.b32 %r26, %r23, %r3, %p3;
    or.b64 %rd15, %rd10, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
