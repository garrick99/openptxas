.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r9, %r3, 15;
    mul.wide.u32 %rd10, %r9, %r9;
    or.b32 %r27, %r9, %r3;
    mul.wide.u32 %rd8, %r27, %r27;
    shl.b32 %r6, %r27, 0;
    mul.wide.u32 %rd11, %r3, %r6;
    shr.u32 %r10, %r3, 3;
    cvt.s32.s64 %r6, %rd8;
    sub.u32 %r11, %r6, 65536;
    max.u32 %r15, %r10, 65535;
    min.u32 %r16, %r10, %r3;
    sub.u32 %r22, %r11, 65535;
    mul.lo.s32 %r20, %r15, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
