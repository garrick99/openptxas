.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r14, %r3, 255;
    cvt.s64.s32 %rd6, %r14;
    mul.wide.s32 %rd15, %r14, %r3;
    xor.b32 %r27, %r14, %r3;
    and.b32 %r13, %r3, %r3;
    add.s32 %r24, %r27, 4;
    mad.lo.u32 %r9, %r13, %r3, %r3;
    shr.s64 %rd11, %rd15, 1;
    cvt.s64.s32 %rd12, %r13;
    shr.u32 %r8, %r24, 30;
    shl.b64 %rd13, %rd15, 16;
    shl.b64 %rd12, %rd12, 62;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
