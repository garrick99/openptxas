.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hi.u32 %p2, %r3, %r3;
    @!%p2 shr.s32 %r21, %r3, 4;
    cvt.s64.s32 %rd10, %r3;
    shr.s32 %r25, %r3, 15;
    cvt.s32.s64 %r7, %rd10;
    xor.b32 %r20, %r25, %r25;
    min.s32 %r9, %r7, %r21;
    mad.lo.u32 %r23, %r21, %r21, %r7;
    cvt.s32.s64 %r10, %rd10;
    mul.lo.u32 %r12, %r7, 256;
    mul.lo.s32 %r27, %r12, %r9;
    cvt.u32.u64 %r4, %rd10;
    sub.u32 %r20, %r9, 2147483647;
    add.s64 %rd14, %rd10, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
