.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r6, %r3, 4;
    max.u32 %r18, %r6, 3;
    max.u32 %r27, %r18, 16;
    mul.wide.s32 %rd15, %r27, %r18;
    sub.s32 %r24, %r6, %r18;
    and.b32 %r19, %r24, 4;
    or.b32 %r20, %r27, 2;
    shr.s64 %rd7, %rd15, 47;
    shr.u32 %r23, %r24, 31;
    xor.b32 %r21, %r19, %r19;
    setp.ls.u32 %p4, %r21, 4;
    @%p4 shr.s32 %r11, %r21, 31;
    selp.b32 %r23, %r20, %r21, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
