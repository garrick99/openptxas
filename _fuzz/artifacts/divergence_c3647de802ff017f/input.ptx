.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r25, %r3, %r3;
    sub.u32 %r19, %r3, 0;
    mul.lo.u32 %r22, %r19, %r25;
    setp.ne.s32 %p4, %r19, %r19;
    @%p4 shl.b32 %r14, %r3, 1;
    shr.u32 %r19, %r14, 16;
    selp.b32 %r23, %r19, %r14, %p4;
    mul.wide.u32 %rd9, %r23, %r3;
    sub.s32 %r27, %r14, %r25;
    mul.wide.u32 %rd15, %r25, %r14;
    mad.lo.u32 %r10, %r25, %r27, %r25;
    shr.s32 %r26, %r14, 1;
    cvt.s32.s64 %r25, %rd15;
    mul.wide.u32 %rd11, %r27, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
