.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    add.u32 %r11, %r3, %r3;
    shr.s64 %rd11, %rd12, 63;
    min.u32 %r16, %r3, 31;
    cvt.s32.s64 %r21, %rd12;
    add.u64 %rd14, %rd12, %rd12;
    min.s32 %r16, %r11, %r11;
    cvt.s64.s32 %rd8, %r11;
    mad.lo.s32 %r15, %r16, %r11, %r21;
    cvt.u64.u32 %rd15, %r16;
    mul.lo.s32 %r4, %r3, %r11;
    max.u32 %r17, %r4, %r11;
    setp.eq.s32 %p1, %r21, %r17;
    @%p1 max.s64 %rd10, %rd12, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
