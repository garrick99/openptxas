    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r9, %r3, 31;
    cvt.s64.s32 %rd13, %r9;
    add.u32 %r5, %r3, %r9;
    min.s32 %r22, %r5, 64;
