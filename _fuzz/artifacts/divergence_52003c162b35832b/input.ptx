.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r10, %r3, %r3;
    mul.lo.s32 %r21, %r3, 32;
    shl.b32 %r14, %r21, 4;
    shr.u32 %r6, %r10, 7;
    setp.eq.u32 %p4, %r21, %r14;
    @%p4 shl.b32 %r20, %r10, 31;
    cvt.s64.s32 %rd11, %r6;
    shl.b32 %r27, %r6, 2;
    cvt.s32.s64 %r16, %rd11;
    shl.b32 %r9, %r20, 7;
    max.u32 %r15, %r21, 256;
    add.s32 %r17, %r21, %r21;
    sub.s32 %r20, %r21, 16;
    or.b32 %r14, %r17, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
