.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    cvt.s32.s64 %r7, %rd10;
    cvt.s32.s64 %r9, %rd10;
    min.s32 %r4, %r3, %r9;
    max.u32 %r27, %r3, 16;
    min.s64 %rd9, %rd10, %rd10;
    mad.lo.s32 %r14, %r7, %r27, %r27;
    cvt.u32.u64 %r5, %rd10;
    cvt.s32.s64 %r9, %rd9;
    min.s32 %r24, %r14, 2;
    shr.s32 %r16, %r5, 3;
    mad.lo.u32 %r19, %r3, %r16, %r24;
    setp.gt.u32 %p4, %r5, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
