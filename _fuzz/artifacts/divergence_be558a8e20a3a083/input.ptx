.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r11, %r3, %r3, %r3;
    and.b32 %r14, %r11, %r11;
    max.s32 %r13, %r11, %r11;
    cvt.s64.s32 %rd7, %r13;
    xor.b64 %rd5, %rd7, %rd7;
    cvt.s32.s64 %r19, %rd5;
    or.b64 %rd14, %rd5, %rd7;
    min.s32 %r17, %r13, %r14;
    cvt.s32.s64 %r4, %rd7;
    setp.eq.s32 %p4, %r13, %r17;
    max.s32 %r27, %r4, 65536;
    max.s32 %r15, %r3, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
