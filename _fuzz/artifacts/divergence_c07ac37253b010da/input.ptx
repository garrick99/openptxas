.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p3, %r3, %r3;
    @%p3 max.s32 %r27, %r3, 65535;
    max.u32 %r26, %r3, 4294967295;
    selp.b32 %r5, %r27, %r3, %p3;
    mul.wide.u32 %rd9, %r3, %r26;
    add.u32 %r15, %r3, 256;
    and.b32 %r24, %r15, 31;
    mul.wide.u32 %rd10, %r27, %r15;
    shr.s64 %rd13, %rd10, 63;
    setp.ge.s32 %p4, %r5, %r5;
    @!%p4 shl.b32 %r15, %r15, 2;
    add.u32 %r18, %r15, %r27;
    xor.b32 %r10, %r18, 1;
    mul.wide.s32 %rd13, %r15, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
