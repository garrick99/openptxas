.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p4, %r3, %r3;
    cvt.s64.s32 %rd12, %r3;
    cvt.s64.s32 %rd14, %r3;
    mul.wide.s32 %rd7, %r3, %r3;
    shl.b32 %r7, %r3, 1;
    setp.le.u32 %p3, %r3, %r3;
    mad.lo.u32 %r19, %r7, %r3, %r3;
    shr.u64 %rd7, %rd14, 63;
    max.u32 %r20, %r7, %r19;
    or.b32 %r15, %r3, 1;
    or.b32 %r8, %r19, %r15;
    selp.b32 %r11, %r19, %r20, %p3;
    mad.lo.s32 %r12, %r20, %r7, %r19;
    shr.u32 %r15, %r20, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
