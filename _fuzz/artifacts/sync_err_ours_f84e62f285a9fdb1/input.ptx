.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    cvt.s32.s64 %r24, %rd15;
    cvt.s32.s64 %r4, %rd15;
    sub.s32 %r23, %r3, 16;
    shr.s32 %r27, %r24, 30;
    sub.s32 %r4, %r23, 0;
    sub.u32 %r9, %r23, %r23;
    shl.b32 %r25, %r24, 7;
    sub.s32 %r19, %r3, 255;
    sub.s32 %r16, %r3, %r9;
    or.b64 %rd12, %rd15, %rd15;
    setp.eq.s32 %p3, %r23, %r4;
    @!%p3 mul.wide.s32 %rd10, %r27, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
