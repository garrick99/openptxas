.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r21, %r3, %r3;
    cvt.s64.s32 %rd5, %r21;
    shl.b32 %r13, %r21, 31;
    cvt.u32.u64 %r13, %rd5;
    mul.wide.u32 %rd14, %r21, %r13;
    xor.b32 %r5, %r13, %r21;
    sub.u32 %r6, %r5, %r5;
    and.b64 %rd15, %rd14, %rd5;
    xor.b64 %rd5, %rd14, %rd15;
    shr.s32 %r9, %r13, 3;
    mad.lo.s32 %r24, %r13, %r3, %r6;
    setp.le.s32 %p3, %r21, %r13;
    @%p3 min.u32 %r14, %r6, 63;
    shr.u64 %rd8, %rd15, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
