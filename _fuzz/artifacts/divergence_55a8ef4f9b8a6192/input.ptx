.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    shl.b32 %r6, %r3, 3;
    min.s32 %r23, %r6, %r3;
    mad.lo.s32 %r13, %r3, %r6, %r3;
    cvt.s64.s32 %rd9, %r13;
    min.s32 %r15, %r13, %r6;
    setp.gt.s32 %p1, %r13, %r23;
    setp.ne.s32 %p1, %r23, %r13;
    @%p1 sub.u32 %r22, %r23, %r3;
    max.s32 %r27, %r3, 2;
    setp.gt.s32 %p3, %r13, %r22;
    @%p3 and.b32 %r9, %r22, %r15;
    setp.lo.u32 %p1, %r15, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
