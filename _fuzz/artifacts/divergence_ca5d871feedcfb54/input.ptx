.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r20, %r3, 65535;
    cvt.s64.s32 %rd13, %r20;
    min.s32 %r12, %r20, 2147483647;
    min.s32 %r11, %r20, 256;
    shr.s64 %rd14, %rd13, 3;
    or.b32 %r5, %r12, %r3;
    min.s32 %r20, %r20, 65535;
    min.u64 %rd7, %rd14, %rd14;
    setp.hi.u32 %p4, %r12, %r20;
    selp.b32 %r18, %r5, %r3, %p4;
    selp.b32 %r5, %r11, %r11, %p4;
    shr.u64 %rd10, %rd7, 32;
    cvt.u64.u32 %rd7, %r12;
    cvt.u64.u32 %rd5, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
