.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    clz.b32 %r11, %r3;
    bfe.s32 %r9, %r11, 15, 8;
    bfe.s32 %r12, %r9, 23, 2;
    bfe.s32 %r20, %r9, 8, 8;
    popc.b32 %r5, %r11;
    bfi.b32 %r23, %r12, %r20, 16, 7;
    bfe.s32 %r5, %r5, 7, 4;
    bfi.b32 %r19, %r9, %r11, 4, 31;
    brev.b32 %r21, %r3;
    bfi.b32 %r9, %r11, %r21, 24, 24;
    bfi.b32 %r14, %r21, %r23, 16, 1;
    xor.b32 %r11, %r14, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
