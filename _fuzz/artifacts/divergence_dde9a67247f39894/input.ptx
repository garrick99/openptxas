.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    shr.u64 %rd13, %rd6, 63;
    min.u32 %r15, %r3, %r3;
    shr.u64 %rd11, %rd6, 1;
    setp.lt.s32 %p2, %r15, 256;
    @!%p2 mul.lo.u32 %r16, %r3, %r15;
    sub.u32 %r15, %r16, 65536;
    shr.s64 %rd11, %rd6, 31;
    mad.lo.u32 %r8, %r15, %r16, %r16;
    cvt.u32.u64 %r23, %rd6;
    cvt.u64.u32 %rd8, %r23;
    mad.lo.s32 %r21, %r23, %r3, %r16;
    max.u32 %r10, %r8, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
