.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r6, %r3, 4;
    max.s32 %r25, %r6, 8;
    mad.lo.s32 %r26, %r6, %r3, %r6;
    mul.wide.u32 %rd10, %r6, %r6;
    mul.lo.s32 %r24, %r26, %r25;
    max.s64 %rd12, %rd10, %rd10;
    sub.u32 %r11, %r26, %r26;
    cvt.u64.u32 %rd12, %r3;
    setp.le.s32 %p3, %r26, 15;
    @!%p3 shr.u64 %rd8, %rd10, 15;
    sub.s64 %rd9, %rd10, %rd10;
    shl.b64 %rd9, %rd12, 33;
    selp.b32 %r17, %r26, %r6, %p3;
    selp.b32 %r4, %r24, %r25, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
