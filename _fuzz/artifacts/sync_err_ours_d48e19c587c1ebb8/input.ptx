.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    min.s32 %r15, %r3, 64;
    min.u32 %r13, %r3, %r3;
    mul.wide.s32 %rd15, %r3, %r3;
    cvt.u32.u64 %r27, %rd8;
    shr.u32 %r15, %r15, 30;
    setp.lo.u32 %p4, %r27, %r27;
    setp.lt.s32 %p4, %r13, 65536;
    min.s64 %rd9, %rd8, %rd15;
    and.b32 %r21, %r13, %r13;
    cvt.s64.s32 %rd10, %r27;
    mad.lo.u32 %r16, %r27, %r27, %r27;
    shl.b64 %rd8, %rd8, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
