.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r12, %r3, %r3, %r3;
    setp.lt.u32 %p1, %r3, %r12;
    @!%p1 cvt.u64.u32 %rd7, %r12;
    max.s64 %rd9, %rd7, %rd7;
    selp.b32 %r7, %r12, %r12, %p1;
    shr.s32 %r10, %r7, 30;
    setp.gt.s32 %p1, %r3, 63;
    @!%p1 shl.b64 %rd10, %rd9, 32;
    add.u32 %r27, %r12, %r3;
    mad.lo.u32 %r9, %r10, %r3, %r12;
    min.u32 %r11, %r3, 31;
    and.b32 %r9, %r12, %r9;
    xor.b64 %rd5, %rd10, %rd10;
    min.u32 %r25, %r11, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
