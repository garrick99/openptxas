.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r6, %r3, %r3;
    xor.b32 %r6, %r6, 15;
    cvt.u64.u32 %rd10, %r3;
    min.u32 %r4, %r3, %r6;
    mad.lo.s32 %r24, %r3, %r6, %r4;
    setp.hs.u32 %p4, %r3, %r3;
    setp.le.u32 %p1, %r4, %r6;
    @%p1 shl.b32 %r12, %r4, 15;
    mul.wide.s32 %rd7, %r3, %r3;
    mul.lo.s32 %r12, %r6, 1;
    add.s32 %r12, %r4, %r3;
    min.u32 %r4, %r24, %r6;
    mul.lo.s32 %r9, %r12, %r4;
    setp.eq.u32 %p1, %r12, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
