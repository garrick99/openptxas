.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    mul.lo.u32 %r10, %r3, 0;
    max.u32 %r14, %r3, %r10;
    shl.b32 %r6, %r10, 0;
    max.s32 %r4, %r10, 8;
    min.u64 %rd14, %rd10, %rd10;
    min.s32 %r17, %r3, %r14;
    add.s32 %r17, %r3, %r4;
    add.u64 %rd7, %rd14, %rd14;
    setp.ne.s32 %p4, %r17, 255;
    setp.gt.s32 %p4, %r4, %r17;
    min.s32 %r23, %r6, %r3;
    min.s32 %r8, %r10, %r17;
    shl.b32 %r24, %r8, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
