.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r16, %r3, 7;
    or.b32 %r10, %r16, %r3;
    mul.wide.u32 %rd12, %r10, %r3;
    setp.eq.s32 %p2, %r10, %r10;
    @!%p2 shr.u32 %r9, %r16, 7;
    and.b32 %r6, %r10, %r9;
    mad.lo.u32 %r25, %r16, %r3, %r16;
    setp.eq.u32 %p3, %r9, 1;
    @%p3 shr.u32 %r27, %r16, 15;
    max.u32 %r16, %r25, %r3;
    min.s32 %r22, %r27, %r9;
    shr.s64 %rd6, %rd12, 2;
    shl.b32 %r7, %r25, 7;
    min.u32 %r27, %r9, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
