.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    xor.b32 %r18, %r3, 2;
    setp.le.s32 %p3, %r3, %r18;
    @!%p3 and.b32 %r14, %r3, 4294967295;
    mul.lo.u32 %r12, %r3, 2;
    max.s32 %r12, %r14, 4294967295;
    shr.u32 %r9, %r18, 4;
    mul.lo.u32 %r4, %r3, %r9;
    sub.u32 %r22, %r14, %r4;
    selp.b32 %r19, %r22, %r18, %p3;
    mul.lo.u32 %r13, %r14, %r22;
    mul.wide.u32 %rd14, %r19, %r19;
    cvt.s32.s64 %r4, %rd9;
    and.b32 %r8, %r14, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
