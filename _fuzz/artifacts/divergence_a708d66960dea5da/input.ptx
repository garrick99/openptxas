.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    mul.lo.s32 %r18, %r3, 4294967295;
    shl.b64 %rd11, %rd8, 3;
    add.u32 %r17, %r3, 32;
    min.u32 %r11, %r18, %r18;
    xor.b32 %r14, %r17, 65535;
    cvt.s32.s64 %r27, %rd11;
    shr.s64 %rd15, %rd8, 0;
    max.s32 %r16, %r17, %r14;
    setp.eq.u32 %p4, %r14, %r16;
    and.b32 %r5, %r11, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
