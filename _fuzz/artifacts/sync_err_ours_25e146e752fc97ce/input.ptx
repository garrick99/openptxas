.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r11, %r3, %r3;
    cvt.s64.s32 %rd12, %r3;
    xor.b32 %r9, %r3, 32;
    shr.s32 %r24, %r3, 1;
    add.s32 %r11, %r3, 0;
    and.b32 %r16, %r3, %r24;
    shl.b64 %rd9, %rd12, 33;
    max.s32 %r12, %r11, 0;
    shr.s32 %r20, %r3, 3;
    or.b32 %r14, %r9, %r12;
    cvt.s64.s32 %rd15, %r16;
    sub.s32 %r5, %r11, %r9;
    shr.u32 %r13, %r9, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
