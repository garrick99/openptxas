.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r26, %r3, 16;
    mad.lo.s32 %r25, %r26, %r26, %r26;
    shr.u32 %r18, %r3, 3;
    sub.u32 %r16, %r26, 7;
    xor.b32 %r21, %r16, %r25;
    mul.wide.u32 %rd5, %r25, %r21;
    sub.s32 %r18, %r16, %r3;
    cvt.u64.u32 %rd12, %r26;
    and.b64 %rd13, %rd12, %rd12;
    sub.u32 %r21, %r16, 63;
    xor.b32 %r17, %r25, 31;
    cvt.u32.u64 %r24, %rd13;
    and.b32 %r11, %r21, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
