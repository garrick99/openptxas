.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r4, %r3, 63;
    add.s32 %r25, %r3, %r4;
    cvt.u64.u32 %rd7, %r4;
    shr.s64 %rd8, %rd7, 7;
    setp.ls.u32 %p1, %r25, %r4;
    mul.wide.u32 %rd6, %r4, %r4;
    cvt.u32.u64 %r4, %rd7;
    mad.lo.s32 %r16, %r25, %r25, %r25;
    setp.le.u32 %p3, %r4, %r4;
    max.s32 %r17, %r25, %r16;
    or.b32 %r25, %r16, %r17;
    max.u32 %r13, %r17, 16;
    or.b64 %rd15, %rd7, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
