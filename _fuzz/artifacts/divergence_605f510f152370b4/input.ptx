.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r21, %r3, 3;
    setp.gt.s32 %p1, %r21, 0;
    @%p1 or.b32 %r4, %r21, 32;
    shl.b32 %r24, %r4, 31;
    mul.wide.u32 %rd14, %r24, %r24;
    mad.lo.u32 %r21, %r4, %r24, %r3;
    or.b32 %r14, %r3, %r4;
    setp.gt.u32 %p3, %r4, %r14;
    @%p3 min.u32 %r18, %r21, 31;
    max.s32 %r11, %r24, 4;
    add.s32 %r13, %r24, 1;
    shr.u32 %r12, %r13, 7;
    mul.lo.u32 %r25, %r21, %r4;
    shl.b64 %rd15, %rd14, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
