.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd14, %r3, %r3;
    shl.b64 %rd5, %rd14, 48;
    shr.s64 %rd13, %rd14, 7;
    setp.ne.u32 %p1, %r3, %r3;
    @%p1 mul.lo.u32 %r21, %r3, 255;
    mad.lo.s32 %r6, %r3, %r21, %r3;
    mad.lo.u32 %r26, %r6, %r21, %r6;
    shr.u32 %r13, %r21, 30;
    sub.u32 %r15, %r6, %r21;
    mad.lo.u32 %r11, %r21, %r26, %r3;
    shl.b64 %rd14, %rd14, 48;
    cvt.s64.s32 %rd15, %r15;
    add.s32 %r16, %r13, %r21;
    max.u32 %r20, %r3, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
