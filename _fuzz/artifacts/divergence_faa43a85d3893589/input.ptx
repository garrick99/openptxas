.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r13, %r3, 8;
    mul.lo.s32 %r15, %r13, %r3;
    add.u32 %r24, %r13, 65535;
    sub.s32 %r21, %r13, %r3;
    cvt.s64.s32 %rd10, %r21;
    sub.u32 %r17, %r3, %r24;
    add.u32 %r10, %r21, 65535;
    add.u32 %r23, %r21, 32;
    mul.wide.s32 %rd15, %r17, %r15;
    cvt.u32.u64 %r17, %rd15;
    cvt.s32.s64 %r4, %rd15;
    mul.wide.u32 %rd10, %r24, %r3;
    add.s32 %r27, %r3, %r15;
    mad.lo.u32 %r8, %r21, %r10, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
