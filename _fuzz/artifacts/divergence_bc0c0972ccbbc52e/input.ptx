.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r15, %r3, 4294967295;
    mul.wide.s32 %rd11, %r15, %r3;
    mul.lo.s32 %r26, %r3, 63;
    sub.s64 %rd14, %rd11, %rd11;
    shr.u32 %r25, %r3, 15;
    shl.b32 %r16, %r26, 7;
    shr.u64 %rd8, %rd14, 47;
    shl.b32 %r15, %r26, 0;
    setp.lt.u32 %p1, %r26, %r25;
    add.s32 %r25, %r25, 32;
    shr.s64 %rd10, %rd14, 47;
    cvt.s32.s64 %r10, %rd8;
    cvt.s32.s64 %r25, %rd11;
    cvt.u64.u32 %rd9, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
