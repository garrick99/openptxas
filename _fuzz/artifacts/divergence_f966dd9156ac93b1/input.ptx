.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r18, %r3, %r3, %r3;
    shr.u32 %r19, %r3, 4;
    mul.wide.s32 %rd8, %r18, %r3;
    cvt.s32.s64 %r11, %rd8;
    min.s64 %rd7, %rd8, %rd8;
    and.b64 %rd14, %rd8, %rd7;
    mul.wide.s32 %rd15, %r19, %r11;
    sub.u32 %r22, %r18, %r18;
    sub.u32 %r27, %r18, %r19;
    add.u32 %r15, %r18, %r22;
    mul.lo.u32 %r4, %r3, %r11;
    min.u64 %rd6, %rd14, %rd8;
    add.u32 %r26, %r18, %r19;
    max.u32 %r6, %r26, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
