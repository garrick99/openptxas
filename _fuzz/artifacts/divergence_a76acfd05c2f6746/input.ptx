.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r4, %r3, 8;
    cvt.s64.s32 %rd12, %r3;
    min.s32 %r6, %r4, 7;
    setp.ne.u32 %p3, %r4, %r4;
    @%p3 mul.lo.s64 %rd8, %rd12, %rd12;
    min.s64 %rd11, %rd8, %rd12;
    mul.lo.s32 %r15, %r6, 65535;
    mul.wide.u32 %rd9, %r3, %r15;
    sub.s32 %r22, %r3, %r4;
    shl.b32 %r9, %r15, 30;
    min.u32 %r23, %r22, 16;
    mul.lo.u32 %r10, %r23, 2147483647;
    sub.s32 %r15, %r15, %r9;
    mul.lo.s32 %r10, %r6, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
