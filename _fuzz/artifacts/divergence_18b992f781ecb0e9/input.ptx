.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    mul.lo.s32 %r5, %r3, %r3;
    mul.lo.s32 %r20, %r5, 65536;
    mul.lo.u32 %r24, %r5, %r20;
    shr.u32 %r22, %r20, 2;
    xor.b64 %rd6, %rd13, %rd13;
    mul.wide.u32 %rd8, %r24, %r20;
    sub.s32 %r25, %r24, %r24;
    shr.u32 %r20, %r5, 30;
    min.s32 %r20, %r25, %r22;
    shr.u64 %rd7, %rd6, 15;
    mad.lo.u32 %r25, %r25, %r24, %r5;
    setp.eq.s32 %p3, %r5, %r3;
    @%p3 add.u32 %r8, %r24, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
