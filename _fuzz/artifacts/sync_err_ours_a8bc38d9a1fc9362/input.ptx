.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd14, %r3, %r3;
    cvt.s32.s64 %r22, %rd14;
    xor.b64 %rd11, %rd14, %rd14;
    cvt.s64.s32 %rd8, %r3;
    add.s32 %r14, %r22, %r22;
    shr.s32 %r12, %r3, 4;
    add.s32 %r6, %r22, %r22;
    mul.lo.u32 %r7, %r12, 1;
    shl.b64 %rd12, %rd11, 4;
    max.s32 %r14, %r3, %r3;
    mul.wide.u32 %rd6, %r12, %r22;
    add.s32 %r23, %r22, %r7;
    shl.b64 %rd14, %rd8, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
