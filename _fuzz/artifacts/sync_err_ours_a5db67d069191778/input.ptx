.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    shl.b64 %rd12, %rd14, 0;
    mul.wide.s32 %rd8, %r3, %r3;
    or.b32 %r10, %r3, 65535;
    max.u32 %r26, %r3, %r10;
    cvt.s32.s64 %r15, %rd14;
    setp.eq.s32 %p3, %r3, 4;
    @%p3 mul.wide.s32 %rd8, %r15, %r26;
    cvt.u64.u32 %rd10, %r10;
    mul.lo.s32 %r25, %r3, %r15;
    shr.s32 %r14, %r25, 0;
    max.s64 %rd5, %rd14, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
