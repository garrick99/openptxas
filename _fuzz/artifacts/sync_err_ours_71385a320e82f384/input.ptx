.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r9, %r3, %r3;
    mul.wide.u32 %rd9, %r3, %r3;
    min.s64 %rd15, %rd9, %rd9;
    setp.ne.s32 %p4, %r3, 2;
    @%p4 selp.b32 %r5, %r9, %r3, %p4;
    add.s64 %rd10, %rd15, %rd15;
    setp.ls.u32 %p3, %r3, %r9;
    @%p3 min.u32 %r23, %r9, 4;
    and.b32 %r13, %r9, %r9;
    shr.s32 %r23, %r3, 31;
    or.b32 %r5, %r13, %r13;
    shr.u32 %r7, %r5, 1;
    or.b32 %r7, %r7, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
