.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd6, %r3, %r3;
    add.s32 %r16, %r3, 3;
    max.s32 %r7, %r3, 8;
    or.b64 %rd6, %rd6, %rd6;
    mul.wide.s32 %rd11, %r7, %r3;
    setp.ne.s32 %p1, %r3, 4294967295;
    mul.lo.s64 %rd8, %rd11, %rd11;
    sub.s64 %rd7, %rd11, %rd6;
    setp.eq.s32 %p2, %r7, %r16;
    @%p2 shr.u32 %r8, %r3, 4;
    mad.lo.s32 %r10, %r8, %r8, %r7;
    max.u32 %r12, %r10, %r7;
    shr.u64 %rd13, %rd8, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
