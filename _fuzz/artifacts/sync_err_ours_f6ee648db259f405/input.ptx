.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r4, %r3, 3;
    setp.hi.u32 %p2, %r3, %r4;
    @%p2 cvt.u64.u32 %rd9, %r3;
    selp.b32 %r6, %r3, %r3, %p2;
    mul.wide.u32 %rd15, %r3, %r3;
    or.b32 %r27, %r6, 63;
    xor.b64 %rd8, %rd9, %rd15;
    shr.s32 %r11, %r27, 15;
    cvt.s32.s64 %r20, %rd15;
    max.u32 %r18, %r6, %r27;
    mul.wide.u32 %rd9, %r3, %r11;
    shr.s64 %rd8, %rd9, 62;
    cvt.u32.u64 %r24, %rd15;
    setp.eq.s32 %p1, %r6, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
