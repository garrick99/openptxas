.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r15, %r3, 5;
    add.s32 %r20, %r3, %r3;
    mul.wide.s32 %rd11, %r20, %r20;
    mul.wide.u32 %rd6, %r20, %r15;
    shr.u32 %r4, %r15, 16;
    cvt.u32.u64 %r26, %rd6;
    mul.lo.s32 %r26, %r15, 65535;
    setp.ge.u32 %p2, %r3, %r15;
    @!%p2 mad.lo.s32 %r13, %r3, %r4, %r3;
    cvt.u64.u32 %rd13, %r20;
    shr.u32 %r15, %r13, 4;
    add.u32 %r27, %r4, 2147483647;
    mul.lo.u64 %rd6, %rd6, %rd13;
    selp.b32 %r5, %r15, %r3, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
