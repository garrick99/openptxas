.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r26, %r3, 0;
    add.u32 %r27, %r3, %r3;
    mad.lo.u32 %r10, %r3, %r26, %r27;
    xor.b32 %r12, %r3, %r3;
    add.s32 %r11, %r3, %r27;
    cvt.s64.s32 %rd11, %r12;
    min.u32 %r12, %r11, 7;
    cvt.u32.u64 %r19, %rd11;
    mad.lo.s32 %r4, %r19, %r12, %r27;
    cvt.s32.s64 %r24, %rd11;
    mad.lo.s32 %r26, %r11, %r11, %r27;
    min.s32 %r9, %r12, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
