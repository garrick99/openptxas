.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.up.b32 %r4, %r3, 2, 0x1f, -1;
    shfl.sync.up.b32 %r10, %r4, 8, 0x1f, -1;
    shfl.sync.down.b32 %r7, %r4, 16, 0x1f, -1;
    max.u32 %r13, %r0, %r4;
    shfl.sync.up.b32 %r18, %r0, 1, 0x1f, -1;
    sub.u32 %r13, %r7, %r7;
    setp.eq.u32 %p3, %r4, 3;
    vote.sync.ballot.b32 %r10, %p3, -1;
    setp.ne.u32 %p3, %r10, 15;
    vote.sync.ballot.b32 %r16, %p3, -1;
    sub.u32 %r12, %r10, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
