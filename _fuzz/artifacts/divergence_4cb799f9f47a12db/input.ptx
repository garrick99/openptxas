.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r10, %r3, 16;
    sub.s32 %r18, %r3, 1;
    sub.u32 %r9, %r3, %r3;
    and.b32 %r27, %r9, 16;
    shr.s32 %r10, %r18, 15;
    setp.lt.s32 %p2, %r9, %r3;
    @!%p2 cvt.u64.u32 %rd11, %r10;
    setp.ne.s32 %p4, %r3, 3;
    sub.s32 %r7, %r18, 2147483647;
    setp.gt.s32 %p1, %r10, %r10;
    @%p1 min.s32 %r14, %r18, 64;
    shr.s64 %rd13, %rd11, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
