.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r21, %r3, 2147483648;
    add.s32 %r6, %r3, 255;
    min.u32 %r11, %r3, 4;
    setp.lt.u32 %p3, %r11, 15;
    setp.eq.s32 %p2, %r11, %r21;
    @%p2 min.s32 %r17, %r11, %r3;
    shr.s32 %r20, %r17, 1;
    min.s32 %r6, %r21, 64;
    sub.s32 %r10, %r3, %r11;
    or.b32 %r24, %r20, %r6;
    sub.u32 %r20, %r6, 32;
    mul.lo.s32 %r27, %r10, 15;
    add.s32 %r20, %r17, %r24;
    shl.b32 %r8, %r20, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
