.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r17, %r3, %r3, %r3;
    shl.b32 %r9, %r3, 2;
    cvt.u64.u32 %rd13, %r9;
    cvt.s32.s64 %r6, %rd13;
    min.s32 %r5, %r9, 32;
    add.s64 %rd6, %rd13, %rd13;
    mul.lo.u32 %r16, %r9, %r9;
    mad.lo.s32 %r11, %r9, %r3, %r9;
    max.s64 %rd7, %rd13, %rd13;
    max.s32 %r22, %r6, %r3;
    setp.lo.u32 %p4, %r6, 4294967295;
    selp.b32 %r6, %r6, %r11, %p4;
    mad.lo.s32 %r10, %r6, %r17, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
