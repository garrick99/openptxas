.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r9, %r3, 15;
    cvt.u64.u32 %rd12, %r9;
    xor.b32 %r6, %r9, %r3;
    mul.lo.u64 %rd13, %rd12, %rd12;
    min.u32 %r16, %r3, %r9;
    mul.wide.u32 %rd15, %r9, %r6;
    min.u32 %r5, %r6, %r9;
    shr.u32 %r26, %r6, 30;
    setp.eq.s32 %p1, %r16, 65536;
    shr.s64 %rd7, %rd13, 33;
    max.s32 %r25, %r16, %r3;
    selp.b32 %r9, %r9, %r9, %p1;
    or.b64 %rd9, %rd15, %rd15;
    and.b64 %rd13, %rd12, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
