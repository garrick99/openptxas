.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r25, %r3, 8;
    mul.wide.s32 %rd8, %r3, %r3;
    shl.b32 %r4, %r3, 16;
    xor.b32 %r10, %r3, %r4;
    shr.u64 %rd8, %rd8, 15;
    mad.lo.s32 %r9, %r3, %r4, %r4;
    mul.lo.s32 %r16, %r4, %r3;
    setp.ls.u32 %p1, %r16, %r10;
    max.s32 %r25, %r4, %r4;
    shr.s64 %rd5, %rd8, 62;
    add.s32 %r10, %r25, %r25;
    selp.b32 %r21, %r9, %r25, %p1;
    max.s32 %r16, %r21, %r21;
    max.s64 %rd10, %rd8, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
