.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r10, %r3, 5;
    cvt.u64.u32 %rd8, %r3;
    mul.lo.s32 %r20, %r10, 15;
    add.u64 %rd7, %rd8, %rd8;
    mul.lo.u64 %rd5, %rd8, %rd8;
    shr.s32 %r18, %r3, 2;
    and.b32 %r12, %r18, %r20;
    mul.lo.u32 %r16, %r3, %r20;
    shr.u32 %r24, %r16, 4;
    mul.wide.s32 %rd11, %r16, %r12;
    shr.u32 %r6, %r10, 15;
    shl.b32 %r16, %r18, 4;
    sub.s32 %r13, %r16, 15;
    shr.u64 %rd15, %rd8, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
