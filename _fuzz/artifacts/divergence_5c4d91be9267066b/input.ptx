.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r14, %r3, %r3;
    setp.hi.u32 %p4, %r14, %r3;
    @%p4 max.u32 %r10, %r3, %r3;
    xor.b32 %r8, %r10, %r14;
    cvt.u64.u32 %rd5, %r14;
    mul.wide.s32 %rd7, %r3, %r3;
    sub.u32 %r15, %r8, %r10;
    setp.le.u32 %p4, %r10, %r14;
    @!%p4 selp.b32 %r16, %r8, %r10, %p4;
    min.u32 %r25, %r10, %r8;
    max.s32 %r15, %r15, %r14;
    shr.u64 %rd12, %rd5, 2;
    add.u32 %r25, %r14, %r25;
    and.b32 %r5, %r8, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
