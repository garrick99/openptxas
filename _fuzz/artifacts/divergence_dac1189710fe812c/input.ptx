.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r24, %r3, 65536;
    mul.wide.s32 %rd6, %r3, %r3;
    max.s32 %r9, %r24, %r3;
    sub.s32 %r8, %r3, 1;
    setp.lo.u32 %p1, %r9, %r24;
    sub.s64 %rd7, %rd6, %rd6;
    sub.u32 %r18, %r8, 1;
    max.u32 %r25, %r9, 7;
    shl.b64 %rd11, %rd6, 62;
    min.u32 %r5, %r24, %r24;
    min.s64 %rd9, %rd6, %rd7;
    and.b32 %r27, %r8, 65536;
    xor.b32 %r10, %r8, %r8;
    add.s32 %r10, %r24, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
