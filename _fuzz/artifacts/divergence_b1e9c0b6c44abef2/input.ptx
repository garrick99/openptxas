.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    shl.b32 %r9, %r3, 30;
    mul.wide.s32 %rd7, %r9, %r9;
    max.u64 %rd7, %rd7, %rd9;
    mul.lo.s32 %r11, %r9, %r3;
    or.b32 %r20, %r11, %r3;
    shr.s32 %r6, %r3, 31;
    sub.s32 %r14, %r20, %r9;
    add.u32 %r21, %r3, 4;
    add.u32 %r15, %r3, 255;
    mad.lo.u32 %r18, %r6, %r21, %r6;
    setp.lt.s32 %p2, %r14, 4;
    cvt.u32.u64 %r8, %rd9;
    mul.lo.u32 %r12, %r18, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
