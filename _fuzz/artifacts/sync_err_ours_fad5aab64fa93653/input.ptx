.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    shl.b32 %r20, %r3, 1;
    mad.lo.s32 %r21, %r3, %r20, %r20;
    cvt.u32.u64 %r26, %rd14;
    min.s64 %rd5, %rd14, %rd14;
    mad.lo.u32 %r19, %r3, %r3, %r3;
    min.u64 %rd13, %rd14, %rd5;
    cvt.u64.u32 %rd10, %r21;
    cvt.s64.s32 %rd13, %r3;
    mad.lo.s32 %r14, %r3, %r19, %r21;
    shl.b64 %rd11, %rd13, 16;
    mul.lo.u32 %r21, %r26, 63;
    shr.u64 %rd6, %rd13, 7;
    max.u32 %r4, %r26, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
