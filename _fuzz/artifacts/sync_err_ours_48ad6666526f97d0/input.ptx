.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r5, %r3, %r3;
    setp.hi.u32 %p3, %r3, %r5;
    mul.wide.s32 %rd11, %r3, %r5;
    shr.s32 %r21, %r5, 0;
    mul.wide.s32 %rd12, %r5, %r21;
    shr.u32 %r16, %r5, 15;
    sub.u32 %r7, %r3, 32;
    sub.u32 %r7, %r7, 4;
    selp.b32 %r15, %r16, %r21, %p3;
    mul.wide.s32 %rd5, %r16, %r5;
    shr.u32 %r10, %r5, 7;
    selp.b32 %r22, %r16, %r10, %p3;
    add.u32 %r5, %r21, %r21;
    mad.lo.s32 %r19, %r15, %r22, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
