.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r14, %r3, 65536;
    cvt.s64.s32 %rd11, %r3;
    shl.b32 %r11, %r3, 0;
    mad.lo.s32 %r8, %r3, %r11, %r11;
    setp.le.u32 %p3, %r11, 64;
    @%p3 mad.lo.s32 %r24, %r3, %r14, %r3;
    selp.b32 %r25, %r24, %r24, %p3;
    xor.b32 %r13, %r25, 7;
    mad.lo.u32 %r16, %r14, %r24, %r13;
    or.b32 %r10, %r11, %r13;
    shr.s64 %rd6, %rd11, 15;
    cvt.s32.s64 %r27, %rd6;
    sub.u32 %r19, %r16, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
