.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r26, %r3, %r3;
    cvt.s64.s32 %rd11, %r26;
    or.b32 %r17, %r26, %r26;
    max.s32 %r21, %r3, 2;
    min.u32 %r9, %r26, %r17;
    sub.u32 %r13, %r21, 64;
    and.b32 %r4, %r3, %r26;
    mad.lo.s32 %r6, %r26, %r13, %r17;
    mad.lo.u32 %r21, %r13, %r4, %r13;
    sub.s32 %r7, %r3, %r6;
    shr.u64 %rd12, %rd11, 30;
    shr.s32 %r6, %r4, 15;
    mad.lo.u32 %r25, %r13, %r13, %r9;
    sub.u32 %r6, %r7, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
