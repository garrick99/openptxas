.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r17, %r3, 30;
    sub.s32 %r14, %r3, 5;
    shr.s32 %r23, %r17, 3;
    mul.lo.s32 %r19, %r17, 1;
    shr.u32 %r20, %r17, 16;
    setp.ge.s32 %p3, %r23, %r3;
    cvt.u64.u32 %rd11, %r17;
    shr.u64 %rd6, %rd11, 47;
    shr.u32 %r11, %r20, 30;
    add.s32 %r8, %r23, 16;
    min.u32 %r19, %r23, 7;
    max.u32 %r10, %r23, 0;
    sub.u32 %r21, %r3, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
