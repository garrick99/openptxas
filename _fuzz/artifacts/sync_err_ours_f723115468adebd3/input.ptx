.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r25, %r3, 16;
    cvt.s64.s32 %rd15, %r25;
    add.s32 %r26, %r25, 64;
    and.b32 %r17, %r26, %r25;
    max.s32 %r24, %r26, %r25;
    shr.s32 %r12, %r24, 7;
    or.b64 %rd14, %rd15, %rd15;
    max.u32 %r17, %r3, %r3;
    sub.u32 %r14, %r24, 2147483647;
    mul.wide.u32 %rd12, %r12, %r26;
    mul.lo.u32 %r14, %r12, %r26;
    shl.b32 %r8, %r26, 16;
    or.b32 %r15, %r3, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
