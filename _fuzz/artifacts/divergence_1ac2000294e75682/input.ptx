.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd11, %r3, %r3;
    cvt.u32.u64 %r19, %rd11;
    xor.b32 %r21, %r3, 4294967295;
    mul.lo.s32 %r18, %r21, %r21;
    max.s64 %rd13, %rd11, %rd11;
    max.u32 %r13, %r19, 2;
    sub.s32 %r16, %r21, 65536;
    max.s32 %r5, %r21, %r16;
    sub.u32 %r20, %r21, %r3;
    setp.lt.s32 %p4, %r18, %r13;
    setp.le.s32 %p2, %r20, %r16;
    add.u32 %r10, %r16, 0;
    max.u32 %r6, %r16, %r5;
    sub.s32 %r23, %r5, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
