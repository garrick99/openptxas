.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    add.s32 %r22, %r3, %r3;
    cvt.s32.s64 %r12, %rd5;
    mad.lo.u32 %r21, %r22, %r22, %r3;
    xor.b32 %r20, %r22, %r21;
    mul.lo.u32 %r18, %r3, %r3;
    max.u32 %r17, %r18, %r22;
    max.s32 %r18, %r20, %r12;
    mad.lo.u32 %r7, %r3, %r22, %r21;
    max.u32 %r21, %r3, %r7;
    add.u32 %r27, %r17, %r12;
    add.s32 %r6, %r17, 1;
    shr.u32 %r13, %r22, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
