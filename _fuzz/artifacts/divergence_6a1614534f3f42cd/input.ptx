.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r11, %r3, 3;
    setp.hi.u32 %p2, %r3, 256;
    @%p2 cvt.s64.s32 %rd13, %r3;
    shl.b64 %rd13, %rd13, 1;
    shl.b32 %r9, %r3, 30;
    shr.s64 %rd9, %rd13, 1;
    selp.b32 %r17, %r9, %r11, %p2;
    mul.lo.u32 %r8, %r3, %r3;
    max.u32 %r15, %r8, %r17;
    setp.ge.s32 %p2, %r8, %r15;
    @%p2 xor.b64 %rd14, %rd9, %rd9;
    add.s32 %r20, %r3, 2;
    setp.le.u32 %p4, %r11, 3;
    @!%p4 cvt.s32.s64 %r26, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
