.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    min.s64 %rd11, %rd13, %rd13;
    cvt.s64.s32 %rd14, %r3;
    min.u32 %r14, %r3, %r3;
    max.s32 %r7, %r3, 31;
    mul.lo.s32 %r4, %r14, %r3;
    add.u32 %r27, %r3, %r4;
    min.u64 %rd11, %rd13, %rd13;
    add.s32 %r20, %r4, 65536;
    shr.u32 %r13, %r7, 30;
    setp.lt.s32 %p2, %r7, 1;
    @!%p2 cvt.s32.s64 %r4, %rd13;
    min.u32 %r10, %r4, %r20;
    shr.u32 %r6, %r7, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
