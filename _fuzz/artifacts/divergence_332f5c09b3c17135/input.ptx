.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p3, %r3, %r3;
    @%p3 sub.u32 %r22, %r3, 16;
    mul.wide.u32 %rd5, %r22, %r3;
    setp.gt.u32 %p1, %r22, %r22;
    @%p1 shl.b32 %r21, %r3, 30;
    shr.u32 %r16, %r21, 3;
    mad.lo.s32 %r8, %r16, %r22, %r16;
    shr.s64 %rd15, %rd5, 1;
    shr.s32 %r4, %r22, 4;
    cvt.u32.u64 %r23, %rd15;
    mul.lo.u32 %r7, %r4, %r4;
    add.u32 %r24, %r7, 65536;
    mad.lo.u32 %r22, %r22, %r4, %r24;
    min.s32 %r19, %r16, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
