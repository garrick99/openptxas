.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r25, %r3, %r3;
    cvt.u64.u32 %rd15, %r25;
    sub.u32 %r23, %r25, 63;
    add.u32 %r19, %r3, %r25;
    setp.gt.u32 %p2, %r23, %r19;
    @%p2 selp.b32 %r11, %r19, %r25, %p2;
    mad.lo.s32 %r11, %r23, %r11, %r3;
    and.b32 %r23, %r23, 4294967295;
    cvt.s64.s32 %rd8, %r19;
    or.b32 %r21, %r11, %r23;
    min.s32 %r10, %r23, %r21;
    max.s32 %r13, %r19, 1;
    sub.s64 %rd14, %rd15, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
