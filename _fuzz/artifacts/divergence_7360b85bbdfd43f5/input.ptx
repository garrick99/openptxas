.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd14, %r3, %r3;
    shl.b32 %r20, %r3, 3;
    add.u32 %r14, %r20, %r3;
    xor.b32 %r9, %r3, %r14;
    shr.s64 %rd12, %rd14, 3;
    mul.lo.s32 %r10, %r9, %r20;
    sub.u32 %r27, %r14, %r10;
    shl.b64 %rd15, %rd12, 47;
    and.b32 %r5, %r10, 64;
    shl.b32 %r12, %r14, 30;
    sub.u32 %r8, %r3, %r12;
    mul.lo.s32 %r16, %r14, 2147483648;
    setp.lt.s32 %p2, %r3, %r20;
    @%p2 max.u32 %r26, %r27, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
