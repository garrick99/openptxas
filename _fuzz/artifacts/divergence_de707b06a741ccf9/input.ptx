.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r16, %r3, %r3;
    max.s32 %r13, %r3, 64;
    cvt.s64.s32 %rd15, %r3;
    max.s32 %r22, %r16, 7;
    mul.wide.s32 %rd14, %r13, %r22;
    shr.s32 %r7, %r16, 15;
    shr.s32 %r16, %r13, 2;
    max.s32 %r17, %r3, 64;
    shr.s32 %r5, %r7, 30;
    sub.u32 %r13, %r5, %r22;
    mad.lo.s32 %r6, %r3, %r13, %r3;
    or.b32 %r7, %r7, %r22;
    sub.u32 %r19, %r22, %r13;
    add.u64 %rd11, %rd14, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
