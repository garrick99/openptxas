    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r9, %r3, 2147483647;
    mul.wide.u32 %rd13, %r9, %r3;
    add.u32 %r21, %r9, %r3;
