.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r5, %r3, 1;
    sub.u32 %r22, %r3, %r3;
    cvt.s64.s32 %rd14, %r3;
    sub.s64 %rd15, %rd14, %rd14;
    mad.lo.s32 %r20, %r22, %r22, %r3;
    max.u32 %r19, %r3, 3;
    shr.s64 %rd8, %rd14, 30;
    min.u32 %r18, %r20, 7;
    min.u32 %r6, %r18, %r19;
    cvt.u64.u32 %rd5, %r6;
    setp.le.s32 %p3, %r19, 255;
    setp.lt.s32 %p3, %r6, 1;
    @%p3 cvt.s32.s64 %r7, %rd5;
    mad.lo.s32 %r25, %r7, %r3, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
