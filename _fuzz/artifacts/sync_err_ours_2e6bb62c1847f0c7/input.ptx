.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    mad.lo.s32 %r6, %r3, %r3, %r3;
    add.u32 %r27, %r6, 63;
    and.b64 %rd14, %rd10, %rd10;
    cvt.u32.u64 %r7, %rd10;
    mul.lo.s32 %r10, %r7, 2147483647;
    setp.ge.u32 %p2, %r7, %r10;
    shl.b32 %r18, %r10, 0;
    mul.lo.s32 %r24, %r10, %r3;
    add.u64 %rd9, %rd14, %rd10;
    sub.u32 %r22, %r18, 3;
    mul.lo.s32 %r8, %r7, %r6;
    or.b32 %r13, %r24, %r10;
    max.u64 %rd7, %rd10, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
