.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p3, %r3, 64;
    cvt.u64.u32 %rd6, %r3;
    min.u32 %r19, %r3, 31;
    shr.s64 %rd9, %rd6, 15;
    add.s32 %r8, %r3, %r3;
    mad.lo.u32 %r5, %r8, %r19, %r3;
    add.u32 %r9, %r5, %r3;
    cvt.u32.u64 %r12, %rd6;
    mad.lo.s32 %r9, %r12, %r8, %r19;
    setp.ge.s32 %p3, %r12, 15;
    selp.b32 %r10, %r19, %r5, %p3;
    or.b64 %rd15, %rd9, %rd6;
    setp.lt.s32 %p3, %r5, %r8;
    @%p3 sub.s64 %rd6, %rd15, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
