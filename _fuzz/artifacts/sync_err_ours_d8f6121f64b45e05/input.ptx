.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    min.u32 %r16, %r3, %r3;
    sub.u32 %r22, %r16, %r3;
    shr.u64 %rd6, %rd9, 63;
    shr.u32 %r26, %r22, 16;
    cvt.s32.s64 %r19, %rd6;
    setp.le.u32 %p4, %r3, 31;
    @%p4 mul.lo.s32 %r12, %r26, %r22;
    setp.ge.u32 %p4, %r22, %r22;
    shr.u32 %r23, %r19, 16;
    max.s64 %rd9, %rd6, %rd6;
    min.u64 %rd7, %rd9, %rd9;
    or.b32 %r27, %r23, %r3;
    max.u32 %r14, %r3, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
