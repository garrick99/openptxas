.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r4, %r3, 4;
    add.s32 %r10, %r4, %r3;
    cvt.u64.u32 %rd10, %r3;
    mad.lo.u32 %r25, %r4, %r10, %r4;
    shl.b64 %rd6, %rd10, 30;
    mul.lo.s32 %r12, %r3, 65536;
    max.u64 %rd7, %rd6, %rd6;
    or.b32 %r13, %r12, 16;
    shr.u32 %r27, %r3, 0;
    min.s32 %r7, %r13, %r25;
    mad.lo.s32 %r24, %r7, %r25, %r27;
    setp.le.s32 %p1, %r12, %r10;
    @%p1 mul.lo.s32 %r22, %r27, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
