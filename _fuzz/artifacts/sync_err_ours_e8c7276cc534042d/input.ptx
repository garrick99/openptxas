.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p1, %r3, %r3;
    @%p1 xor.b32 %r23, %r3, 31;
    or.b32 %r20, %r3, 65535;
    sub.u32 %r16, %r20, %r3;
    shl.b32 %r16, %r3, 3;
    selp.b32 %r11, %r20, %r3, %p1;
    and.b32 %r4, %r11, %r23;
    sub.s32 %r22, %r16, 5;
    cvt.u64.u32 %rd10, %r22;
    cvt.u32.u64 %r10, %rd10;
    mad.lo.u32 %r20, %r16, %r4, %r4;
    sub.s32 %r24, %r16, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
