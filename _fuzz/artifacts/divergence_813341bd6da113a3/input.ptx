.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.idx.b32 %r8, %r3, 1, 0x1f, -1;
    shfl.sync.bfly.b32 %r17, %r0, 4, 0x1f, -1;
    setp.lt.u32 %p3, %r3, 3;
    vote.sync.ballot.b32 %r8, %p3, -1;
    sub.u32 %r15, %r17, %r8;
    shfl.sync.bfly.b32 %r11, %r8, 16, 0x1f, -1;
    shfl.sync.idx.b32 %r9, %r17, 0, 0x1f, -1;
    shfl.sync.idx.b32 %r10, %r8, 1, 0x1f, -1;
    xor.b32 %r7, %r3, %r10;
    min.u32 %r17, %r0, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
