.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r18, %r3, %r3, %r3;
    min.u32 %r9, %r3, 63;
    min.s32 %r22, %r3, %r3;
    cvt.s64.s32 %rd13, %r18;
    sub.s64 %rd8, %rd13, %rd13;
    min.u32 %r21, %r18, %r18;
    min.s32 %r14, %r18, %r18;
    shr.u32 %r24, %r22, 7;
    cvt.s64.s32 %rd12, %r22;
    cvt.s32.s64 %r7, %rd12;
    cvt.s32.s64 %r18, %rd12;
    setp.gt.s32 %p2, %r21, 65535;
    @!%p2 or.b32 %r15, %r14, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
