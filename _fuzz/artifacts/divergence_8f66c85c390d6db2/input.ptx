.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    setp.gt.u32 %p4, %r3, 2147483648;
    @%p4 shl.b32 %r8, %r3, 15;
    mul.wide.u32 %rd11, %r3, %r3;
    mul.lo.u32 %r6, %r3, 2147483647;
    sub.u32 %r8, %r6, 65535;
    or.b32 %r6, %r3, 15;
    min.s32 %r23, %r3, %r8;
    add.s32 %r5, %r8, 256;
    mul.wide.s32 %rd6, %r23, %r8;
    mul.lo.s64 %rd9, %rd11, %rd6;
    shr.s64 %rd6, %rd9, 2;
    shr.u32 %r9, %r5, 30;
    mul.lo.s32 %r16, %r23, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
