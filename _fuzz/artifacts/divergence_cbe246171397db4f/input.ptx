.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r20, %r3, %r3, %r3;
    cvt.s64.s32 %rd12, %r3;
    mul.wide.u32 %rd7, %r20, %r3;
    setp.gt.s32 %p3, %r20, %r3;
    @%p3 mul.lo.s32 %r6, %r3, %r3;
    setp.eq.s32 %p3, %r20, 7;
    setp.lt.s32 %p2, %r6, 15;
    @%p2 shr.u64 %rd14, %rd12, 15;
    shl.b32 %r7, %r3, 30;
    add.u32 %r23, %r6, %r3;
    shr.u64 %rd11, %rd7, 7;
    shr.u32 %r19, %r23, 3;
    mul.wide.s32 %rd14, %r3, %r19;
    shl.b64 %rd13, %rd7, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
