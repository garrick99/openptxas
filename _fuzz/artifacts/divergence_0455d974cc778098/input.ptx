.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r8, %r3, %r3, %r3;
    cvt.s64.s32 %rd10, %r3;
    max.s64 %rd8, %rd10, %rd10;
    or.b32 %r9, %r3, %r3;
    cvt.u64.u32 %rd13, %r8;
    add.s32 %r24, %r8, 2;
    mul.lo.u32 %r11, %r3, 4;
    shr.s64 %rd15, %rd10, 1;
    cvt.u64.u32 %rd7, %r11;
    cvt.s64.s32 %rd15, %r9;
    mul.lo.u32 %r19, %r24, %r3;
    min.s32 %r19, %r19, %r11;
    setp.ne.s32 %p2, %r19, 16;
    @!%p2 mad.lo.u32 %r23, %r9, %r19, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
