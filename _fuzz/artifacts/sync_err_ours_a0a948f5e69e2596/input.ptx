.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r13, %r3, 31;
    setp.lt.u32 %p4, %r3, 31;
    add.s32 %r13, %r13, 16;
    setp.lt.s32 %p3, %r13, 1;
    shr.s32 %r20, %r13, 4;
    max.s32 %r15, %r20, %r13;
    shr.u32 %r26, %r15, 2;
    cvt.s64.s32 %rd15, %r13;
    min.u32 %r11, %r3, %r15;
    xor.b32 %r27, %r26, 8;
    sub.u32 %r12, %r20, %r27;
    or.b32 %r6, %r15, %r3;
    setp.eq.s32 %p3, %r13, %r6;
    setp.lt.u32 %p3, %r15, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
