.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r27, %r3, %r3;
    setp.eq.s32 %p2, %r3, %r3;
    @!%p2 max.u32 %r4, %r3, %r3;
    cvt.s64.s32 %rd13, %r27;
    sub.s32 %r17, %r3, %r27;
    min.s32 %r12, %r4, 2147483648;
    max.s64 %rd6, %rd13, %rd13;
    or.b32 %r5, %r27, %r17;
    max.u32 %r24, %r3, %r4;
    cvt.s32.s64 %r16, %rd6;
    sub.u64 %rd12, %rd13, %rd6;
    mul.lo.s32 %r11, %r27, 256;
    or.b64 %rd9, %rd6, %rd6;
    and.b32 %r6, %r4, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
