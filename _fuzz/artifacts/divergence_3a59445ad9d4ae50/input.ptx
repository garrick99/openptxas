.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p4, %r3, %r3;
    @%p4 max.s32 %r18, %r3, 8;
    shl.b32 %r17, %r18, 3;
    max.u32 %r17, %r17, %r18;
    cvt.s64.s32 %rd10, %r18;
    max.u32 %r27, %r3, 256;
    xor.b32 %r13, %r17, 4294967295;
    mul.lo.s32 %r22, %r13, 31;
    setp.lt.u32 %p3, %r18, 16;
    selp.b32 %r6, %r17, %r3, %p4;
    mad.lo.s32 %r21, %r17, %r17, %r6;
    cvt.s32.s64 %r12, %rd10;
    cvt.s32.s64 %r23, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
