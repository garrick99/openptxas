.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r21, %r3, %r3;
    and.b32 %r17, %r21, 1;
    add.s32 %r10, %r17, %r21;
    cvt.s64.s32 %rd10, %r17;
    shr.s32 %r11, %r10, 16;
    add.s64 %rd10, %rd10, %rd10;
    mul.lo.s32 %r8, %r10, 2147483648;
    mul.wide.u32 %rd11, %r11, %r21;
    setp.lt.s32 %p2, %r17, 16;
    @%p2 or.b32 %r24, %r10, 3;
    sub.s32 %r8, %r21, 3;
    shr.s64 %rd14, %rd11, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
