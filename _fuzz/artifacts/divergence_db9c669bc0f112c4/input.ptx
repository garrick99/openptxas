.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r20, %r3, 2;
    mul.lo.s32 %r4, %r3, 7;
    cvt.u64.u32 %rd13, %r4;
    min.s32 %r16, %r4, %r4;
    or.b64 %rd15, %rd13, %rd13;
    cvt.s32.s64 %r7, %rd15;
    mad.lo.s32 %r26, %r20, %r20, %r7;
    add.s32 %r13, %r16, 32;
    and.b32 %r20, %r3, %r26;
    mul.wide.u32 %rd6, %r13, %r4;
    setp.lo.u32 %p2, %r4, 63;
    mad.lo.s32 %r26, %r26, %r16, %r13;
    mad.lo.s32 %r11, %r26, %r16, %r13;
    mul.wide.u32 %rd14, %r13, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
