.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r22, %r3, %r3;
    or.b32 %r10, %r3, 255;
    mul.lo.u32 %r4, %r22, %r10;
    add.s32 %r23, %r22, %r10;
    shr.s32 %r21, %r3, 15;
    cvt.u64.u32 %rd11, %r3;
    sub.s32 %r19, %r21, 63;
    mad.lo.u32 %r13, %r19, %r10, %r3;
    shr.s32 %r9, %r22, 30;
    sub.s32 %r27, %r19, 1;
    mul.lo.s32 %r11, %r23, %r19;
    setp.gt.s32 %p1, %r3, 65536;
    @%p1 or.b32 %r5, %r3, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
