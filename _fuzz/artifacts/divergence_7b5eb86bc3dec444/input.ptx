.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r25, %r3, 16;
    mad.lo.s32 %r23, %r25, %r3, %r25;
    setp.lo.u32 %p4, %r3, 63;
    @!%p4 shl.b32 %r8, %r23, 30;
    cvt.s64.s32 %rd6, %r23;
    add.u32 %r7, %r23, 255;
    mul.wide.u32 %rd12, %r3, %r25;
    mad.lo.s32 %r9, %r25, %r23, %r25;
    xor.b32 %r15, %r25, %r7;
    cvt.s32.s64 %r22, %rd12;
    shr.u64 %rd11, %rd12, 4;
    mad.lo.u32 %r15, %r8, %r23, %r23;
    mul.wide.s32 %rd9, %r7, %r7;
    shl.b64 %rd13, %rd9, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
