.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p1, %r3, %r3;
    @%p1 mul.wide.u32 %rd14, %r3, %r3;
    min.s64 %rd7, %rd14, %rd14;
    mul.wide.s32 %rd9, %r3, %r3;
    cvt.u32.u64 %r8, %rd14;
    cvt.u32.u64 %r4, %rd14;
    max.u32 %r16, %r8, %r3;
    mul.lo.s32 %r6, %r16, 1;
    min.s32 %r7, %r3, 65536;
    mul.wide.u32 %rd6, %r7, %r3;
    or.b32 %r25, %r16, 63;
    min.u32 %r25, %r16, %r7;
    add.u32 %r25, %r4, 7;
    max.s32 %r20, %r8, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
