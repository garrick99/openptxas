.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r12, %r3, 1;
    shr.u32 %r21, %r12, 3;
    or.b32 %r17, %r12, %r3;
    setp.gt.s32 %p2, %r21, %r3;
    @!%p2 mul.lo.s32 %r16, %r3, %r3;
    max.u32 %r4, %r3, %r17;
    and.b32 %r20, %r4, 4;
    add.s32 %r27, %r16, %r20;
    shr.u32 %r13, %r4, 1;
    add.s32 %r16, %r27, %r12;
    shr.s32 %r15, %r27, 30;
    selp.b32 %r23, %r21, %r12, %p2;
    mad.lo.s32 %r5, %r3, %r16, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
