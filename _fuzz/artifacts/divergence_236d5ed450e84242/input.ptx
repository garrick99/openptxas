.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r12, %r3, %r3;
    cvt.s64.s32 %rd12, %r12;
    shr.u32 %r4, %r3, 4;
    setp.lt.s32 %p4, %r12, 65536;
    @%p4 cvt.u32.u64 %r21, %rd12;
    shl.b32 %r19, %r12, 31;
    mad.lo.u32 %r22, %r4, %r21, %r19;
    min.u32 %r19, %r12, %r3;
    sub.u32 %r24, %r12, 0;
    xor.b64 %rd10, %rd12, %rd12;
    mad.lo.s32 %r4, %r22, %r4, %r3;
    shl.b32 %r19, %r21, 4;
    mul.lo.s32 %r8, %r3, %r3;
    max.u32 %r20, %r21, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
