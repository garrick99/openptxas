.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    shr.u32 %r15, %r3, 15;
    cvt.s32.s64 %r19, %rd9;
    shl.b64 %rd10, %rd9, 33;
    add.s32 %r22, %r19, %r19;
    max.s64 %rd13, %rd9, %rd10;
    shr.u64 %rd6, %rd13, 3;
    shl.b64 %rd14, %rd9, 62;
    sub.u32 %r21, %r22, %r3;
    add.u64 %rd11, %rd9, %rd13;
    add.u32 %r8, %r3, 64;
    add.u32 %r14, %r8, %r8;
    shr.u32 %r8, %r22, 7;
    or.b32 %r4, %r21, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
