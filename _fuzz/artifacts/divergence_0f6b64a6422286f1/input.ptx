.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r9, %r3, 3;
    add.u32 %r24, %r3, 5;
    mul.lo.u32 %r17, %r9, %r3;
    setp.ne.s32 %p3, %r9, %r24;
    setp.hi.u32 %p2, %r24, %r9;
    @!%p2 sub.u32 %r23, %r9, %r24;
    mul.lo.s32 %r19, %r3, 65535;
    sub.s32 %r18, %r19, %r17;
    shl.b32 %r20, %r18, 7;
    xor.b32 %r19, %r23, %r19;
    shl.b32 %r18, %r20, 3;
    cvt.u64.u32 %rd12, %r19;
    cvt.s32.s64 %r16, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
