.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd10, %r3, %r3;
    cvt.u32.u64 %r25, %rd10;
    mad.lo.s32 %r8, %r3, %r25, %r25;
    xor.b64 %rd6, %rd10, %rd10;
    cvt.u64.u32 %rd8, %r3;
    min.u32 %r9, %r8, 16;
    mul.wide.u32 %rd14, %r3, %r25;
    mul.lo.s32 %r9, %r25, %r9;
    setp.ne.s32 %p1, %r9, 7;
    @%p1 min.u32 %r14, %r25, 63;
    selp.b32 %r14, %r14, %r25, %p1;
    setp.hi.u32 %p4, %r9, 4;
    shr.u64 %rd6, %rd14, 47;
    shr.u32 %r16, %r14, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
