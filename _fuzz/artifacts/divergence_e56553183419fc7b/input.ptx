.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r14, %r3, %r3;
    mul.wide.s32 %rd8, %r3, %r14;
    cvt.u32.u64 %r24, %rd8;
    cvt.u32.u64 %r21, %rd8;
    min.u32 %r17, %r21, 4;
    mad.lo.s32 %r22, %r21, %r3, %r3;
    mul.wide.u32 %rd8, %r24, %r14;
    shl.b32 %r7, %r17, 0;
    shr.u32 %r8, %r7, 1;
    shr.s32 %r26, %r7, 0;
    max.u32 %r12, %r8, 4294967295;
    xor.b32 %r11, %r14, 4;
    mul.lo.u32 %r19, %r24, %r24;
    or.b32 %r10, %r22, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
