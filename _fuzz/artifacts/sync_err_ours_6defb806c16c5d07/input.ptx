.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    max.s32 %r9, %r3, %r3;
    add.u32 %r24, %r3, %r9;
    max.u64 %rd11, %rd6, %rd6;
    mul.wide.u32 %rd5, %r24, %r3;
    max.u32 %r5, %r9, %r24;
    max.s64 %rd10, %rd11, %rd11;
    sub.u32 %r21, %r9, 8;
    cvt.s32.s64 %r5, %rd10;
    shl.b64 %rd8, %rd10, 1;
    mul.lo.u64 %rd8, %rd11, %rd11;
    and.b32 %r17, %r24, 63;
    sub.u32 %r11, %r24, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
