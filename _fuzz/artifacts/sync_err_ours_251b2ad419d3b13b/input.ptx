.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r21, %r3, %r3;
    mul.wide.u32 %rd6, %r3, %r3;
    min.u32 %r21, %r3, %r3;
    shr.s64 %rd7, %rd6, 31;
    cvt.u64.u32 %rd9, %r3;
    sub.s32 %r17, %r21, %r3;
    mul.wide.u32 %rd14, %r21, %r17;
    or.b32 %r25, %r21, %r21;
    add.s64 %rd11, %rd6, %rd9;
    sub.s32 %r15, %r3, %r17;
    and.b32 %r7, %r3, %r3;
    shr.s64 %rd10, %rd14, 48;
    shl.b64 %rd12, %rd6, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
