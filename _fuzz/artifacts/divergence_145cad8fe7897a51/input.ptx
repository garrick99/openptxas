.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p4, %r3, 2147483648;
    @%p4 mul.wide.u32 %rd9, %r3, %r3;
    mul.lo.s32 %r5, %r3, %r3;
    sub.u32 %r5, %r3, %r3;
    shl.b64 %rd7, %rd9, 1;
    or.b32 %r21, %r5, 0;
    max.s32 %r5, %r3, %r21;
    cvt.u32.u64 %r19, %rd7;
    selp.b32 %r12, %r19, %r19, %p4;
    shl.b32 %r8, %r19, 30;
    mul.wide.u32 %rd7, %r19, %r19;
    shr.u64 %rd13, %rd7, 32;
    cvt.u64.u32 %rd10, %r21;
    cvt.s64.s32 %rd9, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
