.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r27, %r3, %r3;
    setp.eq.s32 %p4, %r27, 65535;
    setp.lt.s32 %p4, %r27, 31;
    @%p4 and.b32 %r20, %r3, %r3;
    xor.b32 %r21, %r3, 3;
    mul.wide.u32 %rd5, %r3, %r21;
    max.u32 %r13, %r20, %r20;
    selp.b32 %r19, %r27, %r20, %p4;
    cvt.s64.s32 %rd5, %r20;
    sub.s32 %r12, %r3, %r21;
    min.s32 %r12, %r13, %r3;
    xor.b32 %r24, %r27, %r13;
    selp.b32 %r26, %r21, %r19, %p4;
    shr.s32 %r17, %r19, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
