.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r18, %r3, %r3;
    cvt.u64.u32 %rd5, %r3;
    sub.u32 %r21, %r18, 64;
    mul.lo.s32 %r10, %r3, 2;
    min.s32 %r5, %r18, %r21;
    max.s64 %rd14, %rd5, %rd5;
    min.s32 %r23, %r10, %r10;
    sub.s64 %rd7, %rd14, %rd14;
    max.s32 %r16, %r18, %r10;
    cvt.u64.u32 %rd9, %r21;
    sub.s32 %r11, %r16, %r18;
    and.b32 %r26, %r18, 2;
    shl.b32 %r25, %r3, 15;
    add.s32 %r17, %r23, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
