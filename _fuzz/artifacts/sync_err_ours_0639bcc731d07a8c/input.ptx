.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r22, %r3, 30;
    mad.lo.u32 %r10, %r22, %r3, %r22;
    max.u32 %r5, %r3, %r10;
    shr.s32 %r5, %r22, 0;
    shr.s32 %r6, %r3, 4;
    or.b32 %r27, %r10, 63;
    sub.s32 %r13, %r27, 8;
    cvt.s64.s32 %rd7, %r10;
    shr.s64 %rd10, %rd7, 16;
    shr.u64 %rd13, %rd7, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
