.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r8, %r3, %r3;
    max.u32 %r17, %r8, %r3;
    setp.gt.s32 %p3, %r8, 32;
    @%p3 mad.lo.u32 %r7, %r3, %r17, %r3;
    selp.b32 %r9, %r8, %r8, %p3;
    selp.b32 %r14, %r9, %r3, %p3;
    mul.lo.s32 %r9, %r17, %r9;
    mul.lo.s32 %r15, %r7, %r8;
    min.u32 %r8, %r17, %r3;
    max.u32 %r24, %r14, 4294967295;
    max.u32 %r23, %r24, 4;
    xor.b32 %r9, %r17, 65536;
    cvt.u64.u32 %rd6, %r17;
    and.b32 %r21, %r7, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
