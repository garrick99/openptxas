.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r19, %r3, %r3;
    cvt.s64.s32 %rd9, %r19;
    xor.b32 %r12, %r19, %r19;
    setp.eq.s32 %p3, %r19, 16;
    @%p3 mad.lo.s32 %r10, %r12, %r19, %r3;
    mul.lo.s32 %r6, %r10, 31;
    shr.s32 %r8, %r6, 7;
    shr.u64 %rd10, %rd9, 3;
    shr.s32 %r6, %r19, 16;
    add.u32 %r23, %r3, 1;
    shl.b64 %rd8, %rd9, 33;
    setp.ge.s32 %p2, %r8, %r12;
    @%p2 min.u32 %r5, %r6, 65535;
    xor.b32 %r20, %r8, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
