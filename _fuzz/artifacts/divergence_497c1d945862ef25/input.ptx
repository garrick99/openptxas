.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r13, %r3, 16;
    cvt.s64.s32 %rd7, %r3;
    mul.lo.u32 %r4, %r13, %r3;
    setp.le.s32 %p4, %r13, 256;
    @%p4 add.s32 %r22, %r3, 3;
    xor.b32 %r16, %r13, %r13;
    cvt.s64.s32 %rd5, %r16;
    shr.s64 %rd7, %rd7, 31;
    setp.hs.u32 %p1, %r4, %r4;
    @%p1 shr.u32 %r27, %r22, 16;
    min.u32 %r16, %r4, %r4;
    mad.lo.s32 %r6, %r13, %r22, %r4;
    mul.wide.s32 %rd11, %r13, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
