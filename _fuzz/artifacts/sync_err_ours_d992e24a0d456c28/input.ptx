.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r8, %r3, 31;
    and.b32 %r19, %r3, %r8;
    setp.ne.s32 %p1, %r8, 65536;
    @!%p1 cvt.u64.u32 %rd10, %r19;
    setp.gt.s32 %p4, %r19, 3;
    setp.ge.s32 %p2, %r3, 64;
    @%p2 shr.u64 %rd12, %rd10, 4;
    min.u64 %rd9, %rd12, %rd12;
    mul.lo.u32 %r17, %r3, %r19;
    max.u64 %rd10, %rd10, %rd9;
    shl.b64 %rd11, %rd9, 3;
    mad.lo.s32 %r18, %r19, %r8, %r3;
    sub.s32 %r26, %r19, 31;
    shr.s64 %rd8, %rd9, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
