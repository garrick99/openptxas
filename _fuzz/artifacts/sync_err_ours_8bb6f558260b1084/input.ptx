.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    mul.lo.s32 %r14, %r3, 3;
    setp.ge.s32 %p3, %r14, %r3;
    @%p3 mul.lo.s32 %r4, %r3, 5;
    sub.s32 %r7, %r4, 16;
    min.u32 %r21, %r4, 5;
    max.u32 %r23, %r3, %r21;
    mul.wide.u32 %rd7, %r21, %r4;
    min.u32 %r18, %r7, 5;
    and.b32 %r11, %r14, %r18;
    cvt.u64.u32 %rd15, %r4;
    max.s32 %r13, %r21, %r14;
    add.s32 %r22, %r23, 63;
    setp.lo.u32 %p2, %r13, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
