.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r11, %r3, 0;
    cvt.s64.s32 %rd14, %r3;
    min.s32 %r19, %r3, %r3;
    min.u32 %r18, %r11, %r3;
    or.b32 %r27, %r18, 64;
    setp.lo.u32 %p4, %r11, %r18;
    @!%p4 shr.u32 %r11, %r19, 7;
    cvt.s32.s64 %r26, %rd14;
    selp.b32 %r15, %r26, %r27, %p4;
    add.s32 %r18, %r15, 255;
    shr.u32 %r10, %r18, 15;
    mad.lo.u32 %r5, %r3, %r18, %r19;
    shl.b32 %r21, %r10, 7;
    setp.lt.u32 %p2, %r11, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
