.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r23, %r3, %r3;
    cvt.u64.u32 %rd13, %r23;
    mad.lo.s32 %r16, %r23, %r23, %r3;
    mul.lo.s64 %rd11, %rd13, %rd13;
    mul.wide.u32 %rd13, %r23, %r3;
    min.s64 %rd7, %rd13, %rd13;
    or.b32 %r13, %r16, %r23;
    min.s32 %r15, %r23, %r13;
    xor.b64 %rd15, %rd13, %rd13;
    mul.wide.s32 %rd5, %r3, %r13;
    xor.b32 %r15, %r13, %r15;
    and.b32 %r9, %r16, 3;
    shr.u64 %rd11, %rd11, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
