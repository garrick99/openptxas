.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd5, %r3, %r3;
    shr.u32 %r13, %r3, 31;
    mul.lo.u32 %r11, %r13, 63;
    shr.s64 %rd11, %rd5, 7;
    sub.s32 %r5, %r3, 256;
    max.s32 %r4, %r5, 2147483648;
    xor.b64 %rd15, %rd11, %rd5;
    max.u32 %r9, %r5, %r11;
    setp.hs.u32 %p4, %r3, 255;
    @%p4 cvt.u32.u64 %r19, %rd15;
    mul.wide.s32 %rd10, %r19, %r11;
    or.b32 %r19, %r9, %r19;
    shr.s64 %rd12, %rd10, 47;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
