.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    sub.u32 %r27, %r3, %r3;
    sub.u32 %r13, %r27, %r27;
    min.u32 %r18, %r27, %r13;
    mul.wide.s32 %rd10, %r13, %r3;
    and.b32 %r24, %r13, 4;
    cvt.u32.u64 %r14, %rd7;
    min.u64 %rd8, %rd7, %rd7;
    max.u32 %r18, %r14, 4;
    mul.wide.u32 %rd11, %r14, %r18;
    setp.ge.u32 %p3, %r27, 63;
    @%p3 and.b64 %rd13, %rd8, %rd10;
    mad.lo.s32 %r20, %r13, %r24, %r18;
    xor.b32 %r7, %r27, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
