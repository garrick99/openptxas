    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    shr.u64 %rd7, %rd9, 4;
    add.s32 %r27, %r3, %r3;
    shr.u32 %r12, %r27, 15;
    max.s32 %r23, %r12, 0;
    or.b32 %r5, %r27, %r12;
    shl.b32 %r14, %r27, 3;
    sub.u64 %rd6, %rd9, %rd7;
    shr.u64 %rd15, %rd9, 3;
    min.u64 %rd8, %rd6, %rd15;
    min.u32 %r5, %r14, %r3;
    max.s32 %r15, %r5, 2147483647;
    mul.lo.u32 %r21, %r12, %r23;
    mul.lo.u32 %r8, %r14, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
