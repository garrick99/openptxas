.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r4, %r3, %r3;
    add.s32 %r18, %r3, 7;
    cvt.u64.u32 %rd15, %r4;
    add.s32 %r27, %r18, 256;
    min.u32 %r16, %r27, %r18;
    and.b32 %r6, %r3, %r4;
    or.b32 %r19, %r6, %r6;
    mul.wide.s32 %rd5, %r3, %r4;
    cvt.u32.u64 %r9, %rd5;
    shl.b32 %r7, %r9, 16;
    setp.eq.s32 %p3, %r19, %r3;
    @!%p3 min.u32 %r8, %r19, %r9;
    shr.s32 %r12, %r27, 3;
    xor.b32 %r14, %r19, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
