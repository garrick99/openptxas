.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r15, %r3, 64;
    add.u32 %r6, %r15, %r3;
    setp.ge.s32 %p4, %r3, 63;
    @%p4 sub.u32 %r24, %r15, %r3;
    min.u32 %r15, %r6, %r15;
    mul.lo.u32 %r4, %r24, %r3;
    cvt.u64.u32 %rd13, %r4;
    sub.u32 %r22, %r15, %r4;
    cvt.u32.u64 %r18, %rd13;
    shl.b32 %r5, %r15, 3;
    max.s32 %r14, %r24, %r22;
    shl.b32 %r26, %r6, 3;
    shr.u32 %r13, %r3, 1;
    cvt.s32.s64 %r17, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
