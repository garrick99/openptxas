.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    shr.u32 %r5, %r3, 0;
    max.s32 %r27, %r5, %r5;
    mul.lo.s32 %r9, %r27, 4294967295;
    xor.b32 %r22, %r5, %r9;
    cvt.u64.u32 %rd9, %r22;
    mul.wide.u32 %rd11, %r27, %r27;
    mul.wide.s32 %rd13, %r9, %r5;
    cvt.s32.s64 %r17, %rd13;
    max.s32 %r25, %r3, 63;
    mul.wide.s32 %rd10, %r3, %r17;
    sub.s32 %r24, %r25, %r17;
    shl.b32 %r11, %r22, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
