.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r17, %r3, %r3;
    setp.eq.s32 %p1, %r3, 2147483648;
    @%p1 shr.s32 %r15, %r17, 16;
    mul.wide.u32 %rd10, %r17, %r15;
    mul.lo.s32 %r20, %r15, %r15;
    add.u64 %rd12, %rd10, %rd10;
    selp.b32 %r19, %r20, %r20, %p1;
    cvt.u32.u64 %r10, %rd10;
    shl.b32 %r18, %r19, 30;
    mul.wide.u32 %rd8, %r15, %r17;
    or.b32 %r4, %r15, %r20;
    and.b32 %r25, %r18, %r18;
    mul.wide.s32 %rd14, %r19, %r20;
    add.u64 %rd8, %rd12, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
