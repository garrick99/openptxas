.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r13, %r3, 0;
    sub.s32 %r15, %r3, 8;
    shr.s32 %r17, %r13, 3;
    mul.lo.u32 %r25, %r17, %r17;
    cvt.u64.u32 %rd6, %r17;
    sub.u32 %r27, %r25, %r25;
    mul.lo.u32 %r23, %r15, %r3;
    min.u32 %r11, %r15, %r13;
    min.s32 %r25, %r27, 2;
    mul.wide.u32 %rd10, %r15, %r27;
    shl.b64 %rd8, %rd6, 63;
    setp.eq.s32 %p2, %r17, 32;
    @%p2 min.s32 %r10, %r17, 7;
    sub.s32 %r25, %r11, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
