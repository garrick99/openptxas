.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    mul.lo.u32 %r7, %r3, %r3;
    and.b32 %r4, %r7, 5;
    min.u32 %r27, %r7, 15;
    mad.lo.s32 %r23, %r3, %r7, %r3;
    add.u32 %r18, %r4, 31;
    max.u64 %rd9, %rd10, %rd10;
    mul.lo.u32 %r23, %r18, %r23;
    cvt.u32.u64 %r19, %rd10;
    shr.s32 %r9, %r4, 16;
    add.u32 %r27, %r9, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
