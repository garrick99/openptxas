    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd12, %r3, %r3;
    sub.u32 %r12, %r3, 64;
    shr.s64 %rd5, %rd12, 16;
    cvt.u32.u64 %r19, %rd5;
    max.s32 %r19, %r19, 2147483647;
    add.u32 %r8, %r12, 65535;
    max.u32 %r27, %r8, 65535;
    mad.lo.u32 %r4, %r27, %r3, %r3;
    min.u32 %r24, %r19, 63;
