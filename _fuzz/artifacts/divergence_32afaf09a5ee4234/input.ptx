.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r21, %r3, %r3;
    cvt.s64.s32 %rd7, %r21;
    mul.wide.u32 %rd13, %r21, %r21;
    setp.le.s32 %p3, %r3, 1;
    @%p3 max.u32 %r11, %r21, 65536;
    cvt.u32.u64 %r10, %rd13;
    sub.s32 %r15, %r11, %r3;
    shr.u32 %r4, %r21, 3;
    shr.s32 %r25, %r10, 0;
    shr.u64 %rd11, %rd13, 15;
    add.u32 %r26, %r21, %r4;
    shr.u64 %rd14, %rd7, 47;
    setp.ge.u32 %p1, %r11, %r11;
    @!%p1 mul.lo.u32 %r24, %r11, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
