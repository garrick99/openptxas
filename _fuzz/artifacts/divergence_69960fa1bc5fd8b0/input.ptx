.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r23, %r3, %r3;
    cvt.u64.u32 %rd7, %r3;
    mul.lo.s32 %r9, %r23, %r23;
    shr.s32 %r20, %r9, 7;
    min.u32 %r18, %r20, 63;
    setp.ge.s32 %p3, %r3, %r9;
    setp.lt.u32 %p1, %r23, %r9;
    @!%p1 mad.lo.s32 %r17, %r3, %r3, %r23;
    add.u32 %r13, %r9, %r17;
    mad.lo.s32 %r15, %r20, %r17, %r23;
    max.u32 %r22, %r23, %r20;
    shl.b32 %r4, %r9, 2;
    cvt.u32.u64 %r11, %rd7;
    xor.b32 %r9, %r17, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
