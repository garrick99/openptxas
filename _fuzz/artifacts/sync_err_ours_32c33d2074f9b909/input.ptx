.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r15, %r3, 2;
    cvt.u64.u32 %rd14, %r3;
    min.s64 %rd15, %rd14, %rd14;
    max.u32 %r5, %r15, %r15;
    and.b32 %r15, %r3, %r3;
    sub.s64 %rd8, %rd14, %rd15;
    add.u32 %r8, %r15, 64;
    mul.wide.u32 %rd10, %r8, %r3;
    max.s32 %r4, %r5, %r3;
    shl.b32 %r14, %r5, 3;
    sub.s32 %r22, %r8, 2;
    setp.ge.s32 %p2, %r15, %r22;
    @!%p2 mul.lo.s64 %rd12, %rd15, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
