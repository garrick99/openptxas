.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r9, %r3, 1;
    max.s32 %r21, %r9, %r9;
    setp.lt.s32 %p3, %r3, %r9;
    @!%p3 selp.b32 %r5, %r3, %r9, %p3;
    mul.lo.s32 %r10, %r21, %r3;
    max.u32 %r25, %r5, 32;
    setp.lt.u32 %p4, %r3, 4;
    setp.ge.s32 %p4, %r21, 5;
    @%p4 add.s32 %r17, %r5, 7;
    min.s32 %r13, %r3, 2147483648;
    sub.s32 %r6, %r21, 0;
    cvt.s64.s32 %rd8, %r10;
    add.s32 %r6, %r9, %r25;
    mad.lo.u32 %r24, %r25, %r3, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
