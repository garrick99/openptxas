.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    sub.s64 %rd7, %rd11, %rd11;
    sub.u64 %rd7, %rd11, %rd11;
    and.b32 %r23, %r3, %r3;
    mul.lo.s32 %r4, %r23, %r23;
    mul.wide.s32 %rd13, %r23, %r3;
    mad.lo.s32 %r24, %r4, %r3, %r23;
    or.b64 %rd12, %rd13, %rd13;
    mul.wide.s32 %rd8, %r3, %r23;
    sub.s32 %r12, %r24, 64;
    cvt.u32.u64 %r7, %rd8;
    add.s32 %r10, %r3, 2147483648;
    max.s32 %r7, %r24, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
