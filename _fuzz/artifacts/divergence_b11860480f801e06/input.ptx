.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p4, %r3, %r3;
    xor.b32 %r27, %r3, %r3;
    cvt.s64.s32 %rd9, %r3;
    or.b64 %rd11, %rd9, %rd9;
    sub.u64 %rd12, %rd9, %rd11;
    xor.b64 %rd9, %rd9, %rd11;
    shr.u64 %rd7, %rd12, 33;
    shl.b32 %r23, %r3, 2;
    shr.u32 %r13, %r27, 3;
    max.s64 %rd13, %rd11, %rd11;
    min.s32 %r10, %r27, 0;
    sub.s32 %r23, %r3, %r27;
    shl.b64 %rd13, %rd11, 2;
    cvt.s64.s32 %rd7, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
