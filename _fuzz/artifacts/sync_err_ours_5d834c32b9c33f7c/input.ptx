.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p1, %r3, 15;
    @%p1 cvt.u64.u32 %rd10, %r3;
    setp.eq.s32 %p2, %r3, 255;
    @!%p2 and.b64 %rd8, %rd10, %rd10;
    shl.b64 %rd10, %rd8, 30;
    mul.lo.s32 %r13, %r3, %r3;
    setp.eq.u32 %p3, %r13, %r13;
    @%p3 max.u32 %r9, %r13, 8;
    mad.lo.s32 %r19, %r9, %r3, %r3;
    cvt.u64.u32 %rd13, %r19;
    mad.lo.u32 %r17, %r13, %r19, %r9;
    min.u32 %r26, %r17, 255;
    add.u32 %r24, %r19, %r26;
    mul.lo.u32 %r22, %r9, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
