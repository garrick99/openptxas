.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r24, %r3, %r3;
    cvt.s64.s32 %rd8, %r3;
    shl.b64 %rd9, %rd8, 16;
    mul.lo.s32 %r18, %r3, 63;
    add.u32 %r14, %r24, %r18;
    or.b32 %r26, %r24, 63;
    shr.s64 %rd11, %rd9, 1;
    and.b64 %rd15, %rd8, %rd8;
    setp.lt.u32 %p3, %r14, %r24;
    shl.b64 %rd15, %rd9, 2;
    mul.wide.u32 %rd10, %r14, %r14;
    mad.lo.s32 %r13, %r14, %r24, %r26;
    sub.u32 %r19, %r14, %r26;
    max.s64 %rd15, %rd8, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
