.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    setp.le.u32 %p2, %r3, 31;
    mul.wide.u32 %rd10, %r3, %r3;
    mul.wide.s32 %rd6, %r3, %r3;
    add.s32 %r24, %r3, 1;
    selp.b32 %r13, %r3, %r24, %p2;
    mul.lo.u32 %r14, %r13, 256;
    xor.b32 %r4, %r24, 8;
    mul.lo.s32 %r15, %r14, %r14;
    shr.s64 %rd6, %rd6, 3;
    min.s32 %r23, %r13, %r13;
    cvt.s64.s32 %rd13, %r14;
    selp.b32 %r11, %r13, %r3, %p2;
    sub.u32 %r22, %r15, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
