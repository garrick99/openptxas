.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd11, %r3, %r3;
    mul.wide.s32 %rd13, %r3, %r3;
    or.b32 %r12, %r3, %r3;
    max.s32 %r25, %r12, %r3;
    add.s32 %r10, %r25, %r25;
    max.u32 %r26, %r3, %r3;
    add.s64 %rd7, %rd13, %rd11;
    mul.lo.u32 %r11, %r12, %r12;
    mul.lo.s32 %r19, %r26, %r26;
    setp.ne.s32 %p2, %r19, 7;
    @!%p2 cvt.u32.u64 %r22, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
