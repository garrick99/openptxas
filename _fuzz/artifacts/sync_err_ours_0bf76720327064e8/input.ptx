.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    max.u32 %r4, %r3, %r3;
    and.b32 %r12, %r3, %r3;
    shr.u64 %rd12, %rd11, 48;
    min.s32 %r15, %r4, 256;
    mul.wide.s32 %rd7, %r12, %r12;
    mul.lo.u32 %r21, %r12, 256;
    mad.lo.s32 %r8, %r21, %r3, %r3;
    shr.u64 %rd12, %rd12, 4;
    min.u32 %r27, %r15, %r3;
    sub.u32 %r12, %r27, 4;
    max.s32 %r21, %r27, %r8;
    cvt.u32.u64 %r9, %rd11;
    mad.lo.u32 %r4, %r21, %r27, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
