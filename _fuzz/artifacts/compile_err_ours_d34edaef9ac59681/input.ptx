.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.idx.b32 %r17, %r3, 31, 0x1f, -1;
    shfl.sync.bfly.b32 %r18, %r17, 16, 0x1f, -1;
    add.u32 %r9, %r0, %r0;
    shfl.sync.idx.b32 %r10, %r17, 31, 0x1f, -1;
    xor.b32 %r6, %r3, %r17;
    add.u32 %r13, %r0, %r10;
    max.u32 %r10, %r10, %r6;
    setp.lt.u32 %p2, %r3, %r6;
    vote.sync.ballot.b32 %r10, %p2, -1;
    setp.lt.u32 %p2, %r9, %r3;
    vote.sync.ballot.b32 %r16, %p2, -1;
    vote.sync.all.pred %p1, %p2, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
