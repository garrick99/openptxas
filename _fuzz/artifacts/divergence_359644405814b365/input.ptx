    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    shr.s32 %r8, %r3, 31;
    xor.b32 %r25, %r8, 64;
    mul.wide.u32 %rd14, %r3, %r25;
    mul.wide.s32 %rd13, %r25, %r25;
    cvt.s32.s64 %r11, %rd7;
    mul.wide.s32 %rd11, %r11, %r25;
    mad.lo.u32 %r26, %r8, %r11, %r11;
    cvt.u32.u64 %r23, %rd13;
    max.s32 %r14, %r26, 2147483647;
    add.s32 %r11, %r14, 16;
    shl.b64 %rd15, %rd13, 2;
    setp.ne.s32 %p2, %r3, 7;
    add.u32 %r11, %r14, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
