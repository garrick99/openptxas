.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r9, %r3, 4;
    and.b32 %r27, %r3, 16;
    shl.b32 %r19, %r3, 0;
    shr.s32 %r6, %r19, 3;
    setp.ge.u32 %p3, %r19, %r3;
    mad.lo.s32 %r25, %r9, %r6, %r6;
    mul.wide.u32 %rd6, %r25, %r25;
    mul.lo.u32 %r20, %r25, %r27;
    add.s32 %r23, %r3, %r19;
    min.u32 %r14, %r6, %r9;
    or.b32 %r8, %r20, %r19;
    mul.wide.s32 %rd15, %r14, %r6;
    add.s32 %r10, %r19, 7;
    setp.eq.u32 %p1, %r8, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
