.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r4, %r3, %r3;
    or.b32 %r13, %r3, 255;
    setp.eq.s32 %p1, %r13, %r3;
    mul.lo.u32 %r15, %r13, 8;
    mul.lo.u32 %r19, %r4, 63;
    shr.u32 %r25, %r13, 2;
    cvt.u64.u32 %rd15, %r13;
    min.u32 %r6, %r13, 7;
    cvt.u32.u64 %r19, %rd15;
    shr.s64 %rd6, %rd15, 48;
    min.s32 %r12, %r13, 256;
    mul.wide.s32 %rd7, %r4, %r6;
    shl.b32 %r6, %r4, 30;
    add.u32 %r27, %r12, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
