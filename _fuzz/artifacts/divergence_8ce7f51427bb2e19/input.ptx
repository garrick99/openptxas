.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r20, %r3, %r3;
    setp.ne.s32 %p4, %r20, %r3;
    @%p4 selp.b32 %r4, %r3, %r3, %p4;
    cvt.u64.u32 %rd10, %r3;
    max.s32 %r6, %r20, 4294967295;
    mad.lo.u32 %r12, %r4, %r20, %r3;
    mad.lo.u32 %r16, %r20, %r3, %r4;
    max.s32 %r18, %r16, %r3;
    min.s64 %rd13, %rd10, %rd10;
    sub.s32 %r25, %r18, 256;
    cvt.s64.s32 %rd14, %r20;
    or.b64 %rd13, %rd14, %rd10;
    selp.b32 %r6, %r16, %r6, %p4;
    mad.lo.u32 %r4, %r25, %r3, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
