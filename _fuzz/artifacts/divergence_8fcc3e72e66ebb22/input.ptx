.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p4, %r3, 4294967295;
    @%p4 xor.b32 %r18, %r3, 0;
    selp.b32 %r8, %r3, %r18, %p4;
    max.u32 %r27, %r18, 16;
    mul.wide.s32 %rd6, %r8, %r8;
    shl.b64 %rd9, %rd6, 15;
    setp.lt.u32 %p3, %r3, %r8;
    mul.lo.u32 %r11, %r18, %r3;
    shr.u32 %r21, %r11, 4;
    shr.u64 %rd14, %rd9, 15;
    mad.lo.u32 %r21, %r11, %r27, %r8;
    setp.ls.u32 %p4, %r27, 63;
    @%p4 selp.b32 %r13, %r3, %r11, %p3;
    shr.u64 %rd9, %rd6, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
