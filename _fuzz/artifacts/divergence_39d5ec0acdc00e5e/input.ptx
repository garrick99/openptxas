.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r17, %r3, 1;
    sub.s32 %r18, %r3, %r3;
    setp.hi.u32 %p2, %r18, 255;
    @%p2 mul.wide.s32 %rd9, %r3, %r18;
    cvt.u64.u32 %rd15, %r17;
    setp.hs.u32 %p2, %r3, %r18;
    @%p2 add.s32 %r11, %r17, %r17;
    cvt.s64.s32 %rd5, %r11;
    shr.u32 %r8, %r18, 7;
    shr.u32 %r23, %r17, 4;
    max.s32 %r27, %r11, %r3;
    setp.lo.u32 %p3, %r8, 64;
    setp.ne.s32 %p4, %r23, 0;
    @!%p4 mul.lo.u32 %r9, %r27, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
