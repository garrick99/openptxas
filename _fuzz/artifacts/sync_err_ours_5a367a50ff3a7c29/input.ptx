.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r20, %r3, 15;
    cvt.s64.s32 %rd13, %r20;
    cvt.u64.u32 %rd5, %r20;
    shl.b64 %rd8, %rd13, 2;
    xor.b32 %r16, %r20, %r20;
    add.u32 %r22, %r16, 2;
    min.u32 %r23, %r16, %r16;
    shr.s32 %r15, %r16, 7;
    and.b32 %r8, %r20, %r20;
    shr.s32 %r24, %r15, 31;
    xor.b64 %rd12, %rd5, %rd8;
    shl.b32 %r12, %r20, 3;
    cvt.s32.s64 %r15, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
