.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    mad.lo.u32 %r17, %r3, %r3, %r3;
    shr.s32 %r24, %r17, 4;
    add.u32 %r16, %r17, 65535;
    min.s32 %r16, %r3, %r24;
    max.u32 %r17, %r3, 255;
    min.s32 %r9, %r3, %r17;
    setp.ge.u32 %p1, %r16, 7;
    @%p1 shr.s64 %rd13, %rd8, 3;
    shr.u64 %rd11, %rd8, 4;
    mad.lo.s32 %r27, %r17, %r9, %r9;
    setp.eq.u32 %p4, %r16, 5;
    @%p4 shl.b32 %r4, %r16, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
