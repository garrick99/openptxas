.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p3, %r3, 4;
    shr.s32 %r4, %r3, 16;
    shr.s32 %r6, %r3, 16;
    mul.wide.u32 %rd6, %r3, %r3;
    shr.u32 %r18, %r4, 31;
    sub.u32 %r15, %r4, %r4;
    mul.lo.u64 %rd12, %rd6, %rd6;
    max.s32 %r8, %r15, 16;
    cvt.s64.s32 %rd7, %r18;
    add.s64 %rd7, %rd6, %rd12;
    selp.b32 %r20, %r15, %r8, %p3;
    setp.hi.u32 %p4, %r8, 16;
    @%p4 mul.lo.u32 %r17, %r18, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
