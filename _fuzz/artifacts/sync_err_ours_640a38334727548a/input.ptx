.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    shr.u32 %r26, %r3, 1;
    max.u32 %r13, %r26, 255;
    shr.u64 %rd6, %rd8, 15;
    mul.wide.u32 %rd10, %r3, %r26;
    mul.lo.s32 %r13, %r26, %r13;
    setp.ne.s32 %p1, %r13, %r26;
    @%p1 min.u32 %r21, %r13, %r3;
    add.s32 %r21, %r26, 2;
    min.u32 %r4, %r3, %r26;
    mul.wide.u32 %rd14, %r26, %r13;
    cvt.u32.u64 %r4, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
