.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r18, %r3, %r3;
    add.s32 %r21, %r18, 31;
    xor.b32 %r15, %r21, %r21;
    setp.hi.u32 %p4, %r3, 256;
    @!%p4 mad.lo.s32 %r23, %r3, %r21, %r18;
    max.s32 %r19, %r23, %r3;
    cvt.u64.u32 %rd5, %r23;
    mul.lo.s32 %r15, %r3, %r3;
    mul.lo.u64 %rd9, %rd5, %rd5;
    setp.gt.s32 %p3, %r3, 7;
    shr.s64 %rd6, %rd5, 31;
    max.u32 %r21, %r15, %r23;
    setp.lt.s32 %p4, %r23, 3;
    mul.wide.s32 %rd10, %r19, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
