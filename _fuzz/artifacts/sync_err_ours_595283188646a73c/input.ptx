.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    add.s32 %r13, %r3, %r3;
    min.s32 %r11, %r13, %r13;
    shr.s64 %rd13, %rd11, 4;
    and.b32 %r9, %r11, 2147483648;
    setp.eq.s32 %p3, %r13, 65536;
    @!%p3 mad.lo.s32 %r22, %r13, %r3, %r11;
    sub.s32 %r6, %r9, %r11;
    add.s32 %r24, %r6, 64;
    and.b32 %r23, %r3, %r9;
    min.u32 %r6, %r23, %r24;
    shl.b64 %rd9, %rd11, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
