.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    sub.s32 %r26, %r3, 65535;
    mad.lo.s32 %r18, %r26, %r3, %r26;
    mad.lo.s32 %r27, %r18, %r3, %r26;
    setp.gt.s32 %p4, %r18, %r27;
    @!%p4 selp.b32 %r17, %r3, %r18, %p4;
    add.u32 %r11, %r26, 0;
    mad.lo.u32 %r5, %r26, %r17, %r11;
    cvt.s32.s64 %r15, %rd13;
    shl.b32 %r15, %r11, 2;
    and.b32 %r8, %r18, 16;
    setp.gt.s32 %p2, %r27, 64;
    max.s32 %r19, %r27, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
