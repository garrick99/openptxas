.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p3, %r3, 63;
    @%p3 sub.s32 %r5, %r3, %r3;
    cvt.u64.u32 %rd12, %r3;
    xor.b32 %r12, %r3, %r5;
    mul.lo.s64 %rd14, %rd12, %rd12;
    selp.b32 %r13, %r12, %r12, %p3;
    setp.lt.u32 %p3, %r3, 5;
    @%p3 xor.b32 %r16, %r13, 256;
    shr.s32 %r13, %r13, 1;
    sub.u64 %rd11, %rd12, %rd12;
    setp.lo.u32 %p4, %r12, %r16;
    mul.lo.u64 %rd5, %rd11, %rd11;
    sub.s32 %r16, %r3, %r16;
    setp.gt.s32 %p3, %r12, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
