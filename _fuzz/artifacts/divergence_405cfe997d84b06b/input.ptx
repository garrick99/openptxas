.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    mad.lo.s32 %r13, %r3, %r3, %r3;
    cvt.u32.u64 %r26, %rd14;
    add.u32 %r9, %r3, 5;
    min.u32 %r7, %r3, 65535;
    min.s32 %r20, %r13, 4;
    xor.b32 %r18, %r20, %r26;
    min.s32 %r20, %r7, 4294967295;
    or.b64 %rd5, %rd14, %rd14;
    setp.lt.s32 %p3, %r9, 2;
    setp.lt.s32 %p1, %r13, 65535;
    @!%p1 min.u32 %r25, %r18, %r26;
    selp.b32 %r22, %r18, %r7, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
