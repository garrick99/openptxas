.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd10, %r3, %r3;
    sub.u32 %r7, %r3, 31;
    shr.u32 %r6, %r7, 15;
    setp.ge.s32 %p3, %r3, %r7;
    @%p3 mul.wide.u32 %rd7, %r7, %r7;
    mad.lo.s32 %r5, %r6, %r7, %r3;
    xor.b32 %r19, %r5, 65535;
    min.u32 %r26, %r19, 4294967295;
    add.s32 %r11, %r19, 2147483647;
    mad.lo.u32 %r21, %r3, %r7, %r6;
    mul.lo.s32 %r6, %r6, 2;
    setp.le.s32 %p2, %r5, 31;
    @%p2 mad.lo.s32 %r9, %r19, %r3, %r26;
    mul.wide.u32 %rd12, %r26, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
