.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    add.u32 %r7, %r3, %r3;
    add.s32 %r13, %r3, 1;
    shr.s64 %rd8, %rd11, 4;
    max.s32 %r14, %r13, %r3;
    shr.u64 %rd10, %rd8, 2;
    shr.s64 %rd10, %rd11, 4;
    shr.s32 %r10, %r7, 7;
    setp.ge.s32 %p3, %r7, %r14;
    @!%p3 sub.u32 %r20, %r14, %r10;
    add.s32 %r19, %r20, 4294967295;
    shl.b64 %rd14, %rd10, 33;
    shl.b64 %rd11, %rd8, 16;
    shr.s64 %rd7, %rd11, 47;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
