.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r9, %r3, %r3;
    setp.hi.u32 %p3, %r9, 8;
    @%p3 mul.lo.s32 %r21, %r3, %r9;
    shl.b32 %r16, %r3, 30;
    cvt.s64.s32 %rd15, %r9;
    cvt.s32.s64 %r20, %rd15;
    shr.s32 %r9, %r21, 3;
    min.s32 %r6, %r16, 4;
    min.s32 %r17, %r9, 16;
    setp.lo.u32 %p4, %r9, 1;
    @!%p4 sub.u64 %rd11, %rd15, %rd15;
    sub.s32 %r11, %r3, %r17;
    shr.u64 %rd7, %rd15, 33;
    cvt.s32.s64 %r11, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
