.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r20, %r3, 1;
    shr.u32 %r18, %r3, 2;
    mul.lo.s32 %r8, %r3, %r18;
    shr.s32 %r25, %r18, 16;
    cvt.u64.u32 %rd5, %r18;
    setp.lt.u32 %p2, %r20, %r25;
    and.b32 %r20, %r20, %r25;
    shr.u32 %r14, %r8, 0;
    mad.lo.s32 %r16, %r14, %r3, %r8;
    mul.lo.s32 %r9, %r14, 15;
    selp.b32 %r25, %r25, %r14, %p2;
    max.s32 %r13, %r3, %r25;
    and.b32 %r18, %r25, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
