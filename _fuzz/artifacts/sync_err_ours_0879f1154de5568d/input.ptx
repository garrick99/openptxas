.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r27, %r3, %r3;
    mul.lo.u32 %r24, %r27, 32;
    mad.lo.u32 %r27, %r27, %r24, %r27;
    min.s32 %r17, %r24, %r3;
    mul.wide.u32 %rd11, %r17, %r24;
    xor.b32 %r12, %r24, 64;
    shr.u32 %r13, %r24, 7;
    mul.lo.u32 %r11, %r13, 31;
    mul.wide.s32 %rd6, %r17, %r3;
    mul.lo.u32 %r4, %r3, %r24;
    max.s64 %rd14, %rd6, %rd11;
    setp.ge.s32 %p4, %r12, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
