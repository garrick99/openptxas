.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r26, %r3, %r3;
    setp.eq.s32 %p1, %r26, %r26;
    @!%p1 mul.lo.s32 %r24, %r3, %r26;
    selp.b32 %r12, %r26, %r3, %p1;
    selp.b32 %r13, %r3, %r24, %p1;
    cvt.s64.s32 %rd10, %r26;
    cvt.u64.u32 %rd15, %r26;
    max.u32 %r5, %r12, %r12;
    max.u32 %r16, %r5, %r5;
    max.u32 %r15, %r24, 255;
    min.s32 %r16, %r26, 2;
    mul.wide.s32 %rd11, %r13, %r26;
    shl.b64 %rd8, %rd11, 32;
    add.s32 %r17, %r24, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
