.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd10, %r3, %r3;
    cvt.u32.u64 %r16, %rd10;
    cvt.s32.s64 %r8, %rd10;
    add.u32 %r25, %r3, %r3;
    shl.b64 %rd14, %rd10, 2;
    mad.lo.u32 %r22, %r8, %r16, %r8;
    xor.b32 %r12, %r25, 31;
    shr.s32 %r7, %r3, 4;
    cvt.u32.u64 %r10, %rd10;
    max.u32 %r8, %r16, %r8;
    mad.lo.s32 %r22, %r3, %r22, %r12;
    shl.b32 %r13, %r8, 0;
    shl.b32 %r7, %r7, 1;
    setp.le.s32 %p4, %r8, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
