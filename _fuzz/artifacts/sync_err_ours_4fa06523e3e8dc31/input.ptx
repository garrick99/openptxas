.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r14, %r3, %r3;
    cvt.u64.u32 %rd8, %r14;
    shr.s64 %rd6, %rd8, 2;
    shr.s32 %r4, %r14, 31;
    mul.wide.u32 %rd15, %r3, %r3;
    cvt.s64.s32 %rd10, %r4;
    mul.lo.u64 %rd14, %rd10, %rd15;
    add.u32 %r10, %r4, 255;
    mul.lo.u64 %rd14, %rd8, %rd14;
    or.b32 %r14, %r10, %r4;
    add.s32 %r7, %r4, %r10;
    and.b64 %rd5, %rd15, %rd14;
    shr.s32 %r4, %r14, 2;
    cvt.u32.u64 %r26, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
