.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p3, %r3, %r3;
    vote.sync.ballot.b32 %r15, %p3, -1;
    shfl.sync.down.b32 %r17, %r15, 2, 0x1f, -1;
    shfl.sync.idx.b32 %r15, %r17, 31, 0x1f, -1;
    add.u32 %r7, %r0, %r15;
    vote.sync.all.pred %p3, %p3, -1;
    xor.b32 %r16, %r7, %r0;
    shfl.sync.idx.b32 %r14, %r16, 0, 0x1f, -1;
    sub.u32 %r5, %r15, %r14;
    min.u32 %r17, %r14, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
