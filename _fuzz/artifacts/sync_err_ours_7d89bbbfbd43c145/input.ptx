.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r5, %r3, 2;
    setp.hi.u32 %p3, %r3, %r5;
    @!%p3 max.u32 %r8, %r3, 4;
    or.b32 %r5, %r5, 63;
    shr.u32 %r11, %r8, 16;
    xor.b32 %r8, %r5, %r3;
    xor.b32 %r25, %r5, %r11;
    shl.b32 %r10, %r11, 7;
    or.b32 %r25, %r10, %r8;
    min.u32 %r21, %r25, %r11;
    shl.b32 %r21, %r8, 31;
    max.s32 %r13, %r21, 1;
    mad.lo.u32 %r24, %r13, %r10, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
