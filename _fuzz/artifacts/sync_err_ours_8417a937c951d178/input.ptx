.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r5, %r3, %r3;
    cvt.s64.s32 %rd8, %r5;
    add.s64 %rd9, %rd8, %rd8;
    cvt.u32.u64 %r12, %rd8;
    mad.lo.u32 %r6, %r3, %r5, %r12;
    mul.wide.s32 %rd15, %r12, %r12;
    shl.b32 %r21, %r5, 4;
    shr.u32 %r21, %r5, 30;
    sub.u32 %r20, %r5, %r3;
    mad.lo.s32 %r4, %r3, %r3, %r5;
    add.s32 %r23, %r3, %r20;
    max.s32 %r26, %r5, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
