.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd11, %r3, %r3;
    sub.s32 %r24, %r3, %r3;
    add.s32 %r6, %r3, 1;
    min.u32 %r19, %r24, %r24;
    mul.lo.u32 %r10, %r3, 8;
    cvt.s64.s32 %rd14, %r10;
    max.u32 %r12, %r3, 5;
    xor.b32 %r17, %r3, 255;
    cvt.s32.s64 %r17, %rd11;
    mul.lo.s32 %r12, %r12, 16;
    mul.lo.s32 %r20, %r6, %r24;
    and.b32 %r27, %r12, 64;
    shr.u64 %rd13, %rd14, 15;
    setp.hs.u32 %p3, %r27, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
