.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r10, %r3, %r3;
    add.s32 %r12, %r3, 4294967295;
    and.b32 %r7, %r3, 255;
    mad.lo.s32 %r27, %r7, %r10, %r7;
    shr.u32 %r27, %r12, 0;
    sub.u32 %r18, %r7, 15;
    max.s32 %r27, %r18, %r12;
    shl.b32 %r17, %r3, 30;
    shr.s32 %r26, %r17, 7;
    min.s32 %r8, %r17, %r26;
    shr.s32 %r22, %r12, 30;
    or.b32 %r15, %r7, %r10;
    sub.u32 %r9, %r27, %r7;
    sub.s32 %r24, %r8, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
