.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd7, %r3, %r3;
    max.u32 %r20, %r3, %r3;
    max.u32 %r9, %r20, 64;
    cvt.u32.u64 %r15, %rd7;
    cvt.s32.s64 %r24, %rd7;
    mul.lo.u32 %r12, %r3, 2147483647;
    shr.u64 %rd6, %rd7, 3;
    min.s64 %rd6, %rd6, %rd7;
    xor.b32 %r23, %r9, 2147483648;
    mul.lo.u64 %rd7, %rd6, %rd7;
    shl.b64 %rd13, %rd6, 48;
    max.u32 %r26, %r15, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
