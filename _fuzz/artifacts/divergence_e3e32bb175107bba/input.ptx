.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r5, %r3, %r3;
    mul.wide.s32 %rd12, %r5, %r3;
    cvt.s32.s64 %r24, %rd12;
    setp.le.s32 %p2, %r5, 31;
    @%p2 add.s32 %r9, %r5, 255;
    shr.s32 %r17, %r24, 7;
    min.u64 %rd13, %rd12, %rd12;
    add.u32 %r5, %r9, 7;
    mul.wide.s32 %rd14, %r17, %r24;
    and.b32 %r7, %r9, 64;
    mul.lo.u32 %r8, %r9, 8;
    xor.b32 %r15, %r7, 7;
    selp.b32 %r14, %r8, %r9, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
