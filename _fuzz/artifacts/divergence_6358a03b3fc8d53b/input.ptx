.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd14, %r3, %r3;
    mul.wide.u32 %rd7, %r3, %r3;
    min.s32 %r16, %r3, 256;
    or.b32 %r11, %r16, 4294967295;
    setp.ge.s32 %p4, %r11, %r16;
    @%p4 mul.lo.u64 %rd11, %rd14, %rd14;
    setp.lt.s32 %p3, %r16, %r16;
    @%p3 max.s32 %r23, %r3, 64;
    xor.b32 %r20, %r16, %r11;
    shr.u32 %r8, %r20, 30;
    mad.lo.s32 %r13, %r3, %r11, %r8;
    setp.ls.u32 %p3, %r20, %r8;
    @%p3 add.s32 %r27, %r13, %r20;
    min.u32 %r4, %r8, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
