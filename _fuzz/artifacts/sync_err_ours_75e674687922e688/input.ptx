.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    add.s32 %r17, %r3, %r3;
    min.s64 %rd15, %rd8, %rd8;
    or.b64 %rd10, %rd15, %rd8;
    cvt.s32.s64 %r11, %rd10;
    setp.gt.s32 %p4, %r11, 255;
    @%p4 or.b64 %rd13, %rd8, %rd8;
    min.u32 %r26, %r11, 15;
    or.b32 %r21, %r17, %r26;
    add.u32 %r19, %r17, %r21;
    min.s32 %r12, %r26, 4;
    min.s32 %r27, %r17, 1;
    selp.b32 %r27, %r21, %r19, %p4;
    mad.lo.s32 %r10, %r27, %r21, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
