.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r11, %r3, 1;
    cvt.u64.u32 %rd15, %r3;
    max.s32 %r4, %r3, %r3;
    mul.lo.u32 %r19, %r11, %r4;
    mad.lo.u32 %r23, %r4, %r3, %r19;
    add.s32 %r24, %r19, %r4;
    add.u64 %rd11, %rd15, %rd15;
    setp.ne.u32 %p1, %r23, %r19;
    @!%p1 sub.s32 %r6, %r11, %r19;
    min.s32 %r17, %r11, 16;
    selp.b32 %r16, %r17, %r24, %p1;
    mul.wide.s32 %rd6, %r16, %r6;
    mul.lo.u64 %rd6, %rd15, %rd15;
    and.b32 %r24, %r6, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
