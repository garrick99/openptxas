.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    or.b32 %r13, %r3, %r3;
    mad.lo.u32 %r23, %r3, %r13, %r13;
    cvt.s64.s32 %rd13, %r23;
    cvt.s32.s64 %r26, %rd8;
    or.b32 %r20, %r23, 64;
    shl.b32 %r10, %r23, 3;
    mul.wide.s32 %rd15, %r23, %r3;
    max.u32 %r18, %r26, %r20;
    mul.lo.s32 %r26, %r20, %r3;
    xor.b64 %rd9, %rd8, %rd8;
    max.u32 %r16, %r20, 1;
    setp.lt.s32 %p4, %r16, %r18;
    @!%p4 mul.lo.s32 %r27, %r18, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
