.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r27, %r3, %r3;
    mul.wide.u32 %rd7, %r3, %r27;
    sub.s32 %r22, %r3, 8;
    add.u32 %r22, %r22, %r22;
    add.s32 %r9, %r3, 8;
    mad.lo.s32 %r20, %r27, %r3, %r27;
    mad.lo.u32 %r6, %r22, %r27, %r22;
    max.u32 %r27, %r27, %r22;
    shl.b64 %rd8, %rd7, 2;
    setp.eq.s32 %p2, %r6, %r22;
    @%p2 mul.lo.u32 %r16, %r22, 5;
    shr.u64 %rd6, %rd8, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
