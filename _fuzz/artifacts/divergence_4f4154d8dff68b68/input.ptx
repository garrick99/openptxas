    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p2, %r3, 32;
    @%p2 shl.b32 %r24, %r3, 30;
    max.u32 %r9, %r24, %r3;
    setp.lt.s32 %p2, %r24, %r9;
    @!%p2 mul.wide.u32 %rd12, %r3, %r3;
    cvt.u32.u64 %r5, %rd12;
    mad.lo.s32 %r17, %r9, %r5, %r5;
