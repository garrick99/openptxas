.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    setp.ls.u32 %p2, %r3, %r3;
    @!%p2 mul.lo.s64 %rd15, %rd12, %rd12;
    max.u32 %r10, %r3, 64;
    shr.s32 %r5, %r10, 1;
    min.s32 %r20, %r10, %r3;
    and.b64 %rd5, %rd12, %rd12;
    mad.lo.u32 %r18, %r10, %r3, %r20;
    min.u32 %r9, %r5, 65535;
    sub.s64 %rd15, %rd5, %rd12;
    setp.ne.u32 %p3, %r5, %r9;
    @!%p3 and.b64 %rd5, %rd12, %rd15;
    shl.b32 %r6, %r9, 7;
    mul.lo.s32 %r9, %r3, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
