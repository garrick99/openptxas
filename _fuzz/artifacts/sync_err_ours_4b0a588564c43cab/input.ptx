.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r13, %r3, %r3;
    cvt.u64.u32 %rd14, %r3;
    max.u32 %r24, %r13, %r3;
    add.u32 %r17, %r13, 8;
    shl.b32 %r8, %r17, 7;
    sub.u64 %rd9, %rd14, %rd14;
    shr.u64 %rd6, %rd9, 32;
    shr.s32 %r23, %r8, 7;
    min.s32 %r17, %r24, %r17;
    shl.b32 %r24, %r13, 1;
    shr.s64 %rd7, %rd9, 32;
    setp.le.u32 %p2, %r3, 8;
    @!%p2 min.s32 %r12, %r13, 5;
    sub.s32 %r13, %r24, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
