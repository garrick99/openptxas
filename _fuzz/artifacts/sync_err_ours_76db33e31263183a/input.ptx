.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r4, %r3, %r3;
    cvt.s64.s32 %rd9, %r3;
    max.s32 %r24, %r3, %r3;
    and.b32 %r6, %r4, 15;
    mul.wide.u32 %rd5, %r3, %r6;
    max.s64 %rd8, %rd9, %rd5;
    xor.b32 %r10, %r4, 65536;
    shl.b32 %r22, %r6, 4;
    shr.u32 %r13, %r4, 16;
    shl.b64 %rd12, %rd8, 1;
    mul.lo.u32 %r18, %r3, 255;
    mad.lo.s32 %r6, %r6, %r24, %r18;
    shr.s32 %r23, %r24, 0;
    min.s32 %r14, %r3, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
