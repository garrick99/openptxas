.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    mul.lo.s32 %r13, %r3, 65535;
    cvt.u64.u32 %rd7, %r13;
    cvt.s64.s32 %rd13, %r13;
    mul.lo.u32 %r10, %r13, 15;
    mad.lo.s32 %r10, %r13, %r3, %r13;
    max.s32 %r9, %r3, 31;
    shr.u32 %r16, %r13, 3;
    shl.b64 %rd6, %rd13, 47;
    mul.lo.s32 %r11, %r3, 255;
    sub.s64 %rd11, %rd7, %rd11;
    shl.b64 %rd14, %rd7, 47;
    shr.s32 %r25, %r10, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
