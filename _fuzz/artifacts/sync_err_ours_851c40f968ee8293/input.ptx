.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r20, %r3, 32;
    mul.wide.s32 %rd8, %r3, %r20;
    shl.b32 %r17, %r20, 16;
    and.b32 %r5, %r20, %r20;
    setp.lt.u32 %p3, %r17, 32;
    @%p3 mul.wide.s32 %rd7, %r20, %r20;
    mul.wide.s32 %rd7, %r20, %r3;
    sub.s32 %r10, %r20, %r17;
    max.s32 %r25, %r5, 63;
    min.s32 %r9, %r25, %r10;
    or.b32 %r22, %r25, %r20;
    mad.lo.s32 %r7, %r9, %r10, %r3;
    selp.b32 %r4, %r9, %r7, %p3;
    shr.s32 %r26, %r10, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
