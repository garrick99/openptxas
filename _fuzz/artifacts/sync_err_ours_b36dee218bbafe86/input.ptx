.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfi.b32 %r18, %r3, %r3, 8, 32;
    bfi.b32 %r16, %r18, %r18, 8, 2;
    bfe.u32 %r6, %r18, 7, 2;
    bfe.u32 %r15, %r18, 16, 24;
    clz.b32 %r17, %r15;
    or.b32 %r18, %r16, 256;
    bfe.s32 %r14, %r15, 8, 2;
    prmt.b32 %r11, %r3, %r16, 48059;
    popc.b32 %r17, %r18;
    bfe.u32 %r16, %r3, 0, 32;
    bfe.u32 %r18, %r14, 16, 4;
    or.b32 %r7, %r11, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
