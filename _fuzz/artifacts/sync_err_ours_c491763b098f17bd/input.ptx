.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r18, %r3, %r3;
    sub.s32 %r21, %r3, %r18;
    xor.b32 %r17, %r3, 31;
    shl.b32 %r25, %r17, 3;
    sub.s32 %r19, %r25, %r17;
    min.s32 %r7, %r21, %r19;
    cvt.u64.u32 %rd13, %r17;
    setp.lt.u32 %p3, %r17, %r19;
    @%p3 min.u32 %r21, %r18, 5;
    sub.s32 %r6, %r18, %r18;
    shr.s64 %rd10, %rd13, 31;
    shr.u32 %r17, %r17, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
