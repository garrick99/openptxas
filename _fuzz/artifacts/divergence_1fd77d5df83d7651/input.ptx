.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p3, %r3, %r3;
    @%p3 mad.lo.s32 %r7, %r3, %r3, %r3;
    mad.lo.u32 %r6, %r7, %r3, %r7;
    setp.gt.s32 %p3, %r7, %r7;
    @%p3 selp.b32 %r26, %r7, %r6, %p3;
    cvt.u64.u32 %rd5, %r6;
    min.s32 %r24, %r3, 8;
    cvt.u32.u64 %r20, %rd5;
    setp.ge.s32 %p3, %r7, 5;
    add.s64 %rd8, %rd5, %rd5;
    shl.b64 %rd8, %rd5, 1;
    selp.b32 %r20, %r6, %r6, %p3;
    selp.b32 %r27, %r20, %r20, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
