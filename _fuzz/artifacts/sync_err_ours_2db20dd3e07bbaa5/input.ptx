.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r20, %r3, 65535;
    mul.wide.u32 %rd15, %r20, %r3;
    and.b32 %r21, %r3, 2;
    mul.lo.u32 %r18, %r21, 65536;
    shr.s32 %r5, %r21, 4;
    add.u32 %r26, %r18, %r18;
    add.u64 %rd14, %rd15, %rd15;
    cvt.u32.u64 %r25, %rd15;
    shl.b32 %r4, %r18, 3;
    cvt.s32.s64 %r21, %rd14;
    cvt.s64.s32 %rd10, %r4;
    shl.b64 %rd6, %rd14, 7;
    and.b32 %r22, %r26, %r20;
    add.s32 %r16, %r26, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
