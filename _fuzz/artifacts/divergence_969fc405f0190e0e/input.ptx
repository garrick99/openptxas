.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r20, %r3, %r3, %r3;
    shr.s32 %r24, %r20, 4;
    max.u32 %r13, %r24, %r20;
    max.u32 %r27, %r24, 4294967295;
    setp.ge.s32 %p2, %r24, 8;
    @!%p2 mul.wide.u32 %rd8, %r24, %r13;
    shr.s32 %r7, %r3, 0;
    mul.lo.u64 %rd6, %rd8, %rd8;
    selp.b32 %r12, %r7, %r24, %p2;
    shr.u32 %r12, %r24, 7;
    shr.u64 %rd10, %rd6, 1;
    setp.gt.s32 %p1, %r27, %r24;
    @%p1 shl.b32 %r9, %r12, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
