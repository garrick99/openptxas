.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    popc.b32 %r4, %r3;
    bfe.u32 %r9, %r4, 8, 1;
    add.u32 %r8, %r9, %r4;
    prmt.b32 %r23, %r9, %r9, 0;
    popc.b32 %r7, %r3;
    bfe.u32 %r8, %r23, 7, 31;
    add.u32 %r12, %r7, %r9;
    max.u32 %r6, %r4, 15;
    popc.b32 %r10, %r7;
    or.b32 %r21, %r12, 16;
    sub.u32 %r16, %r3, %r10;
    bfi.b32 %r14, %r9, %r16, 8, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
