.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    and.b64 %rd8, %rd11, %rd11;
    mul.wide.u32 %rd10, %r3, %r3;
    min.s32 %r27, %r3, %r3;
    mul.wide.u32 %rd8, %r27, %r3;
    mul.lo.s32 %r27, %r3, 256;
    cvt.u32.u64 %r25, %rd10;
    mul.lo.u32 %r20, %r25, %r25;
    shr.u32 %r21, %r25, 4;
    mad.lo.s32 %r22, %r3, %r27, %r20;
    min.s64 %rd10, %rd11, %rd10;
    shr.u32 %r24, %r3, 4;
    mul.lo.u32 %r27, %r21, %r25;
    cvt.s32.s64 %r12, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
