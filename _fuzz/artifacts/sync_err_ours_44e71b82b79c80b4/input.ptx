.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r15, %r3, %r3;
    sub.u32 %r5, %r3, 63;
    xor.b32 %r26, %r3, %r15;
    mul.wide.s32 %rd15, %r3, %r5;
    mul.wide.u32 %rd15, %r15, %r3;
    mad.lo.u32 %r18, %r5, %r3, %r15;
    add.u32 %r19, %r15, 256;
    sub.u32 %r16, %r19, 16;
    or.b32 %r23, %r26, %r5;
    shl.b32 %r8, %r5, 15;
    cvt.s32.s64 %r8, %rd15;
    shl.b32 %r21, %r18, 3;
    shr.s32 %r27, %r5, 3;
    shl.b32 %r26, %r27, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
