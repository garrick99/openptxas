.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    max.u32 %r25, %r3, %r3;
    and.b32 %r15, %r25, %r3;
    min.u32 %r19, %r15, %r25;
    min.u64 %rd8, %rd14, %rd14;
    min.s32 %r23, %r3, 256;
    min.s32 %r6, %r19, 64;
    setp.eq.s32 %p4, %r3, %r3;
    @!%p4 sub.s32 %r27, %r15, 256;
    cvt.s32.s64 %r6, %rd8;
    add.s64 %rd12, %rd8, %rd8;
    mul.wide.s32 %rd5, %r3, %r27;
    mad.lo.u32 %r8, %r6, %r3, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
