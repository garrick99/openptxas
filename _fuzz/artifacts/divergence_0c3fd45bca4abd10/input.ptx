.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    xor.b32 %r24, %r3, 64;
    shr.u64 %rd10, %rd11, 33;
    mad.lo.s32 %r16, %r24, %r24, %r24;
    max.u32 %r25, %r24, %r16;
    setp.lo.u32 %p3, %r25, %r24;
    @%p3 shr.u32 %r11, %r24, 31;
    min.s32 %r22, %r16, %r3;
    cvt.s32.s64 %r8, %rd11;
    mad.lo.u32 %r21, %r16, %r3, %r16;
    shr.u32 %r14, %r24, 16;
    selp.b32 %r19, %r21, %r24, %p3;
    shr.s32 %r17, %r19, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
