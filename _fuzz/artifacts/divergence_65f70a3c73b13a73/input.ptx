.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r6, %r3, 256;
    cvt.s64.s32 %rd12, %r3;
    shr.s32 %r19, %r3, 0;
    min.u64 %rd5, %rd12, %rd12;
    sub.u64 %rd15, %rd5, %rd12;
    mad.lo.s32 %r24, %r6, %r6, %r3;
    max.u32 %r8, %r24, %r24;
    mad.lo.s32 %r13, %r8, %r8, %r8;
    or.b32 %r12, %r19, %r24;
    mad.lo.s32 %r18, %r19, %r13, %r24;
    shr.u32 %r20, %r12, 7;
    shl.b64 %rd8, %rd15, 47;
    max.u32 %r13, %r13, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
