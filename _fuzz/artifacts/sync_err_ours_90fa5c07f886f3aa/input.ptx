.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r19, %r3, 4;
    shl.b32 %r14, %r19, 16;
    cvt.u64.u32 %rd10, %r14;
    cvt.s32.s64 %r8, %rd10;
    setp.hi.u32 %p3, %r8, %r3;
    @!%p3 cvt.s32.s64 %r17, %rd10;
    min.u32 %r21, %r19, %r19;
    shr.u32 %r7, %r19, 31;
    mad.lo.s32 %r25, %r8, %r21, %r3;
    sub.s32 %r21, %r17, 63;
    add.s32 %r4, %r14, 32;
    max.s32 %r22, %r14, %r14;
    shr.s32 %r15, %r4, 30;
    max.s32 %r26, %r25, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
