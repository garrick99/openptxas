.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p2, %r3, 16;
    @%p2 mad.lo.u32 %r15, %r3, %r3, %r3;
    shl.b32 %r16, %r15, 30;
    setp.lt.s32 %p1, %r16, %r15;
    @%p1 mad.lo.s32 %r17, %r3, %r16, %r16;
    setp.le.s32 %p2, %r17, 255;
    @%p2 shl.b32 %r8, %r16, 1;
    and.b32 %r15, %r3, %r16;
    cvt.s64.s32 %rd12, %r17;
    add.u32 %r5, %r3, %r17;
    max.s32 %r23, %r8, 63;
    min.u32 %r13, %r17, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
