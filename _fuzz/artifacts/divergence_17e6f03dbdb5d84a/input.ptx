.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd5, %r3, %r3;
    shr.s64 %rd12, %rd5, 33;
    mad.lo.u32 %r11, %r3, %r3, %r3;
    or.b32 %r14, %r3, %r3;
    cvt.s32.s64 %r26, %rd12;
    sub.s32 %r17, %r26, 64;
    sub.s32 %r20, %r11, %r14;
    and.b32 %r17, %r3, 15;
    shl.b64 %rd7, %rd5, 0;
    max.s64 %rd8, %rd7, %rd12;
    mul.lo.u32 %r15, %r14, %r14;
    xor.b32 %r9, %r3, %r20;
    setp.le.u32 %p1, %r3, %r11;
    @!%p1 max.s32 %r25, %r14, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
