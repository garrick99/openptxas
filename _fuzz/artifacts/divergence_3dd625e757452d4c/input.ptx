.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p3, %r3, %r3;
    @%p3 mul.lo.s32 %r5, %r3, %r3;
    cvt.s64.s32 %rd8, %r3;
    shr.u32 %r22, %r3, 7;
    shl.b32 %r17, %r5, 1;
    sub.s32 %r4, %r17, 1;
    add.s32 %r7, %r4, 2147483647;
    mad.lo.u32 %r19, %r17, %r22, %r3;
    mul.wide.s32 %rd15, %r22, %r4;
    mul.wide.u32 %rd6, %r3, %r4;
    max.s32 %r25, %r7, 31;
    setp.ge.s32 %p1, %r7, %r22;
    @%p1 mul.wide.s32 %rd13, %r7, %r5;
    add.u32 %r18, %r19, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
