    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r14, %r3, %r3;
    sub.u32 %r19, %r14, 2147483648;
    sub.u32 %r5, %r19, 255;
    add.s32 %r7, %r19, %r14;
