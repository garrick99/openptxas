.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r16, %r3, %r3;
    and.b32 %r25, %r16, %r16;
    setp.ge.u32 %p4, %r16, 3;
    @!%p4 selp.b32 %r7, %r3, %r25, %p4;
    max.u32 %r7, %r25, %r7;
    min.u32 %r7, %r25, %r16;
    add.s32 %r14, %r25, %r7;
    mul.wide.s32 %rd13, %r3, %r7;
    sub.u32 %r10, %r16, %r3;
    add.u32 %r11, %r14, 8;
    shl.b32 %r27, %r11, 30;
    shl.b32 %r21, %r7, 0;
    shr.u64 %rd6, %rd13, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
