.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p3, %r3, %r3;
    @%p3 mad.lo.s32 %r20, %r3, %r3, %r3;
    cvt.u64.u32 %rd9, %r3;
    shl.b64 %rd11, %rd9, 47;
    mul.lo.u32 %r26, %r3, %r3;
    selp.b32 %r7, %r20, %r26, %p3;
    shr.s64 %rd8, %rd9, 1;
    setp.le.u32 %p2, %r26, %r3;
    @%p2 shr.u32 %r8, %r3, 1;
    shl.b64 %rd10, %rd8, 0;
    add.s32 %r17, %r7, 2;
    mul.lo.u64 %rd6, %rd8, %rd8;
    add.u32 %r9, %r20, %r26;
    sub.s32 %r10, %r7, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
