.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    shl.b32 %r5, %r3, 15;
    min.s32 %r24, %r5, %r5;
    shr.u32 %r18, %r3, 7;
    sub.s32 %r18, %r5, 7;
    add.u32 %r15, %r3, 64;
    mad.lo.u32 %r17, %r3, %r5, %r18;
    add.u32 %r23, %r18, 15;
    sub.s32 %r15, %r18, %r3;
    min.u32 %r25, %r15, %r18;
    or.b64 %rd14, %rd7, %rd7;
    mul.wide.u32 %rd7, %r17, %r23;
    cvt.s32.s64 %r9, %rd14;
    or.b32 %r27, %r3, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
