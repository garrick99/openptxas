.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r4, %r3, %r3;
    min.s32 %r24, %r3, 32;
    add.u32 %r22, %r24, %r4;
    shr.u32 %r25, %r24, 7;
    setp.ge.s32 %p4, %r3, 65536;
    cvt.u64.u32 %rd15, %r4;
    setp.ne.s32 %p3, %r25, 1;
    @%p3 shr.s64 %rd13, %rd15, 48;
    cvt.s32.s64 %r6, %rd15;
    add.u32 %r12, %r22, %r24;
    selp.b32 %r18, %r6, %r4, %p3;
    sub.s32 %r11, %r4, %r24;
    shr.s32 %r5, %r11, 3;
    max.s32 %r5, %r3, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
