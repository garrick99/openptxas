.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p1, %r3, 255;
    setp.ne.u32 %p3, %r3, %r3;
    xor.b32 %r11, %r3, 2;
    mul.lo.s32 %r17, %r11, %r11;
    xor.b32 %r22, %r17, %r3;
    xor.b32 %r11, %r11, 2147483648;
    shr.u32 %r23, %r17, 16;
    mad.lo.s32 %r26, %r17, %r23, %r17;
    setp.ne.u32 %p1, %r11, 5;
    @%p1 max.s32 %r12, %r17, 65536;
    setp.gt.s32 %p3, %r12, %r11;
    @%p3 and.b32 %r22, %r23, 3;
    sub.u32 %r9, %r22, %r12;
    mul.lo.s32 %r17, %r23, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
