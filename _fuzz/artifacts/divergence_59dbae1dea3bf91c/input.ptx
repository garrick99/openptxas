.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r7, %r3, %r3;
    setp.hs.u32 %p3, %r3, 65535;
    @%p3 cvt.s64.s32 %rd11, %r7;
    add.s32 %r22, %r7, %r3;
    max.u32 %r14, %r7, 7;
    add.s32 %r20, %r14, 15;
    selp.b32 %r14, %r3, %r3, %p3;
    xor.b32 %r26, %r7, 63;
    shr.s32 %r7, %r14, 3;
    add.s32 %r8, %r20, %r26;
    and.b32 %r13, %r22, %r20;
    shr.s64 %rd5, %rd11, 33;
    mad.lo.s32 %r27, %r14, %r14, %r8;
    max.s32 %r18, %r13, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
