.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r24, %r3, %r3;
    setp.lt.u32 %p1, %r3, %r3;
    @%p1 mul.lo.s32 %r4, %r3, %r3;
    cvt.s64.s32 %rd11, %r3;
    selp.b32 %r19, %r24, %r4, %p1;
    min.u32 %r12, %r24, %r3;
    xor.b32 %r10, %r12, 4294967295;
    shr.u32 %r5, %r10, 4;
    selp.b32 %r4, %r5, %r12, %p1;
    mul.lo.s32 %r17, %r5, %r19;
    cvt.u64.u32 %rd13, %r12;
    sub.s32 %r17, %r4, 16;
    max.s32 %r26, %r24, %r5;
    mad.lo.s32 %r23, %r3, %r24, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
