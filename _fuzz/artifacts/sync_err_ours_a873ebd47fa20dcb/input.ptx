.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r8, %r3, 3;
    max.s32 %r25, %r3, %r8;
    shl.b32 %r9, %r25, 1;
    add.s32 %r17, %r8, 5;
    mul.lo.s32 %r15, %r8, %r25;
    cvt.u64.u32 %rd11, %r8;
    min.s64 %rd14, %rd11, %rd11;
    cvt.u64.u32 %rd7, %r3;
    mul.lo.u32 %r6, %r17, 32;
    or.b32 %r27, %r25, %r6;
    setp.le.s32 %p3, %r8, %r17;
    shr.u32 %r19, %r3, 3;
    sub.s64 %rd14, %rd11, %rd7;
    add.s32 %r15, %r25, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
