.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r26, %r3, %r3;
    mul.wide.u32 %rd9, %r3, %r3;
    or.b32 %r14, %r26, %r26;
    sub.u32 %r9, %r14, %r26;
    cvt.s32.s64 %r27, %rd9;
    shl.b64 %rd8, %rd9, 4;
    max.s32 %r4, %r9, 16;
    mul.wide.u32 %rd8, %r4, %r3;
    shl.b32 %r4, %r27, 0;
    mad.lo.u32 %r27, %r3, %r3, %r9;
    add.s32 %r23, %r9, 65535;
    cvt.u64.u32 %rd13, %r26;
    cvt.u64.u32 %rd13, %r4;
    max.u32 %r5, %r14, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
