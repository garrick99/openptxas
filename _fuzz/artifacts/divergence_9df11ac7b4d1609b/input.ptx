.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    cvt.u32.u64 %r18, %rd5;
    shr.s32 %r23, %r3, 1;
    and.b32 %r7, %r18, %r18;
    min.s32 %r16, %r7, %r7;
    shr.u64 %rd11, %rd5, 15;
    add.s32 %r27, %r23, %r23;
    mad.lo.s32 %r4, %r16, %r23, %r16;
    mul.wide.s32 %rd9, %r3, %r4;
    min.u32 %r15, %r27, %r18;
    min.u32 %r13, %r4, %r16;
    mul.lo.s32 %r22, %r27, 65536;
    min.s32 %r17, %r13, %r13;
    mul.lo.u32 %r14, %r22, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
