.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    add.u64 %rd14, %rd9, %rd9;
    max.u64 %rd11, %rd14, %rd14;
    cvt.s64.s32 %rd7, %r3;
    mul.wide.s32 %rd8, %r3, %r3;
    mad.lo.s32 %r15, %r3, %r3, %r3;
    shr.s32 %r19, %r3, 31;
    min.u32 %r19, %r3, %r3;
    cvt.s32.s64 %r4, %rd7;
    sub.u32 %r23, %r15, %r3;
    mad.lo.s32 %r8, %r4, %r4, %r3;
    add.u32 %r18, %r8, %r4;
    mul.lo.s32 %r7, %r4, %r18;
    sub.s32 %r5, %r4, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
