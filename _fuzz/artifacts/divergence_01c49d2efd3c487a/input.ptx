.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r11, %r3, 31;
    mul.lo.s32 %r22, %r3, %r3;
    mul.lo.s32 %r26, %r11, %r22;
    add.u32 %r20, %r26, 8;
    mul.lo.s32 %r17, %r20, 31;
    mad.lo.u32 %r10, %r26, %r3, %r26;
    add.u32 %r5, %r26, %r10;
    setp.ne.s32 %p2, %r3, 1;
    @%p2 or.b32 %r12, %r26, 4294967295;
    mul.lo.s32 %r8, %r22, 8;
    cvt.s64.s32 %rd7, %r26;
    max.s32 %r6, %r17, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
