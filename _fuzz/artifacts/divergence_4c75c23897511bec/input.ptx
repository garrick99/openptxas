.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p2, %r3, %r3;
    @!%p2 sub.s32 %r25, %r3, 4294967295;
    sub.u32 %r25, %r25, %r25;
    mul.lo.s32 %r20, %r3, %r3;
    setp.le.s32 %p3, %r20, 1;
    @%p3 mul.lo.s32 %r6, %r25, %r25;
    min.u32 %r26, %r25, 3;
    mad.lo.s32 %r5, %r6, %r3, %r26;
    mad.lo.s32 %r25, %r20, %r6, %r20;
    min.u32 %r4, %r20, %r6;
    mul.lo.s32 %r14, %r5, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
