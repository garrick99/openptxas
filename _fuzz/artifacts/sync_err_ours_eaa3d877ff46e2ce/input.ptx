.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r15, %r3, %r3, %r3;
    min.u32 %r21, %r15, %r3;
    min.u32 %r27, %r3, %r3;
    mul.lo.u32 %r11, %r3, 1;
    sub.u32 %r7, %r27, %r27;
    setp.ls.u32 %p4, %r11, %r15;
    setp.le.s32 %p3, %r27, %r11;
    @%p3 shl.b32 %r26, %r27, 31;
    cvt.s64.s32 %rd13, %r27;
    shl.b32 %r15, %r27, 16;
    sub.u32 %r21, %r21, %r7;
    cvt.s32.s64 %r15, %rd13;
    add.s32 %r17, %r3, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
