.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r15, %r3, 16;
    cvt.u64.u32 %rd11, %r3;
    cvt.u64.u32 %rd12, %r3;
    mul.wide.u32 %rd14, %r15, %r3;
    cvt.u64.u32 %rd9, %r3;
    cvt.u32.u64 %r24, %rd9;
    xor.b64 %rd12, %rd12, %rd11;
    and.b64 %rd12, %rd12, %rd14;
    max.u32 %r23, %r15, %r15;
    max.u32 %r8, %r3, %r24;
    sub.s32 %r6, %r3, %r24;
    setp.lo.u32 %p1, %r24, %r15;
    shr.u64 %rd15, %rd9, 4;
    add.s32 %r24, %r15, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
