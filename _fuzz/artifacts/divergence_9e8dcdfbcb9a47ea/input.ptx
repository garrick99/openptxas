.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p4, %r3, 31;
    @%p4 add.s32 %r22, %r3, 256;
    max.s32 %r7, %r3, %r3;
    add.s32 %r26, %r22, %r22;
    mul.wide.u32 %rd15, %r7, %r26;
    selp.b32 %r24, %r22, %r7, %p4;
    setp.lt.s32 %p3, %r24, %r26;
    @!%p3 shl.b32 %r14, %r26, 4;
    add.s64 %rd8, %rd15, %rd15;
    sub.s32 %r13, %r14, 15;
    and.b32 %r19, %r3, %r14;
    selp.b32 %r21, %r13, %r19, %p4;
    max.s32 %r27, %r13, 2;
    shr.u64 %rd9, %rd15, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
