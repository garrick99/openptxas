.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r11, %r3, %r3;
    cvt.s64.s32 %rd10, %r11;
    add.s32 %r21, %r11, %r11;
    min.s64 %rd11, %rd10, %rd10;
    setp.lt.s32 %p2, %r11, 65536;
    @%p2 cvt.u32.u64 %r18, %rd10;
    setp.le.s32 %p4, %r18, %r18;
    max.u64 %rd13, %rd11, %rd11;
    min.u32 %r16, %r21, %r3;
    sub.u64 %rd15, %rd11, %rd10;
    setp.le.s32 %p4, %r16, 255;
    @%p4 mul.lo.u32 %r18, %r11, %r11;
    setp.ge.s32 %p1, %r18, 8;
    @%p1 shr.u32 %r18, %r3, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
