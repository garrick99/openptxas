.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd12, %r3, %r3;
    mul.wide.u32 %rd7, %r3, %r3;
    min.s64 %rd11, %rd12, %rd12;
    setp.ne.s32 %p3, %r3, %r3;
    sub.u32 %r11, %r3, 4294967295;
    mul.lo.u32 %r21, %r11, 32;
    mul.lo.u32 %r26, %r21, %r3;
    selp.b32 %r25, %r26, %r3, %p3;
    sub.s32 %r26, %r25, 65535;
    shr.u32 %r25, %r25, 16;
    mul.wide.u32 %rd11, %r25, %r26;
    mul.lo.s32 %r17, %r3, 5;
    cvt.s32.s64 %r5, %rd7;
    mad.lo.u32 %r19, %r11, %r3, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
