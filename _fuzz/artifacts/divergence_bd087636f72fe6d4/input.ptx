.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd15, %r3, %r3;
    shl.b32 %r9, %r3, 1;
    setp.lt.u32 %p4, %r9, %r9;
    add.s64 %rd5, %rd15, %rd15;
    mul.lo.u64 %rd11, %rd5, %rd5;
    min.u32 %r10, %r3, %r3;
    shr.u64 %rd13, %rd15, 62;
    shr.s32 %r17, %r9, 2;
    max.s32 %r15, %r9, %r10;
    mul.lo.s32 %r4, %r9, %r15;
    cvt.s64.s32 %rd11, %r15;
    shr.u64 %rd14, %rd13, 3;
    min.s32 %r21, %r3, %r3;
    or.b32 %r24, %r10, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
