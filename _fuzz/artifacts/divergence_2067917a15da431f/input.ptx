.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd15, %r3, %r3;
    sub.s32 %r23, %r3, 32;
    mul.lo.u32 %r13, %r3, 65535;
    cvt.u64.u32 %rd12, %r3;
    shr.u32 %r20, %r3, 0;
    max.u64 %rd9, %rd12, %rd15;
    mul.lo.u64 %rd10, %rd9, %rd15;
    shr.u32 %r16, %r13, 2;
    mul.wide.s32 %rd6, %r3, %r23;
    shr.u64 %rd14, %rd9, 30;
    shl.b64 %rd8, %rd12, 1;
    mad.lo.u32 %r9, %r20, %r20, %r20;
    setp.le.s32 %p3, %r16, 32;
    @%p3 shr.u32 %r24, %r16, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
