    cvt.u64.u32 %rd13, %r9;
    max.s32 %r20, %r9, 0;
    setp.ne.s32 %p1, %r20, 2147483648;
    setp.lt.u32 %p2, %r14, 255;
    sub.s32 %r8, %r20, %r20;
    min.u32 %r8, %r8, %r14;
    mul.wide.u32 %rd9, %r22, %r9;
    min.s32 %r20, %r22, 7;
    shr.s64 %rd12, %rd9, 63;
