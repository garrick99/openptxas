.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r26, %r3, 256;
    add.s32 %r24, %r3, %r26;
    cvt.u64.u32 %rd13, %r26;
    shr.u64 %rd8, %rd13, 7;
    setp.ne.u32 %p1, %r26, 63;
    max.s32 %r16, %r26, %r26;
    shl.b64 %rd15, %rd13, 16;
    selp.b32 %r8, %r24, %r16, %p1;
    mad.lo.u32 %r4, %r8, %r16, %r24;
    shr.s64 %rd9, %rd8, 30;
    mad.lo.u32 %r12, %r24, %r26, %r26;
    min.u32 %r8, %r4, 7;
    mul.wide.u32 %rd6, %r8, %r12;
    or.b64 %rd9, %rd6, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
