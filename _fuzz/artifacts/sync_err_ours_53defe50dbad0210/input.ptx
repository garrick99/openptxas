.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r21, %r3, 31;
    sub.s32 %r20, %r3, %r21;
    mul.wide.u32 %rd13, %r20, %r20;
    xor.b64 %rd13, %rd13, %rd13;
    mad.lo.u32 %r8, %r3, %r20, %r20;
    shl.b32 %r16, %r21, 3;
    cvt.s64.s32 %rd8, %r21;
    shl.b64 %rd14, %rd8, 33;
    mul.wide.u32 %rd8, %r3, %r20;
    mad.lo.u32 %r20, %r16, %r3, %r21;
    xor.b32 %r20, %r21, %r20;
    add.s32 %r18, %r20, 256;
    add.s32 %r27, %r18, 31;
    cvt.u64.u32 %rd8, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
