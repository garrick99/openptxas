.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd13, %r3, %r3;
    cvt.s64.s32 %rd6, %r3;
    shl.b64 %rd7, %rd6, 16;
    xor.b32 %r25, %r3, %r3;
    mad.lo.u32 %r22, %r25, %r25, %r25;
    sub.u32 %r12, %r25, %r22;
    max.s64 %rd12, %rd13, %rd6;
    mul.lo.u64 %rd7, %rd6, %rd12;
    cvt.s64.s32 %rd11, %r12;
    mad.lo.s32 %r17, %r3, %r25, %r25;
    shr.u32 %r16, %r17, 3;
    shr.u32 %r9, %r3, 15;
    or.b32 %r14, %r3, %r16;
    setp.eq.s32 %p4, %r17, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
