.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r11, %r3, 7;
    shl.b32 %r7, %r11, 4;
    sub.u32 %r9, %r7, %r11;
    or.b32 %r18, %r7, 0;
    cvt.s64.s32 %rd10, %r11;
    sub.u32 %r15, %r9, 16;
    shr.s32 %r23, %r18, 7;
    mad.lo.u32 %r13, %r9, %r15, %r18;
    sub.u64 %rd13, %rd10, %rd10;
    sub.s64 %rd14, %rd13, %rd13;
    shr.s32 %r9, %r9, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
