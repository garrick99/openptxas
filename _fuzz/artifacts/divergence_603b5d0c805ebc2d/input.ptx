.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r7, %r3, 2147483647;
    add.s32 %r8, %r7, 255;
    sub.u32 %r14, %r8, 31;
    shl.b32 %r13, %r3, 31;
    cvt.u64.u32 %rd14, %r13;
    max.s64 %rd12, %rd14, %rd14;
    mul.lo.s32 %r18, %r7, 7;
    shr.s32 %r9, %r13, 2;
    add.s32 %r11, %r3, %r14;
    add.s32 %r6, %r7, 0;
    mad.lo.s32 %r16, %r14, %r11, %r7;
    or.b32 %r15, %r3, 8;
    max.s32 %r11, %r11, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
