.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r17, %r3, 16;
    cvt.u64.u32 %rd5, %r17;
    shl.b32 %r23, %r3, 16;
    setp.le.u32 %p1, %r17, %r3;
    @%p1 cvt.s32.s64 %r21, %rd5;
    max.s32 %r9, %r21, 65536;
    cvt.s32.s64 %r22, %rd5;
    sub.s64 %rd14, %rd5, %rd5;
    sub.u32 %r10, %r21, 2147483647;
    shr.s32 %r15, %r22, 15;
    shl.b64 %rd8, %rd14, 2;
    xor.b32 %r11, %r21, 32;
    shl.b32 %r5, %r9, 2;
    sub.s32 %r24, %r17, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
