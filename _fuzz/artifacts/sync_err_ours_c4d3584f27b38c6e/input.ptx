.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    mad.lo.u32 %r14, %r3, %r3, %r3;
    shr.s32 %r9, %r3, 7;
    setp.ge.s32 %p2, %r3, 64;
    @%p2 mul.lo.u32 %r23, %r14, %r9;
    mul.lo.u32 %r22, %r14, 31;
    min.s64 %rd13, %rd15, %rd15;
    or.b32 %r6, %r14, %r22;
    shr.s64 %rd15, %rd13, 15;
    and.b32 %r17, %r9, %r3;
    shl.b32 %r17, %r22, 7;
    sub.s64 %rd10, %rd13, %rd13;
    shl.b32 %r17, %r23, 7;
    and.b32 %r22, %r23, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
