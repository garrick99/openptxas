.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r6, %r3, %r3;
    mul.lo.u32 %r16, %r6, 2147483647;
    add.s32 %r15, %r6, %r6;
    cvt.u64.u32 %rd15, %r15;
    sub.s32 %r10, %r6, %r16;
    min.u32 %r21, %r3, %r15;
    mul.wide.u32 %rd13, %r10, %r16;
    cvt.u32.u64 %r11, %rd15;
    mul.wide.s32 %rd13, %r11, %r15;
    setp.ne.s32 %p1, %r3, %r15;
    setp.le.s32 %p4, %r11, %r11;
    @%p4 shl.b32 %r20, %r15, 1;
    add.s32 %r15, %r16, %r10;
    selp.b32 %r21, %r11, %r21, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
