.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p1, %r3, 8;
    @%p1 xor.b32 %r14, %r3, %r3;
    or.b32 %r10, %r14, 2;
    selp.b32 %r26, %r14, %r10, %p1;
    mul.wide.s32 %rd15, %r3, %r10;
    setp.le.u32 %p1, %r26, 4;
    @%p1 add.s32 %r17, %r3, %r14;
    mul.lo.s32 %r20, %r14, %r10;
    add.s32 %r15, %r14, %r17;
    max.s64 %rd5, %rd15, %rd15;
    mad.lo.s32 %r21, %r3, %r20, %r17;
    and.b32 %r13, %r14, %r21;
    mul.wide.s32 %rd5, %r13, %r21;
    shl.b64 %rd6, %rd5, 47;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
