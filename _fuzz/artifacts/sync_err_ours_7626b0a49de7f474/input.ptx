.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r10, %r3, 31;
    cvt.u64.u32 %rd5, %r3;
    sub.s32 %r15, %r10, 31;
    add.u32 %r15, %r15, %r3;
    xor.b32 %r4, %r15, 256;
    mul.lo.u32 %r19, %r10, 65535;
    min.s32 %r17, %r15, 65536;
    and.b32 %r11, %r15, 5;
    shl.b32 %r26, %r10, 15;
    mul.wide.s32 %rd13, %r4, %r26;
    min.u32 %r17, %r11, %r15;
    mul.lo.u32 %r17, %r26, 255;
    mad.lo.s32 %r23, %r26, %r15, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
