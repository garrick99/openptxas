.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r10, %r3, %r3;
    or.b32 %r16, %r3, %r10;
    setp.lt.u32 %p1, %r0, 16;
    vote.sync.ballot.b32 %r15, %p1, -1;
    shfl.sync.up.b32 %r10, %r16, 2, 0x1f, -1;
    shfl.sync.idx.b32 %r9, %r16, 15, 0x1f, -1;
    or.b32 %r12, %r10, %r3;
    shfl.sync.up.b32 %r6, %r12, 8, 0x1f, -1;
    min.u32 %r10, %r3, %r10;
    and.b32 %r18, %r10, %r6;
    setp.eq.u32 %p3, %r18, %r9;
    vote.sync.ballot.b32 %r4, %p3, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
