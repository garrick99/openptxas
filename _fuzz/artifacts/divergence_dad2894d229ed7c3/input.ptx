.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p3, %r3, %r3;
    @%p3 and.b32 %r13, %r3, 2;
    mad.lo.u32 %r27, %r13, %r13, %r3;
    mul.wide.s32 %rd14, %r3, %r13;
    mad.lo.u32 %r8, %r3, %r27, %r13;
    selp.b32 %r17, %r8, %r27, %p3;
    or.b64 %rd12, %rd14, %rd14;
    shr.s64 %rd14, %rd12, 0;
    setp.ge.s32 %p1, %r8, %r13;
    @!%p1 shr.u32 %r17, %r17, 16;
    add.u32 %r15, %r27, %r17;
    min.u32 %r25, %r17, %r17;
    sub.u32 %r7, %r15, 64;
    shl.b32 %r8, %r27, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
