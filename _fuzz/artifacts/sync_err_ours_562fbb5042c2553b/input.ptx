.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p4, %r3, 65536;
    @%p4 cvt.s64.s32 %rd13, %r3;
    add.s32 %r22, %r3, %r3;
    mul.lo.u32 %r21, %r22, 64;
    sub.u32 %r4, %r3, 64;
    add.s32 %r26, %r4, %r3;
    add.u32 %r18, %r4, %r3;
    max.s32 %r21, %r4, %r21;
    and.b64 %rd14, %rd13, %rd13;
    sub.u32 %r10, %r22, 65536;
    cvt.s32.s64 %r14, %rd13;
    add.u64 %rd8, %rd14, %rd13;
    or.b32 %r16, %r18, %r26;
    max.u32 %r24, %r18, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
