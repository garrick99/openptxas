.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd5, %r3, %r3;
    shr.s32 %r24, %r3, 30;
    setp.le.s32 %p1, %r3, 4294967295;
    min.u32 %r14, %r24, 2147483648;
    cvt.u64.u32 %rd9, %r3;
    max.s32 %r8, %r24, %r24;
    max.u32 %r23, %r14, %r14;
    mul.wide.u32 %rd12, %r3, %r8;
    and.b32 %r14, %r8, %r23;
    max.s32 %r26, %r24, 256;
    cvt.u32.u64 %r16, %rd9;
    max.s64 %rd14, %rd9, %rd5;
    max.u32 %r14, %r3, 31;
    shl.b64 %rd15, %rd5, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
