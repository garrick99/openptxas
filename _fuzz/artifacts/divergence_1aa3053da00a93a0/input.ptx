.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r6, %r3, %r3;
    xor.b32 %r6, %r3, 65535;
    cvt.u64.u32 %rd7, %r3;
    shl.b64 %rd11, %rd7, 63;
    sub.u32 %r14, %r3, 65535;
    mul.lo.u32 %r24, %r3, 65535;
    sub.s64 %rd11, %rd7, %rd7;
    sub.s32 %r9, %r24, %r3;
    shl.b32 %r20, %r6, 3;
    cvt.u64.u32 %rd9, %r6;
    shr.s32 %r16, %r20, 2;
    min.u64 %rd5, %rd9, %rd9;
    and.b32 %r7, %r14, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
