.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r7, %r3, 3;
    cvt.s64.s32 %rd13, %r7;
    mad.lo.u32 %r15, %r7, %r7, %r7;
    xor.b32 %r25, %r7, 16;
    add.u32 %r4, %r25, %r25;
    cvt.s32.s64 %r27, %rd13;
    shr.u64 %rd7, %rd13, 4;
    setp.eq.u32 %p4, %r4, %r4;
    cvt.s64.s32 %rd7, %r25;
    min.s64 %rd13, %rd13, %rd13;
    cvt.u32.u64 %r4, %rd7;
    mad.lo.u32 %r7, %r4, %r7, %r15;
    setp.ls.u32 %p2, %r4, 63;
    @!%p2 shr.u32 %r27, %r15, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
