.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r19, %r3, 256;
    mul.wide.s32 %rd14, %r19, %r19;
    add.s64 %rd7, %rd14, %rd14;
    sub.u32 %r17, %r3, 2;
    xor.b32 %r22, %r19, %r17;
    mul.lo.s32 %r6, %r22, 4;
    cvt.u32.u64 %r18, %rd7;
    sub.u32 %r25, %r22, %r19;
    add.u32 %r14, %r3, %r18;
    min.u32 %r18, %r19, %r17;
    shl.b32 %r23, %r14, 1;
    mul.lo.s32 %r25, %r17, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
