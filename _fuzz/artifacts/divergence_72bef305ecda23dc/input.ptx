.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r16, %r3, 15;
    sub.s32 %r20, %r3, 7;
    mul.lo.s32 %r26, %r3, 5;
    max.s32 %r5, %r26, 64;
    shr.u32 %r24, %r26, 7;
    mad.lo.s32 %r19, %r20, %r24, %r5;
    shr.u32 %r16, %r19, 30;
    or.b32 %r14, %r24, 0;
    xor.b32 %r19, %r20, 4294967295;
    max.u32 %r4, %r14, %r19;
    min.s32 %r19, %r5, %r4;
    cvt.u64.u32 %rd7, %r16;
    shl.b64 %rd10, %rd7, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
