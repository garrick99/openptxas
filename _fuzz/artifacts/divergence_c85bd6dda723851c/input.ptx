.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    cvt.s64.s32 %rd9, %r3;
    xor.b64 %rd5, %rd12, %rd12;
    mul.lo.u32 %r20, %r3, %r3;
    add.s32 %r7, %r20, %r20;
    cvt.s64.s32 %rd13, %r20;
    shr.u64 %rd9, %rd12, 3;
    max.u32 %r5, %r7, 2;
    mad.lo.s32 %r6, %r3, %r20, %r20;
    add.u32 %r6, %r20, 63;
    sub.s32 %r27, %r7, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
