.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r26, %r3, %r3;
    setp.ne.u32 %p3, %r3, %r3;
    @%p3 add.u32 %r19, %r26, %r26;
    cvt.u64.u32 %rd12, %r26;
    mad.lo.u32 %r27, %r26, %r3, %r3;
    sub.u32 %r4, %r19, %r27;
    setp.ge.u32 %p4, %r4, 1;
    @!%p4 shr.u32 %r20, %r3, 3;
    cvt.s32.s64 %r4, %rd12;
    min.u32 %r7, %r4, 31;
    sub.u32 %r23, %r20, 2;
    or.b32 %r6, %r3, 65535;
    shl.b32 %r26, %r3, 0;
    max.u32 %r26, %r6, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
