.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd14, %r3, %r3;
    min.u64 %rd11, %rd14, %rd14;
    cvt.s32.s64 %r4, %rd14;
    add.s64 %rd10, %rd11, %rd11;
    add.u32 %r4, %r3, %r4;
    max.s64 %rd7, %rd14, %rd14;
    mad.lo.u32 %r12, %r4, %r4, %r4;
    max.s32 %r11, %r12, 4;
    sub.s64 %rd9, %rd11, %rd11;
    setp.lt.s32 %p4, %r11, 64;
    @!%p4 add.s32 %r16, %r4, %r3;
    mul.lo.s32 %r19, %r12, 255;
    shr.u32 %r17, %r4, 15;
    add.u32 %r17, %r11, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
