.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r14, %r3, 3;
    setp.eq.s32 %p4, %r3, %r14;
    @!%p4 shl.b32 %r7, %r3, 30;
    max.s32 %r21, %r7, %r14;
    shl.b32 %r7, %r21, 3;
    or.b32 %r4, %r7, %r14;
    mad.lo.u32 %r15, %r21, %r14, %r21;
    setp.le.u32 %p2, %r14, %r4;
    @%p2 cvt.u64.u32 %rd12, %r3;
    setp.ne.s32 %p4, %r7, %r21;
    @%p4 min.u32 %r13, %r21, 31;
    setp.gt.s32 %p1, %r13, %r13;
    and.b32 %r27, %r21, 31;
    selp.b32 %r17, %r4, %r3, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
