.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    or.b32 %r9, %r3, %r3;
    mul.lo.s32 %r7, %r3, 32;
    setp.le.u32 %p3, %r9, 64;
    @%p3 selp.b32 %r12, %r7, %r9, %p3;
    mul.wide.u32 %rd5, %r3, %r12;
    mul.wide.s32 %rd14, %r7, %r3;
    sub.u32 %r25, %r12, 16;
    min.u32 %r25, %r9, %r9;
    sub.u32 %r23, %r9, 64;
    sub.s32 %r14, %r23, 65536;
    sub.s32 %r16, %r9, %r3;
    max.s64 %rd5, %rd14, %rd14;
    mul.lo.u32 %r14, %r12, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
