.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r7, %r3, %r3;
    shr.s32 %r9, %r3, 16;
    cvt.s64.s32 %rd15, %r9;
    shl.b64 %rd10, %rd15, 2;
    setp.eq.s32 %p3, %r3, 255;
    @%p3 mul.wide.s32 %rd13, %r9, %r9;
    mul.lo.u64 %rd6, %rd15, %rd10;
    shr.u32 %r5, %r9, 16;
    mad.lo.s32 %r13, %r5, %r7, %r5;
    mad.lo.s32 %r10, %r9, %r3, %r9;
    mul.lo.u32 %r14, %r10, 1;
    cvt.s64.s32 %rd11, %r13;
    max.s64 %rd8, %rd6, %rd13;
    shr.u64 %rd7, %rd15, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
