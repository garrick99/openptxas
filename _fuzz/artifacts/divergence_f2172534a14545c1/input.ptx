.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p4, %r3, %r3;
    @%p4 add.s32 %r14, %r3, %r3;
    cvt.s64.s32 %rd9, %r14;
    sub.s32 %r16, %r14, %r3;
    max.s64 %rd9, %rd9, %rd9;
    max.u64 %rd5, %rd9, %rd9;
    cvt.s32.s64 %r11, %rd5;
    setp.gt.s32 %p1, %r11, 3;
    mul.lo.u32 %r7, %r16, 65535;
    shr.u64 %rd13, %rd5, 0;
    max.u32 %r17, %r16, %r14;
    mad.lo.u32 %r20, %r3, %r14, %r11;
    mul.lo.u32 %r19, %r3, %r14;
    shl.b64 %rd9, %rd9, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
