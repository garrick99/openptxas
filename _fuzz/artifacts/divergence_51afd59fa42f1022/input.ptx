.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r20, %r3, %r3;
    or.b32 %r27, %r20, %r20;
    mul.lo.s32 %r4, %r27, 4294967295;
    or.b32 %r18, %r4, %r3;
    setp.lt.s32 %p1, %r4, 64;
    @%p1 cvt.s64.s32 %rd8, %r20;
    max.s32 %r16, %r27, %r3;
    sub.u64 %rd13, %rd8, %rd8;
    setp.ge.s32 %p3, %r16, 65535;
    @%p3 mad.lo.s32 %r8, %r27, %r18, %r20;
    and.b64 %rd7, %rd8, %rd8;
    mul.wide.s32 %rd11, %r20, %r20;
    mul.lo.u32 %r18, %r18, 4294967295;
    max.u32 %r26, %r18, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
