    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r4, %r3, %r3;
    mad.lo.u32 %r18, %r4, %r4, %r3;
    max.u32 %r9, %r3, %r18;
    setp.lt.u32 %p1, %r18, 2147483647;
    @%p1 cvt.s64.s32 %rd13, %r9;
    cvt.u64.u32 %rd9, %r18;
    add.s64 %rd11, %rd13, %rd9;
    max.s32 %r11, %r9, %r4;
    and.b64 %rd12, %rd9, %rd9;
    selp.b32 %r13, %r3, %r3, %p1;
    max.u32 %r7, %r3, %r3;
    shr.s64 %rd14, %rd12, 2;
