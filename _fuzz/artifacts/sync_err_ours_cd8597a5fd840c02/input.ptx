.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r11, %r3, %r3;
    add.s32 %r6, %r11, 16;
    setp.eq.u32 %p4, %r11, 7;
    @%p4 xor.b32 %r25, %r6, 2147483648;
    shr.s32 %r14, %r6, 16;
    sub.u32 %r22, %r25, %r6;
    sub.u32 %r20, %r3, %r11;
    or.b32 %r23, %r20, %r25;
    mul.wide.u32 %rd11, %r23, %r20;
    selp.b32 %r13, %r25, %r14, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
