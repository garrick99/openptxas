.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    cvt.s64.s32 %rd13, %r3;
    max.s32 %r8, %r3, %r3;
    setp.eq.s32 %p4, %r8, 255;
    @%p4 cvt.u32.u64 %r16, %rd13;
    sub.u32 %r14, %r8, 4;
    xor.b32 %r6, %r16, %r16;
    add.s32 %r8, %r6, %r6;
    shr.s32 %r9, %r16, 16;
    setp.le.s32 %p2, %r3, %r14;
    shl.b32 %r24, %r3, 31;
    min.u64 %rd7, %rd13, %rd13;
    mad.lo.u32 %r17, %r3, %r8, %r9;
    min.u32 %r18, %r8, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
