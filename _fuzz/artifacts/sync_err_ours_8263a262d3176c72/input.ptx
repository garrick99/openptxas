.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    add.u32 %r27, %r3, %r3;
    shr.s32 %r4, %r27, 0;
    or.b32 %r15, %r4, %r3;
    min.s64 %rd5, %rd9, %rd9;
    cvt.s32.s64 %r6, %rd5;
    mul.wide.s32 %rd10, %r3, %r4;
    mad.lo.u32 %r21, %r4, %r6, %r27;
    max.s32 %r24, %r27, %r27;
    mul.wide.s32 %rd10, %r3, %r15;
    shr.u32 %r13, %r21, 31;
    add.u64 %rd9, %rd10, %rd5;
    sub.s64 %rd9, %rd5, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
