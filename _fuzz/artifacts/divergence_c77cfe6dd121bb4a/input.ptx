    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r13, %r3, %r3;
    cvt.s64.s32 %rd10, %r13;
    mul.lo.u32 %r26, %r3, 255;
    min.s64 %rd14, %rd10, %rd10;
    shr.s64 %rd6, %rd10, 31;
    or.b32 %r20, %r3, %r13;
    sub.s64 %rd13, %rd10, %rd10;
    and.b32 %r19, %r13, 2147483648;
    sub.s32 %r11, %r20, 256;
    mul.lo.s32 %r14, %r19, %r20;
    shr.s32 %r22, %r19, 15;
    mul.lo.u32 %r25, %r19, %r22;
    sub.s32 %r18, %r26, 63;
    max.u32 %r27, %r22, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
