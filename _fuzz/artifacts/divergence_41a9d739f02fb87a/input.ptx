.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd11, %r3, %r3;
    mul.lo.u64 %rd13, %rd11, %rd11;
    cvt.s32.s64 %r6, %rd13;
    setp.hi.u32 %p4, %r3, 255;
    setp.hs.u32 %p1, %r3, %r6;
    or.b32 %r4, %r3, 256;
    xor.b64 %rd15, %rd13, %rd13;
    max.s32 %r27, %r3, 7;
    cvt.s32.s64 %r12, %rd13;
    sub.u64 %rd15, %rd15, %rd11;
    add.u32 %r16, %r12, 8;
    mul.lo.s32 %r22, %r3, %r27;
    shr.s32 %r22, %r4, 15;
    selp.b32 %r27, %r27, %r4, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
