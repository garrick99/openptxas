    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r7, %r3, 30;
    add.s32 %r6, %r7, 63;
    setp.le.s32 %p2, %r7, %r7;
    setp.lo.u32 %p1, %r6, 63;
    add.u32 %r9, %r6, 65536;
    shr.s32 %r11, %r6, 2;
    shl.b32 %r11, %r3, 2;
    sub.s32 %r8, %r3, 31;
    add.u32 %r10, %r3, 2147483647;
    add.s32 %r27, %r9, %r11;
    setp.gt.s32 %p2, %r27, 4;
    mad.lo.u32 %r10, %r9, %r10, %r6;
    cvt.s64.s32 %rd11, %r8;
