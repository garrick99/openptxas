.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    add.u64 %rd11, %rd15, %rd15;
    cvt.u32.u64 %r22, %rd15;
    sub.u32 %r21, %r3, 1;
    sub.s64 %rd10, %rd15, %rd15;
    add.u32 %r25, %r22, 31;
    shr.u32 %r27, %r22, 4;
    mul.lo.s32 %r20, %r27, 5;
    mad.lo.s32 %r25, %r21, %r27, %r20;
    mul.wide.u32 %rd9, %r21, %r22;
    shl.b32 %r19, %r27, 15;
    shl.b32 %r16, %r25, 1;
    mul.wide.u32 %rd7, %r27, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
