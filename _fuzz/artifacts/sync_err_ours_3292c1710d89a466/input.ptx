.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r11, %r3, 2;
    min.u32 %r11, %r3, %r3;
    cvt.s64.s32 %rd12, %r3;
    mul.wide.u32 %rd11, %r3, %r11;
    shl.b32 %r25, %r11, 1;
    shl.b64 %rd13, %rd11, 2;
    mul.lo.s32 %r14, %r3, %r25;
    xor.b32 %r22, %r14, %r25;
    mad.lo.u32 %r24, %r14, %r22, %r22;
    setp.ne.s32 %p3, %r22, 64;
    sub.u32 %r18, %r22, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
