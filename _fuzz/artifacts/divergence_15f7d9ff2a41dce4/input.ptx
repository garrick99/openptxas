.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r4, %r3, %r3;
    shl.b32 %r25, %r4, 0;
    min.s32 %r18, %r25, %r25;
    sub.u32 %r4, %r18, %r18;
    setp.ne.s32 %p2, %r18, 15;
    setp.ge.s32 %p2, %r25, %r4;
    @%p2 cvt.s64.s32 %rd14, %r18;
    mul.wide.u32 %rd8, %r18, %r4;
    max.s32 %r24, %r18, 7;
    and.b32 %r7, %r4, 5;
    setp.lt.u32 %p3, %r18, 8;
    @!%p3 mul.lo.s32 %r5, %r4, 31;
    mul.lo.u32 %r24, %r3, 2147483647;
    max.u32 %r13, %r3, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
