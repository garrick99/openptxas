.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r27, %r3, %r3;
    max.s32 %r22, %r27, 7;
    min.s32 %r14, %r27, 1;
    xor.b32 %r5, %r3, %r14;
    shl.b32 %r13, %r22, 16;
    or.b32 %r25, %r22, %r3;
    mul.wide.s32 %rd9, %r5, %r3;
    cvt.s32.s64 %r8, %rd9;
    xor.b32 %r15, %r27, %r22;
    shr.s32 %r4, %r27, 30;
    shl.b32 %r8, %r25, 1;
    setp.hi.u32 %p4, %r14, 0;
    setp.lt.s32 %p4, %r5, %r4;
    @!%p4 mul.lo.s32 %r4, %r13, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
