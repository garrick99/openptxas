.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd10, %r3, %r3;
    and.b64 %rd15, %rd10, %rd10;
    min.s32 %r15, %r3, 65535;
    max.s32 %r24, %r3, 65536;
    mul.lo.u32 %r15, %r24, %r15;
    shl.b32 %r8, %r24, 2;
    cvt.u32.u64 %r18, %rd10;
    mul.lo.u32 %r12, %r15, %r3;
    max.s32 %r5, %r24, %r12;
    setp.lo.u32 %p1, %r18, %r3;
    @%p1 cvt.u32.u64 %r13, %rd10;
    max.u32 %r12, %r8, 3;
    mul.lo.u32 %r7, %r13, 4;
    shl.b64 %rd5, %rd10, 47;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
