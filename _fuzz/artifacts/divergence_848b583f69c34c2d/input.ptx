.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r9, %r3, 7;
    setp.ne.u32 %p2, %r3, %r9;
    @!%p2 cvt.u64.u32 %rd10, %r9;
    mul.lo.s32 %r24, %r3, %r3;
    setp.lt.u32 %p2, %r9, 65536;
    @%p2 cvt.s32.s64 %r6, %rd10;
    xor.b32 %r17, %r9, %r24;
    cvt.s32.s64 %r17, %rd10;
    min.u32 %r18, %r17, %r24;
    cvt.s32.s64 %r16, %rd10;
    max.s32 %r16, %r17, %r3;
    mad.lo.u32 %r20, %r3, %r16, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
