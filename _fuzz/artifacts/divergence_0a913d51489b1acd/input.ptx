.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    cvt.u32.u64 %r15, %rd11;
    cvt.s32.s64 %r7, %rd11;
    xor.b32 %r5, %r3, %r3;
    add.s32 %r11, %r5, %r3;
    setp.eq.s32 %p1, %r5, %r11;
    @%p1 add.s32 %r5, %r5, %r11;
    xor.b32 %r15, %r7, 0;
    mul.lo.u32 %r13, %r5, %r7;
    or.b32 %r16, %r7, 63;
    max.u64 %rd12, %rd11, %rd11;
    selp.b32 %r10, %r15, %r13, %p1;
    or.b32 %r23, %r5, %r10;
    mul.lo.u32 %r12, %r10, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
