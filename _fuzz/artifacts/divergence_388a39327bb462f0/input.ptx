.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p4, %r3, %r3;
    add.s32 %r13, %r3, 65536;
    sub.u32 %r13, %r3, %r13;
    min.s32 %r7, %r13, 8;
    selp.b32 %r8, %r3, %r7, %p4;
    setp.lt.s32 %p4, %r13, %r8;
    @%p4 mad.lo.u32 %r12, %r8, %r3, %r3;
    selp.b32 %r18, %r8, %r12, %p4;
    shl.b32 %r12, %r18, 2;
    selp.b32 %r21, %r13, %r8, %p4;
    mul.wide.s32 %rd11, %r21, %r8;
    mul.lo.u32 %r14, %r7, %r3;
    shr.u32 %r8, %r18, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
