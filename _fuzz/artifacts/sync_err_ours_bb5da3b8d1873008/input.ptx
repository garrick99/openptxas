.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    shr.s64 %rd10, %rd15, 3;
    max.s64 %rd12, %rd15, %rd10;
    shl.b64 %rd7, %rd10, 7;
    sub.s32 %r17, %r3, 32;
    max.u32 %r25, %r3, %r3;
    setp.gt.s32 %p2, %r25, 2147483647;
    @!%p2 sub.u32 %r24, %r25, %r25;
    mul.wide.s32 %rd10, %r25, %r17;
    shl.b32 %r14, %r24, 7;
    setp.eq.u32 %p2, %r25, %r25;
    shr.u64 %rd11, %rd7, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
