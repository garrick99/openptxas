.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r26, %r3, %r3;
    shr.u32 %r27, %r3, 15;
    cvt.s64.s32 %rd15, %r3;
    mul.wide.s32 %rd10, %r26, %r27;
    mul.lo.u64 %rd6, %rd15, %rd10;
    add.u32 %r17, %r3, %r3;
    mul.wide.u32 %rd11, %r17, %r3;
    shl.b64 %rd10, %rd6, 0;
    add.s32 %r14, %r3, 63;
    and.b32 %r11, %r17, %r14;
    shr.u64 %rd11, %rd6, 15;
    shr.u64 %rd8, %rd15, 33;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
