.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd10, %r3, %r3;
    add.s32 %r25, %r3, %r3;
    mul.wide.s32 %rd10, %r3, %r3;
    add.u32 %r13, %r3, %r3;
    mul.wide.u32 %rd5, %r13, %r13;
    xor.b64 %rd7, %rd5, %rd10;
    sub.s32 %r24, %r13, 2147483647;
    shr.s32 %r4, %r25, 7;
    shr.u64 %rd10, %rd10, 33;
    mul.wide.u32 %rd11, %r3, %r13;
    setp.lt.u32 %p2, %r24, %r24;
    @%p2 mul.lo.u32 %r4, %r24, %r24;
    or.b32 %r25, %r13, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
