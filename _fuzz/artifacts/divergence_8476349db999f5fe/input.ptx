.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r9, %r3, %r3;
    sub.s32 %r6, %r9, 255;
    min.u32 %r24, %r9, %r3;
    or.b32 %r16, %r9, 64;
    cvt.s64.s32 %rd14, %r9;
    shl.b64 %rd9, %rd14, 1;
    setp.ne.s32 %p4, %r3, 16;
    @!%p4 cvt.s32.s64 %r20, %rd9;
    max.u32 %r23, %r20, 32;
    min.s32 %r23, %r16, %r6;
    cvt.s64.s32 %rd14, %r24;
    max.s32 %r5, %r23, 4294967295;
    setp.ne.u32 %p1, %r20, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
