.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    sub.u32 %r25, %r3, 65535;
    shr.u32 %r22, %r3, 16;
    min.u32 %r8, %r25, %r25;
    shl.b32 %r6, %r8, 16;
    min.u32 %r27, %r22, %r22;
    setp.hs.u32 %p2, %r8, %r8;
    @!%p2 shr.u32 %r21, %r25, 15;
    selp.b32 %r15, %r27, %r22, %p2;
    cvt.u64.u32 %rd8, %r6;
    setp.lt.u32 %p4, %r3, %r21;
    @%p4 cvt.s32.s64 %r24, %rd6;
    mul.lo.s32 %r27, %r8, %r22;
    selp.b32 %r25, %r24, %r8, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
