.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfi.b32 %r23, %r3, %r3, 8, 31;
    brev.b32 %r17, %r3;
    brev.b32 %r20, %r23;
    popc.b32 %r10, %r3;
    popc.b32 %r13, %r3;
    add.u32 %r16, %r20, %r17;
    popc.b32 %r19, %r3;
    and.b32 %r23, %r20, 15;
    bfi.b32 %r18, %r16, %r23, 24, 4;
    bfe.u32 %r16, %r23, 0, 1;
    bfe.u32 %r16, %r3, 16, 7;
    bfi.b32 %r21, %r3, %r19, 7, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
