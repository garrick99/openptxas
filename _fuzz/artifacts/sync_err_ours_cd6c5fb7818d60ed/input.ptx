.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    shr.u32 %r18, %r3, 0;
    xor.b64 %rd13, %rd6, %rd6;
    add.s64 %rd15, %rd6, %rd6;
    setp.gt.s32 %p2, %r3, 16;
    @!%p2 sub.u32 %r17, %r3, %r18;
    shr.s32 %r16, %r18, 7;
    add.s32 %r7, %r16, %r18;
    shr.u32 %r6, %r18, 16;
    cvt.s64.s32 %rd7, %r3;
    sub.u64 %rd10, %rd13, %rd7;
    add.u64 %rd10, %rd13, %rd6;
    shr.u64 %rd12, %rd13, 3;
    mul.lo.s32 %r25, %r17, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
