    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p3, %r3, 65535;
    @%p3 add.s32 %r9, %r3, 63;
    cvt.u64.u32 %rd5, %r3;
    shl.b32 %r27, %r9, 7;
    setp.le.s32 %p2, %r3, 2147483647;
    @%p2 shr.s64 %rd12, %rd5, 62;
    cvt.u64.u32 %rd8, %r9;
    xor.b64 %rd14, %rd12, %rd12;
