.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r25, %r3, 65536;
    shr.u32 %r9, %r25, 15;
    max.u32 %r6, %r3, %r25;
    cvt.s64.s32 %rd14, %r25;
    sub.u32 %r20, %r3, %r9;
    min.u32 %r9, %r3, %r9;
    xor.b32 %r26, %r6, 4;
    max.s64 %rd14, %rd14, %rd14;
    shl.b32 %r5, %r25, 30;
    min.s64 %rd14, %rd14, %rd14;
    mul.lo.s64 %rd11, %rd14, %rd14;
    shr.u64 %rd15, %rd14, 62;
    min.s32 %r27, %r9, 64;
    mul.lo.s32 %r17, %r26, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
