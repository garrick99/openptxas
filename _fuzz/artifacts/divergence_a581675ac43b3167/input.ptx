.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r5, %r3, %r3;
    shr.u32 %r4, %r3, 31;
    cvt.s64.s32 %rd11, %r3;
    mul.lo.s32 %r22, %r5, 15;
    shr.u32 %r11, %r4, 4;
    mul.lo.s32 %r19, %r22, %r3;
    setp.gt.u32 %p1, %r11, 0;
    @%p1 sub.u64 %rd7, %rd11, %rd11;
    cvt.u64.u32 %rd5, %r22;
    selp.b32 %r26, %r19, %r22, %p1;
    min.u64 %rd15, %rd11, %rd5;
    or.b32 %r16, %r11, %r4;
    cvt.s64.s32 %rd12, %r3;
    max.u32 %r11, %r22, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
