.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    cvt.s32.s64 %r23, %rd13;
    shr.u64 %rd6, %rd13, 1;
    max.s32 %r5, %r3, 1;
    sub.u64 %rd6, %rd13, %rd13;
    setp.hs.u32 %p2, %r5, %r3;
    @%p2 mul.lo.u32 %r20, %r23, 8;
    min.s64 %rd13, %rd6, %rd6;
    add.s32 %r16, %r20, 255;
    min.s64 %rd13, %rd6, %rd6;
    mul.lo.s32 %r6, %r3, %r5;
    mad.lo.s32 %r16, %r6, %r5, %r3;
    and.b32 %r12, %r20, 65536;
    xor.b32 %r21, %r20, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
