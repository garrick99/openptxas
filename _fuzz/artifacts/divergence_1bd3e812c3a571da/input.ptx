.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r17, %r3, %r3;
    and.b32 %r9, %r3, %r17;
    mul.lo.s32 %r26, %r9, %r17;
    max.u32 %r7, %r26, %r17;
    and.b32 %r23, %r9, %r26;
    max.s32 %r24, %r3, %r7;
    cvt.u64.u32 %rd6, %r24;
    mul.wide.s32 %rd10, %r24, %r9;
    shl.b32 %r5, %r7, 0;
    add.s32 %r9, %r24, 65536;
    max.s32 %r25, %r9, %r23;
    max.u32 %r12, %r5, %r7;
    setp.le.u32 %p1, %r12, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
