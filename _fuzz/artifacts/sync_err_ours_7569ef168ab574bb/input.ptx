.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r5, %r3, 64;
    shl.b32 %r18, %r3, 7;
    and.b32 %r4, %r3, %r18;
    sub.s32 %r21, %r18, %r5;
    cvt.u64.u32 %rd14, %r18;
    setp.le.u32 %p2, %r18, 63;
    @%p2 add.u32 %r17, %r3, 32;
    add.s64 %rd12, %rd14, %rd14;
    add.u32 %r17, %r17, %r3;
    min.u32 %r23, %r5, 64;
    sub.u32 %r24, %r18, 65536;
    shr.s32 %r27, %r24, 7;
    or.b32 %r8, %r4, %r3;
    shr.u32 %r11, %r27, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
