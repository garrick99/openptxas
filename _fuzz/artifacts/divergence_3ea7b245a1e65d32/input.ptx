.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r23, %r3, 32;
    mul.lo.s32 %r20, %r23, %r3;
    shl.b32 %r5, %r23, 2;
    or.b32 %r16, %r20, 1;
    min.s32 %r27, %r5, 16;
    cvt.s64.s32 %rd15, %r20;
    xor.b32 %r11, %r16, %r27;
    min.s32 %r10, %r5, 2147483648;
    shr.u32 %r5, %r11, 4;
    sub.u32 %r16, %r11, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
