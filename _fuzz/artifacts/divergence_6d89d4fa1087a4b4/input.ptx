.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r15, %r3, %r3;
    mul.wide.s32 %rd5, %r15, %r15;
    mul.lo.s32 %r13, %r15, %r3;
    or.b32 %r13, %r15, 256;
    sub.s64 %rd8, %rd5, %rd5;
    add.u64 %rd7, %rd8, %rd8;
    min.s32 %r26, %r3, 16;
    setp.lt.s32 %p2, %r26, %r3;
    @%p2 min.s32 %r13, %r26, %r26;
    selp.b32 %r17, %r3, %r26, %p2;
    mul.lo.u32 %r17, %r26, %r13;
    setp.hi.u32 %p1, %r13, 1;
    mul.wide.u32 %rd6, %r13, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
