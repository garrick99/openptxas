.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    shr.s32 %r16, %r3, 2;
    setp.ge.u32 %p1, %r3, 65536;
    @%p1 and.b32 %r26, %r3, %r16;
    add.u32 %r10, %r3, %r16;
    and.b32 %r4, %r3, %r10;
    shr.u64 %rd8, %rd7, 4;
    max.u32 %r20, %r3, %r26;
    cvt.u64.u32 %rd13, %r20;
    min.u32 %r16, %r4, %r20;
    sub.u32 %r6, %r20, 63;
    shl.b32 %r15, %r4, 3;
    sub.s32 %r14, %r16, 15;
    min.s32 %r19, %r14, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
