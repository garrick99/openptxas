.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r7, %r3, %r3;
    setp.ge.s32 %p3, %r3, %r7;
    @%p3 sub.s32 %r7, %r3, %r7;
    cvt.s64.s32 %rd9, %r7;
    or.b32 %r7, %r7, %r3;
    setp.eq.s32 %p3, %r7, 256;
    @%p3 sub.u32 %r12, %r7, 3;
    or.b32 %r13, %r7, 16;
    mul.wide.s32 %rd6, %r13, %r3;
    mul.lo.s64 %rd11, %rd6, %rd9;
    setp.ne.s32 %p3, %r12, %r12;
    min.s64 %rd6, %rd6, %rd11;
    shr.s32 %r18, %r13, 16;
    or.b32 %r26, %r12, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
