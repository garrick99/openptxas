.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r18, %r3, 2;
    cvt.u64.u32 %rd10, %r18;
    or.b64 %rd5, %rd10, %rd10;
    mul.lo.s64 %rd10, %rd5, %rd5;
    setp.ls.u32 %p4, %r3, 7;
    @%p4 cvt.s32.s64 %r11, %rd10;
    max.s32 %r12, %r11, %r11;
    shr.u32 %r21, %r11, 0;
    shl.b64 %rd7, %rd5, 48;
    mul.lo.s32 %r13, %r21, %r18;
    sub.s32 %r21, %r18, 255;
    shl.b64 %rd6, %rd7, 63;
    add.s32 %r9, %r11, 1;
    setp.le.u32 %p4, %r18, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
