.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r21, %r3, 32;
    and.b32 %r24, %r21, 2147483648;
    and.b32 %r26, %r3, 64;
    max.u32 %r22, %r26, 2147483647;
    cvt.u64.u32 %rd5, %r24;
    and.b32 %r27, %r24, %r26;
    shr.s64 %rd7, %rd5, 15;
    mad.lo.u32 %r7, %r21, %r22, %r27;
    setp.ne.s32 %p3, %r26, 4;
    setp.lt.s32 %p4, %r21, %r22;
    @!%p4 cvt.u32.u64 %r25, %rd7;
    shr.s32 %r24, %r3, 2;
    max.s32 %r10, %r3, %r22;
    shr.s32 %r27, %r10, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
