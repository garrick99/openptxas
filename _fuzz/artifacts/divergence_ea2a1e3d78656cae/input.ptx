.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p3, %r3, %r3;
    setp.eq.u32 %p4, %r3, 32;
    @%p4 mul.lo.s32 %r17, %r3, %r3;
    max.s32 %r25, %r3, %r17;
    shl.b32 %r13, %r17, 0;
    mul.lo.s32 %r20, %r25, 16;
    add.u32 %r12, %r3, 15;
    cvt.u64.u32 %rd7, %r20;
    add.s32 %r13, %r25, %r3;
    cvt.s64.s32 %rd5, %r20;
    selp.b32 %r24, %r12, %r3, %p4;
    shr.u32 %r9, %r20, 0;
    mul.wide.u32 %rd11, %r25, %r24;
    shl.b64 %rd7, %rd5, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
