.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r21, %r3, %r3;
    mul.wide.u32 %rd15, %r3, %r21;
    mad.lo.u32 %r13, %r21, %r21, %r3;
    setp.lt.u32 %p2, %r21, 3;
    setp.lo.u32 %p4, %r21, 255;
    @!%p4 add.u32 %r7, %r13, %r21;
    mul.lo.u32 %r13, %r7, 7;
    sub.u32 %r18, %r7, %r7;
    mad.lo.s32 %r18, %r3, %r13, %r21;
    min.u64 %rd9, %rd15, %rd15;
    shl.b32 %r4, %r7, 0;
    min.s32 %r18, %r13, %r3;
    and.b64 %rd8, %rd9, %rd15;
    shl.b32 %r25, %r4, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
