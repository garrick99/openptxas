.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    mad.lo.u32 %r5, %r3, %r3, %r3;
    add.s64 %rd6, %rd6, %rd6;
    sub.s32 %r19, %r5, 4;
    mad.lo.u32 %r10, %r19, %r3, %r19;
    shr.u32 %r5, %r19, 0;
    mad.lo.s32 %r24, %r5, %r19, %r3;
    mad.lo.s32 %r12, %r3, %r5, %r24;
    shr.u32 %r5, %r10, 1;
    shr.s64 %rd11, %rd6, 16;
    mad.lo.s32 %r22, %r3, %r19, %r19;
    mul.lo.s32 %r22, %r5, 4294967295;
    cvt.s64.s32 %rd6, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
