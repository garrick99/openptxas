.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r16, %r3, 31;
    bfe.s32 %r4, %r16, 15, 31;
    bfe.s32 %r7, %r4, 4, 32;
    bfe.s32 %r7, %r16, 24, 2;
    bfe.s32 %r21, %r7, 16, 31;
    bfi.b32 %r8, %r21, %r3, 16, 32;
    bfi.b32 %r10, %r16, %r21, 7, 8;
    bfe.u32 %r21, %r7, 16, 31;
    prmt.b32 %r14, %r7, %r3, 0;
    bfe.s32 %r22, %r8, 16, 2;
    clz.b32 %r16, %r7;
    bfi.b32 %r10, %r21, %r4, 7, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
