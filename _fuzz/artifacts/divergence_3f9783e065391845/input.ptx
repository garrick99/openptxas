.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r21, %r3, %r3;
    mad.lo.u32 %r23, %r21, %r3, %r21;
    max.s32 %r13, %r23, %r23;
    and.b32 %r14, %r3, 255;
    sub.s32 %r16, %r14, 3;
    cvt.u64.u32 %rd14, %r13;
    add.u32 %r17, %r3, %r3;
    mul.lo.u64 %rd8, %rd14, %rd14;
    cvt.s64.s32 %rd7, %r21;
    shl.b32 %r4, %r14, 7;
    shr.u32 %r18, %r4, 0;
    min.u32 %r4, %r16, %r23;
    setp.lt.u32 %p4, %r13, %r17;
    @!%p4 add.s32 %r10, %r3, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
