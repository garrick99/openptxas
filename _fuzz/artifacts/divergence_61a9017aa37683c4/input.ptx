.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    shr.u32 %r25, %r3, 31;
    cvt.s64.s32 %rd12, %r25;
    or.b64 %rd10, %rd12, %rd7;
    sub.u64 %rd12, %rd10, %rd12;
    mul.lo.u32 %r11, %r25, 63;
    shl.b64 %rd12, %rd12, 15;
    mul.lo.s32 %r8, %r3, %r11;
    shr.s32 %r19, %r3, 7;
    setp.ls.u32 %p4, %r3, 65535;
    @!%p4 sub.u32 %r24, %r19, %r19;
    sub.u32 %r10, %r25, 5;
    mul.lo.s64 %rd7, %rd12, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
