.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p3, %r3, %r3;
    @%p3 add.s32 %r14, %r3, %r3;
    mad.lo.u32 %r21, %r3, %r14, %r14;
    shr.u32 %r23, %r14, 7;
    add.s32 %r9, %r14, %r23;
    xor.b32 %r18, %r21, %r3;
    mad.lo.u32 %r21, %r3, %r23, %r14;
    sub.u32 %r5, %r3, %r3;
    xor.b32 %r20, %r18, %r3;
    cvt.u64.u32 %rd14, %r5;
    sub.u32 %r19, %r20, %r3;
    cvt.s64.s32 %rd7, %r19;
    mul.wide.s32 %rd13, %r14, %r20;
    shr.u32 %r15, %r20, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
