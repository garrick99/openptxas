.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r8, %r3, 63;
    max.u32 %r24, %r3, 256;
    max.s32 %r27, %r3, 31;
    cvt.s64.s32 %rd5, %r3;
    add.u32 %r14, %r8, 15;
    cvt.u64.u32 %rd14, %r3;
    mul.wide.u32 %rd6, %r14, %r3;
    mad.lo.s32 %r19, %r3, %r3, %r24;
    add.s32 %r8, %r3, %r3;
    add.u32 %r19, %r19, %r14;
    shr.s64 %rd7, %rd6, 30;
    setp.ls.u32 %p4, %r3, 63;
    @!%p4 cvt.s32.s64 %r7, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
