.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r4, %r3, 31;
    add.u32 %r9, %r4, 4294967295;
    mul.lo.s32 %r25, %r9, %r9;
    add.s32 %r17, %r25, %r3;
    mul.lo.u32 %r13, %r4, 2147483648;
    cvt.s64.s32 %rd12, %r13;
    setp.eq.u32 %p4, %r9, %r3;
    @%p4 selp.b32 %r22, %r25, %r9, %p4;
    cvt.s64.s32 %rd8, %r13;
    mul.wide.u32 %rd14, %r17, %r13;
    cvt.s64.s32 %rd5, %r25;
    or.b32 %r23, %r13, 2;
    mul.wide.s32 %rd7, %r13, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
