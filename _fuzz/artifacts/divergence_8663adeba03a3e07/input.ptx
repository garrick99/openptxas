.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r9, %r3, 31;
    cvt.u64.u32 %rd12, %r9;
    xor.b32 %r9, %r3, %r3;
    shl.b64 %rd11, %rd12, 16;
    sub.u32 %r5, %r9, 3;
    setp.ge.s32 %p4, %r5, %r9;
    @!%p4 mul.lo.s32 %r17, %r5, %r5;
    selp.b32 %r4, %r9, %r17, %p4;
    sub.u32 %r13, %r4, %r9;
    shr.u32 %r18, %r13, 15;
    max.u32 %r24, %r13, %r3;
    mad.lo.u32 %r14, %r13, %r17, %r18;
    max.u32 %r23, %r9, 16;
    max.s64 %rd9, %rd12, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
