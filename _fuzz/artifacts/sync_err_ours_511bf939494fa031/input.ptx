.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r9, %r3, 31;
    max.u32 %r22, %r9, %r3;
    mul.lo.s32 %r22, %r3, 4;
    shl.b32 %r23, %r9, 2;
    shr.s32 %r5, %r9, 31;
    cvt.u64.u32 %rd6, %r22;
    setp.hs.u32 %p2, %r5, 65535;
    @%p2 shr.s32 %r7, %r22, 4;
    min.s32 %r8, %r9, 32;
    min.u32 %r24, %r23, %r8;
    selp.b32 %r12, %r8, %r23, %p2;
    min.s32 %r22, %r7, %r12;
    max.s32 %r11, %r22, %r22;
    shr.u32 %r26, %r5, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
