.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r16, %r3, %r3;
    mul.lo.u32 %r19, %r16, 16;
    min.u32 %r26, %r16, 65535;
    max.u32 %r20, %r26, 65535;
    sub.s32 %r9, %r16, 7;
    cvt.u64.u32 %rd14, %r9;
    shl.b32 %r6, %r16, 31;
    setp.le.s32 %p1, %r3, 2147483648;
    @%p1 min.u32 %r18, %r3, %r19;
    and.b32 %r11, %r6, %r18;
    shl.b32 %r5, %r9, 7;
    mul.lo.s64 %rd8, %rd14, %rd14;
    min.s64 %rd6, %rd8, %rd14;
    setp.eq.u32 %p2, %r11, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
