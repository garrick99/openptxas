    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd13, %r3, %r3;
    max.s32 %r10, %r3, %r3;
    xor.b32 %r12, %r10, 2147483648;
    min.u32 %r19, %r10, 5;
    and.b32 %r22, %r3, %r12;
    and.b32 %r6, %r12, %r22;
    shr.u64 %rd15, %rd13, 4;
