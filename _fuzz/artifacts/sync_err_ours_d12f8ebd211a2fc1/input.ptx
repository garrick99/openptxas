.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r21, %r3, 1;
    shl.b32 %r26, %r3, 0;
    cvt.u64.u32 %rd6, %r21;
    shl.b32 %r8, %r21, 30;
    mul.wide.s32 %rd8, %r3, %r26;
    xor.b32 %r17, %r3, 4294967295;
    sub.u32 %r10, %r26, %r21;
    shr.s32 %r4, %r8, 3;
    min.u32 %r15, %r3, 2147483647;
    mul.wide.s32 %rd13, %r17, %r3;
    setp.eq.s32 %p1, %r26, %r21;
    @%p1 cvt.s32.s64 %r11, %rd6;
    and.b32 %r10, %r21, %r4;
    min.u32 %r14, %r4, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
