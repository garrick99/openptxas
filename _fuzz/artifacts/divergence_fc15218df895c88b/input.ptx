.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p3, %r3, 255;
    @%p3 mul.lo.u32 %r16, %r3, %r3;
    selp.b32 %r8, %r3, %r16, %p3;
    min.s32 %r26, %r8, %r3;
    shr.s32 %r12, %r16, 4;
    or.b32 %r22, %r3, %r8;
    setp.ne.u32 %p4, %r8, %r8;
    mul.wide.u32 %rd10, %r3, %r26;
    shr.s32 %r19, %r16, 7;
    mad.lo.s32 %r10, %r12, %r3, %r12;
    max.u64 %rd6, %rd10, %rd10;
    sub.s64 %rd8, %rd6, %rd10;
    sub.s32 %r5, %r8, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
