    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r14, %r3, 2147483648;
    cvt.u64.u32 %rd11, %r14;
    shr.s64 %rd14, %rd11, 30;
    cvt.u64.u32 %rd9, %r3;
    mul.lo.s32 %r12, %r14, %r14;
