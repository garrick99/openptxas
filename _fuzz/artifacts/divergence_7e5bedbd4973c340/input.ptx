.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r11, %r3, 65535;
    cvt.u64.u32 %rd15, %r3;
    min.u32 %r24, %r11, 32;
    setp.ls.u32 %p3, %r3, %r3;
    @!%p3 mul.lo.s32 %r4, %r3, %r11;
    cvt.u32.u64 %r5, %rd15;
    mad.lo.s32 %r24, %r5, %r5, %r24;
    add.u32 %r18, %r5, 31;
    add.s32 %r23, %r11, %r24;
    cvt.u32.u64 %r7, %rd15;
    mul.wide.u32 %rd6, %r4, %r4;
    or.b32 %r20, %r23, %r23;
    cvt.u32.u64 %r5, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
