.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p2, %r3, 7;
    @%p2 sub.u32 %r24, %r3, %r3;
    min.u32 %r18, %r3, 255;
    add.s32 %r8, %r3, %r18;
    xor.b32 %r5, %r8, %r8;
    mul.lo.s32 %r24, %r18, 5;
    mul.wide.u32 %rd5, %r8, %r5;
    max.s32 %r8, %r3, %r3;
    shr.u32 %r6, %r8, 7;
    or.b32 %r22, %r5, %r3;
    sub.s32 %r10, %r3, %r5;
    shr.s32 %r17, %r10, 15;
    sub.u32 %r16, %r10, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
