.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r24, %r3, %r3, %r3;
    setp.ne.u32 %p3, %r24, 65535;
    @!%p3 shr.s32 %r21, %r3, 2;
    sub.s32 %r19, %r21, 2;
    mul.wide.u32 %rd7, %r19, %r19;
    mad.lo.u32 %r8, %r19, %r3, %r21;
    cvt.u64.u32 %rd7, %r21;
    mad.lo.s32 %r8, %r19, %r3, %r24;
    shl.b32 %r23, %r3, 30;
    and.b64 %rd12, %rd7, %rd7;
    max.s64 %rd8, %rd7, %rd7;
    max.u32 %r16, %r21, 16;
    mad.lo.s32 %r10, %r19, %r21, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
