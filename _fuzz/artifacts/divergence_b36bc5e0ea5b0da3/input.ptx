    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfi.b32 %r11, %r3, %r3, 8, 7;
    bfe.s32 %r18, %r11, 24, 16;
    max.u32 %r8, %r3, %r18;
    bfi.b32 %r11, %r8, %r8, 0, 4;
    bfe.s32 %r6, %r3, 16, 31;
    bfe.u32 %r19, %r11, 1, 16;
    bfi.b32 %r7, %r8, %r11, 8, 16;
    popc.b32 %r20, %r8;
    clz.b32 %r11, %r19;
    popc.b32 %r13, %r20;
    prmt.b32 %r10, %r18, %r20, 17476;
    bfi.b32 %r21, %r10, %r6, 4, 32;
