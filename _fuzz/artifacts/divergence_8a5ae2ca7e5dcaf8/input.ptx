.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r20, %r3, 0;
    min.s32 %r5, %r20, 15;
    sub.u32 %r10, %r5, %r20;
    mul.wide.u32 %rd15, %r10, %r10;
    setp.eq.s32 %p3, %r10, %r5;
    mul.lo.u32 %r20, %r5, 65535;
    shl.b64 %rd9, %rd15, 2;
    max.u64 %rd10, %rd15, %rd15;
    cvt.s64.s32 %rd10, %r3;
    shr.u32 %r17, %r20, 7;
    shr.s32 %r12, %r10, 15;
    shr.s64 %rd15, %rd10, 0;
    max.u64 %rd14, %rd15, %rd10;
    mul.lo.s32 %r14, %r17, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
