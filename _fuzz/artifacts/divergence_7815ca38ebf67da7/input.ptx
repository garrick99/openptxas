.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r11, %r3, 255;
    sub.s32 %r9, %r3, 5;
    cvt.s64.s32 %rd11, %r9;
    sub.s64 %rd15, %rd11, %rd11;
    setp.ge.u32 %p2, %r11, 7;
    @%p2 shr.s64 %rd7, %rd15, 2;
    sub.s32 %r22, %r9, 32;
    mul.wide.s32 %rd9, %r11, %r9;
    xor.b32 %r23, %r11, %r3;
    mul.wide.s32 %rd6, %r3, %r11;
    shl.b32 %r20, %r22, 4;
    min.s32 %r8, %r3, 2147483647;
    cvt.u64.u32 %rd8, %r22;
    min.u64 %rd13, %rd6, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
