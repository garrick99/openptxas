.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r25, %r3, 7;
    cvt.s64.s32 %rd6, %r25;
    mul.lo.u32 %r11, %r3, 2147483647;
    and.b32 %r11, %r25, 63;
    cvt.s32.s64 %r20, %rd6;
    max.u32 %r24, %r25, 4;
    setp.hs.u32 %p3, %r3, %r11;
    @%p3 mul.lo.s32 %r17, %r11, 64;
    shl.b64 %rd8, %rd6, 30;
    max.s32 %r27, %r17, %r24;
    setp.gt.s32 %p1, %r27, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
