.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd13, %r3, %r3;
    mad.lo.u32 %r13, %r3, %r3, %r3;
    shr.s64 %rd8, %rd13, 62;
    setp.ls.u32 %p1, %r13, %r3;
    and.b64 %rd6, %rd8, %rd8;
    max.u32 %r25, %r13, %r3;
    xor.b32 %r23, %r3, 255;
    add.s32 %r26, %r3, %r25;
    mul.wide.s32 %rd15, %r23, %r23;
    mul.wide.u32 %rd8, %r23, %r3;
    selp.b32 %r6, %r25, %r3, %p1;
    shr.s32 %r11, %r23, 2;
    sub.u32 %r14, %r3, %r3;
    mad.lo.u32 %r26, %r25, %r13, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
