.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p3, %r3, %r3;
    @!%p3 and.b32 %r25, %r3, %r3;
    max.u32 %r16, %r3, %r25;
    and.b32 %r7, %r3, %r25;
    setp.lo.u32 %p3, %r7, %r16;
    @%p3 mul.wide.s32 %rd11, %r7, %r7;
    max.u32 %r7, %r7, 5;
    add.u32 %r17, %r16, %r3;
    mad.lo.u32 %r12, %r3, %r25, %r7;
    add.u32 %r8, %r3, %r16;
    cvt.s32.s64 %r12, %rd11;
    add.s32 %r25, %r16, %r16;
    shr.s32 %r5, %r16, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
