.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p1, %r3, 255;
    @!%p1 shr.u32 %r24, %r3, 15;
    selp.b32 %r16, %r3, %r24, %p1;
    add.s32 %r16, %r16, %r24;
    setp.lo.u32 %p2, %r3, 4294967295;
    cvt.s64.s32 %rd9, %r16;
    max.u32 %r17, %r16, %r24;
    add.u32 %r24, %r3, %r3;
    cvt.u64.u32 %rd7, %r3;
    setp.eq.u32 %p2, %r24, 4;
    @%p2 max.u64 %rd11, %rd9, %rd9;
    shl.b32 %r25, %r3, 3;
    sub.s32 %r8, %r16, %r17;
    shr.s32 %r23, %r8, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
