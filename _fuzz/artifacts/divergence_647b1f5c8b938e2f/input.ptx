.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r20, %r3, %r3;
    setp.hi.u32 %p4, %r20, %r3;
    @!%p4 add.s32 %r20, %r20, 2147483648;
    selp.b32 %r9, %r20, %r20, %p4;
    cvt.u64.u32 %rd14, %r20;
    max.u32 %r27, %r3, %r20;
    cvt.s32.s64 %r16, %rd14;
    selp.b32 %r11, %r3, %r9, %p4;
    mul.wide.s32 %rd6, %r9, %r3;
    shl.b64 %rd15, %rd14, 16;
    sub.u32 %r24, %r3, %r3;
    shr.s32 %r20, %r11, 3;
    cvt.u32.u64 %r23, %rd15;
    sub.s32 %r21, %r11, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
