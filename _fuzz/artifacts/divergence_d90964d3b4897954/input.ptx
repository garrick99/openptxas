.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    sub.u64 %rd10, %rd11, %rd11;
    max.u32 %r11, %r3, %r3;
    shl.b32 %r4, %r3, 3;
    add.s64 %rd14, %rd10, %rd10;
    cvt.u64.u32 %rd9, %r4;
    add.u32 %r15, %r4, %r3;
    mul.wide.u32 %rd15, %r3, %r15;
    setp.hi.u32 %p2, %r11, 63;
    selp.b32 %r15, %r11, %r11, %p2;
    shl.b64 %rd11, %rd14, 4;
    min.u32 %r24, %r4, 4;
    add.s64 %rd8, %rd15, %rd10;
    shr.s64 %rd10, %rd15, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
