.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r24, %r3, 15;
    max.u32 %r13, %r3, %r3;
    setp.lt.s32 %p4, %r24, %r13;
    @!%p4 sub.s32 %r16, %r13, %r24;
    mul.wide.s32 %rd11, %r16, %r13;
    cvt.s32.s64 %r19, %rd11;
    mad.lo.s32 %r11, %r16, %r24, %r13;
    mul.lo.u64 %rd6, %rd11, %rd11;
    setp.ge.u32 %p1, %r16, 255;
    @!%p1 shr.u32 %r26, %r16, 15;
    shr.s32 %r26, %r3, 15;
    shr.s32 %r9, %r3, 0;
    mul.lo.u32 %r7, %r11, 3;
    cvt.s32.s64 %r4, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
