.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r9, %r3, 4294967295;
    setp.ge.u32 %p4, %r3, 255;
    @%p4 mul.lo.u32 %r9, %r9, 7;
    cvt.s64.s32 %rd7, %r9;
    selp.b32 %r19, %r9, %r3, %p4;
    cvt.s32.s64 %r6, %rd7;
    setp.lt.s32 %p4, %r3, 65535;
    @%p4 or.b32 %r13, %r3, %r19;
    cvt.u32.u64 %r12, %rd7;
    add.u32 %r8, %r12, %r9;
    xor.b32 %r16, %r6, 256;
    selp.b32 %r26, %r19, %r12, %p4;
    add.u32 %r7, %r13, 2147483647;
    setp.ge.u32 %p1, %r13, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
