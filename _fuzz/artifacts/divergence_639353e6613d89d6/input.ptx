.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    add.u32 %r26, %r3, 65535;
    max.s32 %r10, %r26, 2;
    add.u32 %r13, %r10, 31;
    setp.ne.u32 %p1, %r3, 16;
    @!%p1 xor.b32 %r6, %r26, %r26;
    add.s32 %r9, %r26, 16;
    setp.le.s32 %p4, %r9, 1;
    mul.wide.u32 %rd14, %r26, %r26;
    mad.lo.s32 %r16, %r26, %r9, %r10;
    cvt.s64.s32 %rd14, %r3;
    sub.s32 %r27, %r6, %r10;
    selp.b32 %r20, %r6, %r10, %p1;
    or.b64 %rd6, %rd5, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
