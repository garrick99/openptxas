.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd14, %r3, %r3;
    mul.wide.s32 %rd12, %r3, %r3;
    shl.b32 %r17, %r3, 0;
    mad.lo.s32 %r5, %r3, %r17, %r17;
    mul.wide.u32 %rd9, %r17, %r17;
    max.s32 %r10, %r3, %r5;
    max.u32 %r21, %r3, %r10;
    cvt.s32.s64 %r13, %rd9;
    min.u32 %r27, %r13, %r17;
    cvt.s64.s32 %rd12, %r5;
    mul.wide.s32 %rd15, %r3, %r5;
    max.s32 %r9, %r3, %r21;
    add.s32 %r8, %r10, %r5;
    and.b64 %rd15, %rd14, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
