.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r12, %r3, %r3;
    setp.ne.u32 %p3, %r3, 65535;
    vote.sync.ballot.b32 %r14, %p3, -1;
    shfl.sync.down.b32 %r19, %r3, 16, 0x1f, -1;
    add.u32 %r7, %r0, %r12;
    shfl.sync.idx.b32 %r17, %r19, 0, 0x1f, -1;
    add.u32 %r14, %r12, %r12;
    shfl.sync.down.b32 %r14, %r17, 4, 0x1f, -1;
    xor.b32 %r16, %r7, %r7;
    shfl.sync.bfly.b32 %r16, %r17, 1, 0x1f, -1;
    setp.lt.u32 %p1, %r16, 3;
    vote.sync.ballot.b32 %r5, %p1, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
