.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r11, %r3, 1;
    cvt.u64.u32 %rd9, %r3;
    setp.ls.u32 %p3, %r11, %r11;
    min.s64 %rd6, %rd9, %rd9;
    shr.s64 %rd15, %rd6, 30;
    mul.wide.u32 %rd11, %r11, %r3;
    min.u32 %r17, %r11, 7;
    shl.b64 %rd8, %rd6, 2;
    mul.lo.s32 %r17, %r17, 7;
    mul.wide.u32 %rd12, %r17, %r3;
    min.s32 %r24, %r3, 15;
    mul.wide.s32 %rd6, %r11, %r24;
    shr.s64 %rd13, %rd9, 33;
    min.u32 %r17, %r17, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
