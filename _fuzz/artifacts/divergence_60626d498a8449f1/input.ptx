.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    min.s64 %rd13, %rd13, %rd13;
    setp.gt.u32 %p3, %r3, %r3;
    @%p3 mul.lo.s32 %r17, %r3, %r3;
    max.s32 %r11, %r3, %r17;
    max.s32 %r21, %r11, 16;
    shr.u32 %r6, %r17, 30;
    setp.gt.s32 %p1, %r6, %r17;
    @%p1 add.s64 %rd6, %rd13, %rd13;
    mul.wide.u32 %rd12, %r17, %r17;
    mul.wide.s32 %rd14, %r11, %r11;
    mul.wide.u32 %rd10, %r11, %r21;
    or.b32 %r18, %r21, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
