    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r25, %r3, %r3;
    mad.lo.u32 %r10, %r3, %r3, %r25;
    mul.lo.s32 %r17, %r3, %r25;
    cvt.u64.u32 %rd15, %r3;
    shr.s32 %r22, %r25, 3;
    cvt.s32.s64 %r5, %rd15;
    shl.b64 %rd14, %rd15, 3;
    setp.gt.u32 %p1, %r10, 2147483647;
    or.b32 %r18, %r3, 65535;
    and.b32 %r17, %r25, %r22;
    mul.wide.u32 %rd15, %r3, %r18;
    mul.wide.u32 %rd12, %r22, %r3;
    max.u32 %r4, %r17, 255;
    mul.lo.u32 %r23, %r17, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
