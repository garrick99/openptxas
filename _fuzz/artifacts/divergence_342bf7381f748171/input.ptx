.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r4, %r3, 7;
    xor.b32 %r9, %r4, %r3;
    setp.gt.u32 %p2, %r9, %r3;
    @%p2 selp.b32 %r15, %r4, %r4, %p2;
    setp.lt.s32 %p2, %r3, %r9;
    @%p2 cvt.s64.s32 %rd12, %r4;
    sub.s32 %r15, %r3, 16;
    selp.b32 %r24, %r3, %r9, %p2;
    mad.lo.u32 %r23, %r4, %r9, %r15;
    max.u32 %r8, %r9, %r24;
    add.s32 %r6, %r23, %r9;
    add.s32 %r27, %r24, 8;
    setp.gt.s32 %p1, %r4, %r6;
    @%p1 add.s32 %r12, %r3, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
