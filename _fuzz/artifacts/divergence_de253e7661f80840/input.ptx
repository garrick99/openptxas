.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r6, %r3, 255;
    cvt.s64.s32 %rd15, %r3;
    min.u32 %r11, %r6, %r3;
    setp.ge.s32 %p4, %r6, %r3;
    @!%p4 shr.s64 %rd14, %rd15, 32;
    or.b32 %r8, %r11, 3;
    shr.u64 %rd12, %rd15, 33;
    min.u64 %rd5, %rd14, %rd15;
    setp.ge.s32 %p2, %r3, %r11;
    @%p2 cvt.s64.s32 %rd5, %r8;
    xor.b32 %r15, %r6, %r8;
    xor.b32 %r25, %r8, %r15;
    mul.lo.u64 %rd15, %rd5, %rd14;
    cvt.u32.u64 %r13, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
