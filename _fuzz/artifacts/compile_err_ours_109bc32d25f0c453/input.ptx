.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.up.b32 %r16, %r0, 4, 0x1f, -1;
    shfl.sync.idx.b32 %r5, %r3, 15, 0x1f, -1;
    max.u32 %r10, %r16, %r5;
    xor.b32 %r6, %r3, %r16;
    min.u32 %r5, %r5, %r6;
    and.b32 %r13, %r6, %r16;
    setp.eq.u32 %p2, %r13, %r6;
    vote.sync.ballot.b32 %r8, %p2, -1;
    shfl.sync.up.b32 %r13, %r16, 16, 0x1f, -1;
    shfl.sync.down.b32 %r4, %r13, 8, 0x1f, -1;
    vote.sync.all.pred %p3, %p2, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
