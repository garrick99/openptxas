.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r22, %r3, 64;
    and.b32 %r22, %r22, 0;
    sub.u32 %r5, %r3, %r22;
    setp.lo.u32 %p4, %r22, 15;
    @%p4 cvt.u64.u32 %rd5, %r5;
    mul.lo.u32 %r9, %r5, 1;
    add.u32 %r19, %r5, 4294967295;
    mul.lo.s32 %r15, %r5, 16;
    max.u64 %rd11, %rd5, %rd5;
    cvt.u32.u64 %r18, %rd11;
    mul.wide.s32 %rd14, %r15, %r5;
    and.b32 %r10, %r9, %r18;
    shr.u32 %r13, %r3, 15;
    min.u32 %r16, %r10, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
