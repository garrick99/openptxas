.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r14, %r3, %r3;
    cvt.s64.s32 %rd14, %r14;
    shr.s64 %rd10, %rd14, 48;
    mul.lo.u32 %r25, %r3, 5;
    cvt.u32.u64 %r8, %rd10;
    cvt.s32.s64 %r20, %rd10;
    cvt.u32.u64 %r6, %rd10;
    sub.s64 %rd13, %rd14, %rd14;
    setp.lo.u32 %p1, %r20, 2147483647;
    @!%p1 max.s32 %r20, %r14, %r14;
    and.b64 %rd12, %rd14, %rd13;
    min.s32 %r13, %r3, 255;
    cvt.u64.u32 %rd14, %r8;
    add.s64 %rd8, %rd14, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
