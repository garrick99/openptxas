.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    mul.wide.u32 %rd5, %r3, %r3;
    add.s32 %r21, %r3, 15;
    cvt.s64.s32 %rd6, %r21;
    shr.u64 %rd11, %rd6, 4;
    min.u64 %rd15, %rd14, %rd5;
    mul.wide.s32 %rd7, %r3, %r3;
    mul.wide.s32 %rd5, %r21, %r3;
    shl.b32 %r17, %r21, 4;
    xor.b32 %r6, %r21, 2147483647;
    setp.ls.u32 %p1, %r6, %r3;
    @!%p1 shr.s32 %r17, %r6, 16;
    cvt.s64.s32 %rd11, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
