.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r25, %r3, 7;
    sub.s32 %r15, %r25, 256;
    max.u32 %r12, %r25, %r25;
    xor.b32 %r23, %r3, %r3;
    cvt.s64.s32 %rd15, %r23;
    mad.lo.u32 %r27, %r3, %r23, %r15;
    min.s32 %r25, %r23, 2;
    min.s32 %r21, %r12, %r3;
    max.u32 %r6, %r23, 7;
    shr.u64 %rd12, %rd15, 2;
    shr.u64 %rd15, %rd12, 47;
    max.s32 %r24, %r3, 3;
    mul.wide.s32 %rd15, %r25, %r6;
    min.s32 %r25, %r15, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
