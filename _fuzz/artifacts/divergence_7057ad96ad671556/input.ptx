.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r24, %r3, 16;
    mul.lo.s32 %r17, %r24, %r24;
    mul.lo.s32 %r10, %r24, %r3;
    setp.lt.s32 %p1, %r24, 63;
    @%p1 mad.lo.u32 %r11, %r3, %r24, %r17;
    mul.wide.u32 %rd15, %r10, %r3;
    shr.s32 %r24, %r3, 31;
    setp.ge.s32 %p2, %r17, 2147483648;
    cvt.u32.u64 %r21, %rd15;
    setp.ge.u32 %p4, %r11, 2147483648;
    @%p4 max.u32 %r21, %r11, 0;
    min.u32 %r16, %r17, %r21;
    cvt.s64.s32 %rd12, %r11;
    mad.lo.u32 %r9, %r17, %r3, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
