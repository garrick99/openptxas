.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r15, %r3, 32;
    add.s32 %r24, %r3, 255;
    shr.s32 %r21, %r24, 1;
    add.s32 %r23, %r3, 63;
    cvt.u64.u32 %rd6, %r21;
    mul.wide.u32 %rd14, %r3, %r23;
    add.s32 %r25, %r21, %r3;
    mul.lo.u64 %rd13, %rd14, %rd14;
    and.b64 %rd6, %rd6, %rd13;
    shr.s64 %rd13, %rd14, 3;
    setp.gt.u32 %p1, %r15, %r25;
    mul.lo.s32 %r23, %r24, 5;
    setp.ls.u32 %p1, %r24, 63;
    @%p1 cvt.s32.s64 %r10, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
