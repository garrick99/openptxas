.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd12, %r3, %r3;
    add.u64 %rd11, %rd12, %rd12;
    mad.lo.u32 %r18, %r3, %r3, %r3;
    mul.wide.u32 %rd7, %r3, %r3;
    mul.lo.s64 %rd12, %rd11, %rd12;
    cvt.u64.u32 %rd13, %r18;
    shl.b64 %rd11, %rd11, 3;
    cvt.u64.u32 %rd8, %r3;
    max.s32 %r10, %r18, 2147483647;
    xor.b64 %rd6, %rd7, %rd12;
    min.s32 %r25, %r3, %r18;
    max.u32 %r4, %r25, %r18;
    mad.lo.s32 %r8, %r18, %r3, %r25;
    mul.lo.u64 %rd10, %rd13, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
