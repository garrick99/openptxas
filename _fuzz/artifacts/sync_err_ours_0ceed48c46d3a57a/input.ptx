.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    cvt.s32.s64 %r27, %rd11;
    cvt.s32.s64 %r21, %rd11;
    shr.u32 %r13, %r27, 31;
    cvt.u32.u64 %r9, %rd11;
    xor.b32 %r25, %r27, 31;
    or.b32 %r27, %r27, %r13;
    cvt.s64.s32 %rd14, %r21;
    sub.s32 %r5, %r13, %r13;
    or.b64 %rd8, %rd11, %rd14;
    cvt.u32.u64 %r26, %rd11;
    mul.lo.s32 %r20, %r5, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
