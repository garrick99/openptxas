.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r23, %r3, %r3;
    xor.b32 %r8, %r3, %r23;
    mul.lo.u32 %r12, %r3, 4294967295;
    sub.s32 %r4, %r23, %r8;
    max.s32 %r6, %r12, 3;
    or.b32 %r7, %r6, %r6;
    cvt.u64.u32 %rd7, %r6;
    sub.s32 %r9, %r4, %r4;
    mul.lo.u32 %r10, %r6, 5;
    min.u32 %r22, %r3, %r10;
    or.b64 %rd13, %rd7, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
