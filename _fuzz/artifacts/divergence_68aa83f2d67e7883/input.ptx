.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r17, %r3, 3;
    min.s32 %r6, %r17, %r3;
    min.s32 %r20, %r17, 64;
    setp.gt.s32 %p1, %r3, %r17;
    @%p1 add.s32 %r11, %r20, %r3;
    and.b32 %r24, %r11, 65535;
    sub.s32 %r16, %r6, %r6;
    add.s32 %r23, %r24, %r3;
    min.u32 %r27, %r20, %r24;
    add.s32 %r20, %r16, %r6;
    mul.lo.u32 %r26, %r16, %r20;
    and.b32 %r7, %r23, %r27;
    cvt.s64.s32 %rd13, %r3;
    mul.wide.u32 %rd5, %r11, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
