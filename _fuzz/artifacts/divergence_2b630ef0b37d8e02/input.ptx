.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    max.u32 %r20, %r3, %r3;
    mad.lo.s32 %r10, %r20, %r3, %r20;
    setp.le.s32 %p3, %r3, %r20;
    @%p3 min.s32 %r14, %r3, 3;
    mul.wide.u32 %rd5, %r10, %r10;
    cvt.u64.u32 %rd6, %r3;
    setp.lt.u32 %p3, %r20, 32;
    mul.wide.u32 %rd10, %r20, %r14;
    mad.lo.s32 %r7, %r10, %r14, %r14;
    shr.u64 %rd13, %rd10, 0;
    sub.s32 %r19, %r14, %r3;
    shr.u32 %r8, %r14, 16;
    shr.s32 %r13, %r8, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
