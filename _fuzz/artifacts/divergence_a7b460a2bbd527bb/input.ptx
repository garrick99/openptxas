.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    min.s32 %r10, %r3, %r3;
    and.b32 %r4, %r10, %r3;
    shr.s32 %r7, %r3, 7;
    shr.s32 %r5, %r7, 4;
    or.b32 %r11, %r7, 4;
    sub.u32 %r15, %r4, 65535;
    mad.lo.u32 %r14, %r15, %r11, %r7;
    or.b32 %r8, %r15, %r3;
    cvt.u64.u32 %rd7, %r8;
    max.u64 %rd10, %rd7, %rd14;
    shr.u32 %r16, %r11, 4;
    setp.eq.s32 %p4, %r3, 2;
    @%p4 max.u32 %r24, %r7, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
