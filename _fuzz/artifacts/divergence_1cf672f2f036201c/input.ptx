.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    shl.b64 %rd13, %rd10, 48;
    mul.lo.s32 %r16, %r3, 16;
    setp.le.s32 %p2, %r3, 8;
    @!%p2 mul.lo.u32 %r27, %r3, 65535;
    sub.s32 %r24, %r3, %r27;
    mad.lo.s32 %r11, %r3, %r16, %r27;
    shl.b32 %r22, %r11, 30;
    mad.lo.u32 %r27, %r24, %r27, %r11;
    and.b64 %rd9, %rd10, %rd13;
    and.b32 %r26, %r16, 4;
    and.b32 %r6, %r3, 31;
    min.s32 %r20, %r11, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
