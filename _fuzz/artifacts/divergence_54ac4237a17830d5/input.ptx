.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r20, %r3, 5;
    min.u32 %r4, %r20, %r3;
    sub.u32 %r18, %r3, 3;
    cvt.s64.s32 %rd10, %r4;
    sub.s32 %r21, %r4, 5;
    setp.le.u32 %p1, %r21, 65536;
    @!%p1 and.b64 %rd5, %rd10, %rd10;
    cvt.s32.s64 %r18, %rd5;
    shr.u32 %r4, %r21, 30;
    max.s32 %r26, %r21, %r18;
    mul.lo.u32 %r12, %r3, %r18;
    shr.u32 %r22, %r26, 7;
    shr.s32 %r11, %r18, 3;
    sub.s64 %rd14, %rd10, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
