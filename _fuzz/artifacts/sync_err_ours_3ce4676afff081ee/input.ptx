.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    max.s32 %r6, %r3, 0;
    shr.s32 %r20, %r6, 1;
    setp.gt.s32 %p4, %r6, 5;
    @%p4 min.u32 %r23, %r3, %r3;
    xor.b32 %r22, %r20, %r3;
    shl.b32 %r11, %r6, 15;
    sub.s64 %rd15, %rd11, %rd11;
    sub.u64 %rd13, %rd11, %rd11;
    max.u64 %rd14, %rd13, %rd13;
    sub.u32 %r16, %r11, 3;
    mad.lo.u32 %r27, %r20, %r6, %r3;
    setp.gt.u32 %p2, %r20, 1;
    setp.ne.s32 %p2, %r11, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
