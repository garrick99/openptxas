.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r23, %r3, 0;
    setp.eq.s32 %p1, %r23, 65535;
    @!%p1 shr.s32 %r7, %r3, 30;
    shr.u32 %r19, %r3, 31;
    cvt.u64.u32 %rd6, %r7;
    add.s32 %r10, %r19, %r7;
    sub.u32 %r15, %r19, %r10;
    max.s32 %r23, %r7, %r3;
    and.b32 %r6, %r7, 15;
    xor.b64 %rd14, %rd6, %rd6;
    setp.lt.s32 %p4, %r15, 1;
    setp.eq.u32 %p3, %r6, %r7;
    setp.lo.u32 %p4, %r15, 1;
    @!%p4 and.b32 %r16, %r10, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
