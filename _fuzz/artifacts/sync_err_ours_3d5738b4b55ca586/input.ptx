.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r24, %r3, %r3;
    add.u32 %r15, %r3, %r24;
    mul.wide.u32 %rd5, %r3, %r15;
    sub.u32 %r24, %r3, %r24;
    add.s32 %r9, %r3, %r15;
    shl.b32 %r14, %r15, 4;
    setp.lt.s32 %p2, %r24, 63;
    mad.lo.u32 %r9, %r14, %r24, %r24;
    max.s32 %r20, %r24, %r3;
    max.u32 %r20, %r3, 5;
    shr.s64 %rd13, %rd5, 63;
    and.b32 %r22, %r9, %r20;
    shr.u64 %rd10, %rd5, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
