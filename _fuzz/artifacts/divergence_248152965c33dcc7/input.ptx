.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r23, %r3, 4;
    and.b32 %r21, %r23, 255;
    xor.b32 %r20, %r23, 8;
    cvt.s64.s32 %rd5, %r23;
    cvt.s32.s64 %r10, %rd5;
    shr.s64 %rd5, %rd5, 16;
    and.b32 %r9, %r20, 64;
    shr.u32 %r18, %r23, 7;
    max.u64 %rd7, %rd5, %rd5;
    and.b32 %r27, %r23, 0;
    mad.lo.s32 %r24, %r23, %r10, %r10;
    cvt.s64.s32 %rd5, %r27;
    shl.b32 %r27, %r23, 0;
    cvt.s64.s32 %rd8, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
