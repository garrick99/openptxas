.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p3, %r3, 32;
    @!%p3 min.u32 %r9, %r3, 65536;
    min.s32 %r17, %r9, 2;
    add.u32 %r27, %r9, 1;
    max.u32 %r17, %r17, 4294967295;
    shl.b32 %r26, %r27, 4;
    cvt.u64.u32 %rd13, %r27;
    max.u64 %rd10, %rd13, %rd13;
    mul.lo.u32 %r19, %r9, 63;
    sub.u32 %r4, %r9, 256;
    xor.b32 %r26, %r27, %r27;
    mul.wide.s32 %rd8, %r19, %r17;
    selp.b32 %r11, %r17, %r26, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
