.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r14, %r3, %r3;
    shl.b32 %r16, %r3, 16;
    sub.s32 %r18, %r14, %r16;
    mad.lo.s32 %r27, %r18, %r14, %r16;
    add.u32 %r11, %r18, %r16;
    xor.b32 %r12, %r11, %r27;
    min.u32 %r17, %r18, %r3;
    max.s32 %r7, %r27, %r27;
    and.b32 %r13, %r14, 3;
    mul.wide.u32 %rd10, %r12, %r12;
    min.s32 %r23, %r12, %r18;
    max.s32 %r12, %r14, %r14;
    mad.lo.s32 %r27, %r23, %r7, %r11;
    add.u32 %r22, %r13, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
