.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r27, %r3, %r3, %r3;
    cvt.u64.u32 %rd11, %r3;
    shl.b64 %rd7, %rd11, 0;
    mul.wide.s32 %rd12, %r3, %r3;
    shl.b32 %r5, %r27, 2;
    mul.lo.u32 %r24, %r27, 15;
    sub.s32 %r16, %r3, %r5;
    shr.s32 %r19, %r27, 3;
    and.b32 %r21, %r3, 1;
    mul.wide.u32 %rd12, %r24, %r21;
    mul.lo.s32 %r15, %r27, %r3;
    cvt.s32.s64 %r5, %rd7;
    and.b32 %r22, %r24, %r5;
    mul.lo.s32 %r24, %r24, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
