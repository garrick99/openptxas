.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r18, %r3, %r3;
    cvt.s64.s32 %rd12, %r3;
    setp.hi.u32 %p1, %r18, 15;
    @%p1 max.s32 %r17, %r3, %r3;
    shr.u32 %r9, %r17, 3;
    add.s32 %r9, %r9, 3;
    max.s32 %r10, %r18, %r3;
    sub.s32 %r13, %r10, %r18;
    mul.wide.s32 %rd6, %r13, %r10;
    shr.u32 %r16, %r17, 16;
    setp.lt.u32 %p1, %r16, %r17;
    @!%p1 add.s32 %r5, %r13, %r17;
    and.b32 %r14, %r3, %r16;
    selp.b32 %r17, %r5, %r17, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
