.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    shr.s32 %r24, %r3, 30;
    mul.wide.s32 %rd8, %r3, %r24;
    mul.wide.u32 %rd15, %r24, %r3;
    max.u32 %r13, %r3, %r3;
    shr.s32 %r15, %r24, 7;
    setp.hs.u32 %p4, %r13, %r24;
    @%p4 sub.u32 %r15, %r24, %r15;
    mad.lo.s32 %r11, %r15, %r24, %r15;
    setp.ge.u32 %p2, %r3, 2;
    @!%p2 max.s32 %r21, %r13, 63;
    add.s64 %rd7, %rd14, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
