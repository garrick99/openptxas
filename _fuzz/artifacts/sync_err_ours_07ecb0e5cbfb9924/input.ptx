.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p1, %r3, 16;
    setp.lt.u32 %p2, %r3, 0;
    @!%p2 cvt.u64.u32 %rd9, %r3;
    add.u32 %r19, %r3, %r3;
    shl.b32 %r11, %r3, 3;
    shr.s32 %r26, %r3, 16;
    min.u32 %r21, %r19, %r19;
    min.u32 %r6, %r3, %r11;
    shr.s64 %rd8, %rd9, 33;
    mad.lo.s32 %r27, %r11, %r19, %r3;
    sub.u32 %r4, %r26, %r19;
    max.s64 %rd5, %rd8, %rd9;
    shl.b32 %r26, %r26, 30;
    min.u32 %r15, %r4, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
