.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p2, %r3, 8;
    @%p2 min.u32 %r18, %r3, %r3;
    xor.b32 %r18, %r3, 255;
    cvt.u64.u32 %rd5, %r3;
    and.b32 %r27, %r18, 31;
    mad.lo.s32 %r10, %r3, %r3, %r27;
    or.b32 %r24, %r18, 65535;
    cvt.u64.u32 %rd5, %r27;
    setp.ne.s32 %p1, %r10, %r24;
    @!%p1 sub.s32 %r25, %r10, 255;
    setp.lt.s32 %p3, %r3, %r24;
    mad.lo.s32 %r11, %r25, %r27, %r27;
    add.s32 %r26, %r25, %r10;
    add.s64 %rd8, %rd5, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
