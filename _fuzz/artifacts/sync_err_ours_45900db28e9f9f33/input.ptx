.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    min.u32 %r20, %r3, %r3;
    shr.s32 %r13, %r3, 16;
    xor.b32 %r23, %r13, %r13;
    xor.b64 %rd11, %rd6, %rd6;
    shl.b32 %r24, %r20, 16;
    max.s32 %r17, %r13, %r13;
    setp.lt.s32 %p1, %r17, 31;
    and.b32 %r6, %r3, %r17;
    sub.u32 %r22, %r6, %r24;
    cvt.u64.u32 %rd9, %r3;
    shr.u32 %r10, %r3, 15;
    max.s32 %r14, %r10, 8;
    add.s32 %r19, %r6, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
