.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r25, %r3, 3;
    mad.lo.s32 %r17, %r3, %r25, %r3;
    mul.lo.s32 %r13, %r25, %r17;
    add.s32 %r9, %r13, %r25;
    shl.b32 %r17, %r17, 0;
    mul.lo.u32 %r19, %r13, 3;
    or.b32 %r6, %r19, 65536;
    cvt.u64.u32 %rd14, %r9;
    add.s64 %rd13, %rd14, %rd14;
    add.u32 %r7, %r19, 4294967295;
    shr.u32 %r22, %r3, 3;
    max.u32 %r23, %r19, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
