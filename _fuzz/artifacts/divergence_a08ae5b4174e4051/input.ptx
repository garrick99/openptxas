.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r6, %r3, 31;
    cvt.s64.s32 %rd5, %r3;
    shl.b32 %r26, %r3, 15;
    min.u32 %r21, %r6, %r3;
    mad.lo.s32 %r15, %r3, %r3, %r26;
    add.u32 %r4, %r21, 256;
    cvt.s64.s32 %rd6, %r15;
    min.u64 %rd12, %rd5, %rd5;
    mad.lo.u32 %r14, %r15, %r21, %r4;
    min.s32 %r7, %r6, 7;
    setp.ge.s32 %p1, %r7, 5;
    @%p1 sub.s32 %r7, %r3, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
