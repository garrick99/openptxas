.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p2, %r3, %r3;
    @%p2 or.b32 %r26, %r3, %r3;
    shl.b32 %r9, %r3, 4;
    or.b32 %r19, %r3, %r26;
    add.s32 %r8, %r26, 5;
    cvt.u64.u32 %rd15, %r3;
    sub.u32 %r8, %r8, 4294967295;
    shl.b64 %rd8, %rd15, 15;
    xor.b32 %r7, %r9, 64;
    sub.u32 %r20, %r7, %r26;
    max.s32 %r21, %r20, 256;
    shl.b32 %r22, %r8, 7;
    cvt.s64.s32 %rd14, %r3;
    xor.b32 %r26, %r22, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
