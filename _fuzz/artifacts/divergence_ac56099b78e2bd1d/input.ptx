.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r25, %r3, %r3;
    cvt.u64.u32 %rd5, %r3;
    max.u64 %rd8, %rd5, %rd5;
    and.b32 %r22, %r25, 8;
    setp.lt.s32 %p3, %r25, %r22;
    @%p3 mul.lo.s32 %r10, %r22, %r3;
    selp.b32 %r22, %r3, %r3, %p3;
    cvt.s32.s64 %r11, %rd8;
    shr.s32 %r23, %r3, 3;
    add.s32 %r27, %r3, %r11;
    min.u32 %r11, %r11, %r3;
    sub.s32 %r25, %r11, %r25;
    xor.b32 %r25, %r10, %r10;
    selp.b32 %r16, %r27, %r11, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
