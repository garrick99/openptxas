.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r10, %r3, %r3;
    setp.lt.s32 %p2, %r10, 64;
    @%p2 cvt.u64.u32 %rd10, %r10;
    add.s64 %rd13, %rd10, %rd10;
    xor.b32 %r22, %r10, 7;
    max.s32 %r27, %r10, %r22;
    selp.b32 %r25, %r10, %r27, %p2;
    shr.s64 %rd13, %rd13, 62;
    add.s32 %r22, %r22, %r10;
    selp.b32 %r6, %r27, %r10, %p2;
    or.b32 %r18, %r25, 0;
    mul.wide.s32 %rd10, %r25, %r18;
    or.b32 %r27, %r27, 31;
    mad.lo.u32 %r19, %r25, %r27, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
