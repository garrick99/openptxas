.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r12, %r3, 255;
    or.b32 %r22, %r3, %r3;
    mul.lo.s32 %r5, %r12, %r12;
    add.s32 %r9, %r5, %r5;
    mul.wide.u32 %rd14, %r22, %r22;
    cvt.s64.s32 %rd12, %r3;
    cvt.u64.u32 %rd5, %r3;
    shr.u32 %r19, %r22, 15;
    add.s32 %r23, %r19, %r5;
    setp.gt.u32 %p3, %r22, 5;
    @%p3 shl.b64 %rd5, %rd5, 15;
    setp.lt.s32 %p3, %r12, %r9;
    @%p3 selp.b32 %r12, %r5, %r19, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
