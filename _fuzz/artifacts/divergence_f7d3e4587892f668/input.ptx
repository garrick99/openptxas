.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r10, %r3, %r3;
    cvt.s64.s32 %rd6, %r10;
    sub.u32 %r10, %r3, 4294967295;
    max.u32 %r15, %r10, %r10;
    sub.u32 %r8, %r15, %r15;
    min.s32 %r17, %r8, %r3;
    mul.lo.u32 %r13, %r17, 65535;
    max.u32 %r8, %r10, 31;
    sub.s32 %r10, %r17, 5;
    or.b32 %r20, %r15, %r15;
    shl.b32 %r27, %r8, 1;
    mul.lo.u32 %r24, %r13, 65536;
    and.b64 %rd5, %rd6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
