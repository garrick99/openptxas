.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r4, %r3, 1;
    and.b32 %r10, %r4, %r3;
    cvt.s64.s32 %rd13, %r10;
    cvt.s32.s64 %r22, %rd13;
    min.u32 %r18, %r22, 256;
    shr.u32 %r4, %r18, 16;
    cvt.u64.u32 %rd9, %r3;
    min.s32 %r8, %r4, 2147483648;
    shr.s32 %r24, %r3, 3;
    min.s32 %r16, %r22, %r22;
    max.s32 %r4, %r16, 8;
    mad.lo.u32 %r16, %r18, %r16, %r8;
    add.u32 %r15, %r16, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
