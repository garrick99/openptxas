.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    min.u32 %r19, %r3, 15;
    cvt.u64.u32 %rd12, %r19;
    shr.u64 %rd13, %rd12, 16;
    min.u64 %rd13, %rd13, %rd13;
    add.s64 %rd12, %rd13, %rd13;
    cvt.u32.u64 %r18, %rd5;
    mul.lo.s32 %r12, %r19, %r19;
    and.b32 %r16, %r12, 7;
    or.b32 %r11, %r3, 65536;
    mul.lo.s32 %r26, %r12, %r12;
    add.s32 %r5, %r16, 2;
    shr.s32 %r13, %r12, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
