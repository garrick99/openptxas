.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p2, %r3, %r3;
    cvt.s64.s32 %rd7, %r3;
    max.s32 %r16, %r3, 1;
    min.u32 %r21, %r3, %r16;
    selp.b32 %r9, %r16, %r3, %p2;
    mul.lo.u32 %r15, %r16, 256;
    mad.lo.u32 %r15, %r3, %r9, %r21;
    add.u32 %r15, %r9, %r16;
    mul.lo.u32 %r16, %r3, 32;
    mul.lo.s64 %rd6, %rd7, %rd7;
    setp.hi.u32 %p1, %r16, 3;
    setp.gt.u32 %p1, %r16, 2147483647;
    @%p1 mad.lo.u32 %r26, %r16, %r15, %r15;
    xor.b64 %rd14, %rd6, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
