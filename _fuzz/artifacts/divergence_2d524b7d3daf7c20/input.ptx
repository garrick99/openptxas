.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    setp.le.u32 %p1, %r3, 65536;
    @!%p1 xor.b32 %r11, %r3, 64;
    mad.lo.s32 %r20, %r11, %r11, %r11;
    cvt.u32.u64 %r8, %rd8;
    shr.s32 %r5, %r20, 0;
    sub.s32 %r24, %r8, 32;
    setp.eq.u32 %p1, %r8, %r20;
    @%p1 cvt.s32.s64 %r4, %rd8;
    mad.lo.s32 %r10, %r20, %r4, %r4;
    xor.b32 %r12, %r3, %r4;
    mul.wide.s32 %rd10, %r20, %r11;
    mul.lo.s32 %r26, %r3, %r10;
    add.u32 %r25, %r20, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
