.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r4, %r3, %r3;
    cvt.s64.s32 %rd13, %r3;
    setp.le.s32 %p4, %r3, %r4;
    @%p4 and.b32 %r18, %r3, %r3;
    or.b32 %r26, %r4, %r4;
    mad.lo.s32 %r5, %r3, %r26, %r3;
    max.u32 %r15, %r3, 15;
    add.u32 %r11, %r18, %r3;
    cvt.s32.s64 %r8, %rd13;
    selp.b32 %r20, %r8, %r8, %p4;
    xor.b32 %r10, %r20, 5;
    mul.wide.u32 %rd11, %r5, %r15;
    and.b32 %r26, %r26, %r18;
    selp.b32 %r7, %r18, %r11, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
