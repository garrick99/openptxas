.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r12, %r3, 5;
    cvt.s64.s32 %rd8, %r3;
    mul.wide.s32 %rd9, %r12, %r3;
    sub.s32 %r26, %r3, 3;
    min.u32 %r6, %r3, %r3;
    mul.wide.s32 %rd8, %r26, %r3;
    min.s64 %rd5, %rd9, %rd9;
    cvt.s32.s64 %r5, %rd8;
    setp.ne.s32 %p2, %r6, 31;
    @%p2 shl.b64 %rd11, %rd9, 7;
    min.u32 %r16, %r5, 8;
    setp.ne.u32 %p2, %r16, 7;
    setp.ne.s32 %p4, %r6, %r5;
    @!%p4 mul.wide.u32 %rd7, %r6, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
