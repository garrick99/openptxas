.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p4, %r3, 31;
    cvt.s64.s32 %rd6, %r3;
    selp.b32 %r22, %r3, %r3, %p4;
    sub.s64 %rd8, %rd6, %rd6;
    min.s32 %r14, %r22, %r3;
    mul.wide.u32 %rd11, %r3, %r3;
    shl.b32 %r8, %r22, 15;
    shl.b32 %r9, %r3, 0;
    and.b32 %r17, %r22, 4294967295;
    cvt.u64.u32 %rd10, %r3;
    shr.u64 %rd14, %rd6, 0;
    cvt.s64.s32 %rd11, %r17;
    or.b32 %r22, %r17, 2;
    setp.hi.u32 %p3, %r8, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
