    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    and.b32 %r19, %r3, %r3;
    add.u32 %r19, %r3, 255;
    and.b32 %r26, %r3, %r3;
    min.u32 %r13, %r26, 2147483648;
    add.s32 %r23, %r3, %r13;
    setp.lt.u32 %p3, %r19, %r26;
    @%p3 cvt.s32.s64 %r7, %rd14;
    mul.lo.s32 %r10, %r23, 15;
    min.s64 %rd9, %rd14, %rd14;
    mul.lo.s32 %r16, %r26, 1;
    sub.s32 %r24, %r7, %r23;
    mad.lo.u32 %r13, %r7, %r24, %r19;
    or.b32 %r24, %r19, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
