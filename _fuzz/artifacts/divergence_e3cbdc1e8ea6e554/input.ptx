.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    setp.lo.u32 %p2, %r3, 7;
    add.u32 %r7, %r3, 16;
    xor.b32 %r8, %r3, 64;
    cvt.s64.s32 %rd9, %r3;
    mul.wide.u32 %rd10, %r7, %r7;
    shl.b64 %rd7, %rd11, 48;
    xor.b32 %r5, %r8, %r7;
    and.b64 %rd9, %rd11, %rd9;
    selp.b32 %r26, %r3, %r5, %p2;
    shr.u32 %r15, %r7, 16;
    or.b32 %r14, %r3, %r7;
    setp.lt.s32 %p1, %r8, 5;
    @!%p1 min.u32 %r10, %r8, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
