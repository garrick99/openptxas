.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p1, %r3, %r3;
    @%p1 mul.lo.u32 %r25, %r3, %r3;
    cvt.s64.s32 %rd15, %r3;
    cvt.s32.s64 %r8, %rd15;
    shr.s32 %r19, %r8, 15;
    and.b32 %r10, %r3, 65535;
    mul.lo.u32 %r4, %r3, 8;
    sub.s32 %r10, %r19, 4;
    sub.u32 %r23, %r19, %r19;
    setp.ge.s32 %p1, %r23, 65536;
    max.s32 %r14, %r4, %r23;
    shr.s32 %r4, %r10, 3;
    mul.wide.s32 %rd15, %r14, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
