    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r17, %r3, 2147483648;
    max.u32 %r19, %r3, 16;
    min.u32 %r16, %r17, 4;
    cvt.s64.s32 %rd14, %r19;
    cvt.s64.s32 %rd7, %r19;
    shr.s64 %rd9, %rd7, 3;
    max.u32 %r9, %r3, 16;
    shr.s32 %r14, %r19, 16;
    max.u32 %r22, %r14, %r9;
    min.u64 %rd10, %rd9, %rd7;
    xor.b32 %r25, %r19, %r14;
    sub.s32 %r22, %r16, 7;
    mul.lo.s32 %r13, %r3, %r17;
    ld.param.u64 %rd3, [p_out];
