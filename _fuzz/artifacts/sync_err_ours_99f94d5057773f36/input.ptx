.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r18, %r3, 31;
    mul.wide.u32 %rd8, %r3, %r3;
    or.b32 %r6, %r18, 7;
    mul.wide.u32 %rd9, %r18, %r18;
    cvt.u32.u64 %r5, %rd9;
    sub.u32 %r13, %r5, %r6;
    sub.s32 %r19, %r5, 32;
    add.s32 %r5, %r5, %r13;
    mul.lo.s32 %r5, %r19, 31;
    shl.b64 %rd13, %rd9, 7;
    cvt.s32.s64 %r13, %rd9;
    or.b32 %r15, %r5, %r13;
    max.u32 %r18, %r6, 16;
    xor.b32 %r9, %r3, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
