.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r17, %r3, %r3;
    sub.s32 %r19, %r17, %r3;
    mul.lo.s32 %r14, %r17, 16;
    setp.le.s32 %p3, %r14, %r3;
    mad.lo.u32 %r11, %r19, %r17, %r19;
    mul.lo.u32 %r22, %r11, %r17;
    add.s32 %r21, %r14, 256;
    cvt.u64.u32 %rd10, %r14;
    shr.s64 %rd7, %rd10, 32;
    mad.lo.s32 %r20, %r11, %r22, %r19;
    shr.u32 %r27, %r19, 16;
    min.s32 %r8, %r17, 5;
    mul.lo.s64 %rd14, %rd10, %rd7;
    cvt.u64.u32 %rd6, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
