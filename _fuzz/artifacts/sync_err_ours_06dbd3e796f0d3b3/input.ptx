.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r7, %r3, %r3;
    min.u32 %r9, %r7, %r3;
    cvt.u64.u32 %rd14, %r9;
    shl.b32 %r5, %r9, 15;
    add.u32 %r20, %r5, %r3;
    shr.u64 %rd10, %rd14, 3;
    shr.s64 %rd9, %rd10, 30;
    xor.b32 %r12, %r3, %r3;
    shl.b32 %r10, %r20, 0;
    max.s64 %rd12, %rd10, %rd10;
    setp.eq.u32 %p1, %r5, %r10;
    add.u64 %rd10, %rd14, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
