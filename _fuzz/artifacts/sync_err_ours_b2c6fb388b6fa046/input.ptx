.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    mul.wide.u32 %rd6, %r3, %r3;
    min.s64 %rd10, %rd6, %rd14;
    sub.s32 %r18, %r3, %r3;
    sub.u32 %r15, %r3, %r3;
    and.b32 %r5, %r3, 8;
    cvt.u32.u64 %r16, %rd6;
    sub.u32 %r12, %r18, 256;
    xor.b32 %r16, %r5, %r12;
    sub.s64 %rd9, %rd10, %rd10;
    sub.s32 %r16, %r16, %r12;
    or.b32 %r21, %r5, %r12;
    sub.u32 %r16, %r21, 5;
    sub.s32 %r14, %r15, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
