.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    min.s32 %r6, %r3, 3;
    shl.b32 %r13, %r6, 3;
    mad.lo.u32 %r18, %r6, %r13, %r13;
    add.u32 %r22, %r3, %r3;
    mul.lo.s32 %r9, %r18, 64;
    setp.gt.s32 %p1, %r22, %r22;
    @%p1 mad.lo.s32 %r11, %r9, %r18, %r22;
    min.s32 %r7, %r22, 15;
    selp.b32 %r17, %r3, %r18, %p1;
    sub.s64 %rd12, %rd12, %rd12;
    add.s32 %r17, %r3, %r11;
    selp.b32 %r7, %r22, %r17, %p1;
    min.s32 %r7, %r6, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
