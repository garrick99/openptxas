    or.b32 %r27, %r25, 31;
    mad.lo.u32 %r23, %r27, %r25, %r3;
    and.b32 %r21, %r23, 1;
    sub.s64 %rd10, %rd15, %rd5;
    and.b64 %rd5, %rd10, %rd5;
    mad.lo.u32 %r25, %r23, %r21, %r23;
    max.u64 %rd10, %rd10, %rd5;
    shr.u32 %r24, %r21, 3;
