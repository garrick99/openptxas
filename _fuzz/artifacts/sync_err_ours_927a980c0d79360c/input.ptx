.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd9, %r3, %r3;
    and.b32 %r18, %r3, 4;
    sub.u32 %r5, %r18, 64;
    shr.u32 %r5, %r3, 0;
    add.u64 %rd9, %rd9, %rd9;
    mad.lo.s32 %r11, %r18, %r5, %r5;
    cvt.u32.u64 %r17, %rd9;
    shr.s64 %rd13, %rd9, 3;
    mul.lo.s32 %r9, %r3, 4;
    sub.s32 %r8, %r3, %r11;
    mul.lo.u32 %r19, %r3, %r5;
    cvt.u32.u64 %r4, %rd9;
    or.b32 %r4, %r5, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
