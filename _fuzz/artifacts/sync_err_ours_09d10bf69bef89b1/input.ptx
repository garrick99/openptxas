    @%p2 add.s32 %r12, %r3, 32;
    sub.u32 %r13, %r12, 5;
    cvt.s64.s32 %rd15, %r3;
    mul.lo.u32 %r5, %r13, %r3;
    max.s32 %r27, %r12, %r3;
    min.s32 %r6, %r5, 2147483648;
    shl.b32 %r20, %r6, 7;
    sub.s64 %rd15, %rd7, %rd15;
    cvt.u32.u64 %r19, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
