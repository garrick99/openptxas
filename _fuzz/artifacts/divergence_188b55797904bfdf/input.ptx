    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p1, %r3, %r3;
    sub.u32 %r15, %r3, %r3;
    cvt.u64.u32 %rd10, %r15;
    cvt.u32.u64 %r20, %rd10;
    or.b32 %r14, %r15, 4294967295;
    cvt.s64.s32 %rd11, %r20;
    min.s32 %r23, %r3, %r20;
    mul.lo.s32 %r11, %r15, 63;
    selp.b32 %r16, %r3, %r20, %p1;
    selp.b32 %r18, %r14, %r11, %p1;
    setp.le.u32 %p3, %r20, 4;
    sub.u32 %r12, %r16, 255;
    setp.ls.u32 %p3, %r16, %r15;
    @%p3 sub.u32 %r9, %r14, %r18;
