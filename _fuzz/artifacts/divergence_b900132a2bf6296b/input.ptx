.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r12, %r3, 5;
    setp.lt.s32 %p4, %r12, 7;
    @!%p4 mul.wide.s32 %rd11, %r3, %r12;
    and.b32 %r25, %r12, %r12;
    add.u32 %r14, %r12, %r12;
    cvt.s32.s64 %r20, %rd11;
    min.s32 %r22, %r3, %r14;
    and.b32 %r22, %r20, %r20;
    mad.lo.s32 %r24, %r14, %r14, %r14;
    add.s32 %r5, %r22, %r20;
    setp.eq.u32 %p4, %r20, %r22;
    @%p4 selp.b32 %r4, %r25, %r24, %p4;
    shl.b64 %rd9, %rd11, 4;
    setp.hi.u32 %p2, %r5, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
