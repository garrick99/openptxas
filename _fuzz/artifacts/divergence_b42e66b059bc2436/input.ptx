.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    add.s64 %rd12, %rd5, %rd5;
    mul.lo.s64 %rd13, %rd5, %rd12;
    setp.hi.u32 %p4, %r3, 1;
    @%p4 mad.lo.u32 %r27, %r3, %r3, %r3;
    or.b32 %r24, %r3, %r27;
    and.b64 %rd6, %rd13, %rd5;
    max.u32 %r9, %r3, %r24;
    sub.s64 %rd10, %rd13, %rd12;
    selp.b32 %r10, %r27, %r24, %p4;
    cvt.u32.u64 %r20, %rd12;
    shl.b32 %r26, %r24, 1;
    sub.s32 %r10, %r9, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
