.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p1, %r0, %r3;
    vote.sync.ballot.b32 %r9, %p1, -1;
    sub.u32 %r4, %r9, %r9;
    setp.le.u32 %p3, %r9, 65535;
    vote.sync.ballot.b32 %r6, %p3, -1;
    setp.eq.u32 %p2, %r6, %r4;
    vote.sync.ballot.b32 %r10, %p2, -1;
    shfl.sync.idx.b32 %r12, %r10, 31, 0x1f, -1;
    vote.sync.all.pred %p1, %p2, -1;
    setp.eq.u32 %p1, %r4, 8;
    vote.sync.ballot.b32 %r9, %p1, -1;
    shfl.sync.down.b32 %r7, %r12, 2, 0x1f, -1;
    shfl.sync.up.b32 %r16, %r7, 8, 0x1f, -1;
    shfl.sync.down.b32 %r17, %r9, 16, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
