    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    setp.ge.s32 %p3, %r3, 2147483647;
    @%p3 mul.wide.u32 %rd8, %r3, %r3;
    cvt.s32.s64 %r6, %rd10;
    mul.lo.s32 %r27, %r3, %r3;
    sub.u32 %r17, %r27, %r6;
    and.b32 %r4, %r6, %r27;
    cvt.u64.u32 %rd7, %r17;
    mul.wide.s32 %rd10, %r4, %r17;
    cvt.u64.u32 %rd15, %r4;
    mul.wide.u32 %rd9, %r27, %r17;
    add.s32 %r11, %r3, %r27;
