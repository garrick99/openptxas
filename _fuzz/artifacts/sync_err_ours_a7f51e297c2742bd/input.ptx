.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p4, %r3, 2147483647;
    @%p4 mul.lo.u32 %r14, %r3, 8;
    mul.lo.u32 %r9, %r14, 63;
    xor.b32 %r4, %r14, %r9;
    mul.wide.u32 %rd5, %r4, %r3;
    max.u64 %rd10, %rd5, %rd5;
    max.u32 %r16, %r4, %r4;
    cvt.u32.u64 %r12, %rd10;
    setp.ne.s32 %p2, %r14, 8;
    shl.b32 %r25, %r4, 15;
    max.u32 %r18, %r12, 65536;
    mul.lo.s32 %r13, %r18, %r14;
    cvt.s64.s32 %rd10, %r9;
    min.u64 %rd13, %rd10, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
