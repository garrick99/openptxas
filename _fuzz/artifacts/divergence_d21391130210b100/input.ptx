.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfe.s32 %r18, %r3, 1, 1;
    bfe.u32 %r19, %r3, 23, 4;
    bfe.u32 %r18, %r3, 7, 16;
    clz.b32 %r14, %r19;
    bfe.u32 %r20, %r14, 1, 8;
    clz.b32 %r12, %r18;
    popc.b32 %r8, %r3;
    popc.b32 %r6, %r12;
    bfe.u32 %r20, %r18, 23, 1;
    clz.b32 %r14, %r8;
    bfi.b32 %r4, %r8, %r12, 7, 31;
    popc.b32 %r13, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
