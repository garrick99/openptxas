    and.b32 %r19, %r13, 31;
    xor.b32 %r8, %r5, %r4;
    or.b32 %r27, %r8, %r19;
    min.u64 %rd7, %rd14, %rd6;
    add.s32 %r5, %r19, 5;
    setp.eq.u32 %p2, %r19, %r27;
