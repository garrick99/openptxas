.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p2, %r3, 7;
    cvt.s64.s32 %rd8, %r3;
    cvt.s32.s64 %r15, %rd8;
    cvt.u32.u64 %r15, %rd8;
    or.b32 %r22, %r15, %r15;
    cvt.s32.s64 %r9, %rd8;
    add.u32 %r15, %r9, 31;
    cvt.u32.u64 %r5, %rd8;
    sub.s64 %rd8, %rd8, %rd8;
    shr.u32 %r26, %r15, 7;
    sub.s32 %r22, %r15, %r22;
    shl.b32 %r8, %r22, 30;
    shr.s64 %rd7, %rd8, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
