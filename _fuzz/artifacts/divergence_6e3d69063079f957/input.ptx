.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r27, %r3, %r3;
    shl.b32 %r12, %r27, 3;
    xor.b32 %r12, %r27, 0;
    setp.ge.s32 %p2, %r3, %r27;
    @%p2 xor.b32 %r19, %r12, 255;
    cvt.u64.u32 %rd7, %r19;
    selp.b32 %r24, %r19, %r3, %p2;
    setp.le.u32 %p2, %r24, %r27;
    @!%p2 max.u64 %rd14, %rd7, %rd7;
    or.b64 %rd9, %rd7, %rd14;
    mul.lo.u32 %r14, %r24, %r19;
    mul.wide.u32 %rd12, %r19, %r19;
    min.s32 %r26, %r3, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
