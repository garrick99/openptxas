.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hi.u32 %p2, %r3, 64;
    @%p2 or.b32 %r16, %r3, %r3;
    add.u32 %r22, %r16, %r3;
    cvt.s64.s32 %rd10, %r22;
    xor.b32 %r11, %r22, %r22;
    mul.wide.u32 %rd7, %r16, %r3;
    add.s64 %rd11, %rd10, %rd10;
    sub.s64 %rd13, %rd7, %rd11;
    max.u32 %r10, %r22, %r11;
    shr.s32 %r25, %r10, 30;
    min.s32 %r15, %r3, 3;
    max.s64 %rd15, %rd10, %rd11;
    add.u32 %r12, %r25, %r25;
    cvt.u64.u32 %rd14, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
