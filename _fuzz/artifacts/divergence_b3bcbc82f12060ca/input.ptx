.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r26, %r3, 7;
    mul.wide.s32 %rd6, %r26, %r26;
    mul.lo.u32 %r9, %r3, 1;
    setp.lt.u32 %p3, %r9, %r9;
    @%p3 mad.lo.u32 %r24, %r9, %r26, %r3;
    mul.wide.u32 %rd7, %r24, %r24;
    xor.b32 %r5, %r24, %r9;
    cvt.u64.u32 %rd8, %r5;
    cvt.s32.s64 %r22, %rd7;
    add.s32 %r27, %r3, 255;
    shl.b64 %rd13, %rd7, 7;
    min.u32 %r15, %r5, 65536;
    sub.u32 %r12, %r22, 4;
    xor.b32 %r21, %r5, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
