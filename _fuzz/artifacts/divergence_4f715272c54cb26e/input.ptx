.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r5, %r3, %r3, %r3;
    shr.u32 %r18, %r3, 16;
    max.u32 %r24, %r3, 255;
    shr.u32 %r13, %r24, 31;
    mul.lo.u32 %r4, %r13, 65536;
    mad.lo.u32 %r9, %r4, %r18, %r3;
    add.u32 %r23, %r13, %r4;
    cvt.s64.s32 %rd10, %r4;
    mul.lo.u32 %r25, %r3, 64;
    min.u64 %rd6, %rd10, %rd10;
    and.b32 %r9, %r24, 65535;
    shr.u64 %rd7, %rd6, 31;
    mul.lo.u32 %r16, %r23, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
