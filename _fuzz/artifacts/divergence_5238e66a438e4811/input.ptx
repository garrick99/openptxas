.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r4, %r3, %r3, %r3;
    add.s32 %r6, %r4, %r4;
    cvt.u64.u32 %rd5, %r6;
    mul.lo.u64 %rd11, %rd5, %rd5;
    mul.wide.u32 %rd15, %r3, %r3;
    shr.u32 %r21, %r6, 2;
    cvt.s64.s32 %rd9, %r21;
    min.u32 %r23, %r21, 65536;
    mul.wide.u32 %rd7, %r4, %r21;
    setp.ne.s32 %p3, %r21, 3;
    @!%p3 cvt.u32.u64 %r16, %rd15;
    cvt.u64.u32 %rd15, %r23;
    sub.s32 %r22, %r16, %r23;
    mad.lo.s32 %r11, %r3, %r23, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
