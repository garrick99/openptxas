.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    shr.u64 %rd13, %rd8, 32;
    and.b64 %rd15, %rd13, %rd8;
    shr.u32 %r23, %r3, 1;
    mul.lo.s32 %r19, %r23, %r3;
    sub.s32 %r13, %r3, %r19;
    max.u64 %rd14, %rd13, %rd13;
    shr.s32 %r6, %r13, 1;
    or.b64 %rd5, %rd8, %rd14;
    setp.gt.s32 %p1, %r3, 4;
    @!%p1 add.s32 %r9, %r23, 2147483648;
    min.u64 %rd9, %rd8, %rd15;
    max.s32 %r15, %r13, %r23;
    shl.b64 %rd7, %rd13, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
