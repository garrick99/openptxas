.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r6, %r3, %r3;
    min.s32 %r23, %r6, 65536;
    add.s32 %r6, %r23, %r3;
    shl.b32 %r6, %r23, 16;
    sub.u32 %r9, %r23, %r3;
    mad.lo.s32 %r5, %r9, %r3, %r23;
    mul.wide.u32 %rd5, %r3, %r23;
    xor.b32 %r24, %r6, %r6;
    setp.ne.s32 %p3, %r24, 256;
    max.s32 %r6, %r3, 32;
    xor.b32 %r20, %r9, %r3;
    sub.u32 %r22, %r5, %r23;
    or.b32 %r18, %r22, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
