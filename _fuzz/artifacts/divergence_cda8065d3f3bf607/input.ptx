.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r20, %r3, 16;
    setp.le.u32 %p4, %r20, %r20;
    @%p4 cvt.s64.s32 %rd10, %r20;
    mul.lo.u32 %r20, %r3, 3;
    cvt.u64.u32 %rd5, %r20;
    mul.lo.s32 %r26, %r20, %r20;
    setp.eq.s32 %p1, %r26, %r20;
    @%p1 shl.b32 %r9, %r26, 3;
    mul.wide.u32 %rd13, %r3, %r3;
    mul.wide.s32 %rd5, %r3, %r3;
    shr.u32 %r14, %r9, 15;
    max.s32 %r26, %r9, 4;
    min.s64 %rd12, %rd10, %rd13;
    cvt.u32.u64 %r9, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
