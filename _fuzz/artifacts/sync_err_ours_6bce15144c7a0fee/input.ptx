.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r23, %r3, 4;
    max.u32 %r25, %r3, 5;
    setp.lt.s32 %p1, %r3, %r3;
    @%p1 cvt.u64.u32 %rd6, %r23;
    sub.u32 %r15, %r25, 3;
    shl.b32 %r22, %r23, 3;
    add.s32 %r24, %r15, 256;
    selp.b32 %r14, %r25, %r24, %p1;
    min.u32 %r24, %r14, %r3;
    sub.s32 %r16, %r24, 1;
    cvt.s32.s64 %r13, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
