.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r12, %r3, %r3, %r3;
    cvt.u64.u32 %rd7, %r3;
    max.s32 %r5, %r3, 65535;
    cvt.s32.s64 %r7, %rd7;
    setp.gt.s32 %p2, %r7, %r12;
    @%p2 mul.wide.u32 %rd6, %r7, %r7;
    cvt.u64.u32 %rd8, %r7;
    min.u32 %r24, %r12, %r7;
    mul.lo.u32 %r14, %r24, %r24;
    sub.s64 %rd10, %rd7, %rd6;
    setp.ne.u32 %p3, %r12, %r3;
    @%p3 max.s32 %r26, %r14, 64;
    setp.le.s32 %p1, %r24, %r24;
    @!%p1 shr.u32 %r9, %r24, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
