.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    min.u32 %r24, %r3, 5;
    max.u32 %r9, %r3, 65535;
    cvt.u64.u32 %rd10, %r24;
    xor.b32 %r15, %r24, %r9;
    cvt.s64.s32 %rd10, %r15;
    mad.lo.u32 %r24, %r9, %r24, %r24;
    shr.s32 %r16, %r24, 4;
    sub.u32 %r6, %r3, %r24;
    setp.ne.s32 %p1, %r24, 256;
    @!%p1 max.u32 %r18, %r6, %r3;
    mul.lo.u32 %r14, %r6, %r9;
    shr.s32 %r12, %r15, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
