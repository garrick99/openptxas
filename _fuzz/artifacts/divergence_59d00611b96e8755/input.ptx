.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r19, %r3, 1;
    mul.lo.u32 %r22, %r19, %r19;
    add.u32 %r21, %r22, %r22;
    cvt.u64.u32 %rd10, %r21;
    mad.lo.u32 %r25, %r22, %r19, %r19;
    shr.s32 %r9, %r22, 2;
    add.u32 %r13, %r3, %r19;
    mad.lo.u32 %r26, %r25, %r22, %r25;
    and.b32 %r10, %r21, 65535;
    mad.lo.u32 %r5, %r13, %r25, %r9;
    add.s32 %r8, %r21, 4294967295;
    setp.gt.u32 %p1, %r10, %r22;
    @!%p1 cvt.u32.u64 %r23, %rd10;
    setp.hi.u32 %p1, %r26, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
