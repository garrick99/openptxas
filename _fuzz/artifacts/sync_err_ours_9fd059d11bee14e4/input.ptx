.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r8, %r3, 255;
    mad.lo.u32 %r11, %r8, %r3, %r3;
    mul.wide.u32 %rd11, %r11, %r3;
    add.s32 %r19, %r8, %r3;
    shl.b32 %r22, %r19, 30;
    cvt.u32.u64 %r25, %rd11;
    mul.lo.u32 %r11, %r19, %r25;
    max.s32 %r17, %r22, 4294967295;
    setp.lo.u32 %p2, %r3, 4294967295;
    setp.gt.s32 %p4, %r17, %r25;
    add.s32 %r18, %r17, %r8;
    sub.s32 %r16, %r22, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
