.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r5, %r3, 30;
    add.s32 %r14, %r5, 255;
    max.s32 %r16, %r5, %r14;
    setp.ge.u32 %p3, %r14, %r14;
    @!%p3 cvt.u64.u32 %rd6, %r16;
    shl.b32 %r18, %r3, 4;
    shr.u32 %r23, %r3, 1;
    cvt.s32.s64 %r19, %rd6;
    cvt.u32.u64 %r24, %rd6;
    max.u64 %rd13, %rd6, %rd6;
    xor.b32 %r16, %r19, 5;
    setp.le.u32 %p4, %r18, 32;
    max.u32 %r8, %r16, %r14;
    cvt.s64.s32 %rd10, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
