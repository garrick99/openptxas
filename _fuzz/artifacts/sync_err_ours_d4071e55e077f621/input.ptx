.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r6, %r3, 0;
    add.u32 %r19, %r3, %r6;
    cvt.s64.s32 %rd6, %r3;
    mul.lo.s32 %r21, %r19, %r19;
    xor.b32 %r11, %r21, 255;
    mul.wide.s32 %rd12, %r6, %r21;
    shl.b32 %r4, %r3, 2;
    or.b32 %r15, %r21, 4;
    sub.u32 %r20, %r15, 255;
    min.u32 %r13, %r4, %r20;
    min.u64 %rd11, %rd12, %rd6;
    setp.gt.u32 %p4, %r3, 32;
    @%p4 shr.u64 %rd15, %rd11, 1;
    add.u32 %r7, %r4, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
