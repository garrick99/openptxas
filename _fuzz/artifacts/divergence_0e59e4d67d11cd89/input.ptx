.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r16, %r3, 16;
    shr.s32 %r4, %r3, 0;
    and.b32 %r22, %r4, 2;
    shr.u32 %r17, %r16, 31;
    mul.lo.s32 %r11, %r16, 4;
    setp.lo.u32 %p3, %r11, %r22;
    cvt.u64.u32 %rd10, %r16;
    max.s32 %r13, %r4, 31;
    sub.u32 %r16, %r11, %r17;
    setp.ge.s32 %p3, %r22, 1;
    setp.gt.u32 %p2, %r17, 0;
    @%p2 cvt.u64.u32 %rd5, %r3;
    max.s32 %r5, %r4, 2;
    shr.u64 %rd7, %rd5, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
