.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r22, %r3, 2;
    shr.u32 %r26, %r3, 0;
    shl.b32 %r11, %r26, 1;
    setp.lt.u32 %p4, %r3, 7;
    setp.ne.s32 %p4, %r3, 31;
    @%p4 min.u32 %r4, %r26, %r26;
    cvt.u64.u32 %rd5, %r4;
    add.u32 %r10, %r3, %r4;
    shl.b32 %r23, %r10, 16;
    mul.wide.u32 %rd7, %r4, %r4;
    xor.b32 %r15, %r23, %r3;
    shr.s64 %rd7, %rd5, 4;
    and.b32 %r23, %r11, %r22;
    shr.s64 %rd9, %rd5, 33;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
