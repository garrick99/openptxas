.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r12, %r3, 7;
    cvt.s64.s32 %rd5, %r3;
    sub.s32 %r24, %r12, 2;
    setp.eq.s32 %p4, %r3, 65535;
    @%p4 mul.lo.s32 %r14, %r3, 64;
    and.b32 %r15, %r24, %r24;
    selp.b32 %r23, %r3, %r24, %p4;
    add.s32 %r23, %r23, %r23;
    cvt.s32.s64 %r6, %rd5;
    cvt.u64.u32 %rd11, %r3;
    sub.s32 %r12, %r15, %r12;
    mul.wide.u32 %rd14, %r12, %r15;
    shr.s64 %rd7, %rd11, 15;
    add.s32 %r5, %r15, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
