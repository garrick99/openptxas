.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r15, %r3, %r3;
    add.u32 %r7, %r3, %r3;
    mul.lo.u32 %r27, %r3, 65536;
    mul.wide.u32 %rd5, %r15, %r7;
    cvt.s64.s32 %rd13, %r7;
    mul.lo.u64 %rd6, %rd13, %rd13;
    sub.u32 %r27, %r15, 7;
    and.b32 %r21, %r27, %r7;
    shr.u64 %rd14, %rd5, 47;
    cvt.u64.u32 %rd6, %r21;
    mul.lo.s64 %rd8, %rd6, %rd6;
    min.u32 %r14, %r3, %r15;
    sub.s32 %r11, %r14, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
