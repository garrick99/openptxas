.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r7, %r3, %r3;
    cvt.u64.u32 %rd15, %r7;
    shl.b64 %rd14, %rd15, 47;
    mul.wide.u32 %rd5, %r3, %r7;
    setp.hi.u32 %p4, %r7, %r7;
    @%p4 shr.s32 %r21, %r7, 4;
    max.u32 %r23, %r7, %r7;
    and.b32 %r12, %r3, %r21;
    shl.b32 %r10, %r12, 30;
    shr.s64 %rd10, %rd15, 4;
    max.s32 %r11, %r3, 4294967295;
    mul.lo.u64 %rd8, %rd14, %rd15;
    and.b32 %r21, %r12, 2147483647;
    setp.ge.u32 %p2, %r7, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
