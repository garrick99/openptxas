.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    mul.lo.u32 %r20, %r3, %r3;
    setp.le.s32 %p2, %r20, %r3;
    @%p2 and.b32 %r27, %r20, %r3;
    mad.lo.s32 %r14, %r20, %r20, %r27;
    selp.b32 %r16, %r27, %r27, %p2;
    mul.lo.s64 %rd15, %rd13, %rd13;
    xor.b32 %r12, %r27, %r20;
    mad.lo.u32 %r4, %r27, %r16, %r3;
    shr.u32 %r15, %r14, 1;
    sub.s32 %r6, %r15, 8;
    shr.s64 %rd6, %rd13, 33;
    add.s32 %r27, %r3, %r16;
    mul.lo.u32 %r25, %r15, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
