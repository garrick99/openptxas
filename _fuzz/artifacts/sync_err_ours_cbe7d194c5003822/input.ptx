.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r22, %r3, 2147483647;
    mul.lo.u32 %r9, %r22, %r22;
    max.s32 %r6, %r9, %r3;
    mul.wide.u32 %rd13, %r3, %r22;
    sub.s32 %r21, %r9, %r9;
    setp.gt.u32 %p1, %r9, 32;
    shl.b32 %r23, %r3, 7;
    max.s32 %r13, %r6, 1;
    add.u32 %r11, %r3, %r6;
    mul.lo.u32 %r23, %r3, 8;
    shl.b32 %r17, %r3, 3;
    shr.u64 %rd8, %rd13, 31;
    mul.wide.s32 %rd14, %r11, %r6;
    setp.lt.s32 %p4, %r13, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
