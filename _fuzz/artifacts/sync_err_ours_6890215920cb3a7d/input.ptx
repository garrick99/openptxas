.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    shr.u32 %r6, %r3, 15;
    setp.gt.s32 %p4, %r3, %r3;
    @%p4 or.b32 %r14, %r6, 0;
    min.s32 %r13, %r3, 65535;
    add.s32 %r13, %r3, 15;
    or.b32 %r5, %r3, 63;
    shr.s64 %rd9, %rd7, 7;
    mul.wide.u32 %rd13, %r5, %r14;
    max.s32 %r25, %r5, 65536;
    selp.b32 %r25, %r14, %r14, %p4;
    xor.b64 %rd11, %rd13, %rd7;
    xor.b32 %r10, %r25, 16;
    mul.lo.s32 %r6, %r10, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
