.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r8, %r3, %r3, %r3;
    max.s32 %r21, %r8, 4294967295;
    max.u32 %r7, %r3, 15;
    mad.lo.s32 %r19, %r21, %r3, %r3;
    min.u32 %r25, %r8, %r21;
    add.s32 %r23, %r7, %r7;
    mul.wide.u32 %rd15, %r21, %r19;
    cvt.u32.u64 %r19, %rd15;
    min.s32 %r10, %r25, %r25;
    mul.lo.u32 %r26, %r19, %r7;
    mul.wide.u32 %rd15, %r21, %r21;
    mul.lo.u32 %r14, %r7, %r23;
    max.s32 %r12, %r14, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
