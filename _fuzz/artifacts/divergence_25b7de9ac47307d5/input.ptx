.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r24, %r3, 30;
    max.u32 %r17, %r3, 255;
    setp.lt.s32 %p3, %r24, 5;
    @%p3 and.b32 %r10, %r17, 256;
    and.b32 %r18, %r3, 65535;
    setp.lt.u32 %p3, %r18, %r17;
    @!%p3 mad.lo.u32 %r16, %r3, %r24, %r3;
    and.b32 %r17, %r16, %r18;
    shr.u32 %r26, %r10, 30;
    sub.u32 %r5, %r16, %r26;
    cvt.u64.u32 %rd6, %r16;
    selp.b32 %r16, %r26, %r16, %p3;
    sub.u64 %rd13, %rd6, %rd6;
    cvt.s64.s32 %rd7, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
