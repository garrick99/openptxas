.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd9, %r3, %r3;
    shl.b64 %rd12, %rd9, 2;
    sub.u64 %rd5, %rd12, %rd12;
    shr.s64 %rd15, %rd5, 30;
    max.s32 %r24, %r3, %r3;
    sub.u32 %r26, %r24, %r24;
    mul.wide.s32 %rd5, %r24, %r3;
    add.u32 %r22, %r24, %r24;
    mul.wide.s32 %rd11, %r26, %r24;
    shl.b32 %r9, %r24, 7;
    xor.b32 %r13, %r26, 32;
    sub.u32 %r17, %r26, %r3;
    mul.lo.s32 %r13, %r24, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
