.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r19, %r3, 1;
    sub.u32 %r11, %r3, %r19;
    cvt.s64.s32 %rd14, %r3;
    max.s64 %rd14, %rd14, %rd14;
    cvt.u64.u32 %rd13, %r11;
    and.b64 %rd5, %rd13, %rd14;
    shr.s32 %r25, %r19, 2;
    mul.lo.s32 %r7, %r19, 16;
    or.b64 %rd15, %rd13, %rd14;
    setp.ls.u32 %p4, %r19, %r11;
    mul.wide.u32 %rd11, %r3, %r25;
    cvt.u32.u64 %r25, %rd13;
    sub.s64 %rd8, %rd14, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
