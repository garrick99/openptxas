.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r4, %r3, 3;
    setp.lt.u32 %p4, %r4, %r3;
    @!%p4 cvt.s64.s32 %rd5, %r4;
    max.s32 %r26, %r4, 65535;
    xor.b32 %r18, %r26, %r26;
    setp.ne.u32 %p4, %r26, 1;
    @%p4 and.b64 %rd15, %rd5, %rd5;
    add.s32 %r21, %r18, %r3;
    max.s32 %r7, %r26, 1;
    or.b32 %r17, %r21, %r18;
    min.s32 %r11, %r7, 256;
    min.s32 %r13, %r7, 5;
    cvt.s64.s32 %rd11, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
