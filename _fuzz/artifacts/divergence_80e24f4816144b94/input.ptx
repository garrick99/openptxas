.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r19, %r3, %r3;
    max.u32 %r19, %r19, 63;
    cvt.s64.s32 %rd6, %r19;
    min.u32 %r17, %r3, %r19;
    setp.lt.u32 %p1, %r17, 31;
    @%p1 cvt.u32.u64 %r5, %rd6;
    max.u32 %r9, %r5, 63;
    shr.u64 %rd8, %rd6, 48;
    selp.b32 %r7, %r17, %r5, %p1;
    max.u32 %r13, %r17, 7;
    add.u32 %r4, %r19, 5;
    selp.b32 %r5, %r9, %r9, %p1;
    mad.lo.u32 %r12, %r5, %r9, %r5;
    shr.u64 %rd6, %rd8, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
