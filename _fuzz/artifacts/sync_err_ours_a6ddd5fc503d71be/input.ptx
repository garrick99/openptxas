.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r6, %r3, 16;
    mul.wide.u32 %rd9, %r3, %r3;
    min.s32 %r20, %r3, 5;
    mul.lo.s32 %r13, %r20, 32;
    cvt.s64.s32 %rd9, %r6;
    min.s32 %r11, %r6, %r13;
    setp.lt.u32 %p4, %r11, 31;
    @!%p4 sub.u32 %r21, %r3, %r20;
    min.u64 %rd5, %rd9, %rd9;
    max.s32 %r24, %r20, 64;
    selp.b32 %r16, %r21, %r3, %p4;
    sub.u32 %r17, %r13, 2;
    shr.u32 %r7, %r11, 0;
    shr.s32 %r5, %r7, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
