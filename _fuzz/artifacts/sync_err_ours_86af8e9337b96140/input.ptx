.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r17, %r3, %r3, %r3;
    mul.lo.s32 %r12, %r3, %r17;
    setp.gt.s32 %p1, %r17, 2;
    @%p1 mul.wide.s32 %rd8, %r12, %r12;
    and.b32 %r25, %r17, %r17;
    sub.s32 %r13, %r17, %r25;
    cvt.s64.s32 %rd9, %r17;
    xor.b32 %r11, %r17, %r12;
    max.s32 %r4, %r11, %r25;
    sub.u32 %r23, %r13, %r3;
    setp.gt.u32 %p2, %r3, %r3;
    mad.lo.u32 %r21, %r25, %r4, %r17;
    max.s64 %rd13, %rd9, %rd8;
    shr.s64 %rd6, %rd13, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
