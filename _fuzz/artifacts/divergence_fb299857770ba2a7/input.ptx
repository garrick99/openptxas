.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r12, %r3, %r3;
    cvt.u64.u32 %rd10, %r3;
    setp.lt.s32 %p4, %r12, %r3;
    setp.ne.u32 %p4, %r12, %r12;
    @%p4 xor.b32 %r16, %r3, %r3;
    xor.b32 %r11, %r12, 65536;
    selp.b32 %r25, %r16, %r16, %p4;
    and.b32 %r22, %r25, %r25;
    shr.u32 %r19, %r12, 2;
    mad.lo.s32 %r18, %r19, %r19, %r19;
    cvt.u64.u32 %rd13, %r25;
    setp.eq.s32 %p3, %r18, 5;
    @!%p3 min.u32 %r15, %r3, %r25;
    max.u32 %r22, %r12, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
