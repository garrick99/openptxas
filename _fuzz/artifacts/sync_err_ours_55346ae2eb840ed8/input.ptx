.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r7, %r3, 4294967295;
    setp.ge.u32 %p3, %r3, 7;
    @%p3 xor.b32 %r9, %r7, %r3;
    sub.s32 %r19, %r7, 63;
    max.s32 %r22, %r19, %r9;
    mad.lo.u32 %r6, %r19, %r22, %r9;
    or.b32 %r25, %r22, %r7;
    shr.u32 %r21, %r9, 7;
    selp.b32 %r19, %r21, %r9, %p3;
    or.b32 %r22, %r9, 5;
    min.u32 %r19, %r3, %r6;
    shr.u32 %r27, %r22, 16;
    cvt.s64.s32 %rd7, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
