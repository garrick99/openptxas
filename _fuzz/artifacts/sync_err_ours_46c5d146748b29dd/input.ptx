.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r18, %r3, %r3;
    shr.s32 %r7, %r18, 3;
    cvt.u64.u32 %rd7, %r18;
    mad.lo.s32 %r9, %r3, %r3, %r3;
    min.s32 %r13, %r7, %r7;
    or.b32 %r17, %r18, %r18;
    shr.s64 %rd5, %rd7, 31;
    shr.s32 %r25, %r9, 31;
    min.s32 %r22, %r3, 15;
    min.u32 %r5, %r18, %r22;
    sub.s32 %r6, %r13, %r9;
    shr.s32 %r25, %r7, 1;
    setp.eq.s32 %p3, %r7, %r17;
    @%p3 max.s32 %r8, %r3, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
