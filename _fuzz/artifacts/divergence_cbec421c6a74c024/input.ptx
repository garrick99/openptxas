.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r27, %r3, 64;
    mul.lo.s32 %r5, %r3, %r27;
    shl.b32 %r27, %r3, 31;
    shr.u32 %r7, %r27, 30;
    cvt.s64.s32 %rd10, %r3;
    shr.s64 %rd15, %rd10, 47;
    mul.lo.s64 %rd13, %rd15, %rd15;
    cvt.s32.s64 %r19, %rd13;
    shr.u64 %rd15, %rd10, 2;
    min.u32 %r9, %r7, 256;
    mad.lo.s32 %r4, %r7, %r9, %r5;
    cvt.s32.s64 %r13, %rd15;
    max.u32 %r14, %r7, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
