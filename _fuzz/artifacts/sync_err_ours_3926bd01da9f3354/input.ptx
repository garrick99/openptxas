.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd5, %r3, %r3;
    cvt.s64.s32 %rd9, %r3;
    or.b32 %r21, %r3, %r3;
    min.s32 %r16, %r3, %r3;
    min.u32 %r10, %r21, %r16;
    setp.lt.u32 %p4, %r16, 64;
    shl.b32 %r14, %r21, 31;
    min.s32 %r25, %r16, 63;
    mul.lo.u32 %r20, %r25, 256;
    mul.lo.s32 %r16, %r10, 31;
    shr.u32 %r22, %r3, 7;
    setp.ls.u32 %p2, %r20, %r22;
    @%p2 shr.u32 %r11, %r16, 3;
    add.s64 %rd15, %rd5, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
