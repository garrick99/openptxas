.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r27, %r3, %r3;
    mul.wide.u32 %rd6, %r27, %r3;
    add.s32 %r27, %r27, %r3;
    cvt.s64.s32 %rd12, %r27;
    and.b32 %r24, %r27, 31;
    sub.u32 %r15, %r27, %r24;
    mad.lo.s32 %r9, %r24, %r27, %r15;
    shr.s32 %r6, %r9, 3;
    shr.s64 %rd5, %rd12, 1;
    mul.lo.u32 %r19, %r27, 255;
    mul.wide.u32 %rd14, %r27, %r6;
    cvt.s64.s32 %rd12, %r27;
    min.u32 %r8, %r24, 4294967295;
    mad.lo.u32 %r9, %r9, %r8, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
