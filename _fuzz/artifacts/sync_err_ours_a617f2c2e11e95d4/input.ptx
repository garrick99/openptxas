.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    or.b32 %r20, %r3, %r3;
    min.s32 %r24, %r3, %r3;
    shr.s32 %r25, %r20, 4;
    shl.b64 %rd11, %rd11, 7;
    shl.b32 %r18, %r20, 4;
    min.s32 %r8, %r18, 1;
    cvt.u32.u64 %r26, %rd11;
    setp.ge.u32 %p3, %r18, 4;
    @%p3 shr.s64 %rd6, %rd11, 63;
    shr.u32 %r11, %r3, 16;
    sub.s32 %r11, %r8, 64;
    cvt.u32.u64 %r17, %rd6;
    cvt.u32.u64 %r10, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
