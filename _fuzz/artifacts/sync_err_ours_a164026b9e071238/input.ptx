.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    shr.s32 %r6, %r3, 7;
    add.u32 %r19, %r3, %r3;
    sub.u64 %rd9, %rd11, %rd11;
    max.s32 %r24, %r6, %r19;
    cvt.u32.u64 %r19, %rd11;
    shr.u32 %r15, %r6, 3;
    and.b64 %rd14, %rd9, %rd9;
    min.u32 %r24, %r24, %r15;
    shr.s64 %rd10, %rd9, 62;
    shr.u32 %r27, %r6, 16;
    mul.lo.u64 %rd14, %rd14, %rd11;
    mad.lo.u32 %r5, %r24, %r15, %r3;
    cvt.u64.u32 %rd13, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
