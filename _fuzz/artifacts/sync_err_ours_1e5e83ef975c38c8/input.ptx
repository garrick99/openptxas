.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p2, %r3, %r3;
    @!%p2 sub.s32 %r20, %r3, %r3;
    sub.u32 %r5, %r20, %r3;
    min.u32 %r11, %r20, %r5;
    setp.le.s32 %p2, %r11, 255;
    @%p2 cvt.u64.u32 %rd15, %r20;
    min.u32 %r17, %r11, %r11;
    max.u32 %r20, %r17, %r20;
    shr.u32 %r18, %r17, 4;
    and.b32 %r27, %r5, %r3;
    mul.lo.s64 %rd8, %rd15, %rd15;
    mul.lo.u32 %r16, %r17, %r18;
    max.u64 %rd13, %rd8, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
