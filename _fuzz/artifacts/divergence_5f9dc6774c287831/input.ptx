    setp.ge.u32 %p3, %r9, %r4;
    vote.sync.ballot.b32 %r14, %p3, -1;
    shfl.sync.up.b32 %r4, %r19, 2, 0x1f, -1;
    shfl.sync.idx.b32 %r9, %r19, 1, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
