.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r7, %r3, %r3, %r3;
    cvt.u64.u32 %rd7, %r3;
    mad.lo.u32 %r15, %r3, %r7, %r3;
    xor.b32 %r8, %r15, 255;
    add.u32 %r21, %r3, %r7;
    min.s32 %r8, %r21, 16;
    sub.s32 %r24, %r3, %r3;
    shl.b64 %rd12, %rd7, 48;
    shl.b64 %rd13, %rd7, 47;
    shr.s32 %r13, %r3, 30;
    add.s32 %r23, %r8, %r7;
    cvt.s64.s32 %rd12, %r21;
    max.s32 %r12, %r15, 7;
    cvt.s64.s32 %rd8, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
