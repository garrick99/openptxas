.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    max.s32 %r23, %r3, 15;
    shr.u64 %rd11, %rd13, 31;
    mad.lo.u32 %r20, %r3, %r23, %r3;
    shr.s64 %rd8, %rd13, 2;
    mul.lo.s32 %r7, %r23, %r3;
    cvt.s32.s64 %r23, %rd13;
    add.u32 %r5, %r23, %r23;
    mul.lo.u32 %r25, %r20, %r5;
    shl.b32 %r12, %r5, 1;
    sub.u64 %rd9, %rd11, %rd11;
    mad.lo.u32 %r16, %r25, %r25, %r3;
    add.s32 %r12, %r20, %r7;
    add.s64 %rd13, %rd9, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
