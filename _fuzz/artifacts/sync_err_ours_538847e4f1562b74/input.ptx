.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    sub.u32 %r23, %r3, %r3;
    mad.lo.s32 %r9, %r3, %r3, %r23;
    shr.u64 %rd14, %rd13, 0;
    mul.wide.s32 %rd13, %r9, %r9;
    shl.b64 %rd15, %rd14, 33;
    setp.lt.s32 %p3, %r3, 32;
    selp.b32 %r18, %r9, %r23, %p3;
    cvt.u32.u64 %r18, %rd14;
    shl.b64 %rd9, %rd13, 48;
    min.s64 %rd12, %rd13, %rd15;
    min.u32 %r17, %r18, 0;
    sub.u64 %rd8, %rd9, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
