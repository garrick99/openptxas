.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r4, %r3, 3;
    add.u32 %r18, %r4, 63;
    shr.s32 %r22, %r3, 4;
    setp.ls.u32 %p1, %r22, %r3;
    cvt.u64.u32 %rd11, %r18;
    shr.s32 %r10, %r22, 15;
    setp.gt.s32 %p3, %r10, %r4;
    min.s32 %r5, %r22, 3;
    mul.lo.s32 %r22, %r5, 3;
    shr.s64 %rd11, %rd11, 0;
    mad.lo.s32 %r17, %r5, %r22, %r10;
    cvt.u32.u64 %r7, %rd11;
    add.u64 %rd7, %rd11, %rd11;
    selp.b32 %r14, %r7, %r17, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
