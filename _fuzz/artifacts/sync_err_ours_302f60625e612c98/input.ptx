    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    shr.u32 %r7, %r3, 30;
    shl.b32 %r10, %r3, 4;
    shr.s64 %rd5, %rd15, 7;
