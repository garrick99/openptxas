.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd13, %r3, %r3;
    add.u32 %r10, %r3, %r3;
    cvt.s64.s32 %rd14, %r3;
    min.s32 %r14, %r10, %r3;
    shr.u64 %rd10, %rd14, 15;
    mad.lo.s32 %r17, %r10, %r14, %r10;
    add.s32 %r10, %r14, 64;
    sub.s32 %r20, %r3, %r17;
    shl.b32 %r9, %r14, 1;
    shr.u64 %rd13, %rd14, 4;
    xor.b32 %r6, %r14, %r17;
    max.s32 %r23, %r17, 64;
    mul.lo.u32 %r20, %r20, %r10;
    mad.lo.u32 %r4, %r6, %r20, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
