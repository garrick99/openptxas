.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p1, %r3, 8;
    @!%p1 cvt.s64.s32 %rd11, %r3;
    shr.s64 %rd9, %rd11, 32;
    sub.u32 %r25, %r3, %r3;
    mul.lo.s32 %r7, %r25, 16;
    mad.lo.s32 %r6, %r7, %r7, %r7;
    max.s32 %r4, %r6, 65535;
    add.s32 %r11, %r25, %r25;
    cvt.u32.u64 %r24, %rd9;
    xor.b32 %r4, %r4, %r11;
    cvt.s64.s32 %rd8, %r6;
    selp.b32 %r12, %r6, %r7, %p1;
    max.s32 %r13, %r11, 4;
    sub.u32 %r27, %r24, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
