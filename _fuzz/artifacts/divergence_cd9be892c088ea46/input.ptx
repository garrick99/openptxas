.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r13, %r3, 2;
    shr.u32 %r6, %r3, 30;
    mul.wide.s32 %rd11, %r6, %r13;
    shr.u32 %r23, %r6, 30;
    cvt.u32.u64 %r18, %rd11;
    sub.u32 %r10, %r23, %r6;
    max.u32 %r25, %r23, 15;
    shl.b64 %rd7, %rd11, 48;
    cvt.u64.u32 %rd5, %r3;
    add.u32 %r7, %r3, %r13;
    max.u64 %rd6, %rd5, %rd5;
    sub.s32 %r26, %r10, 2;
    sub.u32 %r7, %r25, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
