.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r9, %r3, 5;
    cvt.s64.s32 %rd15, %r9;
    or.b32 %r5, %r3, 5;
    min.s32 %r24, %r3, %r9;
    shr.u32 %r7, %r24, 7;
    shl.b64 %rd12, %rd15, 15;
    sub.u32 %r17, %r24, 4;
    and.b64 %rd8, %rd12, %rd12;
    max.s64 %rd6, %rd12, %rd15;
    or.b32 %r26, %r9, %r3;
    mul.wide.s32 %rd6, %r3, %r24;
    mad.lo.s32 %r13, %r3, %r24, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
