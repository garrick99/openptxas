.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    add.s32 %r7, %r3, %r3;
    sub.s32 %r10, %r7, 4;
    shr.s32 %r9, %r3, 2;
    cvt.u64.u32 %rd12, %r9;
    shr.s32 %r22, %r3, 0;
    setp.ne.u32 %p4, %r3, %r22;
    @%p4 cvt.s64.s32 %rd10, %r10;
    shl.b64 %rd9, %rd8, 32;
    mad.lo.u32 %r25, %r22, %r3, %r10;
    add.u32 %r5, %r9, %r3;
    mul.wide.s32 %rd10, %r10, %r22;
    sub.s32 %r23, %r10, 15;
    mad.lo.u32 %r7, %r9, %r5, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
