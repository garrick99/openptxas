.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r13, %r3, %r3, %r3;
    cvt.u64.u32 %rd8, %r13;
    cvt.s32.s64 %r4, %rd8;
    mul.wide.s32 %rd13, %r3, %r3;
    mad.lo.s32 %r18, %r13, %r4, %r13;
    max.s32 %r21, %r4, %r3;
    cvt.u32.u64 %r6, %rd8;
    mul.lo.s64 %rd5, %rd8, %rd8;
    setp.gt.s32 %p4, %r13, %r18;
    or.b32 %r20, %r21, 65535;
    xor.b32 %r9, %r4, %r6;
    cvt.u32.u64 %r26, %rd5;
    sub.s32 %r5, %r21, 32;
    cvt.u32.u64 %r5, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
