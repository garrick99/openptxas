.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r10, %r0, %r3;
    shfl.sync.bfly.b32 %r5, %r0, 2, 0x1f, -1;
    add.u32 %r9, %r5, %r10;
    shfl.sync.down.b32 %r6, %r10, 4, 0x1f, -1;
    shfl.sync.down.b32 %r11, %r3, 8, 0x1f, -1;
    setp.le.u32 %p3, %r5, %r5;
    vote.sync.ballot.b32 %r17, %p3, -1;
    shfl.sync.idx.b32 %r19, %r11, 15, 0x1f, -1;
    vote.sync.all.pred %p2, %p3, -1;
    add.u32 %r18, %r10, %r19;
    xor.b32 %r12, %r3, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
