.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r7, %r3, 31;
    shl.b32 %r21, %r7, 15;
    setp.ge.s32 %p4, %r7, %r3;
    cvt.s64.s32 %rd14, %r7;
    shr.u64 %rd13, %rd14, 33;
    add.s32 %r24, %r21, 64;
    shr.u32 %r10, %r3, 3;
    mul.lo.s32 %r4, %r24, 64;
    sub.u64 %rd9, %rd13, %rd14;
    sub.u64 %rd13, %rd14, %rd9;
    setp.ge.u32 %p1, %r21, %r7;
    @!%p1 max.s32 %r12, %r24, %r24;
    setp.eq.s32 %p1, %r7, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
