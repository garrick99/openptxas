.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r23, %r3, %r3;
    add.s32 %r27, %r3, 1;
    cvt.u64.u32 %rd6, %r23;
    max.u64 %rd14, %rd6, %rd6;
    mul.lo.u32 %r15, %r27, %r27;
    cvt.s32.s64 %r13, %rd6;
    shr.u32 %r6, %r23, 31;
    add.u32 %r11, %r23, 15;
    cvt.u32.u64 %r25, %rd6;
    shl.b32 %r12, %r23, 1;
    setp.ge.u32 %p2, %r12, 16;
    @%p2 mad.lo.u32 %r5, %r3, %r25, %r3;
    mul.wide.s32 %rd11, %r23, %r13;
    shr.s64 %rd10, %rd11, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
