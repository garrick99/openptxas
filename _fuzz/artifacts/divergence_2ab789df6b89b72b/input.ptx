.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r5, %r3, %r3;
    max.s32 %r14, %r5, %r3;
    setp.ne.s32 %p4, %r3, 7;
    @!%p4 cvt.s64.s32 %rd9, %r5;
    sub.u64 %rd10, %rd9, %rd9;
    shl.b64 %rd14, %rd9, 62;
    mad.lo.u32 %r7, %r5, %r14, %r14;
    min.u32 %r14, %r7, 64;
    setp.ge.s32 %p2, %r5, 3;
    @%p2 shr.u64 %rd5, %rd9, 16;
    mul.wide.s32 %rd14, %r7, %r14;
    selp.b32 %r4, %r7, %r3, %p4;
    xor.b32 %r19, %r14, %r4;
    mul.wide.u32 %rd15, %r7, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
