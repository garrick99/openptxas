.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    setp.gt.s32 %p1, %r3, 63;
    @%p1 min.u32 %r19, %r3, %r3;
    shr.s64 %rd6, %rd10, 30;
    sub.u32 %r6, %r19, 256;
    and.b32 %r27, %r6, 2;
    xor.b64 %rd6, %rd10, %rd6;
    cvt.s64.s32 %rd13, %r3;
    shl.b64 %rd14, %rd6, 3;
    sub.s64 %rd13, %rd13, %rd13;
    sub.u32 %r12, %r19, 2147483648;
    mul.lo.s32 %r4, %r12, %r3;
    mul.wide.s32 %rd13, %r6, %r12;
    add.u32 %r26, %r19, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
