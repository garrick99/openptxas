.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p1, %r3, 4294967295;
    @%p1 mul.wide.u32 %rd15, %r3, %r3;
    max.s32 %r18, %r3, 4294967295;
    shr.s64 %rd12, %rd15, 62;
    cvt.s32.s64 %r8, %rd12;
    min.u32 %r13, %r8, %r3;
    max.s32 %r24, %r18, %r8;
    setp.ge.u32 %p1, %r3, %r8;
    shr.s64 %rd12, %rd15, 30;
    selp.b32 %r13, %r18, %r24, %p1;
    cvt.s64.s32 %rd12, %r3;
    setp.lt.s32 %p3, %r18, 64;
    @%p3 sub.s64 %rd8, %rd12, %rd12;
    add.s32 %r21, %r18, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
