.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r20, %r3, %r3;
    max.s32 %r26, %r3, %r20;
    sub.u32 %r17, %r3, %r20;
    shr.u32 %r10, %r3, 1;
    mad.lo.u32 %r12, %r10, %r20, %r26;
    shr.u32 %r12, %r12, 4;
    shr.u32 %r27, %r10, 7;
    max.s32 %r4, %r17, %r20;
    cvt.s64.s32 %rd5, %r17;
    sub.s32 %r17, %r26, %r4;
    xor.b32 %r7, %r3, %r4;
    setp.eq.s32 %p1, %r4, 8;
    @%p1 max.s32 %r22, %r26, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
