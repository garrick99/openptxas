.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfe.s32 %r7, %r3, 0, 4;
    bfe.u32 %r18, %r7, 31, 7;
    bfi.b32 %r21, %r3, %r7, 15, 8;
    popc.b32 %r4, %r3;
    popc.b32 %r7, %r21;
    bfe.u32 %r12, %r7, 7, 32;
    add.u32 %r15, %r3, %r18;
    bfe.s32 %r16, %r7, 0, 8;
    brev.b32 %r23, %r15;
    brev.b32 %r20, %r18;
    bfe.s32 %r8, %r7, 16, 4;
    popc.b32 %r23, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
