.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r14, %r3, %r3, %r3;
    max.s32 %r14, %r3, 2;
    xor.b32 %r11, %r14, 64;
    max.u32 %r13, %r14, %r3;
    mad.lo.u32 %r13, %r3, %r14, %r14;
    mul.wide.u32 %rd13, %r14, %r13;
    setp.eq.u32 %p4, %r11, %r14;
    @!%p4 mul.wide.s32 %rd14, %r11, %r3;
    xor.b32 %r10, %r14, 2;
    shr.u32 %r7, %r14, 7;
    and.b64 %rd5, %rd13, %rd14;
    mul.lo.u32 %r18, %r13, %r10;
    max.s32 %r23, %r7, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
