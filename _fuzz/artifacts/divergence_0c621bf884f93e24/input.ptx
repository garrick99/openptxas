.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r19, %r3, 15;
    sub.s32 %r11, %r3, %r3;
    shl.b32 %r15, %r3, 3;
    setp.le.s32 %p3, %r11, %r3;
    @%p3 xor.b32 %r14, %r15, %r19;
    setp.hs.u32 %p2, %r19, 5;
    cvt.s64.s32 %rd13, %r11;
    add.s32 %r9, %r14, %r15;
    mad.lo.s32 %r13, %r15, %r3, %r11;
    sub.s32 %r21, %r19, %r3;
    max.u32 %r10, %r11, %r19;
    mad.lo.s32 %r26, %r13, %r3, %r11;
    shl.b32 %r5, %r13, 31;
    mul.lo.s32 %r21, %r19, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
