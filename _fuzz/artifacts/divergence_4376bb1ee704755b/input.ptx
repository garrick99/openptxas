.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    shr.s64 %rd15, %rd12, 4;
    shl.b64 %rd8, %rd12, 2;
    mul.lo.s32 %r24, %r3, %r3;
    cvt.s64.s32 %rd12, %r3;
    setp.hi.u32 %p1, %r24, %r24;
    @%p1 max.s32 %r20, %r24, 32;
    selp.b32 %r19, %r20, %r20, %p1;
    shl.b32 %r13, %r20, 4;
    shl.b32 %r14, %r13, 15;
    min.s32 %r20, %r14, 31;
    min.s32 %r10, %r20, 256;
    mul.wide.s32 %rd11, %r14, %r19;
    mul.lo.s32 %r6, %r14, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
