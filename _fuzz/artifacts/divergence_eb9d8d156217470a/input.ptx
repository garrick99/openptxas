.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p3, %r3, 65535;
    @!%p3 sub.u32 %r21, %r3, 1;
    mul.lo.s32 %r15, %r3, 5;
    max.s32 %r13, %r21, 15;
    max.u32 %r19, %r21, 3;
    mul.wide.s32 %rd9, %r3, %r13;
    mul.lo.u32 %r8, %r13, %r15;
    add.u32 %r21, %r13, %r15;
    shr.s64 %rd12, %rd9, 15;
    sub.s32 %r7, %r19, 5;
    mad.lo.s32 %r25, %r15, %r8, %r3;
    mul.lo.s32 %r17, %r21, %r21;
    sub.u32 %r25, %r21, %r25;
    min.u32 %r8, %r21, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
