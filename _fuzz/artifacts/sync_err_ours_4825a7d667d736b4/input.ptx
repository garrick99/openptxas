.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd6, %r3, %r3;
    shl.b32 %r7, %r3, 2;
    setp.ne.s32 %p3, %r3, 63;
    @!%p3 mul.lo.s32 %r14, %r3, %r3;
    shl.b32 %r27, %r3, 3;
    cvt.s32.s64 %r12, %rd6;
    mul.wide.u32 %rd7, %r12, %r14;
    or.b32 %r7, %r12, %r14;
    add.s32 %r10, %r7, %r3;
    and.b64 %rd8, %rd7, %rd7;
    mul.wide.s32 %rd12, %r3, %r7;
    add.s32 %r14, %r7, 2147483647;
    setp.lo.u32 %p2, %r14, %r14;
    and.b32 %r21, %r14, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
