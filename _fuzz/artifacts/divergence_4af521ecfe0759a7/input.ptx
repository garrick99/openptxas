.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r22, %r3, 4294967295;
    cvt.s64.s32 %rd9, %r22;
    mul.wide.s32 %rd8, %r3, %r3;
    mul.wide.s32 %rd12, %r22, %r3;
    shl.b64 %rd7, %rd12, 7;
    setp.ge.s32 %p3, %r22, %r22;
    @!%p3 or.b32 %r16, %r22, %r22;
    max.s32 %r18, %r16, %r16;
    mul.lo.s64 %rd12, %rd7, %rd7;
    max.u32 %r25, %r16, 8;
    add.s32 %r15, %r18, %r3;
    mul.wide.s32 %rd6, %r18, %r15;
    cvt.u64.u32 %rd12, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
