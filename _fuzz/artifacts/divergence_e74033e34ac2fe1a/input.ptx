.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r17, %r3, %r3;
    add.s32 %r4, %r3, 1;
    min.u32 %r17, %r4, %r4;
    or.b32 %r18, %r4, %r3;
    mul.lo.s32 %r17, %r17, %r3;
    cvt.u64.u32 %rd10, %r18;
    or.b32 %r22, %r17, 8;
    setp.ls.u32 %p4, %r3, 5;
    cvt.s32.s64 %r20, %rd10;
    sub.s32 %r24, %r20, %r3;
    selp.b32 %r8, %r24, %r24, %p4;
    selp.b32 %r18, %r17, %r8, %p4;
    selp.b32 %r14, %r4, %r17, %p4;
    shr.s64 %rd5, %rd10, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
