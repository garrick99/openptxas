.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd12, %r3, %r3;
    cvt.s64.s32 %rd14, %r3;
    cvt.u64.u32 %rd13, %r3;
    shl.b32 %r20, %r3, 0;
    or.b32 %r19, %r3, 65536;
    xor.b32 %r9, %r20, 7;
    cvt.s32.s64 %r9, %rd14;
    sub.u32 %r11, %r9, %r9;
    mul.wide.s32 %rd12, %r11, %r3;
    max.s32 %r22, %r20, %r20;
    and.b32 %r9, %r22, %r19;
    mul.wide.u32 %rd10, %r11, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
