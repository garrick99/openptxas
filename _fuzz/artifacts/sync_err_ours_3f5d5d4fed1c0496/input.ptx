.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    mul.lo.s64 %rd15, %rd11, %rd11;
    min.s32 %r6, %r3, 255;
    add.u32 %r10, %r6, %r3;
    shl.b32 %r24, %r6, 30;
    cvt.s32.s64 %r13, %rd11;
    mul.lo.u32 %r12, %r10, %r24;
    mad.lo.u32 %r15, %r6, %r13, %r24;
    mad.lo.s32 %r27, %r24, %r13, %r6;
    add.u64 %rd8, %rd15, %rd11;
    cvt.u64.u32 %rd9, %r13;
    add.u32 %r6, %r3, 1;
    cvt.u32.u64 %r8, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
