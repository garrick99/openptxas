.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r12, %r3, 3;
    cvt.s64.s32 %rd13, %r3;
    mul.wide.s32 %rd14, %r3, %r12;
    min.s32 %r8, %r12, %r12;
    mul.wide.u32 %rd10, %r3, %r8;
    shr.s64 %rd12, %rd14, 62;
    setp.hs.u32 %p1, %r3, %r12;
    @%p1 sub.s32 %r21, %r12, 2;
    selp.b32 %r15, %r3, %r21, %p1;
    shr.s64 %rd5, %rd13, 15;
    min.s32 %r7, %r21, %r21;
    xor.b64 %rd10, %rd12, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
