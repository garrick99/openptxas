.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r6, %r3, %r3;
    max.u32 %r26, %r6, 31;
    add.u32 %r13, %r6, %r3;
    setp.ne.s32 %p1, %r26, 0;
    setp.lo.u32 %p4, %r26, 8;
    mul.lo.u32 %r5, %r13, %r3;
    cvt.u64.u32 %rd6, %r26;
    cvt.u64.u32 %rd9, %r6;
    setp.hi.u32 %p4, %r13, %r3;
    @!%p4 max.s32 %r18, %r3, %r13;
    xor.b32 %r17, %r26, 256;
    sub.s64 %rd9, %rd9, %rd6;
    selp.b32 %r13, %r6, %r26, %p1;
    shr.u32 %r13, %r18, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
