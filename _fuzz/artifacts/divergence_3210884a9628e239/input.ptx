    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r26, %r3, 5;
    setp.ge.u32 %p4, %r3, 2147483648;
    @%p4 and.b32 %r10, %r26, %r26;
    xor.b32 %r7, %r26, 64;
    cvt.s64.s32 %rd7, %r7;
    cvt.s32.s64 %r15, %rd7;
    cvt.s32.s64 %r21, %rd7;
