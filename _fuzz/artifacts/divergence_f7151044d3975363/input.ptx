.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p4, %r3, %r3;
    cvt.u64.u32 %rd9, %r3;
    setp.lt.u32 %p3, %r3, 16;
    @!%p3 cvt.u32.u64 %r14, %rd9;
    mul.lo.s32 %r17, %r3, %r3;
    shl.b64 %rd5, %rd9, 63;
    cvt.s64.s32 %rd6, %r17;
    cvt.u64.u32 %rd6, %r14;
    mad.lo.u32 %r16, %r3, %r17, %r14;
    mul.lo.s32 %r5, %r3, 63;
    shr.u64 %rd14, %rd6, 15;
    min.s32 %r26, %r17, %r14;
    setp.eq.s32 %p3, %r26, 256;
    @%p3 or.b32 %r13, %r16, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
