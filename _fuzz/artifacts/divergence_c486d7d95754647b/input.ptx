.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r16, %r3, 15;
    mad.lo.u32 %r17, %r16, %r3, %r3;
    max.s32 %r17, %r16, %r17;
    mul.lo.s32 %r5, %r3, 4;
    cvt.s64.s32 %rd7, %r3;
    mul.lo.s32 %r25, %r17, 64;
    sub.u32 %r22, %r16, 1;
    shr.u32 %r15, %r17, 2;
    mul.wide.s32 %rd15, %r22, %r5;
    mul.wide.u32 %rd10, %r3, %r5;
    shr.s64 %rd8, %rd15, 0;
    setp.le.s32 %p2, %r15, 0;
    @!%p2 min.u32 %r4, %r17, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
