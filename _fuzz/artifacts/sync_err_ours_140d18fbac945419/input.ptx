.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r25, %r3, 5;
    add.u32 %r16, %r25, %r3;
    cvt.s64.s32 %rd6, %r3;
    min.u32 %r11, %r25, %r25;
    shl.b32 %r15, %r11, 31;
    setp.ls.u32 %p3, %r3, 8;
    setp.ge.s32 %p1, %r25, 7;
    @%p1 or.b32 %r27, %r16, 3;
    mul.lo.u32 %r19, %r15, %r3;
    shr.s32 %r8, %r3, 2;
    sub.u32 %r23, %r3, 8;
    setp.eq.u32 %p4, %r19, 65536;
    min.u32 %r17, %r8, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
