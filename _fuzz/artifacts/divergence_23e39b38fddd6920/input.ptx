.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r16, %r3, 4294967295;
    max.s32 %r7, %r16, 65535;
    mul.lo.u32 %r6, %r16, 3;
    mul.lo.u32 %r24, %r16, 64;
    sub.s32 %r18, %r16, %r16;
    add.s32 %r26, %r3, %r18;
    max.s32 %r19, %r18, 16;
    mad.lo.u32 %r9, %r7, %r19, %r3;
    cvt.s64.s32 %rd5, %r19;
    mul.wide.u32 %rd15, %r18, %r9;
    sub.s32 %r26, %r26, 63;
    min.s64 %rd5, %rd15, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
