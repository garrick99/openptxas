.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r26, %r3, 4294967295;
    shl.b32 %r21, %r3, 30;
    max.s32 %r12, %r3, %r26;
    shl.b32 %r4, %r3, 7;
    xor.b32 %r25, %r26, 2147483647;
    shr.u32 %r14, %r25, 7;
    setp.lt.s32 %p2, %r14, %r21;
    selp.b32 %r26, %r26, %r25, %p2;
    cvt.u64.u32 %rd9, %r12;
    mul.lo.s32 %r4, %r26, 8;
    shr.s32 %r6, %r4, 1;
    shr.u32 %r14, %r6, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
