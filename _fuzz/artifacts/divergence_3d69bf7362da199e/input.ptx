.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd7, %r3, %r3;
    setp.ne.u32 %p4, %r3, 63;
    @!%p4 min.u32 %r26, %r3, %r3;
    mad.lo.s32 %r6, %r3, %r26, %r26;
    mad.lo.s32 %r24, %r3, %r6, %r26;
    setp.eq.s32 %p1, %r3, 1;
    add.s32 %r16, %r26, %r6;
    min.s32 %r15, %r24, %r26;
    shr.s64 %rd10, %rd7, 63;
    mul.lo.s32 %r10, %r26, %r15;
    add.u32 %r20, %r10, %r15;
    mad.lo.u32 %r23, %r20, %r26, %r3;
    mad.lo.u32 %r17, %r20, %r20, %r26;
    shr.s64 %rd12, %rd10, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
