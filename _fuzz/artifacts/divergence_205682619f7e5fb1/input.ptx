.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r9, %r3, %r3;
    setp.le.s32 %p2, %r3, %r3;
    mul.wide.s32 %rd6, %r3, %r9;
    shl.b32 %r20, %r9, 16;
    shl.b32 %r14, %r20, 0;
    mul.wide.u32 %rd14, %r20, %r14;
    mul.wide.u32 %rd5, %r9, %r14;
    cvt.u64.u32 %rd6, %r20;
    or.b32 %r26, %r14, %r20;
    selp.b32 %r11, %r9, %r9, %p2;
    shl.b32 %r11, %r20, 30;
    setp.le.s32 %p1, %r3, 15;
    @!%p1 selp.b32 %r8, %r26, %r26, %p2;
    or.b32 %r7, %r9, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
