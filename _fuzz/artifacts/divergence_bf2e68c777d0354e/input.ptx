.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r15, %r3, %r3;
    mul.wide.s32 %rd11, %r3, %r15;
    setp.hi.u32 %p3, %r3, %r15;
    @%p3 shr.s32 %r12, %r15, 30;
    add.u64 %rd8, %rd11, %rd11;
    xor.b32 %r18, %r12, 65535;
    xor.b32 %r10, %r12, 64;
    add.s32 %r22, %r18, 256;
    setp.eq.s32 %p4, %r18, 8;
    @%p4 sub.s32 %r19, %r12, 31;
    mad.lo.u32 %r19, %r22, %r22, %r12;
    max.u32 %r26, %r15, 15;
    shr.s32 %r27, %r22, 3;
    selp.b32 %r16, %r26, %r12, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
