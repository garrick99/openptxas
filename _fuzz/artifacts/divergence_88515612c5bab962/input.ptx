.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p4, %r3, 2147483647;
    setp.ge.u32 %p3, %r3, %r3;
    @!%p3 and.b32 %r5, %r3, 1;
    min.u32 %r9, %r5, 63;
    add.u32 %r24, %r9, %r9;
    selp.b32 %r10, %r3, %r9, %p3;
    cvt.s64.s32 %rd10, %r3;
    shr.s64 %rd9, %rd10, 3;
    xor.b32 %r4, %r5, %r9;
    setp.ne.s32 %p1, %r10, %r10;
    add.s32 %r24, %r24, %r4;
    sub.s32 %r26, %r4, %r4;
    mul.wide.u32 %rd12, %r26, %r10;
    add.u32 %r27, %r24, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
