.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    popc.b32 %r21, %r3;
    clz.b32 %r11, %r3;
    xor.b32 %r6, %r21, %r11;
    bfi.b32 %r7, %r3, %r21, 0, 4;
    and.b32 %r23, %r3, %r3;
    bfe.s32 %r4, %r11, 31, 8;
    clz.b32 %r4, %r6;
    popc.b32 %r14, %r4;
    bfe.s32 %r18, %r3, 15, 24;
    clz.b32 %r21, %r21;
    bfi.b32 %r8, %r4, %r3, 4, 7;
    brev.b32 %r23, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
