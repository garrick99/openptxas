.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p1, %r3, 0;
    @!%p1 add.s32 %r18, %r3, %r3;
    shl.b32 %r11, %r3, 2;
    and.b32 %r12, %r18, %r3;
    or.b32 %r26, %r18, %r18;
    cvt.u64.u32 %rd12, %r11;
    shr.s32 %r20, %r12, 1;
    sub.s32 %r9, %r20, 4294967295;
    mul.lo.u64 %rd9, %rd12, %rd12;
    shl.b32 %r15, %r26, 0;
    mul.wide.s32 %rd15, %r12, %r12;
    mul.wide.u32 %rd10, %r9, %r20;
    setp.le.u32 %p3, %r9, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
