.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r23, %r3, 65535;
    add.s32 %r11, %r3, 16;
    mul.wide.u32 %rd15, %r3, %r3;
    setp.ge.s32 %p2, %r11, 8;
    @!%p2 cvt.s64.s32 %rd7, %r3;
    shr.s32 %r20, %r3, 0;
    sub.u64 %rd11, %rd15, %rd15;
    shr.s32 %r24, %r20, 15;
    or.b32 %r23, %r23, %r11;
    add.u64 %rd5, %rd7, %rd11;
    mul.lo.u32 %r7, %r20, %r23;
    setp.hs.u32 %p2, %r3, 65535;
    @!%p2 or.b32 %r27, %r3, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
