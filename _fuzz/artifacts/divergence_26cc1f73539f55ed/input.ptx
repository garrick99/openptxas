.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r25, %r3, 5;
    mul.lo.s32 %r24, %r3, %r25;
    sub.s32 %r14, %r24, 5;
    sub.u32 %r16, %r3, %r3;
    cvt.u64.u32 %rd10, %r14;
    mul.wide.s32 %rd15, %r25, %r24;
    max.u32 %r25, %r25, 2147483647;
    setp.eq.s32 %p4, %r16, %r24;
    @%p4 mul.lo.u32 %r17, %r25, 15;
    mul.lo.s32 %r12, %r25, %r14;
    selp.b32 %r12, %r25, %r24, %p4;
    max.s32 %r25, %r12, %r17;
    setp.ge.s32 %p3, %r14, %r3;
    @%p3 sub.u32 %r6, %r12, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
