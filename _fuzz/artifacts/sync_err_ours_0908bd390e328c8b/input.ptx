.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r23, %r3, 1;
    sub.u32 %r9, %r3, %r3;
    add.u32 %r25, %r23, %r3;
    min.s32 %r25, %r25, %r25;
    mul.wide.u32 %rd11, %r25, %r25;
    or.b64 %rd6, %rd11, %rd11;
    add.s32 %r13, %r3, 65535;
    sub.u32 %r4, %r23, %r3;
    cvt.u64.u32 %rd15, %r25;
    mad.lo.u32 %r23, %r3, %r13, %r25;
    xor.b32 %r6, %r9, 65536;
    xor.b32 %r25, %r3, %r4;
    shr.s32 %r17, %r4, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
