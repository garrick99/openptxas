.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r18, %r3, %r3;
    shr.s32 %r7, %r3, 15;
    sub.u32 %r20, %r7, 63;
    min.u32 %r11, %r7, 2;
    sub.u32 %r27, %r11, 255;
    or.b32 %r4, %r18, 31;
    max.s32 %r23, %r11, %r18;
    max.u32 %r17, %r18, %r11;
    shr.s32 %r10, %r11, 16;
    max.s32 %r24, %r10, %r11;
    shr.u32 %r4, %r3, 1;
    setp.ne.s32 %p4, %r27, %r11;
    selp.b32 %r8, %r23, %r23, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
