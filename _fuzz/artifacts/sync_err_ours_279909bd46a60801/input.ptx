.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r15, %r3, 15;
    setp.ge.s32 %p3, %r15, %r15;
    @%p3 shr.u32 %r24, %r3, 2;
    xor.b32 %r14, %r3, %r24;
    sub.s32 %r24, %r3, %r15;
    mul.lo.s32 %r25, %r3, 3;
    max.s32 %r12, %r25, %r24;
    mul.wide.s32 %rd6, %r14, %r25;
    mad.lo.s32 %r17, %r24, %r3, %r12;
    and.b64 %rd10, %rd6, %rd6;
    setp.le.u32 %p2, %r14, 4;
    @%p2 mul.wide.u32 %rd14, %r25, %r25;
    add.s32 %r25, %r15, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
