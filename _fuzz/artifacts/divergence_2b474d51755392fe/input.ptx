.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r11, %r3, 8;
    mul.wide.s32 %rd7, %r3, %r11;
    min.u32 %r5, %r3, %r11;
    mul.lo.s32 %r12, %r3, 4294967295;
    setp.lo.u32 %p3, %r5, 16;
    @%p3 cvt.s64.s32 %rd5, %r5;
    sub.u32 %r24, %r12, 2147483647;
    mad.lo.u32 %r23, %r11, %r12, %r3;
    add.u32 %r18, %r12, %r23;
    selp.b32 %r20, %r12, %r11, %p3;
    sub.u32 %r19, %r3, 2147483647;
    cvt.u64.u32 %rd11, %r19;
    add.u32 %r26, %r12, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
