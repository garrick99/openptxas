.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p3, %r3, 65536;
    @%p3 shl.b32 %r12, %r3, 16;
    setp.le.u32 %p4, %r3, 2;
    @%p4 max.s32 %r21, %r12, 16;
    or.b32 %r26, %r3, 64;
    mad.lo.s32 %r27, %r12, %r3, %r21;
    mul.lo.u32 %r7, %r12, 16;
    mul.wide.s32 %rd10, %r27, %r7;
    min.u32 %r24, %r7, %r7;
    shr.s64 %rd7, %rd10, 7;
    selp.b32 %r6, %r26, %r7, %p4;
    cvt.s64.s32 %rd12, %r27;
    mad.lo.s32 %r25, %r12, %r21, %r6;
    mad.lo.s32 %r15, %r27, %r27, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
