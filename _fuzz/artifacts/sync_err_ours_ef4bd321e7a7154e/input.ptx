.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    max.u32 %r21, %r3, 8;
    max.u32 %r6, %r3, %r21;
    cvt.u32.u64 %r17, %rd14;
    max.u64 %rd11, %rd14, %rd14;
    setp.eq.u32 %p2, %r17, 2;
    @%p2 mul.lo.u64 %rd10, %rd11, %rd14;
    add.s32 %r11, %r6, %r17;
    mad.lo.s32 %r17, %r21, %r17, %r21;
    shl.b64 %rd6, %rd10, 31;
    mul.wide.s32 %rd6, %r17, %r11;
    sub.s32 %r23, %r3, %r3;
    mul.wide.s32 %rd9, %r23, %r17;
    mul.wide.u32 %rd7, %r21, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
