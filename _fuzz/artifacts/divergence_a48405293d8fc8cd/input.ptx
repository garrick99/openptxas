.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p3, %r3, 2147483648;
    @%p3 max.u32 %r4, %r3, 1;
    mad.lo.s32 %r15, %r4, %r3, %r4;
    selp.b32 %r18, %r4, %r3, %p3;
    or.b32 %r4, %r4, %r3;
    sub.s32 %r10, %r15, 2;
    add.u32 %r27, %r18, %r4;
    min.s32 %r21, %r15, 64;
    add.s32 %r21, %r18, %r10;
    min.u32 %r25, %r3, %r15;
    cvt.s64.s32 %rd15, %r4;
    min.u64 %rd12, %rd15, %rd15;
    sub.u32 %r16, %r10, %r25;
    mul.wide.s32 %rd12, %r16, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
