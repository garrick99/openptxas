.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r12, %r3, 8;
    max.u32 %r26, %r12, %r3;
    shr.u32 %r17, %r26, 4;
    add.u32 %r23, %r26, %r17;
    cvt.u64.u32 %rd7, %r23;
    setp.ne.u32 %p2, %r23, %r17;
    @!%p2 shl.b32 %r17, %r12, 4;
    min.s32 %r16, %r26, 256;
    add.s32 %r21, %r12, %r17;
    and.b64 %rd6, %rd7, %rd7;
    and.b32 %r9, %r17, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
