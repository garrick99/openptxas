.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r9, %r3, %r3;
    setp.gt.s32 %p4, %r3, 1;
    @%p4 shr.u32 %r22, %r3, 31;
    cvt.u64.u32 %rd8, %r9;
    shr.u64 %rd9, %rd8, 16;
    cvt.s32.s64 %r11, %rd9;
    sub.s32 %r11, %r22, %r11;
    sub.u32 %r24, %r3, %r3;
    mad.lo.s32 %r6, %r9, %r24, %r24;
    shl.b64 %rd14, %rd9, 1;
    cvt.u64.u32 %rd10, %r22;
    or.b32 %r25, %r11, 15;
    setp.lo.u32 %p1, %r6, %r6;
    @%p1 mul.lo.u32 %r26, %r3, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
