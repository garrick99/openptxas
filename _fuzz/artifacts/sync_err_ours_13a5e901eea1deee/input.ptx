.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    cvt.s32.s64 %r17, %rd11;
    max.s32 %r6, %r17, 2147483648;
    min.u32 %r26, %r6, 1;
    shl.b32 %r26, %r17, 2;
    sub.u32 %r21, %r17, %r26;
    xor.b32 %r21, %r17, %r17;
    add.s64 %rd7, %rd11, %rd11;
    add.s32 %r15, %r17, %r6;
    shl.b32 %r12, %r15, 15;
    min.u32 %r8, %r21, 3;
    max.s32 %r21, %r21, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
