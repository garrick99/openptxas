.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r16, %r3, %r3;
    min.s32 %r24, %r16, %r3;
    mul.wide.u32 %rd9, %r24, %r24;
    cvt.u32.u64 %r26, %rd9;
    setp.eq.s32 %p4, %r24, %r16;
    @!%p4 cvt.u32.u64 %r6, %rd9;
    shr.s32 %r27, %r6, 31;
    min.s32 %r10, %r26, 1;
    max.s32 %r15, %r6, %r26;
    mul.lo.u64 %rd12, %rd9, %rd9;
    mul.lo.s32 %r9, %r15, %r16;
    setp.ls.u32 %p2, %r3, 32;
    @%p2 mad.lo.u32 %r5, %r16, %r27, %r15;
    selp.b32 %r13, %r10, %r3, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
