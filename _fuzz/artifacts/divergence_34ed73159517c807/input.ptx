.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    shr.s64 %rd9, %rd14, 33;
    add.u32 %r11, %r3, 255;
    min.s32 %r21, %r11, 2;
    min.s32 %r4, %r11, %r21;
    mul.wide.s32 %rd13, %r4, %r3;
    sub.u32 %r5, %r11, 65536;
    and.b32 %r21, %r3, 1;
    xor.b32 %r24, %r5, %r3;
    setp.gt.u32 %p3, %r3, %r4;
    @%p3 add.s32 %r14, %r21, 63;
    setp.eq.s32 %p1, %r14, 32;
    cvt.u64.u32 %rd5, %r11;
    add.s64 %rd5, %rd5, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
