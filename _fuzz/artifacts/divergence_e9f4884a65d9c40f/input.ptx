.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r4, %r3, %r3;
    setp.hs.u32 %p2, %r4, %r4;
    @!%p2 mul.wide.u32 %rd7, %r4, %r4;
    shr.u64 %rd12, %rd7, 33;
    add.s32 %r13, %r3, 1;
    min.u32 %r26, %r3, %r13;
    add.s32 %r9, %r4, 4;
    cvt.u64.u32 %rd6, %r3;
    mul.lo.s32 %r27, %r9, 65536;
    max.u32 %r12, %r27, 31;
    mul.lo.s32 %r19, %r9, %r26;
    cvt.u64.u32 %rd14, %r26;
    add.u32 %r17, %r27, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
