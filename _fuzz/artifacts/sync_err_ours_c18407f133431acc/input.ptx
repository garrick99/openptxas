.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    sub.u32 %r11, %r3, 4;
    max.s32 %r17, %r11, 3;
    max.u32 %r27, %r11, %r17;
    and.b32 %r11, %r27, 32;
    sub.u32 %r12, %r3, %r11;
    max.u64 %rd14, %rd14, %rd14;
    or.b32 %r6, %r17, %r27;
    setp.eq.s32 %p2, %r27, %r12;
    @!%p2 max.u32 %r19, %r27, %r6;
    setp.lo.u32 %p4, %r19, 63;
    @%p4 mul.lo.s32 %r22, %r17, 31;
    shr.u32 %r22, %r12, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
