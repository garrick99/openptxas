.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r9, %r3, %r3, %r3;
    setp.hi.u32 %p1, %r9, %r9;
    @%p1 shl.b32 %r7, %r9, 0;
    add.u32 %r20, %r9, 5;
    add.u32 %r25, %r7, 32;
    shr.u32 %r12, %r3, 1;
    add.u32 %r23, %r3, %r3;
    cvt.s64.s32 %rd12, %r7;
    max.u64 %rd14, %rd12, %rd12;
    shr.s32 %r20, %r9, 3;
    mul.lo.s32 %r7, %r3, %r23;
    max.s32 %r10, %r7, %r9;
    cvt.u64.u32 %rd7, %r20;
    sub.s32 %r17, %r10, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
