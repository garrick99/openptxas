.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    cvt.s32.s64 %r19, %rd15;
    mul.lo.s32 %r17, %r3, %r3;
    shr.s64 %rd15, %rd15, 16;
    mul.lo.s32 %r14, %r17, 1;
    cvt.u32.u64 %r27, %rd15;
    setp.gt.u32 %p1, %r3, %r17;
    max.s32 %r27, %r14, %r17;
    xor.b32 %r7, %r19, %r17;
    or.b64 %rd8, %rd15, %rd15;
    add.u32 %r23, %r27, 16;
    setp.lt.u32 %p2, %r17, %r19;
    @!%p2 cvt.s32.s64 %r21, %rd8;
    sub.u64 %rd10, %rd8, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
