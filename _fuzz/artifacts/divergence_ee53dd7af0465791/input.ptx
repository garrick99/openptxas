.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p1, %r3, 63;
    @!%p1 cvt.u64.u32 %rd7, %r3;
    add.s32 %r21, %r3, 2;
    shr.s32 %r10, %r21, 2;
    mul.lo.s32 %r7, %r10, 255;
    mad.lo.s32 %r27, %r10, %r7, %r10;
    mad.lo.s32 %r25, %r21, %r7, %r21;
    setp.lt.u32 %p3, %r21, 256;
    @!%p3 add.u32 %r27, %r3, %r25;
    or.b32 %r9, %r25, %r3;
    setp.le.u32 %p1, %r10, 31;
    @!%p1 mad.lo.u32 %r24, %r21, %r10, %r3;
    setp.le.s32 %p4, %r10, %r21;
    @!%p4 sub.u32 %r5, %r27, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
