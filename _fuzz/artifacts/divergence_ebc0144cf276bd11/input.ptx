.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r15, %r3, 15;
    shr.u32 %r20, %r15, 16;
    mul.lo.s32 %r18, %r15, 15;
    mad.lo.s32 %r14, %r18, %r20, %r18;
    mul.lo.s32 %r19, %r15, %r18;
    setp.ls.u32 %p1, %r19, %r14;
    xor.b32 %r17, %r3, %r18;
    mul.wide.u32 %rd5, %r19, %r19;
    min.u32 %r6, %r14, 7;
    selp.b32 %r26, %r17, %r6, %p1;
    setp.ge.s32 %p3, %r15, 65536;
    setp.ge.s32 %p1, %r19, 65535;
    @%p1 cvt.u32.u64 %r25, %rd5;
    max.s64 %rd12, %rd5, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
