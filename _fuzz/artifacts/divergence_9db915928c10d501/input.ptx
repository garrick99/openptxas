.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p1, %r3, %r3;
    @%p1 max.s32 %r12, %r3, 15;
    max.u32 %r10, %r3, 1;
    mul.lo.s32 %r5, %r12, %r3;
    sub.s32 %r14, %r10, %r5;
    mul.wide.u32 %rd5, %r3, %r14;
    shr.u32 %r26, %r3, 15;
    or.b32 %r20, %r14, %r26;
    cvt.u32.u64 %r9, %rd5;
    setp.eq.u32 %p2, %r9, %r20;
    @%p2 xor.b32 %r18, %r3, %r3;
    mul.lo.s32 %r6, %r26, %r9;
    add.s32 %r17, %r14, 256;
    xor.b32 %r22, %r9, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
