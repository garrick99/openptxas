.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p4, %r3, 5;
    @%p4 shl.b32 %r26, %r3, 3;
    add.s32 %r10, %r3, 1;
    shr.u32 %r5, %r3, 30;
    mad.lo.u32 %r22, %r26, %r5, %r3;
    and.b32 %r26, %r26, %r22;
    cvt.u64.u32 %rd6, %r5;
    and.b32 %r21, %r3, %r26;
    and.b32 %r14, %r10, %r21;
    xor.b64 %rd12, %rd6, %rd6;
    max.u64 %rd6, %rd12, %rd6;
    sub.u32 %r6, %r5, %r21;
    add.s32 %r15, %r14, %r5;
    shr.s64 %rd11, %rd6, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
