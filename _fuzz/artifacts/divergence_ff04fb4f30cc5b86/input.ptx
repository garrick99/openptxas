.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r4, %r3, 3;
    and.b32 %r5, %r3, %r4;
    shr.u32 %r12, %r4, 16;
    and.b32 %r7, %r5, 64;
    cvt.u64.u32 %rd7, %r7;
    and.b32 %r10, %r5, 5;
    cvt.s32.s64 %r19, %rd7;
    and.b64 %rd8, %rd7, %rd7;
    shl.b32 %r8, %r19, 31;
    mul.lo.s32 %r7, %r12, %r8;
    setp.ls.u32 %p1, %r4, 32;
    setp.le.u32 %p2, %r7, 0;
    @!%p2 shr.u32 %r22, %r7, 7;
    shl.b64 %rd11, %rd8, 48;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
