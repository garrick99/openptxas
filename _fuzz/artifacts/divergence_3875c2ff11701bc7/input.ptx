.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    max.u32 %r16, %r3, 16;
    or.b32 %r20, %r16, 2147483648;
    mul.lo.s64 %rd7, %rd12, %rd12;
    add.s32 %r11, %r3, 16;
    cvt.s64.s32 %rd9, %r16;
    sub.u32 %r19, %r16, %r20;
    max.s32 %r4, %r16, 32;
    sub.u32 %r11, %r16, 1;
    setp.eq.s32 %p4, %r20, %r19;
    @%p4 sub.u32 %r23, %r4, %r11;
    cvt.s64.s32 %rd13, %r16;
    add.s64 %rd7, %rd9, %rd7;
    shr.s64 %rd8, %rd9, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
