.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r5, %r3, 63;
    add.s32 %r8, %r5, %r5;
    xor.b32 %r4, %r5, 64;
    sub.s32 %r15, %r3, %r4;
    cvt.s64.s32 %rd15, %r3;
    cvt.s64.s32 %rd10, %r3;
    mul.lo.u64 %rd7, %rd10, %rd15;
    min.u32 %r22, %r8, 65536;
    add.u32 %r15, %r5, 2;
    mul.wide.s32 %rd11, %r22, %r3;
    xor.b32 %r14, %r8, 1;
    max.s32 %r26, %r8, 31;
    add.s64 %rd12, %rd15, %rd15;
    min.u64 %rd15, %rd10, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
