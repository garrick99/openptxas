    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r26, %r3, %r3;
    max.u32 %r22, %r3, %r26;
    add.u32 %r21, %r3, 65536;
    min.u32 %r7, %r3, %r26;
    cvt.u64.u32 %rd13, %r26;
    add.s32 %r25, %r7, %r7;
    and.b32 %r26, %r3, 63;
    add.u32 %r24, %r21, %r26;
    and.b32 %r13, %r3, %r22;
    shr.u32 %r22, %r3, 3;
    shr.s64 %rd9, %rd13, 7;
    setp.ne.u32 %p4, %r26, %r26;
    @%p4 selp.b32 %r9, %r25, %r24, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
