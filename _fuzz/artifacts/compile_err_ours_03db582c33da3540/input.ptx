    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.bfly.b32 %r13, %r3, 2, 0x1f, -1;
    setp.lt.u32 %p1, %r13, 255;
    vote.sync.ballot.b32 %r9, %p1, -1;
    shfl.sync.up.b32 %r19, %r3, 8, 0x1f, -1;
    setp.ge.u32 %p1, %r9, 1;
    vote.sync.ballot.b32 %r12, %p1, -1;
    setp.ge.u32 %p1, %r3, 2;
    vote.sync.ballot.b32 %r8, %p1, -1;
    vote.sync.any.pred %p2, %p1, -1;
    add.u32 %r18, %r9, %r9;
    setp.lt.u32 %p1, %r8, 4294967295;
    vote.sync.ballot.b32 %r16, %p1, -1;
    sub.u32 %r4, %r18, %r9;
    shfl.sync.bfly.b32 %r9, %r8, 2, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
