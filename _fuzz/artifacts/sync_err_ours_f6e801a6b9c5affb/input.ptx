.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    mul.lo.s32 %r9, %r3, 32;
    mad.lo.s32 %r18, %r9, %r9, %r3;
    mul.wide.s32 %rd5, %r9, %r3;
    shr.u32 %r18, %r9, 31;
    mul.lo.u64 %rd7, %rd5, %rd5;
    cvt.s32.s64 %r17, %rd10;
    cvt.s32.s64 %r14, %rd10;
    max.s64 %rd9, %rd5, %rd5;
    mad.lo.u32 %r26, %r17, %r18, %r17;
    cvt.u32.u64 %r18, %rd5;
    cvt.s32.s64 %r26, %rd7;
    xor.b32 %r7, %r14, 255;
    shr.u64 %rd11, %rd9, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
