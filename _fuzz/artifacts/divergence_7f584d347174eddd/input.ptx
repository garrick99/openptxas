.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r25, %r3, %r3;
    max.u32 %r24, %r25, %r25;
    sub.s32 %r17, %r3, 7;
    shl.b32 %r4, %r3, 3;
    shr.u32 %r24, %r3, 0;
    mad.lo.s32 %r15, %r3, %r25, %r3;
    or.b32 %r26, %r17, 4294967295;
    add.s32 %r4, %r26, %r26;
    shr.u32 %r24, %r17, 31;
    setp.ge.u32 %p3, %r24, %r15;
    @%p3 mul.lo.s32 %r13, %r3, %r17;
    cvt.s64.s32 %rd8, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
