.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p1, %r3, 64;
    @%p1 shr.s32 %r25, %r3, 3;
    mul.wide.s32 %rd11, %r3, %r25;
    cvt.u32.u64 %r13, %rd11;
    mul.lo.u32 %r11, %r25, %r13;
    or.b32 %r19, %r11, 7;
    max.u32 %r6, %r13, 8;
    sub.u32 %r27, %r25, 0;
    sub.u32 %r25, %r27, %r3;
    max.u32 %r17, %r19, 3;
    mul.wide.u32 %rd6, %r6, %r13;
    mad.lo.s32 %r14, %r19, %r27, %r3;
    mul.wide.s32 %rd7, %r6, %r14;
    or.b32 %r8, %r13, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
