.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p4, %r3, 63;
    or.b32 %r16, %r3, 256;
    cvt.s64.s32 %rd15, %r16;
    max.s32 %r4, %r3, 65535;
    setp.ge.s32 %p2, %r3, 8;
    @%p2 shr.s64 %rd8, %rd15, 4;
    min.s32 %r7, %r4, %r4;
    cvt.s32.s64 %r22, %rd8;
    and.b32 %r14, %r3, %r7;
    mad.lo.u32 %r5, %r22, %r7, %r4;
    cvt.s64.s32 %rd5, %r4;
    add.u32 %r14, %r22, 16;
    max.s32 %r17, %r3, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
