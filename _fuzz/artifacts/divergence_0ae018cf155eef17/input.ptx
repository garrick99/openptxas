.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p4, %r3, 64;
    cvt.u64.u32 %rd14, %r3;
    add.s64 %rd8, %rd14, %rd14;
    mul.wide.s32 %rd14, %r3, %r3;
    min.s32 %r18, %r3, %r3;
    mul.wide.u32 %rd8, %r18, %r18;
    shr.u32 %r27, %r18, 3;
    setp.ge.s32 %p1, %r18, %r3;
    @!%p1 mad.lo.u32 %r5, %r3, %r18, %r27;
    shl.b32 %r11, %r27, 30;
    mul.wide.s32 %rd12, %r11, %r11;
    mul.wide.u32 %rd8, %r18, %r18;
    max.u32 %r8, %r11, 7;
    cvt.u64.u32 %rd14, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
