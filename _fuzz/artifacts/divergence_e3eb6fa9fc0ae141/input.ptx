.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r9, %r3, %r3;
    setp.eq.u32 %p1, %r9, 1;
    setp.ne.u32 %p2, %r3, 64;
    @%p2 mul.wide.u32 %rd8, %r9, %r3;
    selp.b32 %r11, %r3, %r3, %p2;
    setp.ge.u32 %p3, %r3, 15;
    @!%p3 and.b32 %r8, %r9, 31;
    selp.b32 %r22, %r11, %r8, %p1;
    shr.u64 %rd12, %rd8, 15;
    mad.lo.s32 %r6, %r11, %r8, %r11;
    cvt.u32.u64 %r21, %rd12;
    setp.lt.u32 %p2, %r3, %r9;
    @%p2 add.u32 %r23, %r9, 3;
    max.u64 %rd13, %rd8, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
