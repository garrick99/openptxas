    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfe.s32 %r8, %r3, 1, 1;
    popc.b32 %r22, %r3;
    prmt.b32 %r10, %r3, %r8, 4146;
    popc.b32 %r11, %r8;
    brev.b32 %r22, %r22;
    popc.b32 %r22, %r11;
    bfe.s32 %r14, %r3, 7, 8;
