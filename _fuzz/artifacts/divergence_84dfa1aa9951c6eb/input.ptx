.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r21, %r3, 256;
    or.b32 %r19, %r3, %r21;
    cvt.u64.u32 %rd13, %r19;
    max.u32 %r10, %r19, 15;
    cvt.u64.u32 %rd9, %r3;
    setp.lo.u32 %p3, %r19, 1;
    @!%p3 shr.u32 %r24, %r19, 1;
    mad.lo.s32 %r16, %r10, %r24, %r19;
    add.s32 %r22, %r19, 5;
    max.s32 %r21, %r24, %r10;
    sub.u64 %rd8, %rd9, %rd9;
    cvt.s64.s32 %rd11, %r21;
    selp.b32 %r5, %r24, %r16, %p3;
    sub.s64 %rd8, %rd9, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
