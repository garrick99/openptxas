.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r17, %r3, 64;
    mad.lo.u32 %r7, %r17, %r3, %r3;
    min.u32 %r8, %r3, %r3;
    mul.wide.s32 %rd6, %r8, %r17;
    shr.s32 %r20, %r17, 7;
    mul.wide.u32 %rd5, %r3, %r7;
    and.b32 %r6, %r17, %r20;
    shr.s64 %rd8, %rd5, 0;
    cvt.u64.u32 %rd7, %r6;
    add.u64 %rd15, %rd7, %rd8;
    mad.lo.u32 %r13, %r6, %r8, %r17;
    setp.hs.u32 %p2, %r3, %r17;
    @%p2 cvt.u32.u64 %r11, %rd5;
    max.s64 %rd15, %rd5, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
