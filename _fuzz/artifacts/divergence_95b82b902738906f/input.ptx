.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    mul.lo.s32 %r4, %r3, %r3;
    max.s32 %r25, %r3, 2147483648;
    cvt.s64.s32 %rd12, %r25;
    shr.s64 %rd10, %rd12, 31;
    setp.hs.u32 %p2, %r4, %r3;
    @%p2 shl.b64 %rd5, %rd15, 30;
    setp.ne.s32 %p3, %r3, 255;
    @%p3 xor.b64 %rd15, %rd5, %rd5;
    mul.lo.u32 %r7, %r4, %r25;
    and.b64 %rd10, %rd12, %rd12;
    mul.lo.u32 %r20, %r4, %r25;
    mul.lo.u32 %r4, %r7, %r25;
    setp.eq.s32 %p4, %r4, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
