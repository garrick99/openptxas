.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r15, %r3, %r3;
    setp.ge.u32 %p3, %r3, 65536;
    setp.lt.s32 %p3, %r3, 63;
    @!%p3 max.s32 %r18, %r3, %r15;
    max.s32 %r11, %r15, 15;
    add.u32 %r7, %r15, %r15;
    selp.b32 %r8, %r11, %r11, %p3;
    cvt.s64.s32 %rd11, %r8;
    sub.u32 %r23, %r3, 1;
    shr.u32 %r16, %r15, 7;
    xor.b32 %r27, %r15, %r11;
    setp.gt.s32 %p2, %r3, %r15;
    @%p2 xor.b32 %r4, %r18, 65535;
    shr.s64 %rd8, %rd11, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
