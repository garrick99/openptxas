.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p4, %r3, %r3;
    @%p4 or.b32 %r10, %r3, 4;
    min.s32 %r15, %r3, 4294967295;
    selp.b32 %r17, %r10, %r10, %p4;
    mul.lo.s32 %r11, %r3, 4;
    cvt.u64.u32 %rd14, %r10;
    shr.s32 %r25, %r3, 15;
    min.s32 %r11, %r25, %r17;
    max.u32 %r14, %r17, 31;
    shr.u32 %r21, %r10, 1;
    selp.b32 %r16, %r17, %r25, %p4;
    shl.b32 %r18, %r16, 15;
    setp.eq.s32 %p4, %r15, %r25;
    @%p4 mul.lo.s32 %r22, %r16, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
