.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r8, %r3, 0;
    cvt.s64.s32 %rd15, %r8;
    and.b64 %rd12, %rd15, %rd15;
    mul.lo.u32 %r22, %r3, 31;
    min.u64 %rd5, %rd15, %rd15;
    shr.u32 %r24, %r8, 7;
    and.b32 %r21, %r3, %r22;
    sub.u32 %r10, %r8, %r24;
    mad.lo.s32 %r13, %r24, %r3, %r21;
    xor.b32 %r11, %r21, 65535;
    sub.u32 %r27, %r24, 2147483647;
    mul.lo.s32 %r7, %r11, 65536;
    mad.lo.s32 %r11, %r11, %r21, %r27;
    mul.lo.u32 %r16, %r8, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
