.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    brev.b32 %r8, %r3;
    clz.b32 %r16, %r3;
    clz.b32 %r19, %r3;
    clz.b32 %r5, %r8;
    popc.b32 %r13, %r19;
    bfi.b32 %r17, %r19, %r19, 4, 7;
    popc.b32 %r14, %r8;
    prmt.b32 %r22, %r13, %r19, 17493;
    bfi.b32 %r21, %r3, %r22, 1, 16;
    prmt.b32 %r18, %r5, %r13, 29472;
