.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r27, %r3, 2;
    cvt.s64.s32 %rd12, %r27;
    or.b32 %r21, %r3, 63;
    shl.b32 %r15, %r21, 31;
    sub.s32 %r17, %r27, %r27;
    sub.s32 %r7, %r3, 5;
    cvt.s32.s64 %r26, %rd12;
    min.u32 %r6, %r17, %r7;
    mul.wide.u32 %rd11, %r21, %r27;
    add.s32 %r15, %r15, 4294967295;
    sub.s32 %r25, %r27, 65536;
    mad.lo.u32 %r25, %r21, %r15, %r21;
    shl.b32 %r8, %r26, 4;
    setp.ne.s32 %p4, %r7, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
