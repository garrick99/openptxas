.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r18, %r3, %r3, %r3;
    cvt.u64.u32 %rd5, %r18;
    cvt.s32.s64 %r26, %rd5;
    add.s32 %r9, %r3, 64;
    shl.b32 %r17, %r9, 2;
    max.s32 %r22, %r26, 1;
    min.u32 %r21, %r22, 64;
    setp.lt.u32 %p4, %r22, 65536;
    @%p4 shr.s32 %r26, %r21, 30;
    sub.s32 %r11, %r9, %r17;
    max.u32 %r6, %r18, %r21;
    min.s32 %r18, %r6, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
