.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r12, %r3, 3;
    bfi.b32 %r23, %r3, %r12, 24, 32;
    prmt.b32 %r16, %r23, %r12, 12816;
    bfe.s32 %r20, %r23, 15, 24;
    prmt.b32 %r15, %r20, %r12, 0;
    xor.b32 %r4, %r16, %r12;
    and.b32 %r14, %r15, %r23;
    clz.b32 %r14, %r15;
    bfe.u32 %r19, %r15, 8, 31;
    bfe.u32 %r14, %r16, 0, 24;
    sub.u32 %r7, %r19, 1;
    bfi.b32 %r22, %r20, %r7, 0, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
