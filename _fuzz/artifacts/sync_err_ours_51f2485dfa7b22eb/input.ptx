.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r7, %r3, %r3;
    or.b32 %r4, %r3, 2147483648;
    shr.s32 %r13, %r4, 31;
    shr.u32 %r17, %r3, 30;
    add.s32 %r23, %r7, 65536;
    min.u32 %r15, %r23, 64;
    mad.lo.s32 %r9, %r17, %r3, %r4;
    mul.lo.u32 %r7, %r7, %r9;
    shr.s32 %r27, %r15, 30;
    max.u32 %r7, %r23, %r4;
    add.s32 %r19, %r4, 64;
    max.u32 %r15, %r23, %r7;
    setp.ls.u32 %p4, %r3, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
