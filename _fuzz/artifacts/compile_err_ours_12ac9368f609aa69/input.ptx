.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r14, %r0, %r3;
    setp.ge.u32 %p3, %r0, 1;
    vote.sync.ballot.b32 %r4, %p3, -1;
    shfl.sync.down.b32 %r18, %r0, 4, 0x1f, -1;
    shfl.sync.idx.b32 %r5, %r0, 15, 0x1f, -1;
    shfl.sync.idx.b32 %r9, %r5, 0, 0x1f, -1;
    max.u32 %r7, %r9, %r9;
    shfl.sync.down.b32 %r6, %r18, 4, 0x1f, -1;
    max.u32 %r4, %r9, %r14;
    vote.sync.all.pred %p3, %p3, -1;
    vote.sync.any.pred %p2, %p3, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
