.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r20, %r3, 2147483648;
    sub.s32 %r6, %r20, 256;
    setp.lt.u32 %p1, %r6, 3;
    sub.s32 %r18, %r20, %r6;
    shr.u32 %r11, %r20, 15;
    cvt.u64.u32 %rd11, %r18;
    mul.lo.s32 %r13, %r18, %r18;
    shr.s64 %rd10, %rd11, 33;
    mad.lo.s32 %r16, %r18, %r13, %r6;
    shr.u32 %r22, %r11, 4;
    shl.b32 %r5, %r13, 16;
    setp.le.s32 %p2, %r5, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
