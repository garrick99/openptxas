.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r16, %r3, 255;
    mul.wide.u32 %rd10, %r3, %r16;
    shr.u32 %r10, %r16, 0;
    cvt.s64.s32 %rd7, %r10;
    cvt.u64.u32 %rd12, %r3;
    add.s32 %r14, %r16, %r16;
    and.b32 %r21, %r14, %r14;
    shr.s32 %r24, %r3, 2;
    sub.u32 %r20, %r16, %r21;
    shl.b32 %r8, %r16, 30;
    cvt.s32.s64 %r6, %rd12;
    sub.s32 %r20, %r14, %r6;
    and.b32 %r8, %r8, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
