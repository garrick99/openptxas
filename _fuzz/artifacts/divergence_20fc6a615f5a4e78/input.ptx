.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd13, %r3, %r3;
    min.s64 %rd11, %rd13, %rd13;
    and.b32 %r22, %r3, 64;
    add.u32 %r7, %r22, 64;
    add.s64 %rd15, %rd13, %rd11;
    min.u32 %r26, %r3, %r22;
    shr.s64 %rd10, %rd13, 3;
    setp.le.u32 %p2, %r7, %r7;
    @!%p2 add.s64 %rd5, %rd15, %rd15;
    shl.b32 %r16, %r7, 2;
    shr.s32 %r12, %r26, 15;
    max.s32 %r4, %r26, 4;
    selp.b32 %r18, %r26, %r12, %p2;
    sub.u32 %r14, %r18, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
