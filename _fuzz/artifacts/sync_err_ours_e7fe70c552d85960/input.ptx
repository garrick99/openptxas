.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r6, %r3, 3;
    mul.wide.s32 %rd13, %r6, %r6;
    xor.b32 %r23, %r3, 32;
    cvt.s32.s64 %r8, %rd13;
    min.s32 %r24, %r6, %r8;
    shl.b32 %r17, %r8, 0;
    cvt.u32.u64 %r26, %rd13;
    shr.u32 %r20, %r3, 15;
    min.s32 %r15, %r3, 255;
    and.b32 %r9, %r20, %r15;
    shr.s32 %r19, %r17, 16;
    shl.b32 %r16, %r8, 0;
    or.b32 %r21, %r19, %r23;
    add.u32 %r26, %r21, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
