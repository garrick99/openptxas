.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r20, %r3, %r3;
    mad.lo.u32 %r4, %r3, %r3, %r3;
    mul.wide.s32 %rd7, %r4, %r3;
    shr.s32 %r11, %r20, 1;
    setp.eq.s32 %p4, %r20, 0;
    @%p4 mad.lo.u32 %r10, %r11, %r11, %r11;
    max.u32 %r24, %r4, 31;
    min.u32 %r10, %r10, %r4;
    mad.lo.s32 %r21, %r10, %r20, %r24;
    mad.lo.u32 %r16, %r21, %r4, %r3;
    shr.s32 %r17, %r24, 31;
    xor.b32 %r10, %r3, %r16;
    add.u64 %rd5, %rd7, %rd7;
    mad.lo.s32 %r11, %r4, %r16, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
