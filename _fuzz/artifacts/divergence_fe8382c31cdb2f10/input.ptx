    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r14, %r3, 2;
    sub.s32 %r19, %r3, %r14;
    mul.lo.u32 %r23, %r14, %r19;
    shr.u32 %r25, %r14, 0;
