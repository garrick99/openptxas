.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    mul.lo.u32 %r23, %r3, %r3;
    mul.wide.u32 %rd5, %r23, %r23;
    setp.ne.s32 %p2, %r23, 3;
    @%p2 shl.b64 %rd13, %rd5, 1;
    shr.u32 %r13, %r23, 30;
    mad.lo.u32 %r21, %r3, %r3, %r3;
    sub.u32 %r9, %r13, %r21;
    max.u32 %r15, %r23, %r9;
    add.s32 %r7, %r13, 2;
    min.s64 %rd10, %rd13, %rd13;
    shr.u64 %rd9, %rd5, 47;
    max.s32 %r15, %r9, 1;
    add.s32 %r26, %r15, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
