.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    shr.s64 %rd9, %rd9, 4;
    min.u32 %r15, %r3, 15;
    add.u32 %r4, %r15, 63;
    max.u64 %rd11, %rd9, %rd9;
    shl.b32 %r10, %r4, 1;
    mul.lo.s32 %r25, %r3, %r15;
    xor.b32 %r25, %r15, 63;
    setp.gt.s32 %p1, %r25, 3;
    sub.s32 %r7, %r15, %r3;
    max.s64 %rd9, %rd11, %rd11;
    setp.hi.u32 %p2, %r4, 64;
    @%p2 sub.s32 %r23, %r4, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
