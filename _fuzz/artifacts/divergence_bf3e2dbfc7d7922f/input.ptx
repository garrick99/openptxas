.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p2, %r3, 65536;
    @%p2 sub.s32 %r9, %r3, %r3;
    cvt.s64.s32 %rd8, %r3;
    cvt.s32.s64 %r15, %rd8;
    mul.lo.s32 %r19, %r15, %r9;
    mul.wide.s32 %rd6, %r19, %r15;
    shr.s32 %r15, %r15, 4;
    shr.u64 %rd13, %rd6, 48;
    shr.u64 %rd9, %rd6, 33;
    and.b32 %r21, %r15, 2;
    or.b32 %r5, %r3, 255;
    setp.eq.s32 %p4, %r9, 2147483648;
    @%p4 cvt.u32.u64 %r6, %rd6;
    setp.ne.s32 %p4, %r19, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
