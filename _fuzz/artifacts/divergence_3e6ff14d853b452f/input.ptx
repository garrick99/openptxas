.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r21, %r3, 31;
    add.s32 %r7, %r21, 3;
    sub.s32 %r24, %r3, 1;
    shr.u32 %r21, %r7, 31;
    sub.s32 %r13, %r21, 0;
    mad.lo.s32 %r25, %r3, %r3, %r21;
    cvt.s64.s32 %rd8, %r25;
    add.s32 %r21, %r3, %r25;
    cvt.u32.u64 %r24, %rd8;
    shl.b32 %r21, %r24, 31;
    max.u32 %r21, %r24, 64;
    shr.u32 %r27, %r7, 0;
    add.s32 %r11, %r24, %r13;
    shl.b32 %r23, %r27, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
