.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p1, %r3, 15;
    @%p1 shr.s32 %r15, %r3, 16;
    cvt.u64.u32 %rd6, %r15;
    mul.lo.s32 %r18, %r3, 31;
    cvt.u64.u32 %rd8, %r15;
    xor.b32 %r21, %r18, 31;
    sub.s32 %r22, %r3, %r18;
    add.u32 %r9, %r18, 5;
    setp.ge.u32 %p1, %r22, %r21;
    @%p1 and.b32 %r24, %r15, %r21;
    shr.s32 %r26, %r24, 16;
    cvt.u32.u64 %r27, %rd6;
    mul.lo.s64 %rd6, %rd8, %rd8;
    shr.s64 %rd6, %rd8, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
