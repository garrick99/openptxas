.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p1, %r3, %r3;
    @!%p1 min.s32 %r20, %r3, %r3;
    and.b32 %r16, %r20, %r20;
    cvt.u64.u32 %rd6, %r16;
    min.u32 %r12, %r20, %r20;
    or.b32 %r4, %r3, %r12;
    mad.lo.u32 %r24, %r4, %r12, %r16;
    mad.lo.u32 %r18, %r12, %r4, %r4;
    cvt.s64.s32 %rd12, %r18;
    min.s64 %rd11, %rd6, %rd12;
    shr.u32 %r8, %r4, 2;
    cvt.s64.s32 %rd7, %r24;
    shr.u64 %rd8, %rd7, 63;
    or.b32 %r26, %r4, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
