.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    mad.lo.u32 %r27, %r3, %r3, %r3;
    sub.s32 %r12, %r3, %r27;
    shr.s32 %r5, %r27, 16;
    mul.lo.u64 %rd6, %rd7, %rd7;
    setp.eq.s32 %p2, %r12, %r5;
    @%p2 cvt.u32.u64 %r26, %rd6;
    mul.wide.s32 %rd5, %r12, %r27;
    cvt.s64.s32 %rd11, %r12;
    add.u32 %r13, %r26, 8;
    mad.lo.u32 %r16, %r26, %r13, %r27;
    add.s32 %r17, %r3, %r27;
    cvt.s32.s64 %r20, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
