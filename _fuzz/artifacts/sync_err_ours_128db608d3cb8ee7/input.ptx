.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    cvt.u32.u64 %r7, %rd7;
    max.s32 %r10, %r3, %r7;
    min.u32 %r4, %r7, %r3;
    xor.b32 %r20, %r10, 3;
    shl.b32 %r17, %r7, 30;
    cvt.s64.s32 %rd10, %r20;
    shr.u32 %r15, %r20, 1;
    setp.ne.s32 %p3, %r15, 256;
    @%p3 max.u32 %r23, %r4, %r10;
    sub.u32 %r24, %r10, %r17;
    min.s32 %r22, %r3, %r23;
    min.s64 %rd13, %rd10, %rd7;
    shr.s32 %r25, %r17, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
