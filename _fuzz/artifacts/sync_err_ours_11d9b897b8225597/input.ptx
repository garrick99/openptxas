    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    add.u32 %r23, %r3, %r3;
    sub.s64 %rd14, %rd5, %rd5;
    min.s32 %r25, %r23, 65536;
    and.b32 %r27, %r25, %r23;
    mad.lo.u32 %r21, %r3, %r23, %r23;
    shl.b32 %r26, %r3, 2;
    cvt.s64.s32 %rd9, %r3;
    add.s32 %r26, %r27, %r26;
    shr.u64 %rd10, %rd14, 1;
    cvt.s64.s32 %rd6, %r23;
    shl.b64 %rd6, %rd6, 47;
    or.b64 %rd7, %rd5, %rd5;
