.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r26, %r3, 5;
    max.s32 %r19, %r26, %r3;
    xor.b32 %r7, %r26, 65536;
    setp.ls.u32 %p2, %r19, %r26;
    @%p2 and.b32 %r8, %r19, %r26;
    setp.le.s32 %p2, %r26, 4294967295;
    @%p2 mad.lo.s32 %r21, %r19, %r19, %r26;
    max.u32 %r9, %r21, %r21;
    mad.lo.u32 %r23, %r7, %r7, %r9;
    max.u32 %r24, %r19, %r21;
    xor.b32 %r4, %r7, 0;
    shl.b32 %r19, %r9, 16;
    cvt.s64.s32 %rd7, %r4;
    sub.s64 %rd12, %rd7, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
