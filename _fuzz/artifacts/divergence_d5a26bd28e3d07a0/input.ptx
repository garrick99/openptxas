.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r27, %r3, 16;
    cvt.u64.u32 %rd8, %r3;
    mad.lo.s32 %r16, %r3, %r27, %r3;
    max.u64 %rd8, %rd8, %rd8;
    setp.gt.s32 %p2, %r16, 7;
    @!%p2 cvt.s64.s32 %rd9, %r16;
    mul.wide.s32 %rd10, %r3, %r16;
    shr.u64 %rd15, %rd9, 0;
    setp.gt.u32 %p1, %r27, %r27;
    cvt.u32.u64 %r7, %rd9;
    selp.b32 %r25, %r27, %r16, %p2;
    max.s64 %rd14, %rd9, %rd15;
    shr.u32 %r19, %r27, 4;
    mad.lo.u32 %r5, %r3, %r7, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
