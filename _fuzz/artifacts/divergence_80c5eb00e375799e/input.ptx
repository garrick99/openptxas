.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd15, %r3, %r3;
    or.b64 %rd10, %rd15, %rd15;
    min.s32 %r24, %r3, 32;
    cvt.s32.s64 %r25, %rd15;
    setp.lt.s32 %p3, %r25, 65536;
    @%p3 add.u32 %r27, %r24, %r3;
    max.s32 %r25, %r24, %r24;
    cvt.s64.s32 %rd9, %r27;
    setp.le.u32 %p1, %r25, %r3;
    mul.lo.u32 %r25, %r27, 4;
    selp.b32 %r5, %r27, %r27, %p1;
    selp.b32 %r9, %r5, %r3, %p1;
    max.u32 %r16, %r5, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
