.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r18, %r3, %r3, %r3;
    min.u32 %r19, %r18, 255;
    and.b32 %r20, %r3, 5;
    cvt.u64.u32 %rd12, %r18;
    shr.u64 %rd13, %rd12, 31;
    setp.gt.u32 %p4, %r18, %r20;
    @%p4 shl.b64 %rd8, %rd12, 1;
    mul.lo.u32 %r4, %r19, %r20;
    cvt.s32.s64 %r14, %rd12;
    min.s64 %rd5, %rd8, %rd13;
    setp.ge.s32 %p2, %r18, 2147483648;
    mul.lo.u32 %r17, %r3, %r3;
    mul.lo.s32 %r9, %r17, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
