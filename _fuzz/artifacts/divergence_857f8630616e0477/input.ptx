.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r19, %r3, %r3, %r3;
    cvt.s64.s32 %rd15, %r3;
    cvt.u32.u64 %r24, %rd15;
    min.u32 %r25, %r24, 5;
    and.b64 %rd12, %rd15, %rd15;
    min.s32 %r4, %r24, %r25;
    setp.ge.u32 %p2, %r3, 0;
    mul.wide.s32 %rd6, %r19, %r19;
    sub.s32 %r22, %r25, %r24;
    cvt.s64.s32 %rd13, %r3;
    min.s32 %r23, %r25, %r19;
    mul.lo.s64 %rd14, %rd15, %rd12;
    setp.ls.u32 %p3, %r23, 256;
    sub.s64 %rd8, %rd6, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
