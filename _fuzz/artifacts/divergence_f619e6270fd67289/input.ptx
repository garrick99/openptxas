.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r25, %r3, 2;
    shr.u32 %r25, %r25, 3;
    mul.wide.s32 %rd14, %r25, %r25;
    max.s32 %r16, %r3, 8;
    cvt.u64.u32 %rd11, %r16;
    setp.le.u32 %p2, %r3, 65535;
    @%p2 shr.u64 %rd8, %rd11, 48;
    mad.lo.s32 %r12, %r25, %r16, %r16;
    mad.lo.s32 %r24, %r12, %r16, %r12;
    shr.s64 %rd10, %rd8, 33;
    shr.s64 %rd11, %rd10, 47;
    selp.b32 %r11, %r12, %r25, %p2;
    mul.lo.s32 %r25, %r11, %r24;
    sub.u64 %rd6, %rd11, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
