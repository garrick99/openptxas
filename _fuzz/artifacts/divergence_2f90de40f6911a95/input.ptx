.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd7, %r3, %r3;
    min.s64 %rd5, %rd7, %rd7;
    mul.wide.u32 %rd12, %r3, %r3;
    min.s32 %r6, %r3, %r3;
    shr.s64 %rd15, %rd12, 1;
    setp.lo.u32 %p2, %r6, %r3;
    mul.lo.u32 %r11, %r3, %r3;
    shr.u32 %r8, %r11, 3;
    max.u64 %rd10, %rd5, %rd15;
    mul.lo.s64 %rd6, %rd15, %rd5;
    shr.u32 %r13, %r6, 30;
    setp.eq.s32 %p2, %r13, 4294967295;
    @%p2 xor.b32 %r5, %r8, 1;
    add.s64 %rd8, %rd5, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
