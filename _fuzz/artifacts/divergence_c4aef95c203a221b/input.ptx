.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r9, %r3, %r3, %r3;
    cvt.s64.s32 %rd5, %r3;
    cvt.u32.u64 %r21, %rd5;
    shl.b32 %r17, %r9, 31;
    xor.b64 %rd8, %rd5, %rd5;
    min.u32 %r12, %r17, %r3;
    shl.b64 %rd5, %rd8, 4;
    and.b64 %rd5, %rd5, %rd8;
    xor.b32 %r19, %r21, %r21;
    shl.b32 %r25, %r9, 4;
    cvt.u64.u32 %rd6, %r21;
    xor.b32 %r24, %r25, 32;
    add.u32 %r23, %r12, %r17;
    max.s32 %r14, %r17, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
