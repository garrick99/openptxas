.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    shl.b32 %r8, %r3, 2;
    cvt.s32.s64 %r8, %rd6;
    setp.ge.u32 %p3, %r3, 5;
    setp.eq.s32 %p1, %r3, 5;
    mul.lo.s32 %r13, %r3, %r3;
    cvt.u32.u64 %r27, %rd6;
    setp.le.s32 %p2, %r13, %r3;
    @%p2 mul.lo.s32 %r7, %r27, 256;
    sub.s32 %r19, %r13, %r27;
    cvt.s64.s32 %rd9, %r8;
    shr.u64 %rd15, %rd9, 2;
    max.s32 %r23, %r27, %r13;
    mad.lo.s32 %r23, %r23, %r27, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
