.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p3, %r3, 8;
    @%p3 add.u32 %r15, %r3, %r3;
    mul.lo.s32 %r4, %r15, %r15;
    mul.wide.s32 %rd12, %r15, %r4;
    min.s32 %r18, %r3, %r3;
    shr.u32 %r25, %r18, 31;
    add.u32 %r15, %r25, 4294967295;
    min.s32 %r6, %r4, %r25;
    mul.wide.u32 %rd7, %r15, %r6;
    shl.b32 %r13, %r6, 2;
    setp.ge.s32 %p2, %r13, 7;
    @!%p2 shr.u64 %rd10, %rd7, 63;
    selp.b32 %r14, %r3, %r13, %p3;
    mul.wide.u32 %rd8, %r14, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
