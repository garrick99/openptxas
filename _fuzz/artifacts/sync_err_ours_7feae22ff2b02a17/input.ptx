.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd12, %r3, %r3;
    and.b32 %r25, %r3, %r3;
    max.u32 %r14, %r3, 64;
    mad.lo.u32 %r14, %r14, %r14, %r25;
    shr.u64 %rd6, %rd12, 62;
    cvt.u64.u32 %rd13, %r14;
    and.b32 %r21, %r3, 4294967295;
    sub.s32 %r19, %r14, %r3;
    shl.b32 %r10, %r19, 2;
    shl.b32 %r19, %r21, 31;
    shr.s32 %r26, %r3, 30;
    add.s32 %r5, %r21, %r25;
    add.s32 %r23, %r3, %r10;
    setp.lo.u32 %p2, %r23, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
