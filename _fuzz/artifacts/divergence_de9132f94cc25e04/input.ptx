.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    setp.hi.u32 %p1, %r3, %r3;
    @%p1 shl.b32 %r13, %r3, 16;
    and.b32 %r5, %r13, 5;
    shr.u64 %rd10, %rd6, 62;
    sub.s32 %r27, %r5, 5;
    setp.ge.s32 %p3, %r3, %r13;
    @%p3 min.u32 %r21, %r5, %r13;
    shr.u32 %r15, %r5, 0;
    sub.u32 %r8, %r5, 31;
    cvt.s32.s64 %r8, %rd10;
    cvt.u64.u32 %rd7, %r13;
    min.u32 %r15, %r8, 255;
    mad.lo.u32 %r23, %r21, %r3, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
