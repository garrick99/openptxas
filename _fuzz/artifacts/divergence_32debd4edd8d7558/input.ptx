.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r6, %r3, 4;
    shr.u32 %r21, %r6, 15;
    setp.gt.s32 %p4, %r21, %r21;
    @%p4 shl.b32 %r4, %r6, 15;
    selp.b32 %r16, %r4, %r3, %p4;
    cvt.s64.s32 %rd15, %r21;
    mul.lo.s32 %r16, %r4, %r4;
    cvt.u32.u64 %r8, %rd15;
    cvt.s32.s64 %r9, %rd15;
    max.u32 %r15, %r4, %r8;
    mul.lo.s32 %r17, %r8, 65536;
    cvt.s32.s64 %r6, %rd15;
    sub.u32 %r13, %r16, %r9;
    selp.b32 %r5, %r21, %r16, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
