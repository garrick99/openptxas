.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r27, %r3, 3;
    mad.lo.u32 %r4, %r27, %r27, %r3;
    and.b32 %r15, %r4, 2;
    setp.hs.u32 %p1, %r3, 0;
    xor.b32 %r24, %r3, %r27;
    selp.b32 %r15, %r3, %r4, %p1;
    mul.lo.s32 %r12, %r27, 32;
    add.s32 %r6, %r4, 8;
    cvt.s64.s32 %rd8, %r3;
    mad.lo.u32 %r21, %r3, %r6, %r4;
    cvt.s64.s32 %rd14, %r24;
    max.s32 %r25, %r4, 2;
    cvt.s64.s32 %rd12, %r25;
    add.s32 %r16, %r25, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
