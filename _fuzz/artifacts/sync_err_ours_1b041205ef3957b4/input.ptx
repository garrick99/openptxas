.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r6, %r3, 0;
    xor.b32 %r24, %r6, 15;
    shl.b32 %r9, %r3, 15;
    min.u32 %r9, %r24, 63;
    setp.ls.u32 %p3, %r6, %r9;
    @!%p3 add.s32 %r20, %r3, 65535;
    mul.lo.s32 %r8, %r9, %r20;
    shl.b32 %r14, %r20, 4;
    mul.wide.s32 %rd8, %r20, %r9;
    add.u32 %r8, %r8, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
