.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r12, %r3, 8;
    cvt.s64.s32 %rd15, %r12;
    mad.lo.u32 %r13, %r3, %r12, %r3;
    shl.b32 %r10, %r12, 4;
    setp.lo.u32 %p3, %r3, %r10;
    @%p3 min.s32 %r21, %r3, %r12;
    selp.b32 %r23, %r13, %r10, %p3;
    shr.s64 %rd7, %rd15, 15;
    min.s32 %r20, %r12, %r10;
    or.b32 %r23, %r23, 3;
    cvt.u64.u32 %rd9, %r23;
    max.u32 %r20, %r20, 32;
    mul.lo.s32 %r14, %r12, %r3;
    cvt.s32.s64 %r24, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
