.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    mad.lo.s32 %r16, %r3, %r3, %r3;
    max.u64 %rd9, %rd6, %rd6;
    sub.s64 %rd8, %rd9, %rd6;
    mul.lo.s32 %r25, %r3, %r3;
    shl.b32 %r12, %r16, 3;
    cvt.u32.u64 %r18, %rd6;
    shl.b32 %r10, %r16, 7;
    min.s64 %rd11, %rd9, %rd8;
    add.s32 %r20, %r18, 0;
    setp.ls.u32 %p3, %r12, %r20;
    mad.lo.s32 %r5, %r25, %r12, %r12;
    shr.s64 %rd9, %rd11, 4;
    shr.s64 %rd10, %rd9, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
