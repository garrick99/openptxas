.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    shl.b64 %rd14, %rd8, 2;
    sub.s64 %rd12, %rd8, %rd8;
    cvt.s64.s32 %rd6, %r3;
    cvt.s32.s64 %r6, %rd6;
    sub.s32 %r5, %r6, 1;
    sub.u32 %r4, %r3, %r5;
    and.b64 %rd12, %rd14, %rd6;
    sub.u32 %r16, %r4, %r6;
    sub.s32 %r24, %r3, 0;
    cvt.u64.u32 %rd13, %r6;
    sub.u64 %rd11, %rd12, %rd8;
    sub.s64 %rd12, %rd8, %rd8;
    and.b64 %rd9, %rd12, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
