.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r13, %r3, %r3;
    shl.b32 %r22, %r13, 30;
    cvt.u64.u32 %rd7, %r3;
    cvt.s64.s32 %rd12, %r3;
    and.b32 %r6, %r13, 32;
    add.s32 %r21, %r13, %r22;
    shr.u32 %r18, %r3, 2;
    max.s32 %r20, %r22, %r6;
    setp.ge.s32 %p3, %r22, %r20;
    @%p3 shl.b32 %r14, %r13, 7;
    or.b32 %r8, %r13, 31;
    or.b32 %r17, %r6, %r20;
    sub.s32 %r26, %r6, %r6;
    setp.ge.u32 %p3, %r6, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
