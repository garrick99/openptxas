.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r12, %r0, %r0;
    min.u32 %r4, %r0, %r3;
    setp.gt.u32 %p2, %r3, 2;
    vote.sync.ballot.b32 %r8, %p2, -1;
    or.b32 %r12, %r4, %r3;
    setp.lt.u32 %p3, %r12, %r8;
    vote.sync.ballot.b32 %r13, %p3, -1;
    setp.gt.u32 %p3, %r0, %r8;
    vote.sync.ballot.b32 %r11, %p3, -1;
    or.b32 %r11, %r8, %r3;
    shfl.sync.bfly.b32 %r14, %r3, 16, 0x1f, -1;
    max.u32 %r11, %r12, %r8;
    vote.sync.any.pred %p1, %p3, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
