.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    sub.u32 %r9, %r3, 1;
    shr.u32 %r21, %r9, 1;
    min.u32 %r17, %r21, %r21;
    min.s32 %r11, %r9, 256;
    sub.u32 %r14, %r9, %r9;
    xor.b32 %r27, %r9, %r21;
    mul.lo.u32 %r9, %r17, 4294967295;
    max.s64 %rd14, %rd7, %rd7;
    mul.lo.s32 %r16, %r9, 63;
    max.s32 %r11, %r14, 15;
    xor.b64 %rd6, %rd14, %rd7;
    max.s64 %rd11, %rd6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
