.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r13, %r3, %r0;
    min.u32 %r5, %r13, %r0;
    add.u32 %r17, %r0, %r3;
    shfl.sync.up.b32 %r16, %r3, 1, 0x1f, -1;
    sub.u32 %r10, %r5, %r5;
    and.b32 %r9, %r13, %r13;
    shfl.sync.idx.b32 %r10, %r10, 31, 0x1f, -1;
    setp.le.u32 %p2, %r5, 31;
    vote.sync.ballot.b32 %r12, %p2, -1;
    shfl.sync.bfly.b32 %r4, %r3, 1, 0x1f, -1;
    max.u32 %r14, %r12, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
