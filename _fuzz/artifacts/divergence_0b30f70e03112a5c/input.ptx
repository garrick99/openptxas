.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r11, %r3, %r3;
    setp.hs.u32 %p3, %r11, %r11;
    setp.gt.s32 %p2, %r11, 2;
    @%p2 max.u32 %r5, %r11, %r11;
    add.u32 %r4, %r5, 65535;
    setp.ls.u32 %p3, %r11, 15;
    @!%p3 add.u32 %r26, %r11, %r4;
    shl.b32 %r26, %r26, 31;
    cvt.s64.s32 %rd13, %r26;
    add.s64 %rd10, %rd13, %rd13;
    setp.ne.u32 %p2, %r11, %r3;
    @%p2 or.b32 %r23, %r26, %r3;
    shl.b32 %r20, %r23, 2;
    cvt.u64.u32 %rd13, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
