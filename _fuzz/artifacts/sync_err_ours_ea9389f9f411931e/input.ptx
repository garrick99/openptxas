.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    shl.b32 %r27, %r3, 0;
    shr.s64 %rd15, %rd7, 33;
    max.s64 %rd11, %rd7, %rd15;
    mul.lo.s32 %r6, %r3, %r27;
    setp.gt.u32 %p4, %r3, %r3;
    @%p4 cvt.s32.s64 %r23, %rd11;
    shr.s64 %rd9, %rd7, 0;
    add.s32 %r26, %r27, %r27;
    setp.hs.u32 %p2, %r3, %r23;
    min.s32 %r21, %r26, %r27;
    mul.wide.u32 %rd12, %r23, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
