.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    xor.b32 %r9, %r3, 64;
    add.s32 %r13, %r3, 3;
    setp.ne.u32 %p1, %r9, 4294967295;
    min.s32 %r8, %r3, %r9;
    mul.wide.u32 %rd13, %r8, %r13;
    shr.u64 %rd9, %rd13, 32;
    shr.s32 %r24, %r3, 3;
    shr.s32 %r23, %r3, 15;
    mul.wide.u32 %rd5, %r8, %r23;
    shr.u32 %r10, %r24, 31;
    cvt.s64.s32 %rd5, %r3;
    shr.s32 %r4, %r9, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
