.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r26, %r3, 0;
    mul.wide.u32 %rd10, %r26, %r26;
    mul.lo.u32 %r20, %r26, %r3;
    cvt.u64.u32 %rd10, %r3;
    xor.b32 %r5, %r26, %r20;
    cvt.s64.s32 %rd8, %r3;
    shr.u64 %rd11, %rd8, 15;
    mul.wide.u32 %rd11, %r26, %r3;
    setp.eq.s32 %p3, %r20, 32;
    mul.lo.s32 %r20, %r5, 3;
    min.u64 %rd9, %rd11, %rd11;
    shr.u32 %r9, %r3, 4;
    mul.lo.s32 %r26, %r3, %r5;
    mul.lo.u64 %rd8, %rd8, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
