.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r7, %r3, 65536;
    or.b32 %r21, %r7, %r3;
    shr.u32 %r16, %r7, 31;
    add.u32 %r25, %r7, %r7;
    max.u32 %r15, %r3, %r25;
    setp.eq.s32 %p3, %r15, %r16;
    selp.b32 %r24, %r7, %r15, %p3;
    xor.b32 %r18, %r7, %r24;
    cvt.s64.s32 %rd6, %r15;
    mul.lo.u32 %r20, %r24, %r3;
    cvt.u64.u32 %rd13, %r20;
    shl.b64 %rd5, %rd13, 30;
    add.u32 %r16, %r15, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
