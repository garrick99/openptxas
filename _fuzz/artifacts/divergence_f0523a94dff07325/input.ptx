.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    add.s32 %r26, %r3, 1;
    shr.s64 %rd14, %rd8, 47;
    mul.lo.s32 %r6, %r3, %r26;
    shr.s32 %r21, %r3, 30;
    xor.b32 %r6, %r6, 32;
    min.u32 %r9, %r6, 32;
    shl.b32 %r19, %r26, 0;
    cvt.s32.s64 %r4, %rd8;
    sub.s64 %rd14, %rd8, %rd8;
    mad.lo.u32 %r22, %r6, %r19, %r6;
    mul.wide.s32 %rd8, %r6, %r3;
    mul.wide.s32 %rd13, %r4, %r26;
    add.s32 %r20, %r4, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
