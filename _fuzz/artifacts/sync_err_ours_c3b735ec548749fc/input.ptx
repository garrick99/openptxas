.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r16, %r3, 5;
    sub.u32 %r9, %r3, %r16;
    setp.gt.s32 %p3, %r9, 256;
    @%p3 cvt.s64.s32 %rd14, %r16;
    cvt.u32.u64 %r12, %rd14;
    or.b64 %rd10, %rd14, %rd14;
    shl.b32 %r19, %r16, 7;
    shl.b32 %r7, %r16, 7;
    min.s32 %r15, %r9, %r16;
    min.u32 %r16, %r12, 64;
    or.b32 %r22, %r9, 31;
    shl.b64 %rd5, %rd10, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
