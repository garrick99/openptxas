    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r13, %r3, %r3;
    setp.le.s32 %p3, %r3, %r13;
    @%p3 min.u32 %r21, %r13, 15;
    min.u32 %r16, %r3, 4294967295;
    cvt.u64.u32 %rd5, %r3;
    xor.b32 %r14, %r3, 32;
    setp.lt.u32 %p1, %r21, 4;
    @%p1 shr.s32 %r9, %r14, 15;
    or.b32 %r11, %r14, 7;
    setp.gt.s32 %p2, %r21, 65536;
    add.s32 %r26, %r13, %r11;
    mad.lo.s32 %r14, %r11, %r9, %r14;
    setp.hs.u32 %p1, %r14, %r11;
    @%p1 xor.b64 %rd9, %rd5, %rd5;
    ld.param.u64 %rd3, [p_out];
