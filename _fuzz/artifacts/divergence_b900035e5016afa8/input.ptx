.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r17, %r3, %r3;
    shl.b32 %r14, %r3, 1;
    shr.s32 %r18, %r17, 31;
    mad.lo.s32 %r12, %r18, %r3, %r17;
    cvt.u64.u32 %rd8, %r17;
    mul.wide.u32 %rd14, %r3, %r17;
    add.s32 %r8, %r18, 2147483648;
    xor.b32 %r5, %r14, %r3;
    mul.wide.s32 %rd15, %r14, %r5;
    setp.hi.u32 %p4, %r5, %r12;
    @%p4 mad.lo.s32 %r12, %r3, %r8, %r17;
    mul.lo.s32 %r11, %r17, %r18;
    or.b32 %r25, %r12, %r5;
    setp.ge.s32 %p1, %r14, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
