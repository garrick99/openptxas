.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r26, %r3, %r3, %r3;
    shr.s32 %r17, %r26, 16;
    mad.lo.u32 %r18, %r3, %r17, %r17;
    cvt.u64.u32 %rd15, %r26;
    xor.b32 %r14, %r3, %r26;
    shr.s32 %r5, %r26, 1;
    add.u32 %r17, %r17, 2147483648;
    mul.wide.s32 %rd12, %r14, %r18;
    mul.lo.u64 %rd8, %rd12, %rd15;
    setp.lo.u32 %p3, %r14, 31;
    @%p3 min.s32 %r18, %r5, %r3;
    mad.lo.u32 %r13, %r17, %r26, %r18;
    shl.b64 %rd14, %rd15, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
