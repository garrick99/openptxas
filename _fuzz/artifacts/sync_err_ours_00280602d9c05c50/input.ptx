.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r9, %r3, %r3, %r3;
    xor.b32 %r26, %r3, 64;
    setp.lt.u32 %p2, %r3, 3;
    setp.hs.u32 %p2, %r26, %r3;
    @%p2 add.s32 %r13, %r3, 256;
    add.u32 %r10, %r3, %r26;
    mul.lo.s32 %r18, %r10, 31;
    selp.b32 %r4, %r13, %r10, %p2;
    shl.b32 %r19, %r10, 1;
    add.u32 %r22, %r10, %r4;
    mul.lo.s32 %r18, %r3, %r19;
    setp.ne.s32 %p3, %r19, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
