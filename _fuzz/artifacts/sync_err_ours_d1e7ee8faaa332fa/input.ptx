.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd7, %r3, %r3;
    shr.s32 %r15, %r3, 2;
    sub.s32 %r9, %r15, %r3;
    sub.s32 %r7, %r3, %r3;
    xor.b32 %r13, %r9, %r9;
    xor.b32 %r24, %r9, %r7;
    setp.le.u32 %p3, %r24, %r13;
    @%p3 shr.s32 %r27, %r24, 16;
    shr.u32 %r23, %r7, 7;
    sub.s32 %r24, %r13, 65536;
    xor.b32 %r13, %r7, 15;
    max.s32 %r16, %r13, 256;
    mul.wide.u32 %rd13, %r24, %r16;
    max.u32 %r15, %r13, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
