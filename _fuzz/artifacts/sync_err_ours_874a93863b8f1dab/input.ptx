    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r10, %r3, %r3;
    setp.lt.s32 %p1, %r3, 31;
    setp.ls.u32 %p1, %r3, 2147483648;
    mul.wide.s32 %rd5, %r10, %r10;
