.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    and.b32 %r20, %r3, %r3;
    cvt.u32.u64 %r22, %rd7;
    cvt.s64.s32 %rd9, %r20;
    shr.s64 %rd10, %rd9, 15;
    setp.lt.s32 %p3, %r20, %r22;
    @%p3 shl.b64 %rd6, %rd10, 63;
    cvt.u64.u32 %rd6, %r22;
    sub.u32 %r6, %r3, 4294967295;
    min.s64 %rd5, %rd7, %rd10;
    shr.s32 %r17, %r20, 16;
    cvt.u32.u64 %r19, %rd5;
    shr.s32 %r9, %r22, 31;
    max.s32 %r20, %r17, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
