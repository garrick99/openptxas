.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p4, %r3, 15;
    @!%p4 min.u32 %r9, %r3, 0;
    mul.wide.u32 %rd11, %r9, %r9;
    shl.b64 %rd11, %rd11, 1;
    mul.lo.s32 %r25, %r9, %r3;
    sub.s32 %r22, %r25, 3;
    max.u32 %r15, %r3, 0;
    sub.u32 %r26, %r9, %r9;
    xor.b32 %r17, %r3, 3;
    shr.u32 %r24, %r3, 0;
    and.b32 %r7, %r22, 4;
    add.u32 %r24, %r25, 65535;
    shl.b32 %r11, %r24, 1;
    setp.lt.s32 %p3, %r11, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
