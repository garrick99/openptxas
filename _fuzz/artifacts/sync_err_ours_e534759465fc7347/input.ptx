.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r22, %r3, 4;
    shl.b32 %r24, %r3, 31;
    mad.lo.u32 %r27, %r24, %r3, %r24;
    cvt.s64.s32 %rd8, %r24;
    shr.s32 %r27, %r22, 15;
    shl.b32 %r9, %r3, 2;
    or.b32 %r19, %r24, %r24;
    min.s32 %r23, %r9, 255;
    max.s32 %r17, %r27, 3;
    shl.b64 %rd8, %rd8, 16;
    sub.s32 %r8, %r23, %r17;
    max.s32 %r12, %r22, %r9;
    sub.u64 %rd13, %rd8, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
