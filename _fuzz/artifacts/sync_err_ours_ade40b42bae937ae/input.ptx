.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    sub.s32 %r16, %r3, 2147483647;
    max.s32 %r15, %r16, %r3;
    min.s64 %rd14, %rd8, %rd8;
    cvt.u32.u64 %r17, %rd14;
    mul.lo.u32 %r20, %r17, 65535;
    shr.u64 %rd7, %rd14, 32;
    sub.u32 %r18, %r16, 15;
    shr.u64 %rd5, %rd8, 48;
    shr.s64 %rd8, %rd7, 0;
    min.s64 %rd12, %rd5, %rd14;
    setp.lo.u32 %p4, %r3, %r3;
    @%p4 max.u32 %r18, %r20, 5;
    mul.lo.s64 %rd10, %rd7, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
