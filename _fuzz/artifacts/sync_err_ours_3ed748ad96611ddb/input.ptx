.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    shl.b32 %r21, %r3, 3;
    cvt.s32.s64 %r12, %rd7;
    setp.ne.u32 %p4, %r21, %r12;
    @%p4 cvt.s32.s64 %r8, %rd7;
    min.s32 %r21, %r8, %r12;
    add.u64 %rd5, %rd7, %rd7;
    cvt.u64.u32 %rd9, %r12;
    or.b32 %r27, %r12, %r12;
    mul.lo.u64 %rd14, %rd7, %rd5;
    cvt.s64.s32 %rd7, %r27;
    shr.u32 %r20, %r3, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
