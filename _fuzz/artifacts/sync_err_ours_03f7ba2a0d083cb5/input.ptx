.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p2, %r3, %r3;
    setp.gt.s32 %p1, %r3, %r3;
    @%p1 xor.b32 %r24, %r3, %r3;
    sub.u32 %r22, %r3, 0;
    sub.u32 %r23, %r22, 2;
    setp.gt.u32 %p1, %r3, %r3;
    @%p1 max.s32 %r14, %r22, %r22;
    mul.wide.u32 %rd7, %r14, %r14;
    setp.ge.s32 %p2, %r23, 65536;
    shr.s32 %r5, %r14, 0;
    mad.lo.s32 %r20, %r14, %r14, %r22;
    selp.b32 %r13, %r23, %r20, %p2;
    mul.wide.u32 %rd9, %r13, %r23;
    min.u64 %rd10, %rd7, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
