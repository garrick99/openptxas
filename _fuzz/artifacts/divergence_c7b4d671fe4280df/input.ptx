.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r18, %r3, %r3;
    shr.u32 %r9, %r3, 7;
    cvt.u64.u32 %rd7, %r3;
    min.s32 %r26, %r3, %r18;
    max.u32 %r18, %r26, 256;
    max.u32 %r21, %r26, 7;
    setp.ge.s32 %p3, %r9, %r21;
    @!%p3 shr.s32 %r10, %r26, 31;
    mul.lo.u64 %rd14, %rd7, %rd7;
    add.u64 %rd12, %rd14, %rd14;
    max.u32 %r26, %r10, 255;
    selp.b32 %r14, %r9, %r21, %p3;
    xor.b32 %r15, %r10, 256;
    cvt.u64.u32 %rd9, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
