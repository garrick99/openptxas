.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    mul.wide.s32 %rd6, %r3, %r3;
    shl.b64 %rd12, %rd6, 16;
    shr.u32 %r18, %r3, 3;
    setp.ge.s32 %p4, %r18, 64;
    @%p4 mad.lo.s32 %r19, %r18, %r3, %r3;
    shr.s32 %r9, %r19, 4;
    xor.b32 %r17, %r18, %r18;
    mul.lo.s32 %r18, %r9, 2;
    sub.s32 %r23, %r3, 3;
    max.s32 %r23, %r18, %r18;
    mul.wide.u32 %rd11, %r19, %r17;
    mad.lo.s32 %r5, %r17, %r19, %r23;
    mul.wide.s32 %rd6, %r9, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
