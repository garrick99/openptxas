    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    prmt.b32 %r9, %r3, %r3, 291;
    add.u32 %r5, %r9, 31;
    or.b32 %r8, %r5, 31;
    popc.b32 %r22, %r9;
