.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd10, %r3, %r3;
    shl.b64 %rd7, %rd10, 3;
    and.b32 %r8, %r3, 3;
    mul.wide.u32 %rd12, %r3, %r3;
    cvt.s32.s64 %r16, %rd7;
    shr.u32 %r10, %r8, 30;
    shr.s64 %rd11, %rd7, 63;
    or.b32 %r10, %r10, 15;
    xor.b32 %r4, %r3, 2;
    xor.b32 %r11, %r16, 65535;
    min.u32 %r15, %r16, %r16;
    and.b32 %r11, %r11, %r15;
    max.u64 %rd9, %rd11, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
