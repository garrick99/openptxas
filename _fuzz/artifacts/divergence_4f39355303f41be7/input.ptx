.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r8, %r3, 32;
    mul.wide.s32 %rd11, %r3, %r8;
    shl.b32 %r4, %r8, 4;
    or.b32 %r7, %r8, %r4;
    setp.lt.u32 %p4, %r7, %r3;
    @%p4 shl.b32 %r11, %r8, 4;
    min.u32 %r13, %r3, %r4;
    add.s32 %r21, %r13, 63;
    xor.b32 %r11, %r8, 4;
    sub.u64 %rd14, %rd11, %rd11;
    min.s32 %r7, %r3, %r3;
    and.b32 %r26, %r11, 4294967295;
    min.u32 %r14, %r11, %r21;
    cvt.u64.u32 %rd6, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
