.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r4, %r3, 2;
    min.s32 %r16, %r4, 8;
    max.u32 %r12, %r16, %r3;
    setp.ne.s32 %p2, %r12, %r4;
    @%p2 cvt.u64.u32 %rd10, %r16;
    mul.lo.s32 %r9, %r4, 2147483648;
    mul.wide.s32 %rd7, %r16, %r4;
    setp.ge.u32 %p2, %r3, %r12;
    @%p2 selp.b32 %r10, %r12, %r4, %p2;
    min.s32 %r7, %r16, %r16;
    and.b32 %r11, %r10, %r16;
    shl.b32 %r25, %r16, 7;
    setp.eq.u32 %p4, %r12, 4;
    mul.lo.s32 %r11, %r10, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
