.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    shr.u32 %r14, %r3, 1;
    mul.lo.s32 %r15, %r3, %r3;
    cvt.u32.u64 %r6, %rd12;
    cvt.u32.u64 %r21, %rd12;
    setp.hs.u32 %p4, %r6, %r14;
    shr.s64 %rd13, %rd12, 0;
    shr.s32 %r7, %r3, 0;
    min.u32 %r19, %r15, %r3;
    mad.lo.s32 %r21, %r7, %r6, %r7;
    min.s32 %r23, %r21, %r19;
    mul.lo.s32 %r25, %r3, 255;
    sub.s32 %r18, %r19, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
