.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    shr.u32 %r15, %r3, 16;
    min.u32 %r4, %r15, %r15;
    sub.u32 %r10, %r15, 65536;
    shl.b32 %r22, %r3, 3;
    max.u64 %rd13, %rd15, %rd15;
    xor.b64 %rd14, %rd15, %rd15;
    shr.s32 %r17, %r22, 2;
    shr.s64 %rd8, %rd13, 0;
    cvt.s64.s32 %rd8, %r3;
    min.u64 %rd14, %rd8, %rd15;
    mul.lo.s32 %r12, %r22, %r4;
    setp.lo.u32 %p3, %r22, 15;
    @%p3 sub.u32 %r9, %r17, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
