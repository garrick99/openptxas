.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p1, %r3, 1;
    @%p1 cvt.u64.u32 %rd14, %r3;
    sub.u32 %r18, %r3, 0;
    sub.u32 %r7, %r3, %r18;
    cvt.s64.s32 %rd6, %r7;
    mul.wide.u32 %rd15, %r7, %r3;
    or.b32 %r17, %r3, %r3;
    add.s32 %r21, %r17, %r7;
    setp.lt.u32 %p2, %r18, %r18;
    cvt.u32.u64 %r6, %rd14;
    sub.u32 %r4, %r6, %r7;
    cvt.s32.s64 %r26, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
