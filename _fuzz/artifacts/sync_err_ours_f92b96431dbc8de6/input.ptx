.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    cvt.u32.u64 %r8, %rd5;
    sub.u32 %r8, %r3, 4294967295;
    sub.s32 %r8, %r3, %r3;
    max.u32 %r16, %r8, 64;
    shl.b32 %r14, %r3, 1;
    and.b32 %r22, %r14, %r8;
    sub.s32 %r14, %r3, 3;
    min.u32 %r11, %r14, %r16;
    sub.s32 %r27, %r3, 2147483647;
    mul.lo.u32 %r19, %r14, 65535;
    min.s64 %rd5, %rd5, %rd5;
    xor.b32 %r27, %r3, %r16;
    setp.lt.u32 %p3, %r8, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
