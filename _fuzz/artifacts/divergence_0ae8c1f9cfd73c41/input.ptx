.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd13, %r3, %r3;
    shr.s32 %r12, %r3, 7;
    xor.b32 %r10, %r3, %r3;
    cvt.s32.s64 %r18, %rd13;
    xor.b32 %r16, %r3, %r3;
    add.s64 %rd10, %rd13, %rd13;
    setp.le.s32 %p1, %r10, 32;
    @!%p1 and.b32 %r21, %r10, %r3;
    shr.u64 %rd15, %rd10, 7;
    mad.lo.s32 %r13, %r12, %r10, %r16;
    selp.b32 %r23, %r21, %r21, %p1;
    add.s32 %r7, %r18, 8;
    shl.b64 %rd9, %rd13, 1;
    sub.s32 %r7, %r23, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
