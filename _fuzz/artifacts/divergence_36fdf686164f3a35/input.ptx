    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r23, %r3, %r3;
    setp.ls.u32 %p4, %r3, 255;
    @%p4 min.s32 %r20, %r23, %r3;
