.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r9, %r3, 1;
    setp.ne.s32 %p3, %r3, 0;
    @%p3 cvt.u64.u32 %rd14, %r3;
    mul.wide.u32 %rd13, %r3, %r3;
    shr.s32 %r23, %r9, 30;
    max.s32 %r25, %r23, %r9;
    cvt.s32.s64 %r8, %rd14;
    cvt.u64.u32 %rd9, %r23;
    shl.b32 %r20, %r3, 1;
    xor.b32 %r6, %r25, %r8;
    shr.u32 %r4, %r23, 7;
    max.s32 %r20, %r20, %r23;
    mul.wide.u32 %rd5, %r4, %r3;
    min.u32 %r16, %r8, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
