.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r27, %r3, 7;
    shl.b32 %r12, %r3, 7;
    min.u32 %r12, %r27, %r12;
    max.s32 %r20, %r12, %r12;
    min.s32 %r27, %r27, %r12;
    mul.lo.s32 %r9, %r3, 4;
    mad.lo.u32 %r27, %r20, %r27, %r3;
    sub.s32 %r15, %r3, %r27;
    mul.wide.u32 %rd13, %r9, %r20;
    sub.u32 %r16, %r3, 3;
    shr.s64 %rd13, %rd13, 1;
    sub.s64 %rd13, %rd13, %rd13;
    add.s32 %r9, %r9, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
