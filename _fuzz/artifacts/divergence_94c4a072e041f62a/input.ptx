.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r27, %r3, %r3;
    mul.lo.u32 %r26, %r3, %r27;
    cvt.s64.s32 %rd10, %r26;
    mul.wide.s32 %rd6, %r27, %r27;
    setp.ge.s32 %p1, %r26, 1;
    @%p1 mad.lo.u32 %r21, %r26, %r3, %r27;
    xor.b32 %r24, %r26, 4294967295;
    min.s64 %rd14, %rd10, %rd6;
    sub.s32 %r18, %r21, %r27;
    mad.lo.u32 %r24, %r18, %r3, %r27;
    mul.lo.s32 %r23, %r24, %r27;
    add.u32 %r24, %r27, %r26;
    cvt.s64.s32 %rd10, %r23;
    sub.u32 %r16, %r21, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
