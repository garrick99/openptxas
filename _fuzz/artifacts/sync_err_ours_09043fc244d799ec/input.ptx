.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd11, %r3, %r3;
    setp.ne.u32 %p3, %r3, 2147483648;
    @!%p3 or.b32 %r13, %r3, %r3;
    sub.s32 %r17, %r13, 3;
    mul.wide.u32 %rd15, %r13, %r13;
    mul.wide.s32 %rd15, %r17, %r17;
    shl.b32 %r5, %r17, 4;
    setp.gt.u32 %p4, %r5, %r17;
    @%p4 mul.wide.u32 %rd6, %r5, %r5;
    cvt.u64.u32 %rd12, %r17;
    shr.u32 %r17, %r13, 31;
    add.u32 %r22, %r13, %r5;
    max.u32 %r18, %r5, 4294967295;
    sub.u32 %r6, %r13, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
