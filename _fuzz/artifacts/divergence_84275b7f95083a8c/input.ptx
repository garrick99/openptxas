    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r16, %r3, %r3;
    shl.b32 %r27, %r3, 1;
    min.u32 %r22, %r3, 4;
    and.b32 %r6, %r27, %r16;
    max.s32 %r8, %r3, 4;
    cvt.s64.s32 %rd10, %r6;
    setp.le.u32 %p4, %r6, 4294967295;
    or.b32 %r23, %r22, 15;
    max.u32 %r10, %r23, 64;
    mul.lo.u32 %r25, %r6, %r8;
    and.b32 %r21, %r22, 3;
    setp.lt.s32 %p2, %r25, %r8;
    @%p2 and.b32 %r13, %r21, %r23;
    max.u32 %r5, %r21, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
