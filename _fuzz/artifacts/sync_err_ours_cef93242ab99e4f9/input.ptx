.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    setp.ge.s32 %p4, %r3, %r3;
    @%p4 mul.wide.s32 %rd8, %r3, %r3;
    mul.lo.s32 %r20, %r3, %r3;
    add.s32 %r19, %r3, %r3;
    cvt.u32.u64 %r26, %rd10;
    add.s64 %rd5, %rd8, %rd8;
    mul.lo.u32 %r23, %r20, 32;
    setp.ge.s32 %p4, %r19, %r23;
    add.s64 %rd14, %rd10, %rd5;
    mad.lo.s32 %r6, %r26, %r23, %r19;
    and.b64 %rd10, %rd14, %rd8;
    setp.gt.u32 %p4, %r23, 65535;
    @%p4 shl.b32 %r11, %r20, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
