    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    mad.lo.u32 %r6, %r3, %r3, %r3;
    shr.u32 %r5, %r3, 7;
    or.b32 %r24, %r6, 0;
    and.b32 %r13, %r5, %r3;
    shr.u64 %rd8, %rd8, 63;
    xor.b32 %r7, %r24, %r24;
    add.s32 %r14, %r13, 2147483647;
    cvt.u32.u64 %r24, %rd8;
    xor.b32 %r27, %r5, 256;
    mul.wide.u32 %rd6, %r24, %r6;
    setp.eq.s32 %p1, %r5, %r5;
    @!%p1 add.s32 %r9, %r6, %r5;
    cvt.s32.s64 %r13, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
