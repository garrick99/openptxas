.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r26, %r3, 7;
    min.s32 %r22, %r26, 256;
    cvt.s64.s32 %rd12, %r3;
    min.s32 %r25, %r26, 65536;
    cvt.s32.s64 %r16, %rd12;
    setp.ge.u32 %p2, %r22, 1;
    @%p2 selp.b32 %r11, %r3, %r26, %p2;
    setp.gt.u32 %p4, %r11, %r3;
    sub.s32 %r18, %r25, %r16;
    setp.gt.s32 %p2, %r3, 5;
    @%p2 selp.b32 %r12, %r3, %r11, %p4;
    mul.lo.s32 %r22, %r25, %r12;
    setp.ls.u32 %p3, %r26, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
