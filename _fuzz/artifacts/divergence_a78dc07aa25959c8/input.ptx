.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r10, %r3, %r3;
    mul.lo.u32 %r4, %r3, 4294967295;
    mul.lo.u32 %r25, %r10, %r4;
    max.u32 %r14, %r4, 2;
    max.s32 %r23, %r4, %r4;
    setp.hi.u32 %p1, %r23, 7;
    @%p1 max.s32 %r15, %r4, %r10;
    shr.u32 %r13, %r4, 0;
    cvt.s64.s32 %rd8, %r10;
    cvt.u64.u32 %rd13, %r15;
    shr.s32 %r18, %r13, 1;
    add.s32 %r9, %r13, %r25;
    mad.lo.s32 %r24, %r4, %r18, %r9;
    and.b32 %r9, %r24, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
