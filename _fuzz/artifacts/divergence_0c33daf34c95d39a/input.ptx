.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p4, %r3, 65535;
    @!%p4 and.b32 %r14, %r3, 8;
    cvt.s64.s32 %rd10, %r14;
    cvt.u32.u64 %r19, %rd10;
    setp.ne.s32 %p4, %r19, 63;
    @!%p4 max.u32 %r6, %r3, %r3;
    mul.wide.u32 %rd11, %r19, %r3;
    max.s32 %r22, %r3, %r19;
    max.s32 %r11, %r14, 2;
    max.s32 %r21, %r19, %r19;
    add.u32 %r25, %r6, 8;
    or.b64 %rd13, %rd11, %rd11;
    sub.s64 %rd10, %rd11, %rd13;
    xor.b32 %r16, %r6, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
