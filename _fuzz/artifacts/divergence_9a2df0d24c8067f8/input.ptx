.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r27, %r3, 0;
    min.u32 %r18, %r27, 31;
    min.u32 %r10, %r27, 4;
    setp.eq.u32 %p3, %r18, %r27;
    @%p3 mul.wide.s32 %rd12, %r3, %r27;
    min.s32 %r23, %r3, 15;
    setp.le.s32 %p4, %r3, 32;
    @%p4 and.b32 %r20, %r10, 31;
    mul.wide.s32 %rd11, %r3, %r18;
    shr.s64 %rd9, %rd11, 0;
    setp.ne.s32 %p2, %r23, %r18;
    @%p2 min.u32 %r27, %r20, %r23;
    shr.s32 %r6, %r20, 1;
    cvt.s32.s64 %r11, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
