.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd14, %r3, %r3;
    shr.s64 %rd13, %rd14, 7;
    shr.s32 %r7, %r3, 7;
    setp.eq.s32 %p4, %r7, %r7;
    @!%p4 shr.u32 %r13, %r7, 15;
    selp.b32 %r20, %r13, %r3, %p4;
    shr.s32 %r11, %r3, 15;
    min.u32 %r25, %r11, 65536;
    xor.b32 %r21, %r20, %r3;
    mul.wide.s32 %rd10, %r25, %r25;
    max.u32 %r26, %r25, %r3;
    xor.b64 %rd6, %rd10, %rd10;
    sub.s32 %r27, %r3, %r20;
    and.b32 %r4, %r21, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
