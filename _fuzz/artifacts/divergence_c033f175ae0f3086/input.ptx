.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p3, %r3, 64;
    setp.hi.u32 %p3, %r3, 5;
    shr.u32 %r20, %r3, 1;
    mul.wide.s32 %rd9, %r3, %r3;
    setp.lt.u32 %p1, %r20, %r20;
    @%p1 mul.wide.s32 %rd10, %r20, %r20;
    mul.wide.u32 %rd8, %r20, %r3;
    shl.b32 %r25, %r3, 3;
    selp.b32 %r25, %r3, %r25, %p1;
    shl.b64 %rd9, %rd8, 16;
    setp.eq.u32 %p1, %r25, 2147483647;
    @!%p1 selp.b32 %r15, %r25, %r25, %p3;
    shr.s64 %rd15, %rd9, 1;
    sub.u32 %r26, %r15, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
