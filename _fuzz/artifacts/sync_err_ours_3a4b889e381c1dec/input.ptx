.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfi.b32 %r17, %r3, %r3, 24, 1;
    popc.b32 %r12, %r17;
    or.b32 %r9, %r17, %r3;
    bfi.b32 %r10, %r12, %r12, 16, 2;
    bfe.s32 %r11, %r17, 24, 1;
    min.u32 %r14, %r12, %r12;
    popc.b32 %r12, %r10;
    bfe.u32 %r16, %r10, 4, 2;
    popc.b32 %r12, %r10;
    popc.b32 %r14, %r14;
    add.u32 %r17, %r16, %r14;
    bfe.u32 %r19, %r16, 4, 24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
