.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfe.s32 %r5, %r3, 8, 24;
    brev.b32 %r20, %r3;
    bfi.b32 %r11, %r5, %r3, 15, 7;
    xor.b32 %r5, %r5, 65535;
    sub.u32 %r12, %r20, %r11;
    bfe.u32 %r9, %r5, 24, 32;
    bfe.s32 %r4, %r11, 15, 16;
    brev.b32 %r8, %r5;
    bfe.u32 %r14, %r4, 15, 7;
    bfe.u32 %r10, %r14, 31, 2;
    sub.u32 %r20, %r8, 2;
    brev.b32 %r11, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
