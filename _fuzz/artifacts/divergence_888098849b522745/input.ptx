.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    add.u32 %r7, %r3, %r3;
    shr.u64 %rd11, %rd8, 4;
    setp.ge.s32 %p4, %r3, 64;
    shr.s32 %r4, %r7, 4;
    max.u32 %r23, %r4, %r7;
    cvt.u32.u64 %r12, %rd11;
    mad.lo.u32 %r8, %r3, %r4, %r12;
    shl.b32 %r7, %r23, 0;
    cvt.u32.u64 %r16, %rd11;
    cvt.s32.s64 %r23, %rd8;
    mul.wide.u32 %rd15, %r4, %r7;
    min.u32 %r12, %r23, %r8;
    selp.b32 %r23, %r23, %r16, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
