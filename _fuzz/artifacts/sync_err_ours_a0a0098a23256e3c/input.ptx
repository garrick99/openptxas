.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r22, %r3, %r3;
    mad.lo.s32 %r17, %r3, %r3, %r22;
    mul.wide.s32 %rd8, %r22, %r17;
    max.s32 %r23, %r3, %r22;
    cvt.s64.s32 %rd15, %r22;
    mul.lo.s32 %r23, %r3, 4;
    mul.lo.u32 %r8, %r3, 7;
    or.b64 %rd11, %rd8, %rd15;
    and.b32 %r24, %r3, 256;
    shl.b64 %rd13, %rd8, 3;
    shl.b64 %rd12, %rd15, 62;
    min.s64 %rd7, %rd15, %rd11;
    mad.lo.s32 %r6, %r8, %r23, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
