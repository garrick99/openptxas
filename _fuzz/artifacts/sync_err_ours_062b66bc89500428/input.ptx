.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd10, %r3, %r3;
    shr.u64 %rd8, %rd10, 0;
    cvt.s32.s64 %r26, %rd10;
    add.u32 %r11, %r26, 16;
    min.s32 %r9, %r3, 2;
    and.b32 %r22, %r9, 8;
    mul.wide.s32 %rd11, %r3, %r11;
    shr.s32 %r16, %r9, 4;
    shr.s64 %rd7, %rd10, 16;
    xor.b32 %r16, %r9, %r22;
    shr.s32 %r7, %r16, 3;
    shl.b32 %r11, %r11, 31;
    min.s64 %rd15, %rd8, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
