.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r23, %r3, 4;
    shr.s32 %r4, %r23, 4;
    mul.lo.s32 %r27, %r23, 3;
    sub.u32 %r20, %r3, %r4;
    cvt.s64.s32 %rd8, %r20;
    shr.u64 %rd5, %rd8, 7;
    max.s64 %rd7, %rd8, %rd8;
    shr.u32 %r16, %r3, 4;
    and.b32 %r18, %r27, 5;
    sub.u32 %r19, %r16, %r18;
    mul.lo.u32 %r6, %r18, 4294967295;
    cvt.s64.s32 %rd11, %r16;
    shr.u64 %rd5, %rd8, 32;
    sub.u64 %rd11, %rd5, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
