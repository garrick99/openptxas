.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p3, %r3, 3;
    @%p3 cvt.u64.u32 %rd12, %r3;
    shl.b32 %r20, %r3, 31;
    shr.s64 %rd6, %rd12, 1;
    setp.ls.u32 %p4, %r20, 65536;
    @%p4 selp.b32 %r19, %r20, %r3, %p4;
    mul.wide.u32 %rd5, %r19, %r19;
    mad.lo.u32 %r15, %r20, %r19, %r19;
    sub.u64 %rd8, %rd6, %rd5;
    setp.ge.u32 %p1, %r20, %r20;
    @%p1 shr.s32 %r12, %r15, 2;
    shr.u32 %r19, %r19, 4;
    shr.s64 %rd12, %rd5, 3;
    sub.s64 %rd10, %rd5, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
