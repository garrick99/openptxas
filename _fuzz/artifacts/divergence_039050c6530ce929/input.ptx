.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r12, %r3, 32;
    shr.s32 %r8, %r12, 2;
    sub.s32 %r7, %r8, 8;
    xor.b32 %r22, %r7, 255;
    mul.wide.s32 %rd14, %r3, %r22;
    setp.lt.s32 %p1, %r22, %r22;
    @%p1 add.s32 %r21, %r8, %r12;
    shl.b32 %r12, %r3, 1;
    shr.s32 %r5, %r12, 4;
    mul.lo.s32 %r24, %r21, 16;
    sub.s32 %r12, %r7, 4294967295;
    max.s32 %r15, %r3, 15;
    sub.u32 %r15, %r21, %r3;
    max.u32 %r27, %r3, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
