.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r20, %r3, 4;
    cvt.s64.s32 %rd9, %r3;
    and.b32 %r14, %r3, 15;
    setp.eq.u32 %p4, %r3, %r3;
    @!%p4 min.u64 %rd9, %rd9, %rd9;
    min.s32 %r15, %r20, %r14;
    shr.s32 %r8, %r20, 2;
    mad.lo.s32 %r16, %r8, %r8, %r3;
    and.b32 %r21, %r3, %r15;
    cvt.s32.s64 %r11, %rd9;
    mul.lo.s32 %r4, %r16, 32;
    mul.lo.u32 %r5, %r8, %r14;
    setp.le.u32 %p4, %r14, 4;
    @%p4 sub.s32 %r23, %r11, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
