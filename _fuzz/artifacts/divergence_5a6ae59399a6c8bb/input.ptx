.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p2, %r3, 4294967295;
    vote.sync.ballot.b32 %r11, %p2, -1;
    or.b32 %r16, %r3, %r0;
    setp.eq.u32 %p1, %r3, 4294967295;
    vote.sync.ballot.b32 %r17, %p1, -1;
    xor.b32 %r11, %r17, %r0;
    shfl.sync.bfly.b32 %r13, %r17, 16, 0x1f, -1;
    min.u32 %r14, %r16, %r13;
    shfl.sync.bfly.b32 %r4, %r16, 16, 0x1f, -1;
    shfl.sync.down.b32 %r12, %r13, 8, 0x1f, -1;
    shfl.sync.idx.b32 %r9, %r16, 7, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
