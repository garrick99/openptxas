.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r26, %r3, 3;
    shr.u32 %r19, %r26, 1;
    mul.wide.u32 %rd5, %r19, %r19;
    xor.b32 %r8, %r3, %r26;
    mul.lo.s32 %r4, %r8, %r8;
    mad.lo.u32 %r16, %r3, %r4, %r4;
    mul.lo.u64 %rd6, %rd5, %rd5;
    shr.s64 %rd12, %rd5, 47;
    and.b32 %r22, %r8, 3;
    cvt.s64.s32 %rd12, %r16;
    mad.lo.s32 %r5, %r19, %r16, %r22;
    setp.ls.u32 %p1, %r3, 65536;
    @%p1 cvt.u32.u64 %r19, %rd12;
    add.s64 %rd10, %rd5, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
