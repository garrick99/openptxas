.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r26, %r3, %r3;
    mul.wide.u32 %rd10, %r3, %r26;
    mad.lo.s32 %r6, %r3, %r3, %r3;
    sub.s32 %r13, %r3, %r26;
    shr.s32 %r19, %r3, 15;
    min.u32 %r5, %r3, %r19;
    mad.lo.u32 %r8, %r13, %r3, %r5;
    mad.lo.s32 %r12, %r5, %r13, %r19;
    max.u32 %r24, %r8, 65536;
    mul.lo.u64 %rd11, %rd10, %rd10;
    shl.b32 %r16, %r12, 2;
    min.u32 %r25, %r24, %r5;
    mad.lo.s32 %r15, %r3, %r3, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
