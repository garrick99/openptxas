.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r10, %r3, 256;
    mul.wide.s32 %rd8, %r10, %r10;
    sub.u64 %rd9, %rd8, %rd8;
    shl.b32 %r6, %r3, 7;
    shr.u32 %r16, %r10, 4;
    mul.wide.s32 %rd15, %r3, %r10;
    shr.s32 %r13, %r10, 1;
    and.b32 %r27, %r16, 63;
    mul.wide.u32 %rd11, %r3, %r6;
    min.u32 %r6, %r13, 8;
    or.b32 %r4, %r27, %r16;
    mul.lo.s32 %r7, %r13, 0;
    shl.b32 %r11, %r6, 31;
    max.s64 %rd8, %rd9, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
