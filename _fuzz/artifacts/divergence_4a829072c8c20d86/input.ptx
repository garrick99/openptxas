.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r4, %r3, 15;
    shl.b32 %r8, %r4, 1;
    setp.gt.u32 %p3, %r8, 2147483647;
    @!%p3 mad.lo.s32 %r8, %r8, %r4, %r3;
    mad.lo.s32 %r12, %r3, %r8, %r3;
    add.s32 %r17, %r3, %r12;
    selp.b32 %r4, %r4, %r3, %p3;
    setp.eq.u32 %p2, %r12, 32;
    @!%p2 mul.wide.u32 %rd7, %r8, %r17;
    max.u32 %r6, %r17, 31;
    min.s32 %r22, %r6, 64;
    shr.u64 %rd12, %rd7, 32;
    min.s32 %r7, %r17, 4;
    mad.lo.u32 %r18, %r3, %r12, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
