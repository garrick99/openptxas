.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r12, %r3, %r3;
    mul.lo.s32 %r22, %r12, 65536;
    mul.wide.u32 %rd7, %r3, %r3;
    sub.u32 %r6, %r3, 4;
    or.b64 %rd7, %rd7, %rd7;
    max.u32 %r16, %r22, %r6;
    setp.ls.u32 %p3, %r3, 63;
    setp.hi.u32 %p2, %r12, %r22;
    @!%p2 mul.wide.s32 %rd9, %r16, %r3;
    shl.b64 %rd7, %rd9, 1;
    cvt.s32.s64 %r15, %rd7;
    or.b32 %r7, %r22, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
