.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r9, %r3, %r3;
    shr.u32 %r13, %r3, 1;
    mul.wide.s32 %rd12, %r3, %r13;
    add.u32 %r9, %r3, 32;
    cvt.u32.u64 %r24, %rd12;
    mad.lo.u32 %r13, %r13, %r9, %r13;
    min.u32 %r23, %r3, 2147483647;
    setp.ne.s32 %p4, %r23, 2147483648;
    sub.s32 %r7, %r9, %r3;
    shr.s64 %rd11, %rd12, 3;
    max.s32 %r22, %r24, %r23;
    mad.lo.s32 %r9, %r13, %r22, %r22;
    mul.wide.s32 %rd14, %r24, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
