.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r6, %r3, %r3;
    add.s32 %r10, %r3, 31;
    cvt.s64.s32 %rd12, %r10;
    mad.lo.u32 %r10, %r6, %r3, %r10;
    cvt.u32.u64 %r12, %rd12;
    min.u32 %r20, %r12, 256;
    sub.s32 %r5, %r3, 2147483647;
    min.u32 %r11, %r5, 2147483647;
    cvt.u32.u64 %r25, %rd12;
    setp.eq.u32 %p1, %r20, %r10;
    @%p1 mul.wide.s32 %rd7, %r11, %r3;
    cvt.s32.s64 %r19, %rd12;
    xor.b32 %r25, %r20, 15;
    mul.lo.u64 %rd10, %rd7, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
