.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r18, %r3, 31;
    cvt.s64.s32 %rd15, %r3;
    mad.lo.u32 %r8, %r3, %r3, %r3;
    mad.lo.u32 %r10, %r8, %r8, %r3;
    shr.u32 %r22, %r8, 1;
    mul.wide.s32 %rd6, %r8, %r22;
    min.s32 %r26, %r18, %r10;
    setp.eq.s32 %p1, %r3, %r10;
    mad.lo.s32 %r18, %r18, %r3, %r26;
    shl.b32 %r16, %r18, 31;
    shl.b64 %rd8, %rd15, 1;
    mul.lo.s32 %r24, %r3, %r3;
    setp.gt.s32 %p2, %r26, 8;
    or.b32 %r16, %r18, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
