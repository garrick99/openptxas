.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p4, %r3, 4;
    @%p4 min.u32 %r24, %r3, 15;
    cvt.u64.u32 %rd8, %r3;
    cvt.s64.s32 %rd10, %r24;
    min.u32 %r12, %r3, %r24;
    selp.b32 %r23, %r3, %r12, %p4;
    sub.s32 %r5, %r12, %r23;
    sub.s32 %r26, %r12, 1;
    mul.wide.u32 %rd8, %r23, %r26;
    setp.hs.u32 %p3, %r3, %r24;
    @%p3 mul.wide.u32 %rd15, %r24, %r24;
    mul.wide.u32 %rd11, %r12, %r12;
    max.u32 %r13, %r24, 256;
    add.u32 %r17, %r24, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
