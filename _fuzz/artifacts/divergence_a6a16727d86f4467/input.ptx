.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    min.s32 %r27, %r3, 63;
    min.s32 %r17, %r3, 15;
    mad.lo.s32 %r15, %r3, %r17, %r17;
    setp.le.u32 %p4, %r27, 64;
    @%p4 cvt.u64.u32 %rd7, %r27;
    and.b32 %r10, %r17, 64;
    selp.b32 %r7, %r10, %r17, %p4;
    add.s32 %r21, %r17, 2;
    mul.wide.u32 %rd9, %r15, %r10;
    or.b32 %r24, %r7, 63;
    setp.hs.u32 %p2, %r27, %r24;
    @%p2 sub.u32 %r20, %r7, 31;
    cvt.s32.s64 %r23, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
