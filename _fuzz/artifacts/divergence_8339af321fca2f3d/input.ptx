.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r7, %r3, 32;
    cvt.u64.u32 %rd15, %r3;
    mul.lo.s64 %rd11, %rd15, %rd15;
    add.u64 %rd7, %rd11, %rd15;
    mul.lo.s32 %r8, %r7, 16;
    xor.b64 %rd11, %rd11, %rd15;
    setp.ne.s32 %p1, %r8, 63;
    @!%p1 shl.b64 %rd8, %rd15, 4;
    max.u32 %r5, %r8, 32;
    shr.s64 %rd12, %rd8, 15;
    max.s32 %r27, %r7, 32;
    and.b32 %r12, %r5, 15;
    shr.u64 %rd6, %rd12, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
