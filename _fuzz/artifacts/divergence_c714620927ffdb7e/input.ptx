.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r17, %r3, 32;
    cvt.u64.u32 %rd12, %r3;
    min.u32 %r16, %r17, 32;
    sub.u32 %r25, %r16, %r3;
    mul.lo.s32 %r23, %r16, %r25;
    cvt.s32.s64 %r11, %rd12;
    shl.b32 %r6, %r11, 4;
    sub.s32 %r15, %r25, 0;
    mul.lo.u32 %r25, %r23, %r11;
    setp.ne.u32 %p2, %r25, %r11;
    @%p2 mul.lo.s32 %r12, %r17, 65535;
    add.s32 %r27, %r16, %r6;
    and.b32 %r23, %r15, %r12;
    mul.wide.u32 %rd7, %r27, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
