.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r6, %r3, %r3;
    cvt.u64.u32 %rd9, %r6;
    max.u32 %r11, %r3, 2147483648;
    add.s32 %r11, %r6, %r11;
    cvt.u64.u32 %rd12, %r6;
    setp.lt.u32 %p2, %r3, %r3;
    cvt.u64.u32 %rd12, %r11;
    selp.b32 %r6, %r6, %r6, %p2;
    max.u32 %r24, %r3, %r3;
    shr.u64 %rd7, %rd9, 0;
    cvt.u32.u64 %r14, %rd9;
    shr.s64 %rd12, %rd12, 15;
    add.u64 %rd11, %rd9, %rd12;
    selp.b32 %r14, %r6, %r3, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
