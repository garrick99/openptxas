.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r8, %r3, %r3;
    bfi.b32 %r4, %r8, %r3, 31, 31;
    add.u32 %r20, %r4, 65535;
    bfe.u32 %r11, %r20, 16, 24;
    clz.b32 %r4, %r8;
    bfi.b32 %r18, %r8, %r20, 31, 16;
    bfe.s32 %r22, %r11, 24, 24;
    brev.b32 %r8, %r18;
    bfe.s32 %r16, %r11, 15, 32;
    bfi.b32 %r4, %r11, %r11, 23, 2;
    clz.b32 %r18, %r20;
    popc.b32 %r4, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
