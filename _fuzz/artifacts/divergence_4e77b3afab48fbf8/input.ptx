.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p1, %r3, 65536;
    @!%p1 mad.lo.s32 %r17, %r3, %r3, %r3;
    cvt.u64.u32 %rd10, %r17;
    min.s32 %r21, %r17, 1;
    cvt.s32.s64 %r21, %rd10;
    cvt.s32.s64 %r19, %rd10;
    shl.b32 %r27, %r21, 0;
    and.b64 %rd14, %rd10, %rd10;
    mul.lo.u64 %rd7, %rd14, %rd10;
    sub.u32 %r14, %r3, 0;
    cvt.s32.s64 %r10, %rd10;
    mul.lo.s32 %r4, %r21, %r17;
    mul.lo.u32 %r14, %r14, %r19;
    mul.lo.s32 %r21, %r4, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
