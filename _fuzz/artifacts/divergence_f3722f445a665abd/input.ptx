.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r9, %r3, 3;
    add.s32 %r20, %r9, 3;
    mul.wide.s32 %rd14, %r3, %r9;
    mul.wide.u32 %rd13, %r3, %r3;
    min.s32 %r25, %r9, %r20;
    max.s32 %r11, %r9, 15;
    add.u32 %r6, %r25, %r11;
    and.b32 %r9, %r20, 3;
    max.s32 %r19, %r3, %r9;
    mul.wide.u32 %rd10, %r11, %r6;
    shl.b64 %rd11, %rd13, 4;
    setp.eq.u32 %p2, %r6, %r19;
    @%p2 selp.b32 %r19, %r6, %r6, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
