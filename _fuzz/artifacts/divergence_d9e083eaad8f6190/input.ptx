.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r18, %r3, %r3;
    max.s32 %r14, %r3, %r3;
    mul.lo.s32 %r17, %r18, %r3;
    sub.s32 %r5, %r18, %r3;
    cvt.s64.s32 %rd9, %r5;
    shl.b64 %rd13, %rd9, 33;
    cvt.s64.s32 %rd12, %r18;
    sub.u64 %rd5, %rd9, %rd9;
    setp.le.s32 %p3, %r18, 8;
    @%p3 xor.b32 %r15, %r5, 0;
    mul.lo.u32 %r13, %r17, %r3;
    selp.b32 %r13, %r13, %r3, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
