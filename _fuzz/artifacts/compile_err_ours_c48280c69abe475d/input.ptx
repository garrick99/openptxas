.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p3, %r3, 65535;
    vote.sync.ballot.b32 %r14, %p3, -1;
    setp.ne.u32 %p2, %r14, 7;
    vote.sync.ballot.b32 %r14, %p2, -1;
    shfl.sync.bfly.b32 %r8, %r3, 8, 0x1f, -1;
    vote.sync.any.pred %p3, %p3, -1;
    shfl.sync.bfly.b32 %r18, %r0, 16, 0x1f, -1;
    or.b32 %r9, %r18, %r3;
    shfl.sync.bfly.b32 %r8, %r14, 2, 0x1f, -1;
    min.u32 %r19, %r8, %r9;
    sub.u32 %r19, %r19, %r9;
    shfl.sync.up.b32 %r12, %r14, 8, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
