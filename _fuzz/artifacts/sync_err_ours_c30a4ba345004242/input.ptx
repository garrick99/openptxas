.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    max.s32 %r26, %r3, %r3;
    shl.b32 %r25, %r26, 16;
    sub.u32 %r13, %r3, %r26;
    shr.s64 %rd12, %rd8, 31;
    add.u32 %r5, %r26, 256;
    mad.lo.s32 %r18, %r13, %r3, %r5;
    add.s32 %r7, %r25, %r25;
    sub.u32 %r10, %r3, %r13;
    setp.ge.s32 %p1, %r26, 255;
    @%p1 shr.u64 %rd13, %rd8, 15;
    mul.lo.s64 %rd13, %rd12, %rd12;
    cvt.u64.u32 %rd13, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
