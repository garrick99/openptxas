.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r17, %r3, 32;
    and.b32 %r13, %r3, 4294967295;
    add.s32 %r6, %r3, %r3;
    shr.s32 %r5, %r6, 30;
    cvt.u64.u32 %rd14, %r13;
    add.s32 %r20, %r3, %r13;
    mul.lo.s64 %rd9, %rd14, %rd14;
    shr.s32 %r14, %r6, 3;
    setp.eq.u32 %p3, %r14, %r20;
    @%p3 add.s32 %r25, %r6, %r17;
    mul.wide.u32 %rd8, %r13, %r6;
    max.u32 %r14, %r5, %r5;
    mad.lo.s32 %r8, %r5, %r13, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
