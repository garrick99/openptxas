.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    max.s32 %r16, %r3, 256;
    max.s32 %r23, %r16, 2147483648;
    mul.lo.u32 %r9, %r23, %r16;
    cvt.s64.s32 %rd8, %r3;
    setp.lt.u32 %p1, %r16, %r3;
    @%p1 cvt.u64.u32 %rd10, %r9;
    xor.b64 %rd6, %rd13, %rd13;
    shr.u32 %r20, %r9, 30;
    mul.wide.u32 %rd11, %r23, %r20;
    setp.eq.s32 %p4, %r20, %r23;
    @%p4 selp.b32 %r10, %r20, %r23, %p4;
    cvt.u64.u32 %rd8, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
