.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r13, %r3, %r3;
    and.b32 %r25, %r13, 255;
    cvt.u64.u32 %rd5, %r13;
    xor.b32 %r13, %r13, 0;
    sub.u32 %r7, %r25, 63;
    cvt.u32.u64 %r12, %rd5;
    and.b32 %r22, %r3, 15;
    min.u32 %r26, %r3, 4;
    or.b32 %r16, %r22, %r22;
    setp.eq.s32 %p4, %r12, %r25;
    selp.b32 %r17, %r3, %r16, %p4;
    cvt.u32.u64 %r16, %rd5;
    mad.lo.u32 %r12, %r26, %r25, %r17;
    shr.u64 %rd8, %rd5, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
