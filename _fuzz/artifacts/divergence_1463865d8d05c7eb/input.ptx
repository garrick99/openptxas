.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r23, %r3, %r3;
    or.b32 %r10, %r23, %r3;
    mul.lo.s32 %r8, %r10, %r10;
    shr.s32 %r7, %r8, 0;
    add.s32 %r13, %r8, %r8;
    cvt.s64.s32 %rd6, %r13;
    and.b32 %r5, %r7, %r8;
    mad.lo.u32 %r24, %r23, %r8, %r13;
    min.s32 %r17, %r5, %r7;
    mad.lo.s32 %r11, %r3, %r17, %r8;
    sub.u64 %rd11, %rd6, %rd6;
    min.s32 %r26, %r17, 255;
    mul.wide.u32 %rd11, %r13, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
