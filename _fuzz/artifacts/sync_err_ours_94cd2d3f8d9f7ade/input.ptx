.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r11, %r3, %r3;
    mul.wide.s32 %rd15, %r11, %r11;
    min.u32 %r7, %r11, 4;
    shr.u64 %rd5, %rd15, 32;
    cvt.s64.s32 %rd10, %r7;
    shr.u64 %rd5, %rd10, 48;
    min.u32 %r21, %r3, 3;
    mul.lo.s32 %r6, %r11, %r3;
    mul.lo.s32 %r11, %r21, 16;
    cvt.u32.u64 %r5, %rd10;
    sub.s32 %r21, %r5, 2;
    mul.wide.s32 %rd6, %r5, %r11;
    mul.lo.s64 %rd9, %rd10, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
