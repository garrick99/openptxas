.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r12, %r3, 64;
    cvt.u64.u32 %rd14, %r3;
    max.u32 %r8, %r3, %r12;
    cvt.s32.s64 %r11, %rd14;
    max.u32 %r25, %r11, 16;
    setp.eq.u32 %p4, %r25, %r8;
    @!%p4 xor.b32 %r15, %r25, %r11;
    shr.s32 %r21, %r8, 31;
    add.s32 %r15, %r8, %r15;
    min.u32 %r22, %r11, 2147483648;
    max.u32 %r10, %r3, 0;
    mul.wide.s32 %rd15, %r8, %r8;
    mad.lo.u32 %r24, %r8, %r15, %r3;
    and.b64 %rd8, %rd14, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
