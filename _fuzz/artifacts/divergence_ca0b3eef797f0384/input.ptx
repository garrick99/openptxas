.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r26, %r3, 65536;
    cvt.s64.s32 %rd8, %r26;
    add.u32 %r18, %r3, 5;
    setp.lo.u32 %p3, %r3, 65535;
    @!%p3 max.u32 %r15, %r18, 2;
    mul.lo.u32 %r10, %r18, 2147483648;
    min.s32 %r23, %r15, 16;
    mul.lo.u32 %r27, %r15, %r3;
    xor.b64 %rd11, %rd8, %rd8;
    cvt.u32.u64 %r9, %rd8;
    cvt.u32.u64 %r20, %rd11;
    selp.b32 %r15, %r26, %r23, %p3;
    setp.hs.u32 %p2, %r15, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
