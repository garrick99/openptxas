.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r19, %r3, %r3;
    add.u32 %r22, %r19, %r3;
    cvt.s64.s32 %rd13, %r19;
    mad.lo.u32 %r16, %r3, %r19, %r22;
    cvt.s32.s64 %r15, %rd13;
    xor.b32 %r9, %r3, %r15;
    shr.u32 %r22, %r15, 2;
    add.s32 %r6, %r15, %r16;
    setp.gt.s32 %p3, %r15, 7;
    mul.lo.s32 %r4, %r16, 2;
    shr.u64 %rd13, %rd13, 16;
    xor.b32 %r5, %r6, %r19;
    mad.lo.u32 %r12, %r5, %r4, %r3;
    sub.u64 %rd9, %rd13, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
