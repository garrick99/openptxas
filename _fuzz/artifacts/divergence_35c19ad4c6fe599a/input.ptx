.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r5, %r3, %r3;
    mul.lo.s32 %r15, %r3, 255;
    setp.lt.s32 %p4, %r3, %r3;
    and.b32 %r14, %r3, %r15;
    xor.b32 %r15, %r15, %r5;
    max.s32 %r20, %r5, %r15;
    sub.s32 %r21, %r15, 4;
    max.s32 %r11, %r20, 31;
    add.s32 %r7, %r14, %r20;
    cvt.s64.s32 %rd7, %r20;
    mad.lo.u32 %r6, %r11, %r20, %r15;
    min.u32 %r7, %r5, %r14;
    sub.u32 %r14, %r11, %r3;
    cvt.s64.s32 %rd6, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
