.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r8, %r3, 4;
    and.b32 %r5, %r8, 64;
    xor.b32 %r7, %r8, 31;
    setp.ls.u32 %p4, %r8, 16;
    @%p4 min.s32 %r24, %r8, 256;
    setp.ge.s32 %p4, %r8, %r8;
    @%p4 shr.s32 %r7, %r3, 15;
    cvt.s64.s32 %rd15, %r7;
    min.u32 %r14, %r8, %r5;
    add.u64 %rd15, %rd15, %rd15;
    shr.u64 %rd11, %rd15, 15;
    sub.u32 %r12, %r8, 3;
    shl.b32 %r20, %r24, 16;
    mul.wide.u32 %rd11, %r14, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
