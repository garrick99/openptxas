.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r21, %r3, 0;
    cvt.s64.s32 %rd6, %r3;
    mul.lo.u32 %r5, %r21, 31;
    max.u32 %r13, %r3, 2;
    setp.lo.u32 %p4, %r13, %r3;
    @%p4 shr.u64 %rd12, %rd6, 15;
    mad.lo.s32 %r8, %r3, %r13, %r13;
    sub.s32 %r19, %r5, 8;
    shr.s32 %r22, %r5, 3;
    shr.u32 %r9, %r22, 15;
    sub.s64 %rd6, %rd6, %rd12;
    cvt.s32.s64 %r15, %rd6;
    mad.lo.s32 %r9, %r15, %r9, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
