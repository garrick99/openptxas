.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p3, %r0, 15;
    vote.sync.ballot.b32 %r14, %p3, -1;
    setp.gt.u32 %p1, %r3, 65535;
    vote.sync.ballot.b32 %r6, %p1, -1;
    shfl.sync.up.b32 %r16, %r6, 4, 0x1f, -1;
    vote.sync.any.pred %p1, %p3, -1;
    add.u32 %r16, %r6, %r3;
    or.b32 %r17, %r3, %r6;
    setp.lt.u32 %p1, %r6, 7;
    vote.sync.ballot.b32 %r17, %p1, -1;
    max.u32 %r9, %r16, %r14;
    vote.sync.all.pred %p3, %p1, -1;
    and.b32 %r7, %r16, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
