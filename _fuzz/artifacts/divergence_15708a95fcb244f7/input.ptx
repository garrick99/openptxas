.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r23, %r3, %r3;
    mul.wide.u32 %rd15, %r23, %r23;
    setp.gt.u32 %p3, %r3, %r23;
    @%p3 mul.lo.s32 %r26, %r23, 64;
    mul.lo.u32 %r20, %r23, 5;
    selp.b32 %r11, %r23, %r26, %p3;
    mul.lo.u32 %r22, %r11, 65536;
    mad.lo.s32 %r24, %r20, %r22, %r22;
    setp.eq.s32 %p3, %r26, %r11;
    @%p3 mul.wide.u32 %rd8, %r22, %r11;
    setp.gt.u32 %p4, %r23, %r23;
    @%p4 or.b64 %rd7, %rd8, %rd15;
    and.b32 %r6, %r11, %r20;
    sub.u32 %r22, %r20, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
