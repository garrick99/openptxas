.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r4, %r3, %r3;
    min.s32 %r14, %r4, 256;
    sub.u32 %r25, %r14, %r14;
    and.b32 %r7, %r4, 31;
    shr.s32 %r6, %r4, 30;
    xor.b32 %r18, %r4, %r3;
    and.b32 %r23, %r4, 8;
    mad.lo.s32 %r26, %r3, %r18, %r23;
    add.s32 %r25, %r3, 2147483647;
    mul.wide.u32 %rd6, %r18, %r23;
    mul.wide.u32 %rd13, %r25, %r3;
    shl.b64 %rd11, %rd13, 3;
    sub.s32 %r22, %r6, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
