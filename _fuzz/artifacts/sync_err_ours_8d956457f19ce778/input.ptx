.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    mul.lo.s32 %r25, %r3, %r3;
    setp.le.u32 %p1, %r3, 256;
    @%p1 add.u32 %r6, %r25, %r3;
    min.s32 %r11, %r25, %r6;
    max.s32 %r22, %r25, 2;
    setp.lo.u32 %p2, %r11, %r11;
    max.s32 %r9, %r25, %r22;
    mul.lo.s32 %r5, %r25, %r11;
    shl.b32 %r21, %r22, 7;
    add.s32 %r26, %r6, %r25;
    cvt.s64.s32 %rd12, %r6;
    cvt.s32.s64 %r11, %rd12;
    mad.lo.u32 %r20, %r25, %r6, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
