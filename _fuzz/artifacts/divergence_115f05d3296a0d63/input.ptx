.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r25, %r3, %r3;
    cvt.s64.s32 %rd8, %r25;
    min.s64 %rd11, %rd8, %rd8;
    max.s64 %rd8, %rd11, %rd8;
    shl.b64 %rd10, %rd8, 47;
    mad.lo.u32 %r16, %r25, %r25, %r3;
    cvt.u64.u32 %rd7, %r25;
    max.s32 %r17, %r16, %r25;
    mul.wide.s32 %rd8, %r3, %r17;
    mul.wide.u32 %rd12, %r17, %r16;
    mul.lo.s32 %r24, %r17, %r16;
    max.u64 %rd10, %rd12, %rd10;
    cvt.s32.s64 %r5, %rd10;
    sub.u32 %r7, %r5, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
