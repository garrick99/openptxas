.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r5, %r3, 3;
    mul.wide.u32 %rd8, %r3, %r3;
    min.s64 %rd10, %rd8, %rd8;
    setp.le.s32 %p4, %r3, 256;
    @%p4 add.u32 %r26, %r5, %r5;
    or.b32 %r16, %r26, 4;
    add.u32 %r25, %r3, 4294967295;
    shr.s64 %rd14, %rd10, 7;
    add.u32 %r22, %r5, 256;
    mad.lo.s32 %r17, %r25, %r16, %r22;
    selp.b32 %r4, %r22, %r3, %p4;
    shr.u32 %r10, %r26, 3;
    sub.s32 %r11, %r26, 65536;
    max.s32 %r16, %r4, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
