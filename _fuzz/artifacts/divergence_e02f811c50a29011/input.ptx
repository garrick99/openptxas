.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r11, %r3, %r3;
    mul.wide.s32 %rd7, %r3, %r3;
    sub.s32 %r10, %r3, %r3;
    shl.b64 %rd11, %rd7, 1;
    or.b32 %r6, %r10, %r3;
    shr.s32 %r13, %r3, 7;
    add.u32 %r19, %r13, %r6;
    cvt.s64.s32 %rd7, %r19;
    mul.wide.s32 %rd10, %r6, %r11;
    shl.b32 %r8, %r13, 4;
    or.b32 %r26, %r6, 16;
    cvt.u32.u64 %r20, %rd10;
    max.s32 %r27, %r19, %r10;
    mul.lo.u32 %r7, %r27, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
