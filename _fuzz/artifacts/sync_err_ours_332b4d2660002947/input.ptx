.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    max.s64 %rd8, %rd7, %rd7;
    shr.s32 %r15, %r3, 15;
    sub.s32 %r20, %r3, %r15;
    setp.gt.s32 %p3, %r3, %r20;
    @!%p3 and.b32 %r5, %r20, %r20;
    add.u32 %r19, %r20, 3;
    mul.wide.u32 %rd12, %r5, %r3;
    cvt.u64.u32 %rd10, %r3;
    shr.u32 %r18, %r5, 4;
    and.b64 %rd5, %rd8, %rd8;
    or.b32 %r8, %r20, 255;
    max.s32 %r14, %r8, %r8;
    add.s32 %r8, %r19, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
