.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    and.b64 %rd6, %rd12, %rd12;
    setp.ne.u32 %p4, %r3, %r3;
    sub.u32 %r22, %r3, 0;
    mul.lo.s32 %r26, %r3, 7;
    max.u32 %r20, %r3, %r26;
    and.b32 %r8, %r3, %r20;
    add.u64 %rd12, %rd6, %rd6;
    shl.b32 %r6, %r8, 30;
    shr.s64 %rd13, %rd6, 32;
    selp.b32 %r20, %r6, %r8, %p4;
    max.s32 %r7, %r26, %r20;
    add.s64 %rd15, %rd6, %rd12;
    cvt.s64.s32 %rd15, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
