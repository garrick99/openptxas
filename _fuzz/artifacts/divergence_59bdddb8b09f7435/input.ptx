.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r27, %r3, 15;
    mad.lo.s32 %r8, %r27, %r27, %r3;
    min.u32 %r17, %r8, %r27;
    xor.b32 %r14, %r27, %r27;
    shr.u32 %r21, %r14, 30;
    add.u32 %r10, %r8, %r14;
    max.s32 %r15, %r10, 5;
    cvt.s64.s32 %rd10, %r8;
    cvt.u64.u32 %rd5, %r17;
    shl.b32 %r17, %r17, 0;
    setp.ls.u32 %p4, %r21, %r10;
    @%p4 shl.b32 %r15, %r14, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
