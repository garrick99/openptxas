.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p2, %r3, %r0;
    vote.sync.ballot.b32 %r4, %p2, -1;
    shfl.sync.up.b32 %r7, %r3, 4, 0x1f, -1;
    or.b32 %r19, %r7, %r7;
    vote.sync.all.pred %p1, %p2, -1;
    sub.u32 %r4, %r7, %r7;
    vote.sync.any.pred %p2, %p1, -1;
    vote.sync.any.pred %p2, %p1, -1;
    shfl.sync.idx.b32 %r16, %r19, 15, 0x1f, -1;
    setp.le.u32 %p2, %r4, 4294967295;
    vote.sync.ballot.b32 %r13, %p2, -1;
    shfl.sync.idx.b32 %r14, %r19, 0, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
