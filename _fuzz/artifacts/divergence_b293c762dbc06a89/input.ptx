.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r17, %r3, 63;
    add.s32 %r15, %r17, 5;
    add.s32 %r4, %r15, 255;
    mul.wide.u32 %rd12, %r17, %r17;
    setp.lt.u32 %p1, %r17, %r4;
    @%p1 mul.wide.u32 %rd15, %r15, %r15;
    mul.lo.u32 %r27, %r3, 64;
    shr.u32 %r20, %r27, 16;
    shr.s32 %r9, %r3, 16;
    and.b32 %r9, %r15, 63;
    add.u64 %rd8, %rd12, %rd15;
    add.s32 %r24, %r17, 7;
    setp.ne.u32 %p3, %r3, %r9;
    @!%p3 cvt.u32.u64 %r12, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
