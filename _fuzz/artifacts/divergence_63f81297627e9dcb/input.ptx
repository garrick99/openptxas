.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r9, %r3, 2;
    min.s32 %r13, %r9, 2147483648;
    max.s32 %r16, %r13, 31;
    cvt.u64.u32 %rd10, %r9;
    setp.eq.s32 %p2, %r3, 256;
    max.s32 %r5, %r16, %r13;
    setp.eq.s32 %p2, %r3, 256;
    add.s32 %r24, %r9, 65536;
    add.s32 %r17, %r24, 2147483648;
    shl.b64 %rd6, %rd10, 32;
    add.u64 %rd13, %rd10, %rd10;
    shl.b64 %rd10, %rd10, 62;
    min.u32 %r19, %r3, %r5;
