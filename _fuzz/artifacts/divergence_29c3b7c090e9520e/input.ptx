.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r26, %r3, %r3;
    shl.b32 %r17, %r3, 1;
    mul.wide.s32 %rd9, %r17, %r26;
    min.s32 %r21, %r17, 3;
    setp.le.s32 %p1, %r3, 16;
    @!%p1 min.u64 %rd11, %rd9, %rd9;
    shr.u64 %rd5, %rd9, 3;
    shr.u64 %rd12, %rd9, 33;
    cvt.s32.s64 %r25, %rd5;
    or.b32 %r15, %r3, %r25;
    add.u32 %r10, %r3, %r25;
    setp.lt.u32 %p4, %r25, 65535;
    @%p4 cvt.s32.s64 %r20, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
