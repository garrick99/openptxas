    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r7, %r3, 30;
    cvt.u64.u32 %rd10, %r3;
    mul.lo.s64 %rd5, %rd10, %rd10;
    cvt.u64.u32 %rd12, %r3;
    add.u32 %r16, %r3, %r7;
    shr.u32 %r23, %r7, 7;
