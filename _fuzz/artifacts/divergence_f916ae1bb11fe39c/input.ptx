.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r8, %r3, 7;
    setp.eq.u32 %p1, %r8, %r3;
    @!%p1 mad.lo.s32 %r23, %r8, %r3, %r8;
    mul.lo.s32 %r20, %r3, 32;
    min.s32 %r20, %r20, %r8;
    sub.s32 %r7, %r3, %r23;
    cvt.s64.s32 %rd13, %r7;
    max.s32 %r6, %r23, %r7;
    mul.lo.s32 %r21, %r6, %r3;
    selp.b32 %r17, %r21, %r6, %p1;
    mul.wide.u32 %rd15, %r20, %r7;
    shr.s32 %r21, %r21, 3;
    setp.ge.s32 %p4, %r21, %r23;
    @!%p4 max.u32 %r14, %r21, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
