.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p3, %r0, 7;
    vote.sync.ballot.b32 %r10, %p3, -1;
    min.u32 %r16, %r10, %r10;
    shfl.sync.idx.b32 %r13, %r16, 1, 0x1f, -1;
    sub.u32 %r17, %r3, %r3;
    shfl.sync.idx.b32 %r10, %r0, 7, 0x1f, -1;
    shfl.sync.bfly.b32 %r14, %r3, 8, 0x1f, -1;
    sub.u32 %r18, %r10, %r14;
    setp.le.u32 %p1, %r18, %r10;
    vote.sync.ballot.b32 %r19, %p1, -1;
    setp.eq.u32 %p3, %r18, %r13;
    vote.sync.ballot.b32 %r19, %p3, -1;
    setp.ge.u32 %p2, %r3, %r14;
    vote.sync.ballot.b32 %r10, %p2, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
