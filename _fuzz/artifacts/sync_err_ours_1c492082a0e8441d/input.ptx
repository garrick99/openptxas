.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    or.b32 %r16, %r3, 255;
    xor.b64 %rd12, %rd12, %rd12;
    add.s32 %r26, %r3, %r16;
    shr.u32 %r23, %r3, 16;
    mul.wide.s32 %rd14, %r3, %r23;
    mad.lo.s32 %r5, %r16, %r26, %r26;
    shr.u32 %r25, %r16, 0;
    shr.u32 %r11, %r5, 31;
    mul.lo.s32 %r7, %r5, 65536;
    mul.wide.s32 %rd11, %r3, %r7;
    add.u32 %r25, %r25, 255;
    mul.wide.u32 %rd5, %r26, %r7;
    add.s32 %r20, %r26, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
