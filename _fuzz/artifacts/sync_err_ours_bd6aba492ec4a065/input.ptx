.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p3, %r3, 2147483648;
    @!%p3 mul.wide.u32 %rd14, %r3, %r3;
    min.u32 %r14, %r3, 4;
    sub.u32 %r4, %r14, %r14;
    and.b32 %r12, %r14, %r3;
    min.u32 %r25, %r4, %r3;
    min.u64 %rd13, %rd14, %rd14;
    or.b32 %r15, %r3, %r12;
    mad.lo.s32 %r24, %r25, %r14, %r4;
    mul.lo.s32 %r7, %r12, %r12;
    setp.lt.u32 %p3, %r14, %r24;
    cvt.u64.u32 %rd14, %r14;
    mad.lo.s32 %r18, %r24, %r12, %r15;
    mul.wide.s32 %rd5, %r7, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
