.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p2, %r3, 4;
    @!%p2 max.s32 %r24, %r3, %r3;
    mul.wide.u32 %rd8, %r3, %r24;
    setp.eq.s32 %p2, %r24, 2147483647;
    @!%p2 max.s32 %r20, %r3, 1;
    sub.s64 %rd15, %rd8, %rd8;
    and.b32 %r12, %r3, 255;
    setp.eq.u32 %p4, %r3, %r24;
    @%p4 shr.u32 %r15, %r20, 31;
    setp.gt.s32 %p4, %r15, %r15;
    mul.wide.u32 %rd6, %r24, %r12;
    add.s64 %rd6, %rd6, %rd8;
    xor.b32 %r11, %r12, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
