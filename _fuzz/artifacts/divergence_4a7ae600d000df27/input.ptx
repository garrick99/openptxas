.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r18, %r3, %r3;
    mul.lo.s32 %r24, %r18, %r18;
    shr.u32 %r5, %r24, 30;
    and.b32 %r4, %r5, 8;
    mad.lo.u32 %r17, %r4, %r4, %r18;
    cvt.s64.s32 %rd11, %r5;
    setp.lo.u32 %p4, %r5, %r3;
    setp.gt.s32 %p2, %r17, 3;
    @%p2 cvt.u32.u64 %r11, %rd11;
    cvt.u32.u64 %r15, %rd11;
    setp.le.s32 %p2, %r17, 63;
    mul.wide.u32 %rd6, %r24, %r5;
    mad.lo.u32 %r16, %r11, %r3, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
