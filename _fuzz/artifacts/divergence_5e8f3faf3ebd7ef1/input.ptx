.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r17, %r3, 2;
    setp.eq.s32 %p3, %r17, 256;
    @%p3 mad.lo.s32 %r8, %r17, %r17, %r17;
    mul.wide.u32 %rd12, %r3, %r3;
    add.u32 %r15, %r17, 2147483648;
    or.b32 %r4, %r15, %r8;
    mul.lo.u64 %rd10, %rd12, %rd12;
    mul.lo.u64 %rd11, %rd10, %rd12;
    cvt.s64.s32 %rd15, %r8;
    mad.lo.s32 %r4, %r3, %r15, %r17;
    shr.s64 %rd14, %rd10, 30;
    mad.lo.u32 %r10, %r17, %r17, %r8;
    setp.ge.s32 %p4, %r8, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
