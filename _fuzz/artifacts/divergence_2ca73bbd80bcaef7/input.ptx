.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r16, %r3, %r3, %r3;
    cvt.u64.u32 %rd8, %r3;
    or.b32 %r7, %r16, 5;
    sub.s32 %r11, %r7, 1;
    max.s32 %r16, %r7, 4294967295;
    shr.u32 %r12, %r7, 0;
    setp.ne.s32 %p1, %r7, 8;
    @!%p1 max.s32 %r18, %r7, 1;
    mad.lo.s32 %r26, %r16, %r18, %r16;
    shr.u64 %rd6, %rd8, 16;
    cvt.s32.s64 %r4, %rd6;
    shr.s32 %r10, %r12, 3;
    min.s32 %r14, %r18, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
