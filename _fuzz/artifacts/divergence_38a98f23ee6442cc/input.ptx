.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd9, %r3, %r3;
    mul.lo.u64 %rd14, %rd9, %rd9;
    min.u32 %r6, %r3, 1;
    min.s32 %r9, %r3, %r3;
    shr.u32 %r13, %r3, 1;
    setp.ne.u32 %p1, %r3, %r9;
    @!%p1 cvt.s32.s64 %r7, %rd14;
    or.b32 %r13, %r7, %r6;
    setp.ls.u32 %p4, %r3, 16;
    @%p4 sub.s64 %rd9, %rd9, %rd9;
    cvt.u32.u64 %r13, %rd9;
    selp.b32 %r11, %r7, %r7, %p1;
    min.s32 %r21, %r9, %r13;
    sub.u32 %r22, %r13, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
