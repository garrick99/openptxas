.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r12, %r3, 4;
    and.b32 %r20, %r3, %r3;
    sub.u32 %r13, %r3, %r20;
    shl.b32 %r6, %r12, 7;
    shr.s32 %r25, %r20, 16;
    cvt.s64.s32 %rd6, %r25;
    shr.s32 %r26, %r6, 7;
    or.b32 %r21, %r12, %r26;
    min.u32 %r24, %r20, %r26;
    shr.u64 %rd13, %rd6, 63;
    xor.b32 %r18, %r24, 255;
    xor.b64 %rd5, %rd13, %rd13;
    shr.u32 %r9, %r18, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
