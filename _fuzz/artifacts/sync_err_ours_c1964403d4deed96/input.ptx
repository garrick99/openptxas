.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r27, %r3, 4294967295;
    min.u32 %r5, %r27, %r27;
    xor.b32 %r23, %r3, 4;
    cvt.u64.u32 %rd7, %r27;
    add.s32 %r6, %r27, %r3;
    shl.b32 %r22, %r27, 1;
    shr.s32 %r9, %r3, 16;
    add.s32 %r21, %r23, %r27;
    setp.le.u32 %p3, %r6, %r6;
    max.u32 %r18, %r23, 15;
    shl.b64 %rd6, %rd7, 1;
    cvt.u32.u64 %r11, %rd7;
    mul.lo.u64 %rd14, %rd6, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
