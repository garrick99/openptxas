.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r8, %r3, %r3, %r3;
    shl.b32 %r20, %r3, 2;
    min.s32 %r8, %r3, %r8;
    setp.ne.s32 %p1, %r8, %r20;
    @%p1 shl.b32 %r13, %r3, 30;
    sub.u32 %r11, %r20, %r13;
    cvt.u64.u32 %rd11, %r8;
    cvt.s64.s32 %rd6, %r11;
    cvt.s64.s32 %rd13, %r20;
    min.u32 %r17, %r13, 16;
    selp.b32 %r24, %r11, %r13, %p1;
    setp.ge.s32 %p1, %r20, 16;
    @!%p1 add.s64 %rd5, %rd11, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
