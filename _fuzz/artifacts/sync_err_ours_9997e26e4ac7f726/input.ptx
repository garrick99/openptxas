.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r7, %r3, %r3;
    mad.lo.u32 %r12, %r3, %r3, %r3;
    shr.s32 %r15, %r12, 4;
    cvt.u64.u32 %rd11, %r15;
    mul.wide.u32 %rd5, %r3, %r15;
    mul.lo.s32 %r18, %r7, %r3;
    cvt.u64.u32 %rd7, %r7;
    mad.lo.u32 %r18, %r15, %r15, %r15;
    setp.eq.u32 %p4, %r15, %r12;
    mul.wide.u32 %rd7, %r3, %r18;
    shl.b32 %r8, %r15, 15;
    cvt.s32.s64 %r15, %rd5;
    cvt.u32.u64 %r8, %rd5;
    min.s64 %rd13, %rd11, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
