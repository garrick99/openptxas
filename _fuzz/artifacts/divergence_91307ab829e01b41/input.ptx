.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p1, %r3, 15;
    @%p1 shl.b32 %r6, %r3, 30;
    max.u32 %r21, %r3, 3;
    add.u32 %r5, %r3, 65536;
    max.s32 %r25, %r6, 2;
    or.b32 %r24, %r5, %r6;
    mad.lo.s32 %r6, %r5, %r24, %r5;
    or.b32 %r22, %r21, 2;
    shr.u32 %r18, %r25, 30;
    cvt.u64.u32 %rd9, %r3;
    add.u32 %r21, %r18, %r18;
    xor.b32 %r27, %r18, %r25;
    min.s32 %r23, %r27, %r24;
    shr.s64 %rd14, %rd9, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
