    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r25, %r3, %r3, %r3;
    sub.u32 %r4, %r3, %r25;
    setp.gt.u32 %p4, %r3, 2147483647;
    @!%p4 mad.lo.s32 %r24, %r25, %r3, %r25;
    mul.wide.u32 %rd14, %r3, %r4;
    selp.b32 %r9, %r24, %r24, %p4;
    xor.b32 %r25, %r25, %r9;
    sub.u32 %r22, %r24, 31;
