.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd10, %r3, %r3;
    and.b32 %r24, %r3, 4294967295;
    max.s32 %r9, %r24, 4;
    mul.lo.s32 %r23, %r9, %r24;
    xor.b32 %r5, %r24, 8;
    max.u32 %r6, %r23, %r3;
    add.s32 %r10, %r6, %r23;
    mul.wide.u32 %rd6, %r6, %r3;
    shr.u32 %r13, %r23, 4;
    mul.lo.s32 %r16, %r9, 2147483647;
    sub.s64 %rd10, %rd10, %rd10;
    max.u32 %r18, %r9, %r23;
    cvt.s64.s32 %rd7, %r3;
    mad.lo.u32 %r26, %r6, %r23, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
