    setp.lt.s32 %p4, %r5, 2147483647;
    @%p4 mul.lo.s32 %r4, %r14, %r14;
    mad.lo.s32 %r17, %r3, %r5, %r5;
    mul.wide.s32 %rd13, %r17, %r14;
    sub.u32 %r10, %r4, %r17;
    shr.u32 %r21, %r14, 30;
