.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r20, %r3, 15;
    mul.lo.u32 %r19, %r3, %r3;
    cvt.s64.s32 %rd6, %r19;
    mul.wide.s32 %rd11, %r20, %r20;
    mul.wide.u32 %rd6, %r20, %r19;
    xor.b32 %r13, %r3, %r19;
    min.s32 %r11, %r19, 4;
    shr.u32 %r10, %r19, 16;
    shl.b32 %r24, %r20, 2;
    shr.s64 %rd11, %rd11, 2;
    max.s32 %r15, %r24, %r19;
    add.u32 %r24, %r24, 31;
    xor.b64 %rd5, %rd11, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
