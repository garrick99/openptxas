.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd8, %r3, %r3;
    setp.gt.s32 %p3, %r3, 3;
    setp.ge.s32 %p1, %r3, 256;
    @%p1 shl.b32 %r8, %r3, 3;
    add.u64 %rd9, %rd8, %rd8;
    sub.u32 %r15, %r3, %r8;
    setp.hi.u32 %p1, %r8, %r3;
    @!%p1 shl.b32 %r4, %r8, 7;
    cvt.u64.u32 %rd10, %r4;
    add.s32 %r17, %r4, 3;
    shr.s32 %r21, %r17, 30;
    mul.lo.s32 %r11, %r21, 2;
    shr.u32 %r10, %r21, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
