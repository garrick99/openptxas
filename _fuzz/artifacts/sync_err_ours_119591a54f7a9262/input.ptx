.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    sub.u32 %r11, %r3, %r3;
    sub.s32 %r7, %r3, %r11;
    shl.b64 %rd5, %rd13, 1;
    cvt.u32.u64 %r17, %rd13;
    or.b64 %rd10, %rd13, %rd5;
    shr.u32 %r13, %r17, 31;
    cvt.u32.u64 %r17, %rd5;
    sub.u32 %r11, %r7, %r13;
    and.b32 %r5, %r7, 15;
    max.s32 %r6, %r7, %r17;
    setp.ne.s32 %p4, %r11, 4;
    @%p4 sub.s32 %r4, %r6, 64;
    cvt.u32.u64 %r20, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
