.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r19, %r3, 65536;
    mul.wide.s32 %rd9, %r3, %r3;
    mad.lo.s32 %r14, %r3, %r3, %r19;
    max.s32 %r24, %r3, %r19;
    setp.ne.u32 %p3, %r19, %r19;
    @%p3 mad.lo.u32 %r5, %r19, %r3, %r24;
    selp.b32 %r10, %r14, %r5, %p3;
    mul.lo.u32 %r19, %r5, %r10;
    mad.lo.s32 %r27, %r14, %r5, %r24;
    shr.s32 %r5, %r3, 16;
    setp.lt.u32 %p1, %r5, %r27;
    @%p1 sub.s64 %rd15, %rd9, %rd9;
    add.u32 %r21, %r3, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
