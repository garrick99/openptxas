.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    mad.lo.s32 %r27, %r3, %r3, %r3;
    cvt.s64.s32 %rd13, %r27;
    max.u64 %rd10, %rd14, %rd13;
    sub.s64 %rd15, %rd10, %rd13;
    cvt.s32.s64 %r24, %rd15;
    cvt.s32.s64 %r19, %rd13;
    setp.eq.u32 %p1, %r27, 2147483647;
    max.u32 %r17, %r3, 7;
    setp.lo.u32 %p3, %r19, 65536;
    @%p3 or.b64 %rd7, %rd15, %rd15;
    setp.gt.s32 %p2, %r19, 65536;
    @%p2 and.b32 %r16, %r24, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
