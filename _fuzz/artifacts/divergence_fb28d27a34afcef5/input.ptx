.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r9, %r3, 15;
    shr.u32 %r8, %r3, 2;
    add.s32 %r11, %r8, 2;
    shr.s32 %r24, %r11, 0;
    mul.wide.u32 %rd5, %r3, %r8;
    shl.b64 %rd8, %rd5, 63;
    cvt.u32.u64 %r21, %rd5;
    and.b32 %r13, %r3, 65535;
    max.u32 %r17, %r8, 0;
    mul.lo.u32 %r14, %r9, %r24;
    shl.b64 %rd15, %rd8, 32;
    mul.lo.u32 %r17, %r14, %r21;
    mad.lo.u32 %r25, %r24, %r17, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
