.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    brev.b32 %r13, %r3;
    add.u32 %r12, %r3, %r13;
    clz.b32 %r10, %r3;
    bfe.s32 %r22, %r12, 4, 7;
    bfe.s32 %r15, %r3, 7, 4;
    bfe.s32 %r17, %r12, 1, 24;
    clz.b32 %r21, %r22;
    bfe.s32 %r4, %r22, 8, 31;
    bfe.s32 %r17, %r22, 8, 7;
    bfe.u32 %r16, %r21, 0, 32;
    bfi.b32 %r11, %r17, %r17, 0, 32;
    clz.b32 %r10, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
