.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r26, %r3, %r3, %r3;
    cvt.s64.s32 %rd7, %r26;
    max.s32 %r16, %r26, 2;
    setp.lo.u32 %p1, %r16, 63;
    cvt.u32.u64 %r20, %rd7;
    max.s32 %r11, %r3, %r26;
    max.s32 %r24, %r16, %r16;
    mul.lo.s32 %r4, %r26, 8;
    add.u32 %r22, %r11, %r16;
    add.u32 %r6, %r26, 255;
    setp.ge.u32 %p1, %r11, %r24;
    shr.s32 %r14, %r24, 4;
    cvt.s32.s64 %r17, %rd7;
    setp.gt.u32 %p2, %r16, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
