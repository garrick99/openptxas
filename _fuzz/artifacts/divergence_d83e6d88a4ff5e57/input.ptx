.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r7, %r3, 16;
    cvt.u64.u32 %rd5, %r7;
    mul.wide.u32 %rd14, %r7, %r3;
    min.s32 %r4, %r3, 255;
    shr.u64 %rd14, %rd14, 7;
    setp.hi.u32 %p3, %r7, %r4;
    @!%p3 selp.b32 %r27, %r4, %r4, %p3;
    max.u32 %r21, %r27, 3;
    shr.s32 %r6, %r21, 1;
    sub.u32 %r15, %r21, %r27;
    or.b32 %r8, %r15, %r21;
    mul.lo.s32 %r27, %r27, %r15;
    selp.b32 %r23, %r8, %r15, %p3;
    selp.b32 %r7, %r21, %r27, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
