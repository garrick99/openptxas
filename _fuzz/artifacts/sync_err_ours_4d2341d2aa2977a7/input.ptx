.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r16, %r3, 4294967295;
    or.b32 %r6, %r3, %r16;
    shl.b32 %r7, %r6, 3;
    sub.s32 %r19, %r16, 2147483647;
    add.u32 %r8, %r7, 65536;
    shr.u32 %r17, %r3, 1;
    mul.wide.s32 %rd6, %r7, %r8;
    mul.wide.s32 %rd13, %r3, %r8;
    mad.lo.u32 %r11, %r16, %r6, %r3;
    max.u32 %r23, %r17, %r8;
    max.s32 %r16, %r8, 64;
    min.u32 %r17, %r16, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
