.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r24, %r3, 256;
    setp.le.s32 %p3, %r24, %r24;
    mul.wide.u32 %rd10, %r24, %r24;
    mul.wide.u32 %rd14, %r24, %r3;
    mul.wide.u32 %rd6, %r3, %r24;
    shr.s32 %r10, %r24, 4;
    selp.b32 %r16, %r10, %r10, %p3;
    selp.b32 %r12, %r3, %r10, %p3;
    cvt.s32.s64 %r23, %rd10;
    mad.lo.u32 %r4, %r12, %r23, %r23;
    min.s64 %rd13, %rd6, %rd6;
    min.s64 %rd13, %rd10, %rd10;
    setp.le.u32 %p2, %r4, %r3;
    sub.u64 %rd7, %rd6, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
