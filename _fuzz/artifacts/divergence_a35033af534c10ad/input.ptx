.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r17, %r3, 4;
    cvt.u64.u32 %rd9, %r17;
    shl.b32 %r5, %r3, 3;
    setp.le.s32 %p3, %r5, %r3;
    @!%p3 selp.b32 %r23, %r3, %r17, %p3;
    cvt.u32.u64 %r24, %rd9;
    shr.s32 %r8, %r23, 7;
    selp.b32 %r26, %r3, %r8, %p3;
    sub.s32 %r17, %r5, %r23;
    min.s32 %r23, %r17, 64;
    cvt.s32.s64 %r10, %rd9;
    cvt.u64.u32 %rd7, %r26;
    mad.lo.u32 %r13, %r26, %r8, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
