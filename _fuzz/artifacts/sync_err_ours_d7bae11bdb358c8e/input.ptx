.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r24, %r3, 7;
    or.b32 %r9, %r24, 4;
    add.s32 %r12, %r3, %r24;
    cvt.s64.s32 %rd14, %r3;
    shl.b32 %r7, %r3, 1;
    add.u32 %r16, %r9, %r7;
    shl.b32 %r22, %r3, 31;
    cvt.s64.s32 %rd7, %r12;
    and.b32 %r13, %r24, %r22;
    mul.lo.s32 %r24, %r13, 256;
    add.u32 %r10, %r12, %r3;
    sub.s32 %r17, %r3, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
