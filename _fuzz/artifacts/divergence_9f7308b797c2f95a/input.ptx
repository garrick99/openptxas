.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r7, %r3, 7;
    setp.ls.u32 %p1, %r3, 4;
    @%p1 selp.b32 %r20, %r3, %r7, %p1;
    mul.wide.u32 %rd8, %r3, %r3;
    shr.u32 %r12, %r3, 7;
    cvt.u32.u64 %r25, %rd8;
    mul.lo.u32 %r15, %r20, %r25;
    mul.wide.u32 %rd8, %r7, %r15;
    mul.wide.u32 %rd7, %r25, %r12;
    cvt.s64.s32 %rd12, %r12;
    cvt.s64.s32 %rd8, %r12;
    max.u32 %r24, %r7, %r20;
    min.s32 %r4, %r24, %r20;
    xor.b32 %r22, %r25, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
