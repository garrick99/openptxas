.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    sub.u32 %r6, %r3, 4294967295;
    xor.b32 %r25, %r6, %r3;
    cvt.u64.u32 %rd13, %r3;
    min.s64 %rd10, %rd13, %rd13;
    sub.u32 %r13, %r3, 15;
    shr.u32 %r17, %r3, 0;
    shl.b64 %rd6, %rd10, 47;
    sub.s32 %r15, %r13, 65535;
    max.u32 %r27, %r3, 2147483647;
    min.s32 %r13, %r17, 31;
    add.u32 %r15, %r17, %r27;
    max.s32 %r7, %r3, 4294967295;
    ld.param.u64 %rd3, [p_out];
