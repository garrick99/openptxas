.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r21, %r3, %r3;
    setp.eq.s32 %p1, %r3, 15;
    @!%p1 selp.b32 %r9, %r3, %r21, %p1;
    max.u32 %r7, %r9, %r21;
    shr.u32 %r16, %r3, 16;
    mul.wide.s32 %rd14, %r16, %r16;
    cvt.u64.u32 %rd10, %r16;
    mul.wide.u32 %rd7, %r3, %r16;
    add.u64 %rd7, %rd7, %rd7;
    shr.s64 %rd6, %rd14, 1;
    min.s32 %r13, %r7, 4;
    setp.ne.s32 %p3, %r13, %r7;
    @%p3 cvt.s64.s32 %rd15, %r13;
    mad.lo.s32 %r7, %r3, %r7, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
