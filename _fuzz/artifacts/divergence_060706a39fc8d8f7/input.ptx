.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r21, %r3, 0;
    add.s32 %r6, %r21, 4;
    mul.lo.s32 %r4, %r21, %r3;
    min.u32 %r13, %r4, 8;
    mul.wide.u32 %rd8, %r4, %r6;
    max.s32 %r12, %r21, %r6;
    shr.s32 %r4, %r12, 16;
    xor.b32 %r11, %r6, %r6;
    add.u32 %r24, %r12, %r21;
    shr.u64 %rd13, %rd8, 7;
    setp.lt.s32 %p4, %r24, %r4;
    @%p4 max.u64 %rd7, %rd8, %rd13;
    cvt.u32.u64 %r24, %rd8;
    selp.b32 %r26, %r12, %r6, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
