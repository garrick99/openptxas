.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    shr.u32 %r23, %r3, 2;
    mul.wide.s32 %rd11, %r23, %r23;
    add.u32 %r8, %r23, %r3;
    shl.b32 %r24, %r8, 31;
    cvt.u32.u64 %r10, %rd11;
    max.s32 %r23, %r23, 65535;
    mad.lo.u32 %r8, %r23, %r10, %r8;
    shl.b64 %rd11, %rd11, 4;
    mad.lo.u32 %r23, %r10, %r23, %r23;
    mul.lo.s32 %r4, %r3, %r10;
    mad.lo.s32 %r9, %r23, %r23, %r3;
    max.u64 %rd11, %rd12, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
