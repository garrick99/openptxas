.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r18, %r3, 30;
    mul.wide.u32 %rd6, %r18, %r18;
    sub.s32 %r19, %r18, 2;
    min.u64 %rd10, %rd6, %rd6;
    max.u32 %r4, %r19, 4;
    cvt.s32.s64 %r26, %rd6;
    setp.ne.s32 %p2, %r18, %r4;
    @%p2 cvt.u32.u64 %r14, %rd6;
    sub.s64 %rd14, %rd10, %rd6;
    or.b32 %r18, %r4, %r14;
    shr.s32 %r23, %r26, 16;
    shr.u64 %rd7, %rd14, 33;
    shr.s32 %r27, %r14, 15;
    cvt.s32.s64 %r13, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
