.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r8, %r3, %r3;
    sub.u32 %r27, %r8, 64;
    mad.lo.s32 %r12, %r3, %r3, %r3;
    cvt.s64.s32 %rd5, %r27;
    shl.b32 %r25, %r8, 30;
    cvt.s32.s64 %r14, %rd5;
    cvt.s64.s32 %rd5, %r12;
    cvt.s64.s32 %rd10, %r12;
    shl.b32 %r17, %r14, 3;
    min.s32 %r23, %r12, 4294967295;
    xor.b32 %r8, %r8, %r27;
    mad.lo.s32 %r13, %r12, %r25, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
