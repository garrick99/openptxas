.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r10, %r3, 2;
    shr.u32 %r5, %r10, 2;
    min.u32 %r15, %r10, %r3;
    min.u32 %r17, %r10, %r3;
    min.u32 %r7, %r3, 64;
    shr.u32 %r4, %r10, 2;
    add.s32 %r22, %r10, %r15;
    shr.u32 %r27, %r5, 0;
    min.u32 %r6, %r22, %r4;
    min.u32 %r14, %r10, %r17;
    min.s32 %r15, %r4, 2147483648;
    or.b32 %r14, %r7, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
