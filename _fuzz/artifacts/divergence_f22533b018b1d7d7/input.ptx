.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    cvt.u64.u32 %rd5, %r3;
    setp.ne.s32 %p1, %r3, %r3;
    add.s64 %rd12, %rd15, %rd5;
    add.u32 %r27, %r3, %r3;
    sub.u64 %rd7, %rd5, %rd5;
    shr.s64 %rd5, %rd15, 33;
    shl.b64 %rd15, %rd15, 2;
    or.b32 %r14, %r27, %r27;
    setp.gt.s32 %p3, %r27, 8;
    @!%p3 sub.u32 %r6, %r14, %r27;
    mad.lo.u32 %r24, %r14, %r3, %r27;
    shl.b32 %r25, %r14, 15;
    or.b32 %r21, %r6, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
