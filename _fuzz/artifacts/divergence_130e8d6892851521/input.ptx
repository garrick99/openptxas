.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r24, %r3, 65536;
    sub.s32 %r7, %r3, 65535;
    or.b32 %r23, %r3, %r24;
    max.u32 %r13, %r7, %r3;
    cvt.s64.s32 %rd5, %r24;
    add.s64 %rd10, %rd5, %rd5;
    max.s32 %r22, %r3, 65536;
    add.s32 %r16, %r7, 31;
    shl.b64 %rd14, %rd5, 47;
    min.u32 %r22, %r23, %r23;
    shl.b32 %r9, %r24, 16;
    sub.u32 %r26, %r24, %r7;
    shr.u32 %r20, %r23, 4;
    max.s32 %r26, %r9, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
