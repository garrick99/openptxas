.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    min.u32 %r22, %r3, 15;
    shl.b32 %r20, %r22, 4;
    shl.b32 %r25, %r3, 2;
    cvt.u32.u64 %r8, %rd9;
    setp.lt.s32 %p1, %r8, 2;
    @!%p1 max.u32 %r14, %r25, %r3;
    shl.b32 %r13, %r25, 3;
    max.u32 %r19, %r13, 0;
    cvt.s64.s32 %rd5, %r14;
    mul.lo.s64 %rd12, %rd9, %rd9;
    selp.b32 %r21, %r13, %r13, %p1;
    min.s32 %r24, %r21, %r19;
    add.u32 %r7, %r19, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
