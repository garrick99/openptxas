.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r9, %r3, %r3;
    add.u32 %r25, %r9, 0;
    max.u32 %r20, %r9, %r3;
    add.u32 %r22, %r20, %r25;
    cvt.u64.u32 %rd12, %r22;
    shr.s32 %r21, %r22, 31;
    shr.u32 %r27, %r25, 15;
    cvt.s64.s32 %rd5, %r3;
    max.u32 %r11, %r9, 7;
    setp.ge.u32 %p2, %r11, 4;
    setp.gt.u32 %p1, %r20, %r21;
    @%p1 or.b32 %r6, %r22, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
