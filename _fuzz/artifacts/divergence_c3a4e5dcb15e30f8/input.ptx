.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r13, %r3, 256;
    setp.le.s32 %p1, %r3, %r13;
    @!%p1 shr.s32 %r23, %r3, 4;
    cvt.u64.u32 %rd5, %r3;
    min.s64 %rd15, %rd5, %rd5;
    sub.s32 %r20, %r13, 4;
    selp.b32 %r23, %r13, %r3, %p1;
    add.u32 %r14, %r20, %r13;
    and.b32 %r7, %r3, %r20;
    min.s64 %rd6, %rd15, %rd15;
    min.s32 %r15, %r13, %r13;
    selp.b32 %r16, %r14, %r23, %p1;
    add.s32 %r18, %r14, %r14;
    mul.lo.s32 %r15, %r7, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
