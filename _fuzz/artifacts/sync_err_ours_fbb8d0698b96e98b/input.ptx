.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    shr.u32 %r6, %r3, 30;
    sub.u32 %r24, %r3, %r6;
    sub.s32 %r19, %r3, 63;
    shl.b64 %rd9, %rd7, 1;
    max.u32 %r8, %r19, %r3;
    shl.b32 %r7, %r8, 4;
    mul.wide.s32 %rd9, %r8, %r6;
    xor.b32 %r23, %r8, 2;
    max.u32 %r18, %r8, %r6;
    setp.gt.u32 %p4, %r18, 1;
    @%p4 cvt.u32.u64 %r16, %rd9;
    cvt.u64.u32 %rd6, %r24;
    shr.s64 %rd13, %rd7, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
