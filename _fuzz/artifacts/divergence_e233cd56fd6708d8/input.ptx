.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r13, %r3, %r3;
    mul.wide.u32 %rd14, %r13, %r13;
    setp.le.u32 %p2, %r13, %r3;
    sub.u32 %r19, %r3, %r13;
    max.u32 %r23, %r3, %r3;
    min.s64 %rd7, %rd14, %rd14;
    add.s32 %r15, %r3, %r23;
    selp.b32 %r5, %r15, %r23, %p2;
    mad.lo.s32 %r8, %r15, %r19, %r19;
    setp.ge.s32 %p4, %r5, 63;
    @%p4 add.u32 %r8, %r19, %r15;
    mad.lo.s32 %r27, %r5, %r13, %r3;
    and.b32 %r25, %r3, %r23;
    sub.s64 %rd7, %rd14, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
