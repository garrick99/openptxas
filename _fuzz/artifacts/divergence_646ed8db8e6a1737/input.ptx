    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    or.b32 %r12, %r3, %r3;
    shr.u64 %rd10, %rd15, 1;
    min.s32 %r19, %r3, %r3;
    sub.s64 %rd5, %rd15, %rd10;
    cvt.u64.u32 %rd14, %r3;
    mul.lo.u32 %r22, %r12, %r12;
    mul.lo.s32 %r22, %r19, 65536;
    sub.s32 %r9, %r3, 5;
    max.s32 %r22, %r22, %r12;
    mad.lo.u32 %r5, %r22, %r22, %r9;
    mul.lo.s32 %r14, %r12, 2147483648;
    setp.ne.s32 %p1, %r5, 0;
    @%p1 max.u64 %rd5, %rd10, %rd5;
