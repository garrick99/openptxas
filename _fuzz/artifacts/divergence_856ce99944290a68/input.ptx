.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r23, %r3, 15;
    mul.lo.s32 %r4, %r23, 15;
    cvt.s64.s32 %rd6, %r4;
    setp.le.u32 %p2, %r23, 63;
    sub.s64 %rd15, %rd6, %rd6;
    min.s32 %r4, %r23, 31;
    min.u32 %r10, %r23, 4294967295;
    selp.b32 %r5, %r10, %r3, %p2;
    cvt.u32.u64 %r6, %rd6;
    sub.s32 %r24, %r5, %r23;
    min.s32 %r22, %r6, %r4;
    selp.b32 %r12, %r23, %r10, %p2;
    max.s32 %r21, %r24, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
