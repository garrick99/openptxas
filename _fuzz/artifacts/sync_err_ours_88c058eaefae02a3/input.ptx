.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    shr.s32 %r14, %r3, 31;
    mul.lo.u32 %r21, %r14, 0;
    sub.s64 %rd14, %rd8, %rd8;
    cvt.s32.s64 %r22, %rd14;
    shl.b32 %r14, %r14, 7;
    shr.s64 %rd13, %rd8, 4;
    cvt.s64.s32 %rd9, %r3;
    or.b64 %rd10, %rd14, %rd9;
    mad.lo.u32 %r14, %r14, %r14, %r22;
    sub.u32 %r16, %r21, 16;
    shr.u64 %rd7, %rd10, 3;
    mul.lo.u32 %r19, %r22, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
