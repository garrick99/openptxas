.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r5, %r3, %r3;
    cvt.u64.u32 %rd12, %r5;
    min.s32 %r24, %r5, 0;
    xor.b32 %r15, %r24, %r24;
    min.u64 %rd8, %rd12, %rd12;
    add.u32 %r21, %r24, 2;
    sub.s32 %r20, %r15, 15;
    mad.lo.u32 %r24, %r5, %r24, %r15;
    shr.u32 %r22, %r5, 16;
    max.s32 %r8, %r20, 2;
    max.u32 %r18, %r21, 64;
    add.s32 %r13, %r8, %r20;
    add.u32 %r16, %r21, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
