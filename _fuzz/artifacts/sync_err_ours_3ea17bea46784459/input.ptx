.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    shl.b64 %rd9, %rd9, 2;
    and.b32 %r5, %r3, %r3;
    shr.u32 %r12, %r5, 15;
    or.b32 %r17, %r12, %r12;
    add.s32 %r6, %r5, %r12;
    mad.lo.u32 %r25, %r3, %r5, %r5;
    mul.wide.s32 %rd5, %r6, %r6;
    mul.wide.u32 %rd12, %r3, %r5;
    cvt.s32.s64 %r8, %rd9;
    or.b32 %r27, %r8, 255;
    and.b32 %r10, %r17, 32;
    xor.b64 %rd14, %rd9, %rd12;
    xor.b32 %r24, %r12, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
