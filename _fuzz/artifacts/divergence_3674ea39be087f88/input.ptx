.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r9, %r3, 255;
    cvt.u64.u32 %rd12, %r9;
    cvt.s64.s32 %rd11, %r3;
    cvt.s32.s64 %r18, %rd11;
    xor.b64 %rd13, %rd11, %rd11;
    mad.lo.s32 %r6, %r9, %r18, %r9;
    sub.u32 %r15, %r3, 256;
    sub.s32 %r21, %r3, 4294967295;
    setp.le.s32 %p2, %r9, 1;
    @%p2 min.u32 %r8, %r15, 32;
    xor.b32 %r26, %r6, %r6;
    max.u32 %r10, %r21, %r3;
    selp.b32 %r12, %r6, %r26, %p2;
    setp.ge.s32 %p3, %r21, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
