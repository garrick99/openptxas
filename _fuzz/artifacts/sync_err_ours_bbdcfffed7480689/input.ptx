.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r10, %r3, 30;
    or.b32 %r15, %r3, 16;
    min.u32 %r24, %r10, 31;
    setp.eq.u32 %p1, %r24, 65535;
    @!%p1 or.b32 %r24, %r10, 2;
    shr.u32 %r19, %r15, 1;
    shr.u32 %r25, %r24, 4;
    min.s32 %r25, %r25, %r3;
    selp.b32 %r20, %r24, %r15, %p1;
    min.u32 %r5, %r3, %r25;
    selp.b32 %r17, %r5, %r19, %p1;
    min.u32 %r4, %r25, 256;
    cvt.u64.u32 %rd9, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
