.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    brev.b32 %r21, %r3;
    clz.b32 %r5, %r21;
    bfi.b32 %r9, %r21, %r3, 23, 16;
    min.u32 %r23, %r3, 1;
    bfe.s32 %r4, %r3, 15, 32;
    bfi.b32 %r20, %r5, %r4, 15, 1;
    bfe.u32 %r4, %r3, 4, 7;
    bfi.b32 %r5, %r9, %r4, 0, 32;
    brev.b32 %r18, %r23;
    bfi.b32 %r18, %r18, %r5, 23, 7;
    bfi.b32 %r19, %r21, %r20, 23, 24;
    popc.b32 %r14, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
