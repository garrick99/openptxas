.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r24, %r3, %r3;
    mul.lo.s32 %r15, %r3, %r3;
    max.u32 %r10, %r15, %r3;
    sub.s32 %r15, %r24, 1;
    mul.lo.s32 %r20, %r15, %r15;
    setp.hs.u32 %p3, %r24, 15;
    @%p3 cvt.s64.s32 %rd8, %r3;
    cvt.s64.s32 %rd9, %r15;
    max.s64 %rd13, %rd9, %rd9;
    add.s32 %r18, %r20, 15;
    or.b32 %r24, %r18, 4294967295;
    mul.lo.u64 %rd13, %rd8, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
