.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    or.b32 %r9, %r3, %r3;
    min.u32 %r8, %r9, %r9;
    mul.lo.s32 %r13, %r8, %r3;
    mul.lo.u32 %r6, %r3, %r9;
    or.b32 %r12, %r13, %r13;
    and.b64 %rd13, %rd14, %rd14;
    max.u32 %r4, %r13, 5;
    setp.le.s32 %p4, %r6, %r8;
    @%p4 min.s32 %r27, %r3, %r3;
    cvt.s32.s64 %r18, %rd14;
    min.u32 %r12, %r8, %r27;
    add.s64 %rd8, %rd13, %rd13;
    min.s32 %r27, %r9, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
