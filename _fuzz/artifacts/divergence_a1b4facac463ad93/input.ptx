.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r12, %r3, 31;
    shl.b32 %r11, %r3, 2;
    add.u32 %r4, %r3, 8;
    cvt.s64.s32 %rd11, %r3;
    mad.lo.u32 %r27, %r12, %r12, %r4;
    and.b64 %rd11, %rd11, %rd11;
    max.s32 %r21, %r12, %r12;
    setp.le.u32 %p3, %r21, 255;
    @%p3 or.b32 %r12, %r12, %r21;
    and.b32 %r12, %r11, 0;
    mul.wide.s32 %rd5, %r3, %r21;
    mul.lo.s32 %r10, %r4, 5;
    setp.lt.s32 %p2, %r10, %r12;
    @%p2 cvt.u32.u64 %r19, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
