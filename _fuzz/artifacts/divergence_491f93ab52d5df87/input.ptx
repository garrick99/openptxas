.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r16, %r0, %r3;
    shfl.sync.idx.b32 %r8, %r0, 7, 0x1f, -1;
    shfl.sync.bfly.b32 %r17, %r0, 1, 0x1f, -1;
    sub.u32 %r7, %r16, %r17;
    setp.lt.u32 %p2, %r3, %r0;
    vote.sync.ballot.b32 %r16, %p2, -1;
    setp.ne.u32 %p1, %r3, %r17;
    vote.sync.ballot.b32 %r10, %p1, -1;
    shfl.sync.idx.b32 %r4, %r17, 1, 0x1f, -1;
    shfl.sync.idx.b32 %r10, %r16, 15, 0x1f, -1;
    add.u32 %r6, %r7, %r4;
    add.u32 %r5, %r7, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
