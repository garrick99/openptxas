.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd7, %r3, %r3;
    min.s32 %r9, %r3, %r3;
    setp.ge.u32 %p4, %r9, %r9;
    @%p4 xor.b64 %rd14, %rd7, %rd7;
    mul.lo.u32 %r26, %r9, 8;
    or.b32 %r4, %r3, %r9;
    shr.u32 %r12, %r26, 15;
    mul.wide.s32 %rd6, %r9, %r3;
    setp.le.s32 %p2, %r9, %r26;
    @%p2 max.s32 %r20, %r26, 3;
    cvt.s32.s64 %r19, %rd6;
    cvt.u32.u64 %r16, %rd14;
    mul.wide.s32 %rd7, %r4, %r12;
    mul.lo.u32 %r14, %r16, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
