.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r20, %r3, %r3;
    mul.lo.s32 %r27, %r3, %r20;
    max.u32 %r22, %r20, %r20;
    cvt.s64.s32 %rd12, %r20;
    setp.ls.u32 %p2, %r3, 3;
    shl.b32 %r19, %r22, 4;
    sub.s32 %r8, %r3, 64;
    cvt.u32.u64 %r22, %rd12;
    mad.lo.s32 %r14, %r8, %r27, %r8;
    min.s32 %r14, %r3, %r8;
    max.u32 %r21, %r8, 2;
    max.s64 %rd12, %rd12, %rd12;
    add.s32 %r11, %r8, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
