.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r8, %r3, 0;
    mad.lo.s32 %r8, %r3, %r8, %r3;
    shr.u32 %r9, %r3, 4;
    max.u32 %r6, %r8, 4;
    shr.u32 %r8, %r6, 7;
    sub.s32 %r25, %r9, %r6;
    cvt.u64.u32 %rd10, %r8;
    setp.lt.s32 %p1, %r6, 2;
    @%p1 min.s32 %r23, %r6, %r9;
    setp.ne.s32 %p3, %r9, 255;
    setp.hi.u32 %p4, %r6, 32;
    mul.wide.s32 %rd7, %r23, %r25;
    max.u32 %r7, %r23, 8;
    selp.b32 %r13, %r25, %r6, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
