.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r8, %r3, %r3;
    sub.s32 %r22, %r8, 7;
    or.b32 %r25, %r22, 5;
    shr.s32 %r16, %r22, 4;
    mul.lo.s32 %r26, %r25, 16;
    setp.ne.s32 %p2, %r22, 31;
    @!%p2 and.b32 %r8, %r22, 5;
    cvt.u64.u32 %rd5, %r16;
    mul.wide.u32 %rd15, %r25, %r25;
    cvt.u32.u64 %r7, %rd5;
    setp.ne.s32 %p4, %r26, %r3;
    @!%p4 shl.b32 %r22, %r3, 3;
    mul.lo.s32 %r14, %r22, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
