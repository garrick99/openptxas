.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r19, %r3, 4294967295;
    setp.ge.s32 %p1, %r19, 64;
    @!%p1 selp.b32 %r21, %r3, %r19, %p1;
    mul.wide.u32 %rd12, %r3, %r21;
    shr.u32 %r20, %r19, 4;
    add.s64 %rd9, %rd12, %rd12;
    shr.s64 %rd8, %rd12, 0;
    min.s32 %r15, %r21, %r20;
    mul.wide.s32 %rd10, %r21, %r21;
    or.b32 %r10, %r20, %r21;
    mul.lo.s32 %r14, %r20, %r21;
    cvt.u32.u64 %r10, %rd12;
    sub.u32 %r15, %r14, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
