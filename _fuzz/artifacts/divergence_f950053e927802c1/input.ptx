.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r16, %r3, 256;
    mad.lo.u32 %r5, %r16, %r16, %r16;
    max.s32 %r17, %r5, %r16;
    cvt.s64.s32 %rd12, %r17;
    setp.hs.u32 %p4, %r3, 1;
    selp.b32 %r12, %r17, %r5, %p4;
    sub.u32 %r7, %r12, %r12;
    add.s32 %r13, %r3, 65535;
    max.u64 %rd8, %rd12, %rd12;
    shl.b32 %r17, %r5, 2;
    selp.b32 %r7, %r13, %r7, %p4;
    mul.wide.s32 %rd10, %r13, %r3;
    sub.u32 %r22, %r7, 2147483647;
    mul.lo.u32 %r5, %r22, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
