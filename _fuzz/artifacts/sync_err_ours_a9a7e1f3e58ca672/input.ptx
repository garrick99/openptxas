.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r21, %r3, %r3, %r3;
    cvt.u64.u32 %rd8, %r21;
    cvt.u32.u64 %r6, %rd8;
    or.b32 %r14, %r6, 63;
    xor.b32 %r25, %r14, 65535;
    mad.lo.u32 %r12, %r6, %r14, %r6;
    shr.s32 %r26, %r3, 1;
    mul.wide.s32 %rd11, %r21, %r3;
    shr.u32 %r5, %r25, 31;
    setp.lt.u32 %p3, %r26, 1;
    mul.wide.s32 %rd7, %r3, %r21;
    shl.b32 %r14, %r12, 2;
    xor.b32 %r19, %r14, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
