.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r18, %r3, 5;
    cvt.u64.u32 %rd5, %r18;
    or.b64 %rd10, %rd5, %rd5;
    xor.b32 %r19, %r3, %r3;
    max.s32 %r5, %r3, 2147483648;
    mad.lo.u32 %r24, %r5, %r3, %r19;
    or.b32 %r14, %r3, 2;
    xor.b32 %r15, %r14, 4;
    cvt.s32.s64 %r27, %rd5;
    shl.b32 %r4, %r5, 2;
    add.u32 %r21, %r27, %r14;
    mad.lo.s32 %r8, %r4, %r18, %r24;
    xor.b32 %r16, %r8, %r14;
    max.s32 %r21, %r3, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
