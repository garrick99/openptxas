.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r9, %r3, %r3;
    cvt.u64.u32 %rd8, %r9;
    add.u32 %r22, %r3, 65535;
    min.s32 %r16, %r22, %r9;
    or.b32 %r26, %r9, 32;
    shl.b32 %r27, %r26, 3;
    mad.lo.s32 %r12, %r26, %r16, %r9;
    shr.u64 %rd8, %rd8, 3;
    shl.b32 %r11, %r16, 4;
    mad.lo.u32 %r5, %r11, %r9, %r27;
    setp.gt.s32 %p4, %r22, %r5;
    sub.s32 %r4, %r11, %r22;
    max.s32 %r27, %r22, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
