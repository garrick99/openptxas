.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r21, %r3, 65536;
    min.u32 %r16, %r21, 7;
    max.s32 %r9, %r16, 65536;
    cvt.s64.s32 %rd9, %r16;
    mad.lo.u32 %r25, %r21, %r21, %r21;
    shl.b32 %r26, %r3, 4;
    mad.lo.s32 %r17, %r9, %r3, %r3;
    shl.b32 %r22, %r9, 15;
    max.s32 %r24, %r21, 63;
    min.u32 %r26, %r3, 0;
    setp.eq.s32 %p4, %r22, 65535;
    @!%p4 or.b32 %r14, %r22, %r25;
    sub.s64 %rd5, %rd9, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
