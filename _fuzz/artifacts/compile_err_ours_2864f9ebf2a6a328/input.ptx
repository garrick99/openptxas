.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r19, %r3, %r3;
    shfl.sync.idx.b32 %r12, %r19, 15, 0x1f, -1;
    setp.lt.u32 %p2, %r3, 65535;
    vote.sync.ballot.b32 %r11, %p2, -1;
    vote.sync.any.pred %p2, %p2, -1;
    setp.gt.u32 %p1, %r19, 8;
    vote.sync.ballot.b32 %r6, %p1, -1;
    vote.sync.all.pred %p3, %p2, -1;
    shfl.sync.up.b32 %r6, %r0, 2, 0x1f, -1;
    setp.le.u32 %p2, %r6, 255;
    vote.sync.ballot.b32 %r10, %p2, -1;
    shfl.sync.up.b32 %r10, %r10, 16, 0x1f, -1;
    setp.ge.u32 %p3, %r10, 255;
    vote.sync.ballot.b32 %r7, %p3, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
