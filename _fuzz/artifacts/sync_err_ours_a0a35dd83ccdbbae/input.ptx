.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    shl.b32 %r19, %r3, 1;
    cvt.u32.u64 %r18, %rd5;
    add.u64 %rd15, %rd5, %rd5;
    shl.b32 %r21, %r18, 4;
    shr.s64 %rd7, %rd5, 4;
    cvt.s32.s64 %r8, %rd7;
    xor.b32 %r16, %r21, 16;
    add.s64 %rd6, %rd5, %rd15;
    sub.s32 %r20, %r18, 0;
    sub.s32 %r16, %r21, 3;
    shl.b32 %r27, %r8, 30;
    add.u32 %r21, %r18, 32;
    min.u64 %rd12, %rd5, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
