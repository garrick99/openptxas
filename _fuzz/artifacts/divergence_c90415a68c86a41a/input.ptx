.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    shl.b32 %r8, %r3, 4;
    add.u64 %rd11, %rd6, %rd6;
    cvt.s64.s32 %rd15, %r8;
    setp.eq.u32 %p1, %r3, 3;
    @%p1 add.u32 %r19, %r8, %r3;
    max.u32 %r17, %r3, %r8;
    add.s32 %r18, %r19, 2;
    selp.b32 %r16, %r8, %r17, %p1;
    min.u64 %rd12, %rd6, %rd6;
    sub.s32 %r17, %r17, %r18;
    max.s64 %rd13, %rd11, %rd11;
    add.u32 %r11, %r16, 1;
    shr.s32 %r20, %r17, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
