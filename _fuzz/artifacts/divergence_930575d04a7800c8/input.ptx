.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r8, %r3, 3;
    cvt.s64.s32 %rd11, %r8;
    setp.lo.u32 %p4, %r3, %r8;
    setp.ne.s32 %p4, %r3, %r3;
    @%p4 max.s32 %r18, %r3, %r8;
    max.u32 %r19, %r8, %r3;
    shl.b64 %rd8, %rd11, 1;
    or.b32 %r15, %r8, 64;
    xor.b32 %r22, %r8, %r8;
    and.b64 %rd15, %rd8, %rd8;
    mul.wide.u32 %rd7, %r22, %r22;
    cvt.u32.u64 %r22, %rd7;
    max.s32 %r10, %r8, %r19;
    cvt.s64.s32 %rd6, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
