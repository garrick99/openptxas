.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r18, %r3, %r0;
    setp.gt.u32 %p3, %r3, %r0;
    vote.sync.ballot.b32 %r6, %p3, -1;
    sub.u32 %r4, %r3, %r6;
    setp.ne.u32 %p1, %r18, 16;
    vote.sync.ballot.b32 %r4, %p1, -1;
    add.u32 %r8, %r18, %r3;
    setp.lt.u32 %p2, %r0, %r0;
    vote.sync.ballot.b32 %r13, %p2, -1;
    max.u32 %r18, %r0, %r0;
    shfl.sync.up.b32 %r15, %r6, 8, 0x1f, -1;
    sub.u32 %r19, %r6, %r3;
    or.b32 %r11, %r0, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
