.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r26, %r3, %r3;
    max.u32 %r23, %r26, %r26;
    cvt.s64.s32 %rd12, %r26;
    max.u32 %r14, %r26, 8;
    min.u32 %r20, %r26, 8;
    add.s32 %r13, %r23, %r3;
    cvt.u64.u32 %rd6, %r26;
    min.u64 %rd8, %rd12, %rd6;
    cvt.u64.u32 %rd13, %r3;
    cvt.u32.u64 %r13, %rd6;
    min.u32 %r19, %r20, %r23;
    add.u32 %r16, %r20, %r20;
    xor.b32 %r7, %r13, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
