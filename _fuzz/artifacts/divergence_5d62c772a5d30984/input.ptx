.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r12, %r3, 8;
    shl.b32 %r11, %r12, 0;
    mul.lo.s32 %r13, %r11, %r12;
    and.b32 %r16, %r13, 4;
    mul.wide.s32 %rd5, %r16, %r16;
    mul.wide.u32 %rd11, %r16, %r11;
    or.b32 %r18, %r12, 8;
    cvt.s32.s64 %r27, %rd5;
    sub.u32 %r4, %r13, %r11;
    mul.lo.s32 %r17, %r11, %r11;
    mul.wide.s32 %rd7, %r12, %r12;
    sub.u32 %r25, %r3, %r4;
    and.b32 %r11, %r12, 5;
    max.s32 %r9, %r4, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
