.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r4, %r3, %r3;
    max.s32 %r25, %r4, 0;
    or.b32 %r16, %r25, %r4;
    max.s32 %r27, %r4, %r3;
    setp.lt.u32 %p4, %r4, 1;
    @%p4 xor.b32 %r9, %r25, 2147483648;
    add.s32 %r20, %r25, 256;
    xor.b32 %r14, %r27, 31;
    mul.lo.s32 %r23, %r14, 255;
    mad.lo.u32 %r9, %r16, %r25, %r23;
    setp.ge.s32 %p2, %r27, %r20;
    @!%p2 selp.b32 %r7, %r25, %r3, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
