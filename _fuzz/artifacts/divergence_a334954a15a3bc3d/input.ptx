.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p3, %r3, %r3;
    cvt.u64.u32 %rd10, %r3;
    setp.lt.s32 %p2, %r3, 16;
    @!%p2 shl.b32 %r22, %r3, 2;
    sub.u32 %r25, %r22, 15;
    min.s32 %r13, %r22, 32;
    mad.lo.u32 %r13, %r22, %r3, %r3;
    sub.u32 %r16, %r13, %r3;
    mad.lo.s32 %r17, %r25, %r3, %r22;
    mul.wide.u32 %rd5, %r16, %r3;
    mad.lo.u32 %r14, %r3, %r22, %r17;
    cvt.u64.u32 %rd6, %r14;
    cvt.u64.u32 %rd9, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
