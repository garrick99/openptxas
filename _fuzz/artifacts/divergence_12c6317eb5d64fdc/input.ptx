.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r23, %r3, 1;
    cvt.s64.s32 %rd10, %r23;
    or.b32 %r20, %r23, 2;
    max.u64 %rd10, %rd10, %rd10;
    mul.wide.u32 %rd11, %r20, %r20;
    max.s32 %r8, %r3, 5;
    shr.u32 %r26, %r20, 7;
    sub.u64 %rd12, %rd11, %rd11;
    add.s32 %r8, %r23, 16;
    cvt.u64.u32 %rd5, %r3;
    min.u32 %r16, %r8, 16;
    setp.ge.u32 %p2, %r8, 8;
    setp.lt.s32 %p4, %r26, %r16;
    @%p4 min.u32 %r23, %r8, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
