.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r25, %r3, %r3;
    mad.lo.s32 %r23, %r3, %r3, %r25;
    cvt.u64.u32 %rd8, %r25;
    min.s32 %r20, %r25, %r23;
    shr.u64 %rd12, %rd8, 48;
    mul.lo.u64 %rd13, %rd12, %rd12;
    setp.le.u32 %p1, %r23, %r25;
    @!%p1 xor.b32 %r4, %r23, %r23;
    mul.wide.u32 %rd10, %r23, %r20;
    and.b64 %rd6, %rd8, %rd10;
    mad.lo.u32 %r13, %r3, %r20, %r23;
    xor.b32 %r16, %r25, 31;
    add.u64 %rd9, %rd8, %rd13;
    max.u32 %r22, %r25, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
