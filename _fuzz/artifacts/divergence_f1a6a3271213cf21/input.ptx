.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    cvt.u32.u64 %r13, %rd7;
    shr.s64 %rd5, %rd7, 63;
    and.b32 %r5, %r3, 31;
    setp.ge.s32 %p4, %r5, %r3;
    @%p4 shr.s32 %r6, %r3, 31;
    mul.lo.u32 %r6, %r6, 64;
    setp.eq.u32 %p4, %r13, 63;
    and.b32 %r14, %r5, %r6;
    mul.lo.u32 %r19, %r3, %r5;
    mul.lo.s64 %rd7, %rd7, %rd7;
    mul.lo.u32 %r14, %r5, %r5;
    mul.wide.u32 %rd5, %r19, %r5;
    mul.wide.u32 %rd8, %r14, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
