.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    and.b32 %r12, %r3, %r3;
    add.u64 %rd14, %rd5, %rd5;
    or.b32 %r24, %r12, 3;
    mul.lo.u32 %r8, %r12, 2;
    shr.u32 %r8, %r24, 1;
    mul.wide.u32 %rd14, %r3, %r12;
    xor.b64 %rd10, %rd14, %rd5;
    xor.b32 %r23, %r8, 3;
    shr.s32 %r24, %r3, 1;
    min.s32 %r25, %r23, 65535;
    setp.eq.s32 %p2, %r12, 16;
    @!%p2 or.b32 %r9, %r12, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
