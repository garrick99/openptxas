.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r13, %r3, 63;
    mul.wide.s32 %rd12, %r3, %r3;
    cvt.s64.s32 %rd12, %r3;
    max.u64 %rd5, %rd12, %rd12;
    cvt.s64.s32 %rd14, %r13;
    mad.lo.s32 %r26, %r13, %r3, %r3;
    shr.s64 %rd12, %rd5, 63;
    max.u32 %r14, %r13, %r26;
    and.b32 %r6, %r13, %r26;
    shl.b32 %r21, %r26, 7;
    shr.u32 %r21, %r13, 7;
    min.s32 %r7, %r13, 5;
    cvt.u64.u32 %rd10, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
