.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r25, %r3, 2147483647;
    mul.wide.u32 %rd14, %r25, %r25;
    add.u32 %r25, %r3, 255;
    sub.s64 %rd15, %rd14, %rd14;
    mad.lo.u32 %r8, %r25, %r3, %r25;
    cvt.u64.u32 %rd5, %r3;
    mad.lo.u32 %r14, %r8, %r8, %r25;
    max.s64 %rd9, %rd5, %rd15;
    and.b32 %r17, %r25, 31;
    add.u32 %r16, %r3, 1;
    mul.wide.s32 %rd8, %r17, %r16;
    add.s64 %rd5, %rd15, %rd9;
    shr.u64 %rd11, %rd15, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
