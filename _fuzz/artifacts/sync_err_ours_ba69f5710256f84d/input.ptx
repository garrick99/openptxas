.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    min.u64 %rd11, %rd12, %rd12;
    mul.lo.s32 %r21, %r3, %r3;
    sub.u32 %r24, %r21, %r3;
    add.u32 %r19, %r24, 256;
    cvt.u64.u32 %rd14, %r21;
    max.u32 %r17, %r3, %r19;
    shr.s64 %rd13, %rd14, 30;
    mad.lo.u32 %r17, %r17, %r21, %r3;
    mad.lo.s32 %r5, %r17, %r19, %r21;
    mul.lo.u64 %rd6, %rd12, %rd14;
    xor.b32 %r8, %r24, %r21;
    mul.lo.s64 %rd14, %rd13, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
