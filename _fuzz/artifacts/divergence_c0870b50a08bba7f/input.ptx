.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r14, %r3, 4294967295;
    xor.b32 %r17, %r3, %r3;
    min.s32 %r22, %r14, %r14;
    shr.s32 %r10, %r17, 3;
    add.s32 %r23, %r22, %r22;
    max.s32 %r20, %r22, 15;
    mad.lo.u32 %r13, %r14, %r23, %r17;
    and.b32 %r20, %r20, 16;
    cvt.u64.u32 %rd8, %r23;
    shr.s32 %r18, %r3, 2;
    setp.lo.u32 %p4, %r22, 63;
    @!%p4 max.s32 %r27, %r18, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
