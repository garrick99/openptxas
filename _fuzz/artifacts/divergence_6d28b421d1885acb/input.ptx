.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p2, %r3, %r3;
    @%p2 and.b32 %r9, %r3, %r3;
    setp.ge.s32 %p3, %r3, 3;
    @%p3 mul.wide.s32 %rd9, %r9, %r3;
    min.s32 %r16, %r3, 3;
    sub.u32 %r27, %r3, %r16;
    mul.lo.u32 %r16, %r16, %r9;
    add.s32 %r14, %r9, %r27;
    setp.ge.s32 %p3, %r3, 64;
    @%p3 xor.b32 %r14, %r14, %r9;
    mul.lo.u64 %rd7, %rd9, %rd9;
    shr.s64 %rd6, %rd7, 0;
    shl.b32 %r26, %r14, 30;
    mul.wide.s32 %rd7, %r27, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
