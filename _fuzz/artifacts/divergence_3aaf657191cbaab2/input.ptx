.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p1, %r3, 64;
    @%p1 cvt.s64.s32 %rd13, %r3;
    mad.lo.u32 %r11, %r3, %r3, %r3;
    xor.b32 %r14, %r3, 16;
    selp.b32 %r16, %r3, %r11, %p1;
    setp.ne.s32 %p1, %r11, 4294967295;
    @%p1 mad.lo.u32 %r15, %r11, %r14, %r11;
    selp.b32 %r20, %r3, %r16, %p1;
    sub.s32 %r12, %r14, %r11;
    shr.s64 %rd12, %rd13, 3;
    setp.gt.u32 %p4, %r14, %r12;
    sub.u32 %r10, %r11, 63;
    xor.b32 %r20, %r11, %r14;
    selp.b32 %r12, %r16, %r11, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
