.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r22, %r3, 4294967295;
    min.u32 %r20, %r22, 8;
    cvt.u64.u32 %rd10, %r3;
    shl.b32 %r23, %r20, 2;
    cvt.s32.s64 %r25, %rd10;
    add.u32 %r17, %r22, %r20;
    min.u32 %r8, %r22, 65536;
    shr.s32 %r24, %r23, 3;
    shr.s64 %rd8, %rd10, 48;
    xor.b64 %rd6, %rd8, %rd10;
    mul.lo.u64 %rd9, %rd10, %rd10;
    sub.u32 %r4, %r23, 2147483648;
    xor.b32 %r12, %r17, %r23;
    cvt.s64.s32 %rd13, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
