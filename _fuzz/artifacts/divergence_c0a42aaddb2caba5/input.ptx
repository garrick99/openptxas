.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p1, %r3, 0;
    @%p1 sub.s32 %r26, %r3, 15;
    add.u32 %r14, %r26, 4294967295;
    min.u32 %r4, %r3, %r26;
    or.b32 %r9, %r26, %r3;
    shr.s32 %r6, %r4, 31;
    add.u32 %r19, %r14, %r14;
    max.s32 %r9, %r14, %r6;
    min.s32 %r26, %r9, %r3;
    cvt.u64.u32 %rd7, %r26;
    shr.s64 %rd12, %rd7, 31;
    or.b32 %r27, %r26, 1;
    add.s32 %r19, %r27, %r26;
    shl.b64 %rd9, %rd7, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
