.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    min.u64 %rd15, %rd12, %rd12;
    mul.lo.s32 %r21, %r3, %r3;
    shr.s32 %r4, %r3, 1;
    setp.gt.u32 %p4, %r4, %r4;
    @%p4 sub.s32 %r6, %r4, %r21;
    cvt.s64.s32 %rd14, %r6;
    setp.ne.s32 %p2, %r3, 8;
    @%p2 sub.u32 %r18, %r4, %r21;
    add.u64 %rd8, %rd12, %rd12;
    sub.s32 %r18, %r6, 64;
    min.s32 %r8, %r21, %r18;
    setp.le.u32 %p1, %r6, %r18;
    shl.b64 %rd6, %rd15, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
