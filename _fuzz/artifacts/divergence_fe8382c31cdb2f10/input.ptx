    cvt.s64.s32 %rd9, %r25;
    min.s32 %r6, %r23, %r3;
    sub.s32 %r25, %r23, 2147483648;
    xor.b32 %r27, %r3, %r6;
    setp.lt.u32 %p1, %r14, 4;
    @!%p1 selp.b32 %r19, %r14, %r25, %p1;
    cvt.u64.u32 %rd12, %r14;
