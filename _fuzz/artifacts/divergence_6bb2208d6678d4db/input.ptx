.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r14, %r3, %r3;
    max.u32 %r4, %r3, 7;
    mad.lo.u32 %r11, %r14, %r14, %r3;
    setp.le.s32 %p1, %r3, 65536;
    @%p1 add.u32 %r17, %r4, %r3;
    add.s32 %r19, %r4, 65536;
    sub.s32 %r21, %r19, 7;
    shl.b32 %r12, %r19, 0;
    setp.lt.s32 %p1, %r17, 5;
    @%p1 mul.wide.s32 %rd14, %r11, %r19;
    and.b32 %r21, %r19, %r3;
    add.u32 %r8, %r21, 1;
    xor.b32 %r9, %r19, 65536;
    max.u32 %r21, %r3, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
