.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r20, %r3, %r3;
    mul.lo.s32 %r4, %r3, 2;
    cvt.u64.u32 %rd10, %r3;
    cvt.u32.u64 %r14, %rd10;
    cvt.u32.u64 %r15, %rd10;
    sub.u32 %r7, %r4, %r15;
    mad.lo.u32 %r6, %r3, %r7, %r7;
    cvt.u32.u64 %r11, %rd10;
    mul.lo.u32 %r20, %r7, %r7;
    add.s32 %r23, %r15, %r6;
    setp.gt.u32 %p4, %r23, 4294967295;
    @%p4 cvt.u32.u64 %r16, %rd10;
    max.u32 %r21, %r7, 65535;
    sub.s32 %r27, %r21, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
