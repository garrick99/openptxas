.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r23, %r3, 5;
    cvt.s64.s32 %rd14, %r3;
    xor.b64 %rd15, %rd14, %rd14;
    and.b64 %rd8, %rd15, %rd15;
    mul.wide.s32 %rd7, %r23, %r3;
    shl.b64 %rd14, %rd15, 48;
    add.s32 %r14, %r23, %r23;
    or.b32 %r17, %r23, 4;
    min.u32 %r8, %r14, 4;
    and.b32 %r19, %r3, 256;
    or.b32 %r7, %r17, 4;
    max.u32 %r15, %r17, 1;
    mul.lo.u32 %r22, %r7, %r15;
    min.u32 %r27, %r17, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
