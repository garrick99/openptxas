.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    shr.u64 %rd5, %rd7, 48;
    setp.lt.u32 %p2, %r3, %r3;
    @%p2 shr.u32 %r19, %r3, 2;
    mul.wide.s32 %rd14, %r3, %r3;
    shl.b32 %r18, %r3, 3;
    shr.u32 %r6, %r19, 4;
    min.u32 %r21, %r18, %r19;
    or.b64 %rd5, %rd14, %rd14;
    cvt.s32.s64 %r16, %rd7;
    add.u32 %r6, %r19, %r18;
    or.b32 %r18, %r16, %r18;
    max.s32 %r24, %r16, %r18;
    mul.lo.s32 %r8, %r3, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
