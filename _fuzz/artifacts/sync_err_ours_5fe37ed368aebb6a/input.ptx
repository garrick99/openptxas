.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r16, %r3, 0;
    shr.s32 %r19, %r3, 1;
    shl.b32 %r9, %r19, 15;
    shr.s32 %r24, %r16, 4;
    sub.u32 %r8, %r16, %r9;
    cvt.s64.s32 %rd5, %r16;
    max.s32 %r14, %r8, 65535;
    sub.u32 %r9, %r19, %r14;
    cvt.s32.s64 %r17, %rd5;
    add.u32 %r13, %r24, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
