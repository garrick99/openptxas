.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r9, %r3, %r3;
    cvt.u64.u32 %rd15, %r3;
    mul.wide.u32 %rd8, %r3, %r3;
    sub.s32 %r9, %r3, %r9;
    max.u32 %r18, %r9, %r9;
    and.b64 %rd12, %rd15, %rd15;
    xor.b32 %r18, %r9, 32;
    mul.wide.s32 %rd11, %r3, %r9;
    shl.b64 %rd12, %rd12, 4;
    max.s32 %r21, %r18, %r18;
    sub.s32 %r21, %r9, %r21;
    mad.lo.u32 %r21, %r3, %r9, %r3;
    max.s32 %r8, %r18, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
