.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r17, %r3, 2;
    sub.s32 %r23, %r17, %r3;
    cvt.u64.u32 %rd10, %r23;
    mul.wide.s32 %rd6, %r17, %r23;
    mul.wide.u32 %rd12, %r17, %r3;
    shr.u32 %r4, %r17, 0;
    sub.s64 %rd7, %rd6, %rd6;
    max.u32 %r6, %r3, %r4;
    max.u32 %r25, %r6, %r6;
    setp.eq.s32 %p2, %r23, %r3;
    @%p2 mul.lo.u32 %r25, %r17, 256;
    cvt.u64.u32 %rd13, %r6;
    setp.ne.u32 %p4, %r25, %r17;
    @%p4 min.u32 %r24, %r3, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
