.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r8, %r3, %r3;
    setp.ne.u32 %p1, %r8, %r8;
    vote.sync.ballot.b32 %r9, %p1, -1;
    and.b32 %r18, %r0, %r9;
    shfl.sync.bfly.b32 %r9, %r8, 2, 0x1f, -1;
    sub.u32 %r19, %r18, %r0;
    shfl.sync.up.b32 %r14, %r19, 1, 0x1f, -1;
    and.b32 %r6, %r9, %r19;
    add.u32 %r15, %r9, %r9;
    or.b32 %r10, %r8, %r0;
    setp.le.u32 %p3, %r3, %r15;
    vote.sync.ballot.b32 %r18, %p3, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
