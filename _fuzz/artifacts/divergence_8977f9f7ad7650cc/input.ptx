.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r13, %r3, 65536;
    mad.lo.s32 %r11, %r13, %r3, %r3;
    shl.b32 %r15, %r11, 3;
    add.u32 %r26, %r13, 5;
    mul.wide.s32 %rd12, %r26, %r3;
    xor.b32 %r19, %r3, %r13;
    and.b32 %r20, %r11, %r15;
    setp.lt.u32 %p3, %r13, %r15;
    @%p3 sub.s32 %r15, %r19, 7;
    mul.wide.s32 %rd14, %r13, %r20;
    max.s32 %r26, %r11, 255;
    cvt.u64.u32 %rd6, %r11;
    setp.hs.u32 %p2, %r26, 256;
    @%p2 cvt.s32.s64 %r12, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
