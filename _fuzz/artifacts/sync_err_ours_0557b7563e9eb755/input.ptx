.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r25, %r3, 4294967295;
    mul.wide.s32 %rd6, %r3, %r25;
    max.u32 %r24, %r3, %r25;
    setp.ne.s32 %p1, %r24, %r24;
    @!%p1 max.s32 %r15, %r3, 5;
    or.b64 %rd10, %rd6, %rd6;
    cvt.s64.s32 %rd14, %r25;
    and.b32 %r26, %r25, 63;
    shr.u32 %r25, %r15, 16;
    min.u32 %r18, %r24, %r24;
    shr.s64 %rd14, %rd14, 32;
    xor.b32 %r6, %r15, 7;
    setp.gt.s32 %p1, %r3, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
