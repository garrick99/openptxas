.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r26, %r3, 7;
    setp.gt.u32 %p4, %r26, %r3;
    @%p4 mul.lo.u32 %r16, %r26, 32;
    cvt.s64.s32 %rd9, %r16;
    mul.wide.u32 %rd7, %r16, %r3;
    setp.le.s32 %p4, %r26, 0;
    setp.le.s32 %p2, %r16, 2147483647;
    @%p2 mul.lo.u32 %r27, %r3, 1;
    mul.lo.u32 %r6, %r3, %r16;
    and.b32 %r18, %r27, %r26;
    max.s32 %r26, %r27, %r3;
    mad.lo.s32 %r12, %r18, %r3, %r18;
    sub.s32 %r12, %r12, %r16;
    cvt.s64.s32 %rd9, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
