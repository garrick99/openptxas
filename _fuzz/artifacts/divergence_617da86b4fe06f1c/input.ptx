.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r24, %r3, %r3;
    sub.s32 %r18, %r3, 8;
    cvt.u64.u32 %rd13, %r18;
    setp.gt.s32 %p2, %r18, %r24;
    @%p2 and.b64 %rd6, %rd13, %rd13;
    cvt.u32.u64 %r13, %rd6;
    selp.b32 %r7, %r3, %r13, %p2;
    max.u32 %r14, %r24, %r3;
    sub.u32 %r18, %r18, %r24;
    mul.lo.s64 %rd7, %rd6, %rd13;
    max.s32 %r23, %r3, 64;
    shr.s32 %r19, %r3, 30;
    mad.lo.u32 %r6, %r19, %r19, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
