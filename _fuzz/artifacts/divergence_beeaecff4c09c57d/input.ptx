.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r22, %r3, %r3;
    mul.wide.s32 %rd8, %r22, %r3;
    shl.b64 %rd6, %rd8, 30;
    min.u64 %rd14, %rd6, %rd6;
    mul.lo.u32 %r23, %r22, %r22;
    sub.u32 %r25, %r3, %r23;
    min.s64 %rd7, %rd8, %rd14;
    shl.b32 %r24, %r3, 15;
    sub.u32 %r27, %r24, %r23;
    add.u32 %r8, %r3, 256;
    cvt.s32.s64 %r8, %rd7;
    cvt.u64.u32 %rd7, %r27;
    min.s32 %r5, %r25, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
