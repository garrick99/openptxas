.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    cvt.s64.s32 %rd15, %r3;
    min.u32 %r21, %r3, %r3;
    setp.eq.s32 %p4, %r21, 5;
    @%p4 or.b32 %r23, %r21, %r3;
    max.u32 %r6, %r3, %r23;
    mad.lo.s32 %r9, %r3, %r3, %r6;
    mad.lo.u32 %r5, %r21, %r9, %r23;
    shr.s64 %rd12, %rd15, 32;
    min.u32 %r17, %r21, %r5;
    selp.b32 %r15, %r23, %r3, %p4;
    cvt.s32.s64 %r10, %rd10;
    selp.b32 %r12, %r9, %r21, %p4;
    xor.b32 %r8, %r10, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
