.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r11, %r3, 15;
    add.u32 %r25, %r3, 5;
    sub.u32 %r27, %r3, %r25;
    mul.wide.u32 %rd9, %r3, %r11;
    or.b32 %r9, %r3, %r11;
    max.u32 %r19, %r3, 0;
    add.s32 %r21, %r3, %r11;
    setp.gt.u32 %p4, %r9, %r3;
    @%p4 shr.u32 %r14, %r27, 0;
    setp.le.s32 %p3, %r27, 4294967295;
    @%p3 and.b32 %r20, %r14, %r14;
    setp.lt.s32 %p2, %r27, 8;
    @%p2 shl.b64 %rd9, %rd9, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
