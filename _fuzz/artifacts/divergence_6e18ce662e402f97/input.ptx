.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    add.u64 %rd14, %rd8, %rd8;
    shr.s64 %rd5, %rd8, 2;
    cvt.s32.s64 %r13, %rd8;
    shl.b32 %r12, %r13, 31;
    mul.wide.u32 %rd11, %r13, %r13;
    shl.b64 %rd14, %rd14, 2;
    cvt.s32.s64 %r22, %rd11;
    add.u64 %rd15, %rd8, %rd5;
    mad.lo.u32 %r20, %r3, %r22, %r13;
    shr.s32 %r6, %r13, 16;
    mul.wide.u32 %rd6, %r3, %r6;
    and.b32 %r23, %r13, %r13;
    min.s32 %r20, %r3, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
