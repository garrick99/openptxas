    mul.wide.s32 %rd6, %r7, %r11;
    shl.b64 %rd15, %rd6, 63;
    add.s64 %rd7, %rd6, %rd6;
    add.s32 %r13, %r7, %r3;
    mad.lo.s32 %r19, %r13, %r3, %r3;
    mul.lo.s32 %r22, %r19, 16;
    add.u64 %rd14, %rd6, %rd6;
