.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    shl.b32 %r26, %r3, 15;
    shl.b32 %r7, %r26, 4;
    shl.b32 %r9, %r26, 30;
    cvt.s32.s64 %r13, %rd6;
    setp.ne.u32 %p4, %r9, 15;
    @%p4 min.s32 %r23, %r13, 7;
    mad.lo.u32 %r10, %r9, %r23, %r13;
    add.u32 %r11, %r7, 8;
    max.s32 %r19, %r26, %r23;
    max.s32 %r23, %r11, 255;
    cvt.u32.u64 %r8, %rd6;
    min.u64 %rd12, %rd6, %rd6;
    shr.s64 %rd10, %rd6, 47;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
