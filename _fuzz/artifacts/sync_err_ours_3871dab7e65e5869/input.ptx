    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p3, %r3, 1;
    @!%p3 max.u32 %r26, %r3, %r3;
    or.b32 %r25, %r3, %r26;
    shr.s32 %r19, %r26, 1;
    shr.s32 %r18, %r25, 4;
