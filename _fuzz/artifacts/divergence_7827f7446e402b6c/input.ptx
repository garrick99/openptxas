.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r11, %r3, 63;
    sub.s32 %r10, %r11, %r11;
    setp.gt.s32 %p1, %r10, 7;
    @%p1 selp.b32 %r7, %r11, %r10, %p1;
    shr.s32 %r4, %r10, 16;
    sub.u32 %r17, %r7, %r3;
    max.u32 %r18, %r17, %r17;
    mul.wide.s32 %rd10, %r7, %r11;
    max.u32 %r18, %r4, %r17;
    and.b32 %r17, %r3, %r7;
    shr.u32 %r22, %r4, 31;
    or.b32 %r24, %r17, 65535;
    mul.wide.u32 %rd6, %r11, %r11;
    shr.s64 %rd11, %rd6, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
