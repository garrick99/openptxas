.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    and.b32 %r4, %r3, %r3;
    setp.gt.u32 %p1, %r4, %r4;
    @%p1 xor.b32 %r18, %r3, 32;
    max.u32 %r21, %r18, 16;
    shl.b32 %r13, %r3, 0;
    cvt.s64.s32 %rd5, %r3;
    cvt.s64.s32 %rd13, %r21;
    mul.lo.s32 %r7, %r13, 16;
    shl.b32 %r23, %r7, 7;
    and.b32 %r26, %r23, 63;
    selp.b32 %r9, %r21, %r26, %p1;
    setp.eq.s32 %p2, %r23, %r3;
    cvt.u32.u64 %r12, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
