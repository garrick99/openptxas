.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    popc.b32 %r16, %r3;
    brev.b32 %r12, %r3;
    bfi.b32 %r18, %r16, %r16, 0, 24;
    bfe.u32 %r8, %r18, 23, 31;
    bfi.b32 %r14, %r3, %r8, 24, 31;
    bfi.b32 %r8, %r14, %r12, 4, 4;
    bfe.s32 %r12, %r16, 8, 24;
    bfe.u32 %r4, %r18, 7, 2;
    bfi.b32 %r5, %r3, %r18, 7, 31;
    bfi.b32 %r5, %r18, %r4, 4, 31;
    brev.b32 %r4, %r5;
    popc.b32 %r5, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
