.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r21, %r3, %r3;
    shr.u32 %r27, %r21, 4;
    mad.lo.s32 %r13, %r21, %r3, %r3;
    min.u32 %r24, %r21, %r27;
    cvt.u64.u32 %rd10, %r27;
    cvt.s64.s32 %rd9, %r3;
    or.b32 %r15, %r27, %r24;
    sub.s32 %r19, %r13, 8;
    shl.b32 %r25, %r13, 1;
    add.u64 %rd7, %rd9, %rd9;
    and.b32 %r8, %r24, %r13;
    sub.u32 %r25, %r13, %r15;
    shr.s32 %r27, %r8, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
