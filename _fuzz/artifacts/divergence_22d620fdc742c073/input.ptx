.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r13, %r3, 16;
    mul.lo.s32 %r10, %r3, 16;
    cvt.s64.s32 %rd6, %r10;
    min.s32 %r7, %r3, 2;
    cvt.u32.u64 %r26, %rd6;
    mul.wide.u32 %rd9, %r13, %r26;
    cvt.s64.s32 %rd13, %r26;
    xor.b64 %rd12, %rd13, %rd13;
    sub.s32 %r17, %r7, 64;
    add.s32 %r11, %r3, %r26;
    min.u32 %r9, %r13, 16;
    setp.ls.u32 %p4, %r3, 2;
    @%p4 xor.b32 %r5, %r3, 63;
    mul.lo.u64 %rd8, %rd12, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
