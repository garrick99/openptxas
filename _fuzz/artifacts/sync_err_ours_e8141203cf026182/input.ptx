.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r11, %r3, %r3;
    max.s32 %r18, %r3, %r11;
    xor.b32 %r26, %r18, %r3;
    mad.lo.s32 %r8, %r26, %r11, %r3;
    max.u32 %r21, %r3, %r26;
    setp.ls.u32 %p3, %r11, %r21;
    @!%p3 or.b32 %r7, %r11, 63;
    setp.gt.u32 %p3, %r11, 2;
    @%p3 max.s32 %r6, %r26, 31;
    sub.s32 %r22, %r21, %r6;
    mul.wide.s32 %rd10, %r7, %r26;
    min.u32 %r22, %r11, %r8;
    mul.lo.u64 %rd11, %rd10, %rd10;
    shr.s32 %r20, %r18, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
