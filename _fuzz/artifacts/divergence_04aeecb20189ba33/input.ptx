.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r17, %r3, 15;
    cvt.u64.u32 %rd10, %r17;
    xor.b32 %r23, %r3, 4294967295;
    max.u32 %r6, %r17, %r3;
    mad.lo.s32 %r5, %r3, %r17, %r6;
    cvt.u32.u64 %r14, %rd10;
    or.b32 %r8, %r17, %r17;
    mad.lo.u32 %r16, %r17, %r8, %r5;
    setp.lt.s32 %p3, %r6, 0;
    @%p3 mul.lo.u32 %r9, %r6, %r16;
    mul.wide.s32 %rd14, %r8, %r6;
    sub.s64 %rd9, %rd14, %rd10;
    min.s32 %r21, %r9, 31;
    and.b64 %rd7, %rd9, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
