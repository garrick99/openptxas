.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    max.u64 %rd14, %rd8, %rd8;
    setp.eq.s32 %p2, %r3, %r3;
    @%p2 shr.u64 %rd11, %rd8, 0;
    shl.b32 %r22, %r3, 7;
    shl.b64 %rd14, %rd8, 47;
    and.b32 %r6, %r22, %r3;
    setp.ne.u32 %p3, %r6, 256;
    selp.b32 %r4, %r6, %r3, %p3;
    shl.b64 %rd6, %rd14, 33;
    shr.s64 %rd12, %rd8, 16;
    and.b32 %r14, %r22, 256;
    max.s32 %r16, %r3, %r14;
    setp.gt.u32 %p4, %r3, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
