.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r15, %r3, 32;
    cvt.u64.u32 %rd11, %r15;
    add.u32 %r22, %r3, 4;
    sub.u32 %r12, %r15, %r3;
    mul.wide.s32 %rd10, %r15, %r15;
    mul.lo.s32 %r10, %r22, 31;
    min.u32 %r5, %r15, 3;
    sub.s32 %r24, %r5, 255;
    min.u32 %r9, %r5, %r24;
    mad.lo.s32 %r9, %r24, %r10, %r24;
    setp.eq.u32 %p2, %r10, 32;
    @!%p2 sub.u32 %r26, %r15, 1;
    cvt.s32.s64 %r21, %rd10;
    mul.lo.s32 %r10, %r5, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
