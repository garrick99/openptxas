.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r26, %r3, %r3;
    shl.b32 %r7, %r26, 3;
    cvt.s64.s32 %rd7, %r7;
    add.s32 %r21, %r7, %r3;
    setp.eq.s32 %p3, %r26, 8;
    max.s32 %r26, %r26, 2;
    shr.u32 %r25, %r7, 7;
    mul.wide.s32 %rd12, %r25, %r26;
    selp.b32 %r13, %r3, %r7, %p3;
    selp.b32 %r6, %r3, %r25, %p3;
    max.s32 %r27, %r26, 4;
    mul.lo.s32 %r24, %r21, %r26;
    max.s32 %r25, %r25, %r26;
    sub.u64 %rd8, %rd7, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
