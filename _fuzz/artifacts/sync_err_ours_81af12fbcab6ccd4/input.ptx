.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    max.s32 %r19, %r3, 4294967295;
    min.u32 %r20, %r3, %r19;
    or.b64 %rd7, %rd8, %rd8;
    mad.lo.s32 %r4, %r3, %r19, %r3;
    cvt.s64.s32 %rd9, %r4;
    shr.u64 %rd14, %rd7, 7;
    shr.s32 %r18, %r4, 2;
    shr.s32 %r21, %r18, 15;
    max.u32 %r5, %r20, %r20;
    add.u32 %r10, %r20, %r3;
    shr.s32 %r5, %r3, 4;
    min.s64 %rd13, %rd9, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
