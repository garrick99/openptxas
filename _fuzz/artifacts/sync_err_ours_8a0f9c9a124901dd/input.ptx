.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    max.s32 %r11, %r3, 7;
    mul.lo.s32 %r9, %r3, %r3;
    mul.lo.u64 %rd15, %rd11, %rd11;
    shr.u64 %rd15, %rd11, 32;
    shl.b64 %rd9, %rd11, 62;
    min.s64 %rd9, %rd11, %rd15;
    min.u32 %r12, %r3, 65536;
    setp.ge.s32 %p1, %r11, %r12;
    setp.ge.s32 %p2, %r11, 2147483648;
    mul.lo.s64 %rd5, %rd11, %rd11;
    mul.wide.u32 %rd11, %r11, %r9;
    min.u32 %r18, %r3, %r11;
    shr.u32 %r27, %r11, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
