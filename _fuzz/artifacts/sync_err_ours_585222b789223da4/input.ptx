.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r13, %r3, %r3;
    mul.lo.s32 %r18, %r3, %r3;
    mul.lo.s32 %r16, %r13, 16;
    setp.ge.u32 %p4, %r16, %r16;
    @%p4 selp.b32 %r17, %r3, %r3, %p4;
    selp.b32 %r24, %r13, %r16, %p4;
    sub.s32 %r4, %r16, 65535;
    add.s32 %r15, %r18, %r18;
    or.b32 %r9, %r4, %r17;
    mad.lo.s32 %r15, %r13, %r24, %r16;
    min.u32 %r21, %r13, %r9;
    shl.b32 %r6, %r9, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
