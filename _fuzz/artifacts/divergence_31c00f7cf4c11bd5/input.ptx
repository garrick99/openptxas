.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r26, %r3, 16;
    setp.eq.s32 %p4, %r3, %r3;
    @%p4 cvt.u64.u32 %rd9, %r26;
    min.s32 %r19, %r3, %r3;
    mul.lo.s32 %r26, %r3, %r26;
    mul.lo.u32 %r25, %r3, 65536;
    shr.u64 %rd8, %rd9, 3;
    or.b32 %r19, %r26, %r25;
    mad.lo.u32 %r13, %r19, %r3, %r25;
    setp.gt.s32 %p2, %r3, 2147483647;
    cvt.s64.s32 %rd15, %r19;
    xor.b32 %r27, %r3, %r25;
    and.b32 %r8, %r3, 5;
    mul.lo.u32 %r5, %r19, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
