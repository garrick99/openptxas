.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r19, %r3, %r3;
    setp.le.s32 %p3, %r19, %r19;
    @%p3 sub.s32 %r13, %r19, %r19;
    mul.lo.s32 %r15, %r3, %r19;
    add.u32 %r27, %r15, 4;
    sub.u32 %r5, %r3, 31;
    mul.wide.u32 %rd8, %r27, %r19;
    sub.s32 %r25, %r27, %r5;
    cvt.u64.u32 %rd10, %r19;
    shl.b32 %r13, %r5, 2;
    max.s32 %r14, %r19, %r3;
    cvt.u64.u32 %rd15, %r13;
    shr.s64 %rd10, %rd8, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
