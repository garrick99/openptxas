.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r20, %r3, 3;
    cvt.u64.u32 %rd6, %r3;
    sub.s32 %r23, %r20, 32;
    shr.s32 %r21, %r20, 1;
    shr.u32 %r13, %r3, 3;
    max.s32 %r23, %r23, 32;
    cvt.s64.s32 %rd9, %r20;
    min.s64 %rd15, %rd9, %rd6;
    min.s32 %r8, %r3, 65536;
    mul.lo.s32 %r11, %r8, %r13;
    mul.wide.s32 %rd9, %r21, %r20;
    or.b32 %r11, %r21, 4294967295;
    cvt.u32.u64 %r27, %rd6;
    mul.lo.u32 %r6, %r11, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
