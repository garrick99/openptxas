.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r22, %r3, 16;
    shl.b32 %r26, %r22, 16;
    mul.wide.s32 %rd12, %r3, %r3;
    shr.s32 %r25, %r26, 15;
    add.s32 %r18, %r22, 255;
    cvt.u64.u32 %rd6, %r3;
    min.u32 %r25, %r18, 15;
    mul.wide.s32 %rd12, %r18, %r25;
    sub.s32 %r20, %r25, 256;
    sub.u32 %r11, %r26, %r3;
    mul.wide.s32 %rd13, %r20, %r11;
    add.u32 %r16, %r25, %r11;
    shr.u32 %r23, %r18, 16;
    xor.b64 %rd13, %rd13, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
