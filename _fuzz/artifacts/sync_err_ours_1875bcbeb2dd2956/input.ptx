.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    cvt.s32.s64 %r4, %rd15;
    shr.s32 %r11, %r3, 4;
    shr.u64 %rd13, %rd15, 0;
    xor.b32 %r16, %r4, %r11;
    shr.u32 %r8, %r16, 1;
    sub.s32 %r10, %r16, 16;
    setp.ge.s32 %p4, %r8, 65535;
    mul.lo.u32 %r16, %r3, %r8;
    mul.lo.u32 %r26, %r11, %r8;
    sub.s32 %r23, %r10, 7;
    shl.b64 %rd12, %rd13, 0;
    mul.lo.u64 %rd15, %rd12, %rd12;
    mul.lo.s32 %r16, %r8, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
