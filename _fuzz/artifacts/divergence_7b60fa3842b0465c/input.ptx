.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r11, %r3, 30;
    and.b32 %r23, %r3, 32;
    cvt.u64.u32 %rd9, %r11;
    shl.b32 %r22, %r23, 7;
    setp.lo.u32 %p1, %r3, %r11;
    @!%p1 shl.b64 %rd13, %rd9, 32;
    max.s32 %r11, %r22, 4294967295;
    shl.b32 %r14, %r11, 3;
    cvt.u32.u64 %r7, %rd13;
    mul.wide.u32 %rd7, %r22, %r3;
    min.u32 %r21, %r23, %r7;
    mul.wide.s32 %rd8, %r21, %r23;
    setp.lt.s32 %p1, %r23, %r22;
    @%p1 mul.lo.s32 %r15, %r22, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
