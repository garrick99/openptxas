.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r22, %r3, %r3;
    mul.lo.s32 %r11, %r3, %r22;
    mul.lo.s32 %r22, %r22, %r11;
    cvt.u64.u32 %rd6, %r3;
    mul.lo.u32 %r25, %r22, 32;
    shr.s64 %rd11, %rd6, 1;
    shr.s64 %rd7, %rd6, 30;
    setp.ge.s32 %p2, %r11, 7;
    @%p2 mul.wide.s32 %rd6, %r3, %r11;
    sub.s32 %r22, %r25, %r22;
    cvt.u64.u32 %rd5, %r3;
    min.s32 %r19, %r3, 64;
    mul.lo.u32 %r25, %r19, %r22;
    setp.lt.s32 %p2, %r22, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
