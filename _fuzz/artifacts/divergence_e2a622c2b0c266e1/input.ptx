.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    clz.b32 %r11, %r3;
    bfe.s32 %r18, %r11, 24, 7;
    bfe.u32 %r5, %r3, 7, 31;
    sub.u32 %r5, %r3, 65535;
    bfi.b32 %r22, %r5, %r18, 8, 1;
    bfe.s32 %r11, %r18, 4, 16;
    bfe.s32 %r20, %r5, 8, 1;
    brev.b32 %r6, %r22;
    brev.b32 %r5, %r22;
    bfe.s32 %r6, %r6, 0, 31;
    brev.b32 %r17, %r20;
    sub.u32 %r22, %r22, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
