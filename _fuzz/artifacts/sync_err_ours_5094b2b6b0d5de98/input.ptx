.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r5, %r3, 4;
    setp.gt.u32 %p4, %r3, 63;
    @%p4 add.s32 %r6, %r5, %r3;
    mad.lo.s32 %r26, %r3, %r6, %r3;
    mul.lo.u32 %r12, %r26, 4;
    sub.u32 %r12, %r6, %r3;
    selp.b32 %r11, %r6, %r3, %p4;
    mad.lo.u32 %r16, %r11, %r26, %r12;
    shr.u32 %r25, %r5, 3;
    add.u32 %r11, %r3, %r5;
    sub.u32 %r4, %r16, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
