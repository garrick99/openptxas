.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    add.u32 %r12, %r3, %r3;
    sub.u32 %r4, %r3, 31;
    shl.b64 %rd5, %rd10, 48;
    and.b32 %r10, %r4, 1;
    sub.s32 %r14, %r4, %r12;
    setp.le.s32 %p4, %r3, %r3;
    @%p4 add.s32 %r15, %r10, %r4;
    shr.u32 %r10, %r15, 15;
    cvt.u64.u32 %rd14, %r14;
    setp.gt.s32 %p3, %r15, 2;
    mul.wide.s32 %rd8, %r15, %r3;
    selp.b32 %r20, %r10, %r3, %p4;
    mul.wide.s32 %rd7, %r15, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
