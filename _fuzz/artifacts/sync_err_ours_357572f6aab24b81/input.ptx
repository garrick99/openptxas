.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    shr.u32 %r9, %r3, 31;
    cvt.s32.s64 %r4, %rd9;
    setp.le.u32 %p1, %r9, 63;
    add.s32 %r4, %r9, %r3;
    or.b32 %r9, %r9, 2;
    cvt.s64.s32 %rd5, %r9;
    shr.s32 %r13, %r4, 2;
    add.s32 %r14, %r4, %r3;
    setp.ge.s32 %p2, %r14, 16;
    setp.eq.s32 %p1, %r3, 63;
    setp.lt.u32 %p1, %r4, 8;
    @%p1 sub.s32 %r25, %r13, %r4;
    and.b32 %r22, %r25, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
