.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r24, %r3, %r3;
    mul.lo.s32 %r22, %r24, %r24;
    mul.wide.s32 %rd9, %r3, %r24;
    cvt.s32.s64 %r4, %rd9;
    shl.b32 %r17, %r22, 0;
    xor.b32 %r18, %r4, 15;
    max.u32 %r21, %r4, %r18;
    min.u64 %rd9, %rd9, %rd9;
    setp.lo.u32 %p3, %r3, %r4;
    @!%p3 add.u32 %r15, %r3, 8;
    sub.s64 %rd7, %rd9, %rd9;
    shl.b32 %r17, %r3, 7;
    shr.u32 %r9, %r3, 31;
    selp.b32 %r20, %r15, %r17, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
