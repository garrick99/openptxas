.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r11, %r3, %r3;
    setp.eq.s32 %p3, %r3, 3;
    @%p3 max.u32 %r17, %r3, 5;
    max.s32 %r4, %r3, 15;
    sub.s32 %r16, %r11, %r11;
    selp.b32 %r17, %r16, %r4, %p3;
    max.s32 %r22, %r17, 3;
    mul.wide.s32 %rd13, %r22, %r11;
    cvt.u32.u64 %r21, %rd13;
    sub.u32 %r26, %r21, 16;
    shl.b32 %r15, %r26, 3;
    mul.wide.u32 %rd9, %r15, %r4;
    min.u64 %rd6, %rd13, %rd13;
    add.u64 %rd5, %rd9, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
