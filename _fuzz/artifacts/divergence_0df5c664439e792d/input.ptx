.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r23, %r3, %r3;
    cvt.s64.s32 %rd11, %r3;
    sub.s64 %rd7, %rd11, %rd11;
    cvt.u64.u32 %rd13, %r23;
    mul.lo.s32 %r6, %r23, 15;
    setp.le.s32 %p1, %r6, 31;
    mul.lo.u64 %rd6, %rd7, %rd11;
    mul.lo.u64 %rd10, %rd7, %rd11;
    setp.lt.u32 %p1, %r23, %r6;
    setp.ne.s32 %p3, %r6, %r3;
    @%p3 xor.b32 %r12, %r3, %r6;
    shr.s64 %rd15, %rd10, 62;
    shr.s64 %rd5, %rd7, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
