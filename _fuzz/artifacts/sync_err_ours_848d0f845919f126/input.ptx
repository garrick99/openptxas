.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r13, %r3, 15;
    setp.lt.s32 %p2, %r3, 63;
    @%p2 selp.b32 %r26, %r3, %r3, %p2;
    add.u32 %r26, %r3, %r13;
    mul.lo.s32 %r13, %r26, %r13;
    mul.lo.s32 %r20, %r26, 2;
    or.b32 %r4, %r20, 63;
    cvt.u64.u32 %rd12, %r26;
    add.u32 %r15, %r20, 31;
    cvt.s64.s32 %rd9, %r3;
    shl.b32 %r23, %r26, 7;
    min.s64 %rd10, %rd9, %rd12;
    add.s32 %r5, %r3, %r15;
    setp.gt.s32 %p1, %r4, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
