.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r13, %r3, %r3;
    setp.ls.u32 %p4, %r3, 4;
    @%p4 cvt.s64.s32 %rd5, %r3;
    and.b32 %r12, %r3, %r3;
    cvt.u32.u64 %r25, %rd5;
    mad.lo.u32 %r5, %r12, %r12, %r3;
    max.s32 %r15, %r25, %r25;
    sub.u64 %rd13, %rd5, %rd5;
    cvt.s32.s64 %r22, %rd5;
    add.u32 %r24, %r25, %r5;
    add.u32 %r10, %r15, 2;
    mul.lo.u64 %rd9, %rd13, %rd13;
    add.s32 %r11, %r5, %r13;
    add.u32 %r17, %r12, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
