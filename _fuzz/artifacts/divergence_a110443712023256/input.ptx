    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r8, %r3, %r3;
    mul.lo.u32 %r27, %r8, %r3;
    mul.wide.s32 %rd15, %r8, %r3;
    setp.hi.u32 %p1, %r3, %r3;
    selp.b32 %r17, %r8, %r27, %p1;
    mul.lo.u32 %r10, %r8, %r3;
    mul.lo.u32 %r16, %r3, 2147483648;
    min.u64 %rd14, %rd15, %rd15;
    mad.lo.s32 %r15, %r8, %r16, %r10;
    add.u64 %rd7, %rd15, %rd14;
    shr.s32 %r20, %r17, 7;
    max.u32 %r4, %r27, 65536;
    mad.lo.s32 %r13, %r17, %r17, %r16;
    min.u32 %r12, %r3, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
