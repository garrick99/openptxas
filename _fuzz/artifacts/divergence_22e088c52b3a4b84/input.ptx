.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p4, %r3, %r3;
    cvt.s64.s32 %rd14, %r3;
    min.u32 %r6, %r3, 7;
    setp.gt.s32 %p2, %r6, %r6;
    @%p2 add.u32 %r9, %r6, 2;
    selp.b32 %r5, %r6, %r9, %p2;
    min.u32 %r18, %r5, %r9;
    selp.b32 %r8, %r18, %r9, %p2;
    and.b32 %r4, %r6, 3;
    xor.b32 %r12, %r6, 16;
    max.u32 %r17, %r8, 2147483647;
    mad.lo.u32 %r14, %r17, %r17, %r9;
    selp.b32 %r15, %r4, %r8, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
