.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r16, %r3, %r3;
    max.u32 %r9, %r3, %r3;
    mad.lo.s32 %r27, %r16, %r3, %r9;
    cvt.s64.s32 %rd15, %r27;
    mad.lo.s32 %r15, %r9, %r27, %r27;
    mul.wide.s32 %rd7, %r9, %r9;
    cvt.u32.u64 %r20, %rd15;
    min.s32 %r12, %r3, %r20;
    cvt.s64.s32 %rd9, %r12;
    and.b32 %r24, %r9, 256;
    min.s32 %r18, %r12, 15;
    cvt.u64.u32 %rd14, %r9;
    max.u64 %rd11, %rd15, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
