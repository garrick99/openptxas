.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r9, %r3, %r3;
    sub.u32 %r27, %r3, 256;
    or.b32 %r18, %r3, %r27;
    shl.b32 %r14, %r27, 30;
    mad.lo.u32 %r27, %r18, %r9, %r27;
    setp.le.u32 %p3, %r27, %r14;
    @!%p3 mad.lo.s32 %r11, %r14, %r27, %r27;
    or.b32 %r12, %r18, %r9;
    mul.lo.s32 %r27, %r14, %r11;
    or.b32 %r9, %r18, 4;
    setp.ge.u32 %p2, %r14, 8;
    setp.gt.s32 %p1, %r9, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
