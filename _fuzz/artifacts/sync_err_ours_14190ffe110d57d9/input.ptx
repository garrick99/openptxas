.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r11, %r3, %r3;
    cvt.s64.s32 %rd12, %r11;
    mul.wide.u32 %rd5, %r11, %r11;
    xor.b32 %r18, %r11, %r3;
    sub.u32 %r13, %r3, 15;
    cvt.u64.u32 %rd11, %r3;
    mul.wide.s32 %rd10, %r3, %r13;
    mad.lo.u32 %r9, %r13, %r18, %r18;
    sub.u32 %r27, %r13, %r13;
    min.u32 %r5, %r11, 65535;
    setp.lo.u32 %p3, %r11, 8;
    mul.lo.u32 %r23, %r5, 31;
    max.u32 %r25, %r18, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
