.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r16, %r3, %r3;
    shr.u32 %r26, %r3, 31;
    min.u32 %r18, %r16, %r26;
    mul.lo.u32 %r5, %r26, %r18;
    mul.wide.u32 %rd7, %r26, %r26;
    or.b32 %r27, %r16, %r16;
    max.s64 %rd10, %rd7, %rd7;
    setp.eq.u32 %p3, %r5, %r16;
    @%p3 sub.s32 %r27, %r26, 2;
    max.u64 %rd13, %rd10, %rd7;
    sub.u32 %r10, %r18, %r5;
    shr.u64 %rd10, %rd10, 30;
    and.b32 %r22, %r5, %r3;
    shl.b64 %rd11, %rd7, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
