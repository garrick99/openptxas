.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r17, %r3, 1;
    xor.b32 %r9, %r17, %r17;
    cvt.s64.s32 %rd11, %r9;
    cvt.s32.s64 %r19, %rd11;
    max.u32 %r4, %r17, 4294967295;
    setp.eq.s32 %p3, %r17, %r17;
    @%p3 mad.lo.u32 %r5, %r19, %r4, %r4;
    min.u32 %r15, %r4, 65535;
    mul.wide.s32 %rd12, %r4, %r19;
    mad.lo.u32 %r11, %r19, %r19, %r15;
    and.b32 %r14, %r3, %r17;
    selp.b32 %r22, %r14, %r11, %p3;
    sub.s64 %rd5, %rd11, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
