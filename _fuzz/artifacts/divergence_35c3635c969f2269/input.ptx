.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r18, %r3, %r3, %r3;
    cvt.u64.u32 %rd7, %r18;
    sub.s64 %rd14, %rd7, %rd7;
    setp.lt.u32 %p2, %r18, %r18;
    mad.lo.u32 %r19, %r3, %r3, %r18;
    xor.b32 %r26, %r19, 8;
    add.u32 %r7, %r18, %r3;
    max.s32 %r24, %r7, 2147483648;
    max.u64 %rd7, %rd7, %rd14;
    shr.s64 %rd5, %rd14, 31;
    mul.lo.u32 %r16, %r26, %r24;
    mul.lo.u32 %r15, %r26, 2;
    shl.b64 %rd13, %rd5, 4;
    selp.b32 %r16, %r18, %r16, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
