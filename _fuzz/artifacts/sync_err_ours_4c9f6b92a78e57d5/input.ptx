.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    max.s32 %r16, %r3, %r3;
    sub.u32 %r10, %r16, %r3;
    shr.s32 %r8, %r16, 31;
    sub.u32 %r6, %r8, %r10;
    min.u32 %r6, %r8, 65535;
    max.u32 %r21, %r16, %r3;
    shl.b64 %rd13, %rd12, 4;
    min.s32 %r4, %r3, %r10;
    shl.b32 %r9, %r21, 4;
    shr.u64 %rd14, %rd12, 0;
    cvt.u32.u64 %r27, %rd14;
    min.u32 %r9, %r8, 256;
    and.b32 %r11, %r4, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
