.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r8, %r3, 0;
    cvt.u64.u32 %rd12, %r8;
    mul.lo.s32 %r14, %r8, 1;
    min.s64 %rd15, %rd12, %rd12;
    cvt.s32.s64 %r26, %rd15;
    min.s32 %r26, %r14, %r8;
    min.u32 %r10, %r26, 5;
    min.s32 %r22, %r10, %r14;
    sub.u32 %r4, %r10, %r3;
    mad.lo.s32 %r13, %r8, %r22, %r4;
    mul.wide.u32 %rd5, %r13, %r26;
    min.s64 %rd11, %rd12, %rd5;
    add.u64 %rd8, %rd12, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
