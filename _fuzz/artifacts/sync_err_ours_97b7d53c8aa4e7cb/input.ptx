    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r16, %r3, 4;
    setp.ge.s32 %p2, %r3, 65536;
    @%p2 cvt.s64.s32 %rd8, %r3;
    xor.b32 %r25, %r3, %r16;
    cvt.s64.s32 %rd15, %r25;
    setp.gt.s32 %p3, %r3, 2147483648;
    @%p3 mul.lo.s32 %r13, %r25, %r25;
    sub.s32 %r24, %r16, 32;
    mul.wide.s32 %rd6, %r16, %r24;
    shl.b64 %rd6, %rd8, 33;
    cvt.s32.s64 %r4, %rd15;
    shr.s32 %r21, %r24, 4;
    sub.s32 %r11, %r4, %r25;
    min.u64 %rd8, %rd15, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
