.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r23, %r3, 15;
    cvt.u64.u32 %rd10, %r23;
    shr.s32 %r9, %r3, 3;
    mad.lo.s32 %r25, %r23, %r9, %r3;
    shl.b32 %r23, %r23, 4;
    cvt.u32.u64 %r9, %rd10;
    sub.s32 %r10, %r3, 65536;
    cvt.s32.s64 %r19, %rd10;
    setp.le.s32 %p1, %r10, %r25;
    @!%p1 mad.lo.s32 %r6, %r19, %r19, %r19;
    sub.s32 %r10, %r25, 65535;
    selp.b32 %r19, %r9, %r25, %p1;
    or.b64 %rd13, %rd10, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
