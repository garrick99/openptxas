.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r6, %r3, %r3, %r3;
    shl.b32 %r24, %r6, 3;
    cvt.s64.s32 %rd6, %r24;
    cvt.u64.u32 %rd7, %r24;
    max.s32 %r20, %r6, 15;
    shr.s64 %rd8, %rd6, 33;
    min.u32 %r11, %r3, 4294967295;
    add.s64 %rd7, %rd7, %rd7;
    sub.s32 %r26, %r11, %r6;
    cvt.u32.u64 %r6, %rd8;
    sub.u32 %r23, %r24, %r11;
    shl.b32 %r25, %r11, 7;
    add.u32 %r6, %r26, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
