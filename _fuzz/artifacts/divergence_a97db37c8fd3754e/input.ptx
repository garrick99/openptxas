.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r13, %r3, 65535;
    mad.lo.s32 %r9, %r13, %r13, %r3;
    cvt.u64.u32 %rd13, %r3;
    setp.lt.u32 %p2, %r13, %r13;
    @!%p2 sub.s32 %r18, %r13, 255;
    sub.u32 %r10, %r9, 31;
    cvt.s32.s64 %r26, %rd13;
    shr.u32 %r16, %r13, 15;
    mul.wide.u32 %rd6, %r13, %r26;
    sub.s32 %r9, %r16, %r16;
    add.u32 %r25, %r18, %r26;
    xor.b32 %r20, %r10, 65536;
    max.s32 %r8, %r16, 2147483647;
    selp.b32 %r15, %r18, %r10, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
