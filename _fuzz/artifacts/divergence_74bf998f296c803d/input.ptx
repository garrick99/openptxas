.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r5, %r3, 8;
    max.s32 %r11, %r3, %r5;
    add.u32 %r6, %r5, 0;
    shr.u32 %r9, %r6, 16;
    mul.wide.u32 %rd14, %r5, %r11;
    shr.u32 %r19, %r11, 16;
    shr.u32 %r9, %r3, 3;
    mad.lo.s32 %r5, %r6, %r3, %r11;
    mad.lo.s32 %r7, %r9, %r5, %r3;
    setp.le.s32 %p3, %r3, 5;
    @%p3 cvt.s32.s64 %r17, %rd14;
    setp.ge.s32 %p4, %r3, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
