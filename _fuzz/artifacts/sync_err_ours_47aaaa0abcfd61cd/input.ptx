.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r14, %r3, 2;
    cvt.s64.s32 %rd9, %r14;
    sub.s64 %rd15, %rd9, %rd9;
    setp.eq.u32 %p1, %r3, 3;
    @%p1 selp.b32 %r16, %r3, %r14, %p1;
    and.b32 %r16, %r3, %r3;
    cvt.u64.u32 %rd5, %r14;
    or.b64 %rd11, %rd9, %rd5;
    max.s32 %r21, %r14, %r14;
    add.s32 %r6, %r3, 63;
    cvt.s64.s32 %rd8, %r3;
    shr.s32 %r5, %r3, 31;
    or.b32 %r27, %r14, %r21;
    add.u32 %r9, %r3, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
