.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p1, %r3, 5;
    @%p1 mad.lo.s32 %r11, %r3, %r3, %r3;
    mad.lo.u32 %r23, %r3, %r3, %r11;
    shr.u32 %r21, %r11, 30;
    cvt.s64.s32 %rd10, %r21;
    shl.b32 %r5, %r21, 4;
    shr.u64 %rd6, %rd10, 47;
    shr.s64 %rd14, %rd6, 7;
    mul.wide.s32 %rd12, %r5, %r5;
    max.u64 %rd9, %rd12, %rd14;
    selp.b32 %r18, %r3, %r23, %p1;
    shr.u32 %r6, %r23, 30;
    or.b32 %r12, %r11, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
