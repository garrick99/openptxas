.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.up.b32 %r8, %r3, 16, 0x1f, -1;
    shfl.sync.up.b32 %r19, %r0, 16, 0x1f, -1;
    shfl.sync.bfly.b32 %r10, %r19, 16, 0x1f, -1;
    shfl.sync.down.b32 %r11, %r8, 2, 0x1f, -1;
    setp.gt.u32 %p3, %r0, %r10;
    vote.sync.ballot.b32 %r9, %p3, -1;
    min.u32 %r13, %r9, %r0;
    shfl.sync.bfly.b32 %r12, %r3, 8, 0x1f, -1;
    shfl.sync.bfly.b32 %r12, %r8, 8, 0x1f, -1;
    min.u32 %r7, %r11, %r10;
    setp.eq.u32 %p2, %r10, 255;
    vote.sync.ballot.b32 %r11, %p2, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
