.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r23, %r3, 7;
    add.u32 %r17, %r3, 8;
    xor.b32 %r13, %r17, 8;
    setp.ge.u32 %p2, %r13, %r23;
    add.s32 %r7, %r23, %r17;
    setp.ge.u32 %p3, %r17, 4294967295;
    shl.b32 %r11, %r17, 31;
    add.u32 %r9, %r7, %r3;
    selp.b32 %r12, %r13, %r9, %p3;
    shr.u32 %r19, %r23, 3;
    setp.ge.s32 %p1, %r19, %r7;
    @%p1 mul.lo.u32 %r13, %r3, 32;
    cvt.u64.u32 %rd6, %r13;
    add.u32 %r15, %r13, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
