.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    min.u64 %rd10, %rd5, %rd5;
    shr.u64 %rd15, %rd5, 30;
    add.s32 %r14, %r3, 8;
    cvt.u64.u32 %rd13, %r14;
    min.s32 %r4, %r14, 31;
    max.u32 %r16, %r14, 1;
    setp.ls.u32 %p2, %r16, 3;
    setp.le.s32 %p2, %r14, %r14;
    @%p2 mul.wide.u32 %rd12, %r16, %r16;
    sub.u32 %r4, %r16, %r3;
    add.s32 %r16, %r4, 3;
    shr.u32 %r5, %r16, 4;
    selp.b32 %r24, %r16, %r3, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
