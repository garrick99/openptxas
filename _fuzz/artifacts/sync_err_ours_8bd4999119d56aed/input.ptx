.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r26, %r3, 7;
    mul.wide.s32 %rd9, %r26, %r3;
    shr.u32 %r12, %r26, 4;
    mul.lo.s32 %r15, %r12, 4294967295;
    cvt.u64.u32 %rd15, %r3;
    setp.gt.s32 %p1, %r3, 31;
    @!%p1 mad.lo.u32 %r7, %r3, %r26, %r12;
    shr.u32 %r26, %r3, 15;
    cvt.s32.s64 %r17, %rd9;
    mul.lo.s32 %r10, %r7, 256;
    max.u32 %r6, %r3, %r15;
    add.s64 %rd15, %rd15, %rd15;
    shr.u32 %r17, %r12, 1;
    or.b32 %r11, %r7, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
