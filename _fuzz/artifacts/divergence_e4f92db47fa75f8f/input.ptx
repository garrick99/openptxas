.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r7, %r3, %r3;
    xor.b32 %r15, %r7, 31;
    mul.lo.s32 %r26, %r7, %r7;
    cvt.u64.u32 %rd6, %r7;
    min.u32 %r7, %r26, 5;
    add.s32 %r12, %r15, 64;
    sub.s64 %rd6, %rd6, %rd6;
    max.u32 %r24, %r3, %r12;
    cvt.u64.u32 %rd5, %r3;
    shr.u64 %rd9, %rd6, 63;
    min.s32 %r12, %r26, %r24;
    setp.gt.s32 %p1, %r26, 63;
    @%p1 add.u32 %r14, %r3, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
