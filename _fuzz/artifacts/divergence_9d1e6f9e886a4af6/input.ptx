.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r19, %r3, 31;
    max.s32 %r10, %r19, 16;
    cvt.u64.u32 %rd10, %r10;
    max.s32 %r22, %r3, 0;
    mul.lo.u32 %r24, %r19, %r22;
    mul.lo.s64 %rd12, %rd10, %rd10;
    shl.b64 %rd13, %rd12, 33;
    add.u32 %r13, %r3, 4;
    mad.lo.s32 %r21, %r22, %r10, %r13;
    cvt.u32.u64 %r10, %rd10;
    max.s64 %rd15, %rd12, %rd12;
    add.u32 %r17, %r21, %r10;
    max.u32 %r19, %r22, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
