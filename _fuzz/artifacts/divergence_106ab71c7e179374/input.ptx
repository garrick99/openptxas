.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r6, %r3, %r3;
    cvt.u64.u32 %rd10, %r6;
    mul.lo.s64 %rd6, %rd10, %rd10;
    min.u32 %r10, %r6, %r3;
    max.s32 %r18, %r6, %r10;
    max.u32 %r22, %r6, 64;
    shr.s32 %r19, %r3, 30;
    max.u32 %r17, %r19, 16;
    sub.s32 %r12, %r6, 255;
    add.s64 %rd11, %rd10, %rd10;
    max.s32 %r17, %r19, 5;
    mul.lo.u32 %r22, %r22, 1;
    xor.b64 %rd9, %rd10, %rd11;
    add.u64 %rd14, %rd6, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
