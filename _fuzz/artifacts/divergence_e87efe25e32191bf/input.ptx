.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p4, %r3, %r3;
    @%p4 mad.lo.s32 %r25, %r3, %r3, %r3;
    setp.lo.u32 %p4, %r3, %r3;
    @%p4 mad.lo.u32 %r7, %r3, %r25, %r25;
    cvt.s64.s32 %rd5, %r7;
    setp.lt.u32 %p3, %r25, 8;
    @%p3 mad.lo.u32 %r10, %r7, %r3, %r7;
    max.u32 %r27, %r25, 65536;
    shl.b32 %r27, %r27, 30;
    xor.b32 %r5, %r27, %r7;
    shr.u64 %rd7, %rd5, 3;
    sub.s32 %r24, %r25, 16;
    mul.wide.u32 %rd12, %r5, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
