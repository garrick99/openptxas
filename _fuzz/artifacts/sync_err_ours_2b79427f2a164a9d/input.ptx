.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd14, %r3, %r3;
    shl.b32 %r23, %r3, 16;
    mul.lo.u32 %r24, %r23, %r23;
    min.u32 %r15, %r24, %r3;
    shr.u32 %r8, %r24, 31;
    shr.u64 %rd7, %rd14, 3;
    cvt.s32.s64 %r21, %rd14;
    shr.s32 %r8, %r15, 3;
    cvt.s32.s64 %r24, %rd14;
    mad.lo.s32 %r12, %r23, %r8, %r23;
    cvt.s32.s64 %r7, %rd7;
    and.b32 %r16, %r21, 8;
    shr.u32 %r18, %r16, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
