.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r24, %r3, 16;
    cvt.u64.u32 %rd12, %r24;
    setp.ls.u32 %p3, %r24, 0;
    max.s32 %r8, %r24, %r3;
    setp.ge.u32 %p1, %r24, 1;
    @%p1 min.s64 %rd15, %rd12, %rd12;
    min.u32 %r14, %r3, 65535;
    shl.b64 %rd15, %rd15, 62;
    shr.s32 %r10, %r8, 15;
    mad.lo.s32 %r19, %r3, %r8, %r10;
    mad.lo.u32 %r18, %r24, %r19, %r19;
    mad.lo.u32 %r8, %r19, %r24, %r19;
    mul.wide.u32 %rd6, %r8, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
