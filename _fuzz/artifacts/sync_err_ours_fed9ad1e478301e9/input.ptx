.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd14, %r3, %r3;
    mad.lo.s32 %r16, %r3, %r3, %r3;
    shl.b64 %rd5, %rd14, 2;
    add.s32 %r20, %r3, %r16;
    or.b32 %r4, %r3, %r20;
    cvt.u64.u32 %rd14, %r4;
    cvt.u32.u64 %r26, %rd5;
    min.s64 %rd10, %rd14, %rd5;
    setp.lo.u32 %p1, %r26, %r4;
    @%p1 or.b32 %r5, %r16, %r4;
    max.s32 %r23, %r16, %r16;
    setp.ge.u32 %p1, %r5, %r4;
    @!%p1 mul.lo.s32 %r11, %r16, %r4;
    min.u32 %r11, %r16, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
