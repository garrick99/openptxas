.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    mad.lo.u32 %r20, %r3, %r3, %r3;
    mad.lo.u32 %r17, %r3, %r3, %r3;
    and.b64 %rd13, %rd8, %rd8;
    cvt.u32.u64 %r8, %rd8;
    mul.wide.s32 %rd15, %r17, %r3;
    mul.wide.s32 %rd10, %r17, %r3;
    shl.b64 %rd12, %rd15, 32;
    sub.u32 %r10, %r20, 4;
    max.s32 %r13, %r20, 255;
    shr.s32 %r25, %r20, 16;
    shr.u64 %rd13, %rd12, 47;
    sub.u32 %r6, %r25, 65535;
    mul.lo.s32 %r5, %r8, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
