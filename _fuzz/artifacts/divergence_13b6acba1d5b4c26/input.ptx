.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd9, %r3, %r3;
    shl.b64 %rd13, %rd9, 0;
    min.s32 %r5, %r3, 1;
    mad.lo.u32 %r26, %r3, %r5, %r5;
    setp.le.u32 %p3, %r26, 16;
    @%p3 mul.lo.s32 %r23, %r26, 63;
    shr.s32 %r6, %r26, 15;
    shr.u32 %r9, %r23, 16;
    shl.b64 %rd10, %rd13, 33;
    mul.wide.u32 %rd11, %r5, %r6;
    mad.lo.u32 %r26, %r3, %r3, %r23;
    sub.u32 %r21, %r6, %r23;
    cvt.s64.s32 %rd10, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
