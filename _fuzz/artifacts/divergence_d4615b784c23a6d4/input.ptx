.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r9, %r3, 16;
    mul.lo.u32 %r5, %r9, 65535;
    cvt.s64.s32 %rd8, %r5;
    cvt.s32.s64 %r20, %rd8;
    cvt.s64.s32 %rd7, %r9;
    mul.wide.s32 %rd9, %r9, %r5;
    mul.lo.u32 %r4, %r3, %r5;
    mad.lo.s32 %r14, %r20, %r5, %r9;
    mul.lo.s64 %rd15, %rd8, %rd7;
    sub.u32 %r24, %r4, %r14;
    setp.ne.u32 %p2, %r9, 4;
    @!%p2 add.u32 %r22, %r9, 256;
    shr.s64 %rd10, %rd7, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
