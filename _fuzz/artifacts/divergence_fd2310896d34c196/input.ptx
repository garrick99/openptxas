.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    cvt.u64.u32 %rd14, %r3;
    min.s32 %r6, %r3, %r3;
    shr.u32 %r15, %r3, 7;
    shr.u64 %rd9, %rd5, 33;
    shr.s64 %rd5, %rd5, 30;
    cvt.u32.u64 %r5, %rd9;
    mul.lo.s64 %rd15, %rd9, %rd9;
    shl.b64 %rd5, %rd9, 4;
    or.b32 %r20, %r6, %r6;
    setp.lt.s32 %p2, %r3, 3;
    @%p2 selp.b32 %r9, %r5, %r15, %p2;
    setp.lt.s32 %p1, %r3, %r5;
    @!%p1 mul.wide.s32 %rd6, %r20, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
