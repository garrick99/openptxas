.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r11, %r3, %r0;
    add.u32 %r14, %r3, %r11;
    sub.u32 %r9, %r3, %r0;
    shfl.sync.idx.b32 %r7, %r9, 7, 0x1f, -1;
    and.b32 %r9, %r14, %r0;
    shfl.sync.idx.b32 %r15, %r14, 7, 0x1f, -1;
    setp.lt.u32 %p3, %r3, %r3;
    vote.sync.ballot.b32 %r15, %p3, -1;
    max.u32 %r10, %r0, %r0;
    setp.ge.u32 %p3, %r14, %r11;
    vote.sync.ballot.b32 %r11, %p3, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
