    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r9, %r3, %r3;
    setp.ls.u32 %p1, %r9, %r9;
    @!%p1 add.u32 %r5, %r3, %r9;
    sub.u32 %r21, %r9, %r5;
    selp.b32 %r4, %r3, %r21, %p1;
    shr.s32 %r13, %r5, 15;
    min.u32 %r11, %r21, 32;
    xor.b32 %r21, %r11, 4;
    mad.lo.u32 %r26, %r9, %r3, %r21;
    setp.hs.u32 %p3, %r3, %r9;
    setp.gt.s32 %p4, %r13, 2147483648;
    @!%p4 and.b32 %r7, %r26, 0;
    mul.wide.s32 %rd15, %r9, %r13;
    setp.eq.u32 %p2, %r26, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
