.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p1, %r3, %r3;
    cvt.u64.u32 %rd7, %r3;
    cvt.s64.s32 %rd14, %r3;
    sub.u64 %rd6, %rd7, %rd14;
    mad.lo.s32 %r5, %r3, %r3, %r3;
    shr.u64 %rd14, %rd6, 16;
    and.b32 %r10, %r3, %r3;
    mul.lo.s32 %r10, %r5, %r3;
    sub.s32 %r8, %r3, %r10;
    shl.b32 %r17, %r5, 0;
    add.s32 %r14, %r10, 63;
    shr.u64 %rd14, %rd14, 2;
    min.s64 %rd12, %rd7, %rd14;
    cvt.u32.u64 %r20, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
