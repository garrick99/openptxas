.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r10, %r3, 64;
    min.u32 %r23, %r10, %r3;
    add.u32 %r17, %r10, %r3;
    min.u32 %r20, %r10, %r3;
    setp.hi.u32 %p3, %r17, %r3;
    @%p3 cvt.u64.u32 %rd6, %r17;
    xor.b64 %rd15, %rd6, %rd6;
    add.u32 %r9, %r17, 31;
    shl.b64 %rd15, %rd6, 30;
    shr.u64 %rd7, %rd15, 15;
    cvt.u64.u32 %rd11, %r17;
    add.u32 %r13, %r9, %r9;
    shl.b32 %r19, %r17, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
