.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hi.u32 %p4, %r3, 31;
    sub.u32 %r24, %r3, %r3;
    mul.lo.s32 %r11, %r24, %r3;
    setp.ne.u32 %p4, %r3, 65536;
    @%p4 shr.s32 %r14, %r24, 16;
    cvt.s64.s32 %rd11, %r14;
    mul.wide.s32 %rd9, %r14, %r11;
    and.b32 %r21, %r11, %r24;
    selp.b32 %r14, %r24, %r11, %p4;
    cvt.s32.s64 %r15, %rd11;
    setp.gt.s32 %p4, %r3, 63;
    @%p4 shl.b32 %r26, %r14, 0;
    add.u64 %rd7, %rd9, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
