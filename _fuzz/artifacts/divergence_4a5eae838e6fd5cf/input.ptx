.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd9, %r3, %r3;
    min.s32 %r13, %r3, %r3;
    setp.ne.u32 %p3, %r13, %r13;
    @%p3 sub.s32 %r16, %r3, 64;
    and.b64 %rd11, %rd9, %rd9;
    selp.b32 %r19, %r3, %r16, %p3;
    shr.u32 %r10, %r16, 16;
    selp.b32 %r27, %r10, %r19, %p3;
    shr.s64 %rd11, %rd9, 30;
    mad.lo.u32 %r9, %r27, %r10, %r3;
    mul.lo.u64 %rd12, %rd11, %rd11;
    sub.u32 %r24, %r13, %r13;
    setp.lt.s32 %p1, %r16, %r10;
    @%p1 or.b32 %r25, %r27, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
