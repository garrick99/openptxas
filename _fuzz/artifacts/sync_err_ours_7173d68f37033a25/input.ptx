.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r14, %r3, 64;
    max.u32 %r16, %r14, %r14;
    min.s32 %r16, %r14, %r16;
    shr.s32 %r17, %r3, 2;
    shr.s32 %r20, %r14, 16;
    mul.lo.u32 %r26, %r17, 4;
    or.b32 %r26, %r14, %r14;
    cvt.u64.u32 %rd7, %r20;
    sub.s64 %rd14, %rd7, %rd7;
    shr.s64 %rd7, %rd14, 62;
    mad.lo.u32 %r10, %r16, %r14, %r3;
    max.u32 %r10, %r14, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
