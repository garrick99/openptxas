.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p4, %r3, 65535;
    @%p4 sub.s32 %r12, %r3, 64;
    shr.u32 %r21, %r3, 15;
    shl.b32 %r11, %r3, 30;
    cvt.s64.s32 %rd8, %r12;
    max.s32 %r16, %r11, 0;
    add.s64 %rd9, %rd8, %rd8;
    cvt.u32.u64 %r14, %rd8;
    min.s64 %rd9, %rd8, %rd9;
    add.u32 %r21, %r11, %r14;
    min.s32 %r4, %r3, 15;
    cvt.u32.u64 %r19, %rd8;
    shl.b32 %r16, %r12, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
