.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r11, %r3, 255;
    cvt.u64.u32 %rd12, %r11;
    mul.lo.s64 %rd12, %rd12, %rd12;
    cvt.s32.s64 %r8, %rd12;
    add.u32 %r17, %r3, 255;
    add.u32 %r7, %r8, %r3;
    shr.u32 %r6, %r7, 0;
    max.s32 %r6, %r6, %r11;
    mul.wide.s32 %rd15, %r8, %r3;
    max.s32 %r11, %r11, 65535;
    add.s32 %r21, %r6, %r6;
    mul.lo.s32 %r6, %r3, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
