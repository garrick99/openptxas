.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r7, %r3, %r3;
    mad.lo.u32 %r8, %r7, %r3, %r7;
    min.u32 %r18, %r8, %r7;
    sub.s32 %r17, %r8, 2;
    add.u32 %r8, %r7, %r7;
    setp.ne.s32 %p2, %r3, 255;
    @%p2 cvt.u64.u32 %rd12, %r3;
    sub.u32 %r21, %r18, %r17;
    min.u32 %r6, %r17, 32;
    add.s32 %r8, %r21, %r6;
    max.s32 %r10, %r3, 32;
    mad.lo.s32 %r7, %r3, %r17, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
