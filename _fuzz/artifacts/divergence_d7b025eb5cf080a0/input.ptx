.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    mad.lo.s32 %r9, %r3, %r3, %r3;
    max.s32 %r14, %r3, 1;
    and.b32 %r21, %r9, 8;
    xor.b32 %r25, %r21, 256;
    cvt.s64.s32 %rd12, %r3;
    or.b32 %r5, %r25, %r14;
    sub.s32 %r18, %r5, %r25;
    shr.u32 %r18, %r9, 1;
    cvt.s64.s32 %rd8, %r18;
    sub.s32 %r6, %r21, %r3;
    sub.s64 %rd6, %rd8, %rd8;
    mad.lo.u32 %r22, %r3, %r21, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
