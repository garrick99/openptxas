.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd13, %r3, %r3;
    max.u32 %r9, %r3, %r3;
    setp.ne.u32 %p4, %r9, %r9;
    cvt.s32.s64 %r15, %rd13;
    min.u32 %r17, %r9, %r9;
    shl.b32 %r4, %r9, 31;
    min.s64 %rd6, %rd13, %rd13;
    selp.b32 %r16, %r17, %r4, %p4;
    setp.le.s32 %p2, %r9, 63;
    @%p2 add.u32 %r6, %r3, %r3;
    mul.lo.s64 %rd8, %rd6, %rd13;
    max.u32 %r26, %r6, 65535;
    sub.u32 %r12, %r3, %r16;
    mad.lo.u32 %r4, %r6, %r26, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
