.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    shl.b64 %rd5, %rd9, 2;
    min.u64 %rd13, %rd5, %rd5;
    sub.u32 %r22, %r3, %r3;
    shr.u64 %rd5, %rd13, 16;
    xor.b32 %r4, %r3, 4;
    shl.b32 %r8, %r22, 4;
    max.s32 %r14, %r22, %r4;
    mul.wide.s32 %rd13, %r8, %r3;
    mul.lo.s64 %rd9, %rd13, %rd9;
    shl.b32 %r19, %r22, 31;
    cvt.u32.u64 %r26, %rd5;
    mul.wide.u32 %rd8, %r22, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
