.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r11, %r3, 16;
    max.s32 %r21, %r11, 2147483647;
    max.u32 %r27, %r11, %r21;
    cvt.s64.s32 %rd7, %r21;
    add.u32 %r18, %r11, 256;
    shl.b64 %rd9, %rd7, 15;
    and.b64 %rd11, %rd9, %rd7;
    shr.u32 %r21, %r27, 2;
    cvt.s64.s32 %rd11, %r18;
    mul.wide.u32 %rd7, %r21, %r27;
    sub.u64 %rd13, %rd11, %rd11;
    shr.u64 %rd5, %rd7, 1;
    shr.s32 %r18, %r3, 30;
    cvt.s64.s32 %rd7, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
