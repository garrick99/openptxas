    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p3, %r3, %r3;
    @!%p3 cvt.s64.s32 %rd14, %r3;
    selp.b32 %r11, %r3, %r3, %p3;
