.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r18, %r3, %r3;
    add.s32 %r5, %r18, 31;
    mul.lo.s32 %r26, %r18, %r5;
    shr.u32 %r14, %r18, 3;
    cvt.u64.u32 %rd6, %r14;
    shr.s32 %r18, %r18, 0;
    shl.b64 %rd6, %rd6, 4;
    max.u32 %r17, %r3, %r3;
    mul.wide.s32 %rd10, %r5, %r3;
    cvt.u64.u32 %rd15, %r5;
    or.b64 %rd12, %rd10, %rd15;
    shr.u32 %r9, %r14, 15;
    shr.s32 %r17, %r9, 7;
    min.u32 %r7, %r3, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
