.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r18, %r3, 255;
    cvt.u64.u32 %rd10, %r3;
    add.u32 %r26, %r3, 65536;
    setp.le.s32 %p3, %r26, 31;
    @%p3 mad.lo.s32 %r27, %r26, %r26, %r3;
    shr.s32 %r20, %r26, 15;
    sub.u32 %r11, %r27, %r20;
    max.s32 %r20, %r26, %r20;
    cvt.s64.s32 %rd15, %r26;
    add.s32 %r14, %r18, 1;
    min.s32 %r18, %r18, %r3;
    cvt.u32.u64 %r21, %rd15;
    mul.lo.s32 %r26, %r27, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
