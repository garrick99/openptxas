.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r24, %r3, %r3;
    setp.gt.s32 %p1, %r3, 63;
    cvt.s64.s32 %rd8, %r24;
    cvt.s64.s32 %rd7, %r3;
    cvt.s64.s32 %rd12, %r3;
    max.s32 %r26, %r24, %r3;
    or.b32 %r15, %r26, %r24;
    cvt.s64.s32 %rd9, %r26;
    sub.u32 %r9, %r24, %r3;
    shr.s32 %r24, %r24, 30;
    shr.u32 %r18, %r24, 16;
    cvt.u32.u64 %r4, %rd8;
    setp.ne.s32 %p1, %r26, 255;
    @!%p1 shr.u32 %r10, %r18, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
