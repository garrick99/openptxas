.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r4, %r3, %r3, %r3;
    shl.b32 %r23, %r4, 16;
    xor.b32 %r21, %r3, %r23;
    mad.lo.u32 %r22, %r4, %r3, %r23;
    min.s32 %r11, %r22, %r3;
    shr.s32 %r17, %r4, 0;
    cvt.u64.u32 %rd10, %r4;
    shl.b64 %rd15, %rd10, 0;
    and.b32 %r19, %r4, %r4;
    setp.le.s32 %p1, %r3, %r22;
    max.u64 %rd15, %rd10, %rd10;
    cvt.u64.u32 %rd10, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
