.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd9, %r3, %r3;
    shl.b32 %r10, %r3, 2;
    mul.wide.u32 %rd11, %r3, %r10;
    mad.lo.s32 %r20, %r10, %r3, %r3;
    sub.s32 %r11, %r20, %r3;
    min.u32 %r5, %r11, %r20;
    min.u32 %r12, %r20, %r11;
    max.s32 %r23, %r5, %r12;
    shr.u32 %r16, %r23, 0;
    and.b32 %r14, %r12, 255;
    mul.wide.s32 %rd13, %r23, %r14;
    setp.lo.u32 %p3, %r12, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
