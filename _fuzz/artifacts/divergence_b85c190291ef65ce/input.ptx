.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p1, %r3, %r3;
    cvt.u64.u32 %rd5, %r3;
    mul.lo.s32 %r14, %r3, %r3;
    setp.lo.u32 %p1, %r3, 5;
    @%p1 selp.b32 %r18, %r3, %r14, %p1;
    mul.wide.s32 %rd5, %r14, %r3;
    add.u32 %r11, %r14, 15;
    sub.u64 %rd12, %rd5, %rd5;
    shr.u64 %rd12, %rd12, 33;
    add.s32 %r11, %r11, %r14;
    cvt.u32.u64 %r11, %rd12;
    xor.b32 %r20, %r14, 4294967295;
    shl.b32 %r13, %r11, 15;
    min.u32 %r4, %r18, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
