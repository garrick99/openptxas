.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r10, %r3, 15;
    cvt.s64.s32 %rd5, %r10;
    shr.s64 %rd11, %rd5, 47;
    add.s32 %r5, %r3, 65536;
    and.b32 %r23, %r10, %r10;
    mul.lo.s32 %r13, %r5, 7;
    sub.u32 %r25, %r23, 7;
    min.s64 %rd5, %rd5, %rd11;
    mul.lo.u32 %r4, %r25, 65535;
    mad.lo.s32 %r27, %r5, %r10, %r23;
    mul.wide.s32 %rd9, %r3, %r25;
    mul.lo.s64 %rd10, %rd9, %rd9;
    cvt.u32.u64 %r5, %rd9;
    or.b32 %r10, %r4, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
