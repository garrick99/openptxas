.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p2, %r3, 0;
    @%p2 or.b32 %r20, %r3, %r3;
    setp.lo.u32 %p3, %r3, 63;
    @%p3 shl.b32 %r13, %r3, 4;
    setp.ne.u32 %p3, %r3, 2;
    @%p3 and.b32 %r14, %r3, 256;
    shl.b32 %r20, %r14, 15;
    cvt.u64.u32 %rd11, %r13;
    selp.b32 %r18, %r20, %r14, %p2;
    mad.lo.u32 %r12, %r18, %r18, %r3;
    add.u32 %r5, %r12, %r12;
    mul.wide.s32 %rd12, %r20, %r5;
    shr.u32 %r5, %r13, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
