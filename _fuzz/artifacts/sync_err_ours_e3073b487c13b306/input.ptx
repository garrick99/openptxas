.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    shl.b32 %r14, %r3, 16;
    shr.s32 %r10, %r14, 1;
    shr.u32 %r9, %r3, 4;
    shl.b32 %r19, %r14, 7;
    add.s32 %r17, %r9, 7;
    shr.u32 %r6, %r10, 3;
    mul.lo.u32 %r14, %r9, %r14;
    cvt.u32.u64 %r6, %rd15;
    mul.lo.u64 %rd13, %rd15, %rd15;
    mad.lo.s32 %r11, %r14, %r19, %r17;
    min.s64 %rd13, %rd15, %rd13;
    mul.lo.u32 %r24, %r9, %r10;
    min.s32 %r7, %r3, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
