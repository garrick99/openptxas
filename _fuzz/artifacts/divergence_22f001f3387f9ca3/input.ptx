.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    cvt.s32.s64 %r25, %rd6;
    add.u32 %r9, %r25, %r3;
    or.b32 %r22, %r3, 7;
    mad.lo.s32 %r17, %r9, %r25, %r9;
    add.s64 %rd7, %rd6, %rd6;
    max.u64 %rd8, %rd7, %rd7;
    add.s32 %r17, %r17, %r25;
    add.u32 %r24, %r25, %r9;
    sub.u32 %r4, %r9, %r24;
    cvt.u64.u32 %rd8, %r17;
    mul.wide.u32 %rd7, %r9, %r24;
    mad.lo.s32 %r7, %r4, %r24, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
