.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r5, %r3, 2;
    max.u32 %r10, %r5, 5;
    xor.b32 %r17, %r5, %r3;
    sub.s32 %r6, %r10, %r3;
    min.u32 %r15, %r10, %r6;
    min.s32 %r23, %r10, %r10;
    setp.eq.s32 %p3, %r6, 1;
    @%p3 and.b32 %r13, %r5, %r17;
    min.s32 %r8, %r5, %r13;
    shr.u32 %r5, %r3, 1;
    or.b32 %r6, %r13, 32;
    cvt.s64.s32 %rd6, %r17;
    mul.lo.u32 %r16, %r10, %r5;
    or.b32 %r17, %r16, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
