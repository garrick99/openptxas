.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r17, %r3, %r3;
    cvt.u64.u32 %rd12, %r17;
    add.s32 %r22, %r3, %r3;
    cvt.s32.s64 %r9, %rd12;
    cvt.u64.u32 %rd15, %r3;
    setp.lt.s32 %p1, %r22, %r9;
    @%p1 min.s32 %r11, %r3, 4294967295;
    sub.u32 %r14, %r17, 15;
    mul.lo.u32 %r8, %r3, %r9;
    sub.s32 %r25, %r22, 2;
    cvt.u32.u64 %r13, %rd12;
    min.u32 %r10, %r22, 256;
    or.b64 %rd10, %rd12, %rd12;
    max.s32 %r11, %r11, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
