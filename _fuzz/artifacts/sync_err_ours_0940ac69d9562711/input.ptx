.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r25, %r3, 15;
    sub.s32 %r22, %r3, 2147483648;
    xor.b32 %r21, %r3, %r25;
    xor.b32 %r20, %r22, 0;
    shr.u32 %r20, %r3, 30;
    sub.s32 %r27, %r25, %r3;
    cvt.s64.s32 %rd10, %r21;
    sub.s32 %r10, %r21, 3;
    or.b32 %r12, %r27, %r10;
    add.u32 %r11, %r20, %r27;
    shl.b32 %r15, %r11, 3;
    setp.eq.s32 %p3, %r20, 16;
    @%p3 sub.u32 %r4, %r20, %r22;
    add.s32 %r6, %r10, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
