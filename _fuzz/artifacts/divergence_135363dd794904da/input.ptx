.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    shr.s32 %r19, %r3, 15;
    or.b32 %r8, %r3, %r19;
    setp.eq.s32 %p1, %r3, 255;
    @%p1 and.b32 %r17, %r19, %r19;
    max.u32 %r24, %r17, %r8;
    and.b32 %r27, %r24, %r17;
    mad.lo.s32 %r19, %r19, %r3, %r24;
    setp.hi.u32 %p2, %r17, 65535;
    @%p2 sub.s32 %r22, %r27, %r3;
    selp.b32 %r23, %r24, %r27, %p1;
    shr.u32 %r23, %r17, 2;
    selp.b32 %r19, %r27, %r23, %p1;
    shr.u32 %r21, %r19, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
