.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r9, %r3, 255;
    cvt.u64.u32 %rd6, %r3;
    shl.b64 %rd14, %rd6, 4;
    sub.u32 %r12, %r9, 3;
    min.s64 %rd10, %rd14, %rd6;
    max.u32 %r16, %r3, %r9;
    shl.b32 %r16, %r12, 0;
    max.s32 %r5, %r3, %r12;
    add.u64 %rd9, %rd6, %rd6;
    add.s32 %r21, %r9, %r3;
    and.b32 %r12, %r5, %r9;
    shl.b64 %rd14, %rd9, 7;
    xor.b32 %r7, %r3, %r12;
    cvt.s64.s32 %rd5, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
