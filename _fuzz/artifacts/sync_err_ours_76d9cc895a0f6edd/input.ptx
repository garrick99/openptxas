.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    mul.lo.u32 %r11, %r3, %r3;
    mad.lo.u32 %r10, %r11, %r3, %r3;
    shr.u32 %r13, %r3, 0;
    max.s32 %r23, %r3, %r3;
    and.b32 %r26, %r13, %r13;
    shr.u32 %r23, %r11, 2;
    mul.lo.u64 %rd14, %rd5, %rd5;
    mul.wide.u32 %rd5, %r3, %r3;
    or.b32 %r25, %r26, %r11;
    add.u32 %r18, %r13, 0;
    cvt.u64.u32 %rd8, %r18;
    or.b32 %r27, %r25, %r10;
    add.u32 %r5, %r18, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
