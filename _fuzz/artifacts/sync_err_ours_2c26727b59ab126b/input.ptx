.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    shr.s32 %r23, %r3, 3;
    min.s32 %r15, %r3, %r3;
    sub.s32 %r17, %r3, %r3;
    add.s32 %r27, %r23, %r17;
    min.u32 %r11, %r15, 4294967295;
    mul.lo.s32 %r13, %r17, 0;
    min.u32 %r19, %r15, %r23;
    max.u32 %r12, %r23, %r23;
    xor.b64 %rd15, %rd6, %rd6;
    add.u32 %r4, %r13, %r13;
    sub.s64 %rd7, %rd6, %rd15;
    setp.le.s32 %p3, %r4, 5;
    @%p3 add.s32 %r17, %r11, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
