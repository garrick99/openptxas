.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r23, %r3, 15;
    setp.eq.s32 %p4, %r23, 5;
    @%p4 cvt.u64.u32 %rd12, %r3;
    add.s32 %r5, %r23, %r23;
    cvt.u64.u32 %rd11, %r23;
    setp.gt.u32 %p2, %r5, 65536;
    @%p2 max.u32 %r16, %r5, %r5;
    selp.b32 %r4, %r16, %r23, %p2;
    mad.lo.s32 %r22, %r16, %r3, %r3;
    selp.b32 %r15, %r4, %r4, %p4;
    max.s64 %rd6, %rd11, %rd12;
    sub.u32 %r15, %r16, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
