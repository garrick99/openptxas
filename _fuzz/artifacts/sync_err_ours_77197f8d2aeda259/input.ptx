.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r18, %r3, %r3;
    min.u32 %r24, %r3, %r3;
    cvt.s64.s32 %rd15, %r3;
    mad.lo.s32 %r26, %r3, %r18, %r18;
    sub.u64 %rd15, %rd15, %rd15;
    mad.lo.s32 %r17, %r26, %r26, %r18;
    max.u32 %r8, %r18, %r18;
    cvt.s64.s32 %rd15, %r24;
    xor.b32 %r25, %r8, %r26;
    add.u64 %rd13, %rd15, %rd15;
    setp.le.u32 %p1, %r3, 4;
    shr.s32 %r6, %r3, 15;
    min.u64 %rd12, %rd15, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
