.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    cvt.u32.u64 %r10, %rd10;
    sub.u32 %r19, %r10, %r10;
    sub.u32 %r23, %r19, %r19;
    cvt.s32.s64 %r12, %rd10;
    or.b32 %r27, %r23, 2;
    and.b32 %r15, %r12, %r3;
    add.s32 %r25, %r23, 16;
    add.s32 %r24, %r15, %r27;
    shl.b64 %rd10, %rd10, 63;
    max.u32 %r7, %r19, %r12;
    mul.lo.s32 %r25, %r25, 16;
    cvt.u32.u64 %r23, %rd10;
    sub.s32 %r20, %r25, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
