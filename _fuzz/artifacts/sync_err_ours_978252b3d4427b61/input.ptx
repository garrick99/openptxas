.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r6, %r3, 65536;
    max.u32 %r12, %r6, 2147483647;
    mul.lo.u32 %r12, %r6, 65536;
    add.s32 %r26, %r3, %r12;
    mad.lo.u32 %r25, %r26, %r12, %r26;
    max.s32 %r6, %r6, %r12;
    shl.b32 %r21, %r3, 0;
    max.u32 %r11, %r25, 0;
    mad.lo.u32 %r21, %r25, %r6, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
