.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r26, %r3, 30;
    xor.b32 %r5, %r26, 3;
    xor.b32 %r8, %r3, %r5;
    sub.u32 %r9, %r5, %r26;
    max.s32 %r19, %r5, %r3;
    xor.b32 %r22, %r26, 15;
    mad.lo.u32 %r16, %r19, %r5, %r8;
    setp.ge.u32 %p4, %r9, %r22;
    @%p4 min.s32 %r24, %r22, %r19;
    mad.lo.u32 %r10, %r22, %r8, %r26;
    min.s32 %r17, %r9, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
