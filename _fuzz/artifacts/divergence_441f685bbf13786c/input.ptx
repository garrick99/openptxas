.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    mul.lo.u64 %rd11, %rd8, %rd8;
    cvt.u32.u64 %r5, %rd8;
    max.u32 %r16, %r3, 16;
    add.s32 %r4, %r16, 7;
    shr.u64 %rd13, %rd11, 47;
    add.u32 %r23, %r16, 32;
    shl.b32 %r24, %r5, 15;
    add.s32 %r5, %r3, 8;
    shr.u32 %r17, %r5, 16;
    cvt.s64.s32 %rd5, %r5;
    cvt.s64.s32 %rd6, %r3;
    xor.b32 %r5, %r3, %r23;
    mul.wide.s32 %rd13, %r23, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
