.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r16, %r3, 64;
    mul.lo.s32 %r7, %r3, 65535;
    mad.lo.s32 %r6, %r3, %r16, %r16;
    setp.lt.s32 %p1, %r6, %r16;
    setp.eq.s32 %p4, %r3, %r6;
    @%p4 shr.u32 %r8, %r16, 3;
    shr.s32 %r26, %r16, 4;
    shl.b32 %r27, %r6, 2;
    mul.lo.u32 %r24, %r3, %r26;
    setp.gt.s32 %p4, %r24, %r6;
    @!%p4 min.s32 %r22, %r24, %r26;
    min.u32 %r16, %r16, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
