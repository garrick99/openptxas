.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    shl.b64 %rd12, %rd6, 33;
    add.u32 %r26, %r3, 2;
    or.b32 %r14, %r26, 256;
    cvt.u32.u64 %r26, %rd6;
    max.s32 %r7, %r3, %r26;
    setp.ls.u32 %p4, %r26, %r14;
    @%p4 mul.wide.u32 %rd9, %r3, %r3;
    max.s32 %r5, %r14, %r7;
    sub.u32 %r14, %r14, %r14;
    setp.lt.s32 %p1, %r14, 2;
    @%p1 sub.s64 %rd7, %rd9, %rd12;
    setp.le.u32 %p1, %r3, 32;
    @%p1 shr.s32 %r24, %r7, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
