.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r22, %r3, %r3;
    mul.lo.u32 %r17, %r22, %r22;
    mul.wide.s32 %rd13, %r3, %r17;
    cvt.s32.s64 %r22, %rd13;
    add.u32 %r17, %r17, %r22;
    shl.b64 %rd11, %rd13, 31;
    add.u32 %r9, %r3, 65536;
    cvt.s32.s64 %r17, %rd13;
    shr.s64 %rd8, %rd11, 4;
    shl.b64 %rd9, %rd8, 48;
    shr.u32 %r11, %r17, 16;
    max.s64 %rd9, %rd8, %rd13;
    shl.b32 %r21, %r17, 30;
    max.s32 %r6, %r9, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
