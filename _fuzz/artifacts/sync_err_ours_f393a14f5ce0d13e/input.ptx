.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    shl.b64 %rd8, %rd10, 33;
    sub.u32 %r17, %r3, %r3;
    cvt.s32.s64 %r16, %rd10;
    cvt.s64.s32 %rd12, %r16;
    sub.s32 %r14, %r16, 4294967295;
    mul.lo.s32 %r26, %r16, 31;
    max.u32 %r23, %r16, 15;
    setp.hs.u32 %p3, %r26, 4294967295;
    @%p3 max.s64 %rd7, %rd8, %rd12;
    shr.s64 %rd5, %rd8, 0;
    min.s32 %r15, %r17, 5;
    shl.b32 %r22, %r15, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
