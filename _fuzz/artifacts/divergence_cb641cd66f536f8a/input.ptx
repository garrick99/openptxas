.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r21, %r3, %r3;
    add.s32 %r19, %r3, 2;
    or.b32 %r22, %r19, %r21;
    setp.ls.u32 %p1, %r21, 4;
    @%p1 shr.u32 %r24, %r21, 4;
    setp.gt.s32 %p2, %r22, %r24;
    mul.wide.s32 %rd9, %r22, %r21;
    sub.s32 %r10, %r19, %r3;
    cvt.s64.s32 %rd6, %r19;
    setp.lo.u32 %p4, %r19, 65536;
    @%p4 add.s32 %r27, %r19, 65536;
    add.s32 %r19, %r10, %r22;
    shr.s32 %r23, %r27, 30;
    add.u64 %rd5, %rd9, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
