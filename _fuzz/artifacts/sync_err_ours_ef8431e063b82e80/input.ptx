.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p1, %r3, %r3;
    mad.lo.s32 %r9, %r3, %r3, %r3;
    cvt.u64.u32 %rd15, %r3;
    cvt.s64.s32 %rd9, %r3;
    cvt.s32.s64 %r25, %rd9;
    mul.lo.u64 %rd14, %rd9, %rd9;
    selp.b32 %r12, %r3, %r25, %p1;
    mul.lo.s32 %r25, %r9, %r3;
    mul.lo.s32 %r17, %r3, 7;
    xor.b32 %r27, %r12, 65536;
    cvt.s32.s64 %r8, %rd9;
    and.b32 %r5, %r8, %r3;
    mul.lo.u64 %rd14, %rd15, %rd14;
    shr.u32 %r5, %r27, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
