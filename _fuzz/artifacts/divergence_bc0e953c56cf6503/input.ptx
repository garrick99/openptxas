.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r26, %r3, 1;
    add.s32 %r4, %r3, %r26;
    sub.s32 %r14, %r4, %r26;
    add.s32 %r24, %r14, 5;
    add.s32 %r15, %r4, 31;
    min.u32 %r25, %r15, %r4;
    and.b32 %r12, %r3, 63;
    setp.gt.u32 %p2, %r12, 65536;
    @!%p2 mad.lo.u32 %r20, %r24, %r26, %r24;
    setp.eq.s32 %p1, %r26, %r3;
    @%p1 sub.s32 %r10, %r14, %r25;
    cvt.u64.u32 %rd15, %r4;
    cvt.u64.u32 %rd9, %r20;
    max.u32 %r16, %r24, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
