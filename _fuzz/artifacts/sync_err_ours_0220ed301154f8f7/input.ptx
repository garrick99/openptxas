.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd6, %r3, %r3;
    add.u32 %r17, %r3, 16;
    mul.lo.s32 %r10, %r3, %r3;
    add.u32 %r13, %r10, %r10;
    setp.ne.u32 %p3, %r3, 32;
    mul.lo.s32 %r14, %r10, %r10;
    setp.ls.u32 %p4, %r10, 31;
    min.u32 %r19, %r13, %r10;
    max.s32 %r19, %r13, %r3;
    mad.lo.s32 %r12, %r10, %r10, %r13;
    max.s32 %r19, %r12, %r19;
    xor.b64 %rd5, %rd6, %rd6;
    max.s32 %r18, %r17, 4294967295;
    mad.lo.u32 %r14, %r13, %r10, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
