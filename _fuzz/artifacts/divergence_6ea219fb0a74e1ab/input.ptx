.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r20, %r3, %r3;
    bfe.u32 %r21, %r20, 23, 4;
    bfe.u32 %r12, %r21, 8, 1;
    clz.b32 %r11, %r21;
    bfe.u32 %r21, %r21, 8, 31;
    bfi.b32 %r7, %r20, %r12, 15, 32;
    bfe.s32 %r17, %r20, 1, 32;
    bfe.u32 %r10, %r3, 31, 16;
    bfe.u32 %r15, %r12, 24, 1;
    clz.b32 %r18, %r7;
    bfi.b32 %r22, %r18, %r18, 0, 24;
    popc.b32 %r23, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
