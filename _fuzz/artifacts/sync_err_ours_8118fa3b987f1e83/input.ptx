.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r10, %r3, 16;
    shr.s32 %r9, %r3, 15;
    shl.b32 %r5, %r3, 4;
    cvt.s64.s32 %rd15, %r9;
    max.s32 %r14, %r9, %r3;
    cvt.s64.s32 %rd13, %r5;
    and.b32 %r9, %r3, 32;
    max.u64 %rd5, %rd15, %rd13;
    max.u64 %rd7, %rd5, %rd13;
    mad.lo.s32 %r21, %r10, %r3, %r9;
    cvt.u32.u64 %r18, %rd5;
    setp.ge.s32 %p1, %r21, %r5;
    cvt.u32.u64 %r18, %rd13;
    shr.s32 %r21, %r9, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
