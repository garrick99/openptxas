.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r12, %r3, 15;
    shl.b32 %r18, %r12, 7;
    and.b32 %r5, %r3, %r18;
    shr.u32 %r7, %r18, 4;
    cvt.s64.s32 %rd13, %r3;
    mad.lo.u32 %r24, %r5, %r18, %r12;
    xor.b32 %r12, %r3, 65536;
    max.u32 %r4, %r7, 5;
    shr.u32 %r15, %r12, 4;
    cvt.s32.s64 %r20, %rd13;
    cvt.s32.s64 %r5, %rd13;
    cvt.s32.s64 %r24, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
