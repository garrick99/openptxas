.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r14, %r3, 65536;
    min.u32 %r15, %r3, 63;
    cvt.u64.u32 %rd6, %r15;
    shr.s64 %rd11, %rd6, 16;
    mul.lo.u32 %r17, %r3, 0;
    shl.b32 %r14, %r15, 3;
    shr.u32 %r6, %r14, 31;
    cvt.u64.u32 %rd7, %r3;
    and.b32 %r24, %r15, 256;
    mul.wide.s32 %rd12, %r6, %r15;
    add.s64 %rd7, %rd12, %rd11;
    sub.u32 %r14, %r14, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
