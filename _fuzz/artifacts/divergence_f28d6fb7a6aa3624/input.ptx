.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p4, %r3, 65535;
    @%p4 mul.lo.u32 %r25, %r3, 32;
    sub.u32 %r16, %r25, 2147483648;
    setp.ge.s32 %p2, %r25, %r16;
    @%p2 shl.b32 %r4, %r3, 30;
    add.u32 %r12, %r3, %r4;
    max.u32 %r11, %r16, %r16;
    shr.s32 %r20, %r25, 0;
    setp.ge.u32 %p3, %r11, %r12;
    or.b32 %r23, %r25, 63;
    mul.wide.u32 %rd7, %r16, %r23;
    cvt.s32.s64 %r9, %rd7;
    mul.lo.u32 %r21, %r23, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
