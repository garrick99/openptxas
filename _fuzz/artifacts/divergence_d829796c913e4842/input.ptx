.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r22, %r3, 256;
    setp.le.u32 %p1, %r3, 16;
    @%p1 sub.u32 %r26, %r22, 7;
    cvt.u64.u32 %rd13, %r3;
    shr.u64 %rd13, %rd13, 33;
    min.u32 %r8, %r26, 7;
    shl.b32 %r27, %r8, 1;
    or.b32 %r24, %r8, %r26;
    shl.b32 %r13, %r26, 4;
    xor.b32 %r9, %r22, %r3;
    selp.b32 %r22, %r26, %r9, %p1;
    mad.lo.u32 %r8, %r8, %r27, %r26;
    mul.wide.s32 %rd8, %r3, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
