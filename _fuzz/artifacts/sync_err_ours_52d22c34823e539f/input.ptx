.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r7, %r3, 32;
    shr.s32 %r12, %r3, 3;
    sub.s32 %r26, %r3, 65535;
    cvt.s64.s32 %rd12, %r7;
    max.s32 %r21, %r7, %r12;
    sub.s32 %r17, %r3, %r7;
    min.u32 %r20, %r12, %r26;
    min.s32 %r4, %r17, 65536;
    shl.b32 %r11, %r3, 1;
    shl.b32 %r21, %r17, 4;
    setp.eq.u32 %p3, %r11, 31;
    @%p3 sub.s32 %r18, %r26, 256;
    max.u32 %r15, %r3, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
