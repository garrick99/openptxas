.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r5, %r3, 1;
    add.s32 %r11, %r3, %r3;
    cvt.u64.u32 %rd14, %r5;
    mul.wide.u32 %rd9, %r5, %r11;
    setp.ls.u32 %p1, %r5, 7;
    @%p1 add.u32 %r7, %r3, 15;
    xor.b64 %rd11, %rd9, %rd14;
    sub.u32 %r5, %r7, %r7;
    mul.wide.s32 %rd5, %r7, %r5;
    shr.u32 %r5, %r11, 0;
    mul.lo.s32 %r5, %r7, 8;
    min.s32 %r9, %r7, 63;
    sub.s32 %r25, %r9, %r11;
    min.u32 %r5, %r7, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
