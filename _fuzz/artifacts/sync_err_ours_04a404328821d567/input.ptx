.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    add.u32 %r7, %r3, %r3;
    or.b64 %rd8, %rd11, %rd11;
    add.s32 %r19, %r7, %r7;
    shl.b64 %rd6, %rd8, 32;
    shl.b64 %rd14, %rd6, 7;
    cvt.s32.s64 %r27, %rd8;
    shr.u64 %rd6, %rd11, 47;
    shl.b32 %r14, %r7, 16;
    sub.s32 %r17, %r14, %r3;
    cvt.u64.u32 %rd5, %r7;
    shr.s32 %r26, %r17, 2;
    sub.s32 %r27, %r17, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
