.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r26, %r3, 5;
    mul.wide.s32 %rd13, %r3, %r26;
    mul.lo.s64 %rd15, %rd13, %rd13;
    min.s32 %r18, %r3, 65536;
    cvt.s32.s64 %r4, %rd13;
    setp.le.s32 %p2, %r18, 2147483648;
    @%p2 cvt.u32.u64 %r22, %rd13;
    shl.b32 %r22, %r22, 1;
    shl.b64 %rd13, %rd15, 4;
    mul.wide.u32 %rd14, %r4, %r18;
    mul.wide.u32 %rd13, %r18, %r22;
    shr.s64 %rd13, %rd13, 62;
    shr.s32 %r14, %r3, 1;
    mul.lo.s32 %r18, %r22, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
