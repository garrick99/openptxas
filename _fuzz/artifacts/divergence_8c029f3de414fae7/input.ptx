.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r4, %r3, %r3;
    cvt.u64.u32 %rd5, %r3;
    max.s32 %r18, %r4, %r3;
    setp.eq.s32 %p3, %r4, %r3;
    @%p3 max.u32 %r11, %r4, %r4;
    xor.b32 %r19, %r18, %r4;
    shr.s32 %r15, %r18, 16;
    sub.u64 %rd13, %rd5, %rd5;
    and.b32 %r10, %r19, 0;
    selp.b32 %r6, %r3, %r4, %p3;
    xor.b32 %r8, %r15, %r10;
    shl.b64 %rd12, %rd13, 62;
    max.s32 %r17, %r18, 1;
    shl.b64 %rd13, %rd13, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
