.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r19, %r3, %r3;
    add.u32 %r24, %r19, 256;
    shr.s32 %r21, %r24, 7;
    shr.u32 %r19, %r3, 16;
    add.u32 %r20, %r3, 63;
    cvt.s64.s32 %rd7, %r21;
    sub.u32 %r27, %r20, %r19;
    and.b32 %r6, %r3, %r3;
    cvt.s32.s64 %r8, %rd7;
    setp.ge.s32 %p3, %r21, %r27;
    @!%p3 sub.u32 %r4, %r19, 8;
    selp.b32 %r7, %r21, %r19, %p3;
    cvt.u64.u32 %rd8, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
