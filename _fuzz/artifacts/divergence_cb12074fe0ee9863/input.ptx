.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    min.u32 %r20, %r3, 63;
    shr.s64 %rd11, %rd14, 0;
    shl.b32 %r22, %r20, 31;
    mul.lo.s64 %rd10, %rd14, %rd11;
    sub.u32 %r18, %r3, 0;
    min.u32 %r23, %r18, 8;
    sub.s32 %r8, %r18, %r3;
    cvt.s32.s64 %r7, %rd10;
    cvt.s32.s64 %r23, %rd11;
    mad.lo.u32 %r16, %r22, %r3, %r18;
    min.u32 %r27, %r18, %r23;
    max.s64 %rd14, %rd10, %rd10;
    add.s32 %r22, %r18, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
