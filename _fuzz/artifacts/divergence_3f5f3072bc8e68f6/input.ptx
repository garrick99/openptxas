.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r23, %r3, 15;
    cvt.u64.u32 %rd5, %r23;
    mul.wide.s32 %rd8, %r3, %r23;
    shl.b32 %r4, %r3, 1;
    sub.s64 %rd5, %rd8, %rd8;
    sub.u32 %r19, %r3, %r23;
    setp.ls.u32 %p4, %r19, 63;
    @!%p4 add.s32 %r23, %r19, %r3;
    setp.ne.s32 %p3, %r23, %r19;
    @!%p3 shr.u32 %r12, %r23, 1;
    shr.s64 %rd10, %rd5, 0;
    add.s32 %r26, %r19, %r12;
    shr.u64 %rd15, %rd10, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
