.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p1, %r3, 2147483647;
    @!%p1 mul.lo.s32 %r22, %r3, %r3;
    selp.b32 %r20, %r3, %r3, %p1;
    cvt.u64.u32 %rd12, %r22;
    cvt.u32.u64 %r21, %rd12;
    cvt.s32.s64 %r16, %rd12;
    xor.b32 %r21, %r3, 32;
    shr.s32 %r10, %r20, 31;
    selp.b32 %r17, %r16, %r3, %p1;
    mul.lo.u32 %r15, %r16, 4;
    mad.lo.u32 %r5, %r3, %r17, %r22;
    shr.u32 %r22, %r3, 3;
    add.u32 %r23, %r15, %r10;
    shl.b32 %r15, %r15, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
