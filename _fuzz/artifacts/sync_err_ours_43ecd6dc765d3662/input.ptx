.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p3, %r3, %r3;
    @%p3 mul.wide.u32 %rd8, %r3, %r3;
    shr.s32 %r10, %r3, 1;
    min.u32 %r21, %r3, 15;
    mul.wide.u32 %rd13, %r10, %r10;
    and.b32 %r17, %r21, %r10;
    max.s32 %r12, %r3, 8;
    max.s64 %rd12, %rd13, %rd8;
    mul.lo.s32 %r12, %r21, 15;
    and.b32 %r20, %r21, %r17;
    and.b64 %rd7, %rd13, %rd12;
    add.u32 %r7, %r21, 5;
    mul.wide.u32 %rd5, %r12, %r3;
    max.s32 %r26, %r17, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
