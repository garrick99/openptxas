.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r9, %r3, 7;
    add.u32 %r14, %r9, %r9;
    min.s32 %r17, %r3, 2;
    cvt.u64.u32 %rd12, %r17;
    xor.b64 %rd12, %rd12, %rd12;
    min.u32 %r6, %r9, 0;
    setp.ne.s32 %p2, %r14, %r14;
    setp.ge.s32 %p3, %r9, 16;
    @!%p3 min.s32 %r24, %r6, 2147483648;
    cvt.u64.u32 %rd8, %r17;
    setp.hs.u32 %p3, %r14, %r24;
    @!%p3 mad.lo.s32 %r14, %r9, %r6, %r14;
    cvt.u64.u32 %rd10, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
