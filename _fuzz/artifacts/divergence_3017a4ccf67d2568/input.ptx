.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd11, %r3, %r3;
    mul.lo.u64 %rd10, %rd11, %rd11;
    add.u32 %r24, %r3, %r3;
    shl.b64 %rd11, %rd10, 16;
    min.s32 %r27, %r24, %r3;
    setp.gt.s32 %p1, %r3, 7;
    add.u32 %r6, %r3, %r24;
    xor.b32 %r11, %r24, %r6;
    or.b32 %r6, %r6, %r24;
    add.u32 %r11, %r3, %r6;
    max.s32 %r23, %r6, %r3;
    sub.s32 %r24, %r6, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
