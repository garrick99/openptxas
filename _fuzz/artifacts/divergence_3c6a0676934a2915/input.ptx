.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd9, %r3, %r3;
    add.s32 %r22, %r3, 7;
    min.u32 %r13, %r22, %r3;
    shr.u32 %r9, %r22, 4;
    setp.gt.u32 %p2, %r3, 2;
    @!%p2 max.s64 %rd14, %rd9, %rd9;
    mul.lo.s32 %r24, %r22, %r22;
    max.s32 %r6, %r3, %r22;
    add.s32 %r22, %r9, 63;
    mul.lo.s32 %r5, %r6, 5;
    shr.s32 %r5, %r6, 30;
    add.u32 %r16, %r6, %r13;
    mul.lo.s64 %rd9, %rd9, %rd14;
    cvt.u32.u64 %r13, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
