.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r6, %r3, 32;
    cvt.s64.s32 %rd8, %r6;
    setp.eq.s32 %p1, %r6, 4294967295;
    @!%p1 max.u32 %r9, %r3, 2147483647;
    sub.s64 %rd15, %rd8, %rd8;
    and.b32 %r27, %r3, %r6;
    setp.lt.s32 %p3, %r9, 4294967295;
    @%p3 mul.lo.s32 %r11, %r27, %r9;
    and.b32 %r25, %r6, 63;
    min.s32 %r27, %r9, %r6;
    or.b32 %r17, %r11, %r11;
    mul.wide.u32 %rd14, %r6, %r6;
    add.s64 %rd10, %rd15, %rd8;
    and.b32 %r23, %r17, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
