.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r5, %r3, 5;
    or.b32 %r27, %r5, %r3;
    max.u32 %r19, %r27, 65535;
    setp.lo.u32 %p2, %r5, %r5;
    add.u32 %r23, %r27, %r19;
    mul.wide.u32 %rd5, %r5, %r23;
    sub.u32 %r12, %r19, %r19;
    max.s32 %r25, %r23, %r19;
    min.s32 %r8, %r3, %r27;
    setp.gt.s32 %p1, %r23, %r27;
    setp.ge.s32 %p3, %r23, 4;
    @%p3 add.s32 %r24, %r25, %r27;
    shr.u64 %rd6, %rd5, 32;
    mul.wide.u32 %rd7, %r25, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
