.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r8, %r3, 2;
    setp.ls.u32 %p3, %r3, 16;
    @%p3 sub.u32 %r23, %r8, 1;
    cvt.s64.s32 %rd11, %r23;
    and.b32 %r10, %r8, %r23;
    cvt.s64.s32 %rd11, %r10;
    cvt.u64.u32 %rd15, %r8;
    cvt.s64.s32 %rd7, %r10;
    max.u32 %r16, %r23, 255;
    mul.wide.s32 %rd12, %r23, %r3;
    mul.lo.u32 %r22, %r23, 1;
    add.s32 %r17, %r22, 2147483648;
    selp.b32 %r11, %r17, %r23, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
