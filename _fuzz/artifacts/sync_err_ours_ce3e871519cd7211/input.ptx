.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r6, %r3, %r3;
    min.u32 %r25, %r6, 7;
    add.s32 %r16, %r25, %r6;
    cvt.u64.u32 %rd11, %r3;
    shr.s32 %r13, %r6, 15;
    sub.s32 %r21, %r25, 63;
    and.b32 %r5, %r25, %r16;
    shl.b32 %r5, %r6, 15;
    or.b32 %r26, %r25, 64;
    sub.u32 %r8, %r13, %r21;
    mad.lo.s32 %r20, %r5, %r5, %r13;
    mul.lo.u32 %r13, %r5, 15;
    mad.lo.s32 %r25, %r5, %r26, %r8;
    xor.b32 %r6, %r13, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
