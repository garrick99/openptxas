.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    max.s32 %r4, %r3, 4;
    and.b32 %r21, %r3, %r4;
    setp.lt.u32 %p1, %r21, %r21;
    min.u64 %rd6, %rd11, %rd11;
    sub.s32 %r4, %r4, %r3;
    max.s32 %r26, %r4, %r4;
    sub.u32 %r21, %r21, %r4;
    cvt.u32.u64 %r11, %rd6;
    mad.lo.u32 %r23, %r26, %r26, %r26;
    cvt.s32.s64 %r10, %rd11;
    add.u32 %r4, %r11, %r11;
    max.s32 %r25, %r4, %r21;
    cvt.u32.u64 %r22, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
