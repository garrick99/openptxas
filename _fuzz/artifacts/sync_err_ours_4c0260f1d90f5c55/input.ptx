.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    min.s32 %r14, %r3, %r3;
    max.u32 %r23, %r14, %r3;
    shr.u32 %r22, %r3, 7;
    shr.u32 %r6, %r14, 30;
    mul.wide.u32 %rd15, %r23, %r23;
    max.u32 %r20, %r3, 32;
    shr.u32 %r8, %r14, 4;
    cvt.s32.s64 %r13, %rd8;
    and.b32 %r14, %r14, %r20;
    setp.eq.s32 %p3, %r22, %r14;
    min.u64 %rd9, %rd8, %rd8;
    mul.lo.s32 %r8, %r20, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
