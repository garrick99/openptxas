.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd12, %r3, %r3;
    min.u32 %r25, %r3, 5;
    setp.ge.s32 %p4, %r25, %r3;
    @%p4 mad.lo.s32 %r12, %r25, %r25, %r25;
    min.u32 %r7, %r25, %r12;
    add.u32 %r21, %r7, 31;
    setp.le.s32 %p4, %r3, 255;
    @%p4 or.b32 %r17, %r12, %r12;
    max.s32 %r19, %r7, 7;
    mul.lo.u32 %r25, %r21, 31;
    sub.u32 %r11, %r7, %r7;
    selp.b32 %r25, %r17, %r17, %p4;
    setp.ne.u32 %p1, %r19, 32;
    @%p1 add.s32 %r21, %r21, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
