.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r7, %r3, 65535;
    setp.ne.s32 %p4, %r7, %r3;
    shr.s32 %r8, %r7, 0;
    cvt.u64.u32 %rd7, %r8;
    sub.u32 %r16, %r3, %r8;
    mad.lo.s32 %r16, %r7, %r7, %r3;
    setp.lt.s32 %p3, %r3, %r8;
    @!%p3 shl.b64 %rd11, %rd7, 48;
    shl.b32 %r21, %r16, 0;
    setp.lt.u32 %p4, %r7, %r21;
    @%p4 mul.wide.s32 %rd8, %r3, %r16;
    mul.wide.s32 %rd5, %r7, %r21;
    sub.s64 %rd15, %rd5, %rd11;
    mul.lo.s32 %r14, %r21, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
