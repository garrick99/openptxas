.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r24, %r3, %r3, %r3;
    sub.u32 %r12, %r3, 63;
    mul.lo.s32 %r5, %r3, 2147483648;
    max.u32 %r11, %r12, %r3;
    cvt.u64.u32 %rd8, %r11;
    mad.lo.u32 %r8, %r3, %r24, %r24;
    setp.ge.s32 %p2, %r8, 31;
    setp.lt.s32 %p4, %r8, 8;
    @%p4 shr.s32 %r6, %r11, 7;
    min.s32 %r25, %r3, %r5;
    max.s64 %rd13, %rd8, %rd8;
    shr.u64 %rd14, %rd8, 7;
    mul.lo.s32 %r5, %r8, 5;
    shr.u32 %r18, %r25, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
