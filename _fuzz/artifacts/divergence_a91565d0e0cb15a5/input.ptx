.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p1, %r3, %r3;
    @%p1 mad.lo.s32 %r21, %r3, %r3, %r3;
    setp.hs.u32 %p3, %r21, 256;
    @%p3 mul.wide.s32 %rd14, %r3, %r21;
    mul.wide.u32 %rd13, %r21, %r3;
    setp.ge.s32 %p3, %r3, 16;
    @%p3 max.u32 %r10, %r3, 2147483648;
    mad.lo.u32 %r6, %r10, %r3, %r10;
    sub.u32 %r25, %r21, 63;
    selp.b32 %r26, %r25, %r6, %p1;
    shl.b32 %r23, %r3, 31;
    mul.lo.s32 %r7, %r6, %r10;
    cvt.u64.u32 %rd14, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
