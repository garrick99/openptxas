    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r11, %r3, 2147483648;
    max.s32 %r6, %r11, %r3;
    mul.wide.u32 %rd5, %r3, %r6;
    setp.ls.u32 %p4, %r3, 8;
    @%p4 cvt.u64.u32 %rd10, %r6;
    selp.b32 %r25, %r6, %r6, %p4;
    and.b32 %r4, %r11, %r25;
    shr.u64 %rd11, %rd10, 30;
    or.b32 %r27, %r3, %r11;
