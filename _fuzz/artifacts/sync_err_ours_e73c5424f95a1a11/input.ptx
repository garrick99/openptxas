.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    shr.u64 %rd12, %rd11, 48;
    add.s32 %r10, %r3, %r3;
    max.s64 %rd15, %rd12, %rd11;
    mul.wide.s32 %rd6, %r3, %r3;
    mul.wide.s32 %rd5, %r3, %r3;
    max.u32 %r25, %r10, %r10;
    mad.lo.s32 %r5, %r25, %r3, %r25;
    max.u64 %rd14, %rd12, %rd11;
    shr.u64 %rd7, %rd12, 1;
    shr.u32 %r10, %r5, 3;
    shr.u32 %r18, %r5, 1;
    sub.u32 %r13, %r3, %r10;
    add.s32 %r13, %r3, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
