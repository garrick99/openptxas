.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r17, %r3, %r3, %r3;
    setp.ne.u32 %p3, %r17, 2;
    mul.wide.s32 %rd12, %r17, %r3;
    max.u32 %r16, %r17, %r17;
    xor.b32 %r7, %r3, 0;
    shr.u32 %r13, %r7, 0;
    min.u32 %r5, %r17, %r3;
    or.b32 %r11, %r5, %r17;
    setp.ge.s32 %p3, %r16, %r16;
    @!%p3 shr.s32 %r12, %r16, 7;
    or.b64 %rd7, %rd12, %rd12;
    xor.b32 %r10, %r11, 4;
    max.s32 %r15, %r17, %r16;
    sub.u32 %r5, %r17, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
