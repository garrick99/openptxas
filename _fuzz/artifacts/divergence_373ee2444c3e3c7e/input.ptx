.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r16, %r3, 5;
    cvt.u64.u32 %rd5, %r3;
    add.s64 %rd8, %rd5, %rd5;
    cvt.u32.u64 %r8, %rd5;
    min.u32 %r9, %r16, %r3;
    xor.b32 %r14, %r8, 31;
    setp.gt.s32 %p2, %r16, 65535;
    @%p2 shr.s32 %r17, %r9, 3;
    mul.wide.u32 %rd15, %r14, %r17;
    cvt.s64.s32 %rd13, %r16;
    or.b32 %r13, %r9, 2;
    setp.le.s32 %p4, %r9, 16;
    @%p4 cvt.u32.u64 %r10, %rd5;
    mul.wide.u32 %rd12, %r8, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
