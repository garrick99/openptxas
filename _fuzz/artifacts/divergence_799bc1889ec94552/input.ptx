.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    shr.s64 %rd11, %rd7, 2;
    and.b32 %r22, %r3, 64;
    cvt.u64.u32 %rd13, %r22;
    sub.s64 %rd11, %rd13, %rd7;
    mad.lo.u32 %r16, %r3, %r22, %r22;
    mul.wide.u32 %rd14, %r22, %r3;
    mad.lo.s32 %r8, %r3, %r16, %r3;
    max.s32 %r11, %r22, %r8;
    shr.s32 %r13, %r11, 16;
    add.u32 %r5, %r8, %r16;
    cvt.s64.s32 %rd6, %r5;
    max.s32 %r17, %r8, 256;
    cvt.s32.s64 %r9, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
