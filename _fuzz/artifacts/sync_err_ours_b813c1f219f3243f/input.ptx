.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r10, %r3, %r3, %r3;
    setp.eq.s32 %p1, %r3, 0;
    add.u32 %r7, %r10, 65535;
    cvt.s64.s32 %rd15, %r7;
    mul.lo.s32 %r10, %r7, 7;
    add.s32 %r26, %r7, %r3;
    cvt.s32.s64 %r7, %rd15;
    shr.s32 %r20, %r3, 7;
    add.s32 %r5, %r26, 64;
    shr.u32 %r13, %r20, 4;
    max.s32 %r4, %r3, %r7;
    shr.s64 %rd5, %rd15, 15;
    shr.s32 %r18, %r5, 1;
    setp.gt.s32 %p4, %r4, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
