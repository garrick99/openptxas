.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r18, %r3, 5;
    mul.lo.u32 %r20, %r3, %r3;
    max.s32 %r20, %r3, 2147483648;
    mul.wide.u32 %rd9, %r20, %r20;
    mul.lo.u32 %r14, %r20, 65536;
    cvt.s32.s64 %r14, %rd9;
    min.s64 %rd13, %rd9, %rd9;
    min.u32 %r16, %r18, 4;
    setp.ne.u32 %p2, %r20, 256;
    @%p2 max.s32 %r11, %r18, 255;
    mad.lo.s32 %r25, %r14, %r11, %r11;
    setp.ge.s32 %p3, %r18, 2147483648;
    setp.hs.u32 %p1, %r20, %r11;
    @!%p1 shr.s32 %r23, %r25, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
