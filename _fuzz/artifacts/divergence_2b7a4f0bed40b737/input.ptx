.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r15, %r3, %r3;
    setp.eq.u32 %p1, %r3, %r3;
    min.u32 %r24, %r3, %r3;
    cvt.s64.s32 %rd13, %r15;
    add.s32 %r22, %r24, 8;
    shr.u32 %r16, %r15, 1;
    shr.u32 %r14, %r24, 1;
    cvt.s32.s64 %r6, %rd13;
    sub.s32 %r5, %r3, %r15;
    min.u32 %r4, %r16, %r3;
    mul.lo.u32 %r17, %r22, %r6;
    sub.s32 %r21, %r22, 16;
    shr.u32 %r14, %r3, 1;
    or.b32 %r7, %r5, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
