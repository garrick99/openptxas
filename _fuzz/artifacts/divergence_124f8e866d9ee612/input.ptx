.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    mad.lo.s32 %r27, %r3, %r3, %r3;
    shr.u64 %rd11, %rd9, 33;
    mul.lo.s64 %rd12, %rd11, %rd11;
    xor.b32 %r11, %r3, %r27;
    add.s32 %r21, %r27, %r27;
    cvt.u64.u32 %rd12, %r27;
    setp.ne.s32 %p2, %r21, 7;
    setp.lt.s32 %p2, %r21, %r27;
    @!%p2 add.u32 %r10, %r3, %r3;
    sub.u64 %rd12, %rd9, %rd11;
    sub.s64 %rd15, %rd11, %rd12;
    mul.wide.u32 %rd11, %r21, %r3;
    add.s32 %r21, %r27, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
