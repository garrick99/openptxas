.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r9, %r3, 255;
    mad.lo.s32 %r27, %r3, %r9, %r9;
    add.s32 %r16, %r9, 0;
    shr.u32 %r19, %r16, 2;
    shr.s32 %r24, %r19, 15;
    xor.b32 %r6, %r27, %r24;
    mul.wide.u32 %rd15, %r9, %r16;
    setp.lo.u32 %p4, %r16, %r9;
    @%p4 mul.lo.u32 %r22, %r9, 64;
    mul.lo.s32 %r27, %r16, %r16;
    cvt.u32.u64 %r26, %rd15;
    min.s32 %r18, %r6, %r27;
    shr.s64 %rd8, %rd15, 15;
    add.s32 %r4, %r24, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
