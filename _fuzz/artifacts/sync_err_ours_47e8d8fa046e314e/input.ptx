.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd7, %r3, %r3;
    shr.s64 %rd6, %rd7, 3;
    sub.s32 %r5, %r3, %r3;
    shr.s32 %r12, %r5, 15;
    shr.u32 %r4, %r3, 30;
    add.u32 %r17, %r4, %r12;
    and.b32 %r27, %r3, %r17;
    add.s32 %r24, %r3, 2;
    max.u32 %r19, %r5, 65536;
    shr.s32 %r17, %r4, 7;
    max.s32 %r15, %r4, %r17;
    and.b32 %r9, %r4, 3;
    shr.s64 %rd15, %rd6, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
