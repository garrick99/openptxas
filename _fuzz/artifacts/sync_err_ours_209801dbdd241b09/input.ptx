.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd7, %r3, %r3;
    xor.b32 %r13, %r3, 4294967295;
    shl.b32 %r6, %r13, 16;
    mad.lo.s32 %r16, %r13, %r6, %r13;
    mul.lo.u32 %r21, %r3, 3;
    setp.eq.u32 %p4, %r3, %r3;
    @!%p4 cvt.s32.s64 %r4, %rd7;
    min.s32 %r5, %r13, %r21;
    mad.lo.u32 %r26, %r4, %r4, %r16;
    shr.s32 %r17, %r6, 0;
    sub.u32 %r16, %r6, 2;
    shr.s64 %rd15, %rd7, 47;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
