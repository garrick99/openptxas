.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p3, %r3, 256;
    @!%p3 min.s32 %r5, %r3, %r3;
    min.u32 %r20, %r5, 15;
    and.b32 %r27, %r5, 4;
    cvt.s64.s32 %rd15, %r3;
    mad.lo.u32 %r6, %r20, %r27, %r5;
    min.u32 %r8, %r3, %r27;
    cvt.u32.u64 %r27, %rd15;
    max.s32 %r21, %r6, 15;
    setp.eq.u32 %p3, %r27, 5;
    @%p3 mul.wide.u32 %rd8, %r5, %r8;
    or.b32 %r19, %r8, 2147483648;
    mul.wide.s32 %rd7, %r21, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
