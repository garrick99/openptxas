.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r4, %r3, 15;
    cvt.s64.s32 %rd8, %r4;
    setp.lt.u32 %p2, %r4, 4294967295;
    @%p2 mul.wide.u32 %rd15, %r3, %r4;
    xor.b32 %r27, %r4, 64;
    and.b32 %r24, %r4, %r3;
    max.s32 %r10, %r27, %r4;
    selp.b32 %r7, %r24, %r4, %p2;
    setp.le.s32 %p4, %r4, 63;
    shr.s64 %rd9, %rd8, 1;
    cvt.s32.s64 %r23, %rd15;
    shl.b32 %r25, %r24, 4;
    sub.u32 %r23, %r10, %r3;
    shr.s32 %r9, %r24, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
