.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r7, %r3, 3;
    max.s32 %r23, %r3, 4294967295;
    min.u32 %r12, %r23, %r23;
    cvt.s64.s32 %rd14, %r12;
    shl.b64 %rd10, %rd14, 7;
    mul.lo.s32 %r7, %r12, 255;
    mul.wide.u32 %rd11, %r23, %r3;
    or.b32 %r19, %r7, 64;
    max.u32 %r11, %r19, 31;
    or.b32 %r11, %r19, %r19;
    sub.u64 %rd15, %rd11, %rd14;
    mul.lo.s32 %r15, %r3, 32;
    mad.lo.u32 %r14, %r11, %r15, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
