.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd9, %r3, %r3;
    mad.lo.u32 %r17, %r3, %r3, %r3;
    add.s32 %r14, %r3, %r17;
    min.u32 %r15, %r14, %r14;
    max.s64 %rd7, %rd9, %rd9;
    setp.hi.u32 %p4, %r17, 32;
    setp.ls.u32 %p4, %r14, 5;
    mul.wide.s32 %rd5, %r14, %r3;
    mul.wide.u32 %rd12, %r15, %r14;
    mad.lo.s32 %r22, %r14, %r14, %r14;
    min.s32 %r27, %r15, %r22;
    shr.u32 %r11, %r27, 16;
    selp.b32 %r4, %r15, %r27, %p4;
    shr.u64 %rd13, %rd5, 48;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
