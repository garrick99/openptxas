.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd6, %r3, %r3;
    shr.u32 %r14, %r3, 2;
    min.s32 %r7, %r3, %r3;
    mad.lo.s32 %r20, %r7, %r14, %r14;
    cvt.s64.s32 %rd8, %r20;
    shr.u32 %r22, %r3, 15;
    shr.s32 %r21, %r22, 16;
    setp.le.u32 %p4, %r14, %r3;
    @%p4 cvt.u32.u64 %r23, %rd8;
    shl.b32 %r8, %r20, 4;
    min.s32 %r12, %r21, %r20;
    shr.s32 %r10, %r20, 0;
    mul.wide.s32 %rd14, %r7, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
