.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r24, %r3, %r3, %r3;
    mul.wide.u32 %rd11, %r3, %r24;
    setp.ge.s32 %p1, %r24, %r3;
    setp.hs.u32 %p1, %r3, 255;
    @%p1 cvt.s32.s64 %r27, %rd11;
    cvt.u64.u32 %rd14, %r3;
    shr.u32 %r7, %r3, 30;
    shr.u32 %r22, %r24, 3;
    and.b64 %rd11, %rd14, %rd14;
    cvt.u64.u32 %rd10, %r27;
    mul.lo.s32 %r18, %r27, 255;
    add.u32 %r27, %r27, 16;
    selp.b32 %r20, %r3, %r27, %p1;
    max.s64 %rd14, %rd14, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
