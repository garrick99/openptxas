.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    xor.b32 %r6, %r3, %r3;
    setp.ls.u32 %p4, %r3, 65535;
    @%p4 shr.u32 %r23, %r6, 3;
    and.b32 %r11, %r6, %r6;
    setp.le.s32 %p3, %r11, %r11;
    @%p3 xor.b32 %r23, %r6, %r23;
    shl.b64 %rd6, %rd14, 1;
    sub.s32 %r6, %r11, %r6;
    and.b64 %rd13, %rd14, %rd14;
    min.s32 %r16, %r11, 5;
    sub.u32 %r6, %r23, 32;
    mul.wide.u32 %rd13, %r6, %r6;
    cvt.u64.u32 %rd11, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
