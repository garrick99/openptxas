.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r24, %r3, %r3;
    mad.lo.s32 %r8, %r3, %r24, %r3;
    setp.lt.u32 %p4, %r8, %r24;
    @!%p4 max.s32 %r10, %r24, %r24;
    mad.lo.s32 %r5, %r24, %r24, %r10;
    mad.lo.u32 %r8, %r8, %r5, %r5;
    selp.b32 %r6, %r10, %r8, %p4;
    min.s32 %r6, %r10, 31;
    mul.wide.s32 %rd13, %r6, %r8;
    or.b32 %r4, %r6, 256;
    mad.lo.u32 %r7, %r5, %r4, %r6;
    xor.b32 %r5, %r4, 1;
    cvt.s32.s64 %r17, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
