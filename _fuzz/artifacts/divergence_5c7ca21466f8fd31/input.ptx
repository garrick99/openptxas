.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r13, %r3, %r3;
    mul.wide.u32 %rd8, %r13, %r3;
    min.u32 %r13, %r3, 2;
    shr.u32 %r6, %r3, 7;
    cvt.u64.u32 %rd13, %r13;
    setp.hi.u32 %p3, %r3, %r13;
    @%p3 sub.u32 %r13, %r13, 7;
    mad.lo.s32 %r27, %r6, %r6, %r3;
    shl.b64 %rd7, %rd8, 1;
    cvt.u64.u32 %rd5, %r13;
    mad.lo.s32 %r25, %r3, %r3, %r13;
    setp.le.u32 %p1, %r13, 4294967295;
    @%p1 and.b32 %r22, %r3, %r25;
    mul.wide.s32 %rd6, %r6, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
