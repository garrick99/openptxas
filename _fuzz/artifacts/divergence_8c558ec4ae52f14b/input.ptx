    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p3, %r3, 4294967295;
    @%p3 selp.b32 %r4, %r3, %r3, %p3;
    max.s32 %r23, %r3, %r4;
    setp.lo.u32 %p4, %r4, 7;
    min.u32 %r11, %r4, %r4;
    shr.u32 %r23, %r23, 4;
    sub.u32 %r8, %r3, %r23;
    setp.eq.u32 %p3, %r8, 2;
    @%p3 selp.b32 %r5, %r3, %r4, %p3;
    and.b32 %r15, %r23, %r8;
    shr.u32 %r17, %r5, 15;
    add.s32 %r11, %r8, %r4;
    add.s32 %r22, %r15, %r15;
    mul.wide.u32 %rd8, %r17, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
