.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hi.u32 %p3, %r3, 4294967295;
    @%p3 sub.u32 %r11, %r3, %r3;
    shr.u32 %r9, %r11, 3;
    cvt.u64.u32 %rd15, %r9;
    shr.u32 %r22, %r11, 1;
    shl.b32 %r9, %r9, 30;
    setp.ge.s32 %p1, %r3, 31;
    setp.le.u32 %p1, %r11, %r3;
    @%p1 mul.lo.u32 %r25, %r9, 15;
    min.u32 %r21, %r22, %r22;
    cvt.u64.u32 %rd5, %r21;
    or.b32 %r16, %r9, 32;
    or.b32 %r23, %r11, %r3;
    sub.u32 %r17, %r21, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
