.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r9, %r3, 30;
    mul.lo.u32 %r21, %r3, 4294967295;
    mul.lo.s32 %r22, %r9, 15;
    cvt.u64.u32 %rd10, %r22;
    cvt.u32.u64 %r8, %rd10;
    mad.lo.s32 %r26, %r9, %r22, %r3;
    cvt.u32.u64 %r9, %rd10;
    max.s32 %r21, %r8, 65535;
    mad.lo.s32 %r22, %r9, %r22, %r26;
    mul.lo.s32 %r10, %r26, 4294967295;
    sub.s64 %rd8, %rd10, %rd10;
    max.s32 %r14, %r3, %r26;
    xor.b64 %rd15, %rd8, %rd8;
    cvt.u64.u32 %rd9, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
