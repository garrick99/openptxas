.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    shr.s32 %r11, %r3, 1;
    shr.s32 %r19, %r11, 2;
    setp.gt.s32 %p4, %r11, 4294967295;
    @%p4 add.u64 %rd7, %rd6, %rd6;
    min.u32 %r21, %r11, %r3;
    xor.b32 %r19, %r21, 2;
    cvt.u64.u32 %rd7, %r3;
    min.u32 %r7, %r11, 64;
    shr.u64 %rd10, %rd6, 33;
    shr.s64 %rd6, %rd10, 4;
    shr.s32 %r23, %r7, 2;
    xor.b32 %r11, %r23, %r7;
    shr.s64 %rd10, %rd10, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
