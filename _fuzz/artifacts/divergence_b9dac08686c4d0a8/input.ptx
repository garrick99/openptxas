.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p4, %r3, 5;
    @!%p4 selp.b32 %r27, %r3, %r3, %p4;
    xor.b32 %r21, %r27, %r27;
    mul.lo.s32 %r15, %r21, 255;
    mul.wide.s32 %rd7, %r15, %r3;
    mul.lo.s32 %r25, %r27, 4294967295;
    mul.lo.u32 %r10, %r21, 256;
    or.b32 %r24, %r3, %r21;
    mul.wide.s32 %rd13, %r3, %r27;
    sub.u32 %r10, %r27, %r10;
    mul.lo.s64 %rd11, %rd13, %rd7;
    max.s32 %r8, %r15, 255;
    selp.b32 %r4, %r8, %r27, %p4;
    mul.lo.u32 %r13, %r4, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
