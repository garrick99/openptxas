.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r16, %r3, 63;
    shr.u32 %r14, %r16, 4;
    mul.lo.s32 %r26, %r14, 4294967295;
    add.s32 %r9, %r26, %r14;
    min.u32 %r19, %r9, %r26;
    mul.wide.s32 %rd7, %r19, %r19;
    xor.b32 %r23, %r26, %r9;
    add.s32 %r8, %r26, 5;
    setp.lt.u32 %p1, %r19, %r14;
    @%p1 mul.lo.u32 %r13, %r26, %r23;
    and.b32 %r5, %r9, 256;
    shr.s32 %r11, %r9, 31;
    mad.lo.s32 %r20, %r11, %r8, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
