    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r26, %r3, 2;
    or.b32 %r19, %r3, 2;
    mul.wide.s32 %rd5, %r26, %r19;
    min.u32 %r17, %r3, %r3;
