    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    setp.gt.u32 %p1, %r3, 2147483648;
    @%p1 mad.lo.u32 %r25, %r3, %r3, %r3;
    and.b32 %r17, %r3, 1;
    cvt.u32.u64 %r15, %rd8;
    add.s32 %r18, %r15, 65535;
    sub.u32 %r25, %r17, %r25;
    cvt.s32.s64 %r10, %rd8;
    cvt.s32.s64 %r23, %rd8;
    shl.b32 %r16, %r17, 0;
    setp.ge.s32 %p2, %r3, %r17;
    shl.b32 %r5, %r18, 30;
    max.u32 %r16, %r10, %r15;
    mad.lo.s32 %r9, %r5, %r3, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
