.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    or.b32 %r14, %r3, %r3;
    min.u64 %rd11, %rd11, %rd11;
    mad.lo.s32 %r16, %r3, %r3, %r3;
    cvt.u64.u32 %rd7, %r3;
    and.b32 %r16, %r16, 32;
    xor.b32 %r24, %r16, 64;
    cvt.u32.u64 %r17, %rd11;
    cvt.u64.u32 %rd8, %r16;
    mul.lo.u32 %r26, %r16, %r16;
    shr.s32 %r11, %r26, 15;
    shr.s64 %rd12, %rd8, 47;
    mad.lo.s32 %r25, %r11, %r24, %r24;
    mul.wide.u32 %rd9, %r11, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
