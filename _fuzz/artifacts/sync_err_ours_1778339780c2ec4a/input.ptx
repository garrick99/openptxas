.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r5, %r3, 4;
    or.b32 %r13, %r5, %r3;
    cvt.s64.s32 %rd13, %r5;
    shl.b64 %rd15, %rd13, 47;
    shl.b32 %r11, %r3, 3;
    add.u32 %r17, %r5, 2;
    shr.u64 %rd9, %rd13, 63;
    sub.u32 %r22, %r11, %r5;
    mad.lo.s32 %r21, %r13, %r13, %r11;
    sub.s64 %rd5, %rd9, %rd9;
    min.u32 %r10, %r22, %r21;
    or.b32 %r4, %r17, %r22;
    add.u32 %r21, %r13, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
