.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r18, %r3, 31;
    mul.wide.u32 %rd15, %r18, %r3;
    max.u32 %r26, %r3, %r18;
    add.u32 %r26, %r18, 255;
    shl.b64 %rd5, %rd15, 47;
    xor.b32 %r24, %r18, %r26;
    xor.b32 %r19, %r24, 2147483648;
    shl.b64 %rd8, %rd15, 4;
    setp.eq.u32 %p2, %r24, %r26;
    or.b32 %r4, %r3, 64;
    min.s32 %r6, %r3, %r4;
    shr.u32 %r19, %r18, 4;
    cvt.u32.u64 %r6, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
