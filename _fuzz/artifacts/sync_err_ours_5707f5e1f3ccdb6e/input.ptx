.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r4, %r3, %r3, %r3;
    cvt.s64.s32 %rd12, %r4;
    sub.u32 %r26, %r4, 65535;
    shr.u32 %r17, %r26, 30;
    mad.lo.u32 %r24, %r26, %r17, %r17;
    shr.u32 %r19, %r24, 0;
    shl.b32 %r25, %r4, 3;
    or.b32 %r15, %r4, %r19;
    mul.wide.u32 %rd11, %r4, %r4;
    mul.wide.s32 %rd7, %r17, %r25;
    mul.wide.u32 %rd13, %r26, %r24;
    shr.s64 %rd7, %rd12, 16;
    mul.lo.u64 %rd11, %rd7, %rd11;
    max.u32 %r21, %r15, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
