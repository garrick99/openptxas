.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.idx.b32 %r11, %r3, 31, 0x1f, -1;
    shfl.sync.up.b32 %r17, %r3, 16, 0x1f, -1;
    setp.gt.u32 %p2, %r11, 15;
    vote.sync.ballot.b32 %r8, %p2, -1;
    shfl.sync.down.b32 %r11, %r17, 4, 0x1f, -1;
    shfl.sync.idx.b32 %r8, %r17, 7, 0x1f, -1;
    setp.lt.u32 %p1, %r17, 31;
    vote.sync.ballot.b32 %r16, %p1, -1;
    shfl.sync.idx.b32 %r11, %r16, 15, 0x1f, -1;
    vote.sync.all.pred %p3, %p2, -1;
    shfl.sync.idx.b32 %r18, %r3, 7, 0x1f, -1;
    add.u32 %r18, %r3, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
