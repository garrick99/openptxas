.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r4, %r3, %r3;
    setp.lt.s32 %p3, %r3, %r3;
    @%p3 shr.s32 %r21, %r3, 16;
    mad.lo.u32 %r23, %r21, %r3, %r4;
    cvt.u64.u32 %rd11, %r3;
    shl.b32 %r11, %r4, 0;
    selp.b32 %r26, %r11, %r4, %p3;
    add.u32 %r4, %r21, 1;
    selp.b32 %r17, %r3, %r3, %p3;
    mad.lo.u32 %r25, %r17, %r4, %r17;
    mul.wide.s32 %rd15, %r3, %r11;
    mul.wide.s32 %rd13, %r17, %r21;
    and.b32 %r21, %r17, %r21;
    selp.b32 %r16, %r26, %r23, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
