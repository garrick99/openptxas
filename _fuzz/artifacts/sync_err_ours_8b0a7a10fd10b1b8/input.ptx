.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    or.b32 %r10, %r3, %r3;
    sub.u32 %r6, %r10, 8;
    min.s32 %r8, %r10, %r10;
    shr.u32 %r17, %r8, 16;
    xor.b32 %r5, %r17, %r8;
    max.s32 %r8, %r8, 1;
    xor.b32 %r5, %r5, %r17;
    cvt.s32.s64 %r27, %rd15;
    shl.b32 %r17, %r8, 3;
    sub.s32 %r19, %r5, 63;
    min.u32 %r22, %r10, %r17;
    setp.ls.u32 %p1, %r3, %r6;
    @!%p1 cvt.u32.u64 %r11, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
