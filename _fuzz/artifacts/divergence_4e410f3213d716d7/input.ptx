.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r6, %r3, %r3, %r3;
    mad.lo.s32 %r8, %r6, %r3, %r6;
    cvt.u64.u32 %rd14, %r6;
    sub.s64 %rd10, %rd14, %rd14;
    and.b32 %r26, %r8, %r3;
    shl.b32 %r22, %r8, 1;
    add.u32 %r5, %r3, %r26;
    mul.wide.u32 %rd8, %r8, %r22;
    max.s32 %r5, %r22, 256;
    mul.wide.u32 %rd7, %r3, %r22;
    setp.ne.s32 %p2, %r22, %r26;
    setp.ge.s32 %p1, %r5, %r6;
    @%p1 min.u32 %r20, %r5, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
