.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    min.s32 %r4, %r3, 5;
    setp.hs.u32 %p3, %r4, %r4;
    @%p3 shr.u64 %rd11, %rd5, 7;
    cvt.u64.u32 %rd6, %r3;
    shl.b32 %r14, %r3, 7;
    min.s64 %rd13, %rd6, %rd6;
    min.s64 %rd5, %rd13, %rd11;
    shr.u32 %r14, %r4, 0;
    and.b32 %r14, %r14, 0;
    max.u32 %r13, %r3, %r4;
    shl.b64 %rd8, %rd13, 32;
    selp.b32 %r11, %r4, %r3, %p3;
    cvt.u64.u32 %rd6, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
