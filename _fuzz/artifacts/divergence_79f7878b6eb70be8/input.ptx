.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r11, %r3, 256;
    min.u32 %r26, %r11, %r3;
    or.b32 %r9, %r3, 2;
    shr.u32 %r10, %r3, 15;
    setp.eq.s32 %p3, %r11, 256;
    @%p3 xor.b32 %r23, %r3, %r9;
    cvt.u64.u32 %rd7, %r10;
    shl.b32 %r13, %r23, 15;
    mul.lo.s32 %r10, %r13, %r3;
    and.b32 %r19, %r26, %r26;
    mul.wide.u32 %rd6, %r23, %r10;
    mad.lo.u32 %r5, %r10, %r10, %r13;
    cvt.s64.s32 %rd12, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
