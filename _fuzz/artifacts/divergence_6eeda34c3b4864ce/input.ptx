.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r27, %r3, %r3;
    mad.lo.s32 %r13, %r3, %r3, %r27;
    min.u32 %r17, %r27, 65535;
    shl.b32 %r20, %r27, 31;
    mul.wide.u32 %rd14, %r27, %r20;
    shl.b64 %rd6, %rd14, 16;
    cvt.u32.u64 %r6, %rd14;
    add.s32 %r11, %r13, %r3;
    max.u32 %r23, %r11, 8;
    mul.wide.u32 %rd15, %r23, %r11;
    cvt.s64.s32 %rd14, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
