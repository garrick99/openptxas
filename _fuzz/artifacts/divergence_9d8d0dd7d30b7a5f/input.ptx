.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    mul.lo.u32 %r10, %r3, 64;
    and.b32 %r8, %r10, 32;
    setp.lt.u32 %p4, %r8, %r10;
    @%p4 cvt.s64.s32 %rd7, %r8;
    add.s32 %r22, %r3, 2147483647;
    mad.lo.s32 %r20, %r8, %r22, %r8;
    and.b32 %r19, %r8, %r10;
    mul.wide.s32 %rd15, %r3, %r22;
    mul.lo.s32 %r15, %r10, 4;
    xor.b32 %r13, %r19, 15;
    mul.wide.u32 %rd8, %r13, %r20;
    max.u32 %r5, %r20, %r3;
    max.u32 %r22, %r10, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
