.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    shl.b32 %r9, %r3, 16;
    shl.b64 %rd15, %rd5, 7;
    sub.s32 %r9, %r3, %r9;
    shr.s32 %r4, %r9, 31;
    or.b32 %r12, %r4, 64;
    cvt.u32.u64 %r16, %rd15;
    min.u32 %r10, %r4, 31;
    setp.ne.s32 %p3, %r9, 65535;
    @%p3 or.b32 %r11, %r9, 256;
    mul.lo.u32 %r5, %r4, 5;
    add.s32 %r5, %r11, 32;
    sub.u32 %r23, %r5, %r12;
    min.u32 %r17, %r11, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
