.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p1, %r3, 16;
    @%p1 shr.s32 %r18, %r3, 16;
    and.b32 %r14, %r18, %r3;
    mul.wide.u32 %rd10, %r18, %r3;
    shl.b64 %rd5, %rd10, 0;
    shr.s32 %r5, %r18, 7;
    mul.lo.u32 %r25, %r5, %r3;
    mul.lo.s32 %r17, %r18, %r18;
    mad.lo.s32 %r19, %r14, %r5, %r5;
    cvt.s64.s32 %rd5, %r3;
    add.u32 %r4, %r5, %r5;
    or.b32 %r22, %r3, %r14;
    setp.ne.u32 %p2, %r5, 65535;
    @!%p2 or.b32 %r14, %r4, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
