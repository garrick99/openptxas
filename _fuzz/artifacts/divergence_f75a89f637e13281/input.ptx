.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r11, %r3, %r3;
    or.b32 %r27, %r3, %r11;
    cvt.s64.s32 %rd8, %r11;
    setp.ge.s32 %p4, %r3, 15;
    @%p4 mul.wide.s32 %rd6, %r3, %r27;
    or.b32 %r17, %r11, %r11;
    cvt.s32.s64 %r9, %rd6;
    setp.gt.u32 %p1, %r11, %r9;
    mad.lo.s32 %r25, %r11, %r11, %r9;
    mad.lo.u32 %r23, %r25, %r3, %r11;
    setp.le.s32 %p2, %r3, 63;
    setp.eq.u32 %p1, %r27, %r27;
    setp.hi.u32 %p1, %r25, 256;
    @%p1 shr.u32 %r7, %r25, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
