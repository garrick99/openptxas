.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    shl.b64 %rd9, %rd8, 0;
    mul.lo.s64 %rd8, %rd9, %rd9;
    and.b32 %r21, %r3, 2147483647;
    sub.s32 %r10, %r21, 65535;
    sub.u32 %r9, %r21, %r21;
    sub.s32 %r10, %r10, %r9;
    setp.gt.u32 %p1, %r3, 8;
    @%p1 mad.lo.u32 %r11, %r3, %r21, %r21;
    shr.u64 %rd6, %rd8, 16;
    max.u32 %r5, %r3, 32;
    setp.le.s32 %p4, %r3, %r11;
    max.s32 %r8, %r9, 256;
    mul.wide.s32 %rd10, %r10, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
