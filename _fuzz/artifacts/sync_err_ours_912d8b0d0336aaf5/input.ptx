.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p3, %r3, %r3;
    setp.ne.s32 %p1, %r3, 255;
    @!%p1 and.b32 %r15, %r3, %r3;
    shl.b32 %r13, %r15, 2;
    xor.b32 %r27, %r15, %r15;
    mad.lo.s32 %r25, %r3, %r13, %r3;
    selp.b32 %r13, %r25, %r25, %p1;
    setp.ls.u32 %p2, %r27, %r25;
    @%p2 sub.s32 %r22, %r15, 63;
    max.u32 %r10, %r15, %r27;
    min.s32 %r11, %r3, %r15;
    setp.le.u32 %p1, %r13, %r11;
    mul.wide.u32 %rd13, %r3, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
