.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    xor.b32 %r14, %r3, 31;
    mul.lo.s64 %rd5, %rd8, %rd8;
    sub.s32 %r26, %r14, 255;
    shr.u32 %r23, %r14, 15;
    cvt.s32.s64 %r17, %rd8;
    cvt.u64.u32 %rd12, %r14;
    shl.b32 %r24, %r3, 31;
    shr.s32 %r8, %r26, 7;
    cvt.s64.s32 %rd7, %r26;
    mul.wide.s32 %rd13, %r26, %r8;
    mul.wide.s32 %rd10, %r23, %r17;
    min.u32 %r17, %r24, 2147483648;
    setp.eq.u32 %p2, %r3, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
