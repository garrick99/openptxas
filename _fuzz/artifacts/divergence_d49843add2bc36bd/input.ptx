.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r6, %r3, 255;
    setp.le.u32 %p1, %r3, 32;
    shr.s32 %r24, %r6, 1;
    sub.s32 %r8, %r24, %r6;
    shl.b32 %r21, %r8, 7;
    or.b32 %r27, %r8, 255;
    sub.u32 %r7, %r8, 32;
    setp.ge.u32 %p4, %r8, 8;
    @%p4 cvt.u64.u32 %rd7, %r8;
    mul.lo.u32 %r5, %r6, 4;
    min.s32 %r9, %r27, 1;
    shr.s32 %r8, %r5, 31;
    mul.lo.u32 %r20, %r24, 4294967295;
    sub.s64 %rd11, %rd7, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
