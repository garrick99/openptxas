.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p4, %r3, 63;
    @!%p4 and.b32 %r5, %r3, 1;
    cvt.u64.u32 %rd5, %r3;
    shr.s32 %r7, %r5, 1;
    mad.lo.u32 %r18, %r5, %r7, %r7;
    sub.s32 %r22, %r7, %r5;
    xor.b32 %r9, %r5, %r3;
    max.s64 %rd7, %rd5, %rd5;
    max.s32 %r9, %r3, %r5;
    min.u32 %r10, %r3, 5;
    shr.u64 %rd12, %rd7, 62;
    mul.lo.u64 %rd10, %rd12, %rd7;
    mad.lo.u32 %r7, %r5, %r5, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
