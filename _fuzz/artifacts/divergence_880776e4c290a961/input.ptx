.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    mul.lo.u32 %r11, %r3, %r3;
    or.b64 %rd9, %rd5, %rd5;
    mad.lo.s32 %r19, %r11, %r3, %r11;
    shr.u32 %r5, %r19, 30;
    shl.b32 %r8, %r5, 7;
    and.b32 %r23, %r11, %r3;
    cvt.u32.u64 %r26, %rd9;
    mul.wide.u32 %rd5, %r19, %r5;
    shr.s32 %r19, %r23, 2;
    mul.lo.s32 %r27, %r19, 1;
    add.u32 %r22, %r5, 65536;
    shl.b64 %rd9, %rd9, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
