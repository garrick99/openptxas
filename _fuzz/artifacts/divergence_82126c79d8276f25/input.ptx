.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    cvt.s32.s64 %r20, %rd7;
    add.s32 %r23, %r20, 32;
    setp.gt.u32 %p4, %r23, %r20;
    max.u32 %r5, %r20, 1;
    sub.u32 %r16, %r20, 5;
    mad.lo.u32 %r17, %r5, %r3, %r5;
    cvt.s64.s32 %rd15, %r23;
    mul.lo.s32 %r5, %r5, %r17;
    mul.lo.u64 %rd5, %rd7, %rd7;
    shr.u32 %r27, %r17, 4;
    add.u32 %r21, %r20, %r17;
    setp.ls.u32 %p1, %r21, 256;
    @!%p1 add.s64 %rd13, %rd7, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
