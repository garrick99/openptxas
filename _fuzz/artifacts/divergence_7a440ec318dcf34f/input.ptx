.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p4, %r3, 63;
    @%p4 shr.u32 %r26, %r3, 4;
    sub.u32 %r14, %r26, %r26;
    max.s32 %r21, %r14, %r3;
    or.b32 %r13, %r14, %r3;
    mul.wide.s32 %rd9, %r13, %r26;
    or.b32 %r16, %r3, 63;
    shl.b64 %rd8, %rd9, 33;
    mul.wide.u32 %rd13, %r3, %r13;
    selp.b32 %r22, %r13, %r21, %p4;
    xor.b32 %r27, %r16, 7;
    cvt.u32.u64 %r8, %rd9;
    mad.lo.u32 %r6, %r3, %r8, %r8;
    shr.s32 %r9, %r8, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
