.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r25, %r3, 5;
    sub.s32 %r17, %r3, %r3;
    mul.lo.s32 %r14, %r17, 2147483648;
    cvt.s64.s32 %rd10, %r17;
    cvt.u64.u32 %rd15, %r17;
    cvt.u32.u64 %r9, %rd10;
    shl.b32 %r6, %r14, 7;
    shl.b32 %r27, %r9, 15;
    sub.u32 %r11, %r25, %r14;
    shr.s64 %rd14, %rd15, 15;
    min.s32 %r12, %r25, 32;
    mul.wide.u32 %rd5, %r17, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
