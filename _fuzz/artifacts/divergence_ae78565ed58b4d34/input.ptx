.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r20, %r3, 3;
    mad.lo.s32 %r22, %r3, %r3, %r3;
    setp.hs.u32 %p2, %r20, %r22;
    @%p2 cvt.s64.s32 %rd8, %r22;
    min.u32 %r15, %r22, 64;
    setp.eq.u32 %p3, %r15, 255;
    @%p3 add.u32 %r12, %r22, 3;
    max.s32 %r11, %r22, 65536;
    max.s32 %r18, %r22, %r22;
    setp.gt.u32 %p1, %r11, %r15;
    xor.b32 %r20, %r3, 8;
    mad.lo.s32 %r21, %r11, %r18, %r12;
    add.s64 %rd9, %rd8, %rd8;
    mul.wide.s32 %rd14, %r22, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
