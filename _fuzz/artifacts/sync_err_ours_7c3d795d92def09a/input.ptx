.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r12, %r3, 256;
    mad.lo.u32 %r5, %r12, %r3, %r3;
    sub.s32 %r18, %r3, %r12;
    sub.s32 %r21, %r5, 5;
    setp.eq.s32 %p2, %r12, 4;
    @%p2 add.u32 %r15, %r5, 63;
    sub.s32 %r25, %r15, %r12;
    or.b32 %r10, %r3, %r18;
    cvt.s64.s32 %rd8, %r18;
    mul.wide.u32 %rd10, %r15, %r18;
    max.s32 %r12, %r12, %r18;
    xor.b32 %r21, %r5, %r18;
    setp.hi.u32 %p4, %r10, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
