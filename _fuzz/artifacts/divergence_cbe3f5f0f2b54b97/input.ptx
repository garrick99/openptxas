.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    cvt.u64.u32 %rd15, %r3;
    sub.u32 %r7, %r3, %r3;
    shl.b32 %r24, %r3, 1;
    max.u32 %r11, %r7, %r3;
    mad.lo.u32 %r12, %r11, %r3, %r3;
    setp.gt.u32 %p2, %r24, %r12;
    @%p2 selp.b32 %r19, %r12, %r3, %p2;
    add.s32 %r25, %r24, %r19;
    shr.u32 %r13, %r25, 16;
    cvt.u64.u32 %rd7, %r3;
    shl.b32 %r6, %r19, 31;
    mul.wide.u32 %rd13, %r6, %r11;
    shr.u64 %rd11, %rd7, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
