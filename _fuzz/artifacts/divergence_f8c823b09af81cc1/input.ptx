.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r11, %r3, %r3;
    shl.b32 %r4, %r11, 30;
    sub.s32 %r22, %r3, 0;
    setp.ls.u32 %p3, %r4, 4;
    @%p3 and.b32 %r5, %r3, 7;
    shr.u32 %r10, %r11, 4;
    sub.s32 %r7, %r4, %r11;
    and.b32 %r16, %r5, %r11;
    shl.b32 %r14, %r4, 1;
    mad.lo.s32 %r13, %r11, %r5, %r10;
    selp.b32 %r7, %r10, %r3, %p3;
    mul.lo.s32 %r11, %r10, %r11;
    shr.u32 %r14, %r14, 4;
    mul.lo.s32 %r6, %r13, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
