.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    setp.gt.u32 %p1, %r3, 65535;
    @%p1 cvt.s64.s32 %rd12, %r3;
    shr.s32 %r6, %r3, 7;
    min.s32 %r8, %r3, %r3;
    and.b64 %rd7, %rd12, %rd12;
    shl.b64 %rd10, %rd7, 0;
    sub.u32 %r22, %r3, 31;
    setp.lo.u32 %p3, %r22, %r6;
    @%p3 and.b32 %r10, %r6, %r6;
    shl.b32 %r13, %r10, 30;
    min.s64 %rd11, %rd7, %rd5;
    max.u64 %rd12, %rd5, %rd10;
    shl.b64 %rd6, %rd5, 48;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
