.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r4, %r3, %r3, %r3;
    shr.u32 %r15, %r3, 2;
    mul.wide.u32 %rd10, %r15, %r15;
    sub.s32 %r26, %r15, 63;
    mad.lo.u32 %r13, %r26, %r4, %r15;
    mad.lo.u32 %r11, %r26, %r3, %r3;
    mul.lo.u64 %rd12, %rd10, %rd10;
    mul.lo.s32 %r9, %r4, %r13;
    min.u32 %r19, %r3, %r9;
    shr.u32 %r21, %r9, 1;
    max.s32 %r24, %r13, 4294967295;
    sub.s32 %r9, %r21, 5;
    add.s32 %r8, %r26, %r19;
    mul.lo.s32 %r5, %r21, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
