.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r5, %r3, 16;
    add.s32 %r8, %r5, 1;
    mad.lo.s32 %r25, %r5, %r8, %r8;
    shr.u32 %r23, %r5, 16;
    sub.s32 %r8, %r5, %r3;
    cvt.u64.u32 %rd10, %r5;
    min.u32 %r14, %r3, 3;
    max.s32 %r20, %r23, 31;
    shl.b64 %rd7, %rd10, 62;
    cvt.s32.s64 %r15, %rd10;
    shr.s32 %r23, %r25, 30;
    or.b64 %rd10, %rd7, %rd7;
    mul.lo.u32 %r23, %r25, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
