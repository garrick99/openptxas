.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r13, %r3, %r3;
    shr.u32 %r23, %r13, 7;
    cvt.u64.u32 %rd14, %r3;
    setp.le.u32 %p1, %r13, 4;
    @%p1 mul.wide.u32 %rd15, %r13, %r13;
    max.u32 %r17, %r3, 4;
    mad.lo.u32 %r13, %r23, %r3, %r13;
    and.b32 %r4, %r13, %r23;
    min.s32 %r24, %r13, %r4;
    mul.lo.s64 %rd14, %rd14, %rd15;
    min.u32 %r7, %r23, %r3;
    cvt.u32.u64 %r24, %rd14;
    mul.wide.u32 %rd5, %r3, %r23;
    min.u32 %r6, %r13, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
