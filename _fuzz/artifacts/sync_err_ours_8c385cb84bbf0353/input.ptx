.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r22, %r3, %r3;
    mul.wide.u32 %rd8, %r3, %r3;
    or.b32 %r19, %r22, %r22;
    shl.b32 %r13, %r3, 3;
    or.b32 %r10, %r22, 4294967295;
    min.u64 %rd14, %rd8, %rd8;
    shl.b64 %rd14, %rd14, 1;
    shr.u32 %r21, %r22, 15;
    add.u32 %r8, %r21, 7;
    max.s32 %r19, %r8, 255;
    cvt.s64.s32 %rd14, %r13;
    add.s32 %r4, %r19, %r10;
    mul.lo.u32 %r8, %r13, %r3;
    setp.ge.s32 %p3, %r10, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
