    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    and.b32 %r17, %r3, 4294967295;
    shr.u32 %r4, %r3, 3;
    setp.ne.u32 %p1, %r4, %r3;
    @%p1 selp.b32 %r14, %r4, %r4, %p1;
    cvt.s64.s32 %rd7, %r17;
    setp.hi.u32 %p2, %r14, 4294967295;
    @%p2 cvt.u64.u32 %rd14, %r17;
    min.s32 %r18, %r3, %r3;
    shr.u32 %r9, %r17, 1;
    cvt.s32.s64 %r23, %rd14;
    setp.eq.s32 %p1, %r4, %r18;
    setp.lo.u32 %p1, %r23, 15;
    @%p1 and.b32 %r18, %r23, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
