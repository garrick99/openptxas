.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd6, %r3;
    mul.lo.s32 %r27, %r3, 64;
    add.s32 %r16, %r27, %r3;
    mul.lo.s32 %r18, %r3, 1;
    max.s32 %r24, %r16, %r3;
    shr.u64 %rd11, %rd6, 30;
    sub.u32 %r12, %r3, %r27;
    shl.b32 %r8, %r27, 7;
    setp.gt.u32 %p2, %r27, %r3;
    @%p2 shr.u32 %r14, %r27, 4;
    cvt.u32.u64 %r17, %rd6;
    setp.lt.u32 %p4, %r27, 64;
    @!%p4 min.s32 %r17, %r12, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
