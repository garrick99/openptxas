    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r11, %r3, 30;
    mul.lo.s32 %r6, %r11, 3;
    xor.b32 %r26, %r3, 255;
    mad.lo.s32 %r22, %r3, %r11, %r11;
    add.u32 %r16, %r6, %r22;
    add.u32 %r27, %r26, 2147483648;
    max.u32 %r11, %r22, %r22;
    mul.wide.u32 %rd12, %r27, %r6;
    max.s64 %rd12, %rd12, %rd12;
    setp.lt.s32 %p3, %r3, %r22;
    @%p3 cvt.u32.u64 %r11, %rd12;
    setp.le.s32 %p1, %r27, 64;
    @%p1 shl.b64 %rd9, %rd12, 48;
    cvt.s32.s64 %r11, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
