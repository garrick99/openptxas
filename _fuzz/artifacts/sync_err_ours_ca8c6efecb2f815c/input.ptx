.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd7, %r3, %r3;
    mul.wide.s32 %rd7, %r3, %r3;
    min.s32 %r16, %r3, 4294967295;
    setp.ge.s32 %p3, %r3, 15;
    max.s32 %r5, %r3, 4294967295;
    mad.lo.s32 %r12, %r16, %r5, %r5;
    min.u64 %rd11, %rd7, %rd7;
    or.b32 %r18, %r3, %r5;
    cvt.u64.u32 %rd6, %r12;
    mul.wide.s32 %rd10, %r12, %r5;
    shl.b64 %rd8, %rd7, 63;
    shr.s64 %rd14, %rd10, 7;
    min.u32 %r7, %r18, 5;
    add.s64 %rd14, %rd14, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
