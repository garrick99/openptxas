.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r10, %r3, %r3;
    xor.b32 %r6, %r3, %r3;
    sub.u32 %r19, %r3, %r6;
    min.u32 %r9, %r6, %r19;
    mul.wide.s32 %rd13, %r9, %r19;
    shl.b64 %rd9, %rd13, 48;
    shl.b32 %r17, %r10, 4;
    and.b32 %r4, %r19, %r10;
    xor.b32 %r8, %r9, %r10;
    setp.ge.u32 %p4, %r3, 63;
    @%p4 mul.wide.s32 %rd13, %r4, %r3;
    mad.lo.s32 %r11, %r10, %r6, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
