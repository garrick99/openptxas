.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd7, %r3, %r3;
    and.b32 %r25, %r3, 255;
    mul.wide.u32 %rd10, %r25, %r25;
    min.s32 %r24, %r3, 2147483647;
    shr.s64 %rd14, %rd10, 47;
    add.s32 %r16, %r25, 31;
    add.u32 %r20, %r24, 256;
    add.u32 %r13, %r16, 4;
    add.s32 %r21, %r3, %r3;
    shr.u64 %rd8, %rd7, 48;
    sub.u32 %r14, %r21, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
