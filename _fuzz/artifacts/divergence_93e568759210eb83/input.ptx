.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    cvt.u64.u32 %rd11, %r3;
    cvt.s64.s32 %rd10, %r3;
    min.u32 %r4, %r3, 3;
    mul.lo.u32 %r23, %r4, %r3;
    xor.b32 %r17, %r3, %r23;
    mul.wide.s32 %rd11, %r17, %r4;
    min.s32 %r11, %r3, 65536;
    and.b32 %r14, %r4, %r23;
    mul.lo.u32 %r6, %r11, 7;
    cvt.u64.u32 %rd15, %r4;
    setp.gt.s32 %p4, %r23, 255;
    @%p4 mad.lo.s32 %r23, %r23, %r11, %r14;
    and.b64 %rd12, %rd10, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
