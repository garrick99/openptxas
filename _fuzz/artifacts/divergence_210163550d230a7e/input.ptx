.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r14, %r3, %r3;
    or.b32 %r9, %r3, %r3;
    cvt.u64.u32 %rd7, %r3;
    shl.b64 %rd10, %rd7, 30;
    min.u32 %r5, %r14, %r9;
    setp.le.u32 %p1, %r14, 2;
    mul.wide.u32 %rd6, %r9, %r5;
    mul.lo.s32 %r11, %r9, %r9;
    sub.u32 %r25, %r5, 16;
    max.s32 %r13, %r14, %r25;
    shr.u64 %rd13, %rd6, 3;
    sub.s32 %r19, %r9, %r13;
    cvt.u32.u64 %r27, %rd7;
    cvt.s32.s64 %r17, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
