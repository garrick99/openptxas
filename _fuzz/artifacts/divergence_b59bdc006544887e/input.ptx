.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    xor.b32 %r27, %r3, 1;
    shl.b32 %r14, %r3, 31;
    setp.lo.u32 %p3, %r27, %r27;
    min.u32 %r13, %r14, %r27;
    shr.s64 %rd8, %rd9, 0;
    or.b32 %r20, %r14, 31;
    add.u32 %r23, %r13, %r20;
    shl.b64 %rd13, %rd8, 2;
    shr.s64 %rd11, %rd8, 15;
    shr.s32 %r22, %r13, 31;
    mul.wide.u32 %rd9, %r27, %r13;
    cvt.s32.s64 %r7, %rd9;
    max.s32 %r11, %r3, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
