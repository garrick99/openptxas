.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r6, %r3, %r3;
    cvt.s64.s32 %rd11, %r3;
    shr.s32 %r24, %r3, 2;
    mad.lo.s32 %r4, %r3, %r24, %r24;
    add.s32 %r14, %r4, 16;
    setp.lt.u32 %p3, %r6, 63;
    @!%p3 mul.lo.s32 %r5, %r6, %r14;
    selp.b32 %r20, %r5, %r14, %p3;
    shr.s64 %rd11, %rd11, 62;
    min.u32 %r22, %r24, %r14;
    max.s32 %r23, %r22, %r14;
    selp.b32 %r6, %r20, %r23, %p3;
    cvt.s32.s64 %r10, %rd11;
    min.u32 %r14, %r6, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
