.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r17, %r3, 4;
    min.u32 %r27, %r17, 4;
    shl.b32 %r8, %r17, 16;
    cvt.s64.s32 %rd11, %r27;
    shr.s32 %r4, %r17, 4;
    min.u32 %r13, %r27, %r4;
    min.u32 %r11, %r13, 255;
    min.s64 %rd12, %rd11, %rd11;
    sub.u32 %r17, %r8, %r11;
    cvt.s64.s32 %rd6, %r3;
    add.u32 %r14, %r4, %r4;
    mul.wide.u32 %rd9, %r17, %r11;
    sub.s32 %r14, %r11, %r13;
    cvt.u64.u32 %rd8, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
