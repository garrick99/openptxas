.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd11, %r3, %r3;
    and.b64 %rd11, %rd11, %rd11;
    cvt.u32.u64 %r7, %rd11;
    and.b32 %r11, %r7, %r7;
    shl.b32 %r21, %r11, 4;
    and.b32 %r21, %r7, %r21;
    shr.u64 %rd6, %rd11, 31;
    add.s64 %rd10, %rd11, %rd11;
    and.b64 %rd5, %rd11, %rd6;
    shr.u64 %rd15, %rd5, 3;
    setp.hi.u32 %p4, %r21, 256;
    setp.lt.s32 %p2, %r21, 63;
    @%p2 selp.b32 %r4, %r11, %r21, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
