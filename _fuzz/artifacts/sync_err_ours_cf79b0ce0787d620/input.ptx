.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r6, %r3, 65535;
    setp.ge.s32 %p2, %r6, 15;
    @%p2 shr.s32 %r18, %r3, 4;
    max.u32 %r20, %r3, 64;
    selp.b32 %r12, %r6, %r6, %p2;
    cvt.u64.u32 %rd6, %r18;
    selp.b32 %r11, %r3, %r3, %p2;
    sub.u32 %r14, %r20, 3;
    or.b32 %r23, %r12, %r20;
    mul.lo.s32 %r17, %r11, 15;
    sub.u32 %r23, %r12, 3;
    selp.b32 %r18, %r20, %r17, %p2;
    add.u32 %r27, %r17, 3;
    setp.le.u32 %p2, %r17, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
