.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd11, %r3, %r3;
    min.u32 %r12, %r3, %r3;
    mad.lo.s32 %r6, %r3, %r12, %r3;
    or.b32 %r14, %r6, 16;
    shr.u32 %r24, %r6, 3;
    setp.lt.s32 %p4, %r12, %r3;
    selp.b32 %r25, %r6, %r3, %p4;
    xor.b32 %r18, %r12, %r12;
    cvt.s64.s32 %rd7, %r14;
    add.u32 %r26, %r18, 3;
    max.u32 %r27, %r3, 64;
    mul.lo.s32 %r6, %r25, 8;
    sub.s32 %r15, %r25, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
