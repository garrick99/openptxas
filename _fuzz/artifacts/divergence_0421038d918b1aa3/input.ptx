.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd6, %r3, %r3;
    max.u32 %r7, %r3, %r3;
    min.u64 %rd13, %rd6, %rd6;
    min.s32 %r14, %r3, %r3;
    add.u32 %r22, %r14, %r3;
    shl.b32 %r4, %r22, 30;
    setp.lt.u32 %p4, %r7, %r3;
    cvt.u32.u64 %r11, %rd13;
    or.b64 %rd13, %rd13, %rd13;
    mul.wide.s32 %rd5, %r7, %r4;
    min.s32 %r8, %r7, %r14;
    cvt.u32.u64 %r13, %rd6;
    cvt.s32.s64 %r19, %rd6;
    selp.b32 %r7, %r14, %r19, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
