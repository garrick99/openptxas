.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r11, %r3, %r3;
    shr.s32 %r20, %r11, 16;
    mul.wide.s32 %rd14, %r11, %r11;
    mul.wide.s32 %rd14, %r20, %r20;
    max.s32 %r20, %r3, %r11;
    shr.s32 %r7, %r11, 31;
    sub.u32 %r15, %r11, 64;
    mad.lo.s32 %r11, %r11, %r3, %r20;
    setp.ne.s32 %p2, %r20, %r3;
    @!%p2 cvt.s64.s32 %rd8, %r7;
    setp.eq.u32 %p3, %r11, %r20;
    @%p3 max.u32 %r12, %r15, 255;
    xor.b32 %r7, %r11, %r12;
    setp.lo.u32 %p4, %r3, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
