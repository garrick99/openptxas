.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r14, %r3, 2;
    mad.lo.s32 %r9, %r3, %r3, %r3;
    shr.s32 %r6, %r9, 1;
    min.u32 %r25, %r3, 5;
    cvt.s64.s32 %rd11, %r6;
    add.s32 %r7, %r3, %r6;
    sub.s32 %r20, %r25, 65535;
    min.s32 %r23, %r25, %r7;
    shr.s64 %rd15, %rd11, 4;
    and.b32 %r18, %r14, %r20;
    max.s64 %rd13, %rd15, %rd11;
    shr.s32 %r26, %r20, 31;
    setp.le.s32 %p1, %r9, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
