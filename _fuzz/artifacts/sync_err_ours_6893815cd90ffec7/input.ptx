.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    mul.lo.s32 %r6, %r3, 255;
    cvt.u64.u32 %rd13, %r6;
    shl.b64 %rd7, %rd13, 7;
    cvt.u32.u64 %r13, %rd14;
    shr.s64 %rd8, %rd14, 4;
    and.b32 %r26, %r13, 16;
    sub.s32 %r4, %r6, 15;
    cvt.s64.s32 %rd14, %r4;
    mad.lo.s32 %r15, %r6, %r4, %r6;
    mul.lo.s64 %rd14, %rd8, %rd13;
    xor.b32 %r15, %r13, %r6;
    mad.lo.u32 %r5, %r3, %r3, %r4;
    shr.u32 %r4, %r6, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
