.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    mul.lo.u32 %r26, %r3, %r3;
    min.u32 %r14, %r3, 255;
    shr.s64 %rd11, %rd14, 62;
    cvt.s32.s64 %r4, %rd14;
    xor.b32 %r19, %r3, 2147483648;
    shr.s64 %rd6, %rd14, 16;
    setp.le.s32 %p1, %r3, %r26;
    @%p1 and.b64 %rd12, %rd6, %rd14;
    mul.wide.u32 %rd13, %r26, %r3;
    add.u64 %rd9, %rd11, %rd14;
    shr.s64 %rd8, %rd6, 4;
    mul.wide.u32 %rd11, %r3, %r4;
    cvt.s64.s32 %rd7, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
