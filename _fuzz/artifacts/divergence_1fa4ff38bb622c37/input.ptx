.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r7, %r3, 7;
    cvt.u64.u32 %rd7, %r3;
    mul.wide.u32 %rd5, %r3, %r3;
    max.u64 %rd11, %rd7, %rd5;
    shl.b32 %r13, %r3, 1;
    cvt.s32.s64 %r7, %rd11;
    sub.s32 %r4, %r3, 256;
    mul.wide.s32 %rd5, %r4, %r13;
    setp.ls.u32 %p2, %r13, %r3;
    cvt.u32.u64 %r14, %rd11;
    max.u32 %r23, %r14, %r13;
    and.b32 %r5, %r7, 64;
    and.b32 %r5, %r7, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
