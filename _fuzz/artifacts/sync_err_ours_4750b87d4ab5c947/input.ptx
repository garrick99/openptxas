.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r18, %r3, 2;
    shr.u32 %r13, %r3, 3;
    cvt.s64.s32 %rd10, %r13;
    cvt.s32.s64 %r22, %rd10;
    add.u32 %r13, %r22, %r22;
    cvt.u64.u32 %rd11, %r18;
    max.u32 %r9, %r3, 255;
    and.b32 %r20, %r18, 65536;
    min.u32 %r21, %r18, %r22;
    and.b32 %r23, %r21, 0;
    min.u32 %r19, %r21, %r9;
    max.u64 %rd11, %rd10, %rd11;
    mul.wide.u32 %rd12, %r23, %r20;
    add.s32 %r17, %r23, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
