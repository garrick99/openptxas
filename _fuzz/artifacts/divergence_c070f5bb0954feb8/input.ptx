.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p1, %r3, %r3;
    cvt.u64.u32 %rd11, %r3;
    mul.wide.s32 %rd6, %r3, %r3;
    selp.b32 %r16, %r3, %r3, %p1;
    shr.s64 %rd14, %rd6, 7;
    shr.s64 %rd10, %rd11, 47;
    cvt.s32.s64 %r19, %rd6;
    mul.lo.u32 %r14, %r3, 4294967295;
    xor.b32 %r26, %r14, %r3;
    selp.b32 %r21, %r14, %r19, %p1;
    shl.b64 %rd8, %rd10, 48;
    cvt.s64.s32 %rd12, %r16;
    mul.lo.s32 %r4, %r3, 15;
    min.u32 %r11, %r26, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
