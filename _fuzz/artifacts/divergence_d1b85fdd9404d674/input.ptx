.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r9, %r3, 65536;
    cvt.u64.u32 %rd5, %r3;
    min.s32 %r13, %r9, %r9;
    mad.lo.s32 %r19, %r13, %r13, %r9;
    shr.s32 %r23, %r19, 16;
    cvt.u64.u32 %rd13, %r13;
    shl.b32 %r18, %r23, 2;
    mad.lo.u32 %r9, %r19, %r3, %r13;
    xor.b32 %r21, %r13, 7;
    setp.lo.u32 %p2, %r21, 31;
    @%p2 selp.b32 %r23, %r3, %r18, %p2;
    cvt.u32.u64 %r24, %rd13;
    mul.wide.s32 %rd7, %r13, %r19;
    mul.lo.s32 %r21, %r13, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
