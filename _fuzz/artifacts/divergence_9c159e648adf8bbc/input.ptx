.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p2, %r3, 63;
    @!%p2 mul.wide.s32 %rd12, %r3, %r3;
    shl.b32 %r17, %r3, 31;
    shr.s32 %r27, %r17, 16;
    mad.lo.s32 %r18, %r17, %r3, %r27;
    max.s32 %r13, %r27, 255;
    add.u64 %rd14, %rd12, %rd12;
    setp.ne.s32 %p2, %r27, %r13;
    @!%p2 shr.s32 %r18, %r13, 3;
    shr.s32 %r17, %r13, 31;
    sub.u32 %r19, %r17, 7;
    mad.lo.s32 %r11, %r19, %r13, %r18;
    cvt.s64.s32 %rd6, %r11;
    mad.lo.u32 %r9, %r18, %r17, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
