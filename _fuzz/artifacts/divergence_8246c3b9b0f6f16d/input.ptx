.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r15, %r3, 16;
    cvt.u64.u32 %rd8, %r15;
    mad.lo.s32 %r18, %r3, %r3, %r15;
    cvt.u32.u64 %r8, %rd8;
    max.s32 %r19, %r15, %r8;
    cvt.u32.u64 %r24, %rd8;
    cvt.u64.u32 %rd11, %r8;
    mul.lo.u64 %rd6, %rd8, %rd11;
    cvt.s32.s64 %r8, %rd8;
    mul.wide.s32 %rd9, %r24, %r19;
    add.u32 %r27, %r24, 3;
    min.s32 %r23, %r18, 2;
    xor.b64 %rd11, %rd8, %rd6;
    sub.u32 %r9, %r24, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
