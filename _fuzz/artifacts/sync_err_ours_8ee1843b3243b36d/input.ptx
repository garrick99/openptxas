.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r25, %r3, 0;
    shr.s32 %r8, %r3, 15;
    min.u32 %r9, %r8, %r3;
    xor.b32 %r24, %r8, 8;
    mul.wide.s32 %rd15, %r25, %r24;
    min.s32 %r11, %r3, 65535;
    shr.u32 %r16, %r24, 4;
    cvt.u32.u64 %r6, %rd15;
    cvt.u64.u32 %rd11, %r16;
    shr.s64 %rd6, %rd11, 4;
    and.b32 %r21, %r24, %r24;
    add.u32 %r7, %r3, %r21;
    cvt.u32.u64 %r15, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
