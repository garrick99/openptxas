.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r17, %r3, 3;
    add.s32 %r11, %r17, %r3;
    mad.lo.s32 %r8, %r3, %r11, %r17;
    mul.lo.u32 %r13, %r11, 32;
    mul.lo.u32 %r11, %r8, %r3;
    min.u32 %r26, %r8, %r17;
    cvt.s64.s32 %rd13, %r26;
    cvt.s64.s32 %rd8, %r8;
    mul.lo.s32 %r26, %r17, %r17;
    setp.le.s32 %p4, %r26, 65536;
    @%p4 shr.u32 %r12, %r3, 4;
    min.s32 %r8, %r3, 8;
    mul.wide.u32 %rd7, %r12, %r11;
    max.s32 %r25, %r11, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
