.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    shr.u32 %r25, %r3, 1;
    shr.s32 %r15, %r25, 2;
    sub.s32 %r15, %r15, 255;
    or.b32 %r19, %r15, %r25;
    and.b64 %rd11, %rd12, %rd12;
    shr.s32 %r11, %r15, 0;
    or.b32 %r17, %r15, %r19;
    shr.s32 %r14, %r3, 30;
    mul.wide.s32 %rd15, %r15, %r11;
    and.b32 %r8, %r11, 31;
    shl.b32 %r26, %r14, 16;
    sub.s32 %r7, %r15, %r25;
    cvt.s32.s64 %r6, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
