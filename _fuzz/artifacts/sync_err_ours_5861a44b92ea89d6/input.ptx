.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r6, %r3, %r3;
    cvt.u64.u32 %rd8, %r3;
    shr.u64 %rd9, %rd8, 3;
    cvt.s32.s64 %r4, %rd9;
    sub.u64 %rd7, %rd8, %rd9;
    mul.lo.s32 %r26, %r4, %r4;
    sub.u32 %r22, %r3, %r3;
    max.u64 %rd5, %rd8, %rd7;
    add.s32 %r15, %r6, 64;
    add.s32 %r14, %r4, %r15;
    min.s32 %r24, %r3, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
