.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p2, %r3, %r3;
    @%p2 shr.u32 %r22, %r3, 30;
    setp.ne.s32 %p4, %r22, %r3;
    @%p4 cvt.s64.s32 %rd14, %r3;
    cvt.s32.s64 %r9, %rd14;
    max.u32 %r22, %r22, 15;
    mul.wide.s32 %rd12, %r9, %r22;
    cvt.s32.s64 %r18, %rd14;
    cvt.s32.s64 %r19, %rd14;
    shl.b64 %rd5, %rd14, 63;
    selp.b32 %r16, %r19, %r18, %p4;
    sub.u32 %r18, %r3, %r22;
    shr.s32 %r19, %r9, 1;
    and.b32 %r8, %r16, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
