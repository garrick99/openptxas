.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r18, %r3, 4294967295;
    max.u32 %r5, %r18, %r18;
    max.s32 %r12, %r18, %r5;
    max.s32 %r25, %r18, %r5;
    mad.lo.u32 %r7, %r12, %r25, %r3;
    shl.b32 %r11, %r18, 16;
    shr.s32 %r22, %r7, 4;
    cvt.u64.u32 %rd8, %r3;
    add.s32 %r23, %r18, %r11;
    mul.lo.u32 %r20, %r25, 2;
    cvt.s64.s32 %rd14, %r23;
    setp.le.s32 %p4, %r3, 31;
    selp.b32 %r26, %r7, %r18, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
