.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r4, %r3, 2;
    cvt.u64.u32 %rd8, %r4;
    min.u32 %r23, %r4, 64;
    min.s32 %r5, %r3, 1;
    setp.le.s32 %p3, %r5, %r23;
    setp.ls.u32 %p2, %r23, %r23;
    setp.le.u32 %p4, %r23, 2147483647;
    @%p4 shl.b32 %r13, %r5, 4;
    cvt.u64.u32 %rd13, %r3;
    min.u32 %r24, %r4, 8;
    mul.wide.u32 %rd13, %r24, %r13;
    xor.b32 %r27, %r24, %r3;
    mul.lo.s32 %r5, %r24, %r3;
    setp.gt.u32 %p1, %r5, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
