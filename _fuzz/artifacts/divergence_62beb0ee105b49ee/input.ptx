.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r9, %r3, %r3;
    setp.ne.u32 %p1, %r3, 255;
    @%p1 shr.s32 %r26, %r3, 31;
    min.s32 %r6, %r9, %r26;
    selp.b32 %r18, %r6, %r3, %p1;
    max.u32 %r13, %r26, %r18;
    max.s32 %r8, %r3, %r9;
    min.u32 %r7, %r9, 15;
    max.u32 %r13, %r7, %r13;
    setp.le.s32 %p2, %r9, %r6;
    @%p2 mul.lo.u32 %r14, %r8, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
