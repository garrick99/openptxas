.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r5, %r3, %r3;
    shl.b32 %r8, %r3, 0;
    mad.lo.u32 %r18, %r8, %r8, %r5;
    mul.wide.s32 %rd13, %r18, %r18;
    max.s32 %r16, %r18, 3;
    shr.s32 %r11, %r16, 3;
    and.b32 %r5, %r18, 2;
    max.s32 %r7, %r3, %r5;
    add.u32 %r6, %r11, %r11;
    shr.u32 %r25, %r8, 31;
    mul.lo.s32 %r5, %r8, %r6;
    shl.b32 %r4, %r8, 0;
    xor.b32 %r15, %r3, %r4;
    shr.s32 %r9, %r6, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
