.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r5, %r3, %r3;
    cvt.s64.s32 %rd11, %r3;
    setp.lt.u32 %p2, %r3, %r3;
    @!%p2 selp.b32 %r14, %r5, %r3, %p2;
    setp.gt.u32 %p1, %r5, 4294967295;
    @%p1 shr.u32 %r18, %r5, 0;
    cvt.u64.u32 %rd15, %r5;
    min.s64 %rd10, %rd15, %rd11;
    cvt.s32.s64 %r5, %rd15;
    cvt.s32.s64 %r7, %rd10;
    shr.u64 %rd14, %rd10, 0;
    shr.u32 %r8, %r14, 0;
    xor.b32 %r7, %r5, %r5;
    mul.lo.u32 %r13, %r7, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
