.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r20, %r3, 4294967295;
    min.u32 %r27, %r20, %r3;
    cvt.u64.u32 %rd12, %r3;
    min.u32 %r17, %r27, 64;
    mad.lo.s32 %r12, %r3, %r3, %r27;
    min.s32 %r26, %r17, %r17;
    max.u32 %r5, %r17, 255;
    cvt.s64.s32 %rd15, %r17;
    setp.le.u32 %p4, %r26, %r17;
    max.u32 %r12, %r27, %r3;
    setp.ge.s32 %p3, %r27, %r17;
    @%p3 mad.lo.s32 %r15, %r17, %r12, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
