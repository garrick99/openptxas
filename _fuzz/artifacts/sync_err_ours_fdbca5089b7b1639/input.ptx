.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r11, %r3, 31;
    cvt.s64.s32 %rd8, %r3;
    cvt.u32.u64 %r11, %rd8;
    shr.s32 %r9, %r3, 31;
    cvt.u32.u64 %r10, %rd8;
    cvt.u64.u32 %rd14, %r10;
    add.u32 %r9, %r9, %r11;
    shr.u32 %r8, %r9, 15;
    xor.b64 %rd8, %rd8, %rd14;
    mul.lo.s32 %r20, %r9, 8;
    min.u32 %r24, %r11, 32;
    or.b32 %r5, %r11, %r8;
    xor.b64 %rd5, %rd8, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
