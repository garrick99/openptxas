.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r21, %r3, 0;
    cvt.u64.u32 %rd5, %r21;
    shl.b32 %r26, %r3, 16;
    shl.b64 %rd14, %rd5, 1;
    mul.lo.u64 %rd8, %rd14, %rd5;
    shr.s32 %r22, %r3, 1;
    mul.lo.s32 %r20, %r22, 8;
    and.b32 %r7, %r3, %r20;
    and.b64 %rd5, %rd5, %rd5;
    or.b32 %r18, %r22, %r7;
    min.s32 %r5, %r7, 4294967295;
    min.u64 %rd5, %rd8, %rd14;
    mul.lo.s32 %r10, %r5, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
