.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p4, %r3, 65535;
    @%p4 sub.s32 %r13, %r3, %r3;
    shr.u32 %r21, %r13, 0;
    shr.u32 %r25, %r21, 4;
    cvt.u64.u32 %rd5, %r13;
    sub.s32 %r9, %r3, 4294967295;
    setp.lt.s32 %p2, %r13, 2147483647;
    and.b32 %r24, %r13, 255;
    mad.lo.u32 %r20, %r25, %r13, %r24;
    mul.lo.s32 %r12, %r25, 65536;
    add.s32 %r14, %r13, 65535;
    shr.s32 %r24, %r21, 4;
    shl.b32 %r18, %r21, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
