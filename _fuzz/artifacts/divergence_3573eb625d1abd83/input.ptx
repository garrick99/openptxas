.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    min.u32 %r24, %r3, 4294967295;
    shr.s64 %rd11, %rd8, 7;
    shr.s32 %r16, %r3, 15;
    cvt.u64.u32 %rd8, %r3;
    cvt.u32.u64 %r10, %rd11;
    setp.ne.s32 %p3, %r16, 3;
    @%p3 mul.wide.s32 %rd14, %r24, %r10;
    min.u32 %r12, %r16, %r3;
    shl.b32 %r26, %r24, 3;
    cvt.u64.u32 %rd13, %r26;
    setp.ge.s32 %p3, %r16, 2;
    setp.hi.u32 %p4, %r16, %r16;
    @%p4 selp.b32 %r18, %r16, %r26, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
