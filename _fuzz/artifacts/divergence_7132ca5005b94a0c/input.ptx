.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r7, %r3, %r3;
    mul.lo.s32 %r25, %r3, 65536;
    shr.u32 %r20, %r7, 15;
    mul.wide.s32 %rd7, %r7, %r20;
    shr.u32 %r4, %r3, 15;
    max.s32 %r23, %r7, 31;
    setp.lt.u32 %p4, %r3, %r20;
    @!%p4 min.s32 %r18, %r3, 4;
    xor.b64 %rd8, %rd7, %rd7;
    mul.wide.u32 %rd10, %r20, %r18;
    sub.s32 %r13, %r18, %r25;
    cvt.s64.s32 %rd11, %r20;
    shr.u64 %rd9, %rd7, 31;
    selp.b32 %r7, %r13, %r7, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
