.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r24, %r3, 2;
    setp.le.s32 %p3, %r3, 31;
    @%p3 mul.lo.u32 %r14, %r24, %r3;
    max.u32 %r13, %r14, %r24;
    mul.lo.s32 %r4, %r14, 16;
    sub.s32 %r7, %r24, %r4;
    and.b32 %r20, %r13, %r24;
    cvt.u64.u32 %rd15, %r3;
    cvt.s32.s64 %r20, %rd15;
    mad.lo.s32 %r18, %r7, %r14, %r4;
    max.s32 %r12, %r7, 65535;
    add.s64 %rd14, %rd15, %rd15;
    mul.lo.s32 %r26, %r13, %r14;
    or.b32 %r11, %r14, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
