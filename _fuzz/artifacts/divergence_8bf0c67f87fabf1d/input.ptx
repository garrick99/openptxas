.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r27, %r3, 31;
    setp.ge.u32 %p4, %r3, 255;
    @%p4 mul.lo.s32 %r14, %r27, 8;
    setp.eq.s32 %p3, %r3, %r14;
    @%p3 sub.u32 %r14, %r14, %r14;
    mul.wide.s32 %rd15, %r3, %r14;
    shl.b32 %r13, %r14, 4;
    min.u32 %r24, %r14, 16;
    cvt.u32.u64 %r6, %rd15;
    shr.u64 %rd8, %rd15, 47;
    setp.ne.u32 %p1, %r27, %r24;
    @%p1 mad.lo.s32 %r7, %r3, %r3, %r14;
    sub.s32 %r12, %r6, 65535;
    selp.b32 %r11, %r24, %r12, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
