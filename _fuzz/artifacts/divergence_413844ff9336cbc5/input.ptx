.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r11, %r3, %r3;
    shr.u32 %r26, %r11, 0;
    sub.u32 %r27, %r26, 1;
    setp.lo.u32 %p1, %r27, %r27;
    @!%p1 selp.b32 %r22, %r27, %r11, %p1;
    setp.eq.s32 %p3, %r26, 256;
    @!%p3 add.s32 %r17, %r22, 0;
    cvt.u64.u32 %rd11, %r26;
    shr.u32 %r15, %r22, 7;
    min.s32 %r7, %r17, 5;
    selp.b32 %r5, %r22, %r7, %p3;
    sub.s32 %r17, %r15, %r27;
    add.s32 %r23, %r15, %r22;
    and.b32 %r26, %r3, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
