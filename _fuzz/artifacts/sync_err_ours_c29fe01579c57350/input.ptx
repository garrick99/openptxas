.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r20, %r3, 255;
    cvt.s64.s32 %rd12, %r20;
    mad.lo.u32 %r20, %r20, %r20, %r20;
    cvt.s32.s64 %r27, %rd12;
    mul.lo.s64 %rd10, %rd12, %rd12;
    min.u32 %r26, %r20, 31;
    shl.b32 %r10, %r3, 7;
    mul.lo.s32 %r24, %r20, %r27;
    min.u32 %r16, %r27, %r20;
    shr.s32 %r27, %r24, 15;
    mad.lo.u32 %r4, %r27, %r27, %r24;
    cvt.s64.s32 %rd9, %r20;
    cvt.u32.u64 %r10, %rd10;
    mad.lo.s32 %r25, %r27, %r10, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
