.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r5, %r3, 7;
    mad.lo.u32 %r19, %r5, %r5, %r3;
    min.s32 %r5, %r19, %r5;
    min.u32 %r11, %r5, %r5;
    min.u32 %r21, %r11, 64;
    min.s32 %r25, %r3, %r5;
    shl.b32 %r27, %r3, 7;
    setp.ls.u32 %p1, %r25, %r11;
    @%p1 cvt.s64.s32 %rd5, %r11;
    mul.wide.u32 %rd11, %r3, %r19;
    shl.b64 %rd13, %rd5, 32;
    min.u32 %r27, %r11, %r27;
    and.b32 %r8, %r3, %r11;
    selp.b32 %r24, %r27, %r25, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
