.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r17, %r3, 16;
    mad.lo.s32 %r4, %r17, %r17, %r17;
    setp.lt.u32 %p1, %r4, 16;
    @!%p1 add.s32 %r22, %r4, %r4;
    and.b32 %r20, %r3, %r3;
    sub.s32 %r14, %r22, 5;
    cvt.u64.u32 %rd5, %r20;
    setp.ne.u32 %p4, %r17, 2147483648;
    min.u32 %r5, %r22, 3;
    add.u32 %r16, %r4, %r14;
    setp.lt.u32 %p3, %r22, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
