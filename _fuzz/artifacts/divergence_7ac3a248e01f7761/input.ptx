.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p1, %r3, %r3;
    setp.eq.s32 %p3, %r3, 63;
    @%p3 shr.s32 %r7, %r3, 31;
    mul.wide.s32 %rd6, %r3, %r7;
    mul.wide.u32 %rd8, %r7, %r7;
    mad.lo.s32 %r7, %r7, %r3, %r3;
    min.u32 %r4, %r3, 255;
    mul.lo.u32 %r16, %r4, %r3;
    shr.s64 %rd8, %rd6, 30;
    sub.u32 %r16, %r7, %r3;
    setp.ne.s32 %p1, %r7, 31;
    @%p1 shl.b64 %rd6, %rd6, 1;
    mul.lo.u32 %r12, %r7, %r16;
    add.u32 %r25, %r4, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
