.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r17, %r3, 7;
    mad.lo.s32 %r5, %r3, %r17, %r3;
    min.s32 %r15, %r17, %r5;
    shr.s32 %r9, %r3, 4;
    shr.s32 %r14, %r17, 15;
    shr.s32 %r27, %r17, 31;
    mul.wide.s32 %rd5, %r15, %r3;
    mul.lo.u32 %r26, %r9, 256;
    mad.lo.s32 %r12, %r9, %r5, %r17;
    shl.b32 %r23, %r27, 1;
    and.b32 %r22, %r23, 2;
    shl.b32 %r20, %r23, 15;
    and.b32 %r4, %r17, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
