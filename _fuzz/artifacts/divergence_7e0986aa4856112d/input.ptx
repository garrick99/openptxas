.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p2, %r3, %r3;
    @!%p2 add.u32 %r25, %r3, %r3;
    cvt.s64.s32 %rd6, %r3;
    sub.u64 %rd7, %rd6, %rd6;
    max.s32 %r20, %r25, 32;
    sub.s32 %r23, %r20, 15;
    mad.lo.u32 %r16, %r3, %r25, %r23;
    mul.lo.u32 %r11, %r16, %r20;
    setp.ne.u32 %p4, %r23, 1;
    @%p4 mad.lo.u32 %r4, %r25, %r23, %r11;
    shr.u64 %rd8, %rd7, 2;
    shl.b32 %r17, %r11, 30;
    shr.u64 %rd5, %rd7, 33;
    or.b32 %r10, %r25, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
