.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r13, %r3, 255;
    cvt.u64.u32 %rd7, %r3;
    or.b32 %r7, %r3, %r3;
    mad.lo.u32 %r4, %r13, %r3, %r13;
    cvt.u64.u32 %rd14, %r3;
    setp.eq.u32 %p2, %r3, 65535;
    @%p2 and.b32 %r10, %r7, 4;
    shl.b32 %r24, %r13, 3;
    and.b32 %r12, %r4, %r10;
    mul.wide.u32 %rd9, %r24, %r4;
    mul.wide.s32 %rd7, %r4, %r7;
    cvt.s32.s64 %r8, %rd7;
    selp.b32 %r6, %r24, %r10, %p2;
    add.u64 %rd9, %rd7, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
