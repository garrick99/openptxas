.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r17, %r3, 8;
    max.s32 %r13, %r17, %r3;
    sub.u32 %r15, %r13, 4;
    and.b32 %r23, %r13, 8;
    xor.b32 %r6, %r3, 63;
    max.s32 %r4, %r23, %r17;
    mad.lo.u32 %r21, %r3, %r13, %r4;
    shr.u32 %r8, %r17, 0;
    mul.lo.s32 %r16, %r21, %r8;
    xor.b32 %r27, %r4, %r17;
    add.u32 %r21, %r6, %r13;
    mul.wide.s32 %rd12, %r17, %r16;
    setp.eq.u32 %p3, %r17, 15;
    @%p3 max.s32 %r9, %r4, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
