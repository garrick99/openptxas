.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r23, %r3, 64;
    add.s32 %r18, %r3, 4294967295;
    sub.u32 %r8, %r18, 15;
    max.u32 %r11, %r18, %r3;
    min.s32 %r8, %r11, 15;
    max.u32 %r24, %r18, %r8;
    mul.lo.s32 %r8, %r24, %r18;
    cvt.s64.s32 %rd5, %r18;
    setp.lt.s32 %p4, %r3, 65535;
    @%p4 cvt.s32.s64 %r21, %rd5;
    xor.b32 %r17, %r3, 7;
    setp.lo.u32 %p3, %r21, 63;
    @%p3 sub.s32 %r27, %r24, %r18;
    cvt.u64.u32 %rd9, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
