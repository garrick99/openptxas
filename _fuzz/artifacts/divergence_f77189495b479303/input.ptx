.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r6, %r3, %r3;
    cvt.s64.s32 %rd10, %r6;
    xor.b64 %rd12, %rd10, %rd10;
    mul.lo.s32 %r26, %r3, 3;
    mul.wide.u32 %rd12, %r3, %r26;
    mul.wide.s32 %rd8, %r26, %r3;
    xor.b32 %r4, %r6, %r26;
    max.s32 %r5, %r3, 65535;
    shl.b32 %r25, %r6, 7;
    mad.lo.s32 %r24, %r5, %r25, %r4;
    max.s32 %r13, %r24, %r4;
    max.s32 %r11, %r25, 8;
    max.s32 %r16, %r5, %r13;
    shl.b64 %rd7, %rd10, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
