.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r7, %r3, %r3;
    cvt.u64.u32 %rd13, %r7;
    max.u32 %r9, %r7, 2;
    shl.b64 %rd8, %rd13, 2;
    shl.b32 %r15, %r9, 3;
    shr.s64 %rd13, %rd8, 3;
    sub.u64 %rd12, %rd8, %rd8;
    cvt.u32.u64 %r27, %rd12;
    mad.lo.u32 %r26, %r27, %r15, %r3;
    setp.ge.s32 %p3, %r7, 64;
    @%p3 mad.lo.u32 %r25, %r27, %r3, %r3;
    min.u32 %r23, %r25, %r25;
    sub.u32 %r14, %r9, %r25;
    shr.u64 %rd12, %rd8, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
