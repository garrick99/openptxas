.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r17, %r3, %r3;
    shfl.sync.bfly.b32 %r18, %r17, 16, 0x1f, -1;
    shfl.sync.up.b32 %r4, %r0, 4, 0x1f, -1;
    xor.b32 %r13, %r17, %r0;
    shfl.sync.bfly.b32 %r19, %r3, 2, 0x1f, -1;
    setp.le.u32 %p2, %r4, %r17;
    vote.sync.ballot.b32 %r14, %p2, -1;
    vote.sync.any.pred %p2, %p2, -1;
    min.u32 %r16, %r19, %r14;
    shfl.sync.down.b32 %r17, %r18, 8, 0x1f, -1;
    shfl.sync.idx.b32 %r16, %r3, 15, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
