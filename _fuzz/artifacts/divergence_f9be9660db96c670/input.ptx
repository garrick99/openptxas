.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r6, %r3, 16;
    setp.hi.u32 %p4, %r3, %r6;
    @%p4 or.b32 %r27, %r6, 5;
    setp.ls.u32 %p4, %r6, %r6;
    @%p4 selp.b32 %r16, %r6, %r27, %p4;
    cvt.u64.u32 %rd8, %r3;
    mul.lo.s32 %r23, %r16, %r16;
    cvt.s32.s64 %r16, %rd8;
    setp.gt.s32 %p1, %r23, 63;
    xor.b32 %r15, %r16, %r27;
    selp.b32 %r11, %r6, %r3, %p1;
    cvt.s64.s32 %rd8, %r27;
    mad.lo.u32 %r24, %r27, %r15, %r11;
    shr.s64 %rd15, %rd8, 33;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
