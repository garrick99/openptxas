.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p4, %r3, 4;
    @%p4 shr.s32 %r24, %r3, 7;
    add.s32 %r27, %r24, %r3;
    xor.b32 %r22, %r3, 3;
    cvt.s64.s32 %rd11, %r22;
    sub.u32 %r8, %r24, 8;
    sub.u32 %r11, %r8, %r22;
    add.u32 %r5, %r11, %r27;
    shr.u64 %rd15, %rd11, 2;
    and.b32 %r23, %r8, %r8;
    shr.u32 %r7, %r23, 4;
    add.s32 %r17, %r3, %r7;
    sub.s32 %r20, %r5, %r24;
    min.u32 %r25, %r23, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
