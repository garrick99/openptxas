.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r24, %r3, 31;
    shr.u32 %r17, %r24, 4;
    mul.wide.s32 %rd10, %r3, %r17;
    shr.u32 %r16, %r24, 2;
    mad.lo.u32 %r26, %r16, %r17, %r16;
    mad.lo.u32 %r19, %r3, %r16, %r3;
    setp.lo.u32 %p3, %r24, 65536;
    setp.lo.u32 %p3, %r3, %r19;
    and.b32 %r22, %r17, 7;
    add.u32 %r5, %r26, %r22;
    add.s32 %r19, %r26, %r17;
    mul.wide.s32 %rd10, %r24, %r26;
    sub.s32 %r26, %r19, %r24;
    min.s32 %r22, %r26, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
