.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    mul.wide.u32 %rd8, %r3, %r3;
    xor.b64 %rd10, %rd8, %rd7;
    min.u32 %r9, %r3, %r3;
    max.u32 %r17, %r9, 64;
    xor.b32 %r6, %r3, %r9;
    min.s32 %r27, %r9, %r3;
    sub.u32 %r11, %r27, %r6;
    min.s64 %rd14, %rd7, %rd8;
    max.u32 %r15, %r27, %r3;
    max.u64 %rd6, %rd7, %rd8;
    mul.lo.s32 %r8, %r9, %r6;
    and.b32 %r25, %r11, %r11;
    shr.u32 %r18, %r15, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
