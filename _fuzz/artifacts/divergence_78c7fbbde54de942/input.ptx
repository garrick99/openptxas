.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r7, %r3, 4294967295;
    mul.wide.s32 %rd10, %r3, %r7;
    or.b64 %rd13, %rd10, %rd10;
    shr.u64 %rd11, %rd13, 4;
    cvt.u64.u32 %rd5, %r7;
    min.s32 %r12, %r3, %r7;
    mul.wide.u32 %rd10, %r3, %r3;
    cvt.s32.s64 %r4, %rd11;
    sub.s64 %rd5, %rd13, %rd13;
    max.s32 %r16, %r4, %r3;
    sub.u32 %r11, %r4, 3;
    mad.lo.s32 %r14, %r12, %r16, %r3;
    and.b32 %r21, %r11, 32;
    cvt.u64.u32 %rd7, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
