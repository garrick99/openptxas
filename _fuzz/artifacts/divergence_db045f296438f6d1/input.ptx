.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r21, %r3, 2147483648;
    add.u32 %r5, %r21, 3;
    and.b32 %r12, %r5, 8;
    setp.le.s32 %p2, %r21, 7;
    @!%p2 mul.lo.s32 %r22, %r3, %r21;
    mad.lo.u32 %r16, %r12, %r22, %r12;
    max.u32 %r20, %r3, %r16;
    mul.lo.s32 %r15, %r5, %r5;
    shl.b32 %r7, %r22, 31;
    mul.wide.s32 %rd11, %r7, %r15;
    cvt.s64.s32 %rd8, %r5;
    mad.lo.s32 %r15, %r15, %r21, %r22;
    mul.wide.s32 %rd5, %r12, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
