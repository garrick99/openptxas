.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r20, %r3, %r3, %r3;
    max.s32 %r21, %r20, %r20;
    setp.gt.u32 %p1, %r21, %r21;
    @%p1 shr.u32 %r17, %r21, 30;
    mul.lo.u32 %r16, %r20, 31;
    max.s32 %r22, %r17, %r17;
    setp.ls.u32 %p3, %r22, 2147483648;
    cvt.u64.u32 %rd11, %r16;
    shr.u64 %rd15, %rd11, 63;
    shl.b32 %r13, %r17, 31;
    xor.b32 %r26, %r13, %r22;
    min.u32 %r17, %r21, %r3;
    sub.s32 %r20, %r13, 1;
    mul.wide.u32 %rd8, %r16, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
