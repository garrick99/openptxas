.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r17, %r3, %r3;
    cvt.u64.u32 %rd15, %r17;
    setp.eq.s32 %p4, %r3, 8;
    @%p4 shr.u32 %r21, %r3, 7;
    max.s32 %r14, %r21, %r3;
    add.s32 %r5, %r3, 1;
    selp.b32 %r16, %r5, %r5, %p4;
    mad.lo.u32 %r12, %r16, %r14, %r14;
    shr.s32 %r11, %r3, 1;
    sub.u32 %r10, %r14, 8;
    shl.b32 %r21, %r11, 3;
    min.u32 %r27, %r12, %r21;
    shl.b32 %r5, %r12, 30;
    shr.u64 %rd6, %rd15, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
