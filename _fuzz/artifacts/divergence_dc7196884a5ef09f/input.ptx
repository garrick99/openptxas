.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r5, %r3, %r3, %r3;
    mul.lo.u32 %r20, %r5, %r3;
    cvt.u64.u32 %rd11, %r5;
    add.s32 %r21, %r5, %r3;
    mul.lo.s64 %rd13, %rd11, %rd11;
    shl.b64 %rd10, %rd13, 48;
    add.s32 %r14, %r5, 7;
    mul.wide.u32 %rd6, %r5, %r20;
    shr.u32 %r19, %r3, 31;
    mad.lo.s32 %r20, %r14, %r5, %r3;
    shl.b64 %rd8, %rd10, 0;
    mul.lo.u32 %r15, %r19, 7;
    shl.b64 %rd12, %rd10, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
