.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r25, %r3, 15;
    mul.wide.s32 %rd12, %r3, %r3;
    cvt.s64.s32 %rd9, %r25;
    max.s32 %r16, %r25, %r25;
    min.s32 %r11, %r3, %r3;
    setp.gt.s32 %p1, %r11, 65535;
    setp.ge.s32 %p2, %r16, 3;
    @%p2 shr.u32 %r4, %r16, 30;
    and.b32 %r15, %r25, %r16;
    add.s64 %rd15, %rd12, %rd9;
    mul.wide.u32 %rd6, %r4, %r4;
    sub.u32 %r23, %r4, %r15;
    and.b64 %rd9, %rd15, %rd6;
    mul.lo.u32 %r8, %r25, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
