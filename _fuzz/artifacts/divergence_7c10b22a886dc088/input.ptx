.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r16, %r3, 4;
    mad.lo.s32 %r8, %r16, %r16, %r3;
    cvt.s64.s32 %rd6, %r16;
    cvt.u64.u32 %rd11, %r16;
    max.s64 %rd8, %rd6, %rd11;
    shr.s64 %rd9, %rd6, 16;
    mul.wide.u32 %rd11, %r16, %r8;
    xor.b32 %r21, %r16, %r8;
    min.u32 %r6, %r21, 32;
    cvt.s32.s64 %r9, %rd6;
    add.s32 %r23, %r8, %r3;
    setp.lt.s32 %p4, %r3, %r8;
    mad.lo.s32 %r11, %r6, %r16, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
