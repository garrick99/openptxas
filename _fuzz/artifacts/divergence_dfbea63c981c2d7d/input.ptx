.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p4, %r3, 3;
    @!%p4 xor.b32 %r7, %r3, %r3;
    mul.lo.s32 %r19, %r3, 5;
    and.b32 %r6, %r19, 2147483648;
    max.u32 %r6, %r7, %r6;
    max.s32 %r11, %r3, 31;
    shr.u32 %r11, %r11, 0;
    setp.eq.s32 %p2, %r7, 1;
    @%p2 cvt.s64.s32 %rd8, %r3;
    mul.lo.s32 %r5, %r3, 32;
    max.u64 %rd12, %rd8, %rd8;
    sub.s32 %r11, %r11, 8;
    mad.lo.s32 %r23, %r3, %r3, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
