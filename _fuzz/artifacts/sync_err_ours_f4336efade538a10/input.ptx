.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r22, %r3, 65536;
    sub.u32 %r5, %r3, 5;
    min.u32 %r10, %r5, %r3;
    add.u32 %r8, %r22, %r22;
    cvt.u64.u32 %rd15, %r5;
    sub.s32 %r16, %r3, %r22;
    cvt.u64.u32 %rd13, %r16;
    and.b64 %rd13, %rd13, %rd15;
    setp.le.u32 %p3, %r22, %r22;
    sub.u32 %r6, %r22, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
