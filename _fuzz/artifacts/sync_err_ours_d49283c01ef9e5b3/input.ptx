.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r11, %r3, %r3;
    cvt.u64.u32 %rd8, %r3;
    max.u32 %r27, %r3, 64;
    cvt.s32.s64 %r13, %rd8;
    sub.s32 %r12, %r27, 31;
    shl.b32 %r13, %r3, 2;
    mad.lo.u32 %r11, %r3, %r11, %r13;
    mul.lo.s32 %r7, %r13, 0;
    mul.wide.u32 %rd7, %r12, %r12;
    xor.b32 %r19, %r7, %r7;
    min.s32 %r6, %r13, %r7;
    add.s32 %r5, %r13, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
