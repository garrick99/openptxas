.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r11, %r3, 15;
    sub.s32 %r6, %r11, 65536;
    mad.lo.u32 %r11, %r3, %r11, %r3;
    cvt.s64.s32 %rd7, %r11;
    setp.gt.u32 %p1, %r3, 15;
    @!%p1 mul.wide.s32 %rd15, %r6, %r11;
    shr.u32 %r23, %r11, 2;
    min.s32 %r21, %r23, %r3;
    max.u32 %r8, %r11, 8;
    xor.b32 %r7, %r8, 0;
    mul.wide.s32 %rd12, %r3, %r8;
    min.u64 %rd9, %rd15, %rd7;
    shr.s32 %r25, %r7, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
