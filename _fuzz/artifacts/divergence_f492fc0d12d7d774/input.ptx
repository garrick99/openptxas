.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r4, %r3, %r3, %r3;
    mul.lo.u32 %r15, %r3, 1;
    cvt.u64.u32 %rd10, %r4;
    add.s32 %r20, %r15, %r4;
    or.b32 %r24, %r15, 63;
    setp.lo.u32 %p3, %r15, %r24;
    @!%p3 mad.lo.s32 %r15, %r20, %r20, %r4;
    and.b32 %r17, %r20, 4294967295;
    shr.u64 %rd11, %rd10, 2;
    setp.lo.u32 %p2, %r20, 32;
    @%p2 mad.lo.u32 %r15, %r4, %r15, %r4;
    cvt.s64.s32 %rd8, %r15;
    mul.lo.u64 %rd7, %rd11, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
