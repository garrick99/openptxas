.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r25, %r3, 0;
    cvt.s64.s32 %rd8, %r25;
    min.u32 %r13, %r25, %r25;
    cvt.s32.s64 %r16, %rd8;
    max.s32 %r22, %r16, %r25;
    cvt.s32.s64 %r12, %rd8;
    max.u32 %r24, %r3, 64;
    min.s32 %r19, %r16, 3;
    setp.ge.u32 %p2, %r22, %r25;
    @%p2 shr.s32 %r17, %r22, 30;
    add.u32 %r20, %r17, %r17;
    mul.lo.s64 %rd8, %rd8, %rd8;
    add.u32 %r20, %r16, %r20;
    shr.u32 %r12, %r19, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
