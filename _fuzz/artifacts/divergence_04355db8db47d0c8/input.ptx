.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r24, %r3, 1;
    min.u32 %r17, %r3, 4294967295;
    cvt.u64.u32 %rd9, %r24;
    mul.wide.u32 %rd11, %r3, %r17;
    shr.s32 %r26, %r17, 2;
    shr.s32 %r6, %r3, 31;
    cvt.u64.u32 %rd11, %r26;
    min.u32 %r18, %r6, 8;
    shr.u32 %r7, %r3, 31;
    sub.u32 %r18, %r24, %r7;
    add.s32 %r5, %r18, %r26;
    sub.s32 %r21, %r17, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
