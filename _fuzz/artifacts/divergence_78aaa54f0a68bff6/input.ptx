.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r12, %r3, 16;
    add.u32 %r11, %r12, %r3;
    mul.lo.s32 %r15, %r11, %r11;
    cvt.s64.s32 %rd5, %r3;
    setp.lt.u32 %p4, %r15, 256;
    shl.b64 %rd14, %rd5, 3;
    min.s64 %rd5, %rd5, %rd5;
    max.s64 %rd8, %rd5, %rd5;
    shl.b64 %rd13, %rd5, 48;
    shr.s32 %r4, %r11, 31;
    setp.ls.u32 %p2, %r3, 31;
    min.u32 %r25, %r4, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
