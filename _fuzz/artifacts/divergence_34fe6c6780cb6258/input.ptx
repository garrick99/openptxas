.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p2, %r3, %r3;
    @%p2 mad.lo.u32 %r16, %r3, %r3, %r3;
    sub.u32 %r17, %r16, %r3;
    selp.b32 %r17, %r3, %r16, %p2;
    or.b32 %r26, %r16, 31;
    sub.s32 %r26, %r17, 31;
    cvt.s64.s32 %rd7, %r16;
    setp.lt.s32 %p4, %r3, %r26;
    @!%p4 selp.b32 %r8, %r26, %r17, %p2;
    cvt.s32.s64 %r13, %rd7;
    or.b32 %r20, %r13, %r8;
    shr.u32 %r15, %r20, 4;
    min.u32 %r17, %r8, %r3;
    shr.s32 %r7, %r20, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
