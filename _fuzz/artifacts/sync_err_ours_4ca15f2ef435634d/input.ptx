.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r25, %r3, 7;
    sub.s32 %r17, %r25, 65536;
    mad.lo.s32 %r15, %r25, %r25, %r17;
    shr.s32 %r15, %r3, 3;
    min.u32 %r22, %r25, %r25;
    shr.s32 %r22, %r15, 16;
    setp.ne.s32 %p2, %r17, 255;
    @%p2 sub.s32 %r16, %r15, %r3;
    cvt.s64.s32 %rd8, %r16;
    and.b32 %r9, %r22, %r15;
    mul.lo.u32 %r16, %r22, 16;
    cvt.u64.u32 %rd14, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
