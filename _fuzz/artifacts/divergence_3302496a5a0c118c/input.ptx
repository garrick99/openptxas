.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r23, %r3, 4294967295;
    shl.b32 %r25, %r3, 7;
    shr.u32 %r25, %r25, 3;
    max.u32 %r19, %r25, 1;
    shr.u32 %r21, %r19, 2;
    cvt.s64.s32 %rd14, %r3;
    mad.lo.u32 %r10, %r19, %r25, %r25;
    setp.lt.u32 %p1, %r10, %r3;
    @%p1 sub.s32 %r12, %r23, 8;
    setp.ge.s32 %p4, %r12, 4;
    add.u32 %r9, %r10, 3;
    selp.b32 %r14, %r12, %r19, %p4;
    min.u64 %rd15, %rd14, %rd14;
    sub.u64 %rd14, %rd15, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
