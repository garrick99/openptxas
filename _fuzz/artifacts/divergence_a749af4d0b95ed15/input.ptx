.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hi.u32 %p3, %r3, %r3;
    @%p3 sub.u32 %r26, %r3, %r3;
    xor.b32 %r21, %r26, 256;
    cvt.u64.u32 %rd14, %r26;
    max.s32 %r17, %r21, 256;
    or.b32 %r10, %r17, 16;
    selp.b32 %r9, %r26, %r3, %p3;
    cvt.s64.s32 %rd14, %r21;
    shl.b32 %r5, %r10, 1;
    cvt.s64.s32 %rd8, %r21;
    shr.s64 %rd10, %rd14, 0;
    max.u32 %r13, %r10, 0;
    max.s32 %r7, %r26, %r9;
    sub.s64 %rd14, %rd14, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
