.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r18, %r3, 4;
    or.b32 %r24, %r18, %r18;
    xor.b32 %r27, %r18, 2147483647;
    setp.eq.u32 %p3, %r3, %r18;
    @%p3 selp.b32 %r12, %r3, %r24, %p3;
    cvt.u64.u32 %rd5, %r12;
    mul.lo.s32 %r12, %r18, %r12;
    or.b32 %r6, %r18, 4;
    add.u32 %r10, %r18, %r24;
    mad.lo.u32 %r5, %r24, %r6, %r27;
    selp.b32 %r13, %r27, %r3, %p3;
    shr.s64 %rd11, %rd5, 15;
    max.s64 %rd15, %rd5, %rd5;
    mul.wide.u32 %rd13, %r12, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
