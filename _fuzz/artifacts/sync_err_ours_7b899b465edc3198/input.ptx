.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    sub.u32 %r7, %r3, 16;
    and.b32 %r16, %r3, %r3;
    shr.u32 %r9, %r7, 0;
    mul.wide.u32 %rd11, %r16, %r3;
    add.s32 %r13, %r3, %r3;
    cvt.s32.s64 %r21, %rd11;
    setp.lo.u32 %p1, %r13, 65536;
    @%p1 or.b32 %r7, %r3, %r16;
    mad.lo.u32 %r17, %r9, %r16, %r21;
    shr.u64 %rd7, %rd15, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
