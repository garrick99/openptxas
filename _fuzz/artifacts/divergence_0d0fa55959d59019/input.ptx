.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r22, %r3, 65535;
    add.u32 %r13, %r3, %r22;
    max.s32 %r6, %r3, %r13;
    cvt.s64.s32 %rd12, %r13;
    setp.le.s32 %p1, %r22, %r13;
    xor.b32 %r23, %r22, 8;
    selp.b32 %r7, %r3, %r23, %p1;
    cvt.s32.s64 %r21, %rd12;
    max.u32 %r23, %r23, %r21;
    sub.s32 %r13, %r3, 15;
    mul.wide.s32 %rd9, %r13, %r7;
    cvt.s64.s32 %rd6, %r13;
    selp.b32 %r26, %r21, %r22, %p1;
    selp.b32 %r22, %r13, %r3, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
