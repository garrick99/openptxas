.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r10, %r3, 7;
    cvt.u64.u32 %rd10, %r3;
    and.b32 %r11, %r3, %r10;
    max.s32 %r9, %r3, %r11;
    setp.lt.s32 %p4, %r11, 65536;
    @%p4 min.u32 %r20, %r9, %r11;
    setp.gt.u32 %p4, %r3, %r9;
    @%p4 sub.s32 %r25, %r11, %r9;
    add.u32 %r5, %r11, %r25;
    shl.b32 %r22, %r20, 2;
    xor.b32 %r25, %r22, %r11;
    add.u32 %r7, %r11, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
