.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd15, %r3, %r3;
    and.b64 %rd6, %rd15, %rd15;
    and.b64 %rd10, %rd15, %rd6;
    shr.s32 %r16, %r3, 0;
    cvt.u32.u64 %r12, %rd6;
    mul.wide.u32 %rd10, %r3, %r16;
    add.u32 %r20, %r16, %r3;
    max.u32 %r8, %r20, %r3;
    max.s32 %r15, %r12, %r3;
    mul.wide.s32 %rd14, %r12, %r16;
    xor.b32 %r16, %r12, %r8;
    cvt.s32.s64 %r6, %rd15;
    mul.lo.u32 %r15, %r12, %r20;
    and.b32 %r6, %r20, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
