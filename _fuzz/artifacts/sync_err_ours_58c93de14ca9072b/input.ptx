.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r19, %r3, 16;
    mul.lo.s32 %r7, %r3, %r19;
    mul.wide.u32 %rd10, %r19, %r19;
    cvt.s32.s64 %r20, %rd10;
    min.s32 %r14, %r3, %r20;
    or.b32 %r16, %r14, 4294967295;
    mul.lo.s32 %r12, %r19, 8;
    sub.s32 %r23, %r7, %r14;
    mul.wide.s32 %rd7, %r20, %r20;
    shl.b64 %rd5, %rd10, 16;
    cvt.u32.u64 %r25, %rd7;
    sub.u32 %r7, %r19, 1;
    setp.gt.s32 %p3, %r16, 31;
    setp.gt.s32 %p3, %r16, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
