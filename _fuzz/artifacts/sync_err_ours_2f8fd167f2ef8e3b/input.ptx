.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r10, %r3, %r3, %r3;
    sub.s32 %r19, %r3, %r10;
    max.u32 %r11, %r19, 63;
    sub.s32 %r5, %r11, %r10;
    mul.lo.u32 %r5, %r3, %r19;
    setp.le.u32 %p3, %r19, 1;
    @%p3 sub.u32 %r23, %r3, %r19;
    max.s32 %r17, %r10, %r10;
    mul.lo.s32 %r12, %r17, 7;
    selp.b32 %r24, %r3, %r11, %p3;
    sub.s32 %r25, %r17, %r11;
    setp.ls.u32 %p1, %r17, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
