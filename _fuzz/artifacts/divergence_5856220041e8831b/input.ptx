.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p3, %r3, 4294967295;
    setp.eq.s32 %p1, %r3, 65535;
    @%p1 shr.s32 %r18, %r3, 31;
    mul.wide.s32 %rd10, %r18, %r18;
    min.u32 %r13, %r18, 255;
    cvt.u64.u32 %rd9, %r18;
    max.u32 %r13, %r18, 2147483647;
    mul.wide.u32 %rd12, %r3, %r18;
    or.b32 %r15, %r18, %r18;
    sub.u32 %r14, %r13, 2;
    sub.s32 %r16, %r13, 2147483647;
    sub.u64 %rd6, %rd10, %rd12;
    setp.lt.u32 %p4, %r3, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
