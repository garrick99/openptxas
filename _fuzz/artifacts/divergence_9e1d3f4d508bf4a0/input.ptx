.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    or.b32 %r23, %r3, 5;
    sub.u64 %rd8, %rd7, %rd7;
    shr.s64 %rd11, %rd7, 33;
    max.u32 %r22, %r23, %r3;
    max.s32 %r24, %r3, 256;
    cvt.s64.s32 %rd6, %r3;
    cvt.s64.s32 %rd15, %r22;
    shr.u32 %r12, %r22, 16;
    add.s32 %r14, %r24, 5;
    mul.wide.u32 %rd14, %r12, %r24;
    shr.u64 %rd14, %rd11, 32;
    max.u32 %r19, %r14, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
