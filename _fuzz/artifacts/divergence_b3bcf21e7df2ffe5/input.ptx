.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r26, %r3, 0;
    or.b32 %r5, %r3, 5;
    mul.wide.s32 %rd10, %r5, %r5;
    xor.b64 %rd8, %rd10, %rd10;
    xor.b32 %r6, %r5, %r5;
    setp.lt.u32 %p3, %r26, %r6;
    @%p3 sub.u32 %r17, %r5, %r6;
    xor.b32 %r23, %r6, %r6;
    cvt.s32.s64 %r20, %rd10;
    mul.wide.s32 %rd9, %r20, %r20;
    min.u64 %rd7, %rd10, %rd10;
    mad.lo.u32 %r22, %r26, %r6, %r17;
    sub.s32 %r20, %r23, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
