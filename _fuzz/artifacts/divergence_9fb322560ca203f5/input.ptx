.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r15, %r3, 15;
    mul.lo.s32 %r23, %r15, %r3;
    setp.eq.s32 %p3, %r3, %r3;
    @!%p3 selp.b32 %r10, %r15, %r15, %p3;
    setp.gt.u32 %p2, %r15, 2147483647;
    @%p2 or.b32 %r7, %r23, 256;
    mul.lo.u32 %r27, %r3, 31;
    cvt.s64.s32 %rd15, %r23;
    or.b32 %r17, %r23, %r7;
    cvt.s64.s32 %rd14, %r15;
    mul.wide.s32 %rd7, %r23, %r23;
    mul.wide.s32 %rd11, %r17, %r10;
    mad.lo.u32 %r26, %r15, %r3, %r3;
    min.u32 %r11, %r17, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
