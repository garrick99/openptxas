.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r21, %r3, %r3;
    cvt.s64.s32 %rd5, %r21;
    cvt.u32.u64 %r6, %rd5;
    setp.ls.u32 %p3, %r6, %r21;
    @!%p3 shr.s64 %rd9, %rd5, 62;
    min.u32 %r9, %r21, 3;
    or.b32 %r20, %r3, 0;
    add.s64 %rd8, %rd9, %rd9;
    add.u64 %rd13, %rd5, %rd5;
    mul.lo.s32 %r10, %r21, %r6;
    max.u32 %r19, %r6, %r20;
    sub.s32 %r11, %r9, %r6;
    mad.lo.s32 %r15, %r10, %r20, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
