.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r8, %r3, %r3, %r3;
    mul.lo.s32 %r13, %r3, 63;
    mad.lo.s32 %r9, %r8, %r8, %r3;
    shr.s32 %r22, %r8, 16;
    setp.ne.s32 %p2, %r22, 8;
    setp.lt.u32 %p1, %r8, 32;
    @%p1 min.u32 %r11, %r13, 255;
    setp.ls.u32 %p4, %r3, %r8;
    @%p4 min.u32 %r24, %r13, %r3;
    selp.b32 %r6, %r22, %r22, %p1;
    or.b32 %r8, %r24, 2147483648;
    cvt.s64.s32 %rd10, %r24;
    cvt.s64.s32 %rd14, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
