.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r21, %r3, 63;
    mul.lo.s32 %r21, %r3, 4294967295;
    and.b32 %r16, %r21, 4294967295;
    or.b32 %r17, %r21, %r3;
    or.b32 %r25, %r17, %r16;
    mul.wide.s32 %rd13, %r17, %r21;
    shl.b64 %rd6, %rd13, 1;
    mad.lo.s32 %r11, %r25, %r16, %r25;
    shl.b64 %rd14, %rd6, 3;
    shr.u32 %r11, %r11, 15;
    setp.lt.u32 %p3, %r11, 4;
    @!%p3 cvt.s64.s32 %rd9, %r25;
    selp.b32 %r21, %r3, %r17, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
