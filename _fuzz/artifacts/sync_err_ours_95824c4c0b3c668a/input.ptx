.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    cvt.u64.u32 %rd7, %r3;
    cvt.u32.u64 %r19, %rd7;
    mad.lo.s32 %r27, %r3, %r3, %r3;
    xor.b32 %r22, %r27, %r3;
    cvt.s64.s32 %rd7, %r3;
    min.u32 %r10, %r19, 2147483648;
    shr.s64 %rd7, %rd8, 15;
    and.b32 %r14, %r27, %r10;
    setp.ne.s32 %p3, %r19, 4294967295;
    @!%p3 or.b32 %r6, %r19, 255;
    setp.gt.u32 %p2, %r22, 1;
    @%p2 cvt.s64.s32 %rd8, %r22;
    cvt.u32.u64 %r15, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
