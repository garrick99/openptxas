.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p2, %r3, %r3;
    shr.s32 %r13, %r3, 7;
    min.s32 %r17, %r3, 31;
    shr.u32 %r20, %r17, 0;
    mul.wide.s32 %rd14, %r17, %r13;
    shr.u32 %r11, %r20, 0;
    shl.b32 %r24, %r3, 7;
    mul.wide.s32 %rd15, %r20, %r24;
    setp.gt.s32 %p2, %r13, 4;
    sub.s32 %r8, %r24, 1;
    cvt.u32.u64 %r13, %rd15;
    mul.wide.s32 %rd12, %r13, %r17;
    sub.u32 %r13, %r11, 4294967295;
    setp.gt.s32 %p1, %r13, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
