.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    mad.lo.u32 %r22, %r3, %r3, %r3;
    mul.lo.s32 %r8, %r22, 32;
    shl.b64 %rd10, %rd8, 32;
    max.u32 %r19, %r22, 65535;
    max.s32 %r5, %r22, 7;
    shr.u32 %r16, %r5, 2;
    mul.wide.s32 %rd14, %r19, %r19;
    mad.lo.s32 %r5, %r8, %r3, %r16;
    shr.s32 %r12, %r8, 30;
    mul.wide.s32 %rd8, %r22, %r8;
    mul.lo.u64 %rd5, %rd10, %rd14;
    setp.ne.s32 %p4, %r16, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
