.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r20, %r3, 32;
    mad.lo.u32 %r8, %r3, %r3, %r20;
    setp.ge.s32 %p3, %r20, 256;
    @%p3 cvt.s64.s32 %rd5, %r8;
    mul.wide.u32 %rd15, %r8, %r8;
    selp.b32 %r5, %r20, %r8, %p3;
    mul.wide.s32 %rd15, %r8, %r3;
    cvt.u32.u64 %r6, %rd5;
    shl.b64 %rd6, %rd5, 30;
    shr.u64 %rd10, %rd15, 48;
    mul.wide.s32 %rd12, %r6, %r20;
    or.b32 %r15, %r5, %r3;
    or.b32 %r20, %r15, %r6;
    shr.s64 %rd11, %rd10, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
