.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r24, %r3, 3;
    mad.lo.s32 %r4, %r3, %r24, %r24;
    add.s32 %r15, %r4, 0;
    shr.s32 %r24, %r3, 0;
    shr.s32 %r25, %r3, 15;
    setp.le.s32 %p4, %r25, 2;
    and.b32 %r21, %r15, 2147483648;
    sub.s32 %r6, %r15, 16;
    min.s32 %r13, %r4, %r25;
    shr.s32 %r11, %r3, 15;
    cvt.s64.s32 %rd11, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
