.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd5, %r3, %r3;
    min.u64 %rd11, %rd5, %rd5;
    or.b32 %r17, %r3, 4;
    add.s64 %rd13, %rd11, %rd11;
    add.s32 %r26, %r3, %r3;
    sub.s32 %r21, %r3, 1;
    cvt.s64.s32 %rd11, %r3;
    mul.wide.s32 %rd10, %r26, %r26;
    and.b32 %r26, %r17, %r26;
    setp.hs.u32 %p3, %r21, %r26;
    @%p3 and.b32 %r5, %r3, 0;
    max.s32 %r18, %r17, %r3;
    min.s32 %r24, %r21, %r18;
    shr.u32 %r18, %r21, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
