.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    shr.s32 %r9, %r3, 4;
    xor.b32 %r10, %r9, 65536;
    shr.s32 %r19, %r10, 7;
    setp.gt.s32 %p1, %r3, 2147483648;
    mul.wide.u32 %rd15, %r9, %r19;
    setp.eq.s32 %p2, %r10, 15;
    @%p2 min.u32 %r12, %r10, 1;
    max.s64 %rd6, %rd15, %rd15;
    selp.b32 %r16, %r9, %r10, %p1;
    sub.u32 %r26, %r16, 31;
    and.b32 %r19, %r3, 31;
    cvt.s32.s64 %r10, %rd6;
    shl.b64 %rd11, %rd15, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
