.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    mul.lo.s32 %r11, %r3, 65536;
    setp.lt.u32 %p1, %r11, %r3;
    @%p1 add.s64 %rd8, %rd5, %rd5;
    min.u32 %r6, %r11, %r11;
    mul.wide.s32 %rd10, %r6, %r3;
    shr.u64 %rd8, %rd8, 33;
    mul.wide.u32 %rd6, %r11, %r11;
    selp.b32 %r8, %r3, %r3, %p1;
    shl.b64 %rd11, %rd8, 2;
    selp.b32 %r15, %r6, %r11, %p1;
    selp.b32 %r11, %r15, %r6, %p1;
    mul.wide.s32 %rd9, %r6, %r6;
    mad.lo.u32 %r23, %r6, %r6, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
