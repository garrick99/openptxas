.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r24, %r3, %r3;
    shr.u32 %r5, %r24, 4;
    mul.lo.u32 %r16, %r3, %r5;
    add.s32 %r11, %r3, %r5;
    setp.ge.s32 %p3, %r24, 16;
    setp.eq.u32 %p4, %r16, %r11;
    @%p4 mul.lo.s32 %r18, %r3, %r16;
    cvt.u64.u32 %rd13, %r16;
    sub.s64 %rd10, %rd13, %rd13;
    mul.wide.u32 %rd10, %r11, %r16;
    shr.s32 %r12, %r18, 0;
    max.u32 %r11, %r16, 64;
    and.b32 %r16, %r16, %r5;
    add.u32 %r6, %r12, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
