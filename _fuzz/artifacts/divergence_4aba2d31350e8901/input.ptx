.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r20, %r3, %r3;
    mad.lo.s32 %r19, %r3, %r3, %r20;
    cvt.u64.u32 %rd9, %r19;
    and.b64 %rd8, %rd9, %rd9;
    setp.gt.u32 %p3, %r20, %r20;
    @%p3 min.s32 %r12, %r20, %r3;
    max.u32 %r23, %r19, %r12;
    mul.lo.s32 %r8, %r19, %r3;
    selp.b32 %r12, %r3, %r8, %p3;
    mul.lo.u32 %r26, %r19, 31;
    or.b32 %r19, %r23, 5;
    and.b32 %r6, %r20, 4294967295;
    min.s32 %r19, %r23, 4;
    shr.u32 %r22, %r23, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
