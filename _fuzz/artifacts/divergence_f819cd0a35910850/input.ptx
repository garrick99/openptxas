.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r4, %r3, 31;
    add.u32 %r22, %r4, 255;
    add.u32 %r15, %r22, %r3;
    max.u32 %r9, %r22, %r4;
    sub.s32 %r13, %r15, 8;
    mul.lo.u32 %r22, %r3, 8;
    cvt.u64.u32 %rd14, %r22;
    mul.wide.s32 %rd11, %r3, %r22;
    shl.b64 %rd15, %rd14, 16;
    shr.s32 %r22, %r13, 30;
    add.s32 %r25, %r15, 64;
    max.s32 %r13, %r22, %r22;
    mul.wide.u32 %rd11, %r9, %r13;
    mul.lo.u32 %r10, %r9, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
