.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p4, %r3, 8;
    setp.eq.u32 %p2, %r3, 16;
    @%p2 mul.wide.u32 %rd7, %r3, %r3;
    cvt.u32.u64 %r10, %rd7;
    shr.s32 %r14, %r3, 2;
    shr.s64 %rd15, %rd7, 2;
    or.b32 %r7, %r14, %r10;
    sub.s32 %r7, %r3, %r7;
    sub.u64 %rd12, %rd15, %rd7;
    setp.ne.s32 %p2, %r7, %r14;
    @!%p2 min.u32 %r11, %r10, %r7;
    add.s64 %rd13, %rd12, %rd12;
    cvt.u64.u32 %rd13, %r14;
    sub.s32 %r26, %r10, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
