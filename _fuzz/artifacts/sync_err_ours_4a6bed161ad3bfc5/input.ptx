.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r5, %r3, 2;
    mul.lo.u32 %r21, %r5, %r3;
    shr.u32 %r26, %r3, 2;
    shr.u32 %r16, %r21, 0;
    mul.lo.s32 %r9, %r26, %r26;
    setp.ne.s32 %p4, %r16, 256;
    @%p4 mul.wide.s32 %rd8, %r3, %r5;
    mul.lo.s32 %r4, %r3, %r26;
    mul.wide.u32 %rd12, %r9, %r5;
    and.b32 %r7, %r21, 2147483648;
    min.u64 %rd12, %rd12, %rd8;
    cvt.s32.s64 %r8, %rd12;
    add.u64 %rd9, %rd8, %rd12;
    mul.lo.u32 %r14, %r3, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
