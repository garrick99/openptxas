.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p1, %r3, 255;
    setp.lt.u32 %p3, %r3, 32;
    shr.u32 %r7, %r3, 15;
    sub.u32 %r23, %r3, %r3;
    shr.u32 %r22, %r23, 7;
    mul.lo.s32 %r25, %r22, %r7;
    add.s32 %r11, %r3, %r25;
    sub.s32 %r26, %r22, 4;
    min.u32 %r9, %r23, %r3;
    selp.b32 %r25, %r25, %r11, %p1;
    mul.lo.u32 %r7, %r25, 63;
    max.u32 %r16, %r26, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
