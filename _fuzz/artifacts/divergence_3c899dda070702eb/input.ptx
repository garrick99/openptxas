.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    max.s32 %r22, %r3, %r3;
    shr.s32 %r22, %r3, 2;
    shr.u64 %rd10, %rd10, 62;
    mad.lo.u32 %r5, %r22, %r22, %r22;
    add.u64 %rd12, %rd10, %rd10;
    mad.lo.u32 %r8, %r5, %r3, %r22;
    add.s32 %r21, %r5, %r22;
    max.s32 %r21, %r3, %r5;
    sub.u64 %rd5, %rd12, %rd12;
    xor.b32 %r27, %r3, %r8;
    cvt.u32.u64 %r16, %rd12;
    setp.le.s32 %p3, %r27, 63;
    @%p3 xor.b32 %r11, %r22, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
