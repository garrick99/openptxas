.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r22, %r3, 64;
    cvt.s64.s32 %rd14, %r3;
    sub.s64 %rd15, %rd14, %rd14;
    setp.ls.u32 %p4, %r3, 31;
    @%p4 or.b32 %r15, %r22, 31;
    mul.lo.s32 %r18, %r3, 32;
    cvt.s32.s64 %r9, %rd15;
    cvt.u32.u64 %r19, %rd15;
    shr.u64 %rd13, %rd15, 16;
    sub.s32 %r11, %r3, 3;
    sub.s32 %r24, %r18, 15;
    cvt.s32.s64 %r19, %rd13;
    xor.b32 %r21, %r19, %r11;
    max.u32 %r20, %r22, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
