.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd8, %r3, %r3;
    add.s32 %r10, %r3, 65536;
    shr.s32 %r27, %r3, 0;
    max.s32 %r21, %r10, %r27;
    shr.s64 %rd14, %rd8, 0;
    mul.lo.u32 %r7, %r3, 4294967295;
    shr.u32 %r19, %r27, 16;
    setp.ne.s32 %p1, %r7, %r7;
    @!%p1 shr.s32 %r9, %r27, 2;
    shr.u64 %rd13, %rd14, 30;
    setp.ge.s32 %p2, %r27, 256;
    @%p2 cvt.s32.s64 %r25, %rd13;
    min.s32 %r10, %r25, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
