.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r21, %r3, %r3;
    and.b32 %r14, %r3, 2147483648;
    cvt.u64.u32 %rd8, %r14;
    mul.wide.u32 %rd6, %r3, %r14;
    add.u32 %r14, %r3, %r21;
    min.s32 %r26, %r3, 65535;
    cvt.s64.s32 %rd7, %r14;
    setp.hi.u32 %p2, %r26, 5;
    setp.lo.u32 %p1, %r14, 15;
    shl.b64 %rd8, %rd7, 48;
    sub.s32 %r24, %r21, %r3;
    mul.wide.u32 %rd13, %r14, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
