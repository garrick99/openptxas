.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r7, %r3, 65535;
    cvt.s64.s32 %rd8, %r3;
    shr.u32 %r16, %r7, 30;
    min.s64 %rd9, %rd8, %rd8;
    sub.s32 %r18, %r7, 31;
    mul.lo.s32 %r16, %r18, %r16;
    mul.wide.s32 %rd6, %r3, %r7;
    max.u32 %r26, %r3, 64;
    shr.s32 %r23, %r7, 0;
    mul.wide.s32 %rd10, %r18, %r7;
    add.u32 %r5, %r26, %r18;
    or.b32 %r22, %r23, %r23;
    or.b32 %r25, %r26, %r18;
    shr.u64 %rd7, %rd8, 33;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
