.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    shr.s32 %r21, %r3, 30;
    shl.b64 %rd5, %rd9, 30;
    sub.u32 %r16, %r3, %r21;
    shl.b64 %rd14, %rd5, 3;
    max.u32 %r25, %r3, %r3;
    shl.b64 %rd11, %rd9, 63;
    mul.lo.s64 %rd13, %rd11, %rd14;
    shl.b32 %r6, %r25, 3;
    setp.gt.u32 %p1, %r16, 15;
    @%p1 add.s64 %rd13, %rd9, %rd5;
    mad.lo.u32 %r17, %r21, %r6, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
