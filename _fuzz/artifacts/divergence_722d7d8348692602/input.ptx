.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r27, %r3, 7;
    setp.ne.s32 %p4, %r3, %r3;
    @%p4 mul.lo.u32 %r10, %r3, 4;
    setp.eq.s32 %p1, %r10, 2;
    @!%p1 cvt.s64.s32 %rd11, %r10;
    sub.u32 %r17, %r3, %r3;
    xor.b32 %r26, %r17, %r10;
    sub.s32 %r26, %r10, 15;
    mul.lo.u32 %r6, %r10, 32;
    shl.b32 %r14, %r27, 31;
    min.s32 %r6, %r6, 2;
    and.b64 %rd8, %rd11, %rd11;
    max.s32 %r8, %r17, 64;
    cvt.s32.s64 %r19, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
