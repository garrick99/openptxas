.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r27, %r3, 0;
    sub.s32 %r26, %r27, %r27;
    cvt.s64.s32 %rd12, %r27;
    max.s32 %r21, %r3, 4294967295;
    sub.u32 %r24, %r27, 255;
    cvt.u64.u32 %rd5, %r27;
    shr.s32 %r13, %r24, 15;
    add.u32 %r14, %r13, %r3;
    shr.u32 %r7, %r3, 3;
    shr.u64 %rd5, %rd12, 30;
    shr.u32 %r4, %r7, 30;
    sub.u32 %r5, %r3, 2147483647;
    shr.s64 %rd7, %rd5, 0;
    max.s32 %r5, %r7, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
