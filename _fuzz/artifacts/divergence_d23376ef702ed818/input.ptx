.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd13, %r3, %r3;
    min.s32 %r14, %r3, 2;
    mul.lo.u64 %rd6, %rd13, %rd13;
    shl.b32 %r12, %r14, 3;
    shr.s32 %r10, %r12, 30;
    mad.lo.s32 %r26, %r10, %r3, %r14;
    cvt.s64.s32 %rd15, %r26;
    mul.lo.s32 %r18, %r14, 32;
    mad.lo.s32 %r13, %r10, %r3, %r10;
    sub.u32 %r26, %r14, 4;
    setp.hi.u32 %p2, %r18, 4;
    @!%p2 min.s32 %r5, %r10, %r13;
    or.b32 %r13, %r5, 8;
    max.u32 %r20, %r5, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
