    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p2, %r3, %r3;
    @%p2 mul.wide.s32 %rd11, %r3, %r3;
    setp.le.u32 %p3, %r3, 2147483648;
    @%p3 max.s32 %r4, %r3, %r3;
    shl.b32 %r24, %r3, 4;
    shr.s32 %r27, %r24, 4;
    cvt.u32.u64 %r26, %rd11;
    sub.u32 %r6, %r27, %r3;
    shr.s32 %r22, %r6, 15;
    sub.u32 %r19, %r6, %r26;
    and.b32 %r16, %r24, %r6;
    shr.s64 %rd5, %rd11, 0;
    setp.le.u32 %p4, %r22, %r16;
    @%p4 cvt.s32.s64 %r27, %rd11;
