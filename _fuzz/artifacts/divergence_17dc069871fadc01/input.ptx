.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    shr.s32 %r9, %r3, 16;
    mul.lo.s32 %r5, %r9, 63;
    min.s32 %r24, %r9, %r5;
    mul.lo.u64 %rd5, %rd15, %rd15;
    mad.lo.u32 %r19, %r5, %r5, %r3;
    or.b32 %r10, %r24, %r19;
    mad.lo.s32 %r9, %r19, %r3, %r10;
    xor.b64 %rd15, %rd5, %rd5;
    mul.wide.s32 %rd6, %r3, %r9;
    setp.hi.u32 %p1, %r3, %r3;
    @%p1 and.b32 %r5, %r9, 4;
    shl.b64 %rd11, %rd15, 63;
    mul.wide.s32 %rd15, %r9, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
