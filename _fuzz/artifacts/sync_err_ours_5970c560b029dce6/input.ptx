.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd8, %r3, %r3;
    shr.u32 %r13, %r3, 15;
    setp.gt.s32 %p2, %r3, %r3;
    shl.b32 %r18, %r13, 30;
    sub.u32 %r18, %r13, 63;
    or.b32 %r17, %r3, 32;
    cvt.s64.s32 %rd12, %r18;
    shr.s64 %rd7, %rd8, 32;
    cvt.s32.s64 %r13, %rd7;
    min.u32 %r26, %r3, 63;
    mad.lo.s32 %r19, %r17, %r13, %r3;
    min.u32 %r26, %r19, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
