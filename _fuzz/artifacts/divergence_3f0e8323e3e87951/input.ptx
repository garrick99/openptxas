.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r7, %r3, 1;
    shr.u32 %r13, %r3, 3;
    cvt.s64.s32 %rd15, %r7;
    shl.b32 %r5, %r3, 2;
    shl.b64 %rd8, %rd15, 31;
    mul.lo.s32 %r26, %r3, %r13;
    sub.u32 %r14, %r26, 63;
    mul.lo.u32 %r9, %r13, 16;
    mul.wide.s32 %rd13, %r3, %r9;
    min.u32 %r18, %r7, 5;
    shl.b64 %rd7, %rd15, 32;
    shr.s32 %r26, %r14, 30;
    mul.lo.u32 %r5, %r9, %r14;
    cvt.s64.s32 %rd15, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
