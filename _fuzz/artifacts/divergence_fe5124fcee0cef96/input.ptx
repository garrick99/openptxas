.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r14, %r3, %r3;
    setp.le.s32 %p2, %r3, 65536;
    @!%p2 sub.u32 %r4, %r14, %r14;
    mad.lo.u32 %r6, %r4, %r3, %r4;
    cvt.s64.s32 %rd12, %r4;
    mad.lo.u32 %r25, %r3, %r14, %r3;
    setp.gt.s32 %p3, %r14, 4294967295;
    @%p3 min.s32 %r4, %r14, %r14;
    mul.wide.u32 %rd8, %r4, %r3;
    and.b32 %r24, %r3, 63;
    add.u32 %r13, %r3, 64;
    add.s32 %r27, %r24, %r24;
    cvt.s32.s64 %r11, %rd12;
    shr.s64 %rd11, %rd8, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
