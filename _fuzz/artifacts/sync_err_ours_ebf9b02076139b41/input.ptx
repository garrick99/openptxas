.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    mul.lo.s32 %r27, %r3, 16;
    min.s32 %r24, %r3, 2147483648;
    max.u64 %rd5, %rd9, %rd9;
    add.s32 %r15, %r24, 4294967295;
    cvt.u64.u32 %rd9, %r3;
    min.s32 %r8, %r15, %r24;
    sub.u32 %r8, %r24, %r27;
    shr.u32 %r17, %r3, 2;
    max.u32 %r18, %r15, %r3;
    and.b64 %rd11, %rd5, %rd9;
    sub.u32 %r18, %r27, 64;
    cvt.u64.u32 %rd6, %r17;
    sub.s32 %r24, %r17, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
