.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    setp.le.s32 %p4, %r3, %r3;
    @!%p4 or.b64 %rd6, %rd12, %rd12;
    or.b32 %r7, %r3, %r3;
    selp.b32 %r24, %r7, %r3, %p4;
    mul.lo.s32 %r10, %r24, 7;
    max.s64 %rd9, %rd12, %rd6;
    xor.b32 %r25, %r7, %r3;
    cvt.s64.s32 %rd14, %r25;
    cvt.u32.u64 %r20, %rd12;
    sub.u32 %r11, %r3, 0;
    sub.u32 %r12, %r11, %r11;
    mul.wide.s32 %rd7, %r10, %r25;
    max.u32 %r18, %r7, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
