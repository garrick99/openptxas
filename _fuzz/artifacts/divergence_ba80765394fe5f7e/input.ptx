.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd5, %r3, %r3;
    cvt.s64.s32 %rd15, %r3;
    add.u32 %r6, %r3, %r3;
    shr.u64 %rd15, %rd15, 15;
    mul.lo.s32 %r26, %r6, 0;
    mul.wide.s32 %rd10, %r3, %r3;
    max.s32 %r23, %r6, %r26;
    mul.wide.s32 %rd7, %r3, %r6;
    shl.b64 %rd14, %rd5, 62;
    min.s32 %r4, %r3, 0;
    shl.b32 %r25, %r26, 7;
    or.b32 %r21, %r6, 7;
    mul.lo.u32 %r9, %r21, 32;
    or.b32 %r6, %r23, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
