.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r18, %r3, %r3;
    cvt.s64.s32 %rd12, %r3;
    shl.b64 %rd13, %rd12, 33;
    cvt.u32.u64 %r12, %rd12;
    mul.wide.s32 %rd5, %r12, %r12;
    mul.wide.u32 %rd14, %r12, %r18;
    mad.lo.s32 %r8, %r12, %r18, %r18;
    cvt.u32.u64 %r12, %rd12;
    sub.s32 %r24, %r12, 0;
    setp.ne.u32 %p4, %r12, 7;
    shr.u64 %rd13, %rd13, 63;
    mul.wide.u32 %rd14, %r24, %r8;
    or.b32 %r10, %r18, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
