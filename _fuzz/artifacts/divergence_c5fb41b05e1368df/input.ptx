.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    shr.s64 %rd10, %rd13, 31;
    mad.lo.u32 %r6, %r3, %r3, %r3;
    mul.wide.s32 %rd11, %r6, %r3;
    sub.s64 %rd7, %rd11, %rd13;
    cvt.u64.u32 %rd12, %r6;
    mul.wide.s32 %rd6, %r3, %r6;
    mul.lo.u32 %r27, %r6, %r3;
    and.b32 %r23, %r27, 32;
    add.s32 %r19, %r6, %r6;
    shr.s64 %rd10, %rd12, 32;
    mul.lo.s64 %rd11, %rd13, %rd13;
    shl.b64 %rd5, %rd12, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
