.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r14, %r3, %r3, %r3;
    setp.gt.s32 %p2, %r3, 256;
    @%p2 selp.b32 %r6, %r3, %r14, %p2;
    add.s32 %r25, %r14, 4294967295;
    cvt.s64.s32 %rd11, %r3;
    shr.s32 %r18, %r14, 16;
    sub.s32 %r24, %r14, %r18;
    selp.b32 %r22, %r24, %r18, %p2;
    mul.lo.u64 %rd5, %rd11, %rd11;
    mad.lo.u32 %r6, %r3, %r22, %r24;
    mul.lo.u32 %r8, %r18, 31;
    mad.lo.s32 %r4, %r24, %r3, %r25;
    mad.lo.u32 %r19, %r22, %r3, %r4;
    setp.eq.s32 %p4, %r25, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
