.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    setp.ne.s32 %p1, %r3, %r3;
    @%p1 max.u32 %r10, %r3, %r3;
    cvt.s32.s64 %r4, %rd6;
    add.u32 %r27, %r4, %r3;
    xor.b32 %r15, %r27, 3;
    shr.u32 %r5, %r3, 4;
    cvt.u64.u32 %rd5, %r4;
    add.u64 %rd14, %rd5, %rd6;
    mul.wide.s32 %rd13, %r15, %r10;
    xor.b32 %r16, %r10, %r10;
    sub.u32 %r13, %r15, 65535;
    shr.u32 %r24, %r4, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
