.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r12, %r3, 65535;
    cvt.s64.s32 %rd14, %r12;
    min.u32 %r19, %r12, 63;
    xor.b32 %r25, %r19, %r3;
    cvt.u32.u64 %r26, %rd14;
    cvt.s32.s64 %r16, %rd14;
    add.s32 %r15, %r3, %r12;
    and.b32 %r5, %r12, %r26;
    shr.u32 %r8, %r3, 15;
    shl.b64 %rd11, %rd14, 33;
    add.u32 %r11, %r15, %r16;
    xor.b32 %r26, %r5, %r12;
    mad.lo.u32 %r24, %r19, %r8, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
