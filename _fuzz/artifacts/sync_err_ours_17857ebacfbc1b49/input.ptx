.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    shl.b32 %r26, %r3, 7;
    shr.s64 %rd7, %rd14, 15;
    cvt.u64.u32 %rd9, %r26;
    max.s32 %r9, %r3, %r26;
    add.s32 %r21, %r3, %r3;
    mul.lo.u32 %r12, %r21, %r3;
    xor.b32 %r18, %r3, 32;
    sub.u32 %r26, %r21, %r21;
    shr.s32 %r18, %r9, 2;
    mul.wide.u32 %rd6, %r12, %r21;
    mul.lo.s32 %r6, %r9, %r18;
    shr.u32 %r15, %r12, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
