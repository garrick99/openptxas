.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd7, %r3, %r3;
    and.b32 %r4, %r3, %r3;
    cvt.s32.s64 %r9, %rd7;
    sub.s32 %r11, %r3, 255;
    add.u32 %r27, %r9, %r4;
    setp.eq.s32 %p4, %r9, 0;
    @%p4 mul.lo.s32 %r4, %r3, %r9;
    shl.b32 %r9, %r27, 30;
    mad.lo.u32 %r12, %r11, %r11, %r11;
    shl.b64 %rd8, %rd7, 1;
    or.b32 %r18, %r11, %r12;
    min.u32 %r5, %r9, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
