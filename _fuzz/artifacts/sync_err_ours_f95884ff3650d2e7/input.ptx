.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    max.s64 %rd15, %rd11, %rd11;
    shr.s32 %r13, %r3, 30;
    add.u32 %r11, %r3, %r3;
    max.s32 %r24, %r3, 65535;
    mad.lo.u32 %r22, %r13, %r13, %r13;
    sub.u32 %r14, %r13, %r11;
    add.s32 %r9, %r11, 255;
    and.b32 %r27, %r3, %r22;
    sub.u64 %rd7, %rd15, %rd15;
    max.u32 %r7, %r22, 256;
    min.u32 %r24, %r14, 15;
    sub.s64 %rd8, %rd7, %rd7;
    shl.b64 %rd8, %rd7, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
