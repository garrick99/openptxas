.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r17, %r3, %r3;
    cvt.s64.s32 %rd5, %r17;
    cvt.u64.u32 %rd12, %r3;
    shr.s32 %r23, %r17, 2;
    mul.lo.u32 %r10, %r23, 4;
    cvt.s32.s64 %r11, %rd12;
    max.u32 %r8, %r3, %r23;
    setp.gt.s32 %p4, %r23, 32;
    @%p4 min.u64 %rd5, %rd12, %rd5;
    mul.wide.s32 %rd12, %r10, %r11;
    min.u32 %r20, %r8, %r8;
    or.b64 %rd7, %rd12, %rd12;
    cvt.s32.s64 %r20, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
