.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r20, %r3, 2;
    cvt.u64.u32 %rd13, %r20;
    and.b32 %r15, %r3, %r20;
    max.s32 %r17, %r20, %r15;
    max.s32 %r27, %r15, 65536;
    shr.u64 %rd12, %rd13, 48;
    sub.s64 %rd15, %rd12, %rd13;
    sub.u32 %r6, %r15, 5;
    and.b32 %r11, %r6, %r6;
    shl.b64 %rd8, %rd15, 48;
    mul.wide.u32 %rd10, %r17, %r27;
    min.s64 %rd11, %rd15, %rd13;
    max.u32 %r25, %r20, %r27;
    setp.lt.s32 %p4, %r6, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
