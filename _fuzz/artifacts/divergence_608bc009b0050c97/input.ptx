.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r27, %r3, 4;
    or.b32 %r10, %r3, 31;
    add.s32 %r9, %r27, %r10;
    max.u32 %r17, %r9, 65536;
    setp.eq.s32 %p2, %r17, 5;
    selp.b32 %r24, %r3, %r27, %p2;
    shr.u32 %r20, %r9, 30;
    max.u32 %r25, %r3, %r9;
    max.u32 %r20, %r10, 63;
    setp.lt.s32 %p1, %r24, 65535;
    @%p1 mad.lo.s32 %r13, %r25, %r10, %r24;
    setp.eq.s32 %p1, %r13, %r27;
    setp.lo.u32 %p3, %r17, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
