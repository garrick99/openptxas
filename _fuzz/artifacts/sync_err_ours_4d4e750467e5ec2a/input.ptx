.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    sub.s32 %r10, %r3, 4294967295;
    mad.lo.u32 %r17, %r3, %r10, %r3;
    mad.lo.u32 %r25, %r17, %r17, %r17;
    shr.u64 %rd10, %rd15, 32;
    cvt.u32.u64 %r21, %rd10;
    sub.s64 %rd6, %rd15, %rd15;
    sub.u64 %rd6, %rd6, %rd15;
    mad.lo.u32 %r5, %r10, %r3, %r21;
    max.s64 %rd8, %rd6, %rd10;
    sub.u32 %r21, %r3, 256;
    add.s32 %r22, %r5, 64;
    setp.ne.s32 %p3, %r3, %r25;
    min.u32 %r11, %r3, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
