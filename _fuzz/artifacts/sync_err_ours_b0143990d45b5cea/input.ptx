.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p2, %r3, %r3;
    setp.ls.u32 %p2, %r3, %r3;
    @%p2 cvt.u64.u32 %rd8, %r3;
    xor.b32 %r8, %r3, 255;
    and.b64 %rd10, %rd8, %rd8;
    selp.b32 %r9, %r8, %r8, %p2;
    mul.lo.s32 %r11, %r8, 4;
    or.b64 %rd8, %rd8, %rd10;
    or.b32 %r19, %r8, 64;
    and.b64 %rd6, %rd8, %rd8;
    mul.wide.u32 %rd10, %r11, %r9;
    max.s32 %r9, %r8, 5;
    or.b32 %r10, %r3, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
