.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r26, %r3, %r3;
    add.u32 %r10, %r26, %r3;
    setp.gt.u32 %p2, %r10, %r10;
    @!%p2 mul.wide.u32 %rd7, %r3, %r3;
    shr.u32 %r27, %r26, 3;
    setp.le.s32 %p2, %r26, 8;
    @%p2 shr.u64 %rd12, %rd7, 33;
    xor.b32 %r9, %r27, %r3;
    setp.hs.u32 %p3, %r27, %r3;
    @%p3 shr.u32 %r19, %r3, 3;
    cvt.s64.s32 %rd15, %r27;
    max.s32 %r5, %r19, %r26;
    mul.lo.s32 %r27, %r19, 8;
    mul.lo.s32 %r11, %r26, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
