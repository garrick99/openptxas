.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r9, %r3, %r3;
    shr.u32 %r11, %r9, 0;
    sub.s32 %r9, %r3, 8;
    shr.s32 %r13, %r11, 0;
    mul.wide.s32 %rd11, %r13, %r9;
    setp.gt.s32 %p3, %r13, %r3;
    max.s32 %r5, %r11, %r11;
    max.u32 %r16, %r9, 1;
    setp.ne.u32 %p4, %r13, %r11;
    @!%p4 or.b32 %r27, %r5, 65535;
    min.s32 %r8, %r3, %r3;
    mul.wide.s32 %rd6, %r13, %r8;
    sub.u32 %r13, %r27, 15;
    or.b32 %r6, %r11, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
