.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r10, %r3, 1;
    mul.wide.u32 %rd9, %r3, %r3;
    shl.b64 %rd15, %rd9, 33;
    mul.wide.s32 %rd7, %r3, %r10;
    min.u32 %r16, %r10, %r3;
    xor.b32 %r4, %r10, 2147483647;
    sub.u32 %r6, %r10, 15;
    setp.eq.s32 %p2, %r4, %r10;
    @%p2 and.b64 %rd9, %rd15, %rd7;
    setp.le.s32 %p2, %r10, 32;
    @!%p2 xor.b64 %rd9, %rd9, %rd9;
    mul.lo.s32 %r6, %r16, 8;
    selp.b32 %r11, %r4, %r10, %p2;
    xor.b32 %r4, %r4, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
