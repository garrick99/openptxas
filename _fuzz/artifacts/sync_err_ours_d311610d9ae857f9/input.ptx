.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r8, %r3, %r3;
    cvt.u64.u32 %rd9, %r8;
    shr.u32 %r18, %r8, 15;
    mad.lo.u32 %r13, %r18, %r8, %r8;
    shl.b32 %r7, %r13, 16;
    max.s32 %r5, %r7, %r8;
    add.s32 %r6, %r5, %r5;
    setp.ne.s32 %p4, %r6, %r7;
    @%p4 and.b32 %r16, %r3, 64;
    sub.u32 %r10, %r6, %r3;
    max.s64 %rd8, %rd9, %rd9;
    sub.u32 %r16, %r16, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
