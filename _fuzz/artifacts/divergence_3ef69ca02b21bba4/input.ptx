.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r26, %r3, %r3;
    setp.lo.u32 %p4, %r3, 65536;
    @%p4 or.b32 %r17, %r3, %r3;
    max.s32 %r25, %r3, 31;
    sub.u32 %r26, %r26, %r26;
    setp.lt.u32 %p1, %r17, 1;
    setp.hs.u32 %p4, %r26, %r17;
    @!%p4 min.u32 %r22, %r25, %r26;
    cvt.s64.s32 %rd12, %r25;
    mul.lo.s32 %r22, %r3, %r22;
    add.s32 %r11, %r3, 15;
    cvt.s32.s64 %r21, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
