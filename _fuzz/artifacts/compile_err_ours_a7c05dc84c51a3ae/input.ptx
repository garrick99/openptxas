.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p3, %r0, %r0;
    vote.sync.ballot.b32 %r11, %p3, -1;
    vote.sync.any.pred %p3, %p3, -1;
    shfl.sync.bfly.b32 %r10, %r3, 8, 0x1f, -1;
    or.b32 %r7, %r11, %r0;
    xor.b32 %r5, %r0, %r3;
    shfl.sync.bfly.b32 %r6, %r0, 2, 0x1f, -1;
    shfl.sync.down.b32 %r14, %r6, 1, 0x1f, -1;
    setp.ge.u32 %p3, %r3, 15;
    vote.sync.ballot.b32 %r10, %p3, -1;
    xor.b32 %r10, %r10, %r5;
    setp.gt.u32 %p3, %r6, 1;
    vote.sync.ballot.b32 %r17, %p3, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
