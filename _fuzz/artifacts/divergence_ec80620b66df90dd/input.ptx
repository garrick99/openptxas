    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfe.s32 %r4, %r3, 23, 32;
    sub.u32 %r22, %r4, 65536;
    bfe.s32 %r23, %r3, 4, 8;
    or.b32 %r19, %r22, %r22;
    clz.b32 %r14, %r4;
