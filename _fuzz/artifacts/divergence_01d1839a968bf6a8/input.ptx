    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r19, %r3, %r3;
    sub.u32 %r23, %r19, 15;
    and.b32 %r11, %r3, 4294967295;
