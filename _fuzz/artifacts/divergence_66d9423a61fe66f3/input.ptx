.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r4, %r3, %r3;
    setp.gt.s32 %p4, %r3, %r4;
    @%p4 selp.b32 %r8, %r4, %r4, %p4;
    sub.u32 %r13, %r3, 63;
    cvt.s64.s32 %rd9, %r4;
    or.b32 %r15, %r8, 32;
    add.u32 %r18, %r3, %r13;
    mad.lo.s32 %r11, %r4, %r15, %r3;
    mad.lo.u32 %r17, %r18, %r15, %r11;
    mul.lo.u32 %r14, %r13, 255;
    mad.lo.u32 %r4, %r17, %r4, %r4;
    sub.s64 %rd12, %rd9, %rd9;
    setp.hs.u32 %p4, %r8, 32;
    mul.wide.s32 %rd6, %r15, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
