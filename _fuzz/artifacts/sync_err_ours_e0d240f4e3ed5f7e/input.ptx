.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    xor.b32 %r26, %r3, %r3;
    shr.u64 %rd5, %rd7, 1;
    xor.b32 %r11, %r26, %r26;
    mad.lo.s32 %r26, %r3, %r26, %r26;
    or.b64 %rd14, %rd5, %rd7;
    setp.ge.s32 %p2, %r11, 2147483647;
    mul.lo.u64 %rd13, %rd14, %rd14;
    and.b32 %r26, %r11, %r11;
    shr.s32 %r4, %r26, 30;
    cvt.u64.u32 %rd8, %r11;
    mul.lo.s64 %rd15, %rd7, %rd13;
    selp.b32 %r8, %r4, %r4, %p2;
    add.u64 %rd6, %rd14, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
