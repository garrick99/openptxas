.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r23, %r3, 4;
    add.u32 %r13, %r3, 65535;
    cvt.s64.s32 %rd13, %r23;
    sub.u32 %r9, %r13, %r3;
    shl.b32 %r4, %r9, 30;
    mad.lo.s32 %r24, %r23, %r4, %r3;
    add.s64 %rd15, %rd13, %rd13;
    min.s32 %r21, %r23, %r23;
    max.s32 %r17, %r3, %r13;
    and.b32 %r18, %r23, %r24;
    mad.lo.u32 %r25, %r13, %r3, %r23;
    xor.b32 %r24, %r23, %r25;
    shr.s32 %r16, %r17, 16;
    shr.s32 %r10, %r25, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
