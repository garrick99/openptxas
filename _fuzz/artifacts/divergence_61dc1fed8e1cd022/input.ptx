.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r22, %r3, %r3;
    cvt.s64.s32 %rd14, %r3;
    max.u32 %r17, %r3, %r3;
    add.u32 %r23, %r22, %r3;
    shl.b32 %r24, %r23, 7;
    setp.ne.s32 %p3, %r3, 5;
    @%p3 selp.b32 %r9, %r3, %r17, %p3;
    sub.s32 %r9, %r9, %r24;
    add.s32 %r24, %r22, 256;
    max.s32 %r17, %r23, %r22;
    mul.lo.u32 %r17, %r22, %r23;
    setp.ls.u32 %p2, %r3, %r9;
    @!%p2 add.u32 %r15, %r17, %r17;
    setp.gt.u32 %p4, %r23, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
