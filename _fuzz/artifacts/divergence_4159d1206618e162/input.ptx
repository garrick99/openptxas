.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r25, %r3, %r3;
    cvt.s64.s32 %rd11, %r25;
    shr.s64 %rd13, %rd11, 33;
    setp.ne.s32 %p1, %r25, %r25;
    @%p1 sub.u32 %r6, %r25, 15;
    xor.b32 %r24, %r25, 15;
    and.b32 %r26, %r6, 256;
    mul.wide.u32 %rd13, %r25, %r24;
    mul.wide.s32 %rd9, %r24, %r6;
    and.b32 %r24, %r24, 256;
    add.u32 %r23, %r26, %r3;
    mul.lo.s32 %r22, %r23, %r6;
    shl.b32 %r12, %r22, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
