.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd14, %r3, %r3;
    max.s32 %r5, %r3, 1;
    max.s32 %r22, %r5, %r3;
    cvt.s32.s64 %r25, %rd14;
    setp.hi.u32 %p3, %r3, 15;
    @!%p3 mad.lo.u32 %r17, %r22, %r3, %r22;
    shr.s64 %rd7, %rd14, 31;
    setp.lt.s32 %p4, %r25, %r5;
    @%p4 max.s32 %r5, %r22, %r3;
    and.b32 %r7, %r22, %r25;
    xor.b32 %r14, %r22, 2;
    add.s32 %r26, %r17, 4;
    mad.lo.s32 %r27, %r14, %r26, %r22;
    min.s64 %rd13, %rd14, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
