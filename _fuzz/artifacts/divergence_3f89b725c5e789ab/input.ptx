.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r7, %r3, 255;
    setp.lt.s32 %p4, %r7, %r7;
    @%p4 mul.wide.s32 %rd9, %r7, %r3;
    max.s64 %rd6, %rd9, %rd9;
    add.u32 %r6, %r7, %r3;
    xor.b32 %r27, %r7, 2;
    setp.ne.u32 %p1, %r7, %r3;
    @!%p1 sub.u32 %r11, %r7, 2147483648;
    sub.s32 %r4, %r6, %r27;
    min.u64 %rd7, %rd9, %rd9;
    selp.b32 %r23, %r6, %r3, %p1;
    shr.u32 %r14, %r27, 4;
    mad.lo.u32 %r4, %r11, %r27, %r7;
    and.b32 %r21, %r11, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
