.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p1, %r3, %r3;
    @!%p1 mul.wide.u32 %rd15, %r3, %r3;
    add.u32 %r11, %r3, 1;
    shr.s32 %r19, %r3, 31;
    shl.b64 %rd5, %rd15, 32;
    add.u32 %r8, %r11, 5;
    cvt.u64.u32 %rd14, %r8;
    cvt.s32.s64 %r21, %rd15;
    sub.s32 %r17, %r11, 65535;
    xor.b32 %r7, %r19, %r19;
    or.b32 %r11, %r21, 32;
    selp.b32 %r17, %r8, %r7, %p1;
    mul.wide.u32 %rd15, %r7, %r21;
    cvt.u32.u64 %r10, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
