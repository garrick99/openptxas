.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd12, %r3, %r3;
    min.u32 %r4, %r3, 1;
    max.u64 %rd15, %rd12, %rd12;
    and.b32 %r27, %r4, %r3;
    shl.b32 %r10, %r3, 15;
    shl.b64 %rd11, %rd15, 1;
    shr.u64 %rd10, %rd12, 47;
    max.s32 %r9, %r3, %r4;
    mul.lo.u32 %r21, %r10, %r4;
    sub.u64 %rd10, %rd15, %rd12;
    max.s32 %r9, %r10, 16;
    max.u32 %r4, %r4, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
