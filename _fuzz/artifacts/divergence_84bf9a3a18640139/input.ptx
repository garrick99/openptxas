.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    xor.b32 %r24, %r3, 65535;
    min.u32 %r9, %r3, %r3;
    shr.s64 %rd13, %rd11, 16;
    min.s32 %r5, %r24, 7;
    add.u32 %r9, %r24, %r24;
    sub.s32 %r10, %r24, %r24;
    mad.lo.u32 %r4, %r5, %r24, %r9;
    shr.s64 %rd14, %rd11, 15;
    cvt.s32.s64 %r6, %rd13;
    shr.s32 %r22, %r6, 1;
    mul.wide.s32 %rd11, %r3, %r9;
    mul.lo.s64 %rd6, %rd14, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
