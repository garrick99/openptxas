.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r15, %r3, %r3;
    cvt.u64.u32 %rd7, %r15;
    or.b32 %r10, %r15, %r15;
    min.u32 %r10, %r3, %r15;
    sub.u32 %r12, %r15, 1;
    min.s64 %rd12, %rd7, %rd7;
    min.u32 %r6, %r15, 64;
    mul.wide.u32 %rd8, %r6, %r15;
    min.u64 %rd6, %rd8, %rd12;
    shr.u32 %r16, %r3, 3;
    shr.s32 %r15, %r10, 30;
    max.s32 %r15, %r12, 3;
    add.s64 %rd15, %rd6, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
