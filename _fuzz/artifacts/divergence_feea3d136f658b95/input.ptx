.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    add.u32 %r12, %r3, %r3;
    setp.ls.u32 %p1, %r3, %r12;
    @%p1 mad.lo.s32 %r8, %r12, %r3, %r3;
    mul.lo.s32 %r20, %r3, 255;
    shr.s32 %r25, %r8, 3;
    mul.wide.u32 %rd14, %r20, %r3;
    selp.b32 %r19, %r8, %r12, %p1;
    or.b64 %rd5, %rd14, %rd14;
    selp.b32 %r13, %r3, %r20, %p1;
    add.s32 %r19, %r3, %r13;
    setp.hs.u32 %p1, %r19, 8;
    selp.b32 %r24, %r25, %r19, %p1;
    mad.lo.s32 %r24, %r8, %r8, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
