.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r11, %r3, %r3;
    or.b32 %r16, %r3, %r3;
    cvt.s64.s32 %rd6, %r11;
    min.u32 %r24, %r16, 8;
    mul.lo.s32 %r16, %r16, 63;
    add.s32 %r4, %r11, %r16;
    add.u32 %r26, %r3, %r16;
    max.u32 %r17, %r3, %r26;
    xor.b32 %r18, %r4, 2147483647;
    add.u32 %r23, %r18, 4;
    shr.u64 %rd9, %rd6, 3;
    min.u32 %r19, %r23, %r18;
    or.b32 %r23, %r26, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
