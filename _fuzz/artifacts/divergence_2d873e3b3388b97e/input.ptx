.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r17, %r3, 63;
    shl.b32 %r14, %r17, 1;
    or.b32 %r4, %r3, 64;
    setp.le.u32 %p1, %r4, 2147483648;
    @!%p1 cvt.u64.u32 %rd10, %r17;
    cvt.u32.u64 %r6, %rd10;
    add.s32 %r4, %r17, 65536;
    sub.u32 %r9, %r4, 0;
    cvt.u64.u32 %rd10, %r17;
    shl.b32 %r19, %r14, 4;
    shr.u64 %rd6, %rd10, 31;
    mad.lo.u32 %r23, %r6, %r9, %r9;
    or.b32 %r20, %r3, %r6;
    mul.lo.u32 %r22, %r23, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
