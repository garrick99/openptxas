.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p4, %r3, %r3;
    @%p4 sub.u32 %r27, %r3, 16;
    setp.lo.u32 %p4, %r3, %r27;
    @%p4 shl.b32 %r5, %r27, 1;
    mul.lo.s32 %r11, %r27, 65536;
    max.u32 %r16, %r5, %r11;
    cvt.s64.s32 %rd9, %r3;
    selp.b32 %r8, %r5, %r16, %p4;
    sub.u32 %r14, %r5, %r5;
    shr.u32 %r19, %r16, 30;
    cvt.s32.s64 %r12, %rd9;
    cvt.u64.u32 %rd14, %r16;
    selp.b32 %r14, %r19, %r3, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
