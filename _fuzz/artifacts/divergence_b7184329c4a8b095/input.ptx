.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r8, %r3, 1;
    or.b32 %r14, %r8, %r8;
    mul.wide.u32 %rd5, %r14, %r3;
    cvt.u32.u64 %r23, %rd5;
    and.b32 %r11, %r3, %r23;
    shr.s64 %rd7, %rd5, 32;
    or.b32 %r4, %r23, 4;
    setp.ls.u32 %p3, %r3, 65535;
    @%p3 sub.s32 %r24, %r3, %r14;
    mad.lo.s32 %r25, %r24, %r4, %r24;
    max.s32 %r21, %r3, %r14;
    cvt.s32.s64 %r18, %rd5;
    or.b32 %r16, %r3, %r24;
    mad.lo.u32 %r5, %r4, %r24, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
