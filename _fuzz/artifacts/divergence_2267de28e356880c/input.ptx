.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p1, %r3, 16;
    setp.le.u32 %p4, %r3, 15;
    @!%p4 mul.lo.u32 %r19, %r3, 4294967295;
    max.s32 %r20, %r19, 3;
    mul.lo.s32 %r22, %r20, 64;
    mul.lo.s32 %r14, %r22, 2147483647;
    max.s32 %r18, %r20, 2147483648;
    add.s32 %r8, %r22, %r3;
    max.u32 %r19, %r8, %r22;
    max.s32 %r7, %r14, 5;
    min.u32 %r4, %r19, 2147483647;
    mad.lo.u32 %r27, %r4, %r3, %r20;
    setp.hi.u32 %p3, %r27, %r7;
    @%p3 shl.b32 %r16, %r7, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
