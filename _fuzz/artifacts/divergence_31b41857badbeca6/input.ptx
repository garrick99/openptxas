.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p2, %r3, %r3;
    @%p2 shr.s32 %r27, %r3, 4;
    cvt.s64.s32 %rd11, %r27;
    mad.lo.u32 %r27, %r3, %r3, %r3;
    selp.b32 %r8, %r3, %r27, %p2;
    mul.lo.u32 %r19, %r8, %r27;
    sub.s64 %rd10, %rd11, %rd11;
    mad.lo.u32 %r11, %r8, %r8, %r3;
    xor.b64 %rd14, %rd10, %rd11;
    shr.s32 %r10, %r3, 4;
    shl.b64 %rd11, %rd14, 48;
    cvt.u64.u32 %rd13, %r8;
    cvt.s32.s64 %r22, %rd14;
    setp.ne.s32 %p3, %r3, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
