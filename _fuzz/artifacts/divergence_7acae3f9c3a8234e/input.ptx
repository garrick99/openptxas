.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r6, %r3, 5;
    setp.ge.s32 %p4, %r6, %r6;
    @!%p4 sub.u32 %r14, %r3, 0;
    min.s32 %r26, %r3, %r14;
    mad.lo.s32 %r25, %r3, %r26, %r6;
    cvt.s64.s32 %rd11, %r6;
    setp.ne.s32 %p1, %r3, 2147483648;
    @!%p1 sub.u32 %r7, %r14, %r6;
    max.s32 %r16, %r7, 15;
    selp.b32 %r5, %r25, %r14, %p1;
    mad.lo.u32 %r17, %r25, %r5, %r25;
    and.b32 %r12, %r16, 4;
    mul.lo.s32 %r17, %r25, %r16;
    mul.lo.s32 %r21, %r12, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
