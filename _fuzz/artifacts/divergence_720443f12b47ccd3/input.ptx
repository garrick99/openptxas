.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p4, %r3, %r3;
    @!%p4 sub.u32 %r8, %r3, 0;
    cvt.u64.u32 %rd11, %r3;
    max.s32 %r26, %r8, %r8;
    min.s32 %r25, %r26, 4;
    xor.b32 %r21, %r8, %r3;
    mul.lo.s32 %r26, %r3, 16;
    setp.le.s32 %p1, %r26, %r21;
    @%p1 mad.lo.s32 %r27, %r26, %r25, %r21;
    sub.u32 %r12, %r8, 5;
    cvt.s32.s64 %r14, %rd11;
    max.u32 %r14, %r25, %r26;
    shl.b64 %rd15, %rd11, 15;
    mul.lo.s32 %r26, %r27, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
