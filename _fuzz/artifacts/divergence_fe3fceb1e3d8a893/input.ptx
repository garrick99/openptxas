.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd5, %r3, %r3;
    setp.eq.s32 %p1, %r3, 7;
    @%p1 add.s32 %r27, %r3, 1;
    shl.b32 %r8, %r27, 7;
    sub.u64 %rd6, %rd5, %rd5;
    mul.lo.u32 %r21, %r3, %r27;
    shr.s32 %r23, %r21, 15;
    shl.b32 %r17, %r3, 0;
    sub.s32 %r9, %r21, 65535;
    mad.lo.s32 %r7, %r3, %r17, %r17;
    shr.s64 %rd8, %rd6, 4;
    min.u32 %r6, %r7, %r3;
    max.s64 %rd10, %rd6, %rd6;
    max.s32 %r17, %r21, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
