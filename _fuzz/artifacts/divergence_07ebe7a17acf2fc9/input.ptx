.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    sub.s32 %r10, %r3, %r3;
    xor.b32 %r16, %r3, 16;
    sub.u32 %r16, %r3, %r3;
    setp.lt.s32 %p2, %r16, %r16;
    @%p2 or.b32 %r15, %r16, %r10;
    mad.lo.s32 %r22, %r16, %r15, %r15;
    add.s32 %r22, %r10, 16;
    mul.wide.s32 %rd5, %r22, %r3;
    cvt.u32.u64 %r27, %rd5;
    sub.u32 %r16, %r27, 1;
    xor.b32 %r22, %r22, %r27;
    or.b32 %r26, %r27, 63;
    selp.b32 %r18, %r10, %r15, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
