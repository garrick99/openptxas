.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd6, %r3, %r3;
    shr.u64 %rd5, %rd6, 62;
    setp.ne.u32 %p4, %r3, 0;
    @%p4 shl.b32 %r20, %r3, 2;
    sub.s32 %r5, %r3, 7;
    mul.wide.s32 %rd10, %r3, %r20;
    setp.ge.u32 %p2, %r20, 4294967295;
    @%p2 cvt.s64.s32 %rd14, %r20;
    min.u64 %rd15, %rd5, %rd14;
    shr.s32 %r20, %r20, 0;
    shr.u32 %r9, %r3, 16;
    mul.wide.s32 %rd10, %r9, %r3;
    shr.u32 %r5, %r9, 7;
    add.u32 %r5, %r5, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
