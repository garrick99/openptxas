.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r24, %r3, 31;
    shl.b32 %r14, %r3, 31;
    mad.lo.s32 %r17, %r14, %r3, %r24;
    cvt.u64.u32 %rd8, %r3;
    setp.ge.s32 %p4, %r24, %r17;
    @!%p4 min.s32 %r15, %r24, %r24;
    add.u32 %r11, %r17, %r14;
    shr.s64 %rd14, %rd8, 2;
    min.s32 %r13, %r14, %r3;
    xor.b32 %r26, %r24, %r3;
    and.b32 %r13, %r3, %r24;
    add.s32 %r14, %r13, %r15;
    shr.s64 %rd6, %rd14, 63;
    mul.wide.u32 %rd15, %r14, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
