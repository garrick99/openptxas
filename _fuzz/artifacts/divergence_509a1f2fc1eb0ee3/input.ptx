.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r18, %r3, 64;
    sub.u32 %r8, %r18, %r3;
    shl.b32 %r10, %r8, 2;
    min.s32 %r23, %r18, 4;
    cvt.u64.u32 %rd13, %r10;
    mul.lo.u32 %r16, %r18, %r18;
    mad.lo.s32 %r4, %r16, %r18, %r23;
    cvt.s32.s64 %r14, %rd13;
    xor.b32 %r9, %r23, 4294967295;
    setp.lt.s32 %p1, %r10, 65536;
    @!%p1 shr.s32 %r17, %r8, 1;
    shr.s32 %r13, %r9, 1;
    sub.s32 %r22, %r3, 65535;
    mad.lo.u32 %r10, %r9, %r17, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
