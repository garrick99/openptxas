.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r21, %r3, %r3, %r3;
    shr.s32 %r25, %r3, 4;
    max.u32 %r13, %r21, 1;
    mad.lo.u32 %r8, %r3, %r25, %r21;
    mul.wide.s32 %rd6, %r25, %r21;
    mad.lo.s32 %r17, %r3, %r25, %r13;
    mul.wide.s32 %rd14, %r25, %r8;
    mul.lo.s64 %rd7, %rd14, %rd6;
    sub.s64 %rd14, %rd7, %rd14;
    cvt.s32.s64 %r4, %rd6;
    shr.u64 %rd5, %rd14, 47;
    shr.s64 %rd11, %rd6, 15;
    or.b32 %r18, %r17, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
