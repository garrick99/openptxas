.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r10, %r3, 15;
    cvt.s64.s32 %rd14, %r3;
    xor.b32 %r19, %r10, 2147483648;
    cvt.s32.s64 %r12, %rd14;
    mul.lo.u32 %r5, %r19, %r3;
    shr.s32 %r16, %r10, 31;
    add.u32 %r6, %r19, %r5;
    setp.ne.u32 %p4, %r5, %r5;
    setp.ne.s32 %p4, %r12, %r16;
    @!%p4 max.u32 %r13, %r10, 15;
    sub.s32 %r13, %r12, %r16;
    shl.b32 %r7, %r3, 1;
    add.u32 %r16, %r7, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
