.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    cvt.u32.u64 %r4, %rd14;
    add.u32 %r15, %r4, %r4;
    shr.s32 %r4, %r4, 15;
    setp.le.s32 %p3, %r4, 0;
    max.u32 %r4, %r3, %r3;
    or.b32 %r21, %r3, %r4;
    shr.u64 %rd5, %rd14, 33;
    add.s32 %r9, %r4, 7;
    sub.u32 %r25, %r4, %r9;
    add.s32 %r4, %r15, 3;
    sub.s32 %r9, %r15, 2;
    cvt.s32.s64 %r4, %rd14;
    sub.s32 %r5, %r4, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
