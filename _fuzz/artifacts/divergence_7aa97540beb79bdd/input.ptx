.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r25, %r3, %r3;
    cvt.u64.u32 %rd14, %r3;
    cvt.u64.u32 %rd9, %r25;
    add.s32 %r25, %r3, %r3;
    xor.b32 %r10, %r25, %r3;
    mad.lo.u32 %r21, %r25, %r10, %r10;
    and.b32 %r6, %r25, %r21;
    sub.s64 %rd5, %rd14, %rd9;
    shl.b32 %r8, %r10, 0;
    shr.s64 %rd15, %rd5, 15;
    add.s32 %r13, %r8, 65535;
    add.s32 %r13, %r10, %r6;
    max.u64 %rd11, %rd14, %rd5;
    mul.wide.u32 %rd9, %r21, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
