.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p4, %r3, %r3;
    @%p4 mad.lo.s32 %r22, %r3, %r3, %r3;
    cvt.u64.u32 %rd7, %r3;
    add.s32 %r20, %r22, %r3;
    mul.lo.s32 %r24, %r20, 0;
    setp.lt.u32 %p3, %r22, 63;
    @%p3 mul.wide.u32 %rd11, %r3, %r3;
    min.s32 %r17, %r3, 31;
    xor.b32 %r11, %r24, %r22;
    cvt.u64.u32 %rd15, %r11;
    mul.lo.s32 %r7, %r20, %r22;
    min.s32 %r7, %r22, %r20;
    add.u32 %r9, %r3, %r20;
    shr.s64 %rd12, %rd7, 33;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
