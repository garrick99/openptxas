.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd7, %r3, %r3;
    cvt.u32.u64 %r6, %rd7;
    min.u32 %r9, %r6, %r6;
    max.s32 %r8, %r6, %r6;
    setp.ne.u32 %p3, %r8, %r6;
    mul.lo.u32 %r13, %r9, 65536;
    add.s32 %r19, %r9, %r9;
    shl.b64 %rd6, %rd7, 31;
    mul.lo.s32 %r9, %r6, 63;
    sub.s32 %r9, %r3, 256;
    setp.ge.s32 %p4, %r13, %r13;
    @%p4 max.u32 %r9, %r6, %r6;
    sub.s64 %rd11, %rd6, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
