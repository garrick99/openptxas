.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r24, %r3, %r3;
    sub.u32 %r25, %r24, 2147483647;
    xor.b32 %r8, %r24, %r3;
    mul.lo.u32 %r7, %r3, %r24;
    or.b32 %r23, %r8, %r24;
    setp.le.s32 %p2, %r24, 63;
    mul.wide.u32 %rd7, %r23, %r7;
    and.b32 %r9, %r25, 256;
    mad.lo.s32 %r22, %r8, %r25, %r9;
    selp.b32 %r20, %r23, %r9, %p2;
    min.s64 %rd8, %rd7, %rd7;
    mad.lo.s32 %r25, %r25, %r22, %r25;
    setp.ge.u32 %p2, %r25, 3;
    @%p2 shr.s32 %r4, %r8, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
