.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r20, %r3, 30;
    min.u32 %r7, %r20, 16;
    max.s32 %r6, %r20, %r7;
    cvt.s64.s32 %rd9, %r20;
    and.b32 %r8, %r7, 2147483647;
    max.s32 %r21, %r8, 1;
    and.b32 %r13, %r7, %r8;
    xor.b32 %r16, %r21, %r3;
    shr.s64 %rd11, %rd9, 4;
    mul.lo.s64 %rd13, %rd11, %rd11;
    cvt.s64.s32 %rd10, %r7;
    setp.lt.u32 %p4, %r3, 1;
    @%p4 shr.s32 %r11, %r20, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
