.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r20, %r3, 15;
    cvt.s64.s32 %rd14, %r3;
    mul.lo.u32 %r19, %r3, 64;
    add.u32 %r27, %r20, %r20;
    setp.le.s32 %p3, %r19, 4294967295;
    mul.lo.s32 %r5, %r27, 32;
    setp.le.s32 %p2, %r5, 4;
    @%p2 shr.u64 %rd13, %rd14, 16;
    mul.lo.s32 %r11, %r20, 5;
    min.u32 %r12, %r27, 32;
    sub.u32 %r27, %r11, %r3;
    cvt.u32.u64 %r13, %rd14;
    shr.s32 %r20, %r12, 30;
    xor.b64 %rd5, %rd14, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
