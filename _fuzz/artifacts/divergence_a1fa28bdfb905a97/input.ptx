.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r15, %r3, 5;
    setp.le.s32 %p2, %r15, 2147483647;
    cvt.s64.s32 %rd10, %r3;
    shr.s64 %rd13, %rd10, 7;
    sub.s64 %rd10, %rd10, %rd10;
    add.s32 %r22, %r3, 64;
    mad.lo.u32 %r27, %r22, %r3, %r3;
    mad.lo.s32 %r16, %r22, %r3, %r15;
    mad.lo.u32 %r11, %r15, %r15, %r16;
    xor.b32 %r6, %r15, %r15;
    setp.lo.u32 %p1, %r6, 256;
    shl.b32 %r11, %r22, 16;
    cvt.u64.u32 %rd13, %r6;
    setp.lt.u32 %p1, %r3, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
