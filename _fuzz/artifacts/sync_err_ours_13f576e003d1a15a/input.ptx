.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    mad.lo.s32 %r16, %r3, %r3, %r3;
    max.s32 %r7, %r16, %r3;
    shl.b32 %r10, %r3, 1;
    shl.b64 %rd8, %rd7, 62;
    mad.lo.s32 %r13, %r3, %r7, %r16;
    mul.wide.s32 %rd11, %r10, %r7;
    shl.b32 %r7, %r10, 16;
    shl.b64 %rd5, %rd7, 7;
    add.s32 %r5, %r13, %r7;
    min.s32 %r4, %r16, %r13;
    or.b32 %r17, %r13, %r5;
    add.u32 %r24, %r5, 32;
    sub.u32 %r23, %r24, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
