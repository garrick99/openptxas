.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    add.s32 %r9, %r3, 63;
    shr.u32 %r26, %r3, 1;
    max.u32 %r12, %r9, %r26;
    cvt.s32.s64 %r4, %rd14;
    add.s64 %rd14, %rd14, %rd14;
    mul.lo.s32 %r25, %r12, %r9;
    add.s32 %r6, %r4, %r3;
    cvt.s32.s64 %r25, %rd14;
    sub.s32 %r18, %r12, %r26;
    min.u32 %r26, %r25, 65536;
    shr.s64 %rd11, %rd14, 33;
    cvt.s64.s32 %rd13, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
