.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p3, %r3, 0;
    @%p3 sub.u32 %r13, %r3, %r3;
    cvt.u64.u32 %rd11, %r13;
    add.s32 %r5, %r13, %r3;
    sub.u64 %rd7, %rd11, %rd11;
    max.s32 %r11, %r13, %r3;
    min.s32 %r25, %r13, 63;
    mul.wide.u32 %rd15, %r25, %r11;
    shr.u32 %r11, %r13, 30;
    cvt.s64.s32 %rd5, %r25;
    mul.lo.u64 %rd9, %rd15, %rd15;
    cvt.u32.u64 %r18, %rd9;
    setp.hs.u32 %p2, %r3, 63;
    @%p2 add.u64 %rd13, %rd7, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
