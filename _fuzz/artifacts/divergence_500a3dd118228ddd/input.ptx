.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p1, %r3, %r3;
    @!%p1 max.u32 %r9, %r3, 4;
    or.b32 %r19, %r9, %r3;
    setp.ne.u32 %p4, %r3, 2;
    @%p4 mul.wide.u32 %rd7, %r19, %r9;
    min.s64 %rd14, %rd7, %rd7;
    selp.b32 %r21, %r3, %r9, %p4;
    mul.lo.u32 %r20, %r9, %r21;
    or.b32 %r4, %r9, %r19;
    mul.wide.u32 %rd11, %r9, %r20;
    add.s32 %r21, %r21, %r20;
    shr.u32 %r9, %r20, 31;
    add.s32 %r17, %r19, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
