.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r25, %r3, 3;
    setp.gt.s32 %p1, %r3, %r25;
    @%p1 sub.u32 %r20, %r25, %r3;
    selp.b32 %r10, %r25, %r25, %p1;
    cvt.s64.s32 %rd9, %r3;
    mul.lo.u32 %r27, %r20, 1;
    shr.s64 %rd10, %rd9, 48;
    and.b32 %r14, %r25, %r25;
    selp.b32 %r27, %r10, %r14, %p1;
    cvt.u32.u64 %r6, %rd9;
    min.s64 %rd12, %rd10, %rd9;
    add.u64 %rd6, %rd10, %rd10;
    sub.s32 %r15, %r6, %r10;
    max.u32 %r15, %r20, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
