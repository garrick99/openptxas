.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r11, %r3, 4;
    sub.u32 %r18, %r11, 3;
    xor.b32 %r7, %r3, 2147483648;
    max.u32 %r19, %r11, %r7;
    add.u32 %r13, %r19, 4;
    cvt.u64.u32 %rd5, %r11;
    max.u64 %rd5, %rd5, %rd5;
    cvt.u32.u64 %r20, %rd5;
    and.b64 %rd13, %rd5, %rd5;
    setp.ge.s32 %p3, %r7, 2;
    @%p3 mul.wide.s32 %rd5, %r20, %r20;
    selp.b32 %r10, %r11, %r3, %p3;
    sub.u32 %r9, %r20, 256;
    mad.lo.s32 %r25, %r11, %r3, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
