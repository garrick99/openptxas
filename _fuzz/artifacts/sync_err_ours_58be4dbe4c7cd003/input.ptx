    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    min.s32 %r20, %r3, 63;
    xor.b32 %r11, %r20, 2147483647;
    xor.b32 %r25, %r20, %r3;
