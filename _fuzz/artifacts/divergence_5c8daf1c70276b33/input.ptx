.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r18, %r3, 5;
    setp.eq.u32 %p2, %r3, %r18;
    @%p2 add.s32 %r10, %r3, %r3;
    setp.ne.u32 %p2, %r3, %r3;
    @%p2 max.u32 %r24, %r10, 2;
    or.b32 %r13, %r10, %r18;
    setp.gt.u32 %p2, %r13, %r10;
    @!%p2 min.u32 %r17, %r10, %r3;
    max.u32 %r11, %r17, 64;
    sub.u32 %r23, %r10, 3;
    sub.s32 %r21, %r3, 64;
    cvt.s64.s32 %rd11, %r21;
    cvt.s32.s64 %r7, %rd11;
    and.b32 %r25, %r11, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
