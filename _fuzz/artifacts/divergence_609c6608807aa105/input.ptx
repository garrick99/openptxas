.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    sub.u32 %r22, %r3, 5;
    sub.s32 %r24, %r3, %r22;
    min.s32 %r6, %r3, %r3;
    mul.wide.s32 %rd14, %r22, %r6;
    setp.ge.u32 %p1, %r6, 7;
    @!%p1 add.s64 %rd6, %rd15, %rd15;
    shl.b32 %r13, %r22, 31;
    setp.ge.s32 %p1, %r6, 5;
    @!%p1 mad.lo.u32 %r10, %r3, %r6, %r13;
    selp.b32 %r13, %r13, %r6, %p1;
    shr.u32 %r22, %r13, 1;
    selp.b32 %r20, %r10, %r24, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
