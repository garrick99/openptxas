.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r12, %r3, 30;
    max.u32 %r17, %r3, %r3;
    max.u32 %r10, %r3, 64;
    shr.s32 %r6, %r3, 15;
    setp.lt.s32 %p4, %r3, %r10;
    @%p4 cvt.u64.u32 %rd15, %r3;
    max.u32 %r26, %r17, %r17;
    max.u32 %r12, %r6, 255;
    add.u32 %r17, %r12, %r6;
    max.s32 %r15, %r17, 5;
    cvt.u64.u32 %rd10, %r15;
    shr.s32 %r24, %r6, 30;
    shl.b32 %r25, %r17, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
