.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r24, %r3, %r3;
    cvt.u64.u32 %rd14, %r3;
    min.u64 %rd10, %rd14, %rd14;
    add.u32 %r8, %r3, %r24;
    setp.gt.s32 %p3, %r3, 2;
    @%p3 max.s32 %r22, %r8, %r24;
    cvt.s32.s64 %r17, %rd10;
    mad.lo.u32 %r19, %r8, %r17, %r24;
    shr.u64 %rd11, %rd10, 15;
    sub.s64 %rd10, %rd11, %rd10;
    add.s32 %r21, %r19, %r3;
    shl.b64 %rd5, %rd10, 16;
    shr.u32 %r9, %r8, 3;
    min.u32 %r15, %r22, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
