.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r6, %r3, %r3;
    setp.ne.s32 %p2, %r3, %r3;
    cvt.u64.u32 %rd7, %r6;
    shr.u32 %r9, %r6, 31;
    add.u64 %rd15, %rd7, %rd7;
    add.u32 %r4, %r6, %r6;
    cvt.u64.u32 %rd5, %r4;
    mul.lo.s32 %r17, %r9, 7;
    mul.lo.u32 %r22, %r9, %r3;
    min.s32 %r11, %r3, %r3;
    add.u32 %r9, %r6, %r11;
    and.b32 %r15, %r4, 65535;
    setp.lt.u32 %p3, %r3, 65535;
    @%p3 and.b32 %r7, %r15, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
