.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r24, %r3, %r3;
    shl.b32 %r24, %r24, 2;
    cvt.s64.s32 %rd15, %r3;
    setp.ge.s32 %p4, %r3, 63;
    @!%p4 max.u32 %r6, %r3, %r3;
    xor.b32 %r22, %r24, %r24;
    shr.s32 %r12, %r3, 1;
    max.s32 %r17, %r6, %r22;
    mul.wide.s32 %rd11, %r3, %r3;
    shr.s64 %rd8, %rd11, 4;
    setp.lt.s32 %p4, %r22, 15;
    @%p4 mul.lo.s32 %r24, %r17, 3;
    add.s32 %r12, %r6, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
