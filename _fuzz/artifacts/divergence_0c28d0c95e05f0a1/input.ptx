.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r26, %r3, 16;
    add.u32 %r11, %r3, %r26;
    shr.s32 %r26, %r11, 2;
    mul.wide.u32 %rd5, %r3, %r26;
    cvt.s32.s64 %r8, %rd5;
    cvt.u32.u64 %r14, %rd5;
    add.s32 %r22, %r11, 2147483648;
    min.s32 %r8, %r3, 256;
    mul.lo.u32 %r12, %r14, 5;
    setp.ls.u32 %p2, %r12, 1;
    @%p2 mul.lo.s32 %r26, %r8, %r26;
    cvt.u64.u32 %rd13, %r22;
    setp.ne.s32 %p4, %r8, %r26;
    @%p4 max.s32 %r9, %r11, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
