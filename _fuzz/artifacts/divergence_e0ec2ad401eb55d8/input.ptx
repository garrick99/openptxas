.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p2, %r3, %r3;
    or.b32 %r9, %r3, %r3;
    setp.ne.u32 %p4, %r9, 32;
    @!%p4 min.s32 %r5, %r9, %r9;
    min.u32 %r8, %r3, %r9;
    cvt.s64.s32 %rd10, %r5;
    setp.ne.u32 %p3, %r9, 2;
    @%p3 sub.u32 %r15, %r9, 256;
    max.u32 %r13, %r9, 7;
    shl.b32 %r24, %r5, 7;
    mul.wide.u32 %rd11, %r9, %r15;
    and.b32 %r8, %r5, %r9;
    cvt.u64.u32 %rd10, %r15;
    setp.eq.s32 %p4, %r15, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
