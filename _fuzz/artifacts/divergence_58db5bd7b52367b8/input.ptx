.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    and.b32 %r15, %r3, 63;
    mul.lo.s32 %r15, %r15, 4294967295;
    add.s32 %r18, %r15, 65536;
    mul.wide.s32 %rd14, %r3, %r15;
    add.u64 %rd12, %rd14, %rd14;
    or.b32 %r4, %r3, %r3;
    and.b64 %rd14, %rd5, %rd5;
    min.u32 %r21, %r4, %r18;
    setp.ge.u32 %p4, %r15, %r3;
    @%p4 xor.b32 %r10, %r4, 2147483648;
    add.u64 %rd5, %rd12, %rd12;
    or.b32 %r20, %r18, %r15;
    selp.b32 %r10, %r3, %r15, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
