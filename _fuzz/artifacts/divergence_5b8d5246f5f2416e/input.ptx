.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r25, %r3, %r3;
    shr.u32 %r27, %r3, 1;
    cvt.s64.s32 %rd7, %r25;
    sub.s64 %rd6, %rd7, %rd7;
    mul.lo.s32 %r23, %r27, 256;
    min.u64 %rd13, %rd7, %rd6;
    shr.s64 %rd14, %rd13, 0;
    setp.ls.u32 %p4, %r27, 31;
    @%p4 shr.u32 %r22, %r25, 15;
    sub.s32 %r22, %r25, %r3;
    sub.u32 %r25, %r27, %r3;
    xor.b32 %r4, %r25, 64;
    mul.lo.s32 %r22, %r3, 8;
    cvt.u32.u64 %r4, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
