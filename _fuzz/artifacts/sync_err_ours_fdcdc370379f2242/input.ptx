.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    or.b32 %r24, %r3, %r3;
    shr.s32 %r16, %r3, 4;
    setp.ge.s32 %p3, %r16, %r16;
    @%p3 cvt.u32.u64 %r9, %rd5;
    sub.u32 %r25, %r24, %r9;
    shr.u64 %rd13, %rd5, 30;
    cvt.u32.u64 %r5, %rd13;
    selp.b32 %r16, %r9, %r24, %p3;
    shr.u32 %r15, %r16, 7;
    min.u32 %r10, %r9, %r9;
    cvt.u32.u64 %r15, %rd13;
    cvt.s32.s64 %r19, %rd13;
    shr.s64 %rd9, %rd13, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
