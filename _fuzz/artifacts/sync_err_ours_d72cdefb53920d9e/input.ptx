.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    shr.u64 %rd12, %rd14, 2;
    min.s64 %rd14, %rd14, %rd12;
    mad.lo.u32 %r4, %r3, %r3, %r3;
    setp.gt.s32 %p1, %r4, 16;
    @!%p1 cvt.s32.s64 %r20, %rd14;
    xor.b64 %rd6, %rd12, %rd12;
    cvt.s32.s64 %r14, %rd6;
    shr.u64 %rd11, %rd12, 30;
    cvt.u64.u32 %rd8, %r3;
    setp.hs.u32 %p4, %r3, 65535;
    @%p4 max.u32 %r8, %r20, 2147483648;
    mul.lo.u32 %r23, %r4, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
