.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r12, %r3, 3;
    and.b32 %r25, %r12, 256;
    or.b32 %r23, %r12, %r25;
    setp.ge.s32 %p4, %r3, 31;
    @%p4 cvt.s64.s32 %rd8, %r3;
    min.u32 %r23, %r23, 7;
    shl.b32 %r9, %r23, 15;
    and.b32 %r11, %r25, 65535;
    mad.lo.s32 %r16, %r23, %r11, %r11;
    min.s32 %r13, %r9, %r25;
    xor.b32 %r26, %r3, %r25;
    mad.lo.u32 %r26, %r11, %r9, %r16;
    or.b32 %r6, %r13, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
