.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r12, %r3, 3;
    shr.u32 %r12, %r12, 16;
    mul.wide.u32 %rd15, %r3, %r12;
    add.u32 %r23, %r3, %r12;
    shl.b64 %rd5, %rd15, 30;
    mul.lo.s32 %r22, %r3, 16;
    setp.hi.u32 %p1, %r3, 16;
    and.b32 %r11, %r3, 3;
    mul.wide.u32 %rd7, %r22, %r12;
    sub.u32 %r9, %r12, 4294967295;
    setp.lt.s32 %p1, %r23, 15;
    mad.lo.u32 %r11, %r9, %r11, %r9;
    sub.u32 %r6, %r12, 2;
    mul.lo.s32 %r8, %r12, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
