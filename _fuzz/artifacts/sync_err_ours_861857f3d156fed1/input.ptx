.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    add.u64 %rd13, %rd6, %rd6;
    setp.gt.s32 %p1, %r3, 7;
    @%p1 mad.lo.u32 %r7, %r3, %r3, %r3;
    shl.b32 %r18, %r7, 7;
    shr.s32 %r16, %r7, 30;
    or.b32 %r6, %r7, 4;
    add.u32 %r17, %r6, 8;
    mad.lo.s32 %r12, %r3, %r16, %r17;
    mul.lo.s32 %r6, %r16, %r3;
    cvt.s32.s64 %r13, %rd6;
    max.s32 %r27, %r18, %r12;
    mul.lo.s64 %rd14, %rd13, %rd13;
    add.s32 %r22, %r13, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
