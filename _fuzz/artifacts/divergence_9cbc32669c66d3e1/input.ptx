.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p3, %r3, 0;
    @%p3 sub.u32 %r22, %r3, %r3;
    cvt.s64.s32 %rd15, %r3;
    cvt.s32.s64 %r21, %rd15;
    sub.u32 %r6, %r21, 65535;
    mul.lo.u32 %r21, %r21, %r22;
    setp.hs.u32 %p4, %r3, 63;
    @%p4 or.b32 %r20, %r22, 4;
    shr.s32 %r25, %r20, 15;
    shr.s32 %r8, %r6, 2;
    add.u32 %r4, %r21, %r20;
    or.b32 %r12, %r3, 32;
    shl.b64 %rd12, %rd15, 15;
    min.s32 %r14, %r6, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
