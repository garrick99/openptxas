.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r13, %r3, %r3, %r3;
    cvt.s64.s32 %rd7, %r13;
    setp.gt.s32 %p1, %r3, %r13;
    @%p1 shr.s64 %rd14, %rd7, 47;
    min.u32 %r18, %r13, 1;
    mad.lo.s32 %r20, %r3, %r3, %r13;
    setp.ge.s32 %p4, %r20, %r20;
    @!%p4 max.s32 %r6, %r13, %r3;
    mul.wide.s32 %rd9, %r20, %r6;
    xor.b32 %r8, %r13, %r3;
    cvt.u32.u64 %r8, %rd14;
    mad.lo.u32 %r26, %r20, %r3, %r6;
    selp.b32 %r7, %r18, %r8, %p1;
    add.s64 %rd13, %rd9, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
