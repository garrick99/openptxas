.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r14, %r3, %r3;
    cvt.s64.s32 %rd9, %r14;
    or.b32 %r18, %r14, %r14;
    mul.lo.s32 %r10, %r14, %r14;
    min.s32 %r26, %r18, 65535;
    shr.u32 %r20, %r26, 7;
    mul.lo.u32 %r17, %r3, %r20;
    sub.u32 %r23, %r26, %r18;
    mul.wide.s32 %rd12, %r10, %r17;
    add.u32 %r9, %r14, 65535;
    cvt.s32.s64 %r12, %rd12;
    and.b32 %r6, %r17, %r23;
    add.u32 %r10, %r26, 8;
    min.s32 %r5, %r17, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
