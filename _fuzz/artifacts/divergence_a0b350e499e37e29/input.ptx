.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd9, %r3, %r3;
    min.u64 %rd11, %rd9, %rd9;
    sub.u32 %r23, %r3, 5;
    cvt.s64.s32 %rd13, %r3;
    max.s32 %r5, %r23, %r3;
    add.u32 %r6, %r5, 4;
    mul.lo.s64 %rd8, %rd11, %rd11;
    xor.b32 %r16, %r6, %r23;
    shl.b32 %r21, %r3, 31;
    add.s32 %r5, %r6, 63;
    cvt.s32.s64 %r7, %rd13;
    min.u64 %rd5, %rd9, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
