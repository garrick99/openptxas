.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p2, %r3, 0;
    @%p2 or.b32 %r27, %r3, 64;
    shl.b32 %r20, %r3, 30;
    sub.u32 %r19, %r27, %r3;
    mad.lo.s32 %r9, %r20, %r19, %r20;
    cvt.u64.u32 %rd6, %r9;
    max.u32 %r27, %r19, %r9;
    and.b32 %r20, %r19, %r3;
    setp.gt.u32 %p2, %r20, 63;
    @%p2 min.u32 %r4, %r19, %r9;
    min.u32 %r23, %r9, %r4;
    shl.b64 %rd13, %rd6, 0;
    shr.u64 %rd15, %rd13, 0;
    shl.b32 %r5, %r20, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
