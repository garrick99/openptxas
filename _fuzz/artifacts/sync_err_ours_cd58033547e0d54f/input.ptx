.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r5, %r3, 1;
    shr.s32 %r15, %r3, 15;
    mul.wide.u32 %rd6, %r5, %r3;
    shr.s64 %rd11, %rd6, 15;
    max.u32 %r18, %r3, %r15;
    max.u32 %r17, %r15, %r5;
    add.s32 %r20, %r15, 256;
    shl.b32 %r7, %r18, 1;
    cvt.s64.s32 %rd14, %r7;
    sub.u32 %r12, %r18, %r3;
    xor.b32 %r27, %r5, 255;
    setp.ge.s32 %p2, %r15, 5;
    max.u32 %r20, %r27, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
