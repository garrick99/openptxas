.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    or.b32 %r8, %r3, 5;
    shr.s32 %r12, %r3, 2;
    or.b32 %r14, %r12, %r12;
    max.s32 %r11, %r8, 8;
    shl.b32 %r14, %r12, 2;
    shr.s32 %r22, %r11, 2;
    min.u32 %r12, %r22, %r22;
    shr.u32 %r6, %r3, 3;
    shr.s64 %rd12, %rd13, 7;
    min.s32 %r21, %r6, 7;
    shl.b32 %r17, %r22, 0;
    setp.ls.u32 %p2, %r12, 1;
    @%p2 sub.u32 %r15, %r17, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
