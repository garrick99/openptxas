.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r25, %r3, %r3;
    setp.ne.u32 %p4, %r25, 65536;
    and.b32 %r16, %r3, 2;
    shr.s32 %r5, %r3, 31;
    or.b32 %r10, %r3, 1;
    add.s32 %r14, %r5, %r25;
    and.b32 %r22, %r5, %r3;
    selp.b32 %r24, %r10, %r10, %p4;
    cvt.s64.s32 %rd13, %r22;
    cvt.s32.s64 %r18, %rd13;
    min.u32 %r21, %r18, 65535;
    max.u32 %r20, %r22, 65536;
    add.u32 %r21, %r5, %r24;
    or.b32 %r7, %r3, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
