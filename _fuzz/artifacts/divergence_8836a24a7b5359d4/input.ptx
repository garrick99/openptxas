.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p4, %r3, 8;
    @!%p4 add.s32 %r5, %r3, %r3;
    shr.u32 %r23, %r5, 4;
    mad.lo.s32 %r25, %r23, %r23, %r3;
    cvt.s64.s32 %rd8, %r3;
    sub.s32 %r16, %r3, %r3;
    shr.s64 %rd10, %rd8, 47;
    shl.b64 %rd14, %rd10, 47;
    max.u32 %r21, %r3, 8;
    cvt.s32.s64 %r8, %rd14;
    cvt.s64.s32 %rd12, %r5;
    max.s64 %rd10, %rd14, %rd8;
    selp.b32 %r20, %r25, %r23, %p4;
    shr.s32 %r11, %r23, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
