.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    shl.b32 %r16, %r3, 0;
    max.u32 %r4, %r3, 4294967295;
    and.b32 %r23, %r3, 1;
    add.u64 %rd11, %rd5, %rd5;
    cvt.s32.s64 %r10, %rd11;
    add.u32 %r16, %r16, %r10;
    shl.b64 %rd5, %rd5, 2;
    mul.lo.s32 %r17, %r3, 7;
    shr.s64 %rd13, %rd11, 2;
    shr.u32 %r24, %r10, 7;
    and.b32 %r27, %r10, %r16;
    shr.s64 %rd13, %rd5, 31;
    min.u64 %rd8, %rd11, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
