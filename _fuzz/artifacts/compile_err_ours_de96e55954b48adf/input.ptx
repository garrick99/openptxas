.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p2, %r3, %r0;
    vote.sync.ballot.b32 %r17, %p2, -1;
    and.b32 %r14, %r0, %r0;
    shfl.sync.down.b32 %r7, %r3, 2, 0x1f, -1;
    shfl.sync.down.b32 %r4, %r7, 16, 0x1f, -1;
    min.u32 %r7, %r17, %r3;
    setp.ne.u32 %p2, %r7, 7;
    vote.sync.ballot.b32 %r7, %p2, -1;
    min.u32 %r12, %r14, %r7;
    or.b32 %r16, %r17, %r14;
    vote.sync.all.pred %p2, %p2, -1;
    vote.sync.any.pred %p3, %p2, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
