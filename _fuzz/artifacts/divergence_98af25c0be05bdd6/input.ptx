.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    and.b64 %rd11, %rd9, %rd9;
    shl.b32 %r6, %r3, 4;
    shl.b32 %r21, %r6, 30;
    mul.wide.s32 %rd14, %r3, %r6;
    or.b32 %r16, %r21, 31;
    or.b32 %r18, %r3, %r3;
    setp.ls.u32 %p2, %r21, 8;
    @!%p2 or.b32 %r9, %r3, %r3;
    sub.s32 %r8, %r16, 65535;
    max.u32 %r22, %r8, 7;
    cvt.s32.s64 %r22, %rd11;
    add.s32 %r23, %r9, %r3;
    mul.lo.u32 %r11, %r3, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
