.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p1, %r3, 65536;
    @%p1 max.u32 %r20, %r3, 32;
    or.b32 %r22, %r20, %r20;
    add.u32 %r14, %r22, 63;
    max.s32 %r25, %r20, 16;
    cvt.u64.u32 %rd13, %r20;
    mul.lo.u32 %r4, %r20, 16;
    selp.b32 %r17, %r14, %r20, %p1;
    sub.s32 %r10, %r17, 65536;
    setp.lt.s32 %p2, %r17, %r10;
    setp.ne.u32 %p4, %r3, 7;
    @!%p4 mul.lo.u32 %r4, %r22, %r20;
    mad.lo.u32 %r26, %r10, %r25, %r4;
    max.u32 %r17, %r20, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
