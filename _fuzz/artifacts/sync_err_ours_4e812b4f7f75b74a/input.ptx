.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r18, %r3, 63;
    mul.lo.u32 %r19, %r18, 256;
    max.s32 %r14, %r19, %r3;
    min.s32 %r11, %r3, %r18;
    max.s32 %r11, %r14, 0;
    sub.s32 %r21, %r19, 16;
    sub.u32 %r5, %r14, %r11;
    mul.wide.u32 %rd11, %r21, %r19;
    mad.lo.s32 %r11, %r3, %r21, %r18;
    cvt.u32.u64 %r23, %rd11;
    shr.u64 %rd9, %rd11, 0;
    shr.u32 %r18, %r11, 2;
    xor.b32 %r26, %r3, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
