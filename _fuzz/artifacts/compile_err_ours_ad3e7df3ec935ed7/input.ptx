.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r7, %r0, %r0;
    setp.eq.u32 %p3, %r0, 7;
    vote.sync.ballot.b32 %r16, %p3, -1;
    sub.u32 %r13, %r3, %r3;
    setp.ne.u32 %p2, %r0, 2147483647;
    vote.sync.ballot.b32 %r9, %p2, -1;
    or.b32 %r8, %r9, %r7;
    shfl.sync.up.b32 %r9, %r3, 2, 0x1f, -1;
    vote.sync.any.pred %p2, %p2, -1;
