.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd13, %r3, %r3;
    and.b32 %r25, %r3, %r3;
    or.b32 %r19, %r3, 1;
    max.u64 %rd5, %rd13, %rd13;
    mul.wide.u32 %rd14, %r19, %r19;
    shl.b32 %r23, %r3, 31;
    max.s32 %r18, %r3, 4294967295;
    or.b32 %r21, %r25, %r25;
    shr.s64 %rd11, %rd13, 2;
    setp.ne.u32 %p2, %r21, 2147483648;
    selp.b32 %r15, %r18, %r23, %p2;
    xor.b64 %rd8, %rd11, %rd5;
    add.u32 %r15, %r18, 65536;
    max.s32 %r15, %r3, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
