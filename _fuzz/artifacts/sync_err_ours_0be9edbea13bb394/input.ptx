.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r22, %r3, %r3;
    cvt.s64.s32 %rd10, %r22;
    shr.s32 %r6, %r3, 31;
    mul.lo.u32 %r15, %r22, %r6;
    sub.u32 %r9, %r15, %r6;
    max.s32 %r10, %r9, 8;
    cvt.s64.s32 %rd12, %r15;
    mul.wide.u32 %rd12, %r3, %r6;
    setp.ne.s32 %p1, %r3, %r10;
    @%p1 mad.lo.s32 %r4, %r6, %r6, %r6;
    min.u32 %r24, %r4, 65535;
    mul.wide.s32 %rd10, %r10, %r24;
    max.u32 %r24, %r6, 5;
    max.u32 %r9, %r3, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
