.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r9, %r3, 3;
    mul.lo.u32 %r16, %r3, 7;
    setp.gt.s32 %p1, %r3, 7;
    @%p1 mul.wide.u32 %rd10, %r3, %r16;
    max.u32 %r12, %r3, %r3;
    shr.u64 %rd11, %rd10, 3;
    min.s32 %r10, %r9, 65535;
    min.u32 %r23, %r9, %r10;
    max.u32 %r16, %r23, %r23;
    selp.b32 %r9, %r23, %r23, %p1;
    setp.le.s32 %p4, %r16, %r10;
    @%p4 and.b32 %r17, %r16, %r9;
    shl.b32 %r9, %r9, 7;
    max.s64 %rd13, %rd10, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
