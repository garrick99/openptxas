.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r15, %r3, 4;
    max.s32 %r20, %r3, %r15;
    sub.s32 %r16, %r15, 64;
    sub.s32 %r17, %r16, %r15;
    setp.hi.u32 %p4, %r20, 0;
    @%p4 cvt.s64.s32 %rd8, %r15;
    xor.b32 %r24, %r15, 32;
    shr.s32 %r7, %r16, 4;
    mad.lo.s32 %r8, %r16, %r15, %r16;
    selp.b32 %r23, %r17, %r24, %p4;
    setp.lo.u32 %p2, %r3, %r17;
    @!%p2 selp.b32 %r8, %r24, %r16, %p4;
    sub.u32 %r25, %r8, %r16;
    setp.lt.s32 %p2, %r15, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
