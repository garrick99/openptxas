.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    shr.s32 %r14, %r3, 0;
    and.b32 %r16, %r3, 255;
    mul.wide.s32 %rd10, %r14, %r16;
    sub.s64 %rd13, %rd12, %rd10;
    mul.wide.s32 %rd11, %r16, %r16;
    max.s32 %r16, %r16, 5;
    mul.lo.u32 %r4, %r3, 8;
    shl.b32 %r13, %r4, 15;
    cvt.s32.s64 %r22, %rd10;
    max.u32 %r17, %r14, %r16;
    sub.u32 %r27, %r13, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
