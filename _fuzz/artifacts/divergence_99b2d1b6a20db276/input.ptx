.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r21, %r3, 63;
    cvt.u64.u32 %rd11, %r3;
    setp.gt.s32 %p4, %r3, 32;
    @%p4 and.b32 %r13, %r21, 16;
    setp.ne.s32 %p1, %r21, %r21;
    @%p1 mul.lo.u32 %r25, %r13, 64;
    add.u64 %rd10, %rd11, %rd11;
    add.s32 %r26, %r3, %r25;
    mad.lo.u32 %r13, %r21, %r21, %r25;
    selp.b32 %r4, %r21, %r25, %p4;
    selp.b32 %r6, %r13, %r26, %p1;
    shr.s64 %rd15, %rd10, 16;
    shl.b32 %r17, %r6, 16;
    sub.u32 %r16, %r4, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
