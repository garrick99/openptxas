.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r23, %r3, %r3;
    setp.lo.u32 %p4, %r3, %r3;
    @!%p4 and.b32 %r19, %r3, %r23;
    mad.lo.u32 %r23, %r19, %r3, %r23;
    min.u32 %r19, %r23, %r23;
    and.b32 %r12, %r23, 15;
    cvt.u64.u32 %rd11, %r12;
    or.b32 %r13, %r19, %r3;
    min.s32 %r24, %r13, 0;
    shl.b32 %r15, %r24, 30;
    selp.b32 %r18, %r24, %r12, %p4;
    shl.b64 %rd6, %rd11, 1;
    selp.b32 %r15, %r23, %r19, %p4;
    shl.b64 %rd5, %rd11, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
