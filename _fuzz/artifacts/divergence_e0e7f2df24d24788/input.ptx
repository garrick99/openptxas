.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r20, %r3, 2147483647;
    shl.b32 %r21, %r3, 30;
    mad.lo.s32 %r9, %r21, %r21, %r20;
    cvt.s64.s32 %rd6, %r21;
    shr.u64 %rd9, %rd6, 7;
    mul.wide.s32 %rd15, %r9, %r9;
    sub.s32 %r16, %r20, 2;
    and.b32 %r6, %r9, %r9;
    setp.ne.s32 %p4, %r16, %r20;
    @!%p4 mul.wide.s32 %rd14, %r6, %r3;
    setp.gt.s32 %p3, %r21, %r9;
    @!%p3 or.b32 %r5, %r9, 1;
    mul.lo.s32 %r8, %r21, %r16;
    max.s32 %r8, %r9, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
