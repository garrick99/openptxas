.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r11, %r3, 63;
    cvt.u64.u32 %rd6, %r11;
    add.s32 %r25, %r3, 32;
    min.u32 %r5, %r3, 7;
    xor.b32 %r10, %r5, %r3;
    shr.s64 %rd12, %rd6, 2;
    shr.u32 %r23, %r11, 3;
    max.s32 %r18, %r23, %r10;
    shr.s32 %r20, %r10, 31;
    setp.lt.u32 %p4, %r18, 2;
    @%p4 mad.lo.s32 %r15, %r25, %r11, %r20;
    mul.wide.s32 %rd7, %r15, %r20;
    setp.hi.u32 %p4, %r15, %r18;
    sub.u64 %rd13, %rd12, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
