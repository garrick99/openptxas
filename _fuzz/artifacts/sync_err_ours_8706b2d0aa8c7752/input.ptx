.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r14, %r3, %r3;
    min.u32 %r18, %r3, %r14;
    mul.lo.u32 %r19, %r18, 65536;
    mul.wide.s32 %rd5, %r18, %r3;
    cvt.u32.u64 %r26, %rd5;
    mad.lo.u32 %r8, %r26, %r18, %r3;
    xor.b32 %r19, %r19, %r3;
    mul.wide.s32 %rd15, %r14, %r19;
    max.u32 %r16, %r19, 4;
    shr.s32 %r25, %r26, 30;
    sub.u32 %r19, %r25, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
