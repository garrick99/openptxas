.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r20, %r3, 256;
    or.b32 %r18, %r3, 31;
    mul.wide.u32 %rd5, %r3, %r20;
    setp.le.u32 %p1, %r18, %r18;
    @!%p1 selp.b32 %r25, %r18, %r20, %p1;
    mul.wide.u32 %rd6, %r20, %r25;
    and.b32 %r23, %r3, 2147483648;
    cvt.u32.u64 %r24, %rd6;
    setp.le.s32 %p2, %r23, 4294967295;
    @%p2 max.u32 %r6, %r3, %r3;
    shl.b32 %r19, %r6, 1;
    setp.hs.u32 %p3, %r23, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
