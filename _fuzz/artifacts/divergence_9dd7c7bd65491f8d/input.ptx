.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r14, %r3, %r3, %r3;
    and.b32 %r5, %r14, 3;
    and.b32 %r10, %r3, %r3;
    setp.le.s32 %p4, %r10, 64;
    @%p4 sub.u32 %r23, %r3, 255;
    setp.lt.u32 %p2, %r10, 0;
    @!%p2 mad.lo.u32 %r21, %r3, %r10, %r14;
    cvt.u64.u32 %rd11, %r3;
    shr.s32 %r21, %r14, 30;
    shr.s32 %r9, %r3, 30;
    shr.s64 %rd8, %rd11, 62;
    cvt.s32.s64 %r24, %rd8;
    sub.u32 %r21, %r3, 7;
    min.u32 %r24, %r10, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
