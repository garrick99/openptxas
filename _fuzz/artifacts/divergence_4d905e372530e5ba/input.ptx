.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r5, %r3, 31;
    mul.wide.s32 %rd10, %r5, %r5;
    add.u32 %r12, %r5, 1;
    mad.lo.s32 %r7, %r3, %r5, %r3;
    max.s32 %r20, %r3, %r3;
    min.s64 %rd5, %rd10, %rd10;
    setp.lt.s32 %p2, %r5, %r5;
    @%p2 sub.u32 %r22, %r7, 65536;
    max.s32 %r22, %r3, %r22;
    shr.s32 %r25, %r5, 3;
    mad.lo.s32 %r24, %r3, %r20, %r25;
    xor.b32 %r22, %r24, 7;
    mul.lo.s32 %r8, %r5, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
