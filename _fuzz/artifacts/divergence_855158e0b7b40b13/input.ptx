.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    shr.s64 %rd15, %rd7, 0;
    shr.u32 %r11, %r3, 0;
    shr.u64 %rd14, %rd7, 0;
    shr.u32 %r22, %r11, 0;
    mad.lo.u32 %r22, %r3, %r22, %r22;
    shr.u64 %rd15, %rd15, 1;
    cvt.s64.s32 %rd15, %r22;
    max.u32 %r18, %r3, 256;
    mad.lo.s32 %r19, %r22, %r3, %r18;
    mul.wide.u32 %rd8, %r19, %r11;
    max.s32 %r6, %r11, 5;
    shr.s64 %rd5, %rd8, 2;
    sub.s32 %r27, %r11, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
