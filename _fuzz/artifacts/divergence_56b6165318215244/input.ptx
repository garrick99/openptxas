.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    max.s32 %r26, %r3, 15;
    setp.gt.s32 %p3, %r3, %r3;
    @%p3 xor.b32 %r7, %r3, %r26;
    sub.u32 %r20, %r7, %r7;
    and.b32 %r11, %r26, 15;
    mad.lo.s32 %r20, %r11, %r7, %r3;
    mul.wide.s32 %rd12, %r7, %r11;
    mul.wide.s32 %rd14, %r20, %r20;
    cvt.u32.u64 %r7, %rd14;
    cvt.u64.u32 %rd12, %r11;
    add.s32 %r24, %r26, 255;
    mad.lo.s32 %r18, %r26, %r20, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
