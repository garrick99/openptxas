.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r24, %r3, 31;
    min.u32 %r4, %r3, %r24;
    max.u32 %r26, %r4, %r3;
    cvt.u64.u32 %rd15, %r3;
    shr.u64 %rd8, %rd15, 33;
    min.s32 %r20, %r26, 32;
    min.s32 %r20, %r3, 65536;
    mul.wide.s32 %rd7, %r3, %r26;
    xor.b32 %r9, %r26, %r20;
    max.u64 %rd10, %rd15, %rd7;
    sub.s32 %r8, %r9, %r9;
    setp.eq.s32 %p3, %r20, 1;
    @%p3 shl.b32 %r19, %r24, 30;
    max.s32 %r22, %r19, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
