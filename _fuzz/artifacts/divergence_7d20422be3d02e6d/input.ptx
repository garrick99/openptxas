.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r8, %r3, %r3;
    cvt.u64.u32 %rd5, %r3;
    cvt.u64.u32 %rd15, %r8;
    setp.le.u32 %p1, %r8, %r8;
    @%p1 max.s32 %r21, %r3, %r8;
    mul.lo.s32 %r4, %r8, 2147483647;
    mul.lo.s32 %r27, %r8, 31;
    sub.s32 %r18, %r21, 63;
    mul.wide.u32 %rd6, %r27, %r3;
    shl.b32 %r21, %r4, 3;
    sub.u32 %r4, %r21, %r27;
    add.s64 %rd14, %rd5, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
