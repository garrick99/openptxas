.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r4, %r3, 4;
    cvt.u64.u32 %rd6, %r3;
    max.s32 %r25, %r4, %r3;
    and.b32 %r23, %r25, %r3;
    max.u32 %r13, %r25, %r23;
    mad.lo.u32 %r15, %r3, %r3, %r25;
    max.u32 %r12, %r13, %r15;
    max.u32 %r22, %r3, 5;
    sub.s32 %r25, %r15, 16;
    setp.lt.u32 %p2, %r13, %r3;
    @%p2 selp.b32 %r26, %r25, %r3, %p2;
    min.u32 %r10, %r23, %r12;
    shr.s32 %r20, %r3, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
