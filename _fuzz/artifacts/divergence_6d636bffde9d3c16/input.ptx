.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r6, %r3, %r3;
    shr.s32 %r13, %r3, 3;
    setp.eq.s32 %p1, %r3, 255;
    @%p1 and.b32 %r25, %r3, %r3;
    cvt.s64.s32 %rd11, %r25;
    mad.lo.s32 %r22, %r25, %r3, %r3;
    or.b32 %r15, %r13, 255;
    setp.hi.u32 %p1, %r6, 5;
    @%p1 sub.u32 %r18, %r3, %r15;
    mad.lo.s32 %r16, %r25, %r6, %r15;
    max.s64 %rd11, %rd11, %rd11;
    mad.lo.s32 %r7, %r16, %r13, %r3;
    add.s32 %r18, %r6, %r18;
    cvt.s32.s64 %r15, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
