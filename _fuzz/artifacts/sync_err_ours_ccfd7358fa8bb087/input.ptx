.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r12, %r3, 4294967295;
    mul.lo.u32 %r9, %r12, %r3;
    mul.wide.s32 %rd15, %r3, %r9;
    mul.lo.s32 %r17, %r9, 7;
    cvt.s32.s64 %r27, %rd15;
    setp.hs.u32 %p4, %r17, %r12;
    shr.s32 %r14, %r3, 7;
    setp.gt.u32 %p1, %r17, %r27;
    @%p1 shr.u32 %r22, %r27, 3;
    shr.s64 %rd6, %rd15, 31;
    add.u32 %r9, %r22, %r14;
    setp.lo.u32 %p1, %r14, %r14;
    @%p1 mul.lo.s32 %r26, %r17, 3;
    and.b32 %r14, %r17, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
