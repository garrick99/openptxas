.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p3, %r0, 8;
    vote.sync.ballot.b32 %r13, %p3, -1;
    setp.eq.u32 %p3, %r13, %r3;
    vote.sync.ballot.b32 %r16, %p3, -1;
    shfl.sync.up.b32 %r6, %r0, 4, 0x1f, -1;
    setp.gt.u32 %p3, %r6, 15;
    vote.sync.ballot.b32 %r18, %p3, -1;
    shfl.sync.up.b32 %r8, %r16, 4, 0x1f, -1;
    and.b32 %r4, %r16, %r13;
    setp.le.u32 %p2, %r0, 255;
    vote.sync.ballot.b32 %r5, %p2, -1;
    vote.sync.any.pred %p3, %p3, -1;
    and.b32 %r6, %r5, %r18;
    shfl.sync.down.b32 %r5, %r3, 4, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
