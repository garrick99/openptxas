    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r12, %r3, %r3;
    sub.u32 %r12, %r3, 5;
    mul.wide.u32 %rd14, %r3, %r12;
    sub.s32 %r18, %r12, 2147483648;
