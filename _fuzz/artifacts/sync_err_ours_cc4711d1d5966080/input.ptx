.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r4, %r3, %r3;
    cvt.u64.u32 %rd11, %r4;
    mad.lo.s32 %r19, %r3, %r4, %r4;
    shr.u64 %rd7, %rd11, 47;
    cvt.s32.s64 %r26, %rd11;
    shr.s32 %r5, %r26, 15;
    or.b32 %r16, %r5, 1;
    cvt.u64.u32 %rd15, %r3;
    shl.b32 %r24, %r4, 16;
    add.s32 %r16, %r3, 7;
    mul.wide.s32 %rd15, %r24, %r5;
    mul.wide.u32 %rd6, %r26, %r3;
    max.u64 %rd8, %rd6, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
