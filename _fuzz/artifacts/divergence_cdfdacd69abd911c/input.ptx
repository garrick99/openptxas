.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r22, %r3, %r3;
    min.u32 %r11, %r3, %r3;
    setp.le.u32 %p2, %r11, 15;
    @%p2 selp.b32 %r16, %r22, %r3, %p2;
    and.b32 %r21, %r16, 63;
    mad.lo.u32 %r22, %r3, %r3, %r16;
    cvt.s64.s32 %rd9, %r11;
    cvt.u32.u64 %r5, %rd9;
    shr.s32 %r10, %r5, 7;
    shr.s32 %r17, %r11, 3;
    shl.b64 %rd13, %rd9, 2;
    or.b32 %r27, %r16, 2;
    or.b64 %rd11, %rd13, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
