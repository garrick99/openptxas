.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p3, %r3, 4;
    cvt.u64.u32 %rd7, %r3;
    min.s32 %r18, %r3, 2;
    selp.b32 %r18, %r3, %r18, %p3;
    max.s32 %r19, %r18, 0;
    shr.u64 %rd8, %rd7, 2;
    and.b32 %r20, %r19, %r19;
    selp.b32 %r15, %r20, %r20, %p3;
    or.b32 %r11, %r15, %r19;
    mad.lo.u32 %r14, %r15, %r3, %r15;
    cvt.s64.s32 %rd8, %r11;
    shl.b64 %rd15, %rd7, 2;
    max.s64 %rd12, %rd8, %rd15;
    cvt.s64.s32 %rd6, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
