.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    or.b32 %r20, %r3, %r3;
    or.b32 %r24, %r3, %r3;
    shr.u64 %rd8, %rd7, 62;
    shl.b64 %rd13, %rd8, 16;
    max.u32 %r10, %r20, %r24;
    shr.s32 %r18, %r3, 7;
    setp.hi.u32 %p1, %r3, 64;
    max.s32 %r21, %r24, 64;
    add.s64 %rd15, %rd8, %rd7;
    and.b32 %r13, %r24, %r18;
    sub.s32 %r24, %r24, %r13;
    setp.lt.s32 %p1, %r24, %r21;
    mad.lo.s32 %r4, %r21, %r20, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
