.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    max.u32 %r18, %r3, 4;
    xor.b32 %r13, %r3, %r18;
    min.s64 %rd13, %rd6, %rd6;
    shr.s32 %r24, %r3, 3;
    mul.lo.u32 %r20, %r24, 8;
    min.u32 %r8, %r20, 65536;
    mul.lo.s32 %r20, %r13, %r20;
    max.s32 %r8, %r8, 2;
    shr.u32 %r21, %r13, 0;
    sub.s32 %r21, %r21, %r8;
    sub.s32 %r10, %r20, 2;
    sub.s32 %r19, %r21, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
