.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r10, %r3, 64;
    mul.lo.u32 %r13, %r10, 255;
    mul.wide.u32 %rd10, %r10, %r3;
    xor.b64 %rd9, %rd10, %rd10;
    cvt.u32.u64 %r7, %rd9;
    xor.b32 %r8, %r13, 2;
    sub.s32 %r26, %r13, %r3;
    mad.lo.u32 %r15, %r26, %r3, %r10;
    setp.eq.u32 %p4, %r13, %r10;
    @%p4 sub.u32 %r24, %r26, 32;
    setp.ne.u32 %p2, %r13, %r26;
    @%p2 mul.lo.s32 %r20, %r8, 32;
    or.b32 %r6, %r15, %r24;
    shr.u32 %r23, %r20, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
