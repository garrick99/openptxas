.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r19, %r3, %r3;
    sub.u32 %r12, %r3, %r19;
    max.u32 %r22, %r19, 64;
    add.u32 %r21, %r22, 1;
    mad.lo.u32 %r17, %r22, %r22, %r22;
    cvt.s64.s32 %rd9, %r17;
    mad.lo.u32 %r12, %r21, %r3, %r21;
    shr.s32 %r13, %r22, 0;
    sub.s32 %r18, %r3, %r13;
    setp.ne.u32 %p2, %r22, 0;
    mul.lo.u32 %r9, %r18, %r19;
    shr.u64 %rd10, %rd9, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
