.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r11, %r3, 65535;
    shr.u32 %r20, %r3, 3;
    cvt.u64.u32 %rd7, %r20;
    sub.s64 %rd12, %rd7, %rd7;
    xor.b32 %r6, %r20, %r20;
    sub.s32 %r23, %r20, 32;
    add.u32 %r26, %r20, %r23;
    cvt.s32.s64 %r4, %rd7;
    mul.wide.u32 %rd11, %r23, %r20;
    shl.b64 %rd7, %rd11, 32;
    max.u64 %rd14, %rd11, %rd12;
    or.b64 %rd12, %rd11, %rd7;
    setp.hi.u32 %p1, %r6, %r20;
    @!%p1 shr.u32 %r26, %r26, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
