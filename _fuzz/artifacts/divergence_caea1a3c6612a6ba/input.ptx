.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r24, %r3, 31;
    min.u32 %r15, %r3, %r24;
    shr.s32 %r17, %r24, 30;
    setp.le.s32 %p3, %r15, 255;
    or.b32 %r4, %r24, 2147483648;
    mul.wide.u32 %rd9, %r17, %r3;
    add.s32 %r4, %r17, %r3;
    cvt.s64.s32 %rd5, %r4;
    add.u32 %r18, %r17, 31;
    cvt.u64.u32 %rd9, %r4;
    setp.ne.u32 %p4, %r18, %r18;
    @%p4 shl.b32 %r25, %r17, 4;
    cvt.u64.u32 %rd7, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
