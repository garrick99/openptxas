.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r12, %r3, 30;
    shl.b32 %r18, %r3, 3;
    shl.b32 %r25, %r3, 2;
    shr.u32 %r27, %r18, 16;
    cvt.u64.u32 %rd10, %r25;
    shr.u32 %r4, %r18, 1;
    max.u32 %r11, %r4, 3;
    sub.s32 %r13, %r12, 1;
    min.u32 %r10, %r3, 15;
    add.s64 %rd5, %rd10, %rd10;
    cvt.s32.s64 %r26, %rd5;
    mad.lo.u32 %r4, %r10, %r27, %r25;
    min.s32 %r12, %r25, 63;
    shr.u32 %r18, %r10, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
