.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    cvt.s64.s32 %rd6, %r3;
    mul.wide.s32 %rd15, %r3, %r3;
    or.b64 %rd6, %rd15, %rd15;
    min.s32 %r5, %r3, 1;
    min.s32 %r5, %r3, 63;
    setp.ls.u32 %p2, %r5, %r5;
    add.s64 %rd8, %rd6, %rd15;
    and.b64 %rd15, %rd13, %rd13;
    min.s64 %rd9, %rd6, %rd15;
    cvt.s32.s64 %r10, %rd13;
    or.b32 %r25, %r3, %r3;
    cvt.s32.s64 %r5, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
