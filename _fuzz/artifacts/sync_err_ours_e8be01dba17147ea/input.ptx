.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    add.s32 %r9, %r3, 1;
    setp.le.u32 %p2, %r9, 31;
    setp.lt.s32 %p4, %r9, %r9;
    cvt.s32.s64 %r8, %rd5;
    shr.s32 %r5, %r3, 3;
    sub.u32 %r22, %r3, %r3;
    shr.s64 %rd7, %rd5, 7;
    max.u64 %rd10, %rd5, %rd5;
    add.u64 %rd5, %rd5, %rd10;
    selp.b32 %r11, %r9, %r9, %p2;
    max.s32 %r8, %r11, 2;
    max.u64 %rd11, %rd10, %rd5;
    setp.ge.s32 %p4, %r22, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
