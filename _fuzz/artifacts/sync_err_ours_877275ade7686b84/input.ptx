.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd11, %r3, %r3;
    sub.s32 %r6, %r3, %r3;
    add.u32 %r22, %r6, %r3;
    mul.wide.u32 %rd13, %r3, %r3;
    max.s32 %r14, %r3, %r3;
    shr.u64 %rd9, %rd11, 63;
    cvt.u32.u64 %r7, %rd11;
    mul.wide.s32 %rd5, %r3, %r3;
    setp.ge.u32 %p4, %r6, 32;
    setp.gt.s32 %p1, %r6, %r14;
    min.u64 %rd13, %rd9, %rd13;
    mul.wide.u32 %rd6, %r6, %r7;
    setp.lt.s32 %p2, %r22, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
