.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    cvt.u32.u64 %r11, %rd14;
    min.u32 %r18, %r3, %r11;
    mul.lo.s32 %r8, %r3, 3;
    cvt.s64.s32 %rd13, %r11;
    mad.lo.u32 %r8, %r11, %r11, %r3;
    xor.b32 %r25, %r18, %r11;
    or.b32 %r26, %r11, %r11;
    cvt.s32.s64 %r6, %rd13;
    mul.wide.u32 %rd8, %r8, %r18;
    sub.s32 %r7, %r18, 2;
    cvt.s64.s32 %rd15, %r25;
    shr.u32 %r6, %r8, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
