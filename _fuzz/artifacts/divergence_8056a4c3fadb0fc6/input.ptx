.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd11, %r3, %r3;
    setp.eq.u32 %p1, %r3, 63;
    setp.ne.s32 %p1, %r3, %r3;
    @%p1 mul.lo.s32 %r26, %r3, %r3;
    mad.lo.u32 %r9, %r26, %r26, %r26;
    min.u32 %r5, %r3, 16;
    min.s32 %r10, %r5, 3;
    or.b32 %r7, %r5, 2147483647;
    mul.wide.u32 %rd6, %r7, %r26;
    setp.hi.u32 %p1, %r9, 7;
    cvt.u32.u64 %r12, %rd11;
    shr.u32 %r7, %r10, 16;
    shr.u32 %r18, %r9, 15;
    shr.s64 %rd10, %rd11, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
