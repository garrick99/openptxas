.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r7, %r3, 5;
    min.u32 %r17, %r7, %r3;
    min.s32 %r10, %r17, 256;
    max.u32 %r5, %r10, %r10;
    add.u32 %r7, %r17, %r7;
    setp.hi.u32 %p2, %r3, 32;
    @%p2 sub.u32 %r24, %r10, 8;
    cvt.s64.s32 %rd7, %r17;
    setp.ls.u32 %p2, %r10, %r24;
    @!%p2 xor.b32 %r12, %r17, 63;
    setp.lo.u32 %p2, %r5, 0;
    @%p2 sub.s32 %r16, %r12, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
