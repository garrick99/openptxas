.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p1, %r3, %r3;
    and.b32 %r26, %r3, %r3;
    setp.le.u32 %p2, %r3, %r3;
    mul.wide.u32 %rd11, %r26, %r3;
    max.u32 %r19, %r3, 256;
    add.s32 %r15, %r19, %r3;
    shr.s32 %r27, %r3, 3;
    add.u32 %r16, %r3, 255;
    mul.wide.u32 %rd5, %r16, %r26;
    sub.s32 %r19, %r16, 4294967295;
    shr.s32 %r8, %r19, 15;
    shl.b32 %r8, %r26, 4;
    mul.lo.s32 %r4, %r27, %r3;
    shr.u64 %rd13, %rd5, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
