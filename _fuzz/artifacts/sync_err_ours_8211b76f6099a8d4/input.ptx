.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r5, %r3, 31;
    sub.s32 %r6, %r3, %r5;
    shl.b32 %r19, %r5, 15;
    and.b32 %r19, %r19, 15;
    shr.u32 %r10, %r5, 0;
    add.u32 %r5, %r19, 31;
    shr.u32 %r25, %r5, 4;
    setp.le.s32 %p2, %r6, %r6;
    @%p2 or.b32 %r9, %r25, 256;
    shl.b32 %r18, %r3, 4;
    max.s32 %r5, %r19, 4;
    mad.lo.u32 %r7, %r18, %r18, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
