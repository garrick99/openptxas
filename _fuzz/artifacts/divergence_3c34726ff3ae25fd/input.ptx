.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r26, %r3, %r3;
    min.u32 %r19, %r3, 63;
    min.s32 %r10, %r26, %r3;
    setp.gt.u32 %p2, %r10, 32;
    @%p2 shl.b32 %r17, %r19, 1;
    mul.wide.s32 %rd10, %r19, %r3;
    add.s32 %r5, %r10, 5;
    mul.lo.u64 %rd12, %rd10, %rd10;
    mul.wide.u32 %rd11, %r26, %r26;
    mad.lo.u32 %r9, %r3, %r3, %r10;
    or.b64 %rd6, %rd11, %rd10;
    mul.wide.s32 %rd12, %r19, %r5;
    xor.b32 %r23, %r17, 5;
    xor.b32 %r17, %r23, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
