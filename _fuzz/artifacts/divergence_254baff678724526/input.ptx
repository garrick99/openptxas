    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p2, %r3, 1;
    @%p2 selp.b32 %r19, %r3, %r3, %p2;
    max.s32 %r17, %r3, 2147483647;
    cvt.s64.s32 %rd9, %r17;
    setp.ne.s32 %p4, %r3, %r17;
    @%p4 shl.b32 %r11, %r3, 0;
    xor.b32 %r19, %r19, %r17;
