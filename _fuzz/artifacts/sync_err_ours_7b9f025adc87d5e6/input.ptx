.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r8, %r3, 4294967295;
    mul.lo.u32 %r9, %r8, %r3;
    sub.u32 %r14, %r9, %r8;
    add.u32 %r17, %r9, %r8;
    max.u32 %r5, %r17, 15;
    mad.lo.s32 %r6, %r17, %r3, %r9;
    max.u32 %r23, %r5, %r6;
    sub.u32 %r11, %r23, %r23;
    cvt.u64.u32 %rd5, %r14;
    mul.lo.s32 %r9, %r17, %r9;
    cvt.s64.s32 %rd11, %r6;
    and.b32 %r13, %r17, 64;
    mad.lo.u32 %r8, %r9, %r13, %r17;
    mul.lo.u64 %rd10, %rd11, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
