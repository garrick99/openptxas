.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p1, %r3, 16;
    cvt.u64.u32 %rd5, %r3;
    mul.lo.u32 %r9, %r3, 65536;
    or.b32 %r23, %r3, 4;
    shl.b32 %r17, %r3, 15;
    setp.lo.u32 %p3, %r9, %r9;
    @%p3 min.s32 %r5, %r3, 32;
    selp.b32 %r10, %r5, %r17, %p3;
    mad.lo.u32 %r26, %r5, %r5, %r10;
    add.s32 %r13, %r17, %r23;
    setp.ne.s32 %p1, %r13, 65535;
    @%p1 shr.s32 %r11, %r26, 31;
    or.b32 %r15, %r11, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
