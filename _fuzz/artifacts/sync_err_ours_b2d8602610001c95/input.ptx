.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r4, %r3, 4;
    add.u32 %r21, %r3, %r4;
    add.s32 %r26, %r3, %r4;
    shr.s32 %r15, %r4, 7;
    sub.u32 %r24, %r4, %r4;
    setp.ls.u32 %p1, %r24, 16;
    @!%p1 shl.b32 %r19, %r24, 30;
    mul.wide.u32 %rd13, %r3, %r3;
    shl.b64 %rd15, %rd13, 32;
    shr.u32 %r23, %r26, 2;
    mul.wide.s32 %rd9, %r21, %r15;
    min.s32 %r18, %r21, %r24;
    xor.b32 %r26, %r4, %r19;
    cvt.s32.s64 %r8, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
