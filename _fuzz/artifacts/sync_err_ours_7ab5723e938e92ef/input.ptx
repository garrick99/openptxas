.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    max.u32 %r4, %r3, 2147483647;
    min.s64 %rd7, %rd8, %rd8;
    setp.ge.s32 %p1, %r3, 63;
    selp.b32 %r13, %r4, %r4, %p1;
    add.u32 %r22, %r4, 255;
    max.u32 %r14, %r3, %r3;
    min.u32 %r15, %r13, 63;
    add.u32 %r22, %r13, %r3;
    mad.lo.s32 %r4, %r4, %r15, %r3;
    cvt.u32.u64 %r10, %rd8;
    cvt.u64.u32 %rd11, %r22;
    mul.wide.s32 %rd13, %r22, %r4;
    add.s32 %r20, %r3, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
