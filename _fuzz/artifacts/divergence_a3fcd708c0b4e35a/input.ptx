.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r19, %r3, 3;
    setp.le.u32 %p3, %r19, %r3;
    cvt.u64.u32 %rd8, %r19;
    shr.s32 %r20, %r19, 0;
    add.s64 %rd6, %rd8, %rd8;
    cvt.s32.s64 %r23, %rd8;
    max.s32 %r5, %r23, %r19;
    sub.s32 %r13, %r20, 32;
    xor.b32 %r24, %r23, %r13;
    selp.b32 %r4, %r13, %r20, %p3;
    and.b32 %r5, %r24, 63;
    xor.b32 %r27, %r4, %r19;
    selp.b32 %r8, %r23, %r3, %p3;
    mul.lo.s64 %rd12, %rd6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
