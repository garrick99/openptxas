.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r9, %r3, %r3;
    shl.b32 %r27, %r9, 2;
    setp.ge.s32 %p4, %r3, %r3;
    @%p4 shl.b32 %r12, %r27, 30;
    selp.b32 %r21, %r3, %r3, %p4;
    shl.b32 %r25, %r12, 16;
    cvt.s64.s32 %rd6, %r9;
    mul.wide.u32 %rd5, %r12, %r27;
    setp.gt.u32 %p4, %r27, 256;
    @%p4 shr.u32 %r11, %r21, 1;
    setp.ge.s32 %p3, %r11, 2;
    @%p3 sub.s32 %r4, %r25, 2147483647;
    xor.b64 %rd9, %rd6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
