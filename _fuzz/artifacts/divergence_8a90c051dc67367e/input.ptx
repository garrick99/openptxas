.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r22, %r3, %r3;
    xor.b32 %r8, %r3, 255;
    mad.lo.u32 %r6, %r8, %r8, %r22;
    setp.ne.s32 %p4, %r3, %r6;
    @%p4 cvt.u64.u32 %rd9, %r22;
    add.u32 %r21, %r22, %r6;
    sub.s32 %r23, %r22, %r21;
    cvt.s32.s64 %r17, %rd9;
    shr.u32 %r11, %r22, 3;
    mul.lo.u32 %r13, %r17, 255;
    selp.b32 %r24, %r3, %r11, %p4;
    cvt.u32.u64 %r7, %rd9;
    and.b32 %r24, %r8, 2;
    max.u64 %rd6, %rd9, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
