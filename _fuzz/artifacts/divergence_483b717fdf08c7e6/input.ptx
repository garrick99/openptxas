    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r21, %r3, 30;
    and.b32 %r6, %r21, %r3;
    sub.s32 %r7, %r21, %r21;
    add.s32 %r21, %r21, 4294967295;
    mul.wide.s32 %rd13, %r7, %r7;
    sub.u64 %rd10, %rd13, %rd13;
    mul.lo.s32 %r19, %r6, 16;
    shr.u32 %r10, %r21, 3;
