.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r4, %r3, %r3;
    shfl.sync.up.b32 %r16, %r0, 4, 0x1f, -1;
    and.b32 %r5, %r3, %r4;
    setp.gt.u32 %p3, %r4, 255;
    vote.sync.ballot.b32 %r17, %p3, -1;
    xor.b32 %r11, %r3, %r0;
    add.u32 %r15, %r5, %r11;
    shfl.sync.bfly.b32 %r13, %r15, 2, 0x1f, -1;
    or.b32 %r16, %r15, %r16;
    vote.sync.all.pred %p3, %p3, -1;
    sub.u32 %r9, %r3, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
