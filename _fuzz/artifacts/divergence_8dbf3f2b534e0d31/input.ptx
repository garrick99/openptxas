.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p2, %r3, 64;
    @%p2 min.u32 %r27, %r3, %r3;
    cvt.s64.s32 %rd14, %r27;
    max.u32 %r12, %r3, %r27;
    setp.ge.u32 %p4, %r3, %r27;
    shl.b64 %rd12, %rd14, 63;
    cvt.s64.s32 %rd7, %r27;
    sub.s32 %r7, %r3, %r12;
    min.s64 %rd5, %rd7, %rd7;
    xor.b64 %rd13, %rd5, %rd7;
    cvt.s32.s64 %r12, %rd13;
    cvt.u32.u64 %r11, %rd5;
    cvt.u32.u64 %r13, %rd13;
    add.u32 %r12, %r27, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
