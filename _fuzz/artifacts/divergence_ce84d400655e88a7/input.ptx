.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r24, %r3, %r3;
    max.s32 %r6, %r3, %r24;
    mad.lo.u32 %r24, %r24, %r24, %r6;
    or.b32 %r9, %r24, %r3;
    sub.s32 %r19, %r3, %r6;
    cvt.s64.s32 %rd13, %r9;
    shl.b32 %r15, %r9, 31;
    mul.wide.u32 %rd13, %r3, %r15;
    setp.gt.s32 %p2, %r9, 64;
    @%p2 sub.s32 %r4, %r24, %r19;
    min.u64 %rd13, %rd13, %rd13;
    setp.gt.s32 %p2, %r9, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
