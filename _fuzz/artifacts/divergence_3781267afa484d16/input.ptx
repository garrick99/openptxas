.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r17, %r3, %r3;
    cvt.u64.u32 %rd12, %r3;
    or.b32 %r11, %r3, 15;
    add.s32 %r27, %r3, %r3;
    cvt.s32.s64 %r25, %rd12;
    sub.s32 %r13, %r27, %r3;
    max.s32 %r19, %r17, 4;
    cvt.s64.s32 %rd6, %r13;
    and.b32 %r4, %r17, 1;
    cvt.u64.u32 %rd9, %r11;
    cvt.s32.s64 %r10, %rd6;
    max.u64 %rd15, %rd12, %rd9;
    mul.lo.s32 %r8, %r10, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
