.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    mul.lo.s32 %r13, %r3, %r3;
    sub.u32 %r17, %r3, %r3;
    add.s32 %r15, %r17, %r17;
    mad.lo.u32 %r22, %r15, %r15, %r17;
    sub.u32 %r12, %r13, %r17;
    shr.s32 %r10, %r17, 3;
    mul.lo.u32 %r19, %r17, %r3;
    mad.lo.s32 %r19, %r22, %r13, %r3;
    shr.s64 %rd13, %rd10, 63;
    setp.lt.u32 %p3, %r19, %r3;
    setp.hi.u32 %p2, %r19, 15;
    @%p2 or.b32 %r18, %r13, 65536;
    mul.wide.s32 %rd11, %r22, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
