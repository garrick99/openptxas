.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r17, %r3, %r3;
    sub.u32 %r27, %r3, 256;
    cvt.u64.u32 %rd12, %r27;
    max.u32 %r4, %r27, 65536;
    setp.ne.s32 %p3, %r3, %r4;
    @%p3 cvt.s32.s64 %r18, %rd12;
    mul.wide.u32 %rd5, %r4, %r18;
    shr.u32 %r26, %r27, 31;
    cvt.u32.u64 %r18, %rd12;
    cvt.u32.u64 %r20, %rd5;
    sub.u32 %r18, %r27, 255;
    sub.u32 %r8, %r20, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
