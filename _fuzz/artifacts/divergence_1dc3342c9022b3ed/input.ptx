.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r19, %r3, %r3;
    mul.lo.s32 %r8, %r3, %r3;
    setp.lt.s32 %p3, %r3, 7;
    @%p3 cvt.u64.u32 %rd15, %r19;
    setp.hi.u32 %p1, %r8, 4294967295;
    @%p1 add.s32 %r21, %r3, 5;
    sub.u32 %r23, %r19, 2147483647;
    shr.s64 %rd10, %rd15, 3;
    cvt.s32.s64 %r14, %rd15;
    setp.hs.u32 %p2, %r19, %r21;
    @!%p2 and.b32 %r24, %r3, 256;
    mul.wide.u32 %rd7, %r21, %r19;
    min.s32 %r8, %r23, %r3;
    sub.u32 %r16, %r14, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
