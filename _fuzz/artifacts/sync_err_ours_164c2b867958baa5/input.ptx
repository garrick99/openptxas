.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    cvt.s32.s64 %r13, %rd11;
    shr.s32 %r13, %r3, 31;
    cvt.u32.u64 %r9, %rd11;
    mul.lo.s32 %r16, %r9, %r3;
    shr.s64 %rd15, %rd11, 47;
    cvt.s64.s32 %rd10, %r16;
    setp.hs.u32 %p2, %r3, 32;
    @!%p2 sub.u32 %r16, %r16, %r16;
    setp.eq.u32 %p4, %r13, 32;
    @%p4 mul.wide.u32 %rd15, %r9, %r3;
    cvt.s64.s32 %rd6, %r3;
    mul.lo.u32 %r15, %r3, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
