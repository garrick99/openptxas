.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    shr.u32 %r11, %r3, 0;
    cvt.u32.u64 %r6, %rd12;
    mul.lo.u32 %r7, %r3, %r3;
    sub.s32 %r15, %r7, %r6;
    xor.b32 %r14, %r11, 64;
    shl.b64 %rd6, %rd12, 16;
    mul.wide.s32 %rd8, %r3, %r14;
    sub.u32 %r10, %r3, %r6;
    cvt.u64.u32 %rd5, %r11;
    cvt.s32.s64 %r13, %rd5;
    mad.lo.u32 %r25, %r10, %r6, %r11;
    xor.b32 %r11, %r14, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
