.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p1, %r3, %r0;
    vote.sync.ballot.b32 %r7, %p1, -1;
    shfl.sync.up.b32 %r11, %r7, 2, 0x1f, -1;
    setp.ge.u32 %p1, %r11, %r7;
    vote.sync.ballot.b32 %r8, %p1, -1;
    shfl.sync.bfly.b32 %r13, %r7, 4, 0x1f, -1;
    setp.eq.u32 %p1, %r3, 31;
    vote.sync.ballot.b32 %r18, %p1, -1;
    shfl.sync.bfly.b32 %r19, %r8, 2, 0x1f, -1;
    add.u32 %r15, %r13, %r18;
    xor.b32 %r11, %r18, %r11;
    vote.sync.any.pred %p2, %p1, -1;
    add.u32 %r16, %r11, %r0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
