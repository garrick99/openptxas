    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r13, %r3, 4294967295;
    add.s32 %r7, %r13, %r13;
    shl.b32 %r4, %r3, 7;
    mul.lo.s32 %r6, %r4, %r13;
    add.u32 %r18, %r13, %r7;
    setp.ge.u32 %p1, %r6, 5;
    @%p1 mul.lo.s32 %r14, %r18, %r6;
    mul.lo.u32 %r14, %r13, %r13;
    selp.b32 %r27, %r7, %r18, %p1;
    mad.lo.u32 %r27, %r7, %r18, %r7;
    add.u32 %r21, %r7, %r7;
    or.b32 %r20, %r7, %r21;
    setp.lt.s32 %p1, %r13, 255;
    @!%p1 shl.b32 %r22, %r27, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
