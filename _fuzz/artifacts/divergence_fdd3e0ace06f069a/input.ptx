.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r8, %r3, %r3;
    min.u32 %r6, %r8, %r8;
    mul.wide.s32 %rd8, %r6, %r6;
    mul.wide.u32 %rd9, %r6, %r3;
    sub.s32 %r21, %r6, %r8;
    shl.b32 %r7, %r8, 2;
    and.b32 %r10, %r21, 4294967295;
    setp.ls.u32 %p3, %r8, %r3;
    shr.s64 %rd14, %rd8, 32;
    add.u32 %r26, %r10, 3;
    setp.gt.u32 %p4, %r21, %r8;
    @%p4 xor.b64 %rd15, %rd14, %rd9;
    sub.u32 %r22, %r8, 2147483647;
    selp.b32 %r5, %r3, %r26, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
