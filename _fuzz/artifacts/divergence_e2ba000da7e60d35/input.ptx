.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r17, %r3, 15;
    setp.ls.u32 %p2, %r3, 4;
    @!%p2 cvt.s64.s32 %rd15, %r3;
    shr.s32 %r11, %r3, 0;
    cvt.u32.u64 %r9, %rd15;
    cvt.s32.s64 %r16, %rd15;
    mul.lo.s32 %r16, %r17, 1;
    mad.lo.u32 %r5, %r9, %r9, %r3;
    sub.s32 %r22, %r16, %r17;
    mul.lo.s32 %r9, %r11, %r9;
    cvt.u32.u64 %r20, %rd15;
    shr.s64 %rd15, %rd15, 7;
    selp.b32 %r19, %r20, %r17, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
