.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r22, %r3, 64;
    mad.lo.s32 %r13, %r3, %r22, %r22;
    shr.s32 %r20, %r3, 16;
    setp.ne.u32 %p4, %r22, %r13;
    max.u32 %r13, %r22, 256;
    cvt.u64.u32 %rd8, %r3;
    mul.lo.s32 %r4, %r20, %r22;
    cvt.u64.u32 %rd7, %r4;
    add.u64 %rd13, %rd8, %rd7;
    add.s32 %r20, %r20, 15;
    mad.lo.s32 %r4, %r13, %r20, %r3;
    max.s64 %rd14, %rd13, %rd13;
    and.b32 %r24, %r4, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
