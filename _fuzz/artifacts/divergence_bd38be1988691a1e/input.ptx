.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p1, %r3, 4294967295;
    @!%p1 mad.lo.u32 %r16, %r3, %r3, %r3;
    sub.u32 %r23, %r16, %r3;
    shr.u32 %r18, %r16, 16;
    shr.s32 %r20, %r18, 7;
    sub.u32 %r27, %r18, 2;
    mad.lo.u32 %r8, %r18, %r16, %r20;
    add.s32 %r12, %r18, 256;
    xor.b32 %r12, %r27, 3;
    min.u32 %r9, %r3, %r27;
    max.u32 %r22, %r9, 65535;
    sub.u32 %r19, %r20, 65536;
    setp.ge.s32 %p2, %r19, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
