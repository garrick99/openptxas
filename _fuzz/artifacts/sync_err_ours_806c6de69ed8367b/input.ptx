.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r26, %r3, %r3, %r3;
    cvt.s64.s32 %rd7, %r26;
    setp.ne.u32 %p1, %r26, 255;
    @!%p1 selp.b32 %r19, %r26, %r26, %p1;
    add.s32 %r4, %r26, %r19;
    mul.lo.u32 %r15, %r4, %r26;
    shr.s64 %rd14, %rd7, 0;
    shr.u32 %r8, %r4, 1;
    add.s32 %r10, %r8, 16;
    shr.u32 %r25, %r3, 2;
    and.b32 %r13, %r4, 65536;
    min.s32 %r21, %r19, 255;
    max.u32 %r11, %r13, %r26;
    mad.lo.u32 %r14, %r8, %r19, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
