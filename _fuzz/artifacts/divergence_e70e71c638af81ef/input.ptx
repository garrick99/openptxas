.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p3, %r3, 2147483648;
    @%p3 xor.b32 %r23, %r3, %r3;
    and.b32 %r15, %r3, %r3;
    add.u32 %r19, %r15, %r15;
    shr.u32 %r12, %r19, 7;
    setp.eq.s32 %p3, %r15, %r19;
    @!%p3 cvt.s64.s32 %rd12, %r3;
    min.s32 %r20, %r23, 15;
    max.s32 %r25, %r12, 65536;
    mad.lo.u32 %r15, %r19, %r3, %r20;
    and.b32 %r6, %r15, %r25;
    cvt.u64.u32 %rd14, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
