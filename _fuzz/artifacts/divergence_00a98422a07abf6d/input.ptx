.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    cvt.s32.s64 %r14, %rd13;
    add.u32 %r11, %r14, 255;
    shl.b64 %rd14, %rd13, 31;
    xor.b32 %r26, %r14, %r11;
    setp.ne.s32 %p2, %r11, 0;
    @%p2 xor.b32 %r11, %r11, %r3;
    min.u32 %r27, %r14, 16;
    min.s32 %r16, %r3, 65536;
    xor.b32 %r7, %r11, 4;
    mad.lo.s32 %r24, %r14, %r16, %r11;
    shr.u64 %rd11, %rd14, 48;
    mul.wide.s32 %rd8, %r26, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
