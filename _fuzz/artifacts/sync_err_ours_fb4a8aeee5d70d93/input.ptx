.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    max.s64 %rd15, %rd5, %rd5;
    shr.u64 %rd14, %rd5, 62;
    max.u32 %r25, %r3, %r3;
    and.b32 %r27, %r3, %r25;
    cvt.s32.s64 %r10, %rd5;
    mul.lo.s32 %r20, %r3, %r10;
    cvt.u64.u32 %rd5, %r20;
    sub.u32 %r27, %r25, %r3;
    shr.u32 %r6, %r10, 30;
    shl.b32 %r11, %r27, 15;
    shr.u32 %r22, %r10, 2;
    mul.lo.s32 %r25, %r20, %r11;
    setp.ne.s32 %p2, %r6, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
