.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r15, %r3, %r3, %r3;
    mad.lo.s32 %r18, %r3, %r15, %r15;
    shl.b32 %r6, %r15, 1;
    xor.b32 %r16, %r6, %r15;
    mul.lo.u32 %r21, %r15, 64;
    max.s32 %r9, %r16, %r21;
    or.b32 %r4, %r3, 256;
    cvt.u64.u32 %rd8, %r21;
    add.u32 %r15, %r6, %r18;
    min.u64 %rd11, %rd8, %rd8;
    cvt.u32.u64 %r21, %rd8;
    max.u32 %r9, %r9, 2;
    or.b32 %r23, %r9, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
