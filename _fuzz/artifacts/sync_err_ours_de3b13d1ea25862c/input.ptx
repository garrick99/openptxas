.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r19, %r3, 2;
    shr.u32 %r16, %r3, 3;
    mul.wide.u32 %rd13, %r16, %r16;
    shl.b32 %r24, %r3, 31;
    max.u32 %r7, %r3, 65536;
    and.b64 %rd13, %rd13, %rd13;
    sub.s32 %r20, %r19, 2147483648;
    sub.s32 %r26, %r16, %r24;
    xor.b32 %r6, %r20, %r24;
    add.s32 %r14, %r3, 256;
    cvt.u64.u32 %rd11, %r20;
    shr.u32 %r11, %r16, 16;
    mul.lo.u32 %r11, %r16, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
