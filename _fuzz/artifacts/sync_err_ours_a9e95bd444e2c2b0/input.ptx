.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r4, %r3, 255;
    mul.lo.s32 %r27, %r3, 1;
    mul.lo.u32 %r8, %r27, %r4;
    mul.wide.u32 %rd11, %r4, %r8;
    setp.le.s32 %p2, %r3, 64;
    @!%p2 max.s32 %r16, %r27, %r3;
    selp.b32 %r22, %r27, %r4, %p2;
    add.u32 %r22, %r3, %r4;
    mul.lo.s32 %r11, %r27, 1;
    cvt.s32.s64 %r14, %rd11;
    mad.lo.s32 %r17, %r11, %r4, %r27;
    shr.u32 %r13, %r8, 30;
    mul.wide.s32 %rd8, %r4, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
