.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r5, %r3, 65535;
    cvt.s64.s32 %rd12, %r3;
    cvt.s32.s64 %r21, %rd12;
    or.b32 %r24, %r21, %r21;
    shr.s32 %r10, %r3, 3;
    or.b32 %r26, %r3, %r24;
    setp.eq.u32 %p3, %r26, %r26;
    @%p3 mad.lo.u32 %r26, %r24, %r3, %r5;
    selp.b32 %r17, %r26, %r3, %p3;
    min.s32 %r27, %r5, %r10;
    max.s32 %r20, %r3, %r10;
    mad.lo.u32 %r27, %r10, %r10, %r10;
    setp.lt.s32 %p4, %r10, %r17;
    @%p4 max.s32 %r21, %r27, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
