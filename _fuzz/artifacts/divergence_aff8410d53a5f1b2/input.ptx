.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    max.s64 %rd6, %rd7, %rd7;
    cvt.u64.u32 %rd6, %r3;
    shl.b32 %r24, %r3, 3;
    sub.u32 %r6, %r3, %r24;
    cvt.s32.s64 %r23, %rd6;
    shl.b32 %r16, %r6, 30;
    max.s64 %rd10, %rd6, %rd6;
    mul.lo.u64 %rd9, %rd10, %rd6;
    shr.s64 %rd15, %rd7, 32;
    setp.le.u32 %p4, %r24, 7;
    @%p4 sub.s32 %r8, %r16, %r23;
    mul.wide.u32 %rd9, %r16, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
