.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r20, %r3, 1;
    shl.b32 %r6, %r20, 2;
    cvt.s64.s32 %rd5, %r20;
    sub.s64 %rd14, %rd5, %rd5;
    mad.lo.u32 %r23, %r3, %r6, %r20;
    mul.lo.u32 %r19, %r3, %r20;
    max.u32 %r25, %r23, %r23;
    mul.wide.s32 %rd12, %r23, %r20;
    sub.u32 %r26, %r3, %r6;
    shr.s64 %rd15, %rd14, 48;
    max.s64 %rd12, %rd5, %rd14;
    min.s32 %r17, %r6, %r20;
    cvt.u64.u32 %rd11, %r17;
    cvt.s32.s64 %r16, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
