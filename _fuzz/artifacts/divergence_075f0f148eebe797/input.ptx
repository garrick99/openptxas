.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p4, %r3, 7;
    @%p4 add.s32 %r20, %r3, 5;
    setp.ne.u32 %p2, %r20, 2147483647;
    @%p2 cvt.s64.s32 %rd11, %r20;
    max.s32 %r22, %r20, 0;
    mul.lo.s32 %r6, %r20, %r22;
    max.s32 %r19, %r6, 64;
    mul.wide.s32 %rd14, %r20, %r19;
    min.u32 %r16, %r3, %r20;
    mul.lo.u32 %r24, %r19, 64;
    cvt.u32.u64 %r16, %rd11;
    or.b32 %r13, %r24, 31;
    mul.lo.s32 %r12, %r22, %r13;
    shl.b32 %r7, %r22, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
