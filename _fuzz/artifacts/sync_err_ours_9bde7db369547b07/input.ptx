.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd9, %r3, %r3;
    mad.lo.s32 %r24, %r3, %r3, %r3;
    shl.b64 %rd10, %rd9, 4;
    shl.b32 %r8, %r3, 15;
    and.b64 %rd8, %rd10, %rd9;
    mul.wide.s32 %rd5, %r8, %r8;
    mul.lo.u64 %rd14, %rd10, %rd8;
    add.u64 %rd14, %rd5, %rd5;
    shl.b64 %rd9, %rd8, 30;
    sub.u32 %r27, %r8, 2147483647;
    add.u64 %rd6, %rd10, %rd9;
    max.u32 %r14, %r8, 3;
    add.s64 %rd12, %rd8, %rd9;
    shr.s64 %rd13, %rd9, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
