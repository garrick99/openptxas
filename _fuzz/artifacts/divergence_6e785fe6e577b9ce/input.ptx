.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p2, %r3, %r3;
    setp.hs.u32 %p4, %r3, 31;
    @%p4 xor.b32 %r7, %r3, 31;
    mul.wide.u32 %rd7, %r3, %r3;
    shl.b64 %rd14, %rd7, 62;
    add.s32 %r27, %r7, %r3;
    shl.b32 %r19, %r27, 3;
    sub.u32 %r12, %r3, 15;
    xor.b32 %r21, %r3, %r19;
    mul.lo.s32 %r13, %r27, 1;
    selp.b32 %r23, %r19, %r21, %p4;
    and.b32 %r6, %r7, %r7;
    mul.wide.u32 %rd11, %r6, %r12;
    mul.lo.s64 %rd5, %rd14, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
