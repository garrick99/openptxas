.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r5, %r3, 31;
    xor.b32 %r15, %r3, %r5;
    cvt.s64.s32 %rd14, %r3;
    shr.s32 %r23, %r3, 7;
    mad.lo.s32 %r15, %r3, %r15, %r15;
    cvt.s32.s64 %r17, %rd14;
    setp.ls.u32 %p4, %r17, %r15;
    @!%p4 add.s32 %r10, %r17, %r15;
    mad.lo.s32 %r12, %r17, %r15, %r10;
    selp.b32 %r7, %r5, %r3, %p4;
    and.b32 %r25, %r10, 64;
    shl.b64 %rd10, %rd14, 31;
    sub.s32 %r15, %r23, %r12;
    selp.b32 %r20, %r17, %r10, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
