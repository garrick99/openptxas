.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r27, %r3, 5;
    add.s32 %r11, %r27, 8;
    max.s32 %r7, %r11, %r3;
    cvt.s64.s32 %rd10, %r11;
    shr.u32 %r12, %r27, 4;
    cvt.s64.s32 %rd11, %r27;
    mul.wide.u32 %rd11, %r7, %r11;
    shl.b32 %r14, %r11, 31;
    shr.s64 %rd8, %rd10, 47;
    setp.gt.u32 %p1, %r7, %r12;
    @%p1 min.u32 %r25, %r11, 65535;
    xor.b32 %r6, %r25, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
