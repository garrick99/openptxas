.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r17, %r3, %r3;
    mul.lo.s32 %r24, %r17, 63;
    min.u32 %r11, %r17, %r3;
    mul.wide.s32 %rd9, %r3, %r17;
    sub.s64 %rd6, %rd9, %rd9;
    xor.b32 %r9, %r11, %r11;
    min.u32 %r23, %r17, 15;
    sub.u32 %r24, %r24, %r17;
    sub.s32 %r20, %r11, 63;
    sub.u64 %rd15, %rd9, %rd6;
    mad.lo.u32 %r24, %r11, %r23, %r9;
    shl.b64 %rd10, %rd9, 33;
    shr.s64 %rd7, %rd9, 30;
    or.b32 %r17, %r24, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
