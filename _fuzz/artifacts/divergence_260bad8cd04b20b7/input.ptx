.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r23, %r3, %r3;
    cvt.u64.u32 %rd5, %r3;
    mul.wide.u32 %rd10, %r23, %r3;
    mul.lo.u32 %r18, %r23, %r3;
    or.b32 %r20, %r3, %r23;
    sub.s32 %r10, %r20, 2147483647;
    or.b64 %rd5, %rd10, %rd10;
    cvt.s64.s32 %rd6, %r20;
    min.u32 %r9, %r20, 3;
    max.u32 %r16, %r10, %r9;
    max.u32 %r6, %r10, 64;
    max.s32 %r17, %r6, 256;
    shr.s32 %r24, %r16, 30;
    mul.wide.u32 %rd5, %r18, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
