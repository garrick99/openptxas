.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r4, %r3, %r3, %r3;
    mul.wide.u32 %rd7, %r3, %r3;
    setp.lo.u32 %p1, %r4, 31;
    @!%p1 cvt.s32.s64 %r15, %rd7;
    and.b32 %r12, %r4, %r15;
    and.b32 %r8, %r3, %r4;
    xor.b32 %r11, %r15, %r12;
    add.u32 %r15, %r3, %r15;
    min.s64 %rd9, %rd7, %rd7;
    or.b32 %r19, %r12, 64;
    mad.lo.s32 %r5, %r4, %r8, %r11;
    sub.s32 %r14, %r11, 2;
    and.b32 %r21, %r8, %r19;
    mul.lo.s32 %r10, %r14, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
