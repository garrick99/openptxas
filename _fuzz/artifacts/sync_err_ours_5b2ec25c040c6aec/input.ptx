.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd8, %r3, %r3;
    add.s32 %r10, %r3, %r3;
    shl.b32 %r6, %r10, 15;
    shl.b32 %r8, %r3, 15;
    add.u32 %r8, %r6, 64;
    and.b32 %r18, %r6, %r6;
    mad.lo.s32 %r24, %r10, %r3, %r6;
    setp.ge.s32 %p2, %r10, %r24;
    @!%p2 max.u64 %rd15, %rd8, %rd8;
    mul.wide.s32 %rd6, %r24, %r6;
    max.u32 %r4, %r10, %r10;
    min.u32 %r14, %r18, %r8;
    xor.b32 %r11, %r8, 256;
    shr.u32 %r14, %r24, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
