.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    shr.s64 %rd12, %rd5, 4;
    mul.wide.u32 %rd14, %r3, %r3;
    setp.eq.u32 %p1, %r3, %r3;
    shr.s64 %rd13, %rd5, 48;
    max.u32 %r7, %r3, 65536;
    selp.b32 %r17, %r3, %r7, %p1;
    mad.lo.u32 %r19, %r3, %r7, %r7;
    min.s32 %r21, %r17, %r7;
    setp.lt.u32 %p4, %r19, 4294967295;
    @%p4 shl.b32 %r9, %r17, 4;
    cvt.u64.u32 %rd6, %r21;
    setp.gt.u32 %p3, %r17, 65535;
    @%p3 min.s64 %rd12, %rd13, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
