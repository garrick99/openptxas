.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    min.u32 %r5, %r3, 2;
    setp.hs.u32 %p2, %r5, 15;
    @%p2 shr.u64 %rd7, %rd13, 47;
    selp.b32 %r17, %r5, %r3, %p2;
    add.u32 %r23, %r17, 5;
    add.s32 %r13, %r23, 0;
    shl.b32 %r6, %r3, 1;
    add.u64 %rd6, %rd7, %rd13;
    max.u32 %r4, %r23, %r5;
    cvt.u32.u64 %r8, %rd6;
    sub.u64 %rd12, %rd13, %rd7;
    shr.u64 %rd9, %rd6, 3;
    mad.lo.s32 %r21, %r8, %r5, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
