.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    cvt.s64.s32 %rd9, %r3;
    mul.lo.u32 %r11, %r3, 16;
    cvt.s64.s32 %rd7, %r3;
    max.s32 %r7, %r11, 16;
    shl.b64 %rd8, %rd7, 63;
    max.s32 %r15, %r11, 16;
    or.b32 %r20, %r15, %r7;
    xor.b32 %r15, %r15, %r11;
    add.u32 %r17, %r11, %r20;
    shr.u32 %r26, %r7, 1;
    sub.s32 %r14, %r7, %r15;
    max.u32 %r25, %r17, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
