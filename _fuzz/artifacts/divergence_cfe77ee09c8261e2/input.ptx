.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r4, %r3, 1;
    cvt.s64.s32 %rd7, %r4;
    cvt.s64.s32 %rd13, %r3;
    shr.u64 %rd13, %rd13, 3;
    max.u32 %r25, %r4, %r4;
    mul.lo.s32 %r24, %r3, 65535;
    shl.b64 %rd9, %rd13, 63;
    mul.lo.s32 %r15, %r24, %r25;
    xor.b32 %r7, %r25, 15;
    mul.wide.u32 %rd9, %r25, %r24;
    sub.s32 %r24, %r25, %r25;
    shl.b64 %rd11, %rd7, 30;
    setp.ne.u32 %p1, %r25, %r4;
    @%p1 max.s32 %r6, %r7, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
