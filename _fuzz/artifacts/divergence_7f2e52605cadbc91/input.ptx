.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r26, %r3, %r3;
    cvt.s64.s32 %rd15, %r3;
    cvt.u64.u32 %rd15, %r26;
    setp.lt.u32 %p4, %r3, 2;
    @%p4 mul.lo.u32 %r8, %r26, 65535;
    selp.b32 %r16, %r3, %r26, %p4;
    cvt.s32.s64 %r19, %rd15;
    max.s32 %r5, %r26, %r3;
    shr.s32 %r15, %r16, 15;
    add.s32 %r23, %r5, %r3;
    xor.b32 %r25, %r26, 63;
    sub.s32 %r25, %r15, %r8;
    setp.gt.s32 %p4, %r3, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
