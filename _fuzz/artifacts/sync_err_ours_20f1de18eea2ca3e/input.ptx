.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p1, %r3, 7;
    @%p1 and.b32 %r17, %r3, %r3;
    setp.le.s32 %p1, %r17, %r17;
    mul.wide.u32 %rd13, %r17, %r3;
    shr.u64 %rd14, %rd13, 15;
    cvt.s32.s64 %r15, %rd13;
    cvt.u32.u64 %r5, %rd14;
    cvt.s32.s64 %r27, %rd14;
    xor.b64 %rd10, %rd13, %rd14;
    setp.gt.s32 %p2, %r27, %r3;
    @%p2 or.b32 %r19, %r5, %r27;
    cvt.u32.u64 %r5, %rd10;
    cvt.s32.s64 %r9, %rd10;
    max.u64 %rd9, %rd14, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
