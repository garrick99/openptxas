.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.u32 %p4, %r3, 64;
    selp.b32 %r7, %r3, %r3, %p4;
    xor.b32 %r20, %r3, 2147483647;
    mad.lo.s32 %r27, %r3, %r3, %r20;
    or.b32 %r13, %r20, %r27;
    mul.wide.s32 %rd11, %r13, %r20;
    or.b32 %r6, %r27, 8;
    setp.lt.s32 %p4, %r6, %r27;
    mul.lo.s32 %r18, %r7, 4294967295;
    selp.b32 %r22, %r3, %r20, %p4;
    max.u32 %r20, %r7, 5;
    mul.lo.u32 %r26, %r20, 5;
    mul.lo.s32 %r25, %r18, %r22;
    shr.s64 %rd10, %rd11, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
