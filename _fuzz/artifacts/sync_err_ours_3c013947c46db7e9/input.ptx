.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r8, %r3, %r3;
    or.b32 %r10, %r3, %r8;
    add.s32 %r9, %r3, %r10;
    mad.lo.s32 %r25, %r3, %r10, %r8;
    mul.wide.u32 %rd14, %r25, %r9;
    sub.s32 %r18, %r9, 256;
    add.s32 %r19, %r8, 7;
    sub.u32 %r24, %r9, 0;
    add.u64 %rd5, %rd14, %rd14;
    shr.s32 %r17, %r10, 2;
    or.b32 %r27, %r19, %r19;
    min.u32 %r6, %r8, %r10;
    add.u32 %r13, %r17, %r24;
    sub.s32 %r10, %r18, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
