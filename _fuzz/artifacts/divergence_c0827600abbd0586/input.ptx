.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r20, %r3, %r3, %r3;
    sub.s32 %r17, %r20, %r20;
    max.s32 %r4, %r20, 31;
    mad.lo.u32 %r23, %r20, %r3, %r4;
    cvt.s64.s32 %rd5, %r23;
    mad.lo.u32 %r25, %r17, %r23, %r17;
    setp.ge.u32 %p4, %r17, 2;
    mul.lo.s32 %r11, %r20, 256;
    mul.wide.u32 %rd10, %r25, %r23;
    mul.lo.s64 %rd14, %rd5, %rd10;
    selp.b32 %r24, %r11, %r17, %p4;
    mul.lo.u32 %r20, %r4, %r20;
    mul.wide.u32 %rd5, %r25, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
