.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    shl.b32 %r17, %r3, 7;
    or.b32 %r22, %r3, %r17;
    shr.s32 %r18, %r22, 31;
    max.s32 %r24, %r18, %r22;
    shr.s32 %r23, %r18, 31;
    shr.u64 %rd14, %rd10, 3;
    min.u64 %rd13, %rd14, %rd14;
    sub.u32 %r5, %r24, %r17;
    xor.b32 %r25, %r23, 4294967295;
    sub.u64 %rd12, %rd10, %rd14;
    shr.u32 %r9, %r3, 30;
    max.s64 %rd7, %rd12, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
