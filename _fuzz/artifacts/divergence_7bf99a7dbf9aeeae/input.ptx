.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r9, %r3, 2147483648;
    cvt.s64.s32 %rd5, %r3;
    min.u32 %r26, %r9, 7;
    max.s64 %rd10, %rd5, %rd5;
    cvt.u64.u32 %rd12, %r26;
    mul.wide.s32 %rd7, %r26, %r9;
    min.s32 %r25, %r3, 4294967295;
    xor.b32 %r14, %r25, 5;
    mul.lo.u64 %rd8, %rd12, %rd5;
    max.u32 %r11, %r14, 16;
    shl.b32 %r9, %r9, 0;
    max.s32 %r17, %r25, 31;
    setp.ls.u32 %p3, %r11, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
