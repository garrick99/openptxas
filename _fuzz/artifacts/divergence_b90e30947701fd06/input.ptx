.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r21, %r3, %r3;
    mul.lo.u32 %r9, %r3, %r3;
    cvt.u64.u32 %rd6, %r9;
    add.u32 %r18, %r9, %r21;
    or.b32 %r23, %r3, 256;
    shr.s32 %r12, %r9, 4;
    shl.b32 %r23, %r21, 15;
    cvt.s32.s64 %r9, %rd6;
    cvt.s32.s64 %r22, %rd6;
    mul.wide.u32 %rd12, %r21, %r18;
    or.b32 %r4, %r22, %r23;
    shr.u64 %rd14, %rd6, 31;
    min.u32 %r27, %r12, %r9;
    and.b64 %rd10, %rd6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
