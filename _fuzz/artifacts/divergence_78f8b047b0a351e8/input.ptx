.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r15, %r3, %r3;
    shl.b32 %r5, %r3, 31;
    cvt.s64.s32 %rd10, %r5;
    setp.le.u32 %p4, %r15, 31;
    setp.eq.u32 %p3, %r15, %r5;
    @!%p3 and.b32 %r16, %r5, %r3;
    mad.lo.u32 %r8, %r15, %r5, %r16;
    shl.b32 %r15, %r15, 4;
    add.u32 %r6, %r3, 3;
    setp.ge.s32 %p1, %r5, %r5;
    @!%p1 cvt.u64.u32 %rd12, %r8;
    sub.u32 %r9, %r6, 64;
    sub.s32 %r15, %r5, %r15;
    mad.lo.s32 %r19, %r15, %r3, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
