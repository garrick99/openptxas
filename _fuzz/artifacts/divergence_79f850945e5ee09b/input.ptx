.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p2, %r3, %r3;
    @%p2 shr.u32 %r7, %r3, 16;
    cvt.u64.u32 %rd10, %r7;
    mad.lo.s32 %r10, %r7, %r7, %r7;
    shr.s32 %r18, %r10, 30;
    max.u32 %r20, %r7, 1;
    shl.b32 %r6, %r10, 16;
    cvt.s64.s32 %rd9, %r18;
    mad.lo.u32 %r14, %r6, %r6, %r10;
    sub.s32 %r24, %r14, 8;
    min.s32 %r16, %r6, %r3;
    setp.ne.u32 %p3, %r3, 2;
    sub.u32 %r23, %r6, %r10;
    min.s32 %r14, %r20, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
