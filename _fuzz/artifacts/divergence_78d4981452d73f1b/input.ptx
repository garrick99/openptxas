.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r21, %r3, %r3, %r3;
    xor.b32 %r8, %r3, %r21;
    xor.b32 %r13, %r8, %r8;
    setp.lt.s32 %p3, %r8, 63;
    mad.lo.u32 %r11, %r21, %r13, %r8;
    mad.lo.u32 %r13, %r21, %r13, %r11;
    max.u32 %r21, %r11, 4;
    shr.u32 %r24, %r13, 3;
    selp.b32 %r19, %r24, %r11, %p3;
    mul.wide.u32 %rd8, %r24, %r3;
    max.s32 %r9, %r21, %r11;
    and.b64 %rd13, %rd8, %rd8;
    min.u32 %r20, %r13, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
