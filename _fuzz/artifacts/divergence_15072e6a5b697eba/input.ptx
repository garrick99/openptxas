.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r13, %r3, 15;
    setp.gt.u32 %p2, %r3, 63;
    @%p2 mul.wide.u32 %rd5, %r3, %r3;
    min.u32 %r13, %r3, 4;
    min.u32 %r27, %r13, 256;
    add.s32 %r9, %r27, %r13;
    mad.lo.s32 %r11, %r3, %r13, %r3;
    setp.le.s32 %p3, %r3, %r3;
    @%p3 shr.u32 %r11, %r3, 0;
    mul.wide.u32 %rd15, %r11, %r13;
    shl.b32 %r8, %r3, 30;
    mad.lo.u32 %r10, %r11, %r8, %r3;
    setp.ls.u32 %p2, %r27, %r9;
    @%p2 cvt.u32.u64 %r19, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
