.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r26, %r3, %r3, %r3;
    and.b32 %r9, %r26, 63;
    max.u32 %r18, %r26, %r26;
    setp.ge.s32 %p3, %r18, 5;
    @%p3 mad.lo.s32 %r18, %r26, %r3, %r9;
    setp.eq.s32 %p2, %r9, %r26;
    @%p2 mul.wide.s32 %rd15, %r26, %r9;
    shl.b32 %r24, %r3, 7;
    max.u32 %r27, %r3, 2;
    or.b64 %rd8, %rd15, %rd15;
    setp.eq.u32 %p4, %r9, 65536;
    @%p4 sub.u32 %r27, %r27, %r3;
    cvt.s32.s64 %r14, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
