.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r13, %r3, 30;
    mad.lo.s32 %r19, %r3, %r13, %r3;
    sub.s32 %r20, %r13, %r19;
    setp.ge.s32 %p1, %r20, 255;
    sub.s32 %r18, %r20, %r13;
    min.s32 %r7, %r19, 32;
    and.b32 %r16, %r7, %r3;
    xor.b32 %r9, %r19, %r18;
    mul.lo.u32 %r24, %r3, %r18;
    cvt.u64.u32 %rd6, %r3;
    shr.u32 %r18, %r16, 16;
    mad.lo.u32 %r25, %r19, %r7, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
