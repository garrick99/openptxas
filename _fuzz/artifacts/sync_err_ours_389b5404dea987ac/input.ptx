.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r13, %r3, 5;
    shl.b32 %r18, %r13, 31;
    setp.lt.s32 %p1, %r3, %r13;
    sub.s32 %r6, %r18, 1;
    setp.ge.u32 %p2, %r13, %r3;
    @%p2 sub.s32 %r4, %r3, 1;
    selp.b32 %r16, %r3, %r18, %p2;
    max.s32 %r9, %r16, 64;
    selp.b32 %r19, %r4, %r16, %p1;
    mad.lo.s32 %r8, %r16, %r4, %r16;
    min.u32 %r14, %r16, 256;
    sub.u32 %r12, %r18, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
