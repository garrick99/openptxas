.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r15, %r3, 7;
    sub.s32 %r8, %r15, %r15;
    cvt.s64.s32 %rd9, %r15;
    mul.wide.s32 %rd7, %r15, %r8;
    max.s32 %r16, %r3, 2;
    sub.u32 %r15, %r3, 15;
    shl.b64 %rd13, %rd9, 48;
    mul.lo.u32 %r5, %r3, %r3;
    or.b64 %rd14, %rd9, %rd7;
    setp.ge.u32 %p2, %r8, 31;
    @%p2 shr.s32 %r13, %r8, 30;
    shr.u32 %r8, %r13, 0;
    mul.lo.u32 %r24, %r16, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
