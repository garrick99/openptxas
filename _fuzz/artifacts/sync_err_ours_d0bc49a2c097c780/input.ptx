.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r5, %r3, %r3;
    cvt.s64.s32 %rd9, %r5;
    sub.s64 %rd15, %rd9, %rd9;
    shr.s32 %r15, %r5, 2;
    shr.u32 %r25, %r15, 15;
    max.s32 %r22, %r15, %r3;
    cvt.s64.s32 %rd13, %r5;
    sub.u32 %r15, %r5, %r25;
    sub.u64 %rd12, %rd13, %rd15;
    mul.wide.u32 %rd6, %r5, %r22;
    setp.lt.u32 %p4, %r25, %r25;
    @%p4 cvt.u32.u64 %r12, %rd9;
    min.u32 %r8, %r15, %r25;
    cvt.u64.u32 %rd14, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
