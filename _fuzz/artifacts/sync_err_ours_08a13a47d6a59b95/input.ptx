.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd14, %r3, %r3;
    sub.u32 %r4, %r3, 15;
    xor.b32 %r15, %r4, %r3;
    add.u32 %r11, %r3, %r15;
    setp.le.s32 %p3, %r15, %r15;
    @%p3 shr.u64 %rd14, %rd14, 16;
    add.s64 %rd10, %rd14, %rd14;
    shr.u32 %r23, %r4, 1;
    min.s32 %r25, %r15, %r4;
    cvt.u32.u64 %r12, %rd14;
    cvt.s32.s64 %r15, %rd14;
    shl.b32 %r11, %r15, 2;
    min.s32 %r7, %r25, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
