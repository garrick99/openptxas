.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r14, %r3, 1;
    cvt.u64.u32 %rd14, %r14;
    min.u32 %r21, %r3, %r3;
    min.s32 %r14, %r21, %r21;
    add.s32 %r9, %r14, %r21;
    mad.lo.u32 %r16, %r14, %r21, %r3;
    shr.u64 %rd7, %rd14, 15;
    min.s64 %rd10, %rd7, %rd14;
    cvt.u32.u64 %r25, %rd14;
    sub.u32 %r25, %r3, %r14;
    mad.lo.s32 %r22, %r16, %r16, %r16;
    shr.u32 %r27, %r9, 4;
    mad.lo.u32 %r11, %r25, %r22, %r27;
    mul.lo.s64 %rd7, %rd7, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
