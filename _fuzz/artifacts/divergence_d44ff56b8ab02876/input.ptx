.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r20, %r3, %r3;
    mul.wide.s32 %rd9, %r3, %r3;
    setp.gt.s32 %p1, %r20, 0;
    @%p1 max.u32 %r11, %r3, 1;
    add.u32 %r22, %r20, %r11;
    mul.lo.u32 %r25, %r20, 15;
    mul.wide.u32 %rd14, %r11, %r3;
    shr.s64 %rd15, %rd9, 4;
    or.b64 %rd6, %rd9, %rd9;
    min.s32 %r27, %r25, %r11;
    mad.lo.u32 %r10, %r27, %r27, %r25;
    mul.lo.u32 %r14, %r27, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
