.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    shr.u64 %rd11, %rd14, 2;
    mul.wide.s32 %rd13, %r3, %r3;
    min.s32 %r19, %r3, %r3;
    mul.lo.s32 %r24, %r19, %r3;
    sub.u64 %rd6, %rd11, %rd13;
    and.b32 %r14, %r19, 65536;
    mul.wide.u32 %rd12, %r24, %r14;
    max.u32 %r11, %r3, 16;
    mad.lo.s32 %r27, %r11, %r11, %r24;
    shr.s64 %rd8, %rd11, 62;
    and.b32 %r13, %r24, 16;
    sub.s32 %r8, %r24, %r24;
    mad.lo.u32 %r4, %r27, %r8, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
