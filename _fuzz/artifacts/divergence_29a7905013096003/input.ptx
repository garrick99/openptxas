.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r19, %r3, 256;
    min.s32 %r23, %r3, %r3;
    xor.b32 %r16, %r19, %r19;
    shr.s32 %r25, %r23, 3;
    mul.lo.s32 %r22, %r16, 256;
    setp.gt.s32 %p1, %r22, %r16;
    cvt.s64.s32 %rd8, %r25;
    selp.b32 %r9, %r22, %r25, %p1;
    mul.wide.u32 %rd7, %r25, %r9;
    min.s32 %r20, %r23, 0;
    add.s32 %r13, %r25, %r20;
    shr.u32 %r27, %r13, 1;
    selp.b32 %r25, %r19, %r27, %p1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
