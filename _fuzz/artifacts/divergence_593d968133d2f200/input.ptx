.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r6, %r3, 15;
    sub.u32 %r15, %r6, 32;
    mad.lo.u32 %r27, %r15, %r15, %r15;
    mad.lo.u32 %r6, %r27, %r6, %r27;
    setp.lo.u32 %p4, %r27, %r6;
    cvt.s64.s32 %rd8, %r15;
    add.u32 %r24, %r6, %r15;
    max.u32 %r24, %r6, 1;
    sub.s32 %r14, %r24, 63;
    mul.wide.s32 %rd5, %r14, %r6;
    mad.lo.u32 %r15, %r24, %r24, %r14;
    shr.s32 %r11, %r14, 16;
    cvt.u64.u32 %rd9, %r6;
    add.s32 %r5, %r6, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
