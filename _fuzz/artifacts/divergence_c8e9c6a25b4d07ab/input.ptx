.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r11, %r3, %r3;
    add.u32 %r5, %r3, %r3;
    cvt.u64.u32 %rd12, %r3;
    setp.lt.u32 %p3, %r11, %r11;
    cvt.u32.u64 %r10, %rd12;
    setp.hi.u32 %p4, %r11, %r11;
    @!%p4 selp.b32 %r27, %r3, %r11, %p3;
    mul.lo.s32 %r16, %r10, %r5;
    shr.s64 %rd12, %rd12, 4;
    mul.lo.s32 %r27, %r27, 256;
    cvt.u64.u32 %rd15, %r27;
    max.s32 %r8, %r16, 63;
    shr.s64 %rd12, %rd15, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
