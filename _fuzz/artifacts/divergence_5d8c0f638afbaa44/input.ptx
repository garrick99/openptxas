.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    shl.b64 %rd12, %rd12, 4;
    shr.s64 %rd10, %rd12, 15;
    setp.gt.s32 %p3, %r3, %r3;
    setp.lt.u32 %p3, %r3, %r3;
    @%p3 add.s32 %r17, %r3, 32;
    sub.u64 %rd12, %rd12, %rd10;
    or.b32 %r24, %r3, %r3;
    cvt.s32.s64 %r25, %rd12;
    shr.u64 %rd14, %rd10, 31;
    setp.eq.s32 %p4, %r25, %r25;
    selp.b32 %r26, %r17, %r24, %p3;
    min.s32 %r24, %r17, 255;
    min.s64 %rd9, %rd12, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
