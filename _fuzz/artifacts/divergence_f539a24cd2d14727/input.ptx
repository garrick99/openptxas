.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r11, %r3, 31;
    max.u32 %r13, %r3, 255;
    mul.wide.u32 %rd13, %r11, %r3;
    mad.lo.u32 %r11, %r11, %r13, %r13;
    or.b32 %r22, %r3, %r13;
    xor.b32 %r10, %r13, %r11;
    shr.u32 %r6, %r11, 16;
    shr.s64 %rd11, %rd13, 2;
    shr.u32 %r18, %r11, 31;
    mad.lo.s32 %r4, %r22, %r22, %r18;
    or.b32 %r21, %r6, 32;
    shr.u64 %rd10, %rd11, 7;
    min.s32 %r23, %r21, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
