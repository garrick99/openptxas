.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r10, %r3, 65536;
    setp.ge.s32 %p3, %r10, 256;
    @%p3 cvt.u64.u32 %rd11, %r3;
    cvt.s32.s64 %r21, %rd11;
    mad.lo.s32 %r9, %r21, %r3, %r10;
    setp.ge.s32 %p4, %r3, 255;
    @%p4 selp.b32 %r16, %r10, %r10, %p3;
    mul.wide.u32 %rd6, %r16, %r9;
    min.u64 %rd6, %rd11, %rd6;
    setp.lt.s32 %p3, %r9, 65536;
    @%p3 max.u32 %r15, %r21, 32;
    mul.wide.s32 %rd6, %r10, %r3;
    mul.wide.u32 %rd7, %r16, %r21;
    cvt.u32.u64 %r18, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
