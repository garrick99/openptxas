    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r26, %r3, %r3;
    shr.u32 %r19, %r26, 3;
    shl.b32 %r22, %r3, 7;
    mul.lo.u32 %r7, %r22, 2147483647;
    xor.b32 %r14, %r7, %r7;
    cvt.u64.u32 %rd8, %r7;
    sub.u32 %r4, %r22, %r3;
    sub.s32 %r4, %r26, %r22;
