.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd10, %r3, %r3;
    xor.b32 %r16, %r3, 65536;
    min.u32 %r10, %r3, %r3;
    mul.lo.s64 %rd12, %rd10, %rd10;
    sub.s32 %r24, %r16, 2;
    cvt.s32.s64 %r8, %rd12;
    add.s32 %r19, %r16, %r8;
    sub.u32 %r17, %r16, 2;
    xor.b32 %r8, %r16, %r3;
    mul.wide.u32 %rd12, %r10, %r24;
    shr.s64 %rd11, %rd10, 15;
    add.s32 %r18, %r10, %r19;
    cvt.s64.s32 %rd6, %r3;
    min.u32 %r18, %r17, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
