.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r10, %r3, 16;
    sub.s32 %r17, %r3, %r10;
    cvt.s64.s32 %rd5, %r3;
    sub.s32 %r26, %r17, 2;
    max.s32 %r5, %r17, %r10;
    shr.s32 %r19, %r3, 30;
    setp.gt.s32 %p3, %r5, %r5;
    @%p3 add.s32 %r18, %r10, %r26;
    mad.lo.s32 %r16, %r18, %r3, %r26;
    max.s32 %r6, %r3, %r19;
    shr.u32 %r21, %r19, 16;
    sub.u32 %r15, %r18, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
