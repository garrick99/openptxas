.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r18, %r3, %r3;
    shr.s32 %r26, %r3, 30;
    sub.s32 %r4, %r26, 8;
    add.s32 %r16, %r18, 32;
    cvt.s64.s32 %rd10, %r16;
    setp.hs.u32 %p1, %r18, %r4;
    shr.s32 %r13, %r16, 15;
    add.s64 %rd8, %rd10, %rd10;
    or.b32 %r7, %r13, %r16;
    cvt.u32.u64 %r14, %rd10;
    max.s32 %r18, %r18, %r7;
    setp.ls.u32 %p3, %r18, 63;
    @%p3 mad.lo.u32 %r19, %r18, %r26, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
