.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r11, %r3, %r3;
    setp.gt.s32 %p3, %r11, %r11;
    @%p3 selp.b32 %r18, %r3, %r3, %p3;
    sub.u32 %r23, %r18, 256;
    setp.ge.s32 %p2, %r11, 65536;
    @!%p2 xor.b32 %r12, %r23, %r11;
    mul.lo.u32 %r14, %r23, %r11;
    shr.u32 %r14, %r12, 30;
    mul.wide.u32 %rd13, %r23, %r23;
    max.s32 %r27, %r12, 65535;
    max.s32 %r14, %r23, %r14;
    cvt.u64.u32 %rd5, %r14;
    mul.wide.u32 %rd13, %r23, %r18;
    shl.b32 %r11, %r27, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
