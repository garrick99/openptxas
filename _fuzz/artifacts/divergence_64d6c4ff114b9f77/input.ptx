.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    max.s32 %r4, %r3, 5;
    shr.u32 %r7, %r4, 4;
    mul.wide.s32 %rd5, %r3, %r4;
    add.s32 %r13, %r4, %r7;
    min.s32 %r19, %r7, %r4;
    add.s64 %rd7, %rd5, %rd5;
    mul.lo.s32 %r24, %r19, 0;
    sub.s32 %r23, %r19, 63;
    min.s32 %r16, %r7, 1;
    shl.b32 %r11, %r13, 2;
    setp.ne.s32 %p1, %r16, 4;
    max.u32 %r4, %r16, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
