.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r11, %r3, %r3;
    mad.lo.u32 %r6, %r11, %r11, %r3;
    cvt.s64.s32 %rd7, %r6;
    cvt.s32.s64 %r13, %rd7;
    shl.b32 %r13, %r3, 30;
    shl.b32 %r9, %r11, 16;
    setp.le.u32 %p4, %r9, %r13;
    shr.u32 %r6, %r11, 0;
    mul.wide.u32 %rd8, %r3, %r9;
    add.s32 %r25, %r11, %r3;
    and.b32 %r8, %r3, %r6;
    mul.wide.u32 %rd11, %r3, %r9;
    shr.s32 %r15, %r25, 1;
    max.u64 %rd9, %rd11, %rd7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
