.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r19, %r3, %r3;
    mul.wide.u32 %rd14, %r19, %r19;
    cvt.u32.u64 %r9, %rd14;
    min.s32 %r6, %r9, %r9;
    xor.b32 %r17, %r19, %r6;
    shl.b32 %r26, %r6, 31;
    add.u64 %rd5, %rd14, %rd14;
    and.b32 %r19, %r9, 3;
    mul.lo.s32 %r24, %r17, %r3;
    shr.s32 %r22, %r24, 16;
    add.u32 %r12, %r17, 32;
    max.s32 %r27, %r6, %r17;
    mad.lo.u32 %r24, %r22, %r9, %r27;
    min.u32 %r23, %r22, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
