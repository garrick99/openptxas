.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r25, %r3, 65535;
    mul.wide.s32 %rd15, %r25, %r3;
    shr.s32 %r20, %r25, 30;
    shr.s32 %r5, %r20, 16;
    shl.b64 %rd6, %rd15, 31;
    shl.b32 %r24, %r5, 0;
    shr.s32 %r24, %r24, 4;
    mul.lo.s32 %r11, %r25, 3;
    cvt.u64.u32 %rd7, %r24;
    add.s32 %r14, %r20, %r5;
    add.s32 %r9, %r3, %r3;
    setp.gt.s32 %p4, %r24, %r3;
    @%p4 mad.lo.u32 %r12, %r11, %r11, %r25;
    shr.u64 %rd7, %rd15, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
