    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    add.s32 %r20, %r3, 65535;
    sub.s32 %r18, %r20, %r20;
    xor.b32 %r20, %r20, %r3;
    mul.lo.s32 %r8, %r20, %r18;
    cvt.s32.s64 %r6, %rd14;
    or.b64 %rd8, %rd14, %rd14;
    sub.u32 %r9, %r3, 8;
    max.s32 %r26, %r9, %r6;
    shl.b64 %rd13, %rd14, 32;
