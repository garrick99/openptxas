.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    shr.u32 %r17, %r3, 4;
    mad.lo.u32 %r16, %r17, %r3, %r17;
    sub.u32 %r21, %r17, %r3;
    shr.u32 %r16, %r21, 16;
    sub.s32 %r5, %r21, 16;
    setp.le.s32 %p1, %r5, %r21;
    selp.b32 %r13, %r5, %r16, %p1;
    sub.s32 %r10, %r5, %r17;
    add.s32 %r14, %r16, 63;
    sub.s32 %r20, %r10, %r16;
    mul.wide.u32 %rd13, %r5, %r3;
    shr.s32 %r16, %r13, 31;
    shr.u64 %rd5, %rd13, 62;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
