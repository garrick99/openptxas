    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    prmt.b32 %r17, %r3, %r3, 291;
    bfe.s32 %r21, %r17, 4, 31;
