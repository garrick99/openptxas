.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r25, %r3, 15;
    cvt.s64.s32 %rd12, %r3;
    cvt.s32.s64 %r18, %rd12;
    shr.s32 %r14, %r3, 16;
    mul.lo.u64 %rd15, %rd12, %rd12;
    min.u64 %rd7, %rd15, %rd12;
    max.s32 %r13, %r18, 4;
    mul.lo.s32 %r22, %r3, %r14;
    min.s32 %r12, %r18, %r22;
    and.b32 %r27, %r25, 255;
    or.b64 %rd8, %rd7, %rd15;
    max.u32 %r26, %r3, 255;
    shl.b64 %rd5, %rd7, 16;
    sub.u32 %r7, %r13, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
