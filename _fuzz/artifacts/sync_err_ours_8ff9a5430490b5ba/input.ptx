.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd8, %r3, %r3;
    shr.s64 %rd9, %rd8, 32;
    setp.ne.s32 %p4, %r3, 255;
    @%p4 sub.u64 %rd7, %rd9, %rd9;
    cvt.u64.u32 %rd9, %r3;
    shr.u64 %rd9, %rd8, 47;
    setp.le.s32 %p4, %r3, %r3;
    @%p4 sub.u32 %r10, %r3, 8;
    shl.b64 %rd7, %rd9, 47;
    cvt.s64.s32 %rd14, %r10;
    selp.b32 %r25, %r3, %r10, %p4;
    max.s32 %r6, %r10, %r3;
    min.u64 %rd9, %rd7, %rd9;
    setp.ls.u32 %p4, %r6, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
