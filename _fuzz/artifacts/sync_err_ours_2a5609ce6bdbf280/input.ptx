.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r20, %r3, %r3;
    and.b32 %r26, %r3, 16;
    cvt.u64.u32 %rd6, %r3;
    shl.b32 %r21, %r3, 30;
    shl.b64 %rd6, %rd6, 16;
    or.b32 %r11, %r3, %r20;
    cvt.u64.u32 %rd8, %r20;
    mad.lo.s32 %r7, %r11, %r26, %r11;
    shr.s32 %r9, %r11, 31;
    add.u32 %r4, %r20, %r9;
    max.s32 %r19, %r26, %r3;
    add.s32 %r10, %r9, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
