.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p3, %r3, 1;
    @%p3 max.u32 %r9, %r3, %r3;
    shl.b32 %r13, %r9, 31;
    cvt.s64.s32 %rd6, %r3;
    xor.b32 %r22, %r13, 0;
    xor.b32 %r4, %r9, %r3;
    and.b32 %r25, %r13, %r9;
    add.u32 %r17, %r22, 7;
    mad.lo.s32 %r18, %r4, %r17, %r25;
    mad.lo.s32 %r23, %r18, %r22, %r18;
    mul.lo.u32 %r24, %r4, %r13;
    max.s32 %r14, %r22, %r9;
    setp.ne.s32 %p4, %r14, 0;
    @%p4 add.u32 %r7, %r24, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
