.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r15, %r3, 15;
    min.s32 %r26, %r15, 2147483647;
    mul.lo.s32 %r20, %r26, %r26;
    mul.wide.s32 %rd14, %r20, %r15;
    min.s32 %r10, %r3, 3;
    shr.s64 %rd13, %rd14, 0;
    sub.s32 %r10, %r15, %r10;
    min.u32 %r19, %r20, %r26;
    cvt.u64.u32 %rd8, %r20;
    and.b32 %r24, %r26, 256;
    add.s32 %r12, %r3, %r26;
    shr.s32 %r15, %r12, 1;
    add.s32 %r15, %r12, 8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
