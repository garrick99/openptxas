.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p3, %r3, %r3;
    @%p3 and.b32 %r8, %r3, %r3;
    cvt.u64.u32 %rd14, %r8;
    selp.b32 %r16, %r8, %r3, %p3;
    max.s32 %r5, %r16, 3;
    shr.s32 %r19, %r16, 4;
    min.s32 %r27, %r19, 5;
    and.b32 %r15, %r27, 64;
    shr.u64 %rd11, %rd14, 15;
    shr.s32 %r24, %r27, 15;
    sub.s64 %rd10, %rd11, %rd14;
    cvt.s32.s64 %r27, %rd14;
    mad.lo.s32 %r16, %r24, %r5, %r3;
    shl.b32 %r27, %r27, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
