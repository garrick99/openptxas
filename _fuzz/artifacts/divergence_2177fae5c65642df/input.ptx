.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    sub.s32 %r15, %r3, %r3;
    max.s32 %r15, %r3, 4294967295;
    cvt.s32.s64 %r11, %rd15;
    cvt.u32.u64 %r14, %rd15;
    shl.b32 %r20, %r15, 31;
    shl.b32 %r15, %r15, 15;
    and.b32 %r18, %r14, %r15;
    sub.s32 %r23, %r3, 65536;
    min.s64 %rd10, %rd15, %rd15;
    xor.b32 %r25, %r23, %r14;
    mul.lo.s32 %r16, %r20, %r14;
    setp.gt.s32 %p3, %r20, 15;
    @%p3 add.u64 %rd10, %rd10, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
