.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r11, %r3, 63;
    cvt.s64.s32 %rd6, %r3;
    shl.b32 %r4, %r3, 30;
    cvt.s32.s64 %r10, %rd6;
    cvt.s32.s64 %r20, %rd6;
    setp.gt.s32 %p2, %r3, %r20;
    @%p2 selp.b32 %r20, %r3, %r3, %p2;
    min.s64 %rd8, %rd6, %rd6;
    and.b32 %r23, %r3, %r10;
    mul.lo.s32 %r15, %r10, 7;
    mad.lo.u32 %r8, %r11, %r11, %r15;
    selp.b32 %r8, %r11, %r15, %p2;
    add.s64 %rd13, %rd8, %rd6;
    mul.lo.u32 %r11, %r3, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
