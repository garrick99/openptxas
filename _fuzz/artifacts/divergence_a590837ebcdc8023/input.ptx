.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r13, %r3, 8;
    add.s32 %r6, %r13, 16;
    add.u32 %r21, %r13, %r6;
    add.u32 %r26, %r3, 7;
    mul.lo.u32 %r20, %r26, %r13;
    mul.wide.s32 %rd14, %r20, %r20;
    max.u64 %rd13, %rd14, %rd14;
    min.s32 %r12, %r6, 8;
    cvt.u32.u64 %r23, %rd13;
    cvt.u32.u64 %r12, %rd13;
    or.b64 %rd15, %rd14, %rd13;
    sub.s64 %rd9, %rd13, %rd14;
    sub.u32 %r22, %r12, 7;
    mul.lo.u32 %r24, %r26, 2147483647;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
