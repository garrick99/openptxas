.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd8, %r3;
    min.s64 %rd7, %rd8, %rd8;
    min.s32 %r27, %r3, 16;
    shl.b64 %rd10, %rd7, 2;
    sub.u32 %r10, %r27, 1;
    sub.s32 %r18, %r3, %r10;
    shl.b32 %r18, %r27, 7;
    setp.gt.s32 %p3, %r3, %r3;
    shl.b32 %r9, %r18, 4;
    selp.b32 %r14, %r10, %r3, %p3;
    or.b32 %r8, %r18, %r9;
    sub.u32 %r22, %r27, %r8;
    sub.s32 %r23, %r8, %r8;
    shl.b64 %rd9, %rd10, 47;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
