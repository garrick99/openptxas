.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    shl.b64 %rd5, %rd12, 1;
    mul.lo.s32 %r9, %r3, 0;
    mul.lo.s64 %rd13, %rd5, %rd5;
    shl.b64 %rd11, %rd12, 63;
    cvt.u64.u32 %rd7, %r3;
    cvt.u32.u64 %r18, %rd5;
    shr.s64 %rd5, %rd11, 32;
    xor.b32 %r9, %r3, 7;
    mul.lo.u32 %r18, %r18, %r3;
    and.b32 %r23, %r9, 0;
    setp.ge.s32 %p1, %r9, %r23;
    @%p1 max.s32 %r6, %r23, %r23;
    add.s32 %r12, %r9, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
