.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r22, %r3, 32;
    shl.b32 %r22, %r3, 0;
    and.b32 %r18, %r22, 8;
    cvt.u64.u32 %rd10, %r18;
    and.b64 %rd11, %rd10, %rd10;
    max.u64 %rd8, %rd10, %rd10;
    mad.lo.s32 %r10, %r22, %r22, %r22;
    cvt.s32.s64 %r19, %rd11;
    shr.u32 %r8, %r22, 3;
    min.s32 %r4, %r19, 2147483647;
    setp.le.u32 %p4, %r18, %r8;
    @!%p4 shr.s32 %r24, %r8, 7;
    or.b64 %rd8, %rd11, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
