.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r27, %r3, %r3;
    mad.lo.s32 %r27, %r27, %r27, %r3;
    mul.wide.s32 %rd10, %r3, %r3;
    cvt.s32.s64 %r7, %rd10;
    shl.b32 %r21, %r27, 0;
    max.u32 %r15, %r21, 63;
    shr.u32 %r24, %r15, 7;
    mul.wide.u32 %rd5, %r21, %r24;
    mul.wide.u32 %rd8, %r15, %r3;
    mad.lo.u32 %r13, %r7, %r27, %r27;
    shr.s32 %r4, %r15, 31;
    sub.s32 %r9, %r15, 0;
    shr.s64 %rd11, %rd8, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
