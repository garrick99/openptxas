.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r23, %r3, 1;
    cvt.s64.s32 %rd13, %r23;
    mul.wide.s32 %rd8, %r23, %r23;
    max.s32 %r18, %r3, 65535;
    xor.b32 %r15, %r23, 32;
    mad.lo.s32 %r19, %r15, %r18, %r23;
    max.u32 %r13, %r15, %r3;
    xor.b32 %r27, %r13, %r18;
    and.b32 %r25, %r23, %r23;
    mul.lo.u32 %r7, %r18, %r27;
    sub.u64 %rd8, %rd8, %rd8;
    mul.lo.u32 %r16, %r19, %r7;
    or.b32 %r6, %r16, %r18;
    shl.b32 %r16, %r19, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
