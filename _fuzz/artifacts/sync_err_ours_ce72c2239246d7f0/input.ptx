.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r8, %r3, %r3;
    and.b32 %r21, %r3, %r8;
    and.b32 %r10, %r8, %r21;
    shl.b32 %r19, %r3, 4;
    min.u32 %r13, %r8, 31;
    shl.b32 %r20, %r21, 1;
    or.b32 %r27, %r3, 15;
    max.u32 %r26, %r21, %r13;
    cvt.s64.s32 %rd5, %r19;
    or.b32 %r14, %r19, 7;
    mad.lo.u32 %r7, %r27, %r3, %r21;
    max.u32 %r15, %r21, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
