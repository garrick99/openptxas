.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r26, %r3, 2;
    mul.wide.u32 %rd6, %r3, %r26;
    mad.lo.s32 %r9, %r3, %r26, %r26;
    add.u32 %r18, %r9, %r26;
    min.s32 %r11, %r26, %r3;
    min.u64 %rd11, %rd6, %rd6;
    sub.s32 %r23, %r9, %r11;
    cvt.s32.s64 %r21, %rd6;
    xor.b32 %r16, %r18, %r18;
    setp.gt.u32 %p1, %r3, 16;
    sub.s32 %r16, %r11, %r23;
    xor.b32 %r11, %r16, 31;
    mad.lo.u32 %r7, %r26, %r18, %r26;
    sub.u32 %r26, %r26, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
