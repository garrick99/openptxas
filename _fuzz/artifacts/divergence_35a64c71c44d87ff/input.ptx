.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r5, %r3, %r3;
    cvt.s64.s32 %rd8, %r3;
    setp.hs.u32 %p2, %r5, 4;
    @%p2 sub.s32 %r6, %r3, 255;
    and.b32 %r24, %r3, 65536;
    sub.s32 %r21, %r3, %r24;
    shr.u32 %r6, %r21, 2;
    sub.s32 %r6, %r5, %r5;
    mul.lo.u32 %r5, %r3, 65536;
    sub.u32 %r6, %r5, 64;
    setp.ne.s32 %p3, %r6, 4;
    @!%p3 shl.b64 %rd11, %rd8, 33;
    cvt.s32.s64 %r23, %rd11;
    setp.hi.u32 %p3, %r5, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
