.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r10, %r3, %r3;
    min.u32 %r13, %r3, 32;
    setp.ls.u32 %p1, %r13, %r3;
    @%p1 min.u32 %r4, %r3, %r10;
    max.s32 %r6, %r13, 31;
    cvt.u64.u32 %rd5, %r10;
    cvt.s32.s64 %r25, %rd5;
    xor.b64 %rd12, %rd5, %rd5;
    selp.b32 %r13, %r4, %r25, %p1;
    shr.s32 %r7, %r6, 15;
    min.s32 %r19, %r7, %r4;
    shl.b32 %r6, %r19, 3;
    max.s32 %r12, %r13, %r3;
    xor.b32 %r27, %r19, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
