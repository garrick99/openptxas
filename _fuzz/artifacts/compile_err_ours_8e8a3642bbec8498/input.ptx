.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.idx.b32 %r17, %r0, 0, 0x1f, -1;
    shfl.sync.up.b32 %r5, %r0, 1, 0x1f, -1;
    sub.u32 %r18, %r0, %r0;
    and.b32 %r11, %r17, %r3;
    setp.gt.u32 %p1, %r17, %r17;
    vote.sync.ballot.b32 %r7, %p1, -1;
    vote.sync.any.pred %p2, %p1, -1;
    xor.b32 %r17, %r0, %r3;
    and.b32 %r6, %r7, %r5;
    shfl.sync.idx.b32 %r16, %r11, 0, 0x1f, -1;
    shfl.sync.idx.b32 %r9, %r3, 31, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
