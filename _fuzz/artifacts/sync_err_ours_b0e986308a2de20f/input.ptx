.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r19, %r3, 4294967295;
    cvt.s64.s32 %rd15, %r3;
    add.s32 %r13, %r3, %r3;
    or.b32 %r27, %r19, %r3;
    shr.u32 %r17, %r19, 0;
    or.b32 %r4, %r27, %r3;
    mul.lo.u32 %r17, %r19, %r27;
    min.s64 %rd9, %rd15, %rd15;
    shl.b32 %r12, %r13, 2;
    add.s32 %r24, %r27, %r3;
    mad.lo.s32 %r6, %r3, %r3, %r19;
    or.b64 %rd14, %rd15, %rd15;
    max.u32 %r7, %r12, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
