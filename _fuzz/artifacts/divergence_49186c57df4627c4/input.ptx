    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r10, %r3, 31;
    mad.lo.s32 %r7, %r3, %r10, %r10;
    setp.ge.s32 %p1, %r7, %r7;
    @!%p1 mad.lo.s32 %r13, %r7, %r3, %r7;
    selp.b32 %r12, %r7, %r10, %p1;
    setp.ge.s32 %p3, %r12, %r12;
    max.u32 %r15, %r12, %r13;
    add.u32 %r7, %r13, 32;
    sub.u32 %r12, %r15, %r13;
    min.u32 %r6, %r12, %r13;
    or.b32 %r10, %r12, 2147483648;
    and.b32 %r16, %r10, %r10;
    setp.eq.s32 %p1, %r6, 16;
    @!%p1 cvt.u64.u32 %rd14, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
