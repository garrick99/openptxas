.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p1, %r3, 3;
    @!%p1 shr.s32 %r11, %r3, 30;
    add.s32 %r23, %r11, 64;
    add.s32 %r10, %r23, 4;
    min.u32 %r19, %r23, %r3;
    cvt.u64.u32 %rd6, %r10;
    shr.s64 %rd5, %rd6, 2;
    max.s32 %r17, %r11, %r19;
    setp.ne.u32 %p3, %r23, %r17;
    @%p3 cvt.s64.s32 %rd14, %r11;
    max.u32 %r6, %r23, %r11;
    and.b32 %r19, %r19, %r3;
    shl.b32 %r8, %r19, 31;
    shr.s64 %rd8, %rd14, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
