.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p4, %r3, 1;
    @!%p4 cvt.s64.s32 %rd6, %r3;
    xor.b32 %r21, %r3, 4;
    shr.s32 %r27, %r21, 30;
    mul.lo.u32 %r17, %r21, %r27;
    xor.b32 %r10, %r21, 31;
    shr.s64 %rd9, %rd6, 0;
    mul.lo.s32 %r11, %r21, 64;
    and.b32 %r20, %r17, 4;
    mad.lo.s32 %r5, %r27, %r27, %r11;
    xor.b64 %rd14, %rd6, %rd6;
    cvt.s32.s64 %r4, %rd9;
    shl.b32 %r8, %r4, 31;
    mul.wide.u32 %rd14, %r11, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
