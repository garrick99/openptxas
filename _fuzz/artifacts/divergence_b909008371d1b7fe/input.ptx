.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r21, %r3, %r3;
    setp.hi.u32 %p1, %r21, %r3;
    @!%p1 shr.u32 %r23, %r3, 31;
    xor.b32 %r4, %r3, 15;
    and.b32 %r27, %r4, %r23;
    cvt.s64.s32 %rd15, %r21;
    max.u32 %r24, %r4, %r23;
    cvt.u32.u64 %r13, %rd15;
    mul.lo.u32 %r5, %r4, 2;
    max.u32 %r15, %r13, %r24;
    mad.lo.u32 %r6, %r27, %r24, %r15;
    mad.lo.s32 %r20, %r5, %r21, %r27;
    xor.b32 %r11, %r20, 7;
    add.s32 %r7, %r13, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
