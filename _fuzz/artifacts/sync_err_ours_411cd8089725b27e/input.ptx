.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r7, %r3, 65535;
    brev.b32 %r6, %r7;
    bfi.b32 %r18, %r7, %r6, 31, 4;
    max.u32 %r19, %r18, 8;
    bfe.s32 %r16, %r7, 0, 2;
    bfe.s32 %r4, %r19, 31, 2;
    bfi.b32 %r10, %r16, %r7, 23, 32;
    bfe.s32 %r20, %r16, 7, 1;
    bfe.u32 %r15, %r7, 16, 32;
    clz.b32 %r9, %r20;
    bfi.b32 %r21, %r9, %r7, 24, 2;
    clz.b32 %r4, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
