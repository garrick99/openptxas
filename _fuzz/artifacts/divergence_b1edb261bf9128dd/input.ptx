.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    mad.lo.u32 %r16, %r3, %r3, %r3;
    cvt.s32.s64 %r20, %rd15;
    add.s64 %rd6, %rd15, %rd15;
    setp.ls.u32 %p3, %r16, %r3;
    @%p3 cvt.s32.s64 %r26, %rd15;
    cvt.s64.s32 %rd7, %r26;
    mul.lo.s32 %r13, %r16, %r20;
    mul.lo.s64 %rd10, %rd6, %rd6;
    shr.u32 %r23, %r13, 30;
    mad.lo.u32 %r23, %r20, %r16, %r23;
    cvt.u64.u32 %rd9, %r20;
    mul.wide.u32 %rd7, %r26, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
