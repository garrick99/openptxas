.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r4, %r3, 255;
    setp.lt.s32 %p3, %r4, %r3;
    cvt.u64.u32 %rd13, %r4;
    xor.b64 %rd13, %rd13, %rd13;
    max.s32 %r24, %r4, 5;
    shr.u32 %r16, %r24, 4;
    add.s32 %r11, %r4, 65536;
    cvt.s64.s32 %rd11, %r11;
    shr.u32 %r22, %r11, 2;
    shl.b64 %rd15, %rd13, 1;
    add.s32 %r14, %r24, %r3;
    max.u64 %rd8, %rd15, %rd11;
    mul.wide.s32 %rd14, %r24, %r3;
    setp.eq.s32 %p1, %r16, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
