.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r15, %r3, 0;
    cvt.u64.u32 %rd13, %r3;
    or.b32 %r18, %r15, 64;
    or.b32 %r8, %r3, %r18;
    sub.u32 %r27, %r15, %r18;
    add.s32 %r20, %r27, %r18;
    max.u32 %r5, %r3, %r15;
    shr.s64 %rd12, %rd13, 15;
    xor.b32 %r24, %r20, %r20;
    sub.s64 %rd8, %rd13, %rd13;
    cvt.u32.u64 %r23, %rd13;
    add.u32 %r12, %r20, %r3;
    sub.u64 %rd13, %rd12, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
