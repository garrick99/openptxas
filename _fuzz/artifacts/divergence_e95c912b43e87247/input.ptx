.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    setp.lo.u32 %p2, %r3, 4;
    @%p2 min.s32 %r15, %r3, %r3;
    shr.u32 %r13, %r15, 3;
    cvt.u32.u64 %r8, %rd10;
    shl.b32 %r23, %r15, 15;
    or.b32 %r13, %r8, 64;
    setp.eq.s32 %p2, %r8, 1;
    setp.ge.s32 %p3, %r8, 15;
    sub.s32 %r20, %r23, 3;
    shr.u64 %rd5, %rd10, 48;
    add.u32 %r22, %r20, 4;
    min.u32 %r4, %r22, %r8;
    shr.s32 %r20, %r23, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
