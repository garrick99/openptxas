.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r21, %r3, %r3;
    shl.b32 %r12, %r3, 3;
    cvt.u64.u32 %rd6, %r21;
    min.s32 %r20, %r3, 4294967295;
    max.u32 %r25, %r20, 4;
    shl.b32 %r19, %r21, 31;
    cvt.u64.u32 %rd13, %r19;
    shr.u64 %rd10, %rd6, 15;
    sub.u32 %r4, %r12, 15;
    sub.s32 %r27, %r12, 16;
    mul.lo.u32 %r17, %r3, 2147483648;
    shr.u32 %r24, %r17, 4;
    sub.s32 %r17, %r25, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
