.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r11, %r3, 256;
    sub.u32 %r15, %r11, %r11;
    mul.lo.u32 %r15, %r3, %r15;
    max.u32 %r17, %r15, %r11;
    min.u32 %r24, %r3, %r17;
    cvt.u64.u32 %rd5, %r11;
    setp.eq.u32 %p3, %r17, %r15;
    @%p3 shl.b32 %r5, %r11, 1;
    shl.b32 %r18, %r24, 15;
    sub.u32 %r19, %r15, %r18;
    add.s32 %r9, %r11, %r24;
    sub.u32 %r18, %r9, %r15;
    shr.s32 %r11, %r15, 3;
    selp.b32 %r16, %r9, %r24, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
