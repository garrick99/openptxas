.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    mul.lo.s32 %r5, %r3, 15;
    cvt.u32.u64 %r10, %rd6;
    cvt.s32.s64 %r17, %rd6;
    and.b32 %r23, %r17, 255;
    add.s32 %r14, %r5, 1;
    mul.wide.s32 %rd5, %r23, %r23;
    mul.lo.s32 %r16, %r3, %r17;
    max.u64 %rd6, %rd6, %rd6;
    mad.lo.s32 %r8, %r23, %r3, %r23;
    shr.s64 %rd7, %rd5, 30;
    shr.s64 %rd13, %rd5, 16;
    xor.b32 %r14, %r14, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
