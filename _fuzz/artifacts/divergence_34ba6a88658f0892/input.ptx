.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r5, %r3, %r3;
    shr.s32 %r4, %r3, 30;
    cvt.s64.s32 %rd5, %r5;
    mul.wide.s32 %rd13, %r3, %r4;
    and.b32 %r26, %r5, %r5;
    max.s32 %r12, %r26, 256;
    min.s32 %r7, %r12, %r4;
    shl.b32 %r10, %r4, 1;
    cvt.s64.s32 %rd10, %r4;
    shr.s32 %r26, %r4, 31;
    add.u32 %r20, %r10, %r10;
    setp.ne.u32 %p3, %r10, %r4;
    min.u64 %rd8, %rd10, %rd5;
    cvt.s32.s64 %r14, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
