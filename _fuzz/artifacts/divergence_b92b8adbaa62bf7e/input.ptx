.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r6, %r3, %r3;
    sub.s32 %r6, %r6, %r6;
    setp.lt.s32 %p4, %r3, %r6;
    @%p4 sub.u32 %r17, %r6, 15;
    mul.wide.s32 %rd10, %r3, %r17;
    setp.lt.s32 %p4, %r3, %r3;
    mad.lo.s32 %r15, %r3, %r17, %r17;
    shr.u32 %r7, %r6, 16;
    mul.lo.u32 %r5, %r6, %r7;
    mad.lo.s32 %r18, %r15, %r3, %r7;
    max.u32 %r20, %r7, %r6;
    min.s64 %rd13, %rd10, %rd10;
    cvt.u64.u32 %rd8, %r20;
    xor.b32 %r5, %r18, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
