.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p2, %r3, %r3;
    @%p2 selp.b32 %r8, %r3, %r3, %p2;
    cvt.s64.s32 %rd9, %r8;
    cvt.u32.u64 %r12, %rd9;
    sub.u32 %r8, %r8, %r3;
    and.b32 %r5, %r3, %r12;
    max.u32 %r16, %r12, 8;
    mul.lo.u64 %rd5, %rd9, %rd9;
    cvt.u32.u64 %r26, %rd5;
    selp.b32 %r15, %r8, %r26, %p2;
    mul.lo.u32 %r11, %r12, %r15;
    shr.s32 %r9, %r5, 0;
    shr.s32 %r6, %r11, 31;
    shr.u32 %r5, %r6, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
