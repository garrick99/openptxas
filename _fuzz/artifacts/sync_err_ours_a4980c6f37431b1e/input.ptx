.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd10, %r3;
    shl.b32 %r20, %r3, 0;
    sub.s32 %r22, %r20, %r20;
    add.s32 %r6, %r3, %r20;
    shr.s32 %r16, %r22, 31;
    and.b32 %r19, %r20, 5;
    shr.s32 %r11, %r19, 15;
    sub.u32 %r5, %r11, 5;
    shr.s64 %rd15, %rd10, 3;
    setp.lt.u32 %p3, %r5, %r5;
    @!%p3 shr.s32 %r14, %r22, 3;
    shl.b32 %r21, %r11, 31;
    shr.u32 %r22, %r19, 15;
    min.u32 %r24, %r14, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
