.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r18, %r3, %r3;
    add.s32 %r24, %r18, 3;
    and.b32 %r7, %r18, 4;
    min.u32 %r14, %r18, 16;
    setp.le.u32 %p2, %r14, 255;
    max.u32 %r13, %r3, %r3;
    setp.lt.s32 %p4, %r7, 2147483648;
    setp.hi.u32 %p3, %r18, 1;
    @%p3 xor.b32 %r17, %r13, 3;
    or.b32 %r15, %r13, 256;
    mad.lo.u32 %r27, %r24, %r7, %r14;
    max.u32 %r7, %r24, %r13;
    xor.b32 %r18, %r17, %r14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
