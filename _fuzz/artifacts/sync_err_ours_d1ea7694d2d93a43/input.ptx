.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    shl.b64 %rd11, %rd15, 3;
    cvt.u32.u64 %r23, %rd11;
    max.s32 %r10, %r23, 16;
    max.s32 %r5, %r23, %r3;
    xor.b32 %r10, %r23, %r10;
    and.b32 %r7, %r5, %r3;
    setp.gt.s32 %p2, %r7, %r23;
    @%p2 sub.u32 %r16, %r10, %r5;
    cvt.s32.s64 %r15, %rd15;
    min.u32 %r11, %r15, 3;
    shl.b32 %r4, %r11, 16;
    shl.b64 %rd10, %rd15, 3;
    min.s32 %r26, %r16, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
