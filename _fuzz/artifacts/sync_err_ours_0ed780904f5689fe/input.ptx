.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd5, %r3, %r3;
    max.u32 %r22, %r3, 7;
    shl.b32 %r17, %r22, 0;
    mul.wide.s32 %rd5, %r22, %r17;
    max.u32 %r26, %r17, 0;
    or.b32 %r19, %r17, 15;
    add.s32 %r13, %r17, %r22;
    mul.lo.s32 %r8, %r19, %r22;
    shr.s32 %r7, %r22, 2;
    sub.u32 %r8, %r17, %r13;
    mul.wide.u32 %rd8, %r8, %r8;
    sub.u64 %rd13, %rd5, %rd8;
    shr.s32 %r13, %r19, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
