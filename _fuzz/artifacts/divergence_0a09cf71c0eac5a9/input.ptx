.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r26, %r3, 2147483647;
    shr.s32 %r26, %r26, 15;
    max.s32 %r24, %r3, %r26;
    cvt.s64.s32 %rd7, %r24;
    mad.lo.u32 %r27, %r26, %r26, %r26;
    shl.b32 %r24, %r3, 31;
    add.s32 %r25, %r26, %r26;
    shr.u32 %r17, %r3, 31;
    shl.b32 %r21, %r24, 15;
    shl.b32 %r7, %r25, 3;
    mul.lo.s32 %r26, %r25, 4294967295;
    max.s32 %r27, %r7, 65535;
    add.u32 %r27, %r24, %r17;
    add.s32 %r4, %r21, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
