.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r7, %r3, 2;
    mul.lo.s32 %r26, %r7, %r3;
    mul.lo.s32 %r24, %r7, 5;
    shl.b32 %r13, %r7, 2;
    mul.wide.u32 %rd14, %r7, %r24;
    max.s32 %r26, %r3, %r24;
    or.b64 %rd13, %rd14, %rd14;
    cvt.u32.u64 %r19, %rd13;
    and.b32 %r24, %r19, 32;
    min.u32 %r21, %r13, %r26;
    setp.ge.s32 %p3, %r21, %r24;
    @%p3 min.s32 %r9, %r13, 4294967295;
    cvt.u32.u64 %r15, %rd13;
    mul.lo.s32 %r19, %r7, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
