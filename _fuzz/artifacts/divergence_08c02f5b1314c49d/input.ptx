.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r6, %r3, %r3;
    cvt.s64.s32 %rd13, %r6;
    cvt.u32.u64 %r25, %rd13;
    shl.b64 %rd13, %rd13, 2;
    setp.lt.s32 %p2, %r25, %r6;
    @%p2 mad.lo.s32 %r15, %r3, %r3, %r25;
    mad.lo.u32 %r22, %r25, %r6, %r15;
    cvt.s64.s32 %rd10, %r22;
    xor.b64 %rd8, %rd10, %rd13;
    xor.b32 %r10, %r15, 16;
    or.b32 %r10, %r6, 32;
    shl.b32 %r8, %r25, 1;
    mad.lo.u32 %r18, %r3, %r6, %r22;
    cvt.s64.s32 %rd13, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
