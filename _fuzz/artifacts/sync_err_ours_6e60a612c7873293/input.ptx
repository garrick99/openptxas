.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    add.s32 %r17, %r3, %r3;
    cvt.u32.u64 %r6, %rd13;
    setp.ls.u32 %p4, %r17, %r3;
    @%p4 add.u32 %r19, %r6, %r6;
    min.s32 %r12, %r19, %r3;
    cvt.s32.s64 %r18, %rd13;
    max.u64 %rd7, %rd13, %rd13;
    cvt.u32.u64 %r14, %rd7;
    mul.lo.u32 %r22, %r3, 256;
    shr.s32 %r7, %r22, 7;
    selp.b32 %r26, %r12, %r6, %p4;
    min.u32 %r25, %r17, 3;
    shl.b64 %rd15, %rd7, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
