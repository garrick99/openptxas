.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p4, %r3, 16;
    @!%p4 mad.lo.u32 %r21, %r3, %r3, %r3;
    mad.lo.u32 %r8, %r21, %r3, %r21;
    mul.wide.u32 %rd13, %r3, %r8;
    shl.b64 %rd15, %rd13, 63;
    cvt.u64.u32 %rd13, %r21;
    min.s32 %r18, %r3, 1;
    and.b32 %r15, %r18, 7;
    cvt.u64.u32 %rd7, %r18;
    sub.u32 %r5, %r8, 65535;
    mul.lo.u32 %r25, %r5, 15;
    max.s32 %r20, %r25, 64;
    min.s64 %rd13, %rd13, %rd13;
    add.s32 %r20, %r8, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
