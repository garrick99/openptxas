.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r10, %r3, %r3;
    add.u32 %r24, %r3, 2147483648;
    mul.lo.s32 %r16, %r10, 2147483647;
    cvt.s64.s32 %rd12, %r24;
    shr.u64 %rd6, %rd12, 2;
    min.u32 %r6, %r24, 65536;
    mul.lo.u32 %r26, %r16, 4;
    shl.b32 %r24, %r6, 3;
    shl.b32 %r20, %r10, 4;
    cvt.u32.u64 %r26, %rd12;
    mad.lo.s32 %r23, %r3, %r16, %r16;
    shl.b32 %r8, %r16, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
