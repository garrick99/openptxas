.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r27, %r3, 3;
    cvt.s64.s32 %rd12, %r27;
    add.s64 %rd12, %rd12, %rd12;
    mul.lo.s32 %r17, %r27, 4294967295;
    shl.b64 %rd9, %rd12, 15;
    setp.eq.u32 %p1, %r3, 63;
    @%p1 or.b32 %r8, %r27, %r17;
    selp.b32 %r20, %r3, %r27, %p1;
    shr.s64 %rd9, %rd9, 33;
    or.b32 %r13, %r17, %r27;
    max.s32 %r14, %r8, 4294967295;
    xor.b32 %r14, %r14, %r3;
    setp.gt.s32 %p1, %r3, 0;
