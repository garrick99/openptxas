.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r8, %r3, %r3, %r3;
    add.u32 %r16, %r3, %r3;
    add.u32 %r17, %r3, 0;
    setp.ls.u32 %p1, %r8, %r3;
    @!%p1 add.u32 %r8, %r3, %r16;
    mul.wide.u32 %rd5, %r8, %r17;
    mad.lo.s32 %r6, %r3, %r17, %r3;
    setp.ge.s32 %p4, %r16, %r8;
    sub.u32 %r16, %r3, %r6;
    setp.lt.s32 %p1, %r16, %r17;
    @%p1 add.u32 %r27, %r16, 31;
    mul.lo.u32 %r22, %r16, %r6;
    xor.b32 %r9, %r6, %r3;
    mad.lo.s32 %r9, %r17, %r27, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
