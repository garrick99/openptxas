    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r19, %r3, 4;
    cvt.u64.u32 %rd7, %r3;
    setp.gt.s32 %p4, %r3, 1;
    sub.u32 %r10, %r3, 4;
    cvt.u32.u64 %r7, %rd7;
    setp.hi.u32 %p3, %r19, 2;
    @%p3 min.u32 %r13, %r3, %r7;
    mad.lo.s32 %r6, %r10, %r3, %r10;
    or.b32 %r12, %r10, %r10;
    max.s32 %r17, %r19, 31;
