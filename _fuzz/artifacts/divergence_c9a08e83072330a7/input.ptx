.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    mul.lo.s32 %r20, %r3, 2147483647;
    max.u32 %r12, %r3, %r3;
    sub.u32 %r27, %r3, 16;
    and.b32 %r26, %r12, 8;
    setp.lt.u32 %p2, %r20, %r26;
    @!%p2 cvt.s32.s64 %r17, %rd14;
    max.s32 %r5, %r27, 3;
    min.s32 %r18, %r26, %r12;
    shr.s32 %r16, %r27, 15;
    shl.b64 %rd13, %rd14, 48;
    and.b32 %r10, %r5, %r20;
    mul.lo.s64 %rd9, %rd13, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
