    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r13, %r3, 0;
    mul.lo.u32 %r11, %r13, 32;
    mul.wide.s32 %rd13, %r11, %r3;
    max.u32 %r26, %r11, %r11;
    min.s32 %r11, %r3, %r3;
    shr.s64 %rd7, %rd13, 4;
    and.b32 %r27, %r26, %r13;
    shr.s64 %rd14, %rd7, 0;
    max.s32 %r6, %r26, 2147483647;
    add.u32 %r18, %r11, 4;
    shl.b64 %rd10, %rd14, 3;
    shl.b32 %r4, %r13, 1;
    add.s32 %r13, %r26, 16;
    or.b32 %r4, %r18, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
