.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r17, %r3, 7;
    cvt.u64.u32 %rd13, %r17;
    mul.wide.u32 %rd14, %r3, %r3;
    shl.b32 %r7, %r17, 1;
    and.b32 %r12, %r3, %r17;
    add.s32 %r15, %r12, 5;
    add.s32 %r11, %r7, %r17;
    mad.lo.s32 %r25, %r11, %r7, %r7;
    and.b32 %r6, %r11, 0;
    mul.lo.u32 %r22, %r11, %r3;
    shr.s32 %r25, %r25, 30;
    shr.u32 %r10, %r22, 1;
    add.s32 %r10, %r11, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
