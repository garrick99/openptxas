.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    bfe.s32 %r22, %r3, 31, 1;
    add.u32 %r13, %r3, %r22;
    bfe.u32 %r7, %r22, 7, 32;
    popc.b32 %r17, %r13;
    brev.b32 %r18, %r17;
    popc.b32 %r16, %r18;
    bfe.u32 %r17, %r16, 16, 32;
    bfe.s32 %r22, %r16, 0, 16;
    brev.b32 %r4, %r16;
    bfe.u32 %r7, %r16, 8, 24;
    brev.b32 %r6, %r7;
    bfe.s32 %r13, %r4, 31, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
