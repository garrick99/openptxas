.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r16, %r3, %r3;
    cvt.u64.u32 %rd13, %r3;
    min.s32 %r13, %r3, 32;
    cvt.s32.s64 %r10, %rd13;
    xor.b64 %rd7, %rd13, %rd13;
    setp.hi.u32 %p1, %r10, %r3;
    @!%p1 mad.lo.u32 %r25, %r13, %r16, %r13;
    setp.hs.u32 %p3, %r10, 7;
    @%p3 mad.lo.s32 %r20, %r3, %r3, %r16;
    shr.u64 %rd6, %rd13, 62;
    mul.lo.u32 %r26, %r13, 64;
    cvt.u32.u64 %r11, %rd13;
    max.u32 %r23, %r3, 3;
    add.u32 %r15, %r25, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
