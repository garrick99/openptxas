.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p3, %r3, 16;
    @%p3 mul.lo.s32 %r24, %r3, %r3;
    or.b32 %r9, %r24, 2147483647;
    and.b32 %r11, %r24, %r9;
    mul.wide.s32 %rd9, %r9, %r9;
    selp.b32 %r8, %r11, %r9, %p3;
    sub.s32 %r23, %r9, 0;
    cvt.s32.s64 %r13, %rd9;
    min.s32 %r4, %r23, 4;
    shl.b32 %r22, %r13, 31;
    shr.u64 %rd9, %rd9, 32;
    max.u64 %rd10, %rd9, %rd9;
    min.u32 %r22, %r13, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
