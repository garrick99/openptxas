.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r15, %r3, %r3;
    min.s32 %r27, %r3, %r3;
    mul.lo.u32 %r16, %r27, %r27;
    mul.wide.u32 %rd6, %r16, %r15;
    shl.b64 %rd11, %rd6, 7;
    cvt.s32.s64 %r9, %rd11;
    and.b32 %r23, %r16, %r3;
    min.u32 %r21, %r15, 64;
    xor.b32 %r17, %r15, %r23;
    xor.b64 %rd14, %rd11, %rd6;
    mul.wide.u32 %rd13, %r23, %r15;
    or.b32 %r8, %r23, 65535;
    shr.s64 %rd8, %rd6, 33;
    min.s32 %r14, %r3, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
