.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    cvt.u64.u32 %rd14, %r3;
    sub.u32 %r10, %r3, %r3;
    sub.u32 %r9, %r3, 65536;
    setp.lt.s32 %p2, %r10, %r3;
    @%p2 shr.u64 %rd6, %rd9, 16;
    mul.wide.s32 %rd15, %r9, %r9;
    sub.u32 %r8, %r9, %r9;
    cvt.s64.s32 %rd14, %r9;
    shr.s32 %r10, %r8, 1;
    min.s32 %r19, %r9, %r3;
    mul.wide.s32 %rd8, %r19, %r8;
    and.b64 %rd10, %rd6, %rd9;
    min.s32 %r13, %r9, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
