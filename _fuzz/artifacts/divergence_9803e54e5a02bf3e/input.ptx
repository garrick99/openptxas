.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r21, %r3, 2;
    cvt.u64.u32 %rd6, %r3;
    cvt.u32.u64 %r19, %rd6;
    max.s32 %r17, %r21, %r21;
    mul.wide.s32 %rd12, %r19, %r3;
    shr.s32 %r23, %r19, 30;
    and.b32 %r6, %r23, %r23;
    cvt.s64.s32 %rd9, %r6;
    or.b32 %r6, %r19, %r19;
    mul.lo.u32 %r26, %r3, 4294967295;
    min.s64 %rd6, %rd12, %rd9;
    add.s32 %r6, %r21, 2147483648;
    xor.b32 %r24, %r26, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
