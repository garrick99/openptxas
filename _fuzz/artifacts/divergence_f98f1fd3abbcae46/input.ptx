.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r22, %r3, 3;
    or.b32 %r6, %r22, %r3;
    mul.lo.s32 %r5, %r3, %r22;
    and.b32 %r8, %r5, 31;
    or.b32 %r15, %r6, 63;
    sub.s32 %r9, %r22, 255;
    min.s32 %r26, %r6, %r8;
    cvt.u64.u32 %rd13, %r22;
    cvt.s64.s32 %rd12, %r22;
    cvt.u32.u64 %r19, %rd12;
    min.s32 %r14, %r5, 64;
    mul.wide.s32 %rd8, %r3, %r22;
    add.u64 %rd14, %rd8, %rd13;
    add.s32 %r23, %r22, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
