.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r13, %r3, %r3;
    sub.s32 %r11, %r13, %r13;
    mul.lo.s32 %r16, %r13, %r11;
    setp.ge.s32 %p1, %r13, %r3;
    @%p1 min.s32 %r21, %r3, %r3;
    setp.hi.u32 %p1, %r16, %r16;
    @!%p1 cvt.s64.s32 %rd6, %r13;
    shr.u32 %r5, %r13, 0;
    mul.wide.s32 %rd5, %r5, %r13;
    sub.s32 %r11, %r11, %r21;
    max.s32 %r8, %r13, %r11;
    setp.ls.u32 %p3, %r11, 16;
    setp.lt.s32 %p2, %r21, %r5;
    @%p2 shr.u32 %r13, %r13, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
