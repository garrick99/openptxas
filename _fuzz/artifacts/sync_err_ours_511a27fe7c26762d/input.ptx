.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p1, %r3, %r3;
    @!%p1 or.b32 %r7, %r3, 256;
    setp.lt.s32 %p1, %r7, %r3;
    cvt.s64.s32 %rd14, %r3;
    mad.lo.s32 %r19, %r3, %r7, %r3;
    mul.wide.s32 %rd11, %r3, %r7;
    mul.lo.s64 %rd12, %rd11, %rd14;
    shl.b32 %r7, %r7, 16;
    mul.lo.u32 %r26, %r19, %r3;
    setp.lo.u32 %p3, %r19, 255;
    setp.eq.u32 %p1, %r26, %r7;
    @%p1 mul.lo.s32 %r9, %r7, %r3;
    shr.u32 %r15, %r9, 0;
    mul.lo.u32 %r24, %r3, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
