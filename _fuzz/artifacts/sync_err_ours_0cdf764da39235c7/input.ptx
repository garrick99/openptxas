.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p3, %r3, 2;
    @%p3 xor.b32 %r26, %r3, 0;
    xor.b32 %r23, %r3, 31;
    setp.lt.s32 %p4, %r26, 31;
    @%p4 cvt.s64.s32 %rd10, %r3;
    shr.s32 %r11, %r23, 1;
    setp.lt.s32 %p1, %r23, 0;
    @!%p1 max.u64 %rd6, %rd10, %rd10;
    mul.lo.s32 %r4, %r3, %r11;
    min.u32 %r11, %r23, %r11;
    sub.u32 %r9, %r3, %r26;
    min.s64 %rd6, %rd10, %rd6;
    cvt.s64.s32 %rd7, %r23;
    shr.s64 %rd10, %rd6, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
