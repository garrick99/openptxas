.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r6, %r3, %r3;
    cvt.u64.u32 %rd11, %r3;
    mad.lo.u32 %r10, %r6, %r3, %r3;
    and.b32 %r27, %r6, 31;
    min.u32 %r27, %r27, 5;
    mad.lo.u32 %r26, %r10, %r6, %r3;
    setp.ne.u32 %p4, %r26, %r10;
    @%p4 shr.u32 %r16, %r6, 15;
    shr.s32 %r23, %r6, 2;
    max.u32 %r9, %r10, %r23;
    shl.b64 %rd13, %rd11, 2;
    max.u32 %r5, %r26, %r27;
    min.s32 %r16, %r16, 4;
    mul.lo.u32 %r15, %r16, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
