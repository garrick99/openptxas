.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r20, %r3, %r3, %r3;
    max.u32 %r25, %r20, %r20;
    xor.b32 %r15, %r3, %r3;
    cvt.u64.u32 %rd11, %r15;
    and.b32 %r27, %r20, %r20;
    max.u64 %rd10, %rd11, %rd11;
    max.u32 %r14, %r20, 4294967295;
    mad.lo.s32 %r25, %r3, %r14, %r25;
    add.s32 %r18, %r14, %r20;
    setp.gt.s32 %p3, %r25, 0;
    @%p3 max.s32 %r10, %r20, %r20;
    mul.lo.s64 %rd11, %rd11, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
