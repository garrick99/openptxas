.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    shr.s64 %rd13, %rd15, 2;
    cvt.u32.u64 %r6, %rd15;
    min.u32 %r4, %r3, 1;
    or.b32 %r15, %r6, %r4;
    shl.b64 %rd7, %rd15, 16;
    cvt.s32.s64 %r20, %rd15;
    cvt.s32.s64 %r7, %rd7;
    shl.b64 %rd6, %rd15, 63;
    mul.lo.u32 %r15, %r20, %r7;
    xor.b32 %r24, %r20, %r15;
    max.u32 %r21, %r6, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
