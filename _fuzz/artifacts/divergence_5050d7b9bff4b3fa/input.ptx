.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r5, %r3, %r3;
    mul.wide.u32 %rd13, %r3, %r3;
    mad.lo.s32 %r18, %r5, %r3, %r5;
    min.u64 %rd12, %rd13, %rd13;
    min.s32 %r4, %r18, 63;
    sub.s64 %rd14, %rd12, %rd13;
    or.b32 %r14, %r4, %r5;
    shl.b32 %r6, %r4, 0;
    mul.lo.u32 %r10, %r18, %r4;
    and.b32 %r4, %r6, %r5;
    mul.wide.s32 %rd7, %r5, %r4;
    shr.s64 %rd13, %rd7, 3;
    sub.s32 %r5, %r4, 3;
    xor.b32 %r25, %r4, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
