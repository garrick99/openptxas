.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r22, %r3, %r3;
    max.s32 %r10, %r3, 8;
    mad.lo.u32 %r20, %r22, %r10, %r22;
    shr.s32 %r23, %r20, 1;
    sub.u32 %r4, %r20, 3;
    cvt.s64.s32 %rd7, %r20;
    cvt.s32.s64 %r17, %rd7;
    mul.lo.u32 %r16, %r23, %r4;
    and.b32 %r8, %r16, %r20;
    mul.wide.s32 %rd10, %r20, %r16;
    shr.s32 %r26, %r20, 4;
    mul.lo.u64 %rd9, %rd7, %rd10;
    max.u64 %rd15, %rd7, %rd9;
    min.s32 %r19, %r8, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
