.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p1, %r3, 0;
    @%p1 shl.b32 %r20, %r3, 3;
    cvt.s64.s32 %rd15, %r20;
    or.b32 %r17, %r3, 31;
    shr.u32 %r10, %r20, 3;
    selp.b32 %r23, %r3, %r17, %p1;
    mul.wide.s32 %rd7, %r10, %r3;
    setp.ls.u32 %p4, %r20, %r23;
    @%p4 selp.b32 %r10, %r3, %r17, %p1;
    min.s32 %r7, %r20, %r20;
    mad.lo.u32 %r19, %r3, %r7, %r23;
    mul.wide.s32 %rd10, %r19, %r19;
    mul.wide.u32 %rd11, %r3, %r20;
    mad.lo.u32 %r20, %r17, %r23, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
