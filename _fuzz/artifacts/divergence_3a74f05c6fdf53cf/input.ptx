.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r11, %r3, %r3, %r3;
    mul.wide.u32 %rd7, %r3, %r11;
    max.u32 %r20, %r11, 31;
    min.s32 %r19, %r3, 4294967295;
    shl.b64 %rd13, %rd7, 7;
    cvt.s32.s64 %r14, %rd13;
    setp.eq.s32 %p3, %r20, %r3;
    shr.u64 %rd15, %rd7, 2;
    max.u64 %rd13, %rd15, %rd13;
    add.s32 %r17, %r19, %r11;
    selp.b32 %r17, %r11, %r17, %p3;
    mul.lo.s32 %r16, %r17, %r17;
    mul.wide.s32 %rd11, %r11, %r19;
    setp.ge.s32 %p4, %r11, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
