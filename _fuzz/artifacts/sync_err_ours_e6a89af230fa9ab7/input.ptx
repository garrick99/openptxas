.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r17, %r3, 16;
    and.b32 %r21, %r3, 65536;
    sub.s32 %r22, %r17, 2147483648;
    add.u32 %r12, %r22, %r21;
    setp.gt.s32 %p4, %r17, 16;
    @%p4 selp.b32 %r9, %r3, %r3, %p4;
    mul.lo.s32 %r11, %r22, 31;
    mul.lo.u32 %r15, %r3, %r12;
    max.u32 %r21, %r11, %r15;
    cvt.u64.u32 %rd11, %r15;
    mad.lo.u32 %r14, %r12, %r17, %r12;
    shr.s32 %r14, %r11, 0;
    shr.u32 %r5, %r17, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
