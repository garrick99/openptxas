.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r21, %r3, %r3;
    or.b32 %r20, %r3, %r21;
    xor.b32 %r21, %r20, %r3;
    shr.u32 %r7, %r20, 0;
    shr.u32 %r12, %r20, 30;
    mul.lo.u32 %r18, %r12, %r7;
    max.s32 %r16, %r7, %r12;
    cvt.u64.u32 %rd14, %r16;
    xor.b32 %r11, %r3, 0;
    xor.b32 %r19, %r20, 3;
    shr.s64 %rd12, %rd14, 15;
    min.u32 %r5, %r12, 64;
    mul.lo.u64 %rd10, %rd14, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
