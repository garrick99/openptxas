.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r19, %r3, 1;
    shl.b32 %r4, %r19, 7;
    sub.s32 %r27, %r3, %r19;
    and.b32 %r27, %r27, %r27;
    min.s32 %r9, %r4, 255;
    setp.eq.s32 %p3, %r9, 2147483648;
    @%p3 shr.s32 %r5, %r4, 2;
    cvt.u64.u32 %rd13, %r4;
    shr.u32 %r24, %r9, 1;
    mul.wide.s32 %rd12, %r27, %r24;
    or.b32 %r7, %r24, 32;
    cvt.s32.s64 %r22, %rd12;
    setp.ge.s32 %p4, %r7, 65535;
    add.s32 %r21, %r7, 3;
