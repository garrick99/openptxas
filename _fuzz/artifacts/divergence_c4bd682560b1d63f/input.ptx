.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r21, %r3, 7;
    mad.lo.u32 %r23, %r3, %r21, %r3;
    shr.u32 %r13, %r23, 7;
    cvt.s64.s32 %rd12, %r23;
    setp.le.s32 %p2, %r3, %r13;
    @!%p2 sub.s32 %r20, %r3, 2147483648;
    mul.wide.s32 %rd15, %r21, %r13;
    add.s32 %r25, %r13, %r21;
    add.u32 %r21, %r20, %r13;
    mad.lo.u32 %r9, %r21, %r25, %r21;
    setp.gt.s32 %p4, %r23, %r20;
    mad.lo.s32 %r5, %r13, %r20, %r9;
    max.u32 %r11, %r5, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
