.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.u32 %p3, %r0, %r0;
    vote.sync.ballot.b32 %r14, %p3, -1;
    shfl.sync.down.b32 %r6, %r3, 2, 0x1f, -1;
    max.u32 %r14, %r0, %r0;
    shfl.sync.down.b32 %r6, %r14, 4, 0x1f, -1;
    setp.ne.u32 %p1, %r6, %r3;
    vote.sync.ballot.b32 %r10, %p1, -1;
    setp.gt.u32 %p3, %r10, %r14;
    vote.sync.ballot.b32 %r4, %p3, -1;
    min.u32 %r5, %r0, %r3;
    min.u32 %r19, %r4, %r5;
    setp.ne.u32 %p3, %r14, %r4;
    vote.sync.ballot.b32 %r12, %p3, -1;
    vote.sync.all.pred %p1, %p1, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
