    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r12, %r3, 2147483647;
    xor.b32 %r24, %r12, 3;
    max.s32 %r23, %r24, %r24;
    or.b32 %r14, %r23, 4;
    shl.b32 %r17, %r23, 3;
    add.s32 %r19, %r14, 255;
    add.u32 %r18, %r12, 3;
    mul.wide.u32 %rd6, %r24, %r24;
    add.u32 %r24, %r17, %r12;
    max.u32 %r23, %r18, 65535;
    sub.s64 %rd15, %rd6, %rd6;
    min.u64 %rd5, %rd15, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
