.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r5, %r3, 0;
    cvt.s64.s32 %rd10, %r3;
    shl.b64 %rd12, %rd10, 16;
    shr.u32 %r4, %r3, 16;
    mad.lo.u32 %r6, %r4, %r4, %r4;
    mul.wide.u32 %rd9, %r6, %r6;
    max.s32 %r9, %r3, 15;
    shl.b32 %r22, %r9, 2;
    xor.b32 %r26, %r9, 4;
    xor.b32 %r11, %r26, %r22;
    add.s32 %r21, %r5, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
