.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r26, %r3, 2;
    mul.wide.u32 %rd7, %r3, %r26;
    or.b32 %r14, %r26, %r26;
    add.u32 %r17, %r26, 63;
    shl.b32 %r22, %r26, 3;
    shr.u32 %r10, %r26, 0;
    min.s64 %rd15, %rd7, %rd7;
    mad.lo.u32 %r10, %r26, %r22, %r26;
    mul.lo.s32 %r11, %r3, 2147483648;
    sub.s64 %rd11, %rd15, %rd7;
    cvt.u32.u64 %r7, %rd15;
    setp.gt.u32 %p4, %r3, %r22;
    @%p4 max.u32 %r9, %r26, %r7;
    selp.b32 %r14, %r10, %r9, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
