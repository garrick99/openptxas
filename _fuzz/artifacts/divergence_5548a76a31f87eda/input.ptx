.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r6, %r3, %r3;
    cvt.u64.u32 %rd9, %r6;
    shr.s32 %r6, %r3, 30;
    mad.lo.u32 %r4, %r3, %r6, %r3;
    and.b64 %rd14, %rd9, %rd9;
    or.b32 %r4, %r6, %r4;
    max.s32 %r26, %r4, 2147483647;
    and.b64 %rd7, %rd9, %rd9;
    and.b32 %r10, %r4, %r4;
    or.b32 %r20, %r10, %r26;
    shl.b32 %r19, %r6, 2;
    or.b32 %r9, %r4, %r3;
    shr.u32 %r6, %r20, 1;
    setp.lt.u32 %p3, %r6, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
