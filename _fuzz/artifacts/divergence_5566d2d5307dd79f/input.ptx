.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r26, %r3, 0;
    cvt.u64.u32 %rd11, %r26;
    shl.b32 %r8, %r3, 0;
    cvt.u32.u64 %r8, %rd11;
    setp.lt.s32 %p1, %r8, %r8;
    @%p1 selp.b32 %r7, %r26, %r8, %p1;
    sub.u32 %r9, %r26, 5;
    max.s64 %rd8, %rd11, %rd11;
    or.b32 %r20, %r9, %r9;
    cvt.u32.u64 %r19, %rd8;
    xor.b32 %r21, %r9, %r20;
    cvt.u32.u64 %r4, %rd8;
    selp.b32 %r7, %r8, %r9, %p1;
    mad.lo.s32 %r10, %r7, %r9, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
