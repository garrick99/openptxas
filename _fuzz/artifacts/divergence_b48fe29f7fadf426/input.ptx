.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r9, %r3, %r3;
    sub.u32 %r16, %r3, %r9;
    and.b32 %r10, %r3, 8;
    shr.u32 %r12, %r3, 7;
    cvt.s64.s32 %rd7, %r16;
    mad.lo.u32 %r17, %r9, %r9, %r3;
    shr.s64 %rd8, %rd7, 2;
    shl.b32 %r20, %r17, 7;
    setp.eq.s32 %p4, %r3, 16;
    @%p4 max.u32 %r26, %r10, 255;
    min.u32 %r16, %r9, 7;
    mad.lo.u32 %r21, %r12, %r10, %r26;
    shl.b64 %rd8, %rd8, 33;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
