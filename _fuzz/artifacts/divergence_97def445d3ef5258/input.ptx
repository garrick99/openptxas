.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    mul.lo.s32 %r24, %r3, %r3;
    mad.lo.u32 %r10, %r3, %r24, %r24;
    mad.lo.u32 %r17, %r10, %r3, %r3;
    or.b32 %r4, %r10, 65536;
    max.s32 %r24, %r4, %r17;
    sub.s32 %r17, %r4, %r10;
    setp.ge.s32 %p2, %r24, 16;
    @%p2 shr.u32 %r26, %r10, 15;
    cvt.u32.u64 %r14, %rd7;
    sub.u32 %r27, %r24, 255;
    shr.u32 %r6, %r24, 31;
    shr.u32 %r13, %r24, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
