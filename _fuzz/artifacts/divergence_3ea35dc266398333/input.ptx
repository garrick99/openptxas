.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p1, %r3, 15;
    @%p1 sub.u32 %r14, %r3, %r3;
    cvt.s64.s32 %rd10, %r14;
    max.u32 %r22, %r14, 5;
    mul.wide.s32 %rd7, %r14, %r14;
    mad.lo.s32 %r25, %r14, %r22, %r14;
    mul.lo.u32 %r10, %r14, %r14;
    sub.s32 %r13, %r14, 65536;
    min.s32 %r25, %r13, %r3;
    xor.b32 %r16, %r13, 7;
    cvt.u32.u64 %r11, %rd10;
    mad.lo.s32 %r9, %r3, %r3, %r10;
    min.u32 %r16, %r14, %r14;
    sub.s32 %r18, %r14, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
