.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r26, %r3, 5;
    add.s32 %r13, %r26, 16;
    or.b32 %r5, %r13, 255;
    add.u32 %r10, %r5, %r3;
    add.s32 %r16, %r13, 32;
    setp.gt.s32 %p2, %r13, %r10;
    @!%p2 mul.wide.u32 %rd12, %r13, %r3;
    shr.s64 %rd5, %rd12, 7;
    setp.ge.s32 %p3, %r13, %r10;
    @%p3 mul.lo.s32 %r10, %r16, %r5;
    selp.b32 %r5, %r26, %r3, %p3;
    xor.b64 %rd7, %rd12, %rd5;
    max.u32 %r10, %r16, %r13;
    min.u32 %r10, %r10, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
