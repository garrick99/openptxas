.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    mul.lo.s64 %rd6, %rd11, %rd11;
    setp.lt.s32 %p4, %r3, 5;
    sub.u32 %r23, %r3, 1;
    cvt.s64.s32 %rd10, %r3;
    max.s32 %r5, %r23, 31;
    shr.u64 %rd15, %rd10, 63;
    add.s32 %r4, %r23, %r23;
    mad.lo.s32 %r7, %r4, %r5, %r4;
    max.u64 %rd15, %rd15, %rd10;
    sub.s32 %r25, %r5, 7;
    max.s64 %rd15, %rd6, %rd11;
    setp.ge.u32 %p3, %r3, %r25;
    @%p3 shr.s64 %rd7, %rd11, 33;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
