.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    and.b32 %r8, %r3, %r3;
    shl.b32 %r27, %r3, 7;
    mul.lo.u32 %r22, %r8, %r3;
    min.u64 %rd6, %rd5, %rd5;
    add.s32 %r14, %r8, 2147483648;
    mul.wide.u32 %rd5, %r8, %r14;
    mul.wide.s32 %rd7, %r3, %r3;
    mad.lo.u32 %r23, %r22, %r22, %r27;
    mul.lo.s32 %r10, %r3, 65535;
    sub.u64 %rd8, %rd5, %rd7;
    shr.u64 %rd7, %rd7, 3;
    cvt.s32.s64 %r7, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
