.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r4, %r3, 65536;
    setp.ne.s32 %p3, %r4, %r4;
    @%p3 min.s32 %r15, %r4, %r4;
    min.s32 %r13, %r3, 1;
    cvt.u64.u32 %rd6, %r13;
    or.b32 %r10, %r15, 2147483647;
    add.u64 %rd15, %rd6, %rd6;
    mul.lo.u32 %r7, %r4, 256;
    min.u32 %r20, %r4, %r13;
    shr.s64 %rd7, %rd15, 48;
    cvt.s64.s32 %rd11, %r4;
    setp.gt.u32 %p3, %r3, %r7;
    setp.hi.u32 %p3, %r13, %r20;
    @%p3 max.s32 %r20, %r13, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
