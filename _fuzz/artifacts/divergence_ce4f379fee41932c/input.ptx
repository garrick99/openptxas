.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r20, %r3, 15;
    shr.u32 %r6, %r20, 4;
    cvt.u64.u32 %rd8, %r3;
    mul.lo.u32 %r22, %r6, %r20;
    shl.b32 %r21, %r6, 2;
    shr.u64 %rd14, %rd8, 32;
    mul.wide.s32 %rd10, %r22, %r3;
    and.b32 %r27, %r3, %r22;
    max.u32 %r25, %r22, %r6;
    add.s32 %r24, %r6, 8;
    setp.ls.u32 %p4, %r25, 255;
    @%p4 shr.u32 %r18, %r20, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
