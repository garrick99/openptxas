.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd12, %r3, %r3;
    mul.wide.s32 %rd10, %r3, %r3;
    mul.lo.s32 %r20, %r3, %r3;
    sub.s32 %r11, %r20, %r20;
    cvt.u64.u32 %rd5, %r20;
    setp.lo.u32 %p4, %r20, %r20;
    shr.u32 %r8, %r3, 4;
    cvt.s32.s64 %r11, %rd10;
    shr.u64 %rd10, %rd10, 31;
    sub.s32 %r4, %r8, 32;
    cvt.s32.s64 %r22, %rd5;
    min.u64 %rd10, %rd5, %rd12;
    mul.lo.s32 %r7, %r3, 2147483648;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
