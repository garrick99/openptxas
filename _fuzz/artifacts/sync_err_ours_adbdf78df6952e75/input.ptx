    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    setp.le.s32 %p4, %r3, 2147483648;
    max.s64 %rd10, %rd13, %rd13;
    shr.u32 %r18, %r3, 7;
    selp.b32 %r7, %r3, %r18, %p4;
    shr.u32 %r11, %r3, 16;
    sub.s32 %r6, %r3, 65535;
    shr.s64 %rd5, %rd13, 16;
    sub.u32 %r8, %r6, 3;
    cvt.s32.s64 %r18, %rd13;
    setp.ge.s32 %p3, %r18, %r7;
    @%p3 mul.wide.u32 %rd12, %r18, %r18;
    shr.u32 %r7, %r11, 31;
