.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r25, %r3, %r3;
    xor.b32 %r17, %r25, %r3;
    add.s32 %r7, %r25, %r17;
    min.u32 %r17, %r7, 16;
    mul.wide.u32 %rd7, %r7, %r3;
    setp.gt.s32 %p2, %r7, %r3;
    @!%p2 shr.u32 %r4, %r7, 2;
    xor.b64 %rd6, %rd7, %rd7;
    and.b32 %r10, %r17, 16;
    setp.hs.u32 %p4, %r7, 64;
    @%p4 mul.wide.u32 %rd12, %r4, %r4;
    or.b32 %r20, %r4, %r17;
    shr.u32 %r11, %r25, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
