.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r9, %r3, 32;
    max.u32 %r20, %r9, %r3;
    mad.lo.u32 %r25, %r9, %r20, %r20;
    cvt.u64.u32 %rd6, %r9;
    sub.s32 %r13, %r20, %r25;
    max.u32 %r5, %r20, %r25;
    and.b32 %r24, %r20, 63;
    cvt.s64.s32 %rd7, %r20;
    shr.u64 %rd11, %rd6, 15;
    xor.b32 %r14, %r5, %r3;
    setp.eq.s32 %p3, %r13, %r9;
    @!%p3 sub.u32 %r6, %r25, %r24;
    xor.b32 %r20, %r6, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
