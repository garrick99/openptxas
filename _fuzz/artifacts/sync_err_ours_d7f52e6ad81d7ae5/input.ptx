.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    mad.lo.s32 %r21, %r3, %r3, %r3;
    mad.lo.u32 %r21, %r3, %r3, %r3;
    min.u32 %r18, %r21, 32;
    add.u32 %r22, %r21, %r18;
    setp.lt.u32 %p2, %r3, 4294967295;
    setp.le.s32 %p2, %r22, 0;
    @%p2 or.b64 %rd6, %rd7, %rd7;
    selp.b32 %r26, %r22, %r22, %p2;
    cvt.s32.s64 %r13, %rd6;
    mul.lo.s32 %r24, %r26, %r21;
    mul.wide.s32 %rd11, %r24, %r26;
    min.u32 %r21, %r22, %r22;
    mad.lo.u32 %r23, %r26, %r13, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
