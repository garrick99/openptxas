.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shfl.sync.idx.b32 %r7, %r3, 31, 0x1f, -1;
    setp.le.u32 %p2, %r7, 4294967295;
    vote.sync.ballot.b32 %r17, %p2, -1;
    shfl.sync.down.b32 %r11, %r3, 8, 0x1f, -1;
    vote.sync.all.pred %p1, %p2, -1;
    xor.b32 %r13, %r3, %r3;
    vote.sync.all.pred %p2, %p1, -1;
    setp.gt.u32 %p2, %r13, 15;
    vote.sync.ballot.b32 %r18, %p2, -1;
    add.u32 %r11, %r17, %r7;
    shfl.sync.down.b32 %r19, %r18, 4, 0x1f, -1;
    setp.ge.u32 %p3, %r11, 3;
    vote.sync.ballot.b32 %r17, %p3, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
