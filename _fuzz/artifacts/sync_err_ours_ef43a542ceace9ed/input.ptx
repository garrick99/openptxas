.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r11, %r3, %r3;
    cvt.s64.s32 %rd8, %r3;
    cvt.u32.u64 %r13, %rd8;
    sub.u32 %r14, %r11, 0;
    max.s32 %r27, %r14, %r3;
    mul.wide.u32 %rd12, %r11, %r3;
    cvt.s64.s32 %rd14, %r13;
    setp.ls.u32 %p2, %r27, %r3;
    xor.b32 %r4, %r14, %r27;
    max.u64 %rd13, %rd8, %rd12;
    setp.ls.u32 %p3, %r27, %r4;
    @%p3 or.b32 %r24, %r4, 2;
    max.s32 %r19, %r4, %r11;
    sub.u32 %r15, %r19, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
