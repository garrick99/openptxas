.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r24, %r3, %r3;
    max.s32 %r7, %r24, %r3;
    cvt.u64.u32 %rd13, %r3;
    setp.gt.u32 %p2, %r3, 8;
    setp.ne.u32 %p1, %r3, %r7;
    @%p1 min.u32 %r22, %r3, %r7;
    mul.lo.s32 %r5, %r3, 4;
    min.u64 %rd12, %rd13, %rd13;
    and.b64 %rd8, %rd13, %rd12;
    xor.b32 %r8, %r7, %r5;
    xor.b32 %r23, %r7, %r7;
    shr.u64 %rd6, %rd13, 48;
    cvt.u64.u32 %rd6, %r23;
    min.s32 %r18, %r23, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
