.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r5, %r3, %r3;
    min.s32 %r16, %r5, 5;
    mul.lo.s32 %r5, %r3, 8;
    mad.lo.s32 %r15, %r16, %r5, %r16;
    cvt.u64.u32 %rd14, %r3;
    add.s32 %r16, %r16, 0;
    add.u32 %r4, %r3, 255;
    max.s32 %r24, %r15, 65536;
    sub.u32 %r13, %r4, %r16;
    add.s32 %r14, %r16, %r15;
    add.u32 %r16, %r13, %r13;
    add.u32 %r10, %r13, 5;
    max.s32 %r26, %r15, %r24;
    xor.b32 %r9, %r13, 255;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
