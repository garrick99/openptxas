.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd14, %r3, %r3;
    cvt.u32.u64 %r19, %rd14;
    cvt.s32.s64 %r21, %rd14;
    add.u32 %r7, %r21, 256;
    or.b32 %r24, %r21, 8;
    cvt.u32.u64 %r9, %rd14;
    shl.b64 %rd14, %rd14, 15;
    setp.ls.u32 %p3, %r19, %r7;
    @%p3 mul.lo.s32 %r6, %r24, %r9;
    max.u32 %r8, %r21, 32;
    add.u32 %r23, %r19, 2147483648;
    sub.u32 %r27, %r24, 5;
    min.u32 %r5, %r8, 7;
    and.b32 %r25, %r19, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
