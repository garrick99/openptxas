.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r6, %r3, 7;
    max.s32 %r26, %r6, %r6;
    add.u32 %r27, %r6, %r26;
    shr.s32 %r13, %r27, 30;
    mul.lo.s32 %r24, %r27, 4;
    and.b32 %r22, %r13, %r3;
    min.u32 %r26, %r24, 65536;
    setp.ne.u32 %p2, %r13, %r24;
    @!%p2 sub.s32 %r23, %r6, %r22;
    mul.wide.s32 %rd14, %r23, %r27;
    add.u32 %r6, %r6, %r22;
    setp.ne.s32 %p1, %r22, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
