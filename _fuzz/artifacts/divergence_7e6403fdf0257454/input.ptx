.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.u32 %p2, %r3, 256;
    @!%p2 or.b32 %r6, %r3, %r3;
    or.b32 %r6, %r6, %r3;
    or.b32 %r23, %r3, %r6;
    cvt.s64.s32 %rd9, %r6;
    xor.b32 %r25, %r6, %r23;
    and.b32 %r25, %r3, 3;
    sub.s64 %rd14, %rd9, %rd9;
    min.s64 %rd9, %rd9, %rd14;
    min.u32 %r6, %r23, %r3;
    shl.b64 %rd8, %rd14, 33;
    selp.b32 %r5, %r23, %r25, %p2;
    or.b64 %rd8, %rd8, %rd8;
    or.b32 %r23, %r5, 65535;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
