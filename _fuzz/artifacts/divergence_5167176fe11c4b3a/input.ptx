.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ne.s32 %p2, %r3, 4;
    @!%p2 shr.u32 %r20, %r3, 0;
    mul.wide.u32 %rd13, %r20, %r3;
    sub.s32 %r26, %r20, 15;
    sub.s32 %r19, %r26, %r26;
    mul.wide.s32 %rd7, %r20, %r3;
    mul.lo.s32 %r21, %r26, %r3;
    shl.b64 %rd6, %rd7, 2;
    min.u32 %r22, %r20, 4294967295;
    shr.s64 %rd10, %rd7, 4;
    selp.b32 %r22, %r22, %r22, %p2;
    selp.b32 %r18, %r20, %r22, %p2;
    and.b64 %rd15, %rd6, %rd13;
    cvt.s32.s64 %r4, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
