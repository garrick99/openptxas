.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r6, %r3, %r3;
    cvt.u64.u32 %rd13, %r3;
    shl.b64 %rd6, %rd13, 33;
    or.b32 %r17, %r3, %r3;
    add.u32 %r15, %r3, %r6;
    shr.s64 %rd6, %rd6, 30;
    cvt.u64.u32 %rd7, %r17;
    shr.s32 %r16, %r17, 1;
    min.s32 %r17, %r3, %r3;
    or.b64 %rd12, %rd7, %rd13;
    max.s32 %r12, %r17, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
