.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r20, %r3, %r3, %r3;
    mul.wide.s32 %rd11, %r3, %r20;
    add.u64 %rd5, %rd11, %rd11;
    min.u64 %rd15, %rd5, %rd11;
    mul.wide.u32 %rd14, %r20, %r20;
    mul.wide.u32 %rd14, %r3, %r20;
    xor.b32 %r22, %r20, 15;
    mad.lo.s32 %r22, %r22, %r22, %r20;
    min.u64 %rd14, %rd15, %rd11;
    shl.b64 %rd9, %rd15, 1;
    mul.lo.s32 %r25, %r22, 63;
    mad.lo.s32 %r19, %r3, %r20, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
