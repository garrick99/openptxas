.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    popc.b32 %r17, %r3;
    clz.b32 %r14, %r17;
    popc.b32 %r10, %r14;
    sub.u32 %r23, %r17, %r14;
    bfi.b32 %r18, %r10, %r23, 4, 32;
    bfi.b32 %r17, %r14, %r17, 1, 1;
    bfe.u32 %r21, %r14, 16, 24;
    bfe.s32 %r13, %r18, 7, 32;
    clz.b32 %r7, %r21;
    popc.b32 %r8, %r13;
    bfi.b32 %r14, %r17, %r10, 24, 1;
    prmt.b32 %r11, %r13, %r23, 291;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
