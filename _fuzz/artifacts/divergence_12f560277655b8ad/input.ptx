.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r22, %r3, 256;
    sub.s32 %r20, %r22, %r22;
    mad.lo.s32 %r20, %r22, %r20, %r3;
    cvt.s64.s32 %rd15, %r3;
    cvt.u32.u64 %r9, %rd15;
    and.b32 %r10, %r20, %r3;
    sub.s32 %r27, %r10, 8;
    mul.lo.s32 %r20, %r22, 2147483647;
    and.b32 %r12, %r22, %r3;
    shl.b32 %r4, %r20, 30;
    setp.eq.u32 %p1, %r9, %r22;
    @%p1 selp.b32 %r16, %r10, %r27, %p1;
    min.u32 %r24, %r4, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
