.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r16, %r3, 4294967295;
    shr.s32 %r26, %r16, 15;
    mul.wide.s32 %rd9, %r26, %r3;
    shl.b64 %rd5, %rd9, 32;
    shr.u64 %rd12, %rd5, 0;
    shr.u32 %r8, %r26, 3;
    mul.wide.s32 %rd15, %r26, %r16;
    mul.wide.s32 %rd13, %r16, %r16;
    shr.u32 %r13, %r16, 30;
    setp.eq.u32 %p2, %r26, %r8;
    @%p2 shl.b64 %rd7, %rd13, 32;
    mul.lo.s32 %r9, %r13, 8;
    shr.s64 %rd15, %rd5, 0;
    max.u32 %r16, %r26, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
