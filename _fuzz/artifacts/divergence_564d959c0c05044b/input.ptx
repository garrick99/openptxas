.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r7, %r3, 65536;
    mul.lo.u32 %r7, %r7, %r7;
    shl.b32 %r9, %r7, 16;
    setp.le.u32 %p2, %r9, %r3;
    @%p2 shr.u32 %r20, %r9, 3;
    mul.wide.s32 %rd12, %r7, %r7;
    mad.lo.u32 %r5, %r9, %r20, %r20;
    shr.s32 %r8, %r9, 16;
    add.s32 %r25, %r8, %r3;
    sub.s32 %r23, %r25, 32;
    xor.b32 %r25, %r3, %r23;
    sub.u32 %r21, %r3, %r8;
    cvt.u64.u32 %rd11, %r8;
    mad.lo.s32 %r24, %r3, %r23, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
