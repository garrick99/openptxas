.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r8, %r3, %r3, %r3;
    cvt.u64.u32 %rd10, %r3;
    cvt.u64.u32 %rd5, %r3;
    setp.ge.s32 %p4, %r3, 255;
    @!%p4 mul.wide.u32 %rd8, %r3, %r3;
    shr.s64 %rd5, %rd8, 63;
    shr.s32 %r14, %r3, 31;
    cvt.u32.u64 %r4, %rd10;
    selp.b32 %r22, %r14, %r4, %p4;
    add.s32 %r16, %r14, %r22;
    mul.lo.u32 %r27, %r14, %r22;
    cvt.u64.u32 %rd5, %r22;
    max.s32 %r12, %r27, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
