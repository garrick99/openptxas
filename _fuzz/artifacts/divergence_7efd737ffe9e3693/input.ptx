.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r9, %r3, 4294967295;
    cvt.s64.s32 %rd12, %r3;
    or.b32 %r12, %r3, 5;
    setp.lt.s32 %p1, %r9, 8;
    @!%p1 and.b64 %rd8, %rd12, %rd12;
    setp.ne.u32 %p3, %r12, %r3;
    selp.b32 %r19, %r9, %r12, %p1;
    add.s32 %r6, %r9, 255;
    shl.b64 %rd15, %rd8, 48;
    shr.s32 %r12, %r12, 3;
    shr.s32 %r7, %r12, 15;
    sub.s32 %r4, %r12, 3;
    min.u32 %r26, %r19, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
