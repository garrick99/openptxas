.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    setp.gt.s32 %p1, %r3, 63;
    @%p1 mad.lo.u32 %r23, %r3, %r3, %r3;
    or.b32 %r20, %r23, %r23;
    add.s32 %r14, %r20, %r3;
    shl.b32 %r4, %r14, 16;
    mul.lo.s32 %r22, %r4, %r23;
    mul.lo.u64 %rd6, %rd12, %rd12;
    mad.lo.s32 %r12, %r22, %r14, %r4;
    mad.lo.s32 %r21, %r3, %r20, %r12;
    cvt.u32.u64 %r8, %rd12;
    add.u32 %r8, %r14, 31;
    max.u64 %rd7, %rd12, %rd12;
    min.u32 %r22, %r12, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
