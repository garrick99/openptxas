.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r14, %r3, 1;
    add.s32 %r16, %r14, %r14;
    cvt.u64.u32 %rd5, %r14;
    setp.gt.u32 %p4, %r14, 3;
    setp.lo.u32 %p3, %r14, 16;
    @%p3 min.s32 %r21, %r16, %r3;
    xor.b32 %r11, %r16, 63;
    cvt.s32.s64 %r24, %rd5;
    cvt.u64.u32 %rd10, %r16;
    mul.wide.s32 %rd14, %r11, %r14;
    max.u32 %r13, %r11, %r21;
    cvt.s64.s32 %rd11, %r16;
    or.b64 %rd7, %rd11, %rd5;
    setp.lo.u32 %p2, %r11, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
