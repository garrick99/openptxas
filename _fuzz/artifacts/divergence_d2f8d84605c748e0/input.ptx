    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    sub.u32 %r4, %r3, 5;
    shr.u64 %rd15, %rd15, 62;
    xor.b32 %r27, %r3, 4294967295;
    setp.le.s32 %p1, %r4, 3;
    @%p1 and.b32 %r5, %r4, %r3;
    shr.s32 %r12, %r5, 7;
    sub.u32 %r5, %r12, %r27;
    and.b32 %r19, %r5, %r5;
    mul.wide.u32 %rd8, %r5, %r4;
    add.u64 %rd9, %rd15, %rd8;
    mul.wide.u32 %rd9, %r19, %r4;
    setp.hs.u32 %p2, %r5, %r19;
    @%p2 mad.lo.s32 %r26, %r4, %r4, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
