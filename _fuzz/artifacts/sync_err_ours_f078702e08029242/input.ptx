.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r9, %r3, %r3;
    xor.b32 %r4, %r9, 4;
    cvt.s64.s32 %rd8, %r3;
    sub.s32 %r10, %r3, %r4;
    shl.b32 %r4, %r4, 4;
    and.b64 %rd12, %rd8, %rd8;
    and.b32 %r7, %r3, %r9;
    cvt.u32.u64 %r12, %rd12;
    shr.s32 %r25, %r4, 0;
    setp.ne.u32 %p2, %r9, %r4;
    add.s32 %r6, %r3, %r12;
    selp.b32 %r7, %r9, %r6, %p2;
    max.s32 %r18, %r9, 7;
    max.u32 %r13, %r25, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
