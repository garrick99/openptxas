.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r7, %r3, 5;
    shr.s32 %r27, %r3, 4;
    setp.eq.s32 %p1, %r3, 2;
    shr.u32 %r14, %r27, 16;
    cvt.s64.s32 %rd10, %r14;
    add.u32 %r5, %r27, 63;
    max.s64 %rd7, %rd10, %rd10;
    selp.b32 %r14, %r14, %r14, %p1;
    min.s32 %r4, %r27, %r14;
    and.b32 %r26, %r7, %r7;
    or.b32 %r24, %r7, %r14;
    mul.lo.s32 %r27, %r5, 255;
    or.b64 %rd15, %rd10, %rd7;
    max.u32 %r19, %r3, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
