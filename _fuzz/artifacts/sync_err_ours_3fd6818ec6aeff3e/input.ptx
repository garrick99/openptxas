.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r20, %r3, 0;
    xor.b32 %r7, %r3, 4;
    cvt.u64.u32 %rd7, %r20;
    xor.b32 %r14, %r20, %r20;
    sub.s32 %r21, %r7, %r3;
    setp.ne.u32 %p4, %r3, %r14;
    @%p4 min.u32 %r21, %r14, %r7;
    sub.u32 %r21, %r20, 16;
    shl.b32 %r15, %r21, 2;
    add.u32 %r23, %r15, %r21;
    mad.lo.s32 %r17, %r23, %r23, %r21;
    selp.b32 %r20, %r17, %r15, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
