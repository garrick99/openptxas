.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r19, %r3, %r3;
    mul.lo.u32 %r12, %r3, 65535;
    min.u32 %r6, %r3, 0;
    and.b32 %r20, %r12, 65535;
    sub.s32 %r12, %r3, %r12;
    mad.lo.u32 %r25, %r20, %r19, %r6;
    cvt.u64.u32 %rd14, %r20;
    cvt.s32.s64 %r4, %rd14;
    add.s32 %r4, %r3, 3;
    min.s32 %r10, %r19, %r3;
    setp.lt.s32 %p3, %r19, %r19;
    @%p3 shr.u32 %r8, %r10, 3;
    add.u32 %r23, %r20, %r20;
    xor.b32 %r22, %r19, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
