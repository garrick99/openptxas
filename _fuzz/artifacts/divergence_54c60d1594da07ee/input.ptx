.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r21, %r3, 0;
    shr.u32 %r14, %r21, 15;
    cvt.s64.s32 %rd13, %r14;
    setp.ls.u32 %p3, %r14, %r21;
    @%p3 mad.lo.u32 %r8, %r3, %r14, %r21;
    setp.le.s32 %p4, %r14, 3;
    @%p4 mad.lo.s32 %r17, %r3, %r3, %r3;
    cvt.s64.s32 %rd10, %r8;
    max.s32 %r5, %r17, 31;
    setp.ne.s32 %p4, %r5, %r17;
    shl.b64 %rd5, %rd10, 7;
    sub.u32 %r4, %r17, 5;
    sub.s32 %r9, %r4, %r8;
    max.s64 %rd13, %rd10, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
