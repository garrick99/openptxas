.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    add.u32 %r23, %r3, %r3;
    sub.u32 %r16, %r23, 16;
    mul.lo.s32 %r18, %r3, %r16;
    mul.lo.u64 %rd5, %rd9, %rd9;
    cvt.s32.s64 %r11, %rd9;
    cvt.s32.s64 %r23, %rd9;
    cvt.s64.s32 %rd8, %r11;
    shl.b64 %rd9, %rd9, 31;
    mad.lo.s32 %r19, %r3, %r3, %r16;
    shr.u64 %rd12, %rd8, 4;
    cvt.s64.s32 %rd5, %r23;
    mul.lo.s32 %r22, %r19, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
