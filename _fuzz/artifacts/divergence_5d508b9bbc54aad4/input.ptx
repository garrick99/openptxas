.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r10, %r3, 255;
    max.u32 %r17, %r3, 65536;
    sub.s32 %r7, %r17, 5;
    min.u32 %r21, %r7, 63;
    cvt.u64.u32 %rd12, %r17;
    cvt.u32.u64 %r13, %rd12;
    mul.lo.s32 %r8, %r10, %r17;
    cvt.u64.u32 %rd8, %r8;
    and.b32 %r27, %r13, %r3;
    cvt.u64.u32 %rd8, %r21;
    max.u32 %r17, %r21, 16;
    cvt.s64.s32 %rd11, %r17;
    shr.s32 %r18, %r17, 31;
    setp.ge.s32 %p2, %r8, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
