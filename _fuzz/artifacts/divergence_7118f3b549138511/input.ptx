    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p3, %r3, %r3;
    @%p3 min.s32 %r10, %r3, 64;
    cvt.s64.s32 %rd11, %r3;
    setp.lo.u32 %p3, %r10, 2147483648;
    xor.b32 %r16, %r3, %r10;
    cvt.u64.u32 %rd8, %r16;
    max.s64 %rd6, %rd8, %rd11;
    selp.b32 %r23, %r3, %r10, %p3;
    min.u32 %r27, %r16, %r16;
