.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r27, %r3, 255;
    add.u32 %r12, %r3, 8;
    max.s32 %r15, %r12, 65536;
    shr.s32 %r17, %r12, 0;
    add.s32 %r4, %r3, %r15;
    cvt.s64.s32 %rd11, %r27;
    add.s64 %rd11, %rd11, %rd11;
    add.u32 %r23, %r17, %r12;
    add.s32 %r6, %r27, %r23;
    sub.s32 %r16, %r12, %r27;
    xor.b32 %r10, %r27, %r17;
    shr.u32 %r19, %r27, 0;
    add.s32 %r22, %r15, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
