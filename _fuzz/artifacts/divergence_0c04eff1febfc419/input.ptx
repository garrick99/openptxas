.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd11, %r3, %r3;
    or.b32 %r16, %r3, %r3;
    mad.lo.u32 %r21, %r3, %r3, %r16;
    shr.s32 %r25, %r16, 15;
    mul.wide.s32 %rd5, %r21, %r3;
    min.s32 %r14, %r21, %r25;
    cvt.u32.u64 %r4, %rd11;
    cvt.s64.s32 %rd15, %r14;
    shl.b32 %r21, %r3, 30;
    mul.lo.s64 %rd6, %rd11, %rd5;
    mul.lo.s32 %r21, %r25, %r25;
    shr.u32 %r27, %r21, 7;
    setp.ge.u32 %p1, %r21, %r3;
    min.u32 %r26, %r21, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
