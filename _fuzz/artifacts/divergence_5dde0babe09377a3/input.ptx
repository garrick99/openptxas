.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r26, %r3, %r3, %r3;
    add.u32 %r13, %r3, 4;
    cvt.s64.s32 %rd5, %r26;
    shr.s64 %rd15, %rd5, 31;
    mad.lo.s32 %r9, %r13, %r13, %r26;
    shl.b32 %r18, %r26, 0;
    max.s32 %r9, %r18, %r3;
    shl.b64 %rd14, %rd5, 7;
    xor.b64 %rd14, %rd5, %rd14;
    max.u32 %r5, %r18, %r13;
    shl.b32 %r26, %r18, 4;
    setp.le.s32 %p1, %r3, %r13;
    setp.hi.u32 %p2, %r18, 16;
    @%p2 cvt.s32.s64 %r19, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
