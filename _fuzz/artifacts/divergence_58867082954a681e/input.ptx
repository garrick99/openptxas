.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r9, %r3, 5;
    cvt.u64.u32 %rd13, %r9;
    cvt.s64.s32 %rd11, %r3;
    sub.u64 %rd10, %rd13, %rd13;
    shr.u64 %rd10, %rd10, 2;
    min.s64 %rd15, %rd11, %rd13;
    mul.lo.s32 %r27, %r9, %r9;
    setp.gt.s32 %p4, %r9, 1;
    mul.lo.s32 %r9, %r3, %r27;
    setp.ge.s32 %p3, %r3, 256;
    @%p3 xor.b32 %r18, %r3, 31;
    add.s32 %r12, %r9, %r9;
    mul.lo.u32 %r11, %r18, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
