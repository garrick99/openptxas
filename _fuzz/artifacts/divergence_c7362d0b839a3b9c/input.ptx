.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p4, %r3, %r3;
    @%p4 mul.lo.s32 %r18, %r3, 32;
    setp.lt.u32 %p3, %r18, %r3;
    max.s32 %r8, %r18, 4294967295;
    max.u32 %r4, %r8, %r3;
    shr.u32 %r8, %r3, 3;
    mul.lo.s32 %r23, %r8, %r18;
    max.s32 %r9, %r18, %r3;
    cvt.u64.u32 %rd15, %r3;
    mad.lo.u32 %r20, %r23, %r3, %r8;
    cvt.u32.u64 %r5, %rd15;
    shr.u64 %rd8, %rd15, 32;
    mul.wide.s32 %rd7, %r3, %r5;
    selp.b32 %r19, %r18, %r8, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
