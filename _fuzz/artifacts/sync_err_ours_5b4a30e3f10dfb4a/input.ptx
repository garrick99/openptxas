.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd5, %r3;
    and.b32 %r27, %r3, %r3;
    add.s64 %rd13, %rd5, %rd5;
    min.s32 %r4, %r27, %r3;
    shr.u64 %rd13, %rd13, 30;
    shl.b32 %r22, %r27, 16;
    mul.wide.s32 %rd5, %r27, %r22;
    shr.s64 %rd14, %rd5, 15;
    min.u64 %rd13, %rd14, %rd5;
    shr.s32 %r10, %r4, 30;
    cvt.u32.u64 %r15, %rd13;
    sub.u32 %r10, %r15, %r3;
    mad.lo.s32 %r9, %r27, %r27, %r22;
    shr.s32 %r18, %r4, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
