.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r21, %r3, %r3;
    cvt.s64.s32 %rd11, %r21;
    add.u32 %r25, %r3, %r3;
    add.u32 %r15, %r21, %r21;
    shr.u32 %r17, %r15, 2;
    add.s32 %r21, %r21, %r21;
    cvt.u64.u32 %rd11, %r3;
    mul.wide.s32 %rd11, %r17, %r17;
    mul.lo.u32 %r4, %r17, %r15;
    mul.lo.s32 %r22, %r17, 4;
    mad.lo.s32 %r18, %r4, %r4, %r4;
    or.b32 %r14, %r21, 64;
    min.u32 %r14, %r3, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
