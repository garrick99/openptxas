    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r24, %r3, 0;
    cvt.u64.u32 %rd15, %r3;
    cvt.u32.u64 %r12, %rd15;
    cvt.u32.u64 %r15, %rd15;
    sub.u32 %r21, %r15, 255;
    mad.lo.s32 %r6, %r15, %r15, %r12;
    max.u32 %r21, %r3, %r24;
    mad.lo.s32 %r24, %r3, %r15, %r6;
    shr.u64 %rd8, %rd15, 4;
    sub.s32 %r25, %r6, 2;
    mul.lo.u32 %r4, %r24, 2147483647;
    setp.eq.u32 %p3, %r3, 15;
    @!%p3 mul.wide.u32 %rd7, %r3, %r6;
