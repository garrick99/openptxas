.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r11, %r3, 32;
    cvt.s64.s32 %rd5, %r3;
    mul.lo.u32 %r26, %r3, 4294967295;
    mul.wide.u32 %rd7, %r11, %r3;
    mul.wide.u32 %rd15, %r11, %r26;
    max.u32 %r15, %r3, 5;
    setp.ne.s32 %p3, %r26, 2;
    max.s32 %r6, %r3, %r11;
    and.b64 %rd9, %rd15, %rd5;
    shr.s64 %rd15, %rd15, 15;
    mul.wide.u32 %rd6, %r11, %r3;
    mul.lo.u64 %rd12, %rd5, %rd15;
    selp.b32 %r8, %r6, %r15, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
