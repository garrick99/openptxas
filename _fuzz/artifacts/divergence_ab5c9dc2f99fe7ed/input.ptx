.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    add.s32 %r22, %r3, %r3;
    shl.b32 %r16, %r22, 2;
    shr.u32 %r22, %r22, 16;
    add.s32 %r6, %r16, 0;
    cvt.u64.u32 %rd9, %r16;
    cvt.s32.s64 %r13, %rd9;
    and.b32 %r24, %r16, 32;
    setp.ge.u32 %p2, %r3, %r6;
    selp.b32 %r4, %r24, %r24, %p2;
    sub.s32 %r8, %r24, %r4;
    xor.b32 %r9, %r6, 31;
    mad.lo.u32 %r16, %r9, %r3, %r3;
    sub.u32 %r5, %r16, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
