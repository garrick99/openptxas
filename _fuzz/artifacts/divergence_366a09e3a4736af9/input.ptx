.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r22, %r3, %r3;
    cvt.u64.u32 %rd9, %r22;
    or.b32 %r18, %r3, 256;
    shl.b32 %r6, %r18, 31;
    cvt.u32.u64 %r22, %rd9;
    cvt.u32.u64 %r4, %rd9;
    add.u32 %r22, %r18, %r22;
    shr.u64 %rd7, %rd9, 4;
    shl.b32 %r11, %r18, 4;
    mul.lo.u32 %r24, %r3, %r18;
    shr.s64 %rd5, %rd7, 31;
    shl.b64 %rd12, %rd9, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
