.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r7, %r3, 8;
    and.b32 %r18, %r7, %r3;
    min.u32 %r10, %r3, 15;
    max.s32 %r20, %r3, 3;
    or.b32 %r16, %r10, 2147483647;
    cvt.s64.s32 %rd5, %r20;
    max.s32 %r15, %r20, 5;
    or.b64 %rd7, %rd5, %rd5;
    cvt.u32.u64 %r12, %rd5;
    min.u32 %r8, %r16, 256;
    cvt.u32.u64 %r7, %rd7;
    setp.ge.s32 %p1, %r10, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
