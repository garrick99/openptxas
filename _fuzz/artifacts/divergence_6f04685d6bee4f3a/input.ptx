.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.s32 %p4, %r3, %r3;
    @%p4 mul.wide.s32 %rd14, %r3, %r3;
    mad.lo.u32 %r24, %r3, %r3, %r3;
    setp.ne.s32 %p3, %r3, %r24;
    @!%p3 cvt.s32.s64 %r20, %rd14;
    xor.b32 %r27, %r24, 64;
    mul.lo.u32 %r14, %r27, 5;
    cvt.u64.u32 %rd12, %r20;
    setp.ne.s32 %p4, %r14, %r27;
    setp.ls.u32 %p4, %r3, %r3;
    sub.u32 %r14, %r20, %r14;
    add.s32 %r21, %r27, %r24;
    mad.lo.s32 %r4, %r3, %r24, %r14;
    min.u32 %r11, %r20, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
