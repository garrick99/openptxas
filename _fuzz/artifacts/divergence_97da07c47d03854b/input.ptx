.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    mul.lo.u32 %r24, %r3, 255;
    cvt.u64.u32 %rd12, %r24;
    mul.lo.s64 %rd5, %rd13, %rd13;
    shl.b64 %rd9, %rd5, 33;
    shl.b32 %r20, %r24, 4;
    sub.s32 %r6, %r3, %r20;
    mul.lo.u32 %r23, %r6, 64;
    xor.b32 %r17, %r6, 64;
    min.u32 %r21, %r24, %r6;
    mad.lo.u32 %r16, %r21, %r23, %r21;
    min.u32 %r10, %r6, 2;
    max.s32 %r4, %r10, %r23;
    add.u32 %r8, %r23, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
