.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r26, %r3, 15;
    max.u32 %r4, %r3, %r3;
    cvt.s64.s32 %rd14, %r26;
    shl.b32 %r20, %r3, 16;
    cvt.s32.s64 %r12, %rd14;
    and.b32 %r8, %r4, %r12;
    cvt.s32.s64 %r9, %rd14;
    or.b32 %r19, %r8, 65536;
    add.s32 %r21, %r20, 65535;
    mul.lo.u32 %r11, %r3, 1;
    mad.lo.s32 %r13, %r19, %r3, %r9;
    setp.ge.s32 %p4, %r21, %r13;
    mul.wide.u32 %rd6, %r3, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
