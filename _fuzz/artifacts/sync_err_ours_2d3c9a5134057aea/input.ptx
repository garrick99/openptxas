.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    sub.u64 %rd10, %rd12, %rd12;
    max.s32 %r16, %r3, %r3;
    mad.lo.s32 %r20, %r3, %r3, %r16;
    add.s32 %r26, %r16, 65536;
    cvt.u32.u64 %r27, %rd12;
    max.u64 %rd11, %rd10, %rd12;
    setp.eq.s32 %p1, %r3, %r26;
    @%p1 min.s32 %r6, %r27, 7;
    mul.wide.u32 %rd6, %r3, %r27;
    min.u32 %r22, %r16, %r16;
    mul.wide.u32 %rd6, %r20, %r26;
    setp.le.u32 %p1, %r20, 256;
    sub.s32 %r27, %r3, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
