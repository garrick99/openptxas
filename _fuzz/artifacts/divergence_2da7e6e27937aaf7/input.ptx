.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    setp.gt.u32 %p2, %r3, 65535;
    @%p2 cvt.u32.u64 %r8, %rd5;
    cvt.s64.s32 %rd12, %r3;
    cvt.s64.s32 %rd6, %r3;
    selp.b32 %r26, %r8, %r8, %p2;
    shr.s32 %r20, %r8, 0;
    cvt.s32.s64 %r26, %rd5;
    add.u32 %r11, %r3, 8;
    mul.wide.u32 %rd11, %r3, %r11;
    cvt.s64.s32 %rd12, %r20;
    mul.lo.s32 %r20, %r26, %r26;
    xor.b32 %r19, %r26, %r26;
    selp.b32 %r9, %r19, %r11, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
