.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r26, %r3, %r3;
    add.u32 %r27, %r3, %r26;
    cvt.u64.u32 %rd12, %r3;
    shl.b32 %r6, %r3, 15;
    mul.lo.s32 %r16, %r27, 7;
    mul.lo.u32 %r14, %r27, 1;
    cvt.s32.s64 %r8, %rd12;
    setp.gt.s32 %p3, %r8, 64;
    @!%p3 add.u32 %r24, %r16, %r3;
    shl.b64 %rd8, %rd12, 31;
    mul.wide.u32 %rd9, %r14, %r8;
    sub.s64 %rd14, %rd8, %rd12;
    setp.gt.s32 %p1, %r3, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
