.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    min.s32 %r11, %r3, %r3;
    min.u32 %r19, %r11, %r3;
    mad.lo.u32 %r15, %r11, %r19, %r19;
    mad.lo.s32 %r26, %r19, %r11, %r3;
    and.b32 %r17, %r26, %r3;
    cvt.u64.u32 %rd10, %r11;
    shl.b32 %r11, %r26, 1;
    mad.lo.u32 %r6, %r17, %r19, %r3;
    cvt.u64.u32 %rd8, %r15;
    cvt.s32.s64 %r26, %rd8;
    mad.lo.s32 %r23, %r11, %r3, %r26;
    or.b32 %r14, %r26, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
