.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r8, %r3, 4;
    setp.lt.s32 %p2, %r3, 2;
    @%p2 mul.wide.s32 %rd10, %r3, %r8;
    min.s32 %r22, %r8, 8;
    mad.lo.u32 %r26, %r3, %r3, %r8;
    shr.u64 %rd14, %rd10, 2;
    mul.lo.s32 %r5, %r22, 2;
    mad.lo.s32 %r5, %r22, %r26, %r26;
    selp.b32 %r27, %r26, %r3, %p2;
    setp.gt.u32 %p1, %r26, 16;
    mad.lo.s32 %r20, %r22, %r22, %r22;
    mul.lo.s64 %rd9, %rd10, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
