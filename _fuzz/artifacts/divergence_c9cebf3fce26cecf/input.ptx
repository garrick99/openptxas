.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    cvt.s64.s32 %rd10, %r3;
    and.b64 %rd6, %rd7, %rd10;
    and.b32 %r20, %r3, %r3;
    setp.eq.u32 %p3, %r3, 65535;
    @%p3 xor.b32 %r13, %r20, 5;
    selp.b32 %r22, %r13, %r13, %p3;
    setp.gt.u32 %p3, %r13, %r22;
    @%p3 sub.u32 %r17, %r22, 31;
    add.s32 %r7, %r20, %r20;
    cvt.u32.u64 %r22, %rd7;
    or.b64 %rd15, %rd7, %rd10;
    max.u32 %r26, %r17, %r17;
    shr.u64 %rd12, %rd7, 33;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
