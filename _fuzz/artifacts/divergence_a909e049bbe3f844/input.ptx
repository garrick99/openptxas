.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p1, %r3, 2;
    @%p1 min.u32 %r12, %r3, %r3;
    mul.wide.s32 %rd9, %r12, %r12;
    min.u32 %r5, %r3, %r12;
    max.s32 %r24, %r5, %r5;
    mul.wide.s32 %rd7, %r12, %r3;
    cvt.s32.s64 %r19, %rd9;
    add.s32 %r5, %r24, %r3;
    min.s64 %rd14, %rd9, %rd7;
    shr.s64 %rd8, %rd14, 16;
    cvt.s32.s64 %r27, %rd14;
    add.u32 %r6, %r24, 31;
    shr.s64 %rd8, %rd14, 47;
    cvt.s32.s64 %r5, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
