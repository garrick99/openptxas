.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r9, %r3, 256;
    setp.gt.s32 %p2, %r9, 65536;
    @%p2 selp.b32 %r17, %r9, %r9, %p2;
    add.u32 %r5, %r9, %r9;
    max.s32 %r9, %r5, 4294967295;
    setp.ne.u32 %p2, %r9, 7;
    @!%p2 add.u32 %r27, %r17, %r17;
    mul.wide.u32 %rd14, %r17, %r17;
    shl.b64 %rd13, %rd14, 31;
    add.u64 %rd7, %rd13, %rd13;
    max.u32 %r20, %r3, %r27;
    or.b32 %r5, %r9, 7;
    cvt.u32.u64 %r6, %rd13;
    setp.gt.u32 %p1, %r27, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
