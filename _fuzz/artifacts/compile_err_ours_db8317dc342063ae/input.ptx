.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r19, %r3, %r0;
    min.u32 %r15, %r19, %r19;
    setp.le.u32 %p2, %r3, 0;
    vote.sync.ballot.b32 %r18, %p2, -1;
    vote.sync.any.pred %p3, %p2, -1;
    min.u32 %r9, %r0, %r15;
    vote.sync.any.pred %p3, %p3, -1;
    min.u32 %r13, %r15, %r15;
    xor.b32 %r4, %r9, %r9;
    setp.lt.u32 %p2, %r9, %r13;
    vote.sync.ballot.b32 %r11, %p2, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
