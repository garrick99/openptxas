.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r19, %r3, %r3;
    max.u32 %r23, %r3, %r3;
    setp.ge.s32 %p3, %r19, %r3;
    @%p3 shr.s32 %r7, %r3, 31;
    cvt.s64.s32 %rd8, %r3;
    selp.b32 %r4, %r19, %r19, %p3;
    or.b32 %r13, %r3, 256;
    max.s32 %r22, %r4, %r4;
    add.u32 %r7, %r4, %r3;
    sub.s32 %r11, %r19, %r3;
    selp.b32 %r11, %r22, %r7, %p3;
    mul.wide.s32 %rd5, %r7, %r7;
    xor.b32 %r4, %r19, %r3;
    mad.lo.u32 %r18, %r3, %r11, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
