.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd12, %r3, %r3;
    mul.lo.s32 %r4, %r3, 4294967295;
    shr.u64 %rd10, %rd12, 3;
    sub.s32 %r21, %r4, 2147483647;
    max.u32 %r7, %r4, 65536;
    min.s64 %rd9, %rd12, %rd12;
    and.b32 %r6, %r3, %r7;
    add.s32 %r21, %r21, 2;
    shr.s32 %r22, %r6, 16;
    shr.s32 %r14, %r21, 16;
    cvt.s64.s32 %rd13, %r6;
    cvt.s32.s64 %r19, %rd9;
    max.u32 %r11, %r4, 2147483648;
    cvt.u32.u64 %r9, %rd13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
