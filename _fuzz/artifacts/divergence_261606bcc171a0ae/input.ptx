.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r25, %r3, 64;
    add.s32 %r26, %r25, %r25;
    shl.b32 %r6, %r3, 3;
    add.s32 %r21, %r26, 256;
    shr.s32 %r21, %r21, 15;
    cvt.s64.s32 %rd13, %r21;
    shr.s32 %r16, %r6, 15;
    mul.wide.u32 %rd15, %r21, %r6;
    cvt.u64.u32 %rd12, %r6;
    shl.b64 %rd12, %rd15, 3;
    mad.lo.s32 %r25, %r21, %r21, %r21;
    min.s64 %rd11, %rd13, %rd13;
    add.u64 %rd15, %rd12, %rd11;
    cvt.s32.s64 %r19, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
