.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    shr.s64 %rd12, %rd15, 2;
    shr.u32 %r10, %r3, 0;
    mad.lo.s32 %r12, %r10, %r3, %r10;
    or.b32 %r25, %r10, 15;
    sub.s32 %r7, %r3, %r3;
    cvt.s32.s64 %r11, %rd15;
    setp.hi.u32 %p1, %r7, %r7;
    @!%p1 or.b32 %r21, %r3, 1;
    add.u32 %r20, %r21, 8;
    sub.s32 %r26, %r21, 1;
    add.u32 %r12, %r21, 31;
    cvt.u64.u32 %rd13, %r26;
    or.b32 %r7, %r11, %r12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
