.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r21, %r3, 65535;
    setp.lt.u32 %p3, %r3, 31;
    @!%p3 max.s32 %r18, %r21, 64;
    mad.lo.u32 %r21, %r18, %r18, %r3;
    max.u32 %r18, %r21, %r21;
    mul.lo.u32 %r9, %r18, 15;
    or.b32 %r24, %r3, 1;
    add.u32 %r10, %r24, 15;
    selp.b32 %r12, %r24, %r3, %p3;
    sub.u32 %r20, %r9, %r21;
    mad.lo.s32 %r14, %r24, %r20, %r24;
    mul.lo.u32 %r14, %r9, 64;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
