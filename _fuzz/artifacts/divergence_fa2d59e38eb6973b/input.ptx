.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p2, %r3, %r3;
    vote.sync.ballot.b32 %r4, %p2, -1;
    setp.le.u32 %p1, %r4, 65535;
    vote.sync.ballot.b32 %r7, %p1, -1;
    and.b32 %r6, %r7, %r7;
    or.b32 %r16, %r7, %r0;
    shfl.sync.down.b32 %r8, %r6, 16, 0x1f, -1;
    setp.ge.u32 %p2, %r16, 4294967295;
    vote.sync.ballot.b32 %r17, %p2, -1;
    and.b32 %r5, %r17, %r6;
    shfl.sync.up.b32 %r5, %r16, 2, 0x1f, -1;
    setp.le.u32 %p1, %r17, 8;
    vote.sync.ballot.b32 %r18, %p1, -1;
    min.u32 %r14, %r16, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
