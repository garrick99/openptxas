.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r10, %r0, %r3;
    shfl.sync.bfly.b32 %r15, %r3, 8, 0x1f, -1;
    shfl.sync.bfly.b32 %r7, %r3, 16, 0x1f, -1;
    or.b32 %r11, %r10, %r7;
    shfl.sync.idx.b32 %r4, %r3, 15, 0x1f, -1;
    max.u32 %r4, %r4, %r11;
    setp.lt.u32 %p2, %r7, 4294967295;
    vote.sync.ballot.b32 %r15, %p2, -1;
    max.u32 %r5, %r10, %r15;
    setp.eq.u32 %p2, %r4, %r0;
    vote.sync.ballot.b32 %r4, %p2, -1;
    shfl.sync.up.b32 %r5, %r4, 2, 0x1f, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
