.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r11, %r3, 2;
    max.s32 %r17, %r11, 65536;
    cvt.u64.u32 %rd14, %r3;
    min.s64 %rd10, %rd14, %rd14;
    cvt.s64.s32 %rd8, %r3;
    shr.u32 %r17, %r11, 16;
    sub.s64 %rd12, %rd8, %rd8;
    max.s32 %r4, %r17, %r11;
    or.b32 %r4, %r3, %r4;
    shl.b32 %r13, %r3, 16;
    mul.wide.u32 %rd6, %r17, %r3;
    cvt.u32.u64 %r13, %rd14;
    shr.u32 %r24, %r13, 0;
    add.s64 %rd15, %rd6, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
