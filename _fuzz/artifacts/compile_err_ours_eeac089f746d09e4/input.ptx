.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<24>;
    .reg .b64 %rd<8>;
    .reg .pred %p<6>;
    mov.u32 %r0, %tid.x;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    and.b32 %r9, %r0, %r0;
    setp.le.u32 %p2, %r9, %r3;
    vote.sync.ballot.b32 %r15, %p2, -1;
    shfl.sync.up.b32 %r8, %r15, 4, 0x1f, -1;
    shfl.sync.idx.b32 %r13, %r3, 7, 0x1f, -1;
    shfl.sync.up.b32 %r4, %r9, 1, 0x1f, -1;
    vote.sync.any.pred %p2, %p2, -1;
    shfl.sync.down.b32 %r10, %r0, 1, 0x1f, -1;
    xor.b32 %r10, %r10, %r9;
    vote.sync.any.pred %p3, %p2, -1;
    setp.ge.u32 %p2, %r15, %r8;
    vote.sync.ballot.b32 %r17, %p2, -1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
