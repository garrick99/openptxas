.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    shl.b32 %r10, %r3, 3;
    setp.ne.s32 %p3, %r3, 63;
    min.u32 %r22, %r10, 65535;
    mad.lo.u32 %r6, %r10, %r3, %r22;
    mad.lo.u32 %r13, %r6, %r6, %r3;
    cvt.u32.u64 %r10, %rd10;
    shr.u32 %r17, %r10, 30;
    mul.wide.s32 %rd7, %r6, %r13;
    mul.wide.u32 %rd15, %r22, %r13;
    and.b32 %r6, %r17, %r10;
    mul.wide.u32 %rd8, %r17, %r3;
    max.u32 %r24, %r10, %r13;
    and.b64 %rd15, %rd10, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
