.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r6, %r3, %r3;
    setp.ne.s32 %p4, %r3, 63;
    @%p4 cvt.u64.u32 %rd6, %r6;
    shr.u32 %r25, %r3, 3;
    cvt.u64.u32 %rd12, %r6;
    cvt.s64.s32 %rd14, %r6;
    min.s64 %rd9, %rd14, %rd12;
    selp.b32 %r10, %r6, %r25, %p4;
    mul.lo.u32 %r22, %r6, %r3;
    cvt.s64.s32 %rd15, %r22;
    sub.u64 %rd8, %rd12, %rd6;
    mul.wide.u32 %rd9, %r3, %r3;
    shl.b32 %r9, %r3, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
