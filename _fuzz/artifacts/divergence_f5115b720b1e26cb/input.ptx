.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r14, %r3, %r3;
    add.u32 %r25, %r14, 256;
    max.u32 %r11, %r25, %r14;
    cvt.s64.s32 %rd9, %r3;
    setp.hs.u32 %p3, %r14, 32;
    @!%p3 mul.lo.s32 %r10, %r11, %r3;
    cvt.s64.s32 %rd15, %r25;
    selp.b32 %r20, %r11, %r10, %p3;
    add.s32 %r9, %r11, 4294967295;
    max.s32 %r17, %r20, 1;
    shr.s32 %r25, %r9, 16;
    xor.b32 %r11, %r3, %r3;
    shl.b32 %r16, %r9, 4;
    shr.u32 %r24, %r10, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
