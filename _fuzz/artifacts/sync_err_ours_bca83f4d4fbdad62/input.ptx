.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r4, %r3, 30;
    mul.wide.s32 %rd14, %r3, %r3;
    min.u32 %r13, %r3, %r4;
    setp.gt.s32 %p2, %r13, %r13;
    setp.ge.u32 %p2, %r4, 0;
    sub.s32 %r24, %r4, %r3;
    or.b32 %r13, %r13, %r4;
    shl.b32 %r20, %r3, 7;
    min.u32 %r27, %r20, %r24;
    setp.eq.s32 %p1, %r27, 256;
    @%p1 add.s32 %r21, %r27, 8;
    xor.b64 %rd6, %rd14, %rd14;
    xor.b32 %r16, %r13, %r24;
    min.s32 %r17, %r20, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
