.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd9, %r3;
    cvt.s64.s32 %rd10, %r3;
    mad.lo.s32 %r21, %r3, %r3, %r3;
    mul.lo.s32 %r4, %r3, %r3;
    and.b32 %r7, %r4, 65535;
    setp.lo.u32 %p1, %r21, 3;
    @%p1 min.u32 %r12, %r7, 4294967295;
    sub.s32 %r19, %r21, 256;
    cvt.s64.s32 %rd8, %r3;
    xor.b32 %r15, %r7, 16;
    add.u32 %r19, %r12, 8;
    cvt.u64.u32 %rd13, %r7;
    shr.u32 %r19, %r12, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
