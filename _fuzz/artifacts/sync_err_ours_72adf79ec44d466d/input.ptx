.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r4, %r3, %r3;
    sub.s32 %r27, %r4, %r4;
    mul.lo.u32 %r23, %r3, 4294967295;
    shr.u32 %r8, %r4, 1;
    cvt.u64.u32 %rd5, %r3;
    sub.u32 %r24, %r4, %r8;
    mul.lo.s64 %rd12, %rd5, %rd5;
    shl.b64 %rd8, %rd5, 33;
    add.u32 %r24, %r3, %r24;
    shr.u32 %r21, %r27, 15;
    mul.wide.u32 %rd14, %r4, %r8;
    mad.lo.u32 %r11, %r4, %r24, %r4;
    max.u32 %r16, %r24, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
