.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r21, %r3, 3;
    and.b32 %r11, %r21, 8;
    xor.b32 %r18, %r11, %r3;
    sub.u32 %r7, %r21, 64;
    shr.u32 %r10, %r18, 1;
    setp.ge.s32 %p3, %r10, %r21;
    setp.ne.s32 %p2, %r18, %r10;
    @!%p2 min.s32 %r12, %r3, %r11;
    max.u32 %r17, %r11, 63;
    max.u32 %r23, %r11, 31;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
