.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p2, %r3, 63;
    setp.ne.s32 %p2, %r3, 15;
    @%p2 shr.s32 %r6, %r3, 15;
    setp.lo.u32 %p1, %r3, %r3;
    @%p1 xor.b32 %r7, %r3, 2147483647;
    xor.b32 %r19, %r6, %r7;
    xor.b32 %r11, %r7, 31;
    mad.lo.s32 %r16, %r7, %r11, %r6;
    cvt.u64.u32 %rd13, %r19;
    add.s32 %r9, %r7, 3;
    shr.s32 %r15, %r9, 15;
    mul.wide.s32 %rd15, %r6, %r11;
    setp.ge.u32 %p4, %r6, %r9;
    @%p4 add.u32 %r23, %r15, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
