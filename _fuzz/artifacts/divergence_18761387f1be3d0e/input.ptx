.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd13, %r3, %r3;
    mul.wide.u32 %rd6, %r3, %r3;
    or.b32 %r22, %r3, 63;
    mad.lo.s32 %r8, %r3, %r22, %r22;
    mul.lo.u32 %r17, %r8, %r8;
    max.u32 %r20, %r8, %r3;
    mul.lo.u32 %r19, %r8, %r22;
    min.u32 %r17, %r8, 2;
    shr.u64 %rd6, %rd6, 47;
    mul.lo.s32 %r10, %r17, %r8;
    sub.s32 %r24, %r20, 32;
    setp.gt.s32 %p3, %r24, %r20;
    @%p3 sub.s32 %r18, %r8, 1;
    cvt.u64.u32 %rd12, %r20;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
