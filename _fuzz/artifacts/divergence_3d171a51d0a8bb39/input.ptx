.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd11, %r3;
    shr.s64 %rd8, %rd11, 30;
    mul.lo.s32 %r24, %r3, %r3;
    setp.lt.u32 %p3, %r3, %r3;
    @!%p3 shr.u32 %r4, %r24, 30;
    xor.b32 %r11, %r4, %r3;
    sub.u64 %rd12, %rd11, %rd11;
    xor.b32 %r5, %r4, 31;
    sub.s64 %rd13, %rd8, %rd12;
    selp.b32 %r21, %r4, %r4, %p3;
    or.b32 %r25, %r24, %r21;
    setp.eq.s32 %p3, %r25, %r4;
    @%p3 sub.s32 %r15, %r3, 2;
    setp.hi.u32 %p3, %r4, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
