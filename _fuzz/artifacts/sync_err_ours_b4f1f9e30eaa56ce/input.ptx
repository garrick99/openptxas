    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r18, %r3, 63;
    max.s32 %r15, %r18, %r3;
    mul.wide.u32 %rd12, %r18, %r3;
    and.b32 %r24, %r15, %r3;
    shr.s64 %rd10, %rd12, 16;
    or.b32 %r14, %r24, 2147483648;
    max.u32 %r4, %r15, 64;
