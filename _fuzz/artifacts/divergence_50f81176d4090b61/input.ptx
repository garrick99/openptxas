    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r5, %r3, 30;
    add.s32 %r15, %r3, %r5;
    max.s32 %r13, %r5, 0;
    shr.s32 %r25, %r15, 1;
    setp.hs.u32 %p3, %r15, %r13;
    @%p3 min.s32 %r8, %r25, 2147483648;
    shr.s32 %r16, %r15, 4;
    cvt.s64.s32 %rd9, %r15;
    cvt.u32.u64 %r19, %rd9;
    add.s32 %r8, %r13, 256;
    cvt.s32.s64 %r13, %rd9;
    mul.lo.s64 %rd15, %rd9, %rd9;
    setp.hi.u32 %p3, %r13, %r25;
    @%p3 add.u32 %r19, %r8, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
