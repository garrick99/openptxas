.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    sub.u32 %r7, %r3, 63;
    and.b32 %r22, %r7, 4294967295;
    add.s32 %r7, %r7, 4294967295;
    min.s32 %r20, %r3, %r7;
    setp.hs.u32 %p3, %r22, 1;
    cvt.s64.s32 %rd5, %r20;
    shr.u64 %rd14, %rd15, 48;
    shr.s64 %rd9, %rd5, 16;
    mad.lo.s32 %r6, %r22, %r3, %r7;
    mul.lo.s32 %r22, %r7, 4294967295;
    cvt.s64.s32 %rd15, %r20;
    shr.u64 %rd6, %rd9, 33;
    shr.u32 %r9, %r22, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
