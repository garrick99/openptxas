.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r12, %r3, 15;
    max.s32 %r5, %r3, %r3;
    mul.wide.u32 %rd5, %r12, %r12;
    sub.s32 %r11, %r3, %r5;
    sub.u32 %r4, %r3, 64;
    setp.lt.s32 %p1, %r12, %r3;
    @!%p1 add.s64 %rd10, %rd5, %rd5;
    cvt.u32.u64 %r12, %rd5;
    mul.lo.u32 %r20, %r12, 65536;
    sub.s32 %r16, %r5, %r20;
    max.u32 %r9, %r12, 31;
    shl.b64 %rd15, %rd10, 31;
    mul.lo.u32 %r14, %r20, %r12;
    mul.wide.u32 %rd9, %r5, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
