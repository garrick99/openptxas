.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    shr.u64 %rd15, %rd7, 1;
    min.u32 %r23, %r3, %r3;
    xor.b32 %r22, %r3, %r3;
    add.u64 %rd13, %rd7, %rd7;
    shr.s32 %r10, %r23, 7;
    max.s64 %rd12, %rd15, %rd13;
    shl.b32 %r11, %r22, 4;
    min.u32 %r8, %r11, 8;
    add.u32 %r6, %r3, 64;
    max.u32 %r11, %r8, 31;
    shr.u64 %rd13, %rd7, 15;
    shl.b32 %r5, %r8, 1;
    sub.s32 %r7, %r8, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
