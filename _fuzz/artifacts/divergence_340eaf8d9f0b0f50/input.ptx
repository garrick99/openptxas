.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    setp.gt.u32 %p1, %r3, %r3;
    @%p1 selp.b32 %r12, %r3, %r3, %p1;
    add.u32 %r17, %r12, 4;
    xor.b32 %r9, %r12, 63;
    min.u32 %r24, %r17, 255;
    shr.s64 %rd11, %rd15, 2;
    sub.s64 %rd9, %rd15, %rd11;
    min.s32 %r21, %r12, 31;
    shr.u32 %r10, %r9, 30;
    shl.b32 %r9, %r12, 3;
    add.s64 %rd9, %rd11, %rd9;
    max.u32 %r25, %r9, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
