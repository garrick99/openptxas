.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r17, %r3, 5;
    cvt.s64.s32 %rd14, %r3;
    shl.b64 %rd13, %rd14, 15;
    sub.u32 %r16, %r3, 255;
    cvt.u64.u32 %rd13, %r16;
    cvt.s64.s32 %rd14, %r16;
    max.u32 %r21, %r17, 255;
    sub.u32 %r10, %r3, 1;
    shr.u64 %rd10, %rd13, 48;
    and.b32 %r25, %r10, 7;
    max.s64 %rd15, %rd14, %rd10;
    min.u64 %rd14, %rd14, %rd14;
    cvt.s64.s32 %rd11, %r25;
    shr.u32 %r9, %r3, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
