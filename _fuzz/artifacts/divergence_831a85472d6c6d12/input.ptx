.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r16, %r3, 0;
    setp.ne.s32 %p1, %r3, 2;
    @!%p1 sub.u32 %r6, %r16, %r3;
    max.s32 %r6, %r3, %r6;
    mad.lo.s32 %r12, %r16, %r6, %r16;
    mul.lo.u32 %r22, %r16, %r6;
    min.u32 %r7, %r12, %r22;
    shl.b32 %r16, %r6, 4;
    sub.s32 %r21, %r22, %r22;
    setp.ne.s32 %p3, %r16, 3;
    @%p3 selp.b32 %r27, %r21, %r6, %p1;
    cvt.u64.u32 %rd7, %r16;
    or.b32 %r9, %r16, %r3;
    mul.lo.s32 %r17, %r12, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
