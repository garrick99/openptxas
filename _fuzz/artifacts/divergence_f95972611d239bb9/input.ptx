.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p2, %r3, 0;
    @!%p2 and.b32 %r16, %r3, 4294967295;
    selp.b32 %r8, %r3, %r3, %p2;
    or.b32 %r21, %r8, %r3;
    mul.lo.s32 %r8, %r16, 32;
    shr.u32 %r6, %r21, 15;
    setp.hi.u32 %p2, %r6, %r16;
    @%p2 cvt.u64.u32 %rd8, %r6;
    setp.ge.u32 %p3, %r8, 2147483648;
    cvt.u64.u32 %rd8, %r21;
    mul.wide.u32 %rd14, %r3, %r8;
    max.s32 %r13, %r21, %r21;
    add.s32 %r24, %r6, %r13;
    selp.b32 %r16, %r24, %r13, %p3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
