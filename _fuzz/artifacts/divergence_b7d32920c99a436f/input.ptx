    setp.lt.s32 %p2, %r7, 64;
    @%p2 mul.lo.s32 %r25, %r3, 31;
    cvt.s32.s64 %r26, %rd11;
    or.b32 %r10, %r3, 2147483648;
    mul.lo.s32 %r24, %r7, %r7;
    shr.u64 %rd11, %rd11, 1;
