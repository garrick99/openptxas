.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    clz.b32 %r7, %r3;
    bfi.b32 %r14, %r7, %r7, 7, 4;
    clz.b32 %r16, %r7;
    sub.u32 %r6, %r3, 0;
    max.u32 %r13, %r3, 16;
    bfi.b32 %r8, %r16, %r6, 31, 16;
    bfe.s32 %r9, %r16, 0, 31;
    bfe.u32 %r9, %r13, 16, 16;
    popc.b32 %r6, %r6;
    bfe.s32 %r12, %r9, 23, 24;
    bfi.b32 %r22, %r12, %r14, 23, 16;
    and.b32 %r22, %r9, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
