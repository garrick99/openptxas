.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd8, %r3;
    sub.u32 %r8, %r3, 64;
    cvt.u32.u64 %r14, %rd8;
    mad.lo.s32 %r19, %r3, %r8, %r3;
    setp.eq.s32 %p4, %r19, %r14;
    @!%p4 mul.lo.u32 %r18, %r19, %r14;
    min.s64 %rd15, %rd8, %rd8;
    sub.s64 %rd14, %rd8, %rd8;
    cvt.s64.s32 %rd9, %r8;
    cvt.u64.u32 %rd9, %r14;
    sub.s64 %rd15, %rd14, %rd9;
    setp.le.s32 %p2, %r8, %r19;
    @%p2 selp.b32 %r9, %r14, %r3, %p2;
    max.s32 %r24, %r14, %r18;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
