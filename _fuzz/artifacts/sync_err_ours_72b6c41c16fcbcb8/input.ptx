.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r20, %r3, 7;
    cvt.u64.u32 %rd14, %r20;
    cvt.s64.s32 %rd11, %r20;
    shl.b32 %r17, %r20, 4;
    sub.s32 %r9, %r20, 64;
    shr.s32 %r7, %r9, 2;
    shr.s32 %r18, %r3, 2;
    mul.wide.s32 %rd14, %r7, %r17;
    cvt.u32.u64 %r26, %rd14;
    cvt.s32.s64 %r8, %rd14;
    min.s64 %rd12, %rd11, %rd14;
    shr.s64 %rd7, %rd12, 16;
    mad.lo.u32 %r15, %r17, %r18, %r9;
    shr.u32 %r24, %r20, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
