.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r22, %r3, %r3;
    cvt.s64.s32 %rd14, %r3;
    add.u32 %r22, %r3, %r22;
    max.s32 %r13, %r22, %r22;
    mul.lo.u32 %r11, %r13, %r3;
    min.u32 %r13, %r13, %r11;
    setp.ne.s32 %p3, %r3, 32;
    @!%p3 mul.wide.u32 %rd9, %r22, %r22;
    sub.s32 %r9, %r3, 1;
    cvt.u32.u64 %r13, %rd14;
    cvt.s64.s32 %rd11, %r3;
    mad.lo.s32 %r21, %r9, %r3, %r11;
    max.s32 %r19, %r13, %r11;
    and.b32 %r21, %r3, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
