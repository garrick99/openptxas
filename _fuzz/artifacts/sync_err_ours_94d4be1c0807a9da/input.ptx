.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r17, %r3, 4294967295;
    shr.s32 %r22, %r3, 0;
    shl.b32 %r20, %r3, 2;
    cvt.s64.s32 %rd10, %r17;
    and.b32 %r15, %r3, %r22;
    setp.gt.s32 %p1, %r20, %r3;
    @!%p1 shl.b32 %r15, %r17, 7;
    max.s32 %r5, %r22, 1;
    sub.u32 %r8, %r17, 31;
    setp.le.s32 %p1, %r8, %r17;
    selp.b32 %r10, %r17, %r17, %p1;
    shr.u32 %r8, %r20, 15;
    max.s64 %rd9, %rd10, %rd10;
    mul.wide.s32 %rd7, %r3, %r10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
