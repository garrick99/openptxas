.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r11, %r3, %r3;
    cvt.u64.u32 %rd9, %r3;
    mul.wide.u32 %rd12, %r3, %r3;
    min.s32 %r24, %r11, 1;
    xor.b32 %r27, %r11, %r11;
    shr.s32 %r21, %r24, 4;
    xor.b32 %r26, %r27, 31;
    cvt.u32.u64 %r15, %rd12;
    mad.lo.u32 %r19, %r24, %r24, %r27;
    mul.wide.u32 %rd9, %r15, %r15;
    max.s32 %r21, %r21, 256;
    add.s32 %r20, %r24, %r26;
    max.u64 %rd13, %rd9, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
