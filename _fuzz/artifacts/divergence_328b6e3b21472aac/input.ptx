.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ge.s32 %p1, %r3, %r3;
    @!%p1 max.u32 %r22, %r3, 2147483648;
    mul.lo.u32 %r12, %r22, %r22;
    mul.lo.u32 %r23, %r12, %r3;
    cvt.s64.s32 %rd6, %r22;
    add.s32 %r6, %r3, 1;
    shr.s32 %r13, %r6, 0;
    cvt.u32.u64 %r13, %rd6;
    xor.b32 %r11, %r22, 0;
    add.u32 %r23, %r6, %r3;
    shl.b64 %rd9, %rd6, 16;
    shl.b64 %rd11, %rd6, 33;
    max.s32 %r27, %r22, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
