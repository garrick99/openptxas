.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    shr.s32 %r16, %r3, 1;
    add.s32 %r15, %r3, %r3;
    shr.s64 %rd11, %rd9, 32;
    mul.lo.s32 %r9, %r3, %r15;
    and.b64 %rd9, %rd11, %rd9;
    xor.b64 %rd10, %rd9, %rd9;
    cvt.s32.s64 %r5, %rd11;
    shl.b64 %rd9, %rd9, 33;
    min.u32 %r12, %r9, 3;
    sub.s32 %r9, %r16, %r12;
    add.s32 %r25, %r15, %r9;
    shl.b32 %r15, %r5, 16;
    add.u32 %r11, %r9, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
