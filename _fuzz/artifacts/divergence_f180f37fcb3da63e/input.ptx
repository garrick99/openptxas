.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r12, %r3, 15;
    setp.le.u32 %p4, %r3, 64;
    mul.lo.u32 %r4, %r3, 2147483647;
    mul.lo.u32 %r7, %r4, %r3;
    cvt.s64.s32 %rd13, %r7;
    min.s32 %r26, %r12, 256;
    mad.lo.s32 %r12, %r4, %r4, %r7;
    mul.lo.s32 %r17, %r12, %r26;
    xor.b32 %r18, %r26, 4294967295;
    min.u32 %r18, %r18, %r4;
    cvt.u32.u64 %r19, %rd13;
    max.u32 %r12, %r17, 31;
    mul.wide.u32 %rd11, %r26, %r7;
    mul.wide.s32 %rd15, %r18, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
