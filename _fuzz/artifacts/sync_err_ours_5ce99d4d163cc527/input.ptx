.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lo.u32 %p2, %r3, %r3;
    @%p2 min.u32 %r25, %r3, %r3;
    selp.b32 %r6, %r25, %r25, %p2;
    sub.u32 %r5, %r3, 16;
    min.u32 %r18, %r3, 3;
    shl.b32 %r22, %r5, 30;
    max.u32 %r21, %r3, %r3;
    setp.ge.s32 %p3, %r21, %r6;
    @%p3 mul.wide.u32 %rd14, %r5, %r18;
    add.u32 %r7, %r25, %r18;
    mul.lo.s32 %r7, %r5, 31;
    add.u32 %r20, %r7, %r22;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
