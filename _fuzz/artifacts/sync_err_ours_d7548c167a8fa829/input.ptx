.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p1, %r3, %r3;
    @!%p1 cvt.u64.u32 %rd11, %r3;
    cvt.s64.s32 %rd13, %r3;
    sub.u32 %r11, %r3, 65536;
    mul.lo.u32 %r21, %r3, %r3;
    max.u32 %r20, %r21, %r11;
    setp.ne.u32 %p3, %r11, %r21;
    mul.lo.s32 %r21, %r3, 255;
    mul.lo.u32 %r12, %r11, 31;
    setp.ne.u32 %p1, %r11, %r20;
    sub.u32 %r11, %r11, %r3;
    selp.b32 %r11, %r12, %r3, %p3;
    shr.s64 %rd6, %rd11, 62;
    mul.lo.u32 %r6, %r3, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
