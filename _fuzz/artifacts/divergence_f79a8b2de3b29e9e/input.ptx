.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r20, %r3, 63;
    shl.b32 %r17, %r3, 2;
    mul.lo.s32 %r23, %r17, %r17;
    mul.lo.u32 %r19, %r3, %r23;
    cvt.u64.u32 %rd9, %r17;
    cvt.s32.s64 %r7, %rd9;
    mul.lo.s32 %r26, %r17, %r3;
    shr.s64 %rd5, %rd9, 4;
    cvt.u32.u64 %r26, %rd5;
    add.u64 %rd7, %rd5, %rd9;
    cvt.s32.s64 %r5, %rd7;
    mul.wide.u32 %rd10, %r3, %r7;
    and.b32 %r9, %r5, 31;
    min.s32 %r18, %r26, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
