.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r19, %r3, %r3;
    shr.s32 %r24, %r3, 4;
    setp.eq.s32 %p4, %r24, 0;
    @%p4 max.u32 %r9, %r24, %r3;
    add.u32 %r8, %r3, %r9;
    cvt.s64.s32 %rd8, %r24;
    max.s32 %r23, %r19, 255;
    shl.b64 %rd11, %rd8, 15;
    min.u64 %rd5, %rd8, %rd11;
    or.b32 %r26, %r23, 64;
    shr.u32 %r20, %r24, 15;
    mul.wide.s32 %rd8, %r24, %r23;
    or.b32 %r5, %r24, 3;
    add.s32 %r5, %r9, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
