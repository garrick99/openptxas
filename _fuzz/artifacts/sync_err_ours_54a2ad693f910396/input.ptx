.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd13, %r3;
    cvt.u64.u32 %rd8, %r3;
    cvt.s64.s32 %rd7, %r3;
    setp.hi.u32 %p2, %r3, %r3;
    @%p2 max.s32 %r22, %r3, %r3;
    mad.lo.s32 %r10, %r3, %r22, %r22;
    mad.lo.s32 %r7, %r22, %r3, %r22;
    shr.u32 %r16, %r10, 7;
    setp.ge.u32 %p1, %r3, 7;
    setp.gt.u32 %p1, %r16, 2;
    min.u32 %r25, %r16, %r22;
    add.u64 %rd7, %rd8, %rd8;
    and.b64 %rd7, %rd13, %rd13;
    add.u32 %r10, %r22, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
