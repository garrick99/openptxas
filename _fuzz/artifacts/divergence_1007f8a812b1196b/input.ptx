.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r10, %r3, 255;
    mul.lo.s32 %r16, %r10, %r10;
    cvt.u64.u32 %rd8, %r16;
    cvt.u32.u64 %r6, %rd8;
    shl.b32 %r21, %r6, 2;
    add.s32 %r4, %r3, 64;
    min.s32 %r18, %r16, %r6;
    mul.wide.u32 %rd8, %r3, %r10;
    or.b32 %r11, %r16, %r16;
    cvt.s64.s32 %rd8, %r6;
    max.u32 %r13, %r11, 2147483647;
    shl.b64 %rd12, %rd8, 0;
    mul.wide.u32 %rd6, %r4, %r3;
    sub.s32 %r15, %r13, %r21;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
