.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r25, %r3, %r3;
    cvt.u64.u32 %rd12, %r3;
    sub.s64 %rd6, %rd12, %rd12;
    cvt.u64.u32 %rd8, %r25;
    and.b32 %r23, %r3, %r3;
    mul.wide.s32 %rd9, %r25, %r23;
    shl.b32 %r22, %r25, 31;
    xor.b32 %r18, %r22, 64;
    cvt.s32.s64 %r27, %rd6;
    shr.u64 %rd8, %rd6, 7;
    or.b64 %rd12, %rd9, %rd8;
    shr.s32 %r13, %r18, 15;
    add.s32 %r21, %r27, 256;
    add.u32 %r10, %r18, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
