.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r19, %r3, 0;
    and.b32 %r13, %r3, 15;
    sub.s32 %r22, %r13, 2147483647;
    setp.lo.u32 %p4, %r3, 5;
    @%p4 max.s32 %r23, %r3, %r22;
    and.b32 %r24, %r23, 31;
    selp.b32 %r27, %r24, %r3, %p4;
    add.u32 %r13, %r27, %r24;
    cvt.u64.u32 %rd12, %r27;
    selp.b32 %r8, %r19, %r23, %p4;
    shr.s32 %r18, %r13, 31;
    cvt.u64.u32 %rd15, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
