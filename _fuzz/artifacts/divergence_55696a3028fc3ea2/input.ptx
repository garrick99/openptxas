    shfl.sync.down.b32 %r4, %r3, 4, 0x1f, -1;
    setp.ge.u32 %p3, %r4, 2147483647;
    vote.sync.ballot.b32 %r8, %p3, -1;
    or.b32 %r11, %r3, %r3;
