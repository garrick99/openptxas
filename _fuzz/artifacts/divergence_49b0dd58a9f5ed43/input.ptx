.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    sub.s32 %r13, %r3, 2;
    shl.b32 %r13, %r13, 1;
    or.b32 %r5, %r13, %r3;
    max.s32 %r8, %r3, 1;
    or.b32 %r5, %r8, %r3;
    shr.u32 %r19, %r8, 30;
    and.b64 %rd8, %rd15, %rd15;
    mad.lo.u32 %r22, %r19, %r5, %r8;
    sub.u32 %r19, %r22, %r22;
    shr.s32 %r26, %r19, 30;
    setp.eq.s32 %p3, %r5, 0;
    @%p3 shl.b32 %r27, %r5, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
    ret;
}
