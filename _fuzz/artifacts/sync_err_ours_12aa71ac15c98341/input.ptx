.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd15, %r3;
    sub.u32 %r9, %r3, %r3;
    or.b32 %r26, %r3, 7;
    shr.u32 %r6, %r26, 30;
    cvt.u32.u64 %r19, %rd15;
    add.s32 %r13, %r3, 15;
    shr.s64 %rd10, %rd15, 0;
    or.b64 %rd13, %rd10, %rd10;
    cvt.s32.s64 %r23, %rd13;
    cvt.u32.u64 %r4, %rd13;
    sub.u32 %r13, %r13, %r23;
    mul.lo.u64 %rd14, %rd13, %rd10;
    shr.s32 %r12, %r6, 3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
