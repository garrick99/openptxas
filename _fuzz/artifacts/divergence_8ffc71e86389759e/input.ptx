.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r7, %r3, 30;
    mad.lo.s32 %r4, %r3, %r3, %r7;
    sub.s32 %r7, %r3, %r7;
    mul.wide.u32 %rd12, %r4, %r7;
    sub.s32 %r9, %r4, 65536;
    sub.u32 %r6, %r3, %r3;
    shl.b32 %r25, %r7, 2;
    mad.lo.u32 %r13, %r3, %r25, %r9;
    add.s32 %r14, %r7, 63;
    shr.s32 %r6, %r25, 1;
    cvt.u64.u32 %rd14, %r4;
    cvt.u32.u64 %r19, %rd12;
    shl.b64 %rd10, %rd14, 1;
    mul.lo.s32 %r16, %r19, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
