.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r11, %r3, 63;
    cvt.s64.s32 %rd13, %r11;
    and.b32 %r5, %r3, %r3;
    min.u32 %r14, %r5, 15;
    shr.u64 %rd10, %rd13, 16;
    or.b32 %r8, %r14, %r14;
    max.u32 %r4, %r14, 0;
    shr.s64 %rd9, %rd13, 2;
    cvt.s32.s64 %r20, %rd9;
    and.b32 %r15, %r5, %r14;
    add.u32 %r18, %r11, %r15;
    add.s32 %r19, %r20, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
    ret;
}
