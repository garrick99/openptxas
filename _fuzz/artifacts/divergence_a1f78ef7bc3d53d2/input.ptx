.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r23, %r3, 8;
    shr.u32 %r12, %r3, 4;
    shl.b32 %r16, %r23, 16;
    mad.lo.s32 %r21, %r3, %r12, %r12;
    sub.s32 %r23, %r23, %r23;
    cvt.u64.u32 %rd12, %r12;
    mul.lo.u32 %r22, %r21, %r3;
    min.u32 %r12, %r22, 2;
    shr.s32 %r7, %r12, 2;
    max.u32 %r12, %r23, 1;
    mad.lo.s32 %r25, %r7, %r12, %r12;
    max.s32 %r24, %r25, %r21;
    sub.u32 %r24, %r24, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
