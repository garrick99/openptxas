.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd10, %r3, %r3;
    add.s32 %r27, %r3, %r3;
    min.u32 %r26, %r27, %r27;
    add.s32 %r5, %r26, %r27;
    setp.ne.s32 %p1, %r26, %r3;
    setp.ls.u32 %p4, %r27, 4;
    @%p4 add.u32 %r16, %r26, %r3;
    add.u32 %r17, %r16, 255;
    shr.s32 %r21, %r17, 1;
    add.s32 %r19, %r27, %r17;
    add.s64 %rd12, %rd10, %rd10;
    add.s32 %r25, %r5, %r21;
    add.u32 %r10, %r3, %r3;
    selp.b32 %r9, %r26, %r19, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
