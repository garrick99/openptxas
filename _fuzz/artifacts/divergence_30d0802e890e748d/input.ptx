.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r6, %r3, %r3;
    mul.wide.s32 %rd10, %r6, %r3;
    mul.lo.s64 %rd5, %rd10, %rd10;
    mad.lo.u32 %r10, %r3, %r3, %r3;
    setp.eq.s32 %p3, %r10, 255;
    @%p3 add.s32 %r20, %r3, %r6;
    cvt.s32.s64 %r5, %rd5;
    or.b32 %r23, %r6, 2;
    shr.s64 %rd9, %rd10, 31;
    max.u32 %r11, %r5, 4;
    mul.lo.u32 %r5, %r10, %r6;
    max.s32 %r13, %r3, 255;
    setp.ls.u32 %p4, %r20, 2;
    setp.ls.u32 %p3, %r20, 256;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
