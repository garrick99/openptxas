.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r16, %r3, 16;
    max.s32 %r18, %r3, 4294967295;
    cvt.s64.s32 %rd14, %r18;
    xor.b32 %r5, %r3, 2147483647;
    setp.gt.u32 %p2, %r18, %r18;
    @%p2 max.u32 %r18, %r5, 1;
    mul.wide.u32 %rd10, %r18, %r18;
    min.s64 %rd9, %rd14, %rd10;
    shr.s32 %r16, %r16, 1;
    min.u32 %r20, %r16, 32;
    mad.lo.u32 %r23, %r20, %r18, %r5;
    shl.b64 %rd12, %rd9, 2;
    sub.s32 %r18, %r18, 1;
    cvt.u32.u64 %r12, %rd9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
