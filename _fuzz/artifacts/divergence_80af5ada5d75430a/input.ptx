.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shl.b32 %r5, %r3, 30;
    cvt.u64.u32 %rd5, %r5;
    mad.lo.u32 %r18, %r5, %r3, %r5;
    add.s32 %r4, %r3, %r18;
    setp.ne.s32 %p3, %r18, %r5;
    @%p3 max.s32 %r13, %r5, %r18;
    add.u32 %r4, %r5, 15;
    mul.lo.s64 %rd8, %rd5, %rd5;
    add.u64 %rd5, %rd5, %rd5;
    max.u32 %r18, %r4, %r4;
    mul.lo.u32 %r25, %r3, %r3;
    selp.b32 %r7, %r13, %r25, %p3;
    setp.ge.u32 %p4, %r18, %r3;
    @%p4 min.s32 %r24, %r18, 4294967295;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
