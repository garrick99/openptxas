.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    sub.u32 %r10, %r3, %r3;
    min.s32 %r8, %r10, 0;
    mul.wide.s32 %rd9, %r3, %r10;
    shl.b32 %r19, %r3, 3;
    add.u32 %r24, %r8, %r10;
    max.s32 %r18, %r8, %r19;
    min.s32 %r24, %r19, 16;
    add.u32 %r10, %r8, %r8;
    mul.lo.u64 %rd12, %rd11, %rd11;
    mul.wide.s32 %rd10, %r18, %r8;
    setp.lt.u32 %p4, %r24, %r8;
    @%p4 max.u64 %rd13, %rd11, %rd10;
    max.u32 %r18, %r10, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
