.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<28>;
    .reg .b64 %rd<8>;
    .reg .pred %p<4>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    popc.b32 %r12, %r3;
    and.b32 %r12, %r3, 256;
    prmt.b32 %r12, %r3, %r12, 17476;
    bfe.s32 %r18, %r12, 4, 24;
    bfe.s32 %r10, %r18, 24, 4;
    bfe.s32 %r8, %r18, 7, 8;
    prmt.b32 %r18, %r18, %r12, 12816;
    bfi.b32 %r22, %r10, %r3, 0, 16;
    bfe.s32 %r21, %r18, 15, 7;
    brev.b32 %r7, %r8;
    bfe.s32 %r13, %r7, 7, 8;
    bfi.b32 %r20, %r10, %r7, 24, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
