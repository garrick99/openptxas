.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r13, %r3, 4;
    and.b32 %r24, %r13, 65535;
    shr.s32 %r16, %r3, 0;
    sub.s32 %r10, %r3, %r13;
    setp.eq.s32 %p4, %r16, 65535;
    shl.b32 %r8, %r13, 31;
    cvt.u64.u32 %rd11, %r24;
    mul.wide.u32 %rd8, %r13, %r3;
    setp.gt.s32 %p3, %r3, %r8;
    @%p3 cvt.u32.u64 %r18, %rd8;
    sub.s64 %rd8, %rd8, %rd8;
    sub.s32 %r10, %r18, %r3;
    min.s64 %rd14, %rd11, %rd8;
    min.u64 %rd11, %rd8, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
