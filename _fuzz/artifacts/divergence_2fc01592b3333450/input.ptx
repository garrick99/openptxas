.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd15, %r3;
    setp.ge.s32 %p2, %r3, 8;
    @!%p2 max.u32 %r22, %r3, %r3;
    max.u32 %r12, %r3, %r22;
    sub.s32 %r4, %r3, %r12;
    add.u32 %r11, %r3, %r4;
    mul.lo.s32 %r20, %r3, %r4;
    mul.lo.u32 %r8, %r12, %r4;
    or.b32 %r26, %r12, 65536;
    mad.lo.s32 %r8, %r12, %r22, %r12;
    max.s32 %r9, %r12, %r11;
    mad.lo.s32 %r10, %r11, %r26, %r4;
    shr.u64 %rd13, %rd15, 1;
    shr.u64 %rd7, %rd13, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
