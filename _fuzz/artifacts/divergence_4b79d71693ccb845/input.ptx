.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p2, %r3, 15;
    @!%p2 mul.wide.s32 %rd15, %r3, %r3;
    mad.lo.u32 %r10, %r3, %r3, %r3;
    shr.u32 %r24, %r10, 0;
    setp.eq.s32 %p1, %r10, %r3;
    @!%p1 shr.s32 %r7, %r3, 1;
    setp.ls.u32 %p2, %r24, %r3;
    mul.lo.u64 %rd8, %rd15, %rd15;
    setp.ne.s32 %p1, %r24, %r3;
    @%p1 min.u32 %r14, %r10, 7;
    cvt.u64.u32 %rd5, %r14;
    add.u64 %rd12, %rd15, %rd15;
    min.u32 %r15, %r24, 256;
    add.u64 %rd11, %rd5, %rd15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
    ret;
}
