.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.u32 %r24, %r3, 4;
    add.u32 %r4, %r3, %r3;
    cvt.u64.u32 %rd11, %r24;
    sub.u32 %r17, %r3, %r3;
    setp.eq.u32 %p4, %r17, %r24;
    @%p4 max.s64 %rd12, %rd11, %rd11;
    sub.u32 %r6, %r3, 32;
    setp.lo.u32 %p1, %r4, %r24;
    min.s64 %rd15, %rd12, %rd11;
    xor.b32 %r24, %r24, 3;
    selp.b32 %r13, %r6, %r4, %p4;
    mul.wide.s32 %rd12, %r17, %r4;
    shr.u32 %r15, %r4, 15;
    max.s32 %r13, %r13, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
