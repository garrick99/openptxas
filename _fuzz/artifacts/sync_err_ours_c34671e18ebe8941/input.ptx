.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    max.u32 %r18, %r3, 32;
    or.b64 %rd7, %rd7, %rd7;
    add.s32 %r27, %r18, %r18;
    sub.s32 %r22, %r27, %r18;
    max.s32 %r23, %r18, 16;
    cvt.s64.s32 %rd12, %r27;
    min.s64 %rd8, %rd7, %rd12;
    xor.b32 %r9, %r3, 4294967295;
    add.s32 %r7, %r18, 5;
    shr.u64 %rd10, %rd12, 1;
    mul.wide.s32 %rd15, %r23, %r3;
    cvt.s64.s32 %rd15, %r23;
    shr.s64 %rd12, %rd8, 33;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
