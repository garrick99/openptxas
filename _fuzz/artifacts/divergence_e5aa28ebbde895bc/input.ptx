.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd12, %r3, %r3;
    sub.u32 %r9, %r3, 0;
    mul.wide.s32 %rd9, %r9, %r9;
    and.b32 %r8, %r3, %r3;
    sub.s32 %r8, %r8, %r3;
    mul.lo.u64 %rd5, %rd9, %rd9;
    shl.b32 %r24, %r9, 30;
    and.b32 %r22, %r24, %r24;
    mul.wide.s32 %rd13, %r8, %r9;
    shr.s64 %rd11, %rd12, 15;
    shl.b64 %rd13, %rd11, 15;
    mul.lo.s32 %r26, %r3, 1;
    setp.hs.u32 %p1, %r24, %r22;
    @!%p1 cvt.s32.s64 %r20, %rd5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
