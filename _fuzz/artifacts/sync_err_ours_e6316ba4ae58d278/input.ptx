.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r20, %r3, 15;
    cvt.u64.u32 %rd15, %r3;
    mad.lo.s32 %r11, %r20, %r20, %r3;
    min.s64 %rd6, %rd15, %rd15;
    mul.lo.u32 %r6, %r11, 3;
    shr.u64 %rd11, %rd6, 4;
    and.b32 %r7, %r20, 31;
    cvt.u64.u32 %rd8, %r7;
    add.u32 %r8, %r3, 64;
    xor.b32 %r15, %r6, %r20;
    cvt.u64.u32 %rd14, %r3;
    shr.s64 %rd6, %rd6, 33;
    max.u32 %r12, %r20, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
