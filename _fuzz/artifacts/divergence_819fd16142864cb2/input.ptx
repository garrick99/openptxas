.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.s32 %p3, %r3, %r3;
    cvt.u64.u32 %rd9, %r3;
    max.u32 %r25, %r3, 4;
    min.s64 %rd10, %rd9, %rd9;
    selp.b32 %r16, %r3, %r25, %p3;
    min.u32 %r5, %r3, %r25;
    add.s32 %r23, %r25, %r5;
    add.u64 %rd14, %rd10, %rd9;
    mul.lo.s32 %r10, %r23, %r25;
    or.b32 %r22, %r3, %r5;
    add.s32 %r11, %r25, %r25;
    selp.b32 %r11, %r10, %r3, %p3;
    cvt.s32.s64 %r7, %rd14;
    min.s32 %r6, %r3, 5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
