.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.hs.u32 %p1, %r3, %r3;
    @!%p1 max.u32 %r17, %r3, %r3;
    cvt.s64.s32 %rd10, %r3;
    max.s32 %r19, %r17, %r3;
    or.b32 %r21, %r3, %r19;
    add.s32 %r4, %r21, 2147483648;
    setp.gt.s32 %p2, %r21, %r3;
    setp.eq.s32 %p3, %r19, 65536;
    @%p3 and.b32 %r18, %r3, %r21;
    mad.lo.s32 %r16, %r19, %r19, %r18;
    max.s64 %rd9, %rd10, %rd10;
    and.b64 %rd12, %rd9, %rd10;
    setp.lt.s32 %p3, %r19, 1;
    @%p3 or.b32 %r16, %r16, %r16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
