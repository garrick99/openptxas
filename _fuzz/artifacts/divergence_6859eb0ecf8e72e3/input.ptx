.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r26, %r3, %r3;
    setp.lt.u32 %p3, %r3, %r3;
    @%p3 sub.u32 %r16, %r3, %r26;
    add.u32 %r26, %r26, 255;
    max.u32 %r14, %r26, 31;
    selp.b32 %r23, %r3, %r26, %p3;
    mad.lo.u32 %r11, %r16, %r26, %r14;
    shl.b32 %r10, %r14, 1;
    mul.wide.s32 %rd5, %r10, %r26;
    shl.b32 %r20, %r23, 7;
    add.s64 %rd6, %rd5, %rd5;
    or.b32 %r8, %r20, %r26;
    cvt.s64.s32 %rd10, %r3;
    mul.wide.u32 %rd12, %r20, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
