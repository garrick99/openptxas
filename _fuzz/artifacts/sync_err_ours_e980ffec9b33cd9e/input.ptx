.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.u32 %p1, %r3, 7;
    @!%p1 selp.b32 %r6, %r3, %r3, %p1;
    shr.s32 %r21, %r3, 7;
    cvt.s64.s32 %rd5, %r3;
    sub.u32 %r27, %r6, 5;
    shl.b32 %r24, %r27, 30;
    selp.b32 %r4, %r24, %r24, %p1;
    max.s32 %r9, %r24, %r4;
    shr.u64 %rd8, %rd5, 2;
    shr.u32 %r12, %r9, 4;
    sub.u32 %r21, %r27, %r21;
    mul.lo.s32 %r21, %r4, 63;
    sub.s32 %r16, %r24, %r21;
    shl.b32 %r8, %r21, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r8;
    ret;
}
