.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r7, %r3, 5;
    and.b32 %r26, %r3, %r7;
    or.b32 %r18, %r26, 4;
    mul.wide.u32 %rd6, %r18, %r3;
    min.u32 %r13, %r26, 5;
    sub.s32 %r14, %r3, %r3;
    mad.lo.s32 %r5, %r18, %r26, %r26;
    xor.b32 %r6, %r26, %r18;
    setp.lt.u32 %p3, %r18, %r13;
    @%p3 xor.b32 %r5, %r7, 0;
    selp.b32 %r23, %r13, %r6, %p3;
    setp.lt.s32 %p4, %r6, 31;
    @%p4 xor.b64 %rd8, %rd6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
