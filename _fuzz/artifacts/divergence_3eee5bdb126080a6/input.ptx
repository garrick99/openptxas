.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.s32 %r26, %r3, %r3, %r3;
    and.b32 %r17, %r3, %r3;
    mul.lo.u32 %r13, %r3, 4294967295;
    cvt.u64.u32 %rd7, %r26;
    add.u32 %r17, %r17, 2147483647;
    min.s32 %r8, %r3, 5;
    mad.lo.s32 %r9, %r3, %r8, %r26;
    setp.eq.u32 %p4, %r17, %r26;
    @!%p4 add.s64 %rd6, %rd7, %rd7;
    mul.lo.s32 %r11, %r26, 5;
    mul.wide.u32 %rd8, %r11, %r3;
    cvt.u64.u32 %rd8, %r26;
    min.s32 %r11, %r13, %r13;
    mad.lo.s32 %r20, %r8, %r13, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
