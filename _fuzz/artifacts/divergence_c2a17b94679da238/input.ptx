.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.u32 %r16, %r3, 65535;
    setp.gt.s32 %p3, %r3, 255;
    @%p3 mad.lo.s32 %r9, %r3, %r16, %r16;
    selp.b32 %r20, %r3, %r16, %p3;
    mul.wide.s32 %rd13, %r20, %r9;
    add.s32 %r19, %r3, 16;
    mad.lo.s32 %r13, %r9, %r16, %r16;
    or.b32 %r26, %r13, %r13;
    or.b64 %rd12, %rd13, %rd13;
    max.u32 %r22, %r9, %r3;
    cvt.s32.s64 %r14, %rd13;
    max.s32 %r19, %r13, 255;
    and.b32 %r6, %r13, %r3;
    shl.b64 %rd10, %rd13, 48;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
