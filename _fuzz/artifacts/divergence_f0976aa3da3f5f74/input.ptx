.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.s32 %r4, %r3, 2;
    cvt.s64.s32 %rd13, %r4;
    sub.s64 %rd9, %rd13, %rd13;
    cvt.s64.s32 %rd8, %r3;
    mul.lo.u32 %r15, %r4, 64;
    shr.u32 %r26, %r3, 3;
    mul.lo.u32 %r22, %r15, %r15;
    cvt.u64.u32 %rd14, %r26;
    and.b32 %r17, %r3, %r15;
    cvt.u32.u64 %r23, %rd14;
    shr.u32 %r24, %r4, 0;
    sub.s64 %rd15, %rd8, %rd9;
    shr.s32 %r24, %r22, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
