.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    shr.u32 %r10, %r3, 4;
    mul.lo.s32 %r4, %r10, %r3;
    shl.b32 %r20, %r4, 1;
    sub.u64 %rd10, %rd7, %rd7;
    or.b32 %r26, %r20, 2147483647;
    xor.b64 %rd15, %rd10, %rd7;
    or.b32 %r27, %r20, %r20;
    max.s32 %r11, %r4, %r4;
    max.u32 %r24, %r4, %r11;
    sub.u32 %r12, %r20, 5;
    mul.lo.u64 %rd12, %rd10, %rd10;
    shr.s32 %r18, %r27, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
