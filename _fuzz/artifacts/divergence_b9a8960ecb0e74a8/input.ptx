.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r17, %r3, 255;
    cvt.u64.u32 %rd6, %r17;
    shl.b64 %rd11, %rd6, 1;
    cvt.s64.s32 %rd14, %r3;
    add.u32 %r24, %r17, %r3;
    mad.lo.u32 %r21, %r3, %r17, %r17;
    shr.s64 %rd6, %rd11, 15;
    mad.lo.u32 %r6, %r24, %r3, %r24;
    shr.u32 %r5, %r17, 16;
    cvt.u32.u64 %r14, %rd6;
    and.b32 %r24, %r14, 15;
    cvt.s32.s64 %r21, %rd6;
    shl.b64 %rd15, %rd6, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r21;
    ret;
}
