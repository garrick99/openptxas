.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd12, %r3;
    cvt.s32.s64 %r24, %rd12;
    cvt.u32.u64 %r19, %rd12;
    and.b32 %r6, %r3, %r24;
    shl.b64 %rd8, %rd12, 62;
    shr.s32 %r5, %r3, 7;
    setp.lt.s32 %p2, %r3, 1;
    @%p2 mad.lo.u32 %r10, %r3, %r6, %r19;
    mad.lo.u32 %r17, %r6, %r10, %r3;
    shr.u64 %rd8, %rd12, 48;
    setp.ge.u32 %p4, %r17, %r10;
    mul.lo.u64 %rd7, %rd8, %rd12;
    shl.b32 %r13, %r19, 31;
    setp.ne.s32 %p4, %r13, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r13;
    ret;
}
