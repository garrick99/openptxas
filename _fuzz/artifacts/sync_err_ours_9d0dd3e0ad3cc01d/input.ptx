.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    cvt.u32.u64 %r12, %rd14;
    cvt.u32.u64 %r7, %rd14;
    sub.s32 %r20, %r12, %r12;
    cvt.s32.s64 %r9, %rd14;
    xor.b32 %r25, %r12, 2;
    and.b32 %r20, %r25, 15;
    add.u32 %r25, %r20, %r25;
    cvt.u64.u32 %rd15, %r12;
    shr.s64 %rd7, %rd15, 7;
    shr.s32 %r26, %r20, 4;
    or.b32 %r18, %r9, %r9;
    add.u32 %r17, %r12, %r26;
    sub.u32 %r6, %r7, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
