.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd5, %r3, %r3;
    add.s64 %rd11, %rd5, %rd5;
    add.u32 %r16, %r3, %r3;
    shr.s64 %rd9, %rd11, 0;
    max.u32 %r19, %r3, 63;
    mul.wide.s32 %rd11, %r19, %r3;
    cvt.u64.u32 %rd8, %r16;
    min.s32 %r19, %r19, %r3;
    and.b32 %r16, %r19, %r3;
    or.b32 %r24, %r19, 255;
    sub.u32 %r15, %r3, 2147483647;
    setp.gt.s32 %p4, %r16, 2147483647;
    @%p4 and.b32 %r15, %r19, 2;
    cvt.u32.u64 %r7, %rd8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
