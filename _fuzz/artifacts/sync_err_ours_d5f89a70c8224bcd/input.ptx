.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd5, %r3;
    mul.wide.s32 %rd15, %r3, %r3;
    add.s32 %r9, %r3, 2;
    shl.b32 %r13, %r3, 16;
    and.b32 %r21, %r9, 15;
    cvt.u64.u32 %rd8, %r3;
    max.s32 %r9, %r13, %r3;
    shr.s32 %r17, %r13, 31;
    xor.b32 %r9, %r21, 65536;
    setp.le.u32 %p2, %r13, %r3;
    shr.s64 %rd11, %rd8, 30;
    sub.u32 %r25, %r21, 65536;
    add.u32 %r24, %r21, %r3;
    shr.s64 %rd11, %rd5, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
