.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p4, %r3, %r3;
    @!%p4 shl.b32 %r14, %r3, 15;
    cvt.s64.s32 %rd11, %r14;
    max.u32 %r26, %r3, 4294967295;
    and.b32 %r13, %r26, %r14;
    xor.b32 %r21, %r13, %r26;
    xor.b32 %r25, %r26, 4;
    and.b32 %r8, %r25, %r14;
    setp.gt.s32 %p1, %r25, 15;
    @!%p1 sub.u64 %rd13, %rd11, %rd11;
    shr.s32 %r7, %r25, 7;
    max.u32 %r21, %r3, 4294967295;
    cvt.u32.u64 %r10, %rd11;
    selp.b32 %r18, %r10, %r26, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r18;
    ret;
}
