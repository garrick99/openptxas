.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r7, %r3, 32;
    mul.lo.u32 %r24, %r7, 2147483648;
    cvt.s64.s32 %rd11, %r7;
    xor.b32 %r6, %r24, 7;
    or.b32 %r19, %r3, 255;
    setp.hi.u32 %p1, %r7, %r6;
    @!%p1 shr.s32 %r25, %r3, 0;
    shr.u32 %r25, %r19, 30;
    mad.lo.u32 %r4, %r3, %r24, %r6;
    shr.u32 %r5, %r6, 16;
    sub.u32 %r23, %r24, %r19;
    or.b32 %r6, %r3, %r24;
    max.s32 %r24, %r25, %r4;
    and.b32 %r17, %r23, %r7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
