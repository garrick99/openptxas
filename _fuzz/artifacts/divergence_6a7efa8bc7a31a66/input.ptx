    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r25, %r3, 15;
    cvt.u64.u32 %rd12, %r25;
    add.u32 %r12, %r3, %r25;
    cvt.u64.u32 %rd6, %r3;
    cvt.u32.u64 %r9, %rd6;
    setp.le.s32 %p4, %r25, 2147483648;
    @%p4 min.u32 %r9, %r3, 65535;
    shr.s64 %rd14, %rd6, 1;
    sub.u32 %r17, %r3, %r25;
