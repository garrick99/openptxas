.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r26, %r3, %r3;
    min.u32 %r20, %r3, 1;
    and.b32 %r11, %r20, 65535;
    add.u32 %r9, %r20, 5;
    mul.lo.s32 %r25, %r20, %r26;
    min.s32 %r6, %r9, 7;
    cvt.s64.s32 %rd12, %r20;
    setp.ne.u32 %p1, %r3, %r6;
    @%p1 mul.wide.s32 %rd8, %r3, %r6;
    shr.s64 %rd13, %rd12, 48;
    max.s64 %rd10, %rd8, %rd8;
    add.u32 %r23, %r9, %r25;
    min.u32 %r26, %r25, 1;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
