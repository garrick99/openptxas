.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd14, %r3;
    add.u32 %r18, %r3, 7;
    cvt.u32.u64 %r15, %rd14;
    min.u32 %r4, %r3, %r3;
    shr.s32 %r15, %r18, 16;
    setp.ne.s32 %p2, %r4, %r4;
    @%p2 selp.b32 %r9, %r3, %r15, %p2;
    mul.wide.u32 %rd14, %r4, %r18;
    add.s32 %r22, %r18, %r3;
    setp.lt.s32 %p2, %r9, 4;
    @%p2 shr.s32 %r23, %r9, 16;
    sub.s64 %rd6, %rd14, %rd14;
    and.b32 %r13, %r23, %r23;
    add.u32 %r14, %r4, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
