.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r5, %r3, 7;
    mul.lo.u32 %r9, %r3, 4294967295;
    mad.lo.s32 %r26, %r5, %r5, %r9;
    cvt.s64.s32 %rd14, %r5;
    mul.lo.u32 %r22, %r5, %r9;
    mad.lo.s32 %r5, %r5, %r9, %r26;
    shr.s32 %r14, %r22, 0;
    sub.u32 %r4, %r9, %r22;
    add.u32 %r15, %r26, %r14;
    mul.wide.s32 %rd12, %r9, %r15;
    cvt.s32.s64 %r4, %rd14;
    mad.lo.s32 %r5, %r22, %r4, %r14;
    mul.lo.u32 %r12, %r5, 65536;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
