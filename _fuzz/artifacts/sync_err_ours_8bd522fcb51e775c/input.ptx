.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r20, %r3, %r3;
    min.u32 %r26, %r20, 4294967295;
    setp.ne.s32 %p1, %r26, 15;
    @%p1 shr.s32 %r17, %r3, 30;
    mul.wide.s32 %rd6, %r3, %r3;
    min.s64 %rd10, %rd6, %rd6;
    selp.b32 %r15, %r20, %r17, %p1;
    mad.lo.s32 %r12, %r26, %r26, %r17;
    shl.b32 %r25, %r17, 0;
    setp.hs.u32 %p2, %r17, %r20;
    @%p2 min.s32 %r27, %r12, 256;
    shr.u32 %r7, %r26, 16;
    mul.wide.u32 %rd5, %r12, %r12;
    setp.lt.u32 %p4, %r7, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
