.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd12, %r3;
    sub.u32 %r27, %r3, 8;
    shr.u32 %r7, %r3, 1;
    shr.u32 %r10, %r7, 7;
    xor.b32 %r18, %r10, %r10;
    min.s64 %rd14, %rd12, %rd12;
    shl.b32 %r4, %r7, 31;
    xor.b32 %r16, %r27, %r18;
    shr.s32 %r7, %r7, 31;
    shl.b32 %r23, %r18, 3;
    setp.ne.u32 %p2, %r23, %r10;
    @%p2 or.b32 %r6, %r7, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
