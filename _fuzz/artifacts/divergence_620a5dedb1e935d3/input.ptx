.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd8, %r3, %r3;
    mad.lo.s32 %r4, %r3, %r3, %r3;
    max.u32 %r13, %r4, %r3;
    shr.s64 %rd7, %rd8, 7;
    setp.lt.s32 %p2, %r4, %r4;
    @%p2 xor.b32 %r24, %r13, 15;
    shl.b32 %r24, %r13, 1;
    and.b32 %r19, %r4, 2;
    sub.u32 %r15, %r3, 255;
    cvt.s32.s64 %r21, %rd7;
    setp.gt.s32 %p4, %r3, %r4;
    @!%p4 sub.u32 %r9, %r15, %r19;
    selp.b32 %r16, %r9, %r19, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
