.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r26, %r3, 4;
    max.s32 %r5, %r3, %r3;
    mad.lo.u32 %r16, %r26, %r26, %r26;
    max.u32 %r14, %r5, %r26;
    min.s32 %r6, %r5, 1;
    mul.wide.u32 %rd13, %r6, %r16;
    shl.b32 %r9, %r3, 7;
    shr.u32 %r18, %r16, 3;
    add.s32 %r25, %r5, %r16;
    add.s32 %r17, %r16, 16;
    shl.b64 %rd7, %rd13, 33;
    xor.b32 %r27, %r14, %r14;
    sub.s32 %r20, %r9, %r25;
    add.u32 %r24, %r6, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
