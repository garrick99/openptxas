.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r12, %r3, %r3;
    cvt.s64.s32 %rd10, %r3;
    mul.lo.s32 %r4, %r12, %r12;
    max.s32 %r5, %r12, 1;
    sub.s32 %r4, %r12, %r5;
    setp.ls.u32 %p2, %r4, 64;
    @!%p2 add.s32 %r7, %r4, 7;
    and.b32 %r26, %r12, %r3;
    mad.lo.s32 %r24, %r26, %r26, %r12;
    add.s32 %r4, %r26, %r24;
    shr.u32 %r17, %r26, 4;
    sub.u32 %r19, %r5, %r7;
    setp.eq.s32 %p4, %r24, 2147483647;
    shr.u64 %rd5, %rd10, 32;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r19;
