.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd5, %r3, %r3;
    mul.lo.u32 %r22, %r3, 5;
    setp.hs.u32 %p4, %r3, 8;
    @!%p4 selp.b32 %r15, %r3, %r3, %p4;
    cvt.s32.s64 %r7, %rd5;
    add.u32 %r4, %r3, 4;
    or.b32 %r19, %r22, 4294967295;
    mul.wide.s32 %rd15, %r19, %r15;
    selp.b32 %r14, %r4, %r22, %p4;
    shr.u64 %rd7, %rd15, 3;
    cvt.u64.u32 %rd15, %r7;
    or.b32 %r16, %r4, 16;
    or.b32 %r9, %r19, %r4;
    cvt.u64.u32 %rd11, %r4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
