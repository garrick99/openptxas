.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd7, %r3;
    min.u32 %r15, %r3, 7;
    mad.lo.u32 %r13, %r3, %r15, %r15;
    setp.gt.u32 %p1, %r13, %r13;
    @%p1 xor.b32 %r27, %r15, %r3;
    and.b32 %r14, %r15, %r27;
    setp.lt.u32 %p1, %r13, 7;
    @%p1 min.s32 %r12, %r13, %r15;
    shr.u64 %rd12, %rd7, 62;
    or.b32 %r20, %r27, 65535;
    add.s64 %rd9, %rd12, %rd7;
    max.s32 %r15, %r27, %r27;
    shl.b64 %rd13, %rd12, 63;
    mul.lo.u32 %r17, %r15, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
