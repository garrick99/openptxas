.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd11, %r3, %r3;
    mul.lo.s32 %r6, %r3, 65536;
    add.u32 %r22, %r6, %r3;
    setp.lt.s32 %p4, %r3, 63;
    @%p4 add.s32 %r21, %r3, %r3;
    mul.lo.u32 %r22, %r3, 16;
    cvt.s64.s32 %rd12, %r21;
    cvt.u32.u64 %r15, %rd11;
    xor.b32 %r15, %r6, %r21;
    max.s32 %r13, %r15, %r3;
    shl.b64 %rd7, %rd11, 30;
    or.b32 %r18, %r22, 65535;
    add.u32 %r24, %r22, 32;
    mul.lo.u32 %r6, %r24, %r15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
    ret;
}
