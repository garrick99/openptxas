.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.le.u32 %p3, %r3, %r3;
    add.s32 %r11, %r3, %r3;
    selp.b32 %r20, %r11, %r11, %p3;
    setp.hi.u32 %p3, %r3, 65535;
    min.u32 %r24, %r20, 0;
    sub.u32 %r5, %r24, %r20;
    add.u32 %r20, %r11, %r20;
    cvt.u64.u32 %rd9, %r11;
    add.u32 %r5, %r5, %r20;
    sub.s32 %r8, %r24, 64;
    setp.ge.s32 %p1, %r24, %r3;
    setp.eq.s32 %p4, %r3, %r24;
    @%p4 max.u32 %r19, %r8, %r8;
    shr.s32 %r23, %r24, 2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
