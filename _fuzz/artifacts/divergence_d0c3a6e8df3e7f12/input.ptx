.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    xor.b32 %r10, %r3, %r3;
    shl.b32 %r19, %r3, 2;
    max.s32 %r19, %r3, 15;
    xor.b32 %r15, %r10, %r19;
    sub.u32 %r15, %r10, %r10;
    min.u32 %r7, %r10, %r10;
    and.b32 %r26, %r7, %r15;
    mul.wide.s32 %rd7, %r15, %r19;
    shl.b32 %r22, %r10, 16;
    mul.wide.u32 %rd6, %r7, %r22;
    add.u32 %r14, %r7, %r7;
    shl.b64 %rd9, %rd7, 47;
    shl.b64 %rd5, %rd7, 33;
    mad.lo.s32 %r5, %r15, %r15, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
