.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.lo.u32 %r13, %r3, 2147483648;
    setp.ge.u32 %p1, %r13, %r13;
    cvt.s64.s32 %rd14, %r3;
    shl.b64 %rd10, %rd14, 63;
    shr.s32 %r4, %r13, 7;
    mul.wide.u32 %rd5, %r3, %r13;
    mul.lo.s32 %r18, %r3, %r4;
    shr.s64 %rd12, %rd14, 3;
    add.s32 %r17, %r18, %r18;
    cvt.u32.u64 %r19, %rd10;
    mad.lo.u32 %r27, %r3, %r17, %r17;
    shr.s32 %r6, %r17, 0;
    shr.u64 %rd7, %rd10, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r6;
