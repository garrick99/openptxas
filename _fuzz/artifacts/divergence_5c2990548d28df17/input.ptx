.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p1, %r3, 65536;
    @%p1 cvt.u64.u32 %rd13, %r3;
    shl.b64 %rd11, %rd13, 32;
    add.u32 %r14, %r3, 255;
    mul.wide.s32 %rd13, %r14, %r14;
    shl.b64 %rd11, %rd11, 32;
    sub.u32 %r25, %r14, 2147483648;
    sub.s64 %rd14, %rd11, %rd13;
    mul.lo.s64 %rd9, %rd14, %rd11;
    sub.u32 %r5, %r14, 8;
    setp.hi.u32 %p2, %r14, 1;
    @!%p2 mad.lo.u32 %r27, %r25, %r3, %r25;
    cvt.u64.u32 %rd13, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r27;
