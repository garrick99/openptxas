.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd11, %r3, %r3;
    sub.u64 %rd14, %rd11, %rd11;
    and.b32 %r4, %r3, %r3;
    mul.lo.u32 %r8, %r3, 65536;
    mad.lo.s32 %r10, %r8, %r8, %r8;
    shr.s32 %r19, %r3, 7;
    shr.s32 %r24, %r3, 15;
    setp.ge.s32 %p4, %r19, 255;
    setp.ls.u32 %p1, %r10, %r8;
    @%p1 mad.lo.u32 %r19, %r4, %r24, %r4;
    mad.lo.s32 %r20, %r4, %r19, %r10;
    add.s32 %r25, %r24, 4294967295;
    selp.b32 %r15, %r8, %r19, %p1;
    shl.b32 %r12, %r20, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
