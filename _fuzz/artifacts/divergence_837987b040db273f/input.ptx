.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.gt.s32 %p2, %r3, %r3;
    @%p2 cvt.u64.u32 %rd13, %r3;
    min.u32 %r15, %r3, %r3;
    shr.u32 %r18, %r15, 1;
    cvt.u32.u64 %r4, %rd13;
    max.u32 %r26, %r4, %r15;
    add.u32 %r27, %r3, %r4;
    mul.lo.u32 %r20, %r27, 15;
    add.s32 %r23, %r26, 16;
    add.u64 %rd5, %rd13, %rd13;
    min.s32 %r20, %r18, 0;
    mul.wide.u32 %rd9, %r4, %r27;
    mad.lo.u32 %r9, %r20, %r4, %r20;
    shr.s64 %rd14, %rd9, 4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
