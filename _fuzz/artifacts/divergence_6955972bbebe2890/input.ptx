.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r22, %r3, %r3;
    shr.s32 %r20, %r22, 31;
    mad.lo.u32 %r22, %r22, %r3, %r20;
    add.u32 %r10, %r22, 8;
    cvt.s64.s32 %rd7, %r3;
    and.b32 %r25, %r3, %r22;
    min.s32 %r12, %r22, %r10;
    max.s32 %r11, %r20, %r20;
    add.s32 %r27, %r3, %r11;
    mul.wide.s32 %rd14, %r10, %r20;
    shr.u32 %r10, %r10, 7;
    shr.s32 %r5, %r12, 15;
    mul.wide.u32 %rd7, %r20, %r22;
    shr.s32 %r4, %r25, 15;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
