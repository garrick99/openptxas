.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r14, %r3, 0;
    and.b32 %r19, %r3, %r14;
    cvt.s64.s32 %rd5, %r19;
    add.s64 %rd5, %rd5, %rd5;
    min.s32 %r26, %r14, %r3;
    mad.lo.u32 %r21, %r26, %r26, %r26;
    xor.b32 %r8, %r26, %r3;
    min.u32 %r6, %r14, %r19;
    add.u32 %r26, %r3, %r21;
    min.s32 %r23, %r19, 255;
    max.s32 %r9, %r14, %r26;
    setp.lt.u32 %p3, %r9, 15;
    @%p3 add.s32 %r24, %r3, %r8;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r24;
    ret;
}
