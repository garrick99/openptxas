.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r13, %r3, 30;
    add.s32 %r18, %r3, %r3;
    cvt.s64.s32 %rd6, %r3;
    cvt.s32.s64 %r9, %rd6;
    max.u32 %r10, %r3, 8;
    add.u32 %r11, %r13, %r9;
    add.u64 %rd13, %rd6, %rd6;
    mul.wide.s32 %rd13, %r18, %r18;
    or.b32 %r13, %r9, 63;
    shr.s32 %r10, %r13, 31;
    add.s32 %r12, %r18, 4294967295;
    setp.eq.s32 %p3, %r11, %r9;
    @%p3 sub.s64 %rd9, %rd6, %rd6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r12;
    ret;
}
