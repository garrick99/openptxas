.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    or.b32 %r13, %r3, 5;
    add.u32 %r13, %r13, 2147483648;
    cvt.u64.u32 %rd11, %r13;
    mul.wide.u32 %rd10, %r3, %r3;
    setp.ge.s32 %p1, %r3, 2;
    @%p1 min.u64 %rd9, %rd11, %rd10;
    xor.b32 %r8, %r3, 256;
    shr.s32 %r14, %r3, 4;
    mul.lo.u32 %r6, %r14, %r3;
    cvt.u64.u32 %rd9, %r8;
    shr.s64 %rd11, %rd11, 15;
    or.b32 %r27, %r8, %r3;
    mad.lo.s32 %r17, %r13, %r8, %r6;
    min.s32 %r20, %r17, %r6;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r20;
    ret;
}
