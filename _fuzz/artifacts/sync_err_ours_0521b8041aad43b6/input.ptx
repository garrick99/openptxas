.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r11, %r3, 16;
    cvt.s64.s32 %rd10, %r11;
    max.s64 %rd11, %rd10, %rd10;
    shr.u32 %r24, %r3, 31;
    xor.b32 %r6, %r3, %r24;
    mul.lo.u32 %r27, %r24, 16;
    setp.lt.s32 %p3, %r11, 15;
    cvt.s64.s32 %rd15, %r11;
    max.s64 %rd9, %rd10, %rd15;
    min.s32 %r11, %r24, %r6;
    sub.u32 %r5, %r3, 2147483648;
    add.u64 %rd7, %rd15, %rd15;
    shr.s32 %r15, %r11, 0;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r15;
