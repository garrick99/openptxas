.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.ls.u32 %p2, %r3, 65536;
    @%p2 selp.b32 %r26, %r3, %r3, %p2;
    mul.wide.u32 %rd8, %r3, %r26;
    xor.b32 %r15, %r3, %r26;
    and.b32 %r14, %r26, %r26;
    mad.lo.u32 %r12, %r15, %r3, %r3;
    shl.b32 %r14, %r15, 1;
    and.b32 %r14, %r14, 0;
    mad.lo.u32 %r9, %r3, %r12, %r12;
    mul.lo.u32 %r15, %r26, 8;
    min.u64 %rd7, %rd8, %rd8;
    mul.wide.u32 %rd14, %r12, %r15;
    and.b32 %r16, %r3, %r9;
    shl.b64 %rd15, %rd7, 7;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
