.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.eq.u32 %p3, %r3, %r3;
    @!%p3 mul.lo.u32 %r11, %r3, 7;
    min.u32 %r27, %r11, 3;
    cvt.s64.s32 %rd12, %r11;
    mul.lo.s32 %r9, %r11, %r11;
    setp.lt.s32 %p1, %r27, %r27;
    @%p1 shr.u64 %rd12, %rd12, 63;
    mul.lo.u32 %r9, %r11, 1;
    sub.u32 %r26, %r3, 7;
    or.b64 %rd5, %rd12, %rd12;
    setp.ne.s32 %p1, %r3, %r9;
    mul.wide.s32 %rd10, %r11, %r26;
    cvt.u32.u64 %r17, %rd5;
    and.b64 %rd14, %rd10, %rd12;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
