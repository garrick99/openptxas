.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.s32 %r17, %r3, 63;
    setp.gt.s32 %p4, %r3, %r3;
    setp.lt.u32 %p3, %r3, 0;
    setp.lt.u32 %p2, %r3, 65535;
    @%p2 add.u32 %r11, %r17, 256;
    selp.b32 %r8, %r11, %r11, %p4;
    and.b32 %r9, %r11, %r8;
    cvt.u64.u32 %rd11, %r11;
    sub.s32 %r6, %r8, 65535;
    shr.s32 %r27, %r11, 4;
    or.b32 %r9, %r8, %r9;
    shr.u64 %rd10, %rd11, 30;
    or.b32 %r21, %r8, %r27;
    mul.lo.u32 %r17, %r11, %r3;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r17;
    ret;
}
