.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r6, %r3, 3;
    cvt.u64.u32 %rd7, %r3;
    add.u32 %r8, %r6, %r3;
    shl.b32 %r21, %r6, 2;
    add.s32 %r22, %r21, %r3;
    max.u32 %r7, %r6, %r8;
    mad.lo.u32 %r18, %r3, %r6, %r3;
    shr.u32 %r19, %r7, 1;
    shr.s32 %r25, %r18, 1;
    mul.lo.u32 %r13, %r3, %r8;
    shl.b64 %rd10, %rd7, 4;
    setp.ge.u32 %p2, %r3, 8;
    @!%p2 add.u32 %r7, %r25, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
