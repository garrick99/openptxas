.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.u32 %r18, %r3, 15;
    mul.wide.u32 %rd5, %r18, %r3;
    sub.s32 %r21, %r3, %r18;
    mul.wide.s32 %rd7, %r18, %r21;
    cvt.u64.u32 %rd12, %r3;
    sub.u32 %r13, %r3, 65535;
    mul.wide.s32 %rd13, %r3, %r21;
    add.s64 %rd5, %rd5, %rd12;
    shl.b32 %r18, %r3, 30;
    and.b32 %r6, %r18, 2147483647;
    mul.lo.s32 %r25, %r3, 5;
    min.s64 %rd10, %rd12, %rd7;
    setp.eq.u32 %p2, %r21, %r6;
    @%p2 selp.b32 %r11, %r13, %r6, %p2;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
