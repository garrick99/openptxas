.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd9, %r3;
    cvt.s32.s64 %r23, %rd9;
    cvt.s64.s32 %rd15, %r3;
    shl.b64 %rd10, %rd15, 63;
    mul.lo.u64 %rd11, %rd15, %rd15;
    xor.b32 %r23, %r23, 5;
    min.u32 %r12, %r23, 2147483647;
    or.b32 %r10, %r23, 0;
    cvt.s32.s64 %r10, %rd10;
    and.b64 %rd9, %rd9, %rd15;
    mad.lo.u32 %r15, %r10, %r10, %r10;
    sub.s32 %r14, %r23, 63;
    max.s32 %r14, %r14, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
