.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    add.s32 %r6, %r3, 4294967295;
    shr.s32 %r23, %r6, 15;
    mul.lo.u32 %r8, %r6, %r6;
    mad.lo.s32 %r4, %r8, %r23, %r6;
    setp.ge.s32 %p2, %r23, 2;
    @%p2 max.s32 %r13, %r6, 7;
    shr.u32 %r10, %r23, 7;
    or.b32 %r27, %r4, %r3;
    max.s32 %r9, %r10, 1;
    or.b32 %r9, %r23, 255;
    or.b32 %r26, %r10, %r13;
    cvt.s64.s32 %rd15, %r9;
    add.s32 %r25, %r23, %r26;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
