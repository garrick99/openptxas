.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd11, %r3;
    shr.u32 %r23, %r3, 4;
    shr.u64 %rd10, %rd11, 32;
    shl.b64 %rd8, %rd10, 33;
    min.s32 %r15, %r3, 4294967295;
    shl.b32 %r9, %r3, 3;
    cvt.s64.s32 %rd15, %r23;
    setp.le.s32 %p2, %r9, %r3;
    @!%p2 add.s32 %r15, %r9, 4294967295;
    sub.u32 %r4, %r15, 5;
    setp.hs.u32 %p4, %r4, 7;
    @%p4 add.u32 %r13, %r23, %r9;
    shr.s32 %r4, %r15, 2;
    cvt.u64.u32 %rd15, %r9;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
