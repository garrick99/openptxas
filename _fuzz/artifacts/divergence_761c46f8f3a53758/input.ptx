.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.s64.s32 %rd13, %r3;
    mul.lo.u64 %rd11, %rd13, %rd13;
    mul.lo.u32 %r21, %r3, 65536;
    cvt.u64.u32 %rd15, %r21;
    or.b32 %r5, %r3, %r21;
    mad.lo.s32 %r11, %r21, %r5, %r3;
    mul.lo.u32 %r21, %r11, %r21;
    shr.u32 %r7, %r5, 15;
    mul.wide.s32 %rd8, %r5, %r5;
    cvt.s64.s32 %rd5, %r3;
    sub.u32 %r7, %r5, 32;
    mul.wide.u32 %rd7, %r3, %r7;
    min.u32 %r7, %r11, %r11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r7;
    ret;
}
