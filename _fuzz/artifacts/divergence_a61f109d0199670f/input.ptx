.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd14, %r3;
    setp.gt.u32 %p3, %r3, %r3;
    setp.ne.s32 %p4, %r3, 1;
    @%p4 mad.lo.s32 %r26, %r3, %r3, %r3;
    min.u32 %r7, %r26, %r26;
    min.s32 %r7, %r3, 255;
    add.u32 %r5, %r7, 2;
    shl.b32 %r9, %r5, 31;
    xor.b32 %r26, %r26, %r9;
    cvt.s32.s64 %r5, %rd14;
    add.s32 %r17, %r26, %r9;
    or.b32 %r21, %r3, %r17;
    min.u32 %r26, %r9, %r9;
    cvt.u64.u32 %rd6, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
