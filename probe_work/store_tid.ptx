.version 9.0
.target sm_120
.address_size 64

.visible .entry store_tid(
    .param .u64 out_ptr)
{
    .reg .b32   %r<2>;
    .reg .b64   %rd<4>;

    // out[tid.x] = tid.x (32-bit store, no branching)
    mov.u32         %r0, %tid.x;
    cvt.u64.u32     %rd0, %r0;
    shl.b64         %rd0, %rd0, 2;
    ld.param.u64    %rd1, [out_ptr];
    add.u64         %rd2, %rd1, %rd0;
    st.global.u32   [%rd2], %r0;
    ret;
}
