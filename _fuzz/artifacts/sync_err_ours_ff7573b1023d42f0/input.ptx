.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r6, %r3, 4294967295;
    mul.wide.u32 %rd11, %r6, %r3;
    mul.lo.u32 %r4, %r6, %r6;
    shr.s64 %rd12, %rd11, 33;
    shr.s32 %r26, %r4, 4;
    sub.u32 %r19, %r26, 65536;
    sub.s32 %r27, %r26, %r6;
    setp.lo.u32 %p3, %r4, 4;
    @%p3 add.u32 %r5, %r3, 7;
    sub.s32 %r19, %r19, 0;
    mul.lo.u32 %r10, %r4, 3;
    setp.gt.u32 %p4, %r6, %r26;
    @%p4 and.b32 %r27, %r6, 256;
    add.s32 %r11, %r5, %r19;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r11;
    ret;
}
