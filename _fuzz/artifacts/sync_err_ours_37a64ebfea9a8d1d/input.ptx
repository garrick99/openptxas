.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    setp.lt.s32 %p4, %r3, %r3;
    @%p4 cvt.s64.s32 %rd9, %r3;
    shr.s32 %r27, %r3, 2;
    shr.u64 %rd7, %rd9, 33;
    sub.u32 %r23, %r27, 64;
    shr.s32 %r18, %r23, 31;
    mul.lo.u32 %r5, %r27, %r18;
    shl.b32 %r24, %r3, 16;
    cvt.s64.s32 %rd14, %r23;
    shr.s32 %r20, %r27, 31;
    add.u64 %rd14, %rd7, %rd7;
    xor.b64 %rd11, %rd7, %rd9;
    setp.hi.u32 %p2, %r24, 8;
    selp.b32 %r5, %r24, %r18, %p4;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
