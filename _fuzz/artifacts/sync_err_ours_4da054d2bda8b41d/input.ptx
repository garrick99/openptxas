.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.u32 %rd13, %r3, %r3;
    and.b32 %r8, %r3, 3;
    mul.lo.s32 %r25, %r8, 64;
    mad.lo.s32 %r22, %r25, %r25, %r25;
    shr.s32 %r11, %r22, 2;
    xor.b64 %rd6, %rd13, %rd13;
    cvt.s32.s64 %r19, %rd6;
    shr.s32 %r22, %r11, 2;
    mul.wide.u32 %rd7, %r25, %r8;
    sub.s32 %r25, %r8, 2;
    shr.u32 %r8, %r11, 1;
    cvt.s32.s64 %r21, %rd6;
    shr.u64 %rd7, %rd13, 32;
    shl.b32 %r4, %r8, 16;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
