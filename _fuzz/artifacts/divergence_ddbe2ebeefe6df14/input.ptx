.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd10, %r3, %r3;
    shr.s32 %r21, %r3, 7;
    xor.b32 %r13, %r21, 4294967295;
    xor.b32 %r14, %r13, %r13;
    or.b64 %rd12, %rd10, %rd10;
    mad.lo.u32 %r23, %r3, %r21, %r3;
    shr.s32 %r18, %r21, 15;
    cvt.u64.u32 %rd9, %r14;
    setp.hi.u32 %p4, %r13, %r14;
    @%p4 and.b32 %r25, %r3, %r14;
    min.s32 %r16, %r25, %r25;
    mul.lo.u64 %rd10, %rd9, %rd9;
    setp.ne.u32 %p1, %r18, %r25;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r16;
    ret;
}
