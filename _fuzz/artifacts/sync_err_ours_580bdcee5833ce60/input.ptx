.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd10, %r3;
    mad.lo.s32 %r6, %r3, %r3, %r3;
    sub.s32 %r5, %r6, %r3;
    shr.s32 %r13, %r6, 31;
    setp.hi.u32 %p1, %r3, 8;
    @%p1 mul.lo.s32 %r4, %r13, 0;
    selp.b32 %r27, %r5, %r3, %p1;
    or.b32 %r7, %r13, %r3;
    mul.lo.u32 %r21, %r4, %r13;
    max.u32 %r8, %r5, %r4;
    xor.b32 %r12, %r5, %r13;
    mul.lo.s32 %r12, %r7, %r4;
    and.b64 %rd5, %rd10, %rd10;
    max.s32 %r9, %r3, %r5;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r9;
    ret;
}
