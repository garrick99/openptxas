.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mul.wide.s32 %rd11, %r3, %r3;
    min.s32 %r27, %r3, %r3;
    xor.b32 %r25, %r27, %r3;
    and.b64 %rd7, %rd11, %rd11;
    add.u32 %r18, %r27, %r25;
    mul.wide.s32 %rd6, %r3, %r27;
    mul.lo.u32 %r5, %r25, %r27;
    mul.lo.s64 %rd13, %rd11, %rd6;
    mul.lo.s32 %r4, %r3, %r5;
    xor.b32 %r12, %r5, %r25;
    shr.s32 %r23, %r4, 16;
    setp.le.s32 %p3, %r3, 5;
    @%p3 mul.wide.s32 %rd14, %r27, %r27;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r23;
    ret;
}
