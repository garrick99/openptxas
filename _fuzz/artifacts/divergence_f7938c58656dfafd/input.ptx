.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.u32 %r18, %r3, %r3;
    setp.ls.u32 %p4, %r3, 64;
    cvt.s64.s32 %rd13, %r18;
    shr.s32 %r10, %r18, 15;
    setp.le.s32 %p4, %r3, 8;
    @%p4 mul.wide.u32 %rd15, %r10, %r10;
    setp.gt.u32 %p1, %r10, 256;
    @%p1 sub.s32 %r13, %r10, %r18;
    setp.le.s32 %p2, %r13, 4;
    @%p2 mul.lo.s64 %rd11, %rd13, %rd13;
    cvt.s64.s32 %rd6, %r10;
    mad.lo.u32 %r15, %r13, %r3, %r3;
    mad.lo.u32 %r9, %r18, %r18, %r10;
    cvt.s32.s64 %r4, %rd11;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r4;
    ret;
}
