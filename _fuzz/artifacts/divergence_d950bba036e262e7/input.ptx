.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    shr.s32 %r27, %r3, 15;
    min.u32 %r12, %r3, %r27;
    and.b32 %r17, %r12, 2;
    shl.b32 %r6, %r3, 7;
    shr.s32 %r23, %r27, 2;
    min.u32 %r16, %r6, %r27;
    max.s32 %r22, %r17, 65536;
    cvt.s64.s32 %rd11, %r17;
    mul.lo.u32 %r25, %r22, 4;
    min.u32 %r21, %r17, %r27;
    sub.s32 %r22, %r12, %r16;
    setp.lt.s32 %p4, %r23, %r17;
    @!%p4 mul.lo.s32 %r5, %r25, %r23;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
