.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd6, %r3;
    cvt.u32.u64 %r26, %rd6;
    add.s32 %r7, %r26, 256;
    mul.wide.u32 %rd6, %r3, %r7;
    setp.gt.s32 %p2, %r7, %r7;
    @!%p2 add.u32 %r26, %r3, 31;
    max.u32 %r25, %r26, %r26;
    max.s32 %r14, %r3, 64;
    cvt.s32.s64 %r21, %rd6;
    shr.s32 %r24, %r3, 30;
    mul.lo.s32 %r13, %r26, 0;
    add.u32 %r17, %r25, 64;
    selp.b32 %r4, %r17, %r7, %p2;
    max.s32 %r25, %r13, %r24;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
