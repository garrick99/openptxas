.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r5, %r3, %r3;
    cvt.s64.s32 %rd13, %r3;
    sub.u32 %r19, %r5, %r3;
    shr.u32 %r11, %r3, 2;
    min.s32 %r21, %r19, %r5;
    min.s32 %r15, %r19, %r19;
    and.b32 %r27, %r21, %r5;
    min.u64 %rd14, %rd13, %rd13;
    min.u32 %r20, %r21, 2;
    or.b32 %r6, %r5, %r15;
    shl.b64 %rd7, %rd14, 3;
    xor.b32 %r10, %r27, 7;
    cvt.s64.s32 %rd14, %r21;
    sub.u64 %rd7, %rd7, %rd14;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r10;
    ret;
}
