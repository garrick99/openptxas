    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    cvt.u64.u32 %rd7, %r3;
    shr.s32 %r11, %r3, 30;
    setp.hi.u32 %p3, %r3, 64;
    sub.s32 %r8, %r11, 63;
    or.b32 %r14, %r8, 2147483647;
    mul.lo.u32 %r22, %r3, %r8;
    setp.eq.s32 %p3, %r14, 63;
    mul.wide.u32 %rd14, %r3, %r22;
    setp.le.s32 %p3, %r11, %r14;
    @!%p3 min.u32 %r21, %r14, 4294967295;
    mul.wide.s32 %rd10, %r21, %r14;
    shr.u64 %rd8, %rd10, 1;
    or.b32 %r26, %r8, 2;
    min.s32 %r17, %r22, 63;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
