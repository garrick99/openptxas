.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r22, %r3, %r3, %r3;
    shr.u32 %r18, %r22, 3;
    sub.u32 %r26, %r22, %r18;
    mul.lo.s32 %r11, %r18, 8;
    sub.s32 %r7, %r26, %r26;
    mad.lo.s32 %r13, %r11, %r26, %r7;
    setp.eq.s32 %p4, %r13, 255;
    shl.b32 %r8, %r11, 15;
    cvt.s64.s32 %rd5, %r18;
    mul.wide.u32 %rd10, %r26, %r7;
    xor.b32 %r21, %r8, %r26;
    mad.lo.s32 %r16, %r26, %r18, %r7;
    setp.lt.u32 %p4, %r16, 16;
    @!%p4 mul.lo.s32 %r25, %r3, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r25;
    ret;
}
