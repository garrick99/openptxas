.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    mad.lo.u32 %r11, %r3, %r3, %r3;
    cvt.u64.u32 %rd11, %r11;
    max.u32 %r4, %r3, %r3;
    add.u64 %rd12, %rd11, %rd11;
    add.s32 %r22, %r3, 4294967295;
    mul.wide.u32 %rd5, %r22, %r4;
    mul.wide.u32 %rd11, %r4, %r22;
    shr.s64 %rd10, %rd5, 63;
    mul.lo.s32 %r8, %r4, 2;
    setp.gt.s32 %p1, %r11, %r11;
    cvt.u32.u64 %r7, %rd12;
    xor.b32 %r14, %r11, %r22;
    shr.s64 %rd11, %rd5, 30;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r14;
    ret;
}
