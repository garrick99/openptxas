.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    min.u32 %r13, %r3, 3;
    shr.s32 %r19, %r13, 15;
    sub.u32 %r20, %r19, %r19;
    and.b32 %r24, %r13, 64;
    max.s32 %r15, %r3, 4294967295;
    min.u32 %r13, %r20, %r24;
    max.u32 %r11, %r20, %r24;
    sub.u32 %r19, %r15, 7;
    mad.lo.s32 %r20, %r24, %r3, %r13;
    mul.lo.u32 %r22, %r20, %r11;
    mul.wide.u32 %rd10, %r19, %r24;
    cvt.u64.u32 %rd10, %r3;
    cvt.s32.s64 %r5, %rd10;
    max.u64 %rd13, %rd10, %rd10;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r5;
    ret;
}
