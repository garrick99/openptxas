.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    sub.s32 %r18, %r3, %r3;
    cvt.u64.u32 %rd15, %r3;
    and.b32 %r26, %r3, %r18;
    setp.gt.s32 %p2, %r3, 64;
    @%p2 shl.b32 %r26, %r18, 15;
    mul.wide.u32 %rd8, %r18, %r26;
    sub.s32 %r16, %r3, %r18;
    cvt.s32.s64 %r27, %rd8;
    shr.u32 %r13, %r3, 1;
    cvt.s64.s32 %rd7, %r16;
    sub.u32 %r10, %r18, %r18;
    sub.s32 %r12, %r13, 65536;
    cvt.u64.u32 %rd7, %r26;
    and.b32 %r22, %r27, %r13;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r22;
    ret;
}
