.version 9.0
.target sm_120
.address_size 64

.visible .entry fuzz(.param .u64 p_in, .param .u64 p_out, .param .u32 n) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .pred %p<8>;
    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;
    ld.param.u64 %rd0, [p_in];
    cvt.u64.u32 %rd1, %r0;
    shl.b64 %rd1, %rd1, 2;
    add.u64 %rd2, %rd0, %rd1;
    ld.global.u32 %r3, [%rd2];
    max.s32 %r4, %r3, %r3;
    add.s32 %r14, %r4, 3;
    xor.b32 %r9, %r3, %r14;
    sub.s32 %r13, %r4, 31;
    sub.u32 %r17, %r13, 65536;
    max.u32 %r18, %r13, %r3;
    setp.hs.u32 %p4, %r13, %r9;
    @!%p4 min.u32 %r23, %r13, %r17;
    min.u32 %r20, %r4, %r4;
    min.s32 %r22, %r9, %r17;
    mul.lo.s32 %r26, %r14, %r20;
    setp.ge.s32 %p2, %r20, 4;
    cvt.s64.s32 %rd7, %r17;
    ld.param.u64 %rd3, [p_out];
    add.u64 %rd4, %rd3, %rd1;
    st.global.u32 [%rd4], %r26;
    ret;
}
